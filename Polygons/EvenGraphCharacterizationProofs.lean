            have hpy_shr : p.y = v.y + s_f*(p0.y - v.y) := by
              rw [← hp0_eq]; show (shrinkPoint v s_f p0).y = _; simp [shrinkPoint]; ring
            have h_eq_x : s_f*(p0.x - v.x) = s*(seg.p1.x - v.x) := by
              have h := hsx.symm.trans hpx_shr; linarith
            have h_eq_y : s_f*(p0.y - v.y) = s*(seg.p1.y - v.y) := by
              have h := hsy.symm.trans hpy_shr; linarith
            rw [mem_rayFrom]
            refine ⟨s / s_f, div_nonneg hs0 hs_f_pos.le, ?_, ?_⟩
