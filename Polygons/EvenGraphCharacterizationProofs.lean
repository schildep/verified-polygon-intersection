    -- Split h_polylines_combined into G and V_extra parts.
    have h_polylines : ∀ ps ∈ P.segments, ∀ w ∈ G.toVertices, ∀ t : ℚ,
        ¬ (w.x = (1-t)*ps.p1.x + t*ps.p2.x ∧ w.y = (1-t)*ps.p1.y + t*ps.p2.y) := by
      intro ps hps w hw
      apply h_polylines_combined ps hps w
      rw [hverts_to_avoid_def, List.mem_append]; exact Or.inl hw
    have h_polylines_vextra : ∀ ps ∈ P.segments, ∀ w ∈ V_extra, ∀ t : ℚ,
        ¬ (w.x = (1-t)*ps.p1.x + t*ps.p2.x ∧ w.y = (1-t)*ps.p1.y + t*ps.p2.y) := by
      intro ps hps w hw
      apply h_polylines_combined ps hps w
      rw [hverts_to_avoid_def, List.mem_append]
      right; exact Finset.mem_toList.mpr hw
    -- Apply polygon_walk_count_even_no_nondegen with extras.
    have h_sum_even : (P.segments.map fun ps => polysegCrossingsCount ps G).sum % 2 = 0 :=
      polygon_walk_count_even_no_nondegen P G I V_extra S_extra
        h_polylines h_polylines_vextra h_polyverts_off h_polyverts_off_sextra hI_property
    -- Now identify this sum with the degree of v.
    -- Step 1: rewrite sum as a swapped double sum over G.segments.
    have h_swap : (P.segments.map fun ps => polysegCrossingsCount ps G).sum =
        (G.segments.map fun seg =>
          P.segments.countP (fun ps => decide (ps.toSet ∩ seg.toSet).Nonempty)).sum := by
      unfold polysegCrossingsCount
      exact sum_countP_swap P.segments G.segments
        (fun ps seg => decide (ps.toSet ∩ seg.toSet).Nonempty)
    -- Helper: shrinkPoint is injective in its target argument when s_f ≠ 0.
    have h_shrink_inj : Function.Injective (shrinkPoint v s_f) := by
      intro a b h
      simp only [shrinkPoint] at h
      have hsf_ne : s_f ≠ 0 := ne_of_gt hs_f_pos
      have hx : a.x = b.x := by
        have hh := congrArg Vector2D.x h
        simp only at hh
        have h1 : s_f * a.x = s_f * b.x := by linarith
        exact mul_left_cancel₀ hsf_ne h1
      have hy : a.y = b.y := by
        have hh := congrArg Vector2D.y h
        simp only at hh
        have h1 : s_f * a.y = s_f * b.y := by linarith
        exact mul_left_cancel₀ hsf_ne h1
      exact Vector2D.ext hx hy
    -- Helper: P.segments.Nodup, since P0.segments.Nodup and shrinking is injective on segments.
    have h_P_segs_nodup : P.segments.Nodup := by
      rw [hP_def, polygonShrink_segments]
      apply List.Nodup.map _ h_P0_segs_nodup
      -- Map preserves Nodup if function is injective.
      intro a b h
      have h1 : shrinkPoint v s_f a.p1 = shrinkPoint v s_f b.p1 := by
        have := congrArg LineSegment.p1 h
        exact this
      have h2 : shrinkPoint v s_f a.p2 = shrinkPoint v s_f b.p2 := by
        have := congrArg LineSegment.p2 h
        exact this
      have hp1 : a.p1 = b.p1 := h_shrink_inj h1
      have hp2 : a.p2 = b.p2 := h_shrink_inj h2
      cases a; cases b; simp at hp1 hp2; subst hp1; subst hp2; rfl
    -- Step 2: For each seg ∈ G.segments, compute the count.
    have h_per_seg : ∀ seg ∈ G.segments,
        P.segments.countP (fun ps => decide (ps.toSet ∩ seg.toSet).Nonempty) =
          if seg.p1 = v ∨ seg.p2 = v then 1 else 0 := by
      intro seg hseg
      by_cases h_inc : seg.p1 = v ∨ seg.p2 = v
      · rw [if_pos h_inc]
        -- Get w = the "other endpoint" of seg.
        have h_segP1_ne_p2 : seg.p1 ≠ seg.p2 := G.segments_nondegenerate seg hseg
        -- Define w explicitly.
        by_cases h_p1v : seg.p1 = v
        · -- w = seg.p2
          have hw_ne : seg.p2 ≠ v := fun h => h_segP1_ne_p2 (by rw [h_p1v, h])
          have hw_in_inc : seg.p2 ∈ incidentOtherEndpoints G v := by
            rw [mem_incidentOtherEndpoints]
            refine ⟨seg, hseg, ?_⟩
            unfold otherEndpoint; rw [if_pos h_p1v]
          have h_seg_eq_v_w : ∀ q, q ∈ seg.toSet ↔ q ∈ (LineSegment.mk v seg.p2).toSet := by
            intro q
            constructor
            · intro hq
              obtain ⟨t, ht0, ht1, hqx, hqy⟩ := hq
              refine ⟨t, ht0, ht1, ?_, ?_⟩
              · simp; rw [hqx, h_p1v]
              · simp; rw [hqy, h_p1v]
            · intro hq
              obtain ⟨t, ht0, ht1, hqx, hqy⟩ := hq
              simp at hqx hqy
              refine ⟨t, ht0, ht1, ?_, ?_⟩
              · rw [hqx, h_p1v]
              · rw [hqy, h_p1v]
          have hseg_sub_ray : seg.toSet ⊆ (rayFrom v seg.p2 hw_ne).toSet := by
            intro q hq
            obtain ⟨t, ht0, ht1, hqx, hqy⟩ := hq
            rw [mem_rayFrom]
            refine ⟨t, ht0, ?_, ?_⟩
            · rw [hqx, h_p1v]; ring
            · rw [hqy, h_p1v]; ring
          -- Now use these.
          set w := seg.p2 with hw_def
          set r_w := rayFrom v w hw_ne with hr_w_def
          obtain ⟨ps0, hps0, hps0_int⟩ := h_P0_hit_G hw_ne hw_in_inc
          set ps_target : LineSegment :=
            ⟨shrinkPoint v s_f ps0.p1, shrinkPoint v s_f ps0.p2⟩ with hps_t_def
          have h_ps_target_in_P : ps_target ∈ P.segments := by
            rw [hP_def, polygonShrink_segments]
            exact List.mem_map_of_mem _ hps0
          -- (a) ps_target ∩ seg ≠ ∅.
          have h_target_int : (ps_target.toSet ∩ seg.toSet).Nonempty := by
            have h_line_avoid_v_ps0 := h_v_off_P0_lines ps0 hps0
            have h_iff := rayFromV_intersects_shrunken_iff v w hw_ne ps0 s_f hs_f_pos h_line_avoid_v_ps0
            have h_r_w_int_target : rayIntersectsSegment r_w ps_target := h_iff.mp hps0_int
            obtain ⟨q, hq_ray, hq_target⟩ := h_r_w_int_target
            have h_q_dist_lt : (q.x - v.x)^2 + (q.y - v.y)^2 < r^2 / 4 := by
              have h_q_dist_le := h_seg_bound ps_target h_ps_target_in_P q hq_target
              nlinarith
            have h_w_dist_ge : r^2 ≤ (w.x - v.x)^2 + (w.y - v.y)^2 := by
              have h_endcase : w = seg.p1 ∨ w = seg.p2 := Or.inr rfl
              have hseg_ext : seg ∈ G_ext.segments := by
                rw [hG_ext_segs, List.mem_append]; exact Or.inl hseg
              exact hr_end seg hseg_ext w h_endcase hw_ne
            rw [mem_rayFrom] at hq_ray
            obtain ⟨t, ht0, hqx_ray, hqy_ray⟩ := hq_ray
            have h_qx_minus : q.x - v.x = t * (w.x - v.x) := by linarith
            have h_qy_minus : q.y - v.y = t * (w.y - v.y) := by linarith
            have h_dist_sq_eq : (q.x - v.x)^2 + (q.y - v.y)^2 =
                t^2 * ((w.x - v.x)^2 + (w.y - v.y)^2) := by
              rw [h_qx_minus, h_qy_minus]; ring
            have h_w_v_sq_pos : 0 < (w.x - v.x)^2 + (w.y - v.y)^2 := by
              have : 0 < r^2 := by positivity
              linarith
            have h_t_sq_lt : t^2 < 1 := by
              have h_lt : t^2 * ((w.x - v.x)^2 + (w.y - v.y)^2) < r^2 / 4 := by
                rw [← h_dist_sq_eq]; exact h_q_dist_lt
              -- r^2 / 4 < r^2 ≤ |w-v|^2.
              have h_r2_pos : 0 < r^2 := by positivity
              have h_lt2 : t^2 * ((w.x - v.x)^2 + (w.y - v.y)^2) < ((w.x - v.x)^2 + (w.y - v.y)^2) := by
                have : r^2 / 4 < r^2 := by linarith
                have : r^2 / 4 < (w.x - v.x)^2 + (w.y - v.y)^2 := by linarith
                linarith
              -- Divide both sides by |w-v|^2 > 0.
              have := h_lt2
              nlinarith [h_w_v_sq_pos]
            have h_t_lt_one : t ≤ 1 := by
              by_contra h
              push_neg at h
              have : 1 ≤ t^2 := by nlinarith
              linarith
            refine ⟨q, hq_target, ?_⟩
            rw [h_seg_eq_v_w]
            refine ⟨t, ht0, h_t_lt_one, ?_, ?_⟩
            · simp; linarith
            · simp; linarith
          -- (b) Every P-segment intersecting seg is ps_target.
          have h_unique : ∀ ps' ∈ P.segments, (ps'.toSet ∩ seg.toSet).Nonempty → ps' = ps_target := by
            intro ps' hps' h_int'
            rw [hP_def, polygonShrink_segments] at hps'
            rw [List.mem_map] at hps'
            obtain ⟨ps0', hps0', hps0'_eq⟩ := hps'
            have h_int'_target : rayIntersectsSegment r_w
                (LineSegment.mk (shrinkPoint v s_f ps0'.p1) (shrinkPoint v s_f ps0'.p2)) := by
              obtain ⟨q, hq_ps', hq_seg⟩ := h_int'
              have hq_ray : q ∈ r_w.toSet := hseg_sub_ray hq_seg
              rw [← hps0'_eq] at hq_ps'
              exact ⟨q, hq_ray, hq_ps'⟩
            have h_line_avoid_v_ps0' := h_v_off_P0_lines ps0' hps0'
            have h_iff' := rayFromV_intersects_shrunken_iff v w hw_ne ps0' s_f hs_f_pos h_line_avoid_v_ps0'
            have h_r_w_int_ps0' : rayIntersectsSegment r_w ps0' := h_iff'.mpr h_int'_target
            have h_ps0_eq : ps0 = ps0' :=
              h_P0_unique_ray_G hw_ne hw_in_inc ps0 hps0 ps0' hps0' hps0_int h_r_w_int_ps0'
            rw [← hps0'_eq, ← h_ps0_eq]
          -- countP via filter and Nodup.
          have h_filter_eq : P.segments.filter (fun ps => decide (ps.toSet ∩ seg.toSet).Nonempty)
              = [ps_target] := by
            -- Filter contains ps_target (by h_target_int) and only ps_target (by h_unique).
            -- And P.segments.Nodup ⟹ filter is Nodup ⟹ exactly one occurrence.
            have h_target_dec : decide (ps_target.toSet ∩ seg.toSet).Nonempty = true := by
              simp [h_target_int]
            -- Filter is Nodup with all elements = ps_target. So filter = [] or [ps_target].
            -- Filter is non-empty since ps_target is in it.
            have h_filter_nodup : (P.segments.filter
                (fun ps => decide (ps.toSet ∩ seg.toSet).Nonempty)).Nodup := h_P_segs_nodup.filter _
            have h_target_in_filter : ps_target ∈ P.segments.filter
                (fun ps => decide (ps.toSet ∩ seg.toSet).Nonempty) := by
              rw [List.mem_filter]
              exact ⟨h_ps_target_in_P, h_target_dec⟩
            have h_all_eq_target : ∀ ps ∈ P.segments.filter
                (fun ps => decide (ps.toSet ∩ seg.toSet).Nonempty), ps = ps_target := by
              intro ps hps
              rw [List.mem_filter] at hps
              obtain ⟨hps_in_P, h_dec⟩ := hps
              simp at h_dec
              exact h_unique ps hps_in_P h_dec
            -- A Nodup list whose every element equals ps_target and that contains ps_target = [ps_target].
            -- Use List.eq_singleton_of_unique or manually.
            cases h_lst : P.segments.filter (fun ps => decide (ps.toSet ∩ seg.toSet).Nonempty) with
            | nil =>
              rw [h_lst] at h_target_in_filter; simp at h_target_in_filter
            | cons hd tl =>
              have h_hd_eq : hd = ps_target := h_all_eq_target hd (by rw [h_lst]; simp)
              have h_tl_empty : tl = [] := by
                cases tl with
                | nil => rfl
                | cons hd2 tl2 =>
                  exfalso
                  have h_hd2_eq : hd2 = ps_target := h_all_eq_target hd2 (by rw [h_lst]; simp)
                  rw [h_lst] at h_filter_nodup
                  simp at h_filter_nodup
                  have h_ne := h_filter_nodup.1.1
                  rw [h_hd_eq, h_hd2_eq] at h_ne
                  exact h_ne rfl
              rw [h_hd_eq, h_tl_empty]
          rw [List.countP_eq_length_filter, h_filter_eq]
          rfl
        · -- seg.p2 = v (from h_inc).
          have h_p2v : seg.p2 = v := h_inc.resolve_left h_p1v
          have hw_ne : seg.p1 ≠ v := h_p1v
          have hw_in_inc : seg.p1 ∈ incidentOtherEndpoints G v := by
            rw [mem_incidentOtherEndpoints]
            refine ⟨seg, hseg, ?_⟩
            unfold otherEndpoint; rw [if_neg h_p1v, if_pos h_p2v]
          have h_seg_eq_v_w : ∀ q, q ∈ seg.toSet ↔ q ∈ (LineSegment.mk v seg.p1).toSet := by
            intro q
            constructor
            · intro hq
              obtain ⟨t, ht0, ht1, hqx, hqy⟩ := hq
              refine ⟨1 - t, by linarith, by linarith, ?_, ?_⟩
              · simp; rw [hqx, h_p2v]; ring
              · simp; rw [hqy, h_p2v]; ring
            · intro hq
              obtain ⟨t, ht0, ht1, hqx, hqy⟩ := hq
              simp at hqx hqy
              refine ⟨1 - t, by linarith, by linarith, ?_, ?_⟩
              · rw [hqx, h_p2v]; ring
              · rw [hqy, h_p2v]; ring
          have hseg_sub_ray : seg.toSet ⊆ (rayFrom v seg.p1 hw_ne).toSet := by
            intro q hq
            obtain ⟨t, ht0, ht1, hqx, hqy⟩ := hq
            rw [mem_rayFrom]
            refine ⟨1 - t, by linarith, ?_, ?_⟩
            · rw [hqx, h_p2v]; ring
            · rw [hqy, h_p2v]; ring
          set w := seg.p1 with hw_def
          set r_w := rayFrom v w hw_ne with hr_w_def
          obtain ⟨ps0, hps0, hps0_int⟩ := h_P0_hit_G hw_ne hw_in_inc
          set ps_target : LineSegment :=
            ⟨shrinkPoint v s_f ps0.p1, shrinkPoint v s_f ps0.p2⟩ with hps_t_def
          have h_ps_target_in_P : ps_target ∈ P.segments := by
            rw [hP_def, polygonShrink_segments]
            exact List.mem_map_of_mem _ hps0
          have h_target_int : (ps_target.toSet ∩ seg.toSet).Nonempty := by
            have h_line_avoid_v_ps0 := h_v_off_P0_lines ps0 hps0
            have h_iff := rayFromV_intersects_shrunken_iff v w hw_ne ps0 s_f hs_f_pos h_line_avoid_v_ps0
            have h_r_w_int_target : rayIntersectsSegment r_w ps_target := h_iff.mp hps0_int
            obtain ⟨q, hq_ray, hq_target⟩ := h_r_w_int_target
            have h_q_dist_lt : (q.x - v.x)^2 + (q.y - v.y)^2 < r^2 / 4 := by
              have h_q_dist_le := h_seg_bound ps_target h_ps_target_in_P q hq_target
              nlinarith
            have h_w_dist_ge : r^2 ≤ (w.x - v.x)^2 + (w.y - v.y)^2 := by
              have h_endcase : w = seg.p1 ∨ w = seg.p2 := Or.inl rfl
              have hseg_ext : seg ∈ G_ext.segments := by
                rw [hG_ext_segs, List.mem_append]; exact Or.inl hseg
              exact hr_end seg hseg_ext w h_endcase hw_ne
            rw [mem_rayFrom] at hq_ray
            obtain ⟨t, ht0, hqx_ray, hqy_ray⟩ := hq_ray
            have h_qx_minus : q.x - v.x = t * (w.x - v.x) := by linarith
            have h_qy_minus : q.y - v.y = t * (w.y - v.y) := by linarith
            have h_dist_sq_eq : (q.x - v.x)^2 + (q.y - v.y)^2 =
                t^2 * ((w.x - v.x)^2 + (w.y - v.y)^2) := by
              rw [h_qx_minus, h_qy_minus]; ring
            have h_w_v_sq_pos : 0 < (w.x - v.x)^2 + (w.y - v.y)^2 := by
              have : 0 < r^2 := by positivity
              linarith
            have h_t_sq_lt : t^2 < 1 := by
              have h_lt : t^2 * ((w.x - v.x)^2 + (w.y - v.y)^2) < r^2 / 4 := by
                rw [← h_dist_sq_eq]; exact h_q_dist_lt
              have h_r2_pos : 0 < r^2 := by positivity
              have h_lt2 : t^2 * ((w.x - v.x)^2 + (w.y - v.y)^2) < ((w.x - v.x)^2 + (w.y - v.y)^2) := by
                have h1 : r^2 / 4 < r^2 := by linarith
                have h2 : r^2 / 4 < (w.x - v.x)^2 + (w.y - v.y)^2 := by linarith
                linarith
              nlinarith [h_w_v_sq_pos]
            have h_t_lt_one : t ≤ 1 := by
              by_contra h
              push_neg at h
              have : 1 ≤ t^2 := by nlinarith
              linarith
            refine ⟨q, hq_target, ?_⟩
            rw [h_seg_eq_v_w]
            refine ⟨t, ht0, h_t_lt_one, ?_, ?_⟩
            · simp; linarith
            · simp; linarith
          have h_unique : ∀ ps' ∈ P.segments, (ps'.toSet ∩ seg.toSet).Nonempty → ps' = ps_target := by
            intro ps' hps' h_int'
            rw [hP_def, polygonShrink_segments] at hps'
            rw [List.mem_map] at hps'
            obtain ⟨ps0', hps0', hps0'_eq⟩ := hps'
            have h_int'_target : rayIntersectsSegment r_w
                (LineSegment.mk (shrinkPoint v s_f ps0'.p1) (shrinkPoint v s_f ps0'.p2)) := by
              obtain ⟨q, hq_ps', hq_seg⟩ := h_int'
              have hq_ray : q ∈ r_w.toSet := hseg_sub_ray hq_seg
              rw [← hps0'_eq] at hq_ps'
              exact ⟨q, hq_ray, hq_ps'⟩
            have h_line_avoid_v_ps0' := h_v_off_P0_lines ps0' hps0'
            have h_iff' := rayFromV_intersects_shrunken_iff v w hw_ne ps0' s_f hs_f_pos h_line_avoid_v_ps0'
            have h_r_w_int_ps0' : rayIntersectsSegment r_w ps0' := h_iff'.mpr h_int'_target
            have h_ps0_eq : ps0 = ps0' :=
              h_P0_unique_ray_G hw_ne hw_in_inc ps0 hps0 ps0' hps0' hps0_int h_r_w_int_ps0'
            rw [← hps0'_eq, ← h_ps0_eq]
          have h_filter_eq : P.segments.filter (fun ps => decide (ps.toSet ∩ seg.toSet).Nonempty)
              = [ps_target] := by
            have h_target_dec : decide (ps_target.toSet ∩ seg.toSet).Nonempty = true := by
              simp [h_target_int]
            have h_filter_nodup : (P.segments.filter
                (fun ps => decide (ps.toSet ∩ seg.toSet).Nonempty)).Nodup := h_P_segs_nodup.filter _
            have h_target_in_filter : ps_target ∈ P.segments.filter
                (fun ps => decide (ps.toSet ∩ seg.toSet).Nonempty) := by
              rw [List.mem_filter]
              exact ⟨h_ps_target_in_P, h_target_dec⟩
            have h_all_eq_target : ∀ ps ∈ P.segments.filter
                (fun ps => decide (ps.toSet ∩ seg.toSet).Nonempty), ps = ps_target := by
              intro ps hps
              rw [List.mem_filter] at hps
              obtain ⟨hps_in_P, h_dec⟩ := hps
              simp at h_dec
              exact h_unique ps hps_in_P h_dec
            cases h_lst : P.segments.filter (fun ps => decide (ps.toSet ∩ seg.toSet).Nonempty) with
            | nil =>
              rw [h_lst] at h_target_in_filter; simp at h_target_in_filter
            | cons hd tl =>
              have h_hd_eq : hd = ps_target := h_all_eq_target hd (by rw [h_lst]; simp)
              have h_tl_empty : tl = [] := by
                cases tl with
                | nil => rfl
                | cons hd2 tl2 =>
                  exfalso
                  have h_hd2_eq : hd2 = ps_target := h_all_eq_target hd2 (by rw [h_lst]; simp)
                  rw [h_lst] at h_filter_nodup
                  simp at h_filter_nodup
                  have h_ne := h_filter_nodup.1.1
                  rw [h_hd_eq, h_hd2_eq] at h_ne
                  exact h_ne rfl
              rw [h_hd_eq, h_tl_empty]
          rw [List.countP_eq_length_filter, h_filter_eq]
          rfl
      · rw [if_neg h_inc]
        -- Non-incident: count = 0.
        push_neg at h_inc
        rw [List.countP_eq_zero]
        intro ps hps
        simp only [decide_eq_true_eq]
        intro h_int
        -- ps is a P-segment, every point ≤ s_f^2 * M < r² from v.
        -- seg has every point ≥ r² from v (non-incident).
        obtain ⟨q, hq_ps, hq_seg⟩ := h_int
        have h_q_dist_lt : (q.x - v.x)^2 + (q.y - v.y)^2 < r^2 := by
          have h_le := h_seg_bound ps hps q hq_ps
          linarith
        have hseg_ext : seg ∈ G_ext.segments := by
          rw [hG_ext_segs, List.mem_append]; exact Or.inl hseg
        have h_q_dist_ge : r^2 ≤ (q.x - v.x)^2 + (q.y - v.y)^2 :=
          hr_seg seg hseg_ext h_inc.1 h_inc.2 q hq_seg
        linarith
    -- Now combine: sum = countP. Use h_per_seg.
    have h_swap_eq_count : (G.segments.map fun seg =>
          P.segments.countP (fun ps => decide (ps.toSet ∩ seg.toSet).Nonempty)).sum =
        G.segments.countP (fun seg => seg.p1 = v ∨ seg.p2 = v) := by
      -- Replace each summand using h_per_seg.
      have h_map_eq : G.segments.map (fun seg =>
            P.segments.countP (fun ps => decide (ps.toSet ∩ seg.toSet).Nonempty)) =
          G.segments.map (fun seg => if seg.p1 = v ∨ seg.p2 = v then (1:ℕ) else 0) := by
        apply List.map_congr_left
        intro seg hseg
        exact h_per_seg seg hseg
      rw [h_map_eq]
      -- Sum of indicators = countP.
      induction G.segments with
      | nil => simp
      | cons s ss ih =>
        simp only [List.map_cons, List.sum_cons, List.countP_cons]
        rw [ih]
        by_cases h : s.p1 = v ∨ s.p2 = v
        · simp [h]; omega
        · simp [h]
    -- Combine.
    rw [h_swap] at h_sum_even
    rw [h_swap_eq_count] at h_sum_even
    -- h_sum_even : (countP) % 2 = 0. Goal: Even (countP).
    rw [Nat.even_iff]
    exact h_sum_even
  · -- Case: v ∉ G.toVertices. Count is 0.
    -- For each seg, neither p1 nor p2 equals v (else v would be a vertex).
    have h_count_zero : G.segments.countP (fun seg => seg.p1 = v ∨ seg.p2 = v) = 0 := by
      rw [List.countP_eq_zero]
      intro seg hseg
      simp only [decide_eq_true_eq]
      push_neg
      refine ⟨?_, ?_⟩
      · intro h_eq
        apply h_v_in
        simp only [Graph.toVertices, List.mem_dedup, List.mem_flatMap, List.mem_cons,
          (List.not_mem_nil _), or_false]
        exact ⟨seg, hseg, Or.inl h_eq.symm⟩
      · intro h_eq
        apply h_v_in
        simp only [Graph.toVertices, List.mem_dedup, List.mem_flatMap, List.mem_cons,
          (List.not_mem_nil _), or_false]
        exact ⟨seg, hseg, Or.inr h_eq.symm⟩
    rw [h_count_zero]
    exact ⟨0, rfl⟩

end EvenGraphCharacterizationProofs

end
