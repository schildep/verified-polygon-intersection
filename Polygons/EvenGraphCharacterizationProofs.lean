/-- For a point `p` on segment `(a, b)`, the squared distance from `p` to
`v` is bounded by the maximum of squared distances from `a` and `b` to `v`. -/
private theorem segment_dist_sq_le_max (v a b p : Vector2D) (M : ℚ)
    (hMa : (a.x - v.x)^2 + (a.y - v.y)^2 ≤ M)
    (hMb : (b.x - v.x)^2 + (b.y - v.y)^2 ≤ M)
    (hp : p ∈ (LineSegment.mk a b).toSet) :
    (p.x - v.x)^2 + (p.y - v.y)^2 ≤ M := by
  obtain ⟨t, ht0, ht1, hpx, hpy⟩ := hp
  set ax := a.x - v.x with hax_def
  set ay := a.y - v.y with hay_def
  set bx := b.x - v.x with hbx_def
  set by_ := b.y - v.y with hby_def
  have h_p_minus_v_sq :
      (p.x - v.x)^2 + (p.y - v.y)^2 =
        (1-t)^2 * (ax^2 + ay^2) + 2 * (1-t) * t * (ax*bx + ay*by_) + t^2 * (bx^2 + by_^2) := by
    rw [hpx, hpy]
    simp only [hax_def, hay_def, hbx_def, hby_def] at *
    show ((1 - t) * a.x + t * b.x - v.x)^2 + ((1 - t) * a.y + t * b.y - v.y)^2 = _
    ring
  rw [h_p_minus_v_sq]
  have h_CS : 2 * (ax*bx + ay*by_) ≤ (ax^2 + ay^2) + (bx^2 + by_^2) := by
    nlinarith [sq_nonneg (ax - bx), sq_nonneg (ay - by_)]
  have h_1mt_nn : 0 ≤ 1 - t := by linarith
  have h_t_nn : 0 ≤ t := ht0
  have h_1mt_t : 0 ≤ (1 - t) * t := mul_nonneg h_1mt_nn h_t_nn
  have h_step1 : (1-t)^2 * (ax^2 + ay^2) + 2 * (1-t) * t * (ax*bx + ay*by_) + t^2 * (bx^2 + by_^2) ≤
      (1-t)^2 * (ax^2 + ay^2) + (1-t) * t * ((ax^2 + ay^2) + (bx^2 + by_^2)) + t^2 * (bx^2 + by_^2) := by
    have h2 : 2 * (1-t) * t * (ax*bx + ay*by_) = (1-t) * t * (2 * (ax*bx + ay*by_)) := by ring
    have h_mul : (1-t) * t * (2 * (ax*bx + ay*by_)) ≤ (1-t) * t * ((ax^2 + ay^2) + (bx^2 + by_^2)) :=
      mul_le_mul_of_nonneg_left h_CS h_1mt_t
    linarith
  have h_simplify : (1-t)^2 * (ax^2 + ay^2) + (1-t) * t * ((ax^2 + ay^2) + (bx^2 + by_^2)) + t^2 * (bx^2 + by_^2) =
      (1-t) * (ax^2 + ay^2) + t * (bx^2 + by_^2) := by ring
  rw [h_simplify] at h_step1
  have h_step2 : (1 - t) * (ax^2 + ay^2) + t * (bx^2 + by_^2) ≤ M := by
    have hh : (1 - t) * (ax^2 + ay^2) + t * (bx^2 + by_^2) ≤ (1 - t) * M + t * M := by
      apply add_le_add
      · exact mul_le_mul_of_nonneg_left hMa h_1mt_nn
      · exact mul_le_mul_of_nonneg_left hMb h_t_nn
    have : (1 - t) * M + t * M = M := by ring
    linarith
  linarith

/-- The maximum squared distance from `v` to a vertex in a list of points. -/
private noncomputable def listMaxSqDist (v : Vector2D) (l : List Vector2D) : ℚ :=
  (l.map (fun p => (p.x - v.x)^2 + (p.y - v.y)^2)).foldr max 0

private lemma listMaxSqDist_ge_zero (v : Vector2D) (l : List Vector2D) :
    0 ≤ listMaxSqDist v l := by
  unfold listMaxSqDist
  induction l with
  | nil => simp
  | cons p ps ih =>
    simp only [List.map_cons, List.foldr_cons]
    exact le_max_of_le_right ih

private lemma listMaxSqDist_ge (v : Vector2D) (l : List Vector2D) (p : Vector2D) (hp : p ∈ l) :
    (p.x - v.x)^2 + (p.y - v.y)^2 ≤ listMaxSqDist v l := by
  unfold listMaxSqDist
  induction l with
  | nil => simp at hp
  | cons q qs ih =>
    simp only [List.map_cons, List.foldr_cons]
    rcases List.mem_cons.mp hp with rfl | hp_rest
    · exact le_max_left _ _
    · exact le_max_of_le_right (ih hp_rest)

/-- Candidate bad shrink factor for a (P0-segment, vertex) pair: the unique
`s ∈ ℚ` (if denominator ≠ 0) such that the line through the shrunken
`ps0` (with shrink center `v`) passes through `w`. -/
private noncomputable def candidateBadS (v : Vector2D) (ps0 : LineSegment) (w : Vector2D) : ℚ :=
  let q1x := ps0.p1.x - v.x
  let q1y := ps0.p1.y - v.y
  let q2x := ps0.p2.x - v.x
  let q2y := ps0.p2.y - v.y
  let wx := w.x - v.x
  let wy := w.y - v.y
  let denom := q1x * q2y - q1y * q2x
  if denom = 0 then 0
  else (wx * (q2y - q1y) - wy * (q2x - q1x)) / denom

/-- The Finset of bad shrink factors (those `s` where some shrunken segment
line might hit some vertex in the given list). -/
private noncomputable def badShrinkFinset
    (P0 : Polygon) (verts : List Vector2D) (v : Vector2D) : Finset ℚ :=
  -- 0 is always added (we need s ≠ 0).
  insert 0
    ((P0.segments.product verts).map (fun p => candidateBadS v p.1 p.2)).toFinset

/-- If `s` is a non-zero shrink factor at which some shrunken P0-segment line
passes through some vertex `w` in the given list, then `s` is in the bad finset.
The specific `ps0` must be nondegenerate; we only need this for that segment. -/
private theorem mem_badShrinkFinset_of_line_through
    (P0 : Polygon) (verts : List Vector2D) (v : Vector2D)
    (h_v_off_lines : ∀ ps0 ∈ P0.segments, ∀ t : ℚ,
      ¬ (v.x = (1-t)*ps0.p1.x + t*ps0.p2.x ∧ v.y = (1-t)*ps0.p1.y + t*ps0.p2.y))
    {s : ℚ} {ps0 : LineSegment} {w : Vector2D} {t : ℚ}
    (h_nondeg : ps0.p1 ≠ ps0.p2)
    (hps0 : ps0 ∈ P0.segments) (hw : w ∈ verts)
    (hwx : w.x = (1-t)*(shrinkPoint v s ps0.p1).x + t*(shrinkPoint v s ps0.p2).x)
    (hwy : w.y = (1-t)*(shrinkPoint v s ps0.p1).y + t*(shrinkPoint v s ps0.p2).y) :
    s ∈ badShrinkFinset P0 verts v := by
  unfold badShrinkFinset
  by_cases hs0 : s = 0
  · rw [hs0]; exact Finset.mem_insert_self _ _
  · -- Show s = candidateBadS v ps0 w.
    apply Finset.mem_insert.mpr
    right
    rw [List.mem_toFinset, List.mem_map]
    refine ⟨(ps0, w), ?_, ?_⟩
    · exact List.mem_product.mpr ⟨hps0, hw⟩
    · -- Show: candidateBadS v ps0 w = s.
      unfold candidateBadS
      simp only
      set q1x := ps0.p1.x - v.x with hq1x
      set q1y := ps0.p1.y - v.y with hq1y
      set q2x := ps0.p2.x - v.x with hq2x
      set q2y := ps0.p2.y - v.y with hq2y
      set wx := w.x - v.x with hwx_def
      set wy := w.y - v.y with hwy_def
      set denom := q1x * q2y - q1y * q2x with hdenom_def
      -- Expand hwx and hwy: w.x - v.x = s*(q1x + t*(q2x - q1x))
      have h_eq1 : wx = s * (q1x + t * (q2x - q1x)) := by
        simp only [shrinkPoint] at hwx
        simp only [hwx_def, hq1x, hq2x]
        linarith
      have h_eq2 : wy = s * (q1y + t * (q2y - q1y)) := by
        simp only [shrinkPoint] at hwy
        simp only [hwy_def, hq1y, hq2y]
        linarith
      -- Show denom ≠ 0: if denom = 0, then q1x*q2y = q1y*q2x, meaning
      -- (q1x, q1y) parallel to (q2x, q2y), so v on line(ps0). Contradicts h_v_off_lines.
      have h_denom_ne : denom ≠ 0 := by
        intro h_denom_zero
        -- Find t' such that v on line(ps0): need (1-t')*ps0.p1.x + t'*ps0.p2.x = v.x.
        -- I.e., (1-t')*q1x + t'*q2x = 0, similarly for y.
        -- From q1x*q2y = q1y*q2x, the vectors (q1x, q1y) and (q2x, q2y) are parallel.
        -- Case 1: q1 = 0 = (0, 0). Then ps0.p1 = v. So set t' = 0.
        -- Case 2: q2 = 0 = (0, 0). Then ps0.p2 = v. So set t' = 1.
        -- Case 3: both nonzero. Then q2 = λ*q1 for some λ. We need
        --   (1-t')*q1x + t'*q2x = 0, i.e., (1-t' + t'*λ)*q1x = 0. So 1-t'+t'*λ = 0
        --   (assuming q1x ≠ 0), so t' = 1/(1-λ) — when λ ≠ 1. But if λ = 1 then q1 = q2,
        --   meaning p1 = p2 (degenerate); not the case here, but anyway this'd require
        --   q1 = q2 = 0 too, contradiction.
        -- This is getting complex. Let me handle all cases.
        by_cases hq1_zero : q1x = 0 ∧ q1y = 0
        · -- ps0.p1 = v.
          obtain ⟨hq1xz, hq1yz⟩ := hq1_zero
          apply h_v_off_lines ps0 hps0 0
          refine ⟨?_, ?_⟩
          · show v.x = (1 - 0) * ps0.p1.x + 0 * ps0.p2.x
            have : ps0.p1.x = v.x := by linarith [hq1xz]
            rw [this]; ring
          · show v.y = (1 - 0) * ps0.p1.y + 0 * ps0.p2.y
            have : ps0.p1.y = v.y := by linarith [hq1yz]
            rw [this]; ring
        · push_neg at hq1_zero
          by_cases hq2_zero : q2x = 0 ∧ q2y = 0
          · -- ps0.p2 = v.
            obtain ⟨hq2xz, hq2yz⟩ := hq2_zero
            apply h_v_off_lines ps0 hps0 1
            refine ⟨?_, ?_⟩
            · show v.x = (1 - 1) * ps0.p1.x + 1 * ps0.p2.x
              have : ps0.p2.x = v.x := by linarith [hq2xz]
              rw [this]; ring
            · show v.y = (1 - 1) * ps0.p1.y + 1 * ps0.p2.y
              have : ps0.p2.y = v.y := by linarith [hq2yz]
              rw [this]; ring
          · push_neg at hq2_zero
            -- Both nonzero. q1 × q2 = 0, so q1 || q2.
            -- We can find t' such that (1-t')*q1 + t'*q2 = 0.
            -- Equivalent: q1 = (t'/(t'-1)) * q2 when t' ≠ 1, etc.
            -- Cleanest: use determinant-based parametrization.
            -- (1-t')*q1x + t'*q2x = 0 (i)
            -- (1-t')*q1y + t'*q2y = 0 (ii)
            -- Both must hold simultaneously.
            -- If we use t' = q1x / (q1x - q2x) when q1x ≠ q2x, then:
            -- 1 - t' = -q2x / (q1x - q2x), so (1-t')*q1x + t'*q2x = (-q2x*q1x + q1x*q2x)/(q1x-q2x) = 0. ✓
            -- Need to also verify (ii): (1-t')*q1y + t'*q2y = (-q2x*q1y + q1x*q2y)/(q1x-q2x) =
            --                       (q1x*q2y - q1y*q2x)/(q1x-q2x) = denom/(q1x-q2x) = 0 since denom = 0. ✓
            -- So t' = q1x / (q1x - q2x), provided q1x ≠ q2x.
            -- Case 3a: q1x ≠ q2x. Use t' = q1x / (q1x - q2x).
            -- Case 3b: q1x = q2x. Then symmetrically use y. q1y ≠ q2y? If q1y = q2y too,
            -- then q1 = q2. Then q1 nonzero means q1 = q2 nonzero, but denom = q1x*q1y - q1y*q1x = 0 ✓.
            -- And they're in same direction. Hmm, but we need to find t' such that both equations hold.
            -- (1-t')*q1 + t'*q1 = q1 ≠ 0. So no t' makes both zero. So this case is impossible
            -- (we can't conclude v on line in this case... wait but denom = 0 with q1 = q2 is fine,
            -- we just have a degenerate segment). But ps0 is a segment of P0; we should have
            -- ps0.p1 ≠ ps0.p2 only if P0's segments are nondegenerate. Hmm, do we have that?
            -- We don't have that guarantee a priori. But: if q1 = q2 and both nonzero,
            -- then ps0.p1 ≠ v and ps0.p2 ≠ v but they might be the same. The segment is
            -- degenerate, but we can still ask if v is on line. Line through (a, a) is just {a}.
            -- v ≠ a since q1 ≠ 0. So h_v_off_lines holds vacuously? No it doesn't —
            -- h_v_off_lines says ∀ t, ¬(v.x = ...). For ps0.p1 = ps0.p2 = a (some a ≠ v),
            -- (1-t)*a.x + t*a.x = a.x ≠ v.x, so h_v_off_lines is satisfied for all t.
            -- But we need to derive a contradiction. Hmm. Actually we need denom = 0 to imply
            -- a contradiction with h_v_off_lines, but if line is just {a} ≠ {v}, we can't derive it.
            -- So this case must not arise.
            -- Let's see: if q1 = q2 (i.e., ps0.p1 = ps0.p2 + v difference is same),
            -- well actually q1 = q2 means ps0.p1 - v = ps0.p2 - v, so ps0.p1 = ps0.p2.
            -- We'd need ps0 nondegenerate. But P0.segments come from P0.vertices via
            -- consecutive pairs, so if vertices are distinct consecutive pairs are distinct.
            -- We don't have that hypothesis here. So we need to add it or work around.
            --
            -- Alternative: Just prove this case is impossible using denom = 0.
            -- denom = q1x*q2y - q1y*q2x = 0.
            by_cases hq1q2x : q1x = q2x
            · -- q1x = q2x. Then denom = q1x*q2y - q1y*q1x = q1x*(q2y - q1y) = 0.
              -- So either q1x = 0 or q2y = q1y.
              by_cases hq1xz : q1x = 0
              · -- q1x = q2x = 0. Then both q1 and q2 have x=0.
                -- Since q1 and q2 are not zero (above), q1y ≠ 0 or q2y ≠ 0.
                -- Find t' ∈ ℚ such that (1-t')*q1y + t'*q2y = 0.
                -- If q1y = 0, then q1 = 0. Contradicts hq1_zero.
                -- If q2y = 0, then q2 = 0. Contradicts hq2_zero.
                -- So q1y ≠ 0 and q2y ≠ 0. Then need 1-t' = -t'*(q2y/q1y), t' = 1/(1-q2y/q1y) ...
                -- Or simpler: (1-t')*q1y = -t'*q2y, so t' = q1y/(q1y - q2y) when q1y ≠ q2y.
                -- If q1y = q2y, then q1 = q2 (both x and y), giving degenerate segment.
                by_cases hq1q2y : q1y = q2y
                · -- q1 = q2. Then ps0.p1 = ps0.p2, contradicting h_nondeg.
                  exfalso
                  apply h_nondeg
                  ext
                  · have : q1x = q2x := hq1q2x
                    simp only [hq1x, hq2x] at this
                    linarith
                  · have : q1y = q2y := hq1q2y
                    simp only [hq1y, hq2y] at this
                    linarith
                · -- q1y ≠ q2y. Use t' = q1y/(q1y - q2y).
                  set t' : ℚ := q1y / (q1y - q2y)
                  have hd_ne : q1y - q2y ≠ 0 := sub_ne_zero.mpr hq1q2y
                  apply h_v_off_lines ps0 hps0 t'
                  refine ⟨?_, ?_⟩
                  · show v.x = (1 - t') * ps0.p1.x + t' * ps0.p2.x
                    have ha : (1-t')*ps0.p1.x + t'*ps0.p2.x =
                        v.x + ((1-t')*q1x + t'*q2x) := by
                      simp only [hq1x, hq2x]; ring
                    rw [ha]
                    -- (1-t')*q1x + t'*q2x = (1-t')*0 + t'*0 = 0 (since q1x = q2x = 0)
                    have : (1-t')*q1x + t'*q2x = 0 := by
                      rw [hq1xz, ← hq1q2x, hq1xz]; ring
                    linarith
                  · show v.y = (1 - t') * ps0.p1.y + t' * ps0.p2.y
                    have ha : (1-t')*ps0.p1.y + t'*ps0.p2.y =
                        v.y + ((1-t')*q1y + t'*q2y) := by
                      simp only [hq1y, hq2y]; ring
                    rw [ha]
                    have : (1-t')*q1y + t'*q2y = 0 := by
                      have h_t' : t' * (q1y - q2y) = q1y := by
                        rw [show t' = q1y / (q1y - q2y) from rfl]
                        field_simp
                      linarith
                    linarith
              · -- q1x ≠ 0. Then from hq1q2x, q2x = q1x ≠ 0. Use t' = q1x/(q1x-q2x). But q1x = q2x means denom = 0.
