        set rw_ray := rayFrom v seg.p2 hw_ne with hrw_def
        have h_p_on_ray : p ∈ rw_ray.toSet := by
          obtain ⟨t, ht0, ht1, hpx, hpy⟩ := hp_in_seg
          rw [hrw_def, mem_rayFrom]
          refine ⟨t, ht0, ?_, ?_⟩
          · rw [hpx, h_inc1]; ring
          · rw [hpy, h_inc1]; ring
        have h_p0_on_ray : p0 ∈ rw_ray.toSet := by
          rw [mem_rayFrom] at h_p_on_ray
          obtain ⟨s, hs0, hsx, hsy⟩ := h_p_on_ray
          have hsf_ne : s_f ≠ 0 := ne_of_gt hs_f_pos
          have hpx_shr : p.x = v.x + s_f*(p0.x - v.x) := by
            rw [← hp0_eq]; show (shrinkPoint v s_f p0).x = _; simp [shrinkPoint]; ring
          have hpy_shr : p.y = v.y + s_f*(p0.y - v.y) := by
            rw [← hp0_eq]; show (shrinkPoint v s_f p0).y = _; simp [shrinkPoint]; ring
          have h_eq_x : s_f*(p0.x - v.x) = s*(seg.p2.x - v.x) := by
            have h := hsx.symm.trans hpx_shr; linarith
          have h_eq_y : s_f*(p0.y - v.y) = s*(seg.p2.y - v.y) := by
            have h := hsy.symm.trans hpy_shr; linarith
          rw [mem_rayFrom]
          refine ⟨s / s_f, div_nonneg hs0 hs_f_pos.le, ?_, ?_⟩
