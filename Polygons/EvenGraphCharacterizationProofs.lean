            have hyy' : s_f * (ps0.p1.y - v.y) = w.y - v.y := by linarith
            -- Show s_f = candidateShrinkEq ps0.p1 w.
            have h_p0_ne_v : ps0.p1 ≠ v := h_P0_verts_ne_v ps0.p1 hp0_in
            have h_sf_eq : s_f = candidateShrinkEq ps0.p1 w := by
              by_cases hpx : ps0.p1.x = v.x
              · -- p0.x = v.x. Then s_f * 0 = w.x - v.x, so w.x = v.x.
                have hwx_eq : w.x = v.x := by
                  have := hxx'; rw [hpx] at this; linarith
                show s_f = (if ps0.p1.x = v.x then if ps0.p1.y = v.y then 0
                  else (w.y - v.y) / (ps0.p1.y - v.y)
                  else (w.x - v.x) / (ps0.p1.x - v.x))
                rw [if_pos hpx]
                by_cases hpy : ps0.p1.y = v.y
                · -- p0.y = v.y too. Then p0 = v, contradicts h_p0_ne_v.
                  exfalso; apply h_p0_ne_v; exact Vector2D.ext hpx hpy
                · rw [if_neg hpy]
                  have hp0_y_ne : ps0.p1.y - v.y ≠ 0 := sub_ne_zero.mpr hpy
                  -- s_f = (w.y - v.y) / (p0.y - v.y).
                  have h_eq : s_f * (ps0.p1.y - v.y) = w.y - v.y := hyy'
                  field_simp [hp0_y_ne]
                  linarith
              · -- p0.x ≠ v.x.
                show s_f = (if ps0.p1.x = v.x then _
                  else (w.x - v.x) / (ps0.p1.x - v.x))
                rw [if_neg hpx]
                have hp0_x_ne : ps0.p1.x - v.x ≠ 0 := sub_ne_zero.mpr hpx
                have h_eq : s_f * (ps0.p1.x - v.x) = w.x - v.x := hxx'
                field_simp [hp0_x_ne]
                linarith
            have hs_in_bad_pt : s_f ∈ bad_pt := by
              rw [hbad_pt_def, List.mem_toFinset, List.mem_map]
              refine ⟨(ps0.p1, w), ?_, ?_⟩
              · exact List.mem_product.mpr ⟨hp0_in, by rw [Finset.mem_toList]; exact hw_V⟩
              · exact h_sf_eq.symm
            have hs_in_bad : s_f ∈ bad := by
              rw [hbad_def]
              exact Finset.mem_union_right _ hs_in_bad_pt
            exact hs_f_bad hs_in_bad
      · -- Nondegenerate case. Apply mem_badShrinkFinset_of_line_through.
        have h_s_in_bad_line : s_f ∈ bad_line :=
          mem_badShrinkFinset_of_line_through P0 verts_to_avoid v h_v_off_P0_lines h_p1p2 hps0 hw
            hcontra.1 hcontra.2
        have hs_in_bad : s_f ∈ bad := by
          rw [hbad_def]
          exact Finset.mem_union_left _ h_s_in_bad_line
        exact hs_f_bad hs_in_bad
    -- Hypothesis 2: P-vertex avoids G.toBoundarySet.
    have h_polyverts_off : ∀ p ∈ P.toVertices, p ∉ G.toBoundarySet := by
      intro p hp h_in_b
      -- p is a shrunken P0-vertex: p = shrinkPoint v s_f p0 for some p0 ∈ P0.vertices.
      have hp_in_verts : p ∈ P.vertices := hp
      rw [hP_def, polygonShrink_vertices] at hp_in_verts
      rw [List.mem_map] at hp_in_verts
      obtain ⟨p0, hp0_in, hp0_eq⟩ := hp_in_verts
      -- p has squared distance s_f^2 * (dist² p0 v) from v ≤ s_f^2 * M < r².
      have hp_dist : (p.x - v.x)^2 + (p.y - v.y)^2 < r^2 := by
        rw [← hp0_eq, shrinkPoint_dist_sq_eq]
        have h0 := h_listMax p0 hp0_in
        have h_sf_sq_nn : 0 ≤ s_f^2 := by positivity
        have : s_f^2 * ((p0.x - v.x)^2 + (p0.y - v.y)^2) ≤ s_f^2 * M :=
          mul_le_mul_of_nonneg_left h0 h_sf_sq_nn
        linarith
      -- p ∈ G.toBoundarySet: ∃ seg ∈ G.segments, p ∈ seg.toSet.
      obtain ⟨seg, hseg, hp_seg⟩ := h_in_b
      -- Case split on seg incident to v or not.
      by_cases h_inc1 : seg.p1 = v
      · -- seg.p1 = v. seg is incident.
        -- p is on seg from v to seg.p2. Show p is on the ray from v through seg.p2.
        -- Then p ∈ ray r_w where w = seg.p2.
        -- But P0 vertex p0 (with p = shrinkPoint v s_f p0) avoids the ray r_w
        -- (h_P0_avoid). And p on the ray ⟹ p0 on the ray (since p, p0 on the same line through v).
        -- Wait: p = (1-s_f)*v + s_f*p0 lies between v and p0. If p is on the ray from v through w,
        -- then either v ∈ ray(v, w) (true, t=0) and p ∈ ray(v, w). The ray contains v + t*(w-v) for t ≥ 0.
        -- p = v + s*(w-v) for some s ≥ 0 means p - v = s*(w-v).
        -- p - v = s_f*(p0 - v). So s*(w-v) = s_f*(p0 - v). For this to hold with s ≥ 0,
        -- (w - v) and (p0 - v) must be parallel with same sign.
        -- Conclusion: p0 - v = (s/s_f)*(w-v), i.e., p0 = v + (s/s_f)*(w-v) which is on ray r_w
        -- (with parameter s/s_f ≥ 0). Hence p0 ∈ r_w.toSet.
        -- This contradicts h_P0_avoid (p0 ∈ P0.vertices avoids r_w).
        have hw_ne : seg.p2 ≠ v := by
          intro h_eq
          have := G.segments_nondegenerate seg hseg
          apply this; rw [h_inc1, h_eq]
        have h_w_in_endpoints : seg.p2 ∈ incidentOtherEndpoints G v := by
          rw [mem_incidentOtherEndpoints]
          refine ⟨seg, hseg, ?_⟩
          unfold otherEndpoint
          rw [if_pos h_inc1]
        set rw_ray := rayFrom v seg.p2 hw_ne with hrw_def
        -- p ∈ rw_ray.toSet. p ∈ seg = (v, seg.p2).
        have h_p_on_ray : p ∈ rw_ray.toSet := by
          obtain ⟨t, ht0, ht1, hpx, hpy⟩ := hp_seg
          rw [hrw_def, mem_rayFrom]
          refine ⟨t, ht0, ?_, ?_⟩
          · rw [hpx, h_inc1]; ring
          · rw [hpy, h_inc1]; ring
        -- Show p0 ∈ rw_ray.toSet.
        have h_p0_on_ray : p0 ∈ rw_ray.toSet := by
          rw [mem_rayFrom] at h_p_on_ray
          obtain ⟨s, hs0, hsx, hsy⟩ := h_p_on_ray
          have hsf_ne : s_f ≠ 0 := ne_of_gt hs_f_pos
          have hpx_shr : p.x = v.x + s_f*(p0.x - v.x) := by
            rw [← hp0_eq]; show (shrinkPoint v s_f p0).x = _; simp [shrinkPoint]; ring
          have hpy_shr : p.y = v.y + s_f*(p0.y - v.y) := by
            rw [← hp0_eq]; show (shrinkPoint v s_f p0).y = _; simp [shrinkPoint]; ring
          have h_eq_x : s_f*(p0.x - v.x) = s*(seg.p2.x - v.x) := by
            have h := hsx.symm.trans hpx_shr
            linarith
          have h_eq_y : s_f*(p0.y - v.y) = s*(seg.p2.y - v.y) := by
            have h := hsy.symm.trans hpy_shr
            linarith
          rw [mem_rayFrom]
          refine ⟨s / s_f, div_nonneg hs0 hs_f_pos.le, ?_, ?_⟩
          · have h_step : s_f * p0.x = s_f * (v.x + (s/s_f) * (seg.p2.x - v.x)) := by
              have h_rhs : s_f * (v.x + (s/s_f) * (seg.p2.x - v.x)) = s_f*v.x + s*(seg.p2.x - v.x) := by
                field_simp; ring
              rw [h_rhs]
              linarith
            exact mul_left_cancel₀ hsf_ne h_step
          · have h_step : s_f * p0.y = s_f * (v.y + (s/s_f) * (seg.p2.y - v.y)) := by
              have h_rhs : s_f * (v.y + (s/s_f) * (seg.p2.y - v.y)) = s_f*v.y + s*(seg.p2.y - v.y) := by
                field_simp; ring
              rw [h_rhs]
              linarith
            exact mul_left_cancel₀ hsf_ne h_step
        exact h_P0_avoid_anyG hw_ne h_w_in_endpoints p0 hp0_in h_p0_on_ray
      · -- seg.p1 ≠ v.
        by_cases h_inc2 : seg.p2 = v
        · -- seg.p2 = v.
          have hw_ne : seg.p1 ≠ v := h_inc1
          have h_w_in_endpoints : seg.p1 ∈ incidentOtherEndpoints G v := by
            rw [mem_incidentOtherEndpoints]
            refine ⟨seg, hseg, ?_⟩
            unfold otherEndpoint
            rw [if_neg h_inc1, if_pos h_inc2]
          set rw_ray := rayFrom v seg.p1 hw_ne with hrw_def
          have h_p_on_ray : p ∈ rw_ray.toSet := by
            obtain ⟨t, ht0, ht1, hpx, hpy⟩ := hp_seg
            rw [hrw_def, mem_rayFrom]
            refine ⟨1 - t, by linarith, ?_, ?_⟩
            · rw [hpx, h_inc2]; ring
            · rw [hpy, h_inc2]; ring
          have h_p0_on_ray : p0 ∈ rw_ray.toSet := by
            rw [mem_rayFrom] at h_p_on_ray
            obtain ⟨s, hs0, hsx, hsy⟩ := h_p_on_ray
            have hsf_ne : s_f ≠ 0 := ne_of_gt hs_f_pos
            have hpx_shr : p.x = v.x + s_f*(p0.x - v.x) := by
              rw [← hp0_eq]; show (shrinkPoint v s_f p0).x = _; simp [shrinkPoint]; ring
            have hpy_shr : p.y = v.y + s_f*(p0.y - v.y) := by
              rw [← hp0_eq]; show (shrinkPoint v s_f p0).y = _; simp [shrinkPoint]; ring
            have h_eq_x : s_f*(p0.x - v.x) = s*(seg.p1.x - v.x) := by
              have h := hsx.symm.trans hpx_shr
              linarith
            have h_eq_y : s_f*(p0.y - v.y) = s*(seg.p1.y - v.y) := by
              have h := hsy.symm.trans hpy_shr
              linarith
            rw [mem_rayFrom]
            refine ⟨s / s_f, div_nonneg hs0 hs_f_pos.le, ?_, ?_⟩
            · have h_step : s_f * p0.x = s_f * (v.x + (s/s_f) * (seg.p1.x - v.x)) := by
                have h_rhs : s_f * (v.x + (s/s_f) * (seg.p1.x - v.x)) = s_f*v.x + s*(seg.p1.x - v.x) := by
                  field_simp; ring
                rw [h_rhs]
                linarith
              exact mul_left_cancel₀ hsf_ne h_step
            · have h_step : s_f * p0.y = s_f * (v.y + (s/s_f) * (seg.p1.y - v.y)) := by
                have h_rhs : s_f * (v.y + (s/s_f) * (seg.p1.y - v.y)) = s_f*v.y + s*(seg.p1.y - v.y) := by
                  field_simp; ring
                rw [h_rhs]
                linarith
              exact mul_left_cancel₀ hsf_ne h_step
          exact h_P0_avoid_anyG hw_ne h_w_in_endpoints p0 hp0_in h_p0_on_ray
        · -- seg.p1 ≠ v and seg.p2 ≠ v: non-incident.
          -- p is at distance < r from v. By hr_seg (for G_ext), every point on seg
          -- has distance² ≥ r² from v. Contradiction.
          have hseg_ext : seg ∈ G_ext.segments := by
            rw [hG_ext_segs, List.mem_append]; exact Or.inl hseg
          have h_p_dist_ge : r^2 ≤ (p.x - v.x)^2 + (p.y - v.y)^2 :=
            hr_seg seg hseg_ext h_inc1 h_inc2 p hp_seg
          linarith
    -- Now extend h_polyverts_off to S_extra: polygon vertices avoid S_extra segments.
    have h_polyverts_off_sextra : ∀ p ∈ P.toVertices, ∀ s ∈ S_extra, p ∉ s.toSet := by
      intro p hp seg hseg_in_S hp_in_seg
      have hp_in_verts : p ∈ P.vertices := hp
      rw [hP_def, polygonShrink_vertices] at hp_in_verts
      rw [List.mem_map] at hp_in_verts
      obtain ⟨p0, hp0_in, hp0_eq⟩ := hp_in_verts
      have hp_dist : (p.x - v.x)^2 + (p.y - v.y)^2 < r^2 := by
