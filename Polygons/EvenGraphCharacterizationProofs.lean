                -- denom = q1x*q2y - q1y*q2x = q1x*q2y - q1y*q1x = q1x*(q2y - q1y) = 0.
                -- q1x ≠ 0, so q2y = q1y.
                have hq1q2y : q1y = q2y := by
                  have h_denom : q1x*q2y - q1y*q2x = 0 := h_denom_zero
                  have h2 : q1x*q2y - q1y*q1x = 0 := by rw [← hq1q2x] at h_denom; exact h_denom
                  have : q1x * (q2y - q1y) = 0 := by linarith
                  rcases mul_eq_zero.mp this with hh | hh
                  · exact absurd hh hq1xz
                  · linarith
                -- q1 = q2 (since q1x = q2x, q1y = q2y). So ps0 degenerate.
                apply h_nondeg
                ext
                · have : q1x = q2x := hq1q2x
                  simp only [hq1x, hq2x] at this
                  linarith
                · have : q1y = q2y := hq1q2y
                  simp only [hq1y, hq2y] at this
                  linarith
            · -- q1x ≠ q2x. Use t' = q1x/(q1x - q2x).
              set t' : ℚ := q1x / (q1x - q2x)
              have hd_ne : q1x - q2x ≠ 0 := sub_ne_zero.mpr hq1q2x
              apply h_v_off_lines ps0 hps0 t'
              refine ⟨?_, ?_⟩
              · show v.x = (1 - t') * ps0.p1.x + t' * ps0.p2.x
                have ha : (1-t')*ps0.p1.x + t'*ps0.p2.x =
                    v.x + ((1-t')*q1x + t'*q2x) := by
                  simp only [hq1x, hq2x]; ring
                rw [ha]
                have : (1-t')*q1x + t'*q2x = 0 := by
                  have h_t' : t' * (q1x - q2x) = q1x := by
                    rw [show t' = q1x / (q1x - q2x) from rfl]
                    field_simp
                  linarith
                linarith
              · show v.y = (1 - t') * ps0.p1.y + t' * ps0.p2.y
                have ha : (1-t')*ps0.p1.y + t'*ps0.p2.y =
                    v.y + ((1-t')*q1y + t'*q2y) := by
                  simp only [hq1y, hq2y]; ring
                rw [ha]
                have : (1-t')*q1y + t'*q2y = 0 := by
                  -- (1-t')*q1y + t'*q2y = q1y + t'*(q2y - q1y).
                  -- We need this to be 0. From denom = 0: q1x*q2y - q1y*q2x = 0,
                  -- so q1x*q2y = q1y*q2x.
                  -- t' = q1x/(q1x - q2x). t'*(q2y - q1y) = q1x*(q2y - q1y)/(q1x - q2x).
                  -- Goal: q1y + q1x*(q2y - q1y)/(q1x - q2x) = 0
                  --     ⟺ q1y*(q1x - q2x) + q1x*(q2y - q1y) = 0
                  --     ⟺ q1y*q1x - q1y*q2x + q1x*q2y - q1x*q1y = 0
                  --     ⟺ q1x*q2y - q1y*q2x = 0. Which is denom = 0. ✓
                  have h_t' : t' * (q1x - q2x) = q1x := by
                    rw [show t' = q1x / (q1x - q2x) from rfl]
                    field_simp
                  -- Multiply goal by (q1x - q2x): want (1-t')*q1y*(q1x-q2x) + t'*q2y*(q1x-q2x) = 0
                  have hgoal : (q1x - q2x) * ((1-t')*q1y + t'*q2y) = 0 := by
                    have h1 : (q1x - q2x) * ((1-t')*q1y + t'*q2y) =
                        (q1x - q2x)*q1y + (t'*(q1x - q2x))*(q2y - q1y) := by ring
                    rw [h1, h_t']
                    have : (q1x - q2x)*q1y + q1x*(q2y - q1y) = q1x*q2y - q1y*q2x := by ring
                    rw [this]
                    exact h_denom_zero
                  rcases mul_eq_zero.mp hgoal with hh | hh
                  · exact absurd hh hd_ne
                  · exact hh
                linarith
      -- denom ≠ 0. Compute s.
      -- From h_eq1, h_eq2 (after rearranging), we have:
      -- wx = s*q1x + s*t*(q2x - q1x)
      -- wy = s*q1y + s*t*(q2y - q1y)
      -- Eliminate t: multiply first by (q2y - q1y), second by (q2x - q1x), subtract:
      -- wx*(q2y - q1y) - wy*(q2x - q1x) = s*(q1x*(q2y - q1y) - q1y*(q2x - q1x))
      --                                = s*(q1x*q2y - q1x*q1y - q1y*q2x + q1y*q1x)
      --                                = s*(q1x*q2y - q1y*q2x) = s*denom.
      -- So s = (wx*(q2y - q1y) - wy*(q2x - q1x))/denom.
      have h_eq3 : wx*(q2y - q1y) - wy*(q2x - q1x) = s*denom := by
        have e1 : wx*(q2y - q1y) = s*(q1x + t*(q2x - q1x))*(q2y - q1y) := by rw [h_eq1]
        have e2 : wy*(q2x - q1x) = s*(q1y + t*(q2y - q1y))*(q2x - q1x) := by rw [h_eq2]
        rw [e1, e2]
        simp only [hdenom_def]
        ring
      -- Compute candidateBadS.
      have h_target : (wx*(q2y - q1y) - wy*(q2x - q1x))/denom = s := by
        rw [h_eq3]
        field_simp
      -- Goal: candidateBadS computation = s.
      -- candidateBadS unfolds to: if denom = 0 then 0 else (wx*(q2y - q1y) - wy*(q2x - q1x))/denom.
      rw [if_neg h_denom_ne]
      exact h_target

/-! ### Polygon vertex distance bound after shrinking -/

/-- After shrinking by `s` (with `s² * M ≤ R`), every vertex of the shrunken
polygon is at squared distance ≤ R from `v`. -/
private theorem polygonShrink_vertex_dist_sq_le (P0 : Polygon) (v : Vector2D)
    (s : ℚ) (M R : ℚ)
    (hM_bound : ∀ p ∈ P0.vertices, (p.x - v.x)^2 + (p.y - v.y)^2 ≤ M)
    (h_sM_le_R : s^2 * M ≤ R) (_hM_nn : 0 ≤ M) (hs_sq_nn : 0 ≤ s^2) :
    ∀ q ∈ (polygonShrink P0 v s).vertices,
      (q.x - v.x)^2 + (q.y - v.y)^2 ≤ R := by
  intro q hq
  rw [polygonShrink_vertices, List.mem_map] at hq
  obtain ⟨p, hp, hq_eq⟩ := hq
  rw [← hq_eq]
  rw [shrinkPoint_dist_sq_eq]
  have hp_dist : (p.x - v.x)^2 + (p.y - v.y)^2 ≤ M := hM_bound p hp
  have h_pos : 0 ≤ (p.x - v.x)^2 + (p.y - v.y)^2 := by positivity
  -- s² * (sqdist) ≤ s² * M ≤ R.
  have : s^2 * ((p.x - v.x)^2 + (p.y - v.y)^2) ≤ s^2 * M :=
    mul_le_mul_of_nonneg_left hp_dist hs_sq_nn
  linarith

/-- A shrunken polygon segment is the segment between two shrunken vertices,
both within squared distance `R` of `v`. So every point on the segment is too. -/
private theorem polygonShrink_segment_dist_sq_le
    (P0 : Polygon) (v : Vector2D) (s : ℚ) (R : ℚ)
    (h_vert_bound : ∀ q ∈ (polygonShrink P0 v s).vertices,
      (q.x - v.x)^2 + (q.y - v.y)^2 ≤ R)
    (ps : LineSegment) (hps : ps ∈ (polygonShrink P0 v s).segments)
    (q : Vector2D) (hq : q ∈ ps.toSet) :
    (q.x - v.x)^2 + (q.y - v.y)^2 ≤ R := by
  -- ps.p1, ps.p2 are vertices.
  have h_p1_vert : ps.p1 ∈ (polygonShrink P0 v s).vertices := by
    have h_p1_list := polygon_segments_p1_list (polygonShrink P0 v s)
    -- We need length ≥ 2 to use this. Check.
    by_cases h_len : (polygonShrink P0 v s).vertices.length ≥ 2
    · have := polygon_segments_p1_list (polygonShrink P0 v s) h_len
      have : ps.p1 ∈ ((polygonShrink P0 v s).segments.map (fun ps' => ps'.p1)) :=
        List.mem_map_of_mem _ hps
      rw [polygon_segments_p1_list (polygonShrink P0 v s) h_len] at this
      exact this
    · push_neg at h_len
      -- length < 2 → segments = []
      have h_segs_nil : (polygonShrink P0 v s).segments = [] := by
        unfold Polygon.segments
        cases hverts : (polygonShrink P0 v s).vertices with
        | nil => rfl
        | cons v1 vs =>
          cases hvs : vs with
          | nil => rfl
          | cons w ws =>
            exfalso
            rw [hverts, hvs] at h_len
            simp at h_len
            omega
      rw [h_segs_nil] at hps
      simp at hps
  have h_p2_vert : ps.p2 ∈ (polygonShrink P0 v s).vertices := by
    by_cases h_len : (polygonShrink P0 v s).vertices.length ≥ 2
    · have h_perm := polygon_segments_p2_list (polygonShrink P0 v s) h_len
      have h_in : ps.p2 ∈ ((polygonShrink P0 v s).segments.map (fun ps' => ps'.p2)) :=
        List.mem_map_of_mem _ hps
      exact h_perm.mem_iff.mp h_in
    · push_neg at h_len
      have h_segs_nil : (polygonShrink P0 v s).segments = [] := by
        unfold Polygon.segments
        cases hverts : (polygonShrink P0 v s).vertices with
        | nil => rfl
        | cons v1 vs =>
          cases hvs : vs with
          | nil => rfl
          | cons w ws =>
            exfalso
            rw [hverts, hvs] at h_len
            simp at h_len
            omega
      rw [h_segs_nil] at hps
      simp at hps
  exact segment_dist_sq_le_max v ps.p1 ps.p2 q R
    (h_vert_bound ps.p1 h_p1_vert) (h_vert_bound ps.p2 h_p2_vert) hq

/-! ### Sum swap lemma -/

/-- Sum of indicator over both lists, two ways. -/
private theorem sum_indicator_swap (l1 : List LineSegment) (l2 : List LineSegment)
    (P : LineSegment → LineSegment → Bool) :
    (l1.map (fun a => (l2.map (fun b => if P a b then (1:ℕ) else 0)).sum)).sum =
    (l2.map (fun b => (l1.map (fun a => if P a b then (1:ℕ) else 0)).sum)).sum := by
  induction l1 with
  | nil =>
    -- LHS = 0. RHS: each b contributes 0.
    show (([] : List LineSegment).map fun a => (l2.map fun b => if P a b then (1:ℕ) else 0).sum).sum =
         (l2.map fun b => (([] : List LineSegment).map fun a => if P a b then (1:ℕ) else 0).sum).sum
    rw [List.map_nil, List.sum_nil]
    have h_l2_eq : (l2.map (fun b => (([] : List LineSegment).map fun a => if P a b then (1:ℕ) else 0).sum)) =
        l2.map (fun _ : LineSegment => (0:ℕ)) := by
      apply List.map_congr_left
      intro b _; simp
    have h_sum_zero : (l2.map (fun _ : LineSegment => (0:ℕ))).sum = 0 := by
      induction l2 with
      | nil => simp
      | cons _ _ _ => simp
    rw [h_l2_eq, h_sum_zero]
  | cons a as ih =>
    -- Don't simp the LHS map_cons; keep cons structure.
    -- Compute the inner-cons identity first.
    have h_inner_cons : ∀ b : LineSegment,
        ((a :: as).map fun a' => if P a' b then (1:ℕ) else 0).sum =
        (if P a b then (1:ℕ) else 0) + (as.map fun a' => if P a' b then (1:ℕ) else 0).sum := by
      intro b; simp [List.map_cons, List.sum_cons]
    -- Replace inner sums in RHS.
    have h_map_eq : (l2.map (fun b => ((a :: as).map fun a' => if P a' b then (1:ℕ) else 0).sum)) =
        (l2.map (fun b => (if P a b then (1:ℕ) else 0) +
                          (as.map fun a' => if P a' b then (1:ℕ) else 0).sum)) := by
      apply List.map_congr_left
      intro b _; exact h_inner_cons b
    have h_rhs_eq : (l2.map (fun b => ((a :: as).map fun a' => if P a' b then (1:ℕ) else 0).sum)).sum =
        (l2.map (fun b => (if P a b then (1:ℕ) else 0) +
                          (as.map fun a' => if P a' b then (1:ℕ) else 0).sum)).sum := by
      rw [h_map_eq]
    -- Sum split.
    have h_sum_split : ∀ l2' : List LineSegment,
        (l2'.map (fun b => (if P a b then (1:ℕ) else 0) +
                           (as.map fun a' => if P a' b then (1:ℕ) else 0).sum)).sum =
        (l2'.map (fun b => if P a b then (1:ℕ) else 0)).sum +
        (l2'.map (fun b => (as.map fun a' => if P a' b then (1:ℕ) else 0).sum)).sum := by
      intro l2'
      induction l2' with
      | nil => simp
      | cons b bs ih2 =>
        simp only [List.map_cons, List.sum_cons]
        rw [ih2]
        ring
    -- Now combine.
    rw [show ((a :: as).map fun a => (l2.map fun b => if P a b then (1:ℕ) else 0).sum).sum =
        (l2.map fun b => if P a b then (1:ℕ) else 0).sum +
        (as.map fun a => (l2.map fun b => if P a b then (1:ℕ) else 0).sum).sum from
      by simp [List.map_cons, List.sum_cons]]
    rw [ih, h_rhs_eq, h_sum_split]

/-- Specialize to countP for both. -/
private theorem sum_countP_swap (l1 : List LineSegment) (l2 : List LineSegment)
    (P : LineSegment → LineSegment → Bool) :
    (l1.map (fun a => l2.countP (P a))).sum = (l2.map (fun b => l1.countP (fun a => P a b))).sum := by
  have h_countP_eq : ∀ (l : List LineSegment) (Q : LineSegment → Bool),
      l.countP Q = (l.map (fun x => if Q x then (1:ℕ) else 0)).sum := by
    intro l Q
    induction l with
    | nil => simp
    | cons x xs ih =>
      simp only [List.countP_cons, List.map_cons, List.sum_cons]
      rw [ih]
      by_cases hQ : Q x = true
      · rw [hQ]
        simp; omega
      · simp only [hQ]
        omega
  have h_lhs : (l1.map (fun a => l2.countP (P a))).sum =
      (l1.map (fun a => (l2.map (fun b => if P a b then (1:ℕ) else 0)).sum)).sum := by
    have heq : (l1.map (fun a => l2.countP (P a))) =
        (l1.map (fun a => (l2.map (fun b => if P a b then (1:ℕ) else 0)).sum)) := by
      apply List.map_congr_left
      intros a _
      exact h_countP_eq l2 (P a)
    rw [heq]
  have h_rhs : (l2.map (fun b => l1.countP (fun a => P a b))).sum =
      (l2.map (fun b => (l1.map (fun a => if P a b then (1:ℕ) else 0)).sum)).sum := by
    have heq : (l2.map (fun b => l1.countP (fun a => P a b))) =
        (l2.map (fun b => (l1.map (fun a => if P a b then (1:ℕ) else 0)).sum)) := by
      apply List.map_congr_left
      intros b _
      exact h_countP_eq l1 (fun a => P a b)
    rw [heq]
  rw [h_lhs, h_rhs]
  exact sum_indicator_swap l1 l2 P

/-! ### Main theorem -/

set_option maxHeartbeats 1000000 in

/-- See `Graph.isEven_of_exists_interior_set` in `EvenGraphCharacterization.lean`
    for the statement. -/
theorem isEven_of_exists_interior_set
    (G : Graph)
    (V_extra : Finset Vector2D)
    (S_extra : Finset LineSegment)
    (h_S_extra_nondeg : ∀ seg ∈ S_extra, seg.p1 ≠ seg.p2)
    (h_no_segment_interior_vertices : ∀ v ∈ G.toVertices,
      (∀ seg ∈ G.segments, seg.p1 ≠ v → seg.p2 ≠ v → v ∉ seg.toSet) ∧
      (∀ seg ∈ S_extra, seg.p1 ≠ v → seg.p2 ≠ v → v ∉ seg.toSet))
    (h_exists : ∃ I : Set Vector2D,
      I ∩ G.toBoundarySet = ∅ ∧
      ∀ r : Ray,
        r.origin ∉ G.toBoundarySet →
        (∀ s ∈ S_extra, r.origin ∉ s.toSet) →
        rayAvoidsGraphVertices r G →
        (∀ v ∈ V_extra, v ∉ r.toSet) →
        (intersectionRayGraphSegmentsNumber r G % 2 = 1 ↔ r.origin ∈ I)) :
    G.IsEven := by
  obtain ⟨I, hI_disjoint, hI_property⟩ := h_exists
  -- Build G_ext = G ∪ S_extra by appending the lists.
  let G_ext : Graph := G.append ⟨S_extra.toList, fun seg hseg =>
    h_S_extra_nondeg seg (Finset.mem_toList.mp hseg)⟩
  have hG_ext_segs : G_ext.segments = G.segments ++ S_extra.toList := rfl
  -- Membership in G_ext segments.
  have h_mem_G_ext : ∀ seg, seg ∈ G_ext.segments ↔ seg ∈ G.segments ∨ seg ∈ S_extra := by
    intro seg
    rw [hG_ext_segs, List.mem_append]
    constructor
    · rintro (h | h)
      · exact Or.inl h
      · exact Or.inr (Finset.mem_toList.mp h)
    · rintro (h | h)
      · exact Or.inl h
      · exact Or.inr (Finset.mem_toList.mpr h)
  -- v ∈ G.toVertices ⟹ v ∈ G_ext.toVertices.
  have h_GtV_sub_extV : ∀ v, v ∈ G.toVertices → v ∈ G_ext.toVertices := by
    intro v hv
    simp only [Graph.toVertices, List.mem_dedup, List.mem_flatMap, List.mem_cons,
      (List.not_mem_nil _), or_false] at hv ⊢
    obtain ⟨seg, hseg, hh⟩ := hv
    refine ⟨seg, ?_, hh⟩
    rw [hG_ext_segs, List.mem_append]
    exact Or.inl hseg
  -- For v ∈ G.toVertices, h_no_segment_interior_vertices extends to G_ext.
  have h_no_segment_interior_vertices_ext : ∀ v ∈ G.toVertices, ∀ seg ∈ G_ext.segments,
      seg.p1 ≠ v → seg.p2 ≠ v → v ∉ seg.toSet := by
    intro v hv seg hseg hp1 hp2
    rcases (h_mem_G_ext seg).mp hseg with hG | hS
    · exact (h_no_segment_interior_vertices v hv).1 seg hG hp1 hp2
    · exact (h_no_segment_interior_vertices v hv).2 seg hS hp1 hp2
  intro v
  -- Case: v ∉ G.toVertices. Then no segments incident, count = 0.
  by_cases h_v_in : v ∈ G.toVertices
  · -- Main case: v ∈ G.toVertices.
    -- Either v is incident to some segment (via toVertices), or not.
    -- v ∈ G.toVertices means v is an endpoint of some segment. Get one.
    have h_v_incident : ∃ seg ∈ G.segments, seg.p1 = v ∨ seg.p2 = v := by
      simp only [Graph.toVertices, List.mem_dedup, List.mem_flatMap, List.mem_cons,
        (List.not_mem_nil _), or_false] at h_v_in
      obtain ⟨seg, hseg, hh⟩ := h_v_in
      refine ⟨seg, hseg, ?_⟩
      rcases hh with h | h
      · exact Or.inl h.symm
      · exact Or.inr h.symm
    have h_v_incident_ext : ∃ seg ∈ G_ext.segments, seg.p1 = v ∨ seg.p2 = v := by
      obtain ⟨seg, hseg, hh⟩ := h_v_incident
      exact ⟨seg, by rw [hG_ext_segs, List.mem_append]; exact Or.inl hseg, hh⟩
    -- Step C: get safe radius r — using G_ext for both segment-avoidance and endpoint distance.
    obtain ⟨r, hr_pos, hr_seg, hr_end⟩ :=
      exists_vertex_neighborhood_avoiding_non_incident G_ext v h_v_incident_ext
        (fun seg hseg => h_no_segment_interior_vertices_ext v h_v_in seg hseg)
    -- Step A: build rays from v in G_ext, then dedup via pwFilter on toSet inequality.
    -- The dedup'd list `rs` has pairwise distinct toSets BY CONSTRUCTION.
    let rs_full : List Ray := raysFrom G_ext v
    have h_rs_full_origin : ∀ r ∈ rs_full, r.origin = v := by
      intro r hr; exact raysFrom_origin hr
    -- Dedup by toSet inequality.
    let rs : List Ray :=
      List.pwFilter (fun r1 r2 => r1.toSet ≠ r2.toSet) rs_full
    have h_rs_sub : ∀ r ∈ rs, r ∈ rs_full := List.pwFilter_subset _
    have h_rays_origin : ∀ r1 ∈ rs, ∀ r2 ∈ rs, sameOrigin r1 r2 := by
      intro r1 hr1 r2 hr2
      unfold sameOrigin
      rw [h_rs_full_origin r1 (h_rs_sub r1 hr1), h_rs_full_origin r2 (h_rs_sub r2 hr2)]
    have h_rays_distinct : rs.Pairwise (fun r1 r2 => r1.toSet ≠ r2.toSet) :=
      List.pairwise_pwFilter _
    -- Property: for every full-list ray, there exists a representative in rs
    -- with the same toSet. Proved by induction on the list.
    have h_rs_repr : ∀ r ∈ rs_full, ∃ r' ∈ rs, r.toSet = r'.toSet := by
      show ∀ r ∈ rs_full, ∃ r' ∈ List.pwFilter
        (fun r1 r2 => r1.toSet ≠ r2.toSet) rs_full, r.toSet = r'.toSet
      generalize hL : rs_full = L
      clear hL
      intro r hr
      induction L with
      | nil => exact absurd hr (List.not_mem_nil _)
      | cons hd tl ih =>
        rcases List.mem_cons.mp hr with rfl | hr_tl
        · -- r = hd. Two cases on pwFilter behavior.
          by_cases h_pos : ∀ b ∈ List.pwFilter (fun r1 r2 => r1.toSet ≠ r2.toSet) tl,
              r.toSet ≠ b.toSet
          · -- hd kept: pwFilter (hd :: tl) = hd :: pwFilter tl.
            rw [List.pwFilter_cons_of_pos h_pos]
            exact ⟨r, (List.mem_cons_self _ _), rfl⟩
          · -- hd dropped: there's some b ∈ pwFilter tl with r.toSet = b.toSet.
            rw [List.pwFilter_cons_of_neg h_pos]
            push_neg at h_pos
            obtain ⟨b, hb_mem, hb_eq⟩ := h_pos
            exact ⟨b, hb_mem, hb_eq⟩
        · -- r ∈ tl: by IH.
          obtain ⟨r', hr'_mem, hr'_eq⟩ := ih hr_tl
          by_cases h_pos : ∀ b ∈ List.pwFilter (fun r1 r2 => r1.toSet ≠ r2.toSet) tl,
              hd.toSet ≠ b.toSet
          · rw [List.pwFilter_cons_of_pos h_pos]
            exact ⟨r', List.mem_cons_of_mem _ hr'_mem, hr'_eq⟩
          · rw [List.pwFilter_cons_of_neg h_pos]
            exact ⟨r', hr'_mem, hr'_eq⟩
    -- Step B: apply exists_polygon_separating_rays.
    obtain ⟨P0, h_P0_avoid, h_P0_unique_seg, h_P0_hit, h_P0_unique_ray, h_P0_line_avoid_v,
        h_P0_segs_nodup⟩ :=
      exists_polygon_separating_rays rs h_rays_origin h_rays_distinct
    -- Helper: G-incident rays have representatives in rs.
    have h_G_ray_repr : ∀ {w : Vector2D} (h_ne : w ≠ v),
        w ∈ incidentOtherEndpoints G v →
        ∃ r' ∈ rs, (rayFrom v w h_ne).toSet = r'.toSet := by
      intro w h_ne hw
      have hw_ext : w ∈ incidentOtherEndpoints G_ext v := by
        rw [mem_incidentOtherEndpoints] at hw ⊢
        obtain ⟨seg, hseg, hh⟩ := hw
        exact ⟨seg, by rw [hG_ext_segs, List.mem_append]; exact Or.inl hseg, hh⟩
      have h_in_full : rayFrom v w h_ne ∈ rs_full := by
        rw [mem_raysFrom]; exact ⟨w, hw_ext, h_ne, rfl⟩
      exact h_rs_repr _ h_in_full
    -- Helper: a P0-vertex p0 in some ray r.toSet implies it's in the representative's toSet.
    -- (We just convert via toSet equality.)
    have h_P0_avoid_anyG : ∀ {w : Vector2D} (h_ne : w ≠ v),
        w ∈ incidentOtherEndpoints G v →
        ∀ p0 ∈ P0.vertices, p0 ∉ (rayFrom v w h_ne).toSet := by
      intro w h_ne hw p0 hp0 hp0_in
      obtain ⟨r', hr'_mem, hr'_eq⟩ := h_G_ray_repr h_ne hw
      have : p0 ∈ r'.toSet := by rw [← hr'_eq]; exact hp0_in
      exact h_P0_avoid p0 hp0 r' hr'_mem this
    -- Helper: get a polygon segment intersecting the G-incident ray (via representative).
    have h_P0_hit_G : ∀ {w : Vector2D} (h_ne : w ≠ v),
        w ∈ incidentOtherEndpoints G v →
        ∃ ps0 ∈ P0.segments, rayIntersectsSegment (rayFrom v w h_ne) ps0 := by
      intro w h_ne hw
      obtain ⟨r', hr'_mem, hr'_eq⟩ := h_G_ray_repr h_ne hw
      obtain ⟨ps0, hps0, hint⟩ := h_P0_hit r' hr'_mem
      refine ⟨ps0, hps0, ?_⟩
      rw [rayIntersectsSegment] at hint ⊢
      obtain ⟨q, hq_r', hq_ps0⟩ := hint
      refine ⟨q, ?_, hq_ps0⟩
      rw [hr'_eq]; exact hq_r'
    -- Helper: uniqueness of polygon segment intersected by a G-incident ray.
    have h_P0_unique_ray_G : ∀ {w : Vector2D} (h_ne : w ≠ v),
        w ∈ incidentOtherEndpoints G v →
        ∀ ps1 ∈ P0.segments, ∀ ps2 ∈ P0.segments,
          rayIntersectsSegment (rayFrom v w h_ne) ps1 →
          rayIntersectsSegment (rayFrom v w h_ne) ps2 → ps1 = ps2 := by
      intro w h_ne hw ps1 hps1 ps2 hps2 hint1 hint2
      obtain ⟨r', hr'_mem, hr'_eq⟩ := h_G_ray_repr h_ne hw
      have hint1' : rayIntersectsSegment r' ps1 := by
        obtain ⟨q, hq_r, hq_ps⟩ := hint1
        exact ⟨q, by rw [← hr'_eq]; exact hq_r, hq_ps⟩
      have hint2' : rayIntersectsSegment r' ps2 := by
        obtain ⟨q, hq_r, hq_ps⟩ := hint2
        exact ⟨q, by rw [← hr'_eq]; exact hq_r, hq_ps⟩
      exact h_P0_unique_ray r' hr'_mem ps1 hps1 ps2 hps2 hint1' hint2'
    -- Helper: S_extra-incident rays have representatives in rs.
    have h_S_ray_repr : ∀ {w : Vector2D} (h_ne : w ≠ v),
        (∃ s ∈ S_extra, otherEndpoint v s = some w) →
        ∃ r' ∈ rs, (rayFrom v w h_ne).toSet = r'.toSet := by
      intro w h_ne hw
      obtain ⟨s, hs_in, hs_op⟩ := hw
      have hw_ext : w ∈ incidentOtherEndpoints G_ext v := by
        rw [mem_incidentOtherEndpoints]
        refine ⟨s, ?_, hs_op⟩
        rw [hG_ext_segs, List.mem_append]
        right; exact Finset.mem_toList.mpr hs_in
      have h_in_full : rayFrom v w h_ne ∈ rs_full := by
        rw [mem_raysFrom]; exact ⟨w, hw_ext, h_ne, rfl⟩
      exact h_rs_repr _ h_in_full
    have h_P0_avoid_anyS : ∀ {w : Vector2D} (h_ne : w ≠ v),
        (∃ s ∈ S_extra, otherEndpoint v s = some w) →
        ∀ p0 ∈ P0.vertices, p0 ∉ (rayFrom v w h_ne).toSet := by
      intro w h_ne hw p0 hp0 hp0_in
      obtain ⟨r', hr'_mem, hr'_eq⟩ := h_S_ray_repr h_ne hw
      have : p0 ∈ r'.toSet := by rw [← hr'_eq]; exact hp0_in
      exact h_P0_avoid p0 hp0 r' hr'_mem this
    -- Adapt: P0 vertices avoid all rays, in particular v: if v ∈ P0.toVertices,
    -- then v on some ray, but v is the origin — origin is on ray. So P0 vertices ≠ v.
