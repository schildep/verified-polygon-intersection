namespace GraphVertexNeighborhoodProofs

/-! ### Measure -/

noncomputable def segRaysCount (seg : LineSegment) (rs : List Ray) : ℕ :=
  rs.countP fun r => decide (rayIntersectsSegment r seg)

noncomputable def polyRaysExcess (poly : Polygon) (rs : List Ray) : ℕ :=
  (poly.segments.map fun seg => segRaysCount seg rs - 1).sum

private lemma list_sum_nat_eq_zero_iff_all_zero (l : List ℕ) :
    l.sum = 0 ↔ ∀ n ∈ l, n = 0 := by
  induction l with
  | nil => simp
  | cons a as ih => simp [List.sum_cons, ih]

private lemma polyRaysExcess_zero_iff (poly : Polygon) (rs : List Ray) :
    polyRaysExcess poly rs = 0 ↔ ∀ seg ∈ poly.segments, segRaysCount seg rs ≤ 1 := by
  unfold polyRaysExcess
  rw [list_sum_nat_eq_zero_iff_all_zero]
  constructor
  · intro h seg hseg
    have := h (segRaysCount seg rs - 1) (List.mem_map_of_mem _ hseg)
    omega
  · intro h n hn
    rw [List.mem_map] at hn
    obtain ⟨seg, hseg, rfl⟩ := hn
    have := h seg hseg
    omega

/-! ### Ray helpers -/

private lemma toSet_eq_of_pos_scalar_dir (r1 r2 : Ray)
    (h_origin : r1.origin = r2.origin)
    (c : ℚ) (hc : 0 < c)
    (hdx : r1.direction.x = c * r2.direction.x)
    (hdy : r1.direction.y = c * r2.direction.y) :
    r1.toSet = r2.toSet := by
  ext p
  simp only [Ray.toSet, Set.mem_setOf_eq]
  have hc_ne : c ≠ 0 := ne_of_gt hc
  constructor
  · rintro ⟨s, hs, hsx, hsy⟩
    refine ⟨s * c, mul_nonneg hs hc.le, ?_, ?_⟩
    · rw [hsx, h_origin, hdx]; ring
    · rw [hsy, h_origin, hdy]; ring
  · rintro ⟨s, hs, hsx, hsy⟩
    refine ⟨s / c, div_nonneg hs hc.le, ?_, ?_⟩
    · rw [hsx, ← h_origin, hdx]; field_simp; ring
    · rw [hsy, ← h_origin, hdy]; field_simp; ring

private lemma common_point_origin_or_eq (r1 r2 : Ray)
    (h_origin : sameOrigin r1 r2)
    (p : Vector2D) (hp1 : p ∈ r1.toSet) (hp2 : p ∈ r2.toSet) :
    p = r1.origin ∨ r1.toSet = r2.toSet := by
  unfold sameOrigin at h_origin
  obtain ⟨t1, ht1_nn, hx1, hy1⟩ := hp1
  obtain ⟨t2, ht2_nn, hx2, hy2⟩ := hp2
  rcases eq_or_lt_of_le ht1_nn with rfl | ht1_pos
  · left; simp at hx1 hy1
    ext
    · exact hx1
    · exact hy1
  rcases eq_or_lt_of_le ht2_nn with rfl | ht2_pos
  · left; simp at hx2 hy2
    rw [← h_origin] at hx2 hy2
    ext
    · exact hx2
    · exact hy2
  right
  have h_eq_x : t1 * r1.direction.x = t2 * r2.direction.x := by
    have heq : r1.origin.x + t1 * r1.direction.x = r2.origin.x + t2 * r2.direction.x := by
      rw [← hx1, ← hx2]
    rw [h_origin] at heq; linarith
  have h_eq_y : t1 * r1.direction.y = t2 * r2.direction.y := by
    have heq : r1.origin.y + t1 * r1.direction.y = r2.origin.y + t2 * r2.direction.y := by
      rw [← hy1, ← hy2]
    rw [h_origin] at heq; linarith
  have ht1_ne : t1 ≠ 0 := ne_of_gt ht1_pos
  have hdx : r1.direction.x = (t2 / t1) * r2.direction.x := by
    field_simp; linarith
  have hdy : r1.direction.y = (t2 / t1) * r2.direction.y := by
    field_simp; linarith
  exact toSet_eq_of_pos_scalar_dir r1 r2 h_origin (t2 / t1)
    (div_pos ht2_pos ht1_pos) hdx hdy

private lemma distinct_common_point_is_origin (r1 r2 : Ray)
    (h_origin : sameOrigin r1 r2)
    (h_ne : r1.toSet ≠ r2.toSet)
    (p : Vector2D) (hp1 : p ∈ r1.toSet) (hp2 : p ∈ r2.toSet) :
    p = r1.origin :=
  (common_point_origin_or_eq r1 r2 h_origin p hp1 hp2).resolve_right h_ne

/-! ### Positive rational in open interval avoiding finite set -/

private lemma exists_rat_in_open_ioo (a b : ℚ) (h_lt : a < b) (bad : Finset ℚ) :
    ∃ q : ℚ, a < q ∧ q < b ∧ q ∉ bad := by
  let f : ℕ → ℚ := fun n => a + (b - a) / (n + 2 : ℚ)
  have hba : 0 < b - a := by linarith
  have hba_ne : b - a ≠ 0 := ne_of_gt hba
  have hf_inj : Function.Injective f := by
    intro x y hxy
    simp only [f] at hxy
    have h1 : (x + 2 : ℚ) > 0 := by positivity
    have h2 : (y + 2 : ℚ) > 0 := by positivity
    have h1_ne : (x + 2 : ℚ) ≠ 0 := ne_of_gt h1
    have h2_ne : (y + 2 : ℚ) ≠ 0 := ne_of_gt h2
    have h_eq : (b - a) / (x + 2 : ℚ) = (b - a) / (y + 2 : ℚ) := by linarith
    rw [div_eq_div_iff h1_ne h2_ne] at h_eq
    have hxy_eq : (x + 2 : ℚ) = (y + 2 : ℚ) := (mul_left_cancel₀ hba_ne h_eq).symm
    have : (x : ℚ) = (y : ℚ) := by linarith
    exact_mod_cast this
  have hf_in : ∀ n, a < f n ∧ f n < b := by
    intro n
    refine ⟨?_, ?_⟩
    · simp only [f]
      have : (0 : ℚ) < (b - a) / (n + 2 : ℚ) := div_pos hba (by positivity)
      linarith
    · simp only [f]
      have h_pos : (0 : ℚ) < (n + 2 : ℚ) := by positivity
      have h1_lt : (1 : ℚ) < (n + 2 : ℚ) := by
        have : (0 : ℚ) ≤ (n : ℚ) := by positivity
        linarith
      have h_div : (b - a) / (n + 2 : ℚ) < b - a := by
        rw [div_lt_iff₀ h_pos]
        nlinarith
      linarith
  let candidates : Finset ℕ := Finset.range (bad.card + 1)
  let img : Finset ℚ := candidates.image f
  have h_card : img.card = bad.card + 1 := by
    rw [Finset.card_image_of_injective _ hf_inj, Finset.card_range]
  have h_exists : ∃ q ∈ img, q ∉ bad := by
    by_contra h
    push_neg at h
    have h_sub : img ⊆ bad := h
    have : img.card ≤ bad.card := Finset.card_le_card h_sub
    omega
  obtain ⟨q, hq_mem, hq_bad⟩ := h_exists
  obtain ⟨n, _, hn_eq⟩ := Finset.mem_image.mp hq_mem
  refine ⟨q, ?_, ?_, hq_bad⟩
  · exact hn_eq ▸ (hf_in n).1
  · exact hn_eq ▸ (hf_in n).2

/-! ### Triangle: vertices `triA = o + (1, qA)`, `triB = o + (-1, 1+qB)`, `triC = o + (-1, -1+qC)`. -/

private def triA (o : Vector2D) (q : ℚ) : Vector2D := ⟨o.x + 1, o.y + q⟩
private def triB (o : Vector2D) (q : ℚ) : Vector2D := ⟨o.x - 1, o.y + 1 + q⟩
private def triC (o : Vector2D) (q : ℚ) : Vector2D := ⟨o.x - 1, o.y - 1 + q⟩

/-- A vertex with x-offset 1 is on ray r (origin o) iff qA = r.dy/r.dx
    with r.dx > 0. The "bad" qA is undefined if r.dx ≤ 0. -/
private lemma not_on_triA (o : Vector2D) (qA : ℚ) (r : Ray) (hr : r.origin = o)
    (h_not_bad : ¬ (r.direction.x > 0 ∧ qA * r.direction.x = r.direction.y)) :
    triA o qA ∉ r.toSet := by
  simp only [triA, Ray.toSet, Set.mem_setOf_eq, hr]
  rintro ⟨t, ht, hx, hy⟩
  have hx' : t * r.direction.x = 1 := by linarith
  have hy' : t * r.direction.y = qA := by linarith
  by_cases h_dx_pos : r.direction.x > 0
  · apply h_not_bad
    refine ⟨h_dx_pos, ?_⟩
    linear_combination r.direction.y * hx' - r.direction.x * hy'
  · push_neg at h_dx_pos
    rcases eq_or_lt_of_le h_dx_pos with h_zero | h_neg
    · rw [h_zero] at hx'; linarith
    · have h1 : t * r.direction.x ≤ 0 := mul_nonpos_of_nonneg_of_nonpos ht h_neg.le
      linarith

private lemma not_on_triB (o : Vector2D) (qB : ℚ) (r : Ray) (hr : r.origin = o)
    (h_not_bad : ¬ (r.direction.x < 0 ∧ (1 + qB) * r.direction.x = -r.direction.y)) :
    triB o qB ∉ r.toSet := by
  simp only [triB, Ray.toSet, Set.mem_setOf_eq, hr]
  rintro ⟨t, ht, hx, hy⟩
  have hx' : t * r.direction.x = -1 := by linarith
  have hy' : t * r.direction.y = 1 + qB := by linarith
  by_cases h_dx_neg : r.direction.x < 0
  · apply h_not_bad
    refine ⟨h_dx_neg, ?_⟩
    linear_combination r.direction.y * hx' - r.direction.x * hy'
  · push_neg at h_dx_neg
    rcases eq_or_lt_of_le h_dx_neg with h_zero | h_pos
    · rw [← h_zero] at hx'; linarith
    · have : 0 ≤ t * r.direction.x := mul_nonneg ht h_pos.le
      linarith

private lemma not_on_triC (o : Vector2D) (qC : ℚ) (r : Ray) (hr : r.origin = o)
    (h_not_bad : ¬ (r.direction.x < 0 ∧ (-1 + qC) * r.direction.x = -r.direction.y)) :
    triC o qC ∉ r.toSet := by
  simp only [triC, Ray.toSet, Set.mem_setOf_eq, hr]
  rintro ⟨t, ht, hx, hy⟩
  have hx' : t * r.direction.x = -1 := by linarith
  have hy' : t * r.direction.y = -1 + qC := by linarith
  by_cases h_dx_neg : r.direction.x < 0
  · apply h_not_bad
    refine ⟨h_dx_neg, ?_⟩
    linear_combination r.direction.y * hx' - r.direction.x * hy'
  · push_neg at h_dx_neg
    rcases eq_or_lt_of_le h_dx_neg with h_zero | h_pos
    · rw [← h_zero] at hx'; linarith
    · have : 0 ≤ t * r.direction.x := mul_nonneg ht h_pos.le
      linarith

/-! ### Finding good q_A, q_B, q_C avoiding all rays' bad values -/

/-- Given rays, produce finite bad q-value sets. -/
private noncomputable def badQsA (rs : List Ray) : Finset ℚ :=
  (rs.filterMap fun r => if r.direction.x > 0 then
    some (r.direction.y / r.direction.x) else none).toFinset

private noncomputable def badQsB (rs : List Ray) : Finset ℚ :=
  (rs.filterMap fun r => if r.direction.x < 0 then
    some (-r.direction.y / r.direction.x - 1) else none).toFinset

private noncomputable def badQsC (rs : List Ray) : Finset ℚ :=
  (rs.filterMap fun r => if r.direction.x < 0 then
    some (-r.direction.y / r.direction.x + 1) else none).toFinset

/-- If qA ∉ badQsA rs, then triA o qA avoids all rays in rs (assuming common origin). -/
private lemma triA_avoids_rays (o : Vector2D) (qA : ℚ) (rs : List Ray)
    (h_origin : ∀ r ∈ rs, r.origin = o) (h_qA : qA ∉ badQsA rs) :
    ∀ r ∈ rs, triA o qA ∉ r.toSet := by
  intro r hr
  apply not_on_triA o qA r (h_origin r hr)
  intro ⟨hdx, hqA_eq⟩
  apply h_qA
  simp only [badQsA, List.mem_toFinset, List.mem_filterMap]
  refine ⟨r, hr, ?_⟩
  simp [if_pos hdx]
  have hdx_ne : r.direction.x ≠ 0 := ne_of_gt hdx
  field_simp
  linarith

private lemma triB_avoids_rays (o : Vector2D) (qB : ℚ) (rs : List Ray)
    (h_origin : ∀ r ∈ rs, r.origin = o) (h_qB : qB ∉ badQsB rs) :
    ∀ r ∈ rs, triB o qB ∉ r.toSet := by
  intro r hr
  apply not_on_triB o qB r (h_origin r hr)
  intro ⟨hdx, hqB_eq⟩
  apply h_qB
  simp only [badQsB, List.mem_toFinset, List.mem_filterMap]
  refine ⟨r, hr, ?_⟩
  simp [if_pos hdx]
  have hdx_ne : r.direction.x ≠ 0 := ne_of_lt hdx
  field_simp
  linarith

private lemma triC_avoids_rays (o : Vector2D) (qC : ℚ) (rs : List Ray)
    (h_origin : ∀ r ∈ rs, r.origin = o) (h_qC : qC ∉ badQsC rs) :
    ∀ r ∈ rs, triC o qC ∉ r.toSet := by
  intro r hr
  apply not_on_triC o qC r (h_origin r hr)
  intro ⟨hdx, hqC_eq⟩
  apply h_qC
  simp only [badQsC, List.mem_toFinset, List.mem_filterMap]
  refine ⟨r, hr, ?_⟩
  simp [if_pos hdx]
  have hdx_ne : r.direction.x ≠ 0 := ne_of_lt hdx
  field_simp
  linarith

/-! ### "Every ray hits some edge" of the triangle -/

/-- Helper: ray hits segment at specific parameters. -/
private lemma ray_hits_seg_at (r : Ray) (seg : LineSegment) (t s : ℚ)
    (ht : 0 ≤ t) (hs0 : 0 ≤ s) (hs1 : s ≤ 1)
    (hx : r.origin.x + t * r.direction.x = (1 - s) * seg.p1.x + s * seg.p2.x)
    (hy : r.origin.y + t * r.direction.y = (1 - s) * seg.p1.y + s * seg.p2.y) :
    rayIntersectsSegment r seg := by
  refine ⟨⟨r.origin.x + t * r.direction.x, r.origin.y + t * r.direction.y⟩, ?_, ?_⟩
  · exact ⟨t, ht, rfl, rfl⟩
  · exact ⟨s, hs0, hs1, hx, hy⟩

/-- For a ray with `dx > 0` and `qA * dx ≤ dy`, the ray hits segment `[triA, triB]`.
    For `q_A, q_B ∈ [0, 1/4]` so that `1 + q_B - q_A ≥ 3/4 > 0`. -/
private lemma ray_hits_AB_of_dxpos (o : Vector2D) (qA qB : ℚ)
    (hqA0 : 0 ≤ qA) (hqA1 : qA ≤ 1/4) (hqB0 : 0 ≤ qB) (_hqB1 : qB ≤ 1/4)
    (r : Ray) (hr : r.origin = o)
    (hdxpos : r.direction.x > 0) (hslope : qA * r.direction.x ≤ r.direction.y) :
    rayIntersectsSegment r ⟨triA o qA, triB o qB⟩ := by
  -- t = (1+qA+qB) / (2*dy + dx*(1+qB-qA)), s = (1 - t*dx)/2.
  set α := 2 * r.direction.y + r.direction.x * (1 + qB - qA) with hα_def
  have hα_pos : 0 < α := by
    have : 1 + qB - qA ≥ 3/4 := by linarith
    have h1 : r.direction.x * (1 + qB - qA) > 0 := mul_pos hdxpos (by linarith)
    have h2 : 2 * r.direction.y ≥ 2 * (qA * r.direction.x) := by linarith
    have h3 : qA * r.direction.x ≥ 0 := mul_nonneg hqA0 hdxpos.le
    linarith
  have hα_ne : α ≠ 0 := ne_of_gt hα_pos
  set t := (1 + qA + qB) / α with ht_def
  set s := (1 - t * r.direction.x) / 2 with hs_def
  have ht_nn : 0 ≤ t := by
    have : 0 ≤ 1 + qA + qB := by linarith
    exact div_nonneg this hα_pos.le
  have ht_dx_le_1 : t * r.direction.x ≤ 1 := by
    -- t*dx = (1+qA+qB)*dx/α, and we need this ≤ 1
    -- α = 2*dy + dx*(1+qB-qA). We need (1+qA+qB)*dx ≤ α
    -- (1+qA+qB)*dx ≤ 2*dy + dx*(1+qB-qA)
    -- dx*((1+qA+qB) - (1+qB-qA)) ≤ 2*dy
    -- dx*(2*qA) ≤ 2*dy
    -- qA*dx ≤ dy  ✓ (this is hslope)
    rw [ht_def]
    rw [div_mul_eq_mul_div, div_le_iff₀ hα_pos]
    rw [hα_def]
    nlinarith [hslope]
  have ht_dx_ge_m1 : -1 ≤ t * r.direction.x :=
    le_trans (by linarith) (mul_nonneg ht_nn hdxpos.le)
  have hs0 : 0 ≤ s := by
    rw [hs_def]; linarith
  have hs1 : s ≤ 1 := by
    rw [hs_def]; linarith
  apply ray_hits_seg_at r _ t s ht_nn hs0 hs1
  · -- x equation: r.origin.x + t * dx = (1-s)*triA.x + s*triB.x
    simp only [triA, triB]
    rw [hr, hs_def]
    ring
  · -- y equation
    simp only [triA, triB]
    rw [hr, hs_def]
    -- LHS: o.y + t*dy
    -- RHS: (1 - (1-t*dx)/2) * (o.y + qA) + ((1-t*dx)/2) * (o.y + 1 + qB)
    --    = (1+t*dx)/2 * (o.y + qA) + (1-t*dx)/2 * (o.y + 1 + qB)
    -- After simplification, need to equal o.y + t*dy.
    -- Using t = (1+qA+qB)/α and α = 2*dy + dx*(1+qB-qA).
    field_simp
    -- Need: 2 * (o.y + t * r.direction.y) = ((1+t*dx) * (o.y + qA) + (1-t*dx) * (o.y + 1 + qB))
    -- Expand RHS: 2*o.y + t*dx*(qA - (1+qB)) + qA + 1+qB
    -- LHS: 2*o.y + 2*t*dy
    -- So need: 2*t*dy = t*dx*(qA - 1 - qB) + qA + 1 + qB
    -- Equiv: 2*t*dy + t*dx*(1+qB-qA) = 1 + qA + qB
    -- i.e., t * (2*dy + dx*(1+qB-qA)) = 1 + qA + qB
    -- i.e., t * α = 1 + qA + qB, which holds since t = (1+qA+qB)/α.
    have ht_mul : t * α = 1 + qA + qB := by
      rw [ht_def]; field_simp
    linear_combination ht_mul

/-- For a ray with `dx > 0` and `dy < qA * dx`, the ray hits segment `[triC, triA]`. -/
private lemma ray_hits_CA_of_dxpos (o : Vector2D) (qA qC : ℚ)
    (hqA0 : 0 ≤ qA) (hqA1 : qA ≤ 1/4) (_hqC0 : 0 ≤ qC) (hqC1 : qC ≤ 1/4)
    (r : Ray) (hr : r.origin = o)
    (hdxpos : r.direction.x > 0) (hslope : r.direction.y < qA * r.direction.x) :
    rayIntersectsSegment r ⟨triC o qC, triA o qA⟩ := by
  set α := r.direction.x * (1 + qA - qC) - 2 * r.direction.y with hα_def
  have h_qsum : qA + qC ≤ 1/2 := by linarith
  have h_qsum_lt_1 : qA + qC < 1 := by linarith
  have h_1pqAqC : 1 + qA - qC ≥ 3/4 := by linarith
  have hα_pos : 0 < α := by
    have h1 : 0 < r.direction.x * (1 - qA - qC) := mul_pos hdxpos (by linarith)
    -- α = dx*(1+qA-qC) - 2*dy. Using hslope: 2*dy < 2*qA*dx.
    -- α > dx*(1+qA-qC) - 2*qA*dx = dx*(1 - qA - qC) > 0.
    nlinarith [h1, hslope, hdxpos]
  have hα_ne : α ≠ 0 := ne_of_gt hα_pos
  set t := (1 - qA - qC) / α with ht_def
  set s := (1 + t * r.direction.x) / 2 with hs_def
  have ht_nn : 0 ≤ t := by
    have : 0 ≤ 1 - qA - qC := by linarith
    exact div_nonneg this hα_pos.le
  have h_tdx_nn : 0 ≤ t * r.direction.x := mul_nonneg ht_nn hdxpos.le
  have ht_dx_le_1 : t * r.direction.x ≤ 1 := by
    rw [ht_def]
    rw [div_mul_eq_mul_div, div_le_iff₀ hα_pos]
    rw [hα_def]
    nlinarith [hslope]
  have hs0 : 0 ≤ s := by
    rw [hs_def]; linarith
  have hs1 : s ≤ 1 := by
    rw [hs_def]; linarith
  apply ray_hits_seg_at r _ t s ht_nn hs0 hs1
  · simp only [triA, triC]
    rw [hr, hs_def]
    ring
  · simp only [triA, triC]
    rw [hr, hs_def]
    field_simp
    have ht_mul : t * α = 1 - qA - qC := by
      rw [ht_def]; field_simp
    linear_combination -ht_mul

/-- For a ray with `dx < 0` and `dy > -(1+qB)*dx`, the ray hits segment `[triA, triB]`. -/
private lemma ray_hits_AB_of_dxneg (o : Vector2D) (qA qB : ℚ)
    (hqA0 : 0 ≤ qA) (hqA1 : qA ≤ 1/4) (hqB0 : 0 ≤ qB) (_hqB1 : qB ≤ 1/4)
    (r : Ray) (hr : r.origin = o)
    (hdxneg : r.direction.x < 0)
    (hslope : r.direction.y > -(1 + qB) * r.direction.x) :
    rayIntersectsSegment r ⟨triA o qA, triB o qB⟩ := by
  set α := 2 * r.direction.y + r.direction.x * (1 + qB - qA) with hα_def
  have h_1pqBqA : 1 + qB - qA ≥ 3/4 := by linarith
  have h_1pqAqB_nn : 0 ≤ 1 + qA + qB := by linarith
  -- α_AB > -dx*(1+qA+qB) > 0
  have hα_lb : α > -r.direction.x * (1 + qA + qB) := by
    have h1 : 2 * r.direction.y > -2 * (1 + qB) * r.direction.x := by linarith
    nlinarith [h1, hdxneg]
  have hα_pos : 0 < α := by
    have : 0 ≤ -r.direction.x * (1 + qA + qB) := by
      apply mul_nonneg
      · linarith
      · linarith
    linarith
  have hα_ne : α ≠ 0 := ne_of_gt hα_pos
  set t := (1 + qA + qB) / α with ht_def
  set s := (1 - t * r.direction.x) / 2 with hs_def
  have ht_nn : 0 ≤ t := by
    exact div_nonneg h_1pqAqB_nn hα_pos.le
  have h_tdx_nonpos : t * r.direction.x ≤ 0 := by
    have hdx_nonpos : r.direction.x ≤ 0 := le_of_lt hdxneg
    exact mul_nonpos_of_nonneg_of_nonpos ht_nn hdx_nonpos
  have ht_dx_ge_m1 : -1 ≤ t * r.direction.x := by
    -- need: (1+qA+qB)*dx/α ≥ -1, i.e., (1+qA+qB)*dx ≥ -α (since α>0)
    -- i.e., α ≥ -(1+qA+qB)*dx = -dx*(1+qA+qB). This is hα_lb.
    rw [ht_def, div_mul_eq_mul_div, le_div_iff₀ hα_pos]
    nlinarith [hα_lb]
  have hs0 : 0 ≤ s := by
    rw [hs_def]; linarith
  have hs1 : s ≤ 1 := by
    rw [hs_def]; linarith
  apply ray_hits_seg_at r _ t s ht_nn hs0 hs1
  · simp only [triA, triB]
    rw [hr, hs_def]
    ring
  · simp only [triA, triB]
    rw [hr, hs_def]
    field_simp
    have ht_mul : t * α = 1 + qA + qB := by
      rw [ht_def]; field_simp
    linear_combination ht_mul

/-- For a ray with `dx < 0` and `dy < (1-qC)*dx`, the ray hits segment `[triC, triA]`. -/
private lemma ray_hits_CA_of_dxneg (o : Vector2D) (qA qC : ℚ)
    (hqA0 : 0 ≤ qA) (hqA1 : qA ≤ 1/4) (_hqC0 : 0 ≤ qC) (hqC1 : qC ≤ 1/4)
    (r : Ray) (hr : r.origin = o)
    (hdxneg : r.direction.x < 0)
    (hslope : r.direction.y < (1 - qC) * r.direction.x) :
    rayIntersectsSegment r ⟨triC o qC, triA o qA⟩ := by
  set α := r.direction.x * (1 + qA - qC) - 2 * r.direction.y with hα_def
  have h_qsum_lt_1 : qA + qC < 1 := by linarith
  have h_1_sub_qAqC_pos : 0 < 1 - qA - qC := by linarith
  have h_1pqAqC_pos : 0 < 1 + qA - qC := by linarith
  -- α > -dx*(1-qA-qC) > 0
  have hα_lb : α > -r.direction.x * (1 - qA - qC) := by
    have h1 : -2 * r.direction.y > -2 * ((1 - qC) * r.direction.x) := by linarith
    nlinarith [h1, hdxneg]
  have hα_pos : 0 < α := by
    have h0 : 0 ≤ -r.direction.x * (1 - qA - qC) := by
      apply mul_nonneg
      · linarith
      · linarith
    linarith
  have hα_ne : α ≠ 0 := ne_of_gt hα_pos
  set t := (1 - qA - qC) / α with ht_def
  set s := (1 + t * r.direction.x) / 2 with hs_def
  have ht_nn : 0 ≤ t := div_nonneg h_1_sub_qAqC_pos.le hα_pos.le
  have h_tdx_nonpos : t * r.direction.x ≤ 0 := by
    exact mul_nonpos_of_nonneg_of_nonpos ht_nn (le_of_lt hdxneg)
  have ht_dx_ge_m1 : -1 ≤ t * r.direction.x := by
    rw [ht_def, div_mul_eq_mul_div, le_div_iff₀ hα_pos]
    nlinarith [hα_lb]
  have hs0 : 0 ≤ s := by
    rw [hs_def]; linarith
  have hs1 : s ≤ 1 := by
    rw [hs_def]; linarith
  apply ray_hits_seg_at r _ t s ht_nn hs0 hs1
  · simp only [triA, triC]
    rw [hr, hs_def]
    ring
  · simp only [triA, triC]
    rw [hr, hs_def]
    field_simp
    have ht_mul : t * α = 1 - qA - qC := by
      rw [ht_def]; field_simp
    linear_combination -ht_mul

/-- For a ray with `dx < 0` and `(1-qC)*dx ≤ dy ≤ -(1+qB)*dx`, the ray hits segment `[triB, triC]`. -/
private lemma ray_hits_BC_of_dxneg (o : Vector2D) (qB qC : ℚ)
    (hqB0 : 0 ≤ qB) (_hqB1 : qB ≤ 1/4) (_hqC0 : 0 ≤ qC) (hqC1 : qC ≤ 1/4)
    (r : Ray) (hr : r.origin = o)
    (hdxneg : r.direction.x < 0)
    (h_lo : (1 - qC) * r.direction.x ≤ r.direction.y)
    (h_hi : r.direction.y ≤ -(1 + qB) * r.direction.x) :
    rayIntersectsSegment r ⟨triB o qB, triC o qC⟩ := by
  have hdx_ne : r.direction.x ≠ 0 := ne_of_lt hdxneg
  -- Use t such that t * dx = -1, and s ∈ [0,1] such that
  -- t * dy = (1-s)*(1+qB) + s*(-1+qC) = 1+qB - s*(2+qB-qC).
  -- i.e., s*(2+qB-qC) = 1+qB - t*dy.
  set β := 2 + qB - qC with hβ_def
  have hβ_pos : 0 < β := by rw [hβ_def]; linarith
  have hβ_ne : β ≠ 0 := ne_of_gt hβ_pos
  have hdx_neg_pos : 0 < -r.direction.x := by linarith
  have hdx_neg_ne : -r.direction.x ≠ 0 := ne_of_gt hdx_neg_pos
  -- Define u = 1+qB + dy/dx (this will be s * β)
  -- Rewrite without division: use t = 1/(-dx), s = ((1+qB)*(-dx) + (-dy))/(β*(-dx))
  -- equivalently: s*β*(-dx) = (1+qB)*(-dx) + (-dy).
  set t := 1 / (-r.direction.x) with ht_def
  have ht_nn : 0 ≤ t := by
    rw [ht_def]; exact div_nonneg (by norm_num) hdx_neg_pos.le
  have h_tdx : t * r.direction.x = -1 := by
    rw [ht_def]; field_simp
  have h_tdy_eq2 : t * r.direction.y * (-r.direction.x) = r.direction.y := by
    rw [ht_def]; field_simp
  set s := ((1 + qB) * (-r.direction.x) + (-r.direction.y)) / (β * (-r.direction.x)) with hs_def
  have hβdx_pos : 0 < β * (-r.direction.x) := mul_pos hβ_pos hdx_neg_pos
  have hβdx_ne : β * (-r.direction.x) ≠ 0 := ne_of_gt hβdx_pos
  have hs0 : 0 ≤ s := by
    rw [hs_def]
    apply div_nonneg _ hβdx_pos.le
    -- (1+qB)*(-dx) + (-dy) ≥ 0 iff dy ≤ (1+qB)*(-dx) = -(1+qB)*dx, which is h_hi.
    have : r.direction.y ≤ -(1 + qB) * r.direction.x := h_hi
    have h2 : (1 + qB) * (-r.direction.x) = -(1 + qB) * r.direction.x := by ring
    linarith
  have hs1 : s ≤ 1 := by
    rw [hs_def, div_le_one hβdx_pos]
    -- (1+qB)*(-dx) + (-dy) ≤ β*(-dx) = (2+qB-qC)*(-dx)
    -- iff -dy ≤ (β - (1+qB)) * (-dx) = (1 - qC)*(-dx) = -(1-qC)*dx
    -- iff dy ≥ (1-qC)*dx, which is h_lo.
    have h_lo_r : (1 - qC) * r.direction.x ≤ r.direction.y := h_lo
    nlinarith [h_lo_r, hdxneg]
  apply ray_hits_seg_at r _ t s ht_nn hs0 hs1
  · simp only [triB, triC]
    rw [hr]
    rw [h_tdx]
    ring
  · simp only [triB, triC]
    rw [hr]
    -- Need: o.y + t*dy = (1-s)*(o.y+1+qB) + s*(o.y-1+qC).
    -- i.e., t*dy = (1+qB) - s*(2+qB-qC) = (1+qB) - s*β.
    -- We prove: (1+qB - s*β - t*dy)*(-dx) = 0. Since -dx ≠ 0, equal.
    have hsβ_mul : s * β * (-r.direction.x) = (1 + qB) * (-r.direction.x) + (-r.direction.y) := by
      rw [hs_def]; field_simp; ring
    have h_tdy_val : t * r.direction.y = 1 + qB - s * β := by
      have h_eq_mul : ((1 + qB - s * β) - t * r.direction.y) * (-r.direction.x) = 0 := by
        have hrew : ((1 + qB - s * β) - t * r.direction.y) * (-r.direction.x) =
            ((1 + qB) * (-r.direction.x) - s * β * (-r.direction.x))
              - t * r.direction.y * (-r.direction.x) := by ring
        rw [hrew, hsβ_mul, h_tdy_eq2]
        ring
      have : (1 + qB - s * β) - t * r.direction.y = 0 := by
        rcases mul_eq_zero.mp h_eq_mul with h | h
        · exact h
        · exact absurd h hdx_neg_ne
      linarith
    rw [hβ_def] at h_tdy_val
    linear_combination h_tdy_val

/-! ### Necessary slope conditions from a segment hit -/

/-- If a ray with origin `o` hits `[triA, triB]`, then it satisfies the slope bounds
    `qA * dx ≤ dy` and `dy ≥ -(1+qB) * dx`. -/
private lemma rayHitsAB_implies (o : Vector2D) (qA qB : ℚ)
    (hqA0 : 0 ≤ qA) (hqB0 : 0 ≤ qB)
    (r : Ray) (hr : r.origin = o)
    (h_hit : rayIntersectsSegment r ⟨triA o qA, triB o qB⟩) :
    qA * r.direction.x ≤ r.direction.y ∧
      r.direction.y ≥ -(1 + qB) * r.direction.x := by
  obtain ⟨p, ⟨t, ht_nn, hpx_r, hpy_r⟩, ⟨s, hs0, hs1, hpx_s, hpy_s⟩⟩ := h_hit
  -- Combine to get t*dx = 1 - 2s and t*dy = qA + s*(1+qB-qA)
  simp only [triA, triB] at hpx_s hpy_s
  rw [hpx_r, hr] at hpx_s
  rw [hpy_r, hr] at hpy_s
  have hx_eq : t * r.direction.x = 1 - 2 * s := by linarith
  have hy_eq : t * r.direction.y = qA + s * (1 + qB - qA) := by linarith
  -- t > 0: if t = 0 then from hx_eq s = 1/2, then from hy_eq qA + (1+qB-qA)/2 = 0
  -- which contradicts qA, qB ≥ 0.
  have ht_pos : 0 < t := by
    rcases eq_or_lt_of_le ht_nn with ht_zero | ht_pos
    · exfalso
      rw [← ht_zero] at hx_eq hy_eq
      have hs_half : s = 1/2 := by linarith
      rw [hs_half] at hy_eq
      -- hy_eq: 0 * dy = qA + (1/2)*(1+qB-qA)
      -- so 0 = qA + (1+qB-qA)/2 = (qA+1+qB)/2, so qA + 1 + qB = 0.
      nlinarith
    · exact ht_pos
  refine ⟨?_, ?_⟩
  · -- qA * dx ≤ dy. t*(dy - qA*dx) = s*(1+qA+qB)
    have h_mul : t * (r.direction.y - qA * r.direction.x) = s * (1 + qA + qB) := by
      have : t * r.direction.y - qA * (t * r.direction.x) = s * (1 + qA + qB) := by
        rw [hx_eq, hy_eq]; ring
      linarith [this]
    have h_rhs_nn : 0 ≤ s * (1 + qA + qB) :=
      mul_nonneg hs0 (by linarith)
    have h_lhs_nn : 0 ≤ t * (r.direction.y - qA * r.direction.x) := by
      rw [h_mul]; exact h_rhs_nn
    have h_factor_nn : 0 ≤ r.direction.y - qA * r.direction.x :=
      nonneg_of_mul_nonneg_right h_lhs_nn ht_pos
    linarith
  · -- dy ≥ -(1+qB)*dx. t*(dy + (1+qB)*dx) = (1+qA+qB)*(1-s)
    have h_mul : t * (r.direction.y + (1 + qB) * r.direction.x) =
        (1 + qA + qB) * (1 - s) := by
      have : t * r.direction.y + (1 + qB) * (t * r.direction.x) =
          (1 + qA + qB) * (1 - s) := by
        rw [hx_eq, hy_eq]; ring
      linarith [this]
    have h_rhs_nn : 0 ≤ (1 + qA + qB) * (1 - s) :=
      mul_nonneg (by linarith) (by linarith)
    have h_lhs_nn : 0 ≤ t * (r.direction.y + (1 + qB) * r.direction.x) := by
      rw [h_mul]; exact h_rhs_nn
    have h_factor_nn : 0 ≤ r.direction.y + (1 + qB) * r.direction.x :=
      nonneg_of_mul_nonneg_right h_lhs_nn ht_pos
    linarith

/-- If a ray with origin `o` hits `[triB, triC]`, then its `dx < 0` and
    `(1-qC)*dx ≤ dy ≤ -(1+qB)*dx`. -/
private lemma rayHitsBC_implies (o : Vector2D) (qB qC : ℚ)
    (hqB0 : 0 ≤ qB) (_hqC0 : 0 ≤ qC) (hqC1 : qC ≤ 1/4)
    (r : Ray) (hr : r.origin = o)
    (h_hit : rayIntersectsSegment r ⟨triB o qB, triC o qC⟩) :
    r.direction.x < 0 ∧
      (1 - qC) * r.direction.x ≤ r.direction.y ∧
      r.direction.y ≤ -(1 + qB) * r.direction.x := by
  obtain ⟨p, ⟨t, ht_nn, hpx_r, hpy_r⟩, ⟨s, hs0, hs1, hpx_s, hpy_s⟩⟩ := h_hit
  simp only [triB, triC] at hpx_s hpy_s
  rw [hpx_r, hr] at hpx_s
  rw [hpy_r, hr] at hpy_s
  -- t*dx = -1, t*dy = (1+qB) + s*(-2 - qB + qC) = (1+qB) - s*(2+qB-qC)
  have hx_eq : t * r.direction.x = -1 := by linarith
  have hy_eq : t * r.direction.y = (1 + qB) - s * (2 + qB - qC) := by linarith
  -- dx < 0: if dx ≥ 0, then t*dx ≥ 0 ≠ -1.
  have hdx_neg : r.direction.x < 0 := by
    by_contra h
    push_neg at h
    have : 0 ≤ t * r.direction.x := mul_nonneg ht_nn h
    linarith
  have ht_pos : 0 < t := by
    rcases eq_or_lt_of_le ht_nn with ht_zero | ht_pos
    · exfalso; rw [← ht_zero] at hx_eq; linarith
    · exact ht_pos
  -- We have t*dx = -1, so t = 1/(-dx), and t*dy = dy/(-dx).
  -- For s ∈ [0,1]: t*dy ∈ [-1+qC, 1+qB]. Use 2+qB-qC ≥ 7/4 > 0.
  have h_coef_pos : 0 < 2 + qB - qC := by linarith
  have hy_lo : -1 + qC ≤ t * r.direction.y := by
    rw [hy_eq]
    have : s * (2 + qB - qC) ≤ 1 * (2 + qB - qC) :=
      mul_le_mul_of_nonneg_right hs1 h_coef_pos.le
    linarith
  have hy_hi : t * r.direction.y ≤ 1 + qB := by
    rw [hy_eq]
    have : 0 * (2 + qB - qC) ≤ s * (2 + qB - qC) :=
      mul_le_mul_of_nonneg_right hs0 h_coef_pos.le
    linarith
  -- Multiply by -dx > 0.
  have hmdx_pos : 0 < -r.direction.x := by linarith
  have h_t_mdx : t * (-r.direction.x) = 1 := by
    have : t * (-r.direction.x) = -(t * r.direction.x) := by ring
    rw [this, hx_eq]; ring
  refine ⟨hdx_neg, ?_, ?_⟩
  · -- (1-qC)*dx ≤ dy. Multiply by -dx > 0: dy*(-dx) ≥ (1-qC)*dx*(-dx) = -(1-qC)*dx*dx
    -- Actually easier: t*dy ≥ -1 + qC means dy*t ≥ -1+qC. Mul both sides by -dx > 0:
    -- dy*t*(-dx) ≥ (-1+qC)*(-dx). LHS = dy * (t*(-dx)) = dy * 1 = dy.
    -- RHS = (-1+qC)*(-dx) = (1-qC)*dx.
    have h1 : (-1 + qC) * (-r.direction.x) ≤ t * r.direction.y * (-r.direction.x) := by
      exact mul_le_mul_of_nonneg_right hy_lo hmdx_pos.le
    have h2 : t * r.direction.y * (-r.direction.x) = r.direction.y := by
      have : t * r.direction.y * (-r.direction.x) = r.direction.y * (t * (-r.direction.x)) := by
        ring
      rw [this, h_t_mdx]; ring
    have h3 : (-1 + qC) * (-r.direction.x) = (1 - qC) * r.direction.x := by ring
    linarith
  · -- dy ≤ -(1+qB)*dx. Mul (1+qB) ≥ t*dy by -dx > 0:
    -- (1+qB)*(-dx) ≥ t*dy*(-dx) = dy.
    -- RHS in target: -(1+qB)*dx = (1+qB)*(-dx).
    have h1 : t * r.direction.y * (-r.direction.x) ≤ (1 + qB) * (-r.direction.x) := by
      exact mul_le_mul_of_nonneg_right hy_hi hmdx_pos.le
    have h2 : t * r.direction.y * (-r.direction.x) = r.direction.y := by
      have : t * r.direction.y * (-r.direction.x) = r.direction.y * (t * (-r.direction.x)) := by
        ring
      rw [this, h_t_mdx]; ring
    have h3 : (1 + qB) * (-r.direction.x) = -(1 + qB) * r.direction.x := by ring
    linarith

/-- If a ray with origin `o` hits `[triC, triA]`, then `dy ≤ qA * dx` and
    `dy ≤ (1-qC) * dx`. -/
private lemma rayHitsCA_implies (o : Vector2D) (qA qC : ℚ)
    (_hqA0 : 0 ≤ qA) (_hqC0 : 0 ≤ qC) (hqC1 : qC ≤ 1/4) (hqA1 : qA ≤ 1/4)
    (r : Ray) (hr : r.origin = o)
    (h_hit : rayIntersectsSegment r ⟨triC o qC, triA o qA⟩) :
    r.direction.y ≤ qA * r.direction.x ∧
      r.direction.y ≤ (1 - qC) * r.direction.x := by
  obtain ⟨p, ⟨t, ht_nn, hpx_r, hpy_r⟩, ⟨s, hs0, hs1, hpx_s, hpy_s⟩⟩ := h_hit
  simp only [triC, triA] at hpx_s hpy_s
  rw [hpx_r, hr] at hpx_s
  rw [hpy_r, hr] at hpy_s
  -- t*dx = 2s - 1, t*dy = (-1+qC) + s*(1+qA-qC)
  have hx_eq : t * r.direction.x = 2 * s - 1 := by linarith
  have hy_eq : t * r.direction.y = (-1 + qC) + s * (1 + qA - qC) := by linarith
  -- t > 0: if t = 0, hx_eq gives s = 1/2, and hy_eq gives
  -- 0 = -1 + qC + (1+qA-qC)/2 = (-2+2qC+1+qA-qC)/2 = (-1+qA+qC)/2.
  -- So qA + qC = 1. But qA, qC ≤ 1/4 means qA+qC ≤ 1/2. Contradiction.
  have ht_pos : 0 < t := by
    rcases eq_or_lt_of_le ht_nn with ht_zero | ht_pos
    · exfalso
      rw [← ht_zero] at hx_eq hy_eq
      have hs_half : s = 1/2 := by linarith
      rw [hs_half] at hy_eq
      nlinarith
    · exact ht_pos
  refine ⟨?_, ?_⟩
  · -- dy ≤ qA*dx. t*(qA*dx - dy) = (1-qA-qC)*(1-s)
    have h_mul : t * (qA * r.direction.x - r.direction.y) =
        (1 - qA - qC) * (1 - s) := by
      have : qA * (t * r.direction.x) - t * r.direction.y =
          (1 - qA - qC) * (1 - s) := by
        rw [hx_eq, hy_eq]; ring
      linarith [this]
    have h_rhs_nn : 0 ≤ (1 - qA - qC) * (1 - s) :=
      mul_nonneg (by linarith) (by linarith)
    have h_lhs_nn : 0 ≤ t * (qA * r.direction.x - r.direction.y) := by
      rw [h_mul]; exact h_rhs_nn
    have h_factor_nn : 0 ≤ qA * r.direction.x - r.direction.y :=
      nonneg_of_mul_nonneg_right h_lhs_nn ht_pos
    linarith
  · -- dy ≤ (1-qC)*dx. t*((1-qC)*dx - dy) = (1-qA-qC)*s
    have h_mul : t * ((1 - qC) * r.direction.x - r.direction.y) =
        (1 - qA - qC) * s := by
      have : (1 - qC) * (t * r.direction.x) - t * r.direction.y =
          (1 - qA - qC) * s := by
        rw [hx_eq, hy_eq]; ring
      linarith [this]
    have h_rhs_nn : 0 ≤ (1 - qA - qC) * s :=
      mul_nonneg (by linarith) hs0
    have h_lhs_nn : 0 ≤ t * ((1 - qC) * r.direction.x - r.direction.y) := by
      rw [h_mul]; exact h_rhs_nn
    have h_factor_nn : 0 ≤ (1 - qC) * r.direction.x - r.direction.y :=
      nonneg_of_mul_nonneg_right h_lhs_nn ht_pos
    linarith

/-- A ray cannot hit both `[triA, triB]` and `[triB, triC]` unless `triB` is on the ray. -/
private lemma not_both_AB_BC (o : Vector2D) (qA qB qC : ℚ)
    (hqA0 : 0 ≤ qA) (hqB0 : 0 ≤ qB) (hqC0 : 0 ≤ qC) (hqC1 : qC ≤ 1/4)
    (r : Ray) (hr : r.origin = o)
    (h_B_avoid : triB o qB ∉ r.toSet)
    (h_AB : rayIntersectsSegment r ⟨triA o qA, triB o qB⟩)
    (h_BC : rayIntersectsSegment r ⟨triB o qB, triC o qC⟩) : False := by
  obtain ⟨_, h_AB2⟩ := rayHitsAB_implies o qA qB hqA0 hqB0 r hr h_AB
  obtain ⟨hdx_neg, _, h_BC2⟩ := rayHitsBC_implies o qB qC hqB0 hqC0 hqC1 r hr h_BC
  -- Both give dy = -(1+qB)*dx, and dx < 0.
  have h_eq : r.direction.y = -(1 + qB) * r.direction.x := by linarith
  -- Show triB on ray.
  apply h_B_avoid
  have hdx_ne : r.direction.x ≠ 0 := ne_of_lt hdx_neg
  have hmdx_pos : 0 < -r.direction.x := by linarith
  refine ⟨1 / (-r.direction.x), ?_, ?_, ?_⟩
  · exact div_nonneg (by norm_num) hmdx_pos.le
  · simp only [triB]
    rw [hr]
    have h_tdx : 1 / (-r.direction.x) * r.direction.x = -1 := by
      field_simp
    linarith
  · simp only [triB]
    rw [hr, h_eq]
    have h_tdx : 1 / (-r.direction.x) * (-(1 + qB) * r.direction.x) = 1 + qB := by
      field_simp; ring
    linarith

/-- A ray cannot hit both `[triB, triC]` and `[triC, triA]` unless `triC` is on the ray. -/
private lemma not_both_BC_CA (o : Vector2D) (qA qB qC : ℚ)
    (hqA0 : 0 ≤ qA) (hqB0 : 0 ≤ qB) (hqC0 : 0 ≤ qC)
    (hqA1 : qA ≤ 1/4) (hqC1 : qC ≤ 1/4)
    (r : Ray) (hr : r.origin = o)
    (h_C_avoid : triC o qC ∉ r.toSet)
    (h_BC : rayIntersectsSegment r ⟨triB o qB, triC o qC⟩)
    (h_CA : rayIntersectsSegment r ⟨triC o qC, triA o qA⟩) : False := by
  obtain ⟨hdx_neg, h_BC_lo, _⟩ := rayHitsBC_implies o qB qC hqB0 hqC0 hqC1 r hr h_BC
  obtain ⟨_, h_CA_hi⟩ := rayHitsCA_implies o qA qC hqA0 hqC0 hqC1 hqA1 r hr h_CA
  -- Both give dy = (1-qC)*dx, and dx < 0.
  have h_eq : r.direction.y = (1 - qC) * r.direction.x := by linarith
  apply h_C_avoid
  have hdx_ne : r.direction.x ≠ 0 := ne_of_lt hdx_neg
  have hmdx_pos : 0 < -r.direction.x := by linarith
  refine ⟨1 / (-r.direction.x), ?_, ?_, ?_⟩
  · exact div_nonneg (by norm_num) hmdx_pos.le
  · simp only [triC]
    rw [hr]
    have h_tdx : 1 / (-r.direction.x) * r.direction.x = -1 := by
      field_simp
    linarith
  · simp only [triC]
    rw [hr, h_eq]
    have h_tdy : 1 / (-r.direction.x) * ((1 - qC) * r.direction.x) = -(1 - qC) := by
      field_simp; ring
    linarith

/-- A ray cannot hit both `[triA, triB]` and `[triC, triA]` unless `triA` is on the ray,
    provided the direction is nonzero (guaranteed by `Ray.direction_nonzero`). -/
private lemma not_both_AB_CA (o : Vector2D) (qA qB qC : ℚ)
    (hqA0 : 0 ≤ qA) (hqB0 : 0 ≤ qB) (hqC0 : 0 ≤ qC)
    (hqA1 : qA ≤ 1/4) (hqC1 : qC ≤ 1/4)
    (r : Ray) (hr : r.origin = o)
    (h_A_avoid : triA o qA ∉ r.toSet)
    (h_AB : rayIntersectsSegment r ⟨triA o qA, triB o qB⟩)
    (h_CA : rayIntersectsSegment r ⟨triC o qC, triA o qA⟩) : False := by
  obtain ⟨h_AB1, h_AB2⟩ := rayHitsAB_implies o qA qB hqA0 hqB0 r hr h_AB
  obtain ⟨h_CA1, _⟩ := rayHitsCA_implies o qA qC hqA0 hqC0 hqC1 hqA1 r hr h_CA
  -- Equality: dy = qA * dx.
  have h_eq : r.direction.y = qA * r.direction.x := by linarith
  -- Case on sign of dx.
  rcases lt_trichotomy r.direction.x 0 with hdx_neg | hdx_zero | hdx_pos
  · -- dx < 0. From h_AB2: dy ≥ -(1+qB)*dx > 0 (since dx < 0, so -(1+qB)*dx > 0).
    -- From h_eq: dy = qA*dx ≤ 0. Contradiction.
    have h_pos : 0 < -(1 + qB) * r.direction.x := by nlinarith
    have h_dy_pos : 0 < r.direction.y := by linarith
    have h_dy_nonpos : r.direction.y ≤ 0 := by
      rw [h_eq]
      exact mul_nonpos_of_nonneg_of_nonpos hqA0 hdx_neg.le
    linarith
  · -- dx = 0: dy = qA*0 = 0. Contradicts direction_nonzero.
    have h_dy_zero : r.direction.y = 0 := by rw [h_eq, hdx_zero]; ring
    apply r.direction_nonzero
    ext
    · exact hdx_zero
    · exact h_dy_zero
  · -- dx > 0. Show triA on ray with t = 1/dx.
    apply h_A_avoid
    have hdx_ne : r.direction.x ≠ 0 := ne_of_gt hdx_pos
    refine ⟨1 / r.direction.x, ?_, ?_, ?_⟩
    · exact div_nonneg (by norm_num) hdx_pos.le
    · simp only [triA]
      rw [hr]
      have h_tdx : 1 / r.direction.x * r.direction.x = 1 := by field_simp
      linarith
    · simp only [triA]
      rw [hr, h_eq]
      have h_tdy : 1 / r.direction.x * (qA * r.direction.x) = qA := by field_simp
      linarith

/-! ### Base step: initial triangle polygon

Given rays with a common origin `o`, there exists a triangle polygon whose:
- vertices avoid all rays,
- every ray intersects some polygon segment,
- no segment contains `o` (so origin is strictly in the interior of the triangle),
- polygon has exactly 3 vertices. -/

private lemma exists_initial_triangle
    (rs : List Ray) (o : Vector2D)
    (h_origin : ∀ r ∈ rs, r.origin = o) :
    ∃ poly : Polygon,
      poly.vertices.length = 3 ∧
      (∀ v ∈ poly.toVertices, ∀ r ∈ rs, v ∉ r.toSet) ∧
      (∀ r ∈ rs, ∃ seg ∈ poly.segments, rayIntersectsSegment r seg) ∧
      (∀ seg ∈ poly.segments, o ∉ seg.toSet) ∧
      (∀ r ∈ rs, ∀ seg1 ∈ poly.segments, ∀ seg2 ∈ poly.segments,
         rayIntersectsSegment r seg1 → rayIntersectsSegment r seg2 → seg1 = seg2) ∧
      poly.segments.Nodup ∧
      (∀ seg ∈ poly.segments, ∀ t : ℚ,
         ¬ (o.x = (1-t)*seg.p1.x + t*seg.p2.x ∧
            o.y = (1-t)*seg.p1.y + t*seg.p2.y)) := by
  -- Step 1: find good qA, qB, qC in (0, 1/4) avoiding bad sets.
  have h_lt : (0 : ℚ) < 1/4 := by norm_num
  obtain ⟨qA, hqA_pos, hqA_lt, hqA_good⟩ :=
    exists_rat_in_open_ioo 0 (1/4) h_lt (badQsA rs)
  obtain ⟨qB, hqB_pos, hqB_lt, hqB_good⟩ :=
    exists_rat_in_open_ioo 0 (1/4) h_lt (badQsB rs)
  obtain ⟨qC, hqC_pos, hqC_lt, hqC_good⟩ :=
    exists_rat_in_open_ioo 0 (1/4) h_lt (badQsC rs)
  have hqA0 : 0 ≤ qA := le_of_lt hqA_pos
  have hqA1 : qA ≤ 1/4 := le_of_lt hqA_lt
  have hqB0 : 0 ≤ qB := le_of_lt hqB_pos
  have hqB1 : qB ≤ 1/4 := le_of_lt hqB_lt
  have hqC0 : 0 ≤ qC := le_of_lt hqC_pos
  have hqC1 : qC ≤ 1/4 := le_of_lt hqC_lt
  -- Step 2: define the polygon.
  refine ⟨⟨[triA o qA, triB o qB, triC o qC]⟩, ?_, ?_, ?_, ?_, ?_, ?_, ?_⟩
  · -- length = 3
    rfl
  · -- vertex avoidance
    intro v hv r hr
    simp only [Polygon.toVertices, Set.mem_setOf_eq, List.mem_cons, (List.not_mem_nil _),
      or_false] at hv
    rcases hv with rfl | rfl | rfl
    · exact triA_avoids_rays o qA rs h_origin hqA_good r hr
    · exact triB_avoids_rays o qB rs h_origin hqB_good r hr
    · exact triC_avoids_rays o qC rs h_origin hqC_good r hr
  · -- every ray hits some edge
    intro r hr
    have hr_origin := h_origin r hr
    -- segments of our polygon: [⟨triA, triB⟩, ⟨triB, triC⟩, ⟨triC, triA⟩]
    have hsegs : (⟨[triA o qA, triB o qB, triC o qC]⟩ : Polygon).segments =
        [⟨triA o qA, triB o qB⟩, ⟨triB o qB, triC o qC⟩, ⟨triC o qC, triA o qA⟩] := by
      simp [Polygon.segments, List.zip]
    rw [hsegs]
    -- Case analysis on r.direction.x sign
    by_cases hdxpos : r.direction.x > 0
    · -- dx > 0
      by_cases hslope : qA * r.direction.x ≤ r.direction.y
      · -- hits AB
        refine ⟨⟨triA o qA, triB o qB⟩, ?_, ?_⟩
        · simp
        · exact ray_hits_AB_of_dxpos o qA qB hqA0 hqA1 hqB0 hqB1 r hr_origin hdxpos hslope
      · -- hits CA
        push_neg at hslope
        refine ⟨⟨triC o qC, triA o qA⟩, ?_, ?_⟩
        · simp
        · exact ray_hits_CA_of_dxpos o qA qC hqA0 hqA1 hqC0 hqC1 r hr_origin hdxpos hslope
    · push_neg at hdxpos
      by_cases hdxneg : r.direction.x < 0
      · -- dx < 0
        by_cases h_AB : r.direction.y > -(1 + qB) * r.direction.x
        · -- hits AB
          refine ⟨⟨triA o qA, triB o qB⟩, ?_, ?_⟩
          · simp
          · exact ray_hits_AB_of_dxneg o qA qB hqA0 hqA1 hqB0 hqB1 r hr_origin hdxneg h_AB
        · push_neg at h_AB
          by_cases h_CA : r.direction.y < (1 - qC) * r.direction.x
          · -- hits CA
            refine ⟨⟨triC o qC, triA o qA⟩, ?_, ?_⟩
            · simp
            · exact ray_hits_CA_of_dxneg o qA qC hqA0 hqA1 hqC0 hqC1 r hr_origin hdxneg h_CA
          · -- hits BC
            push_neg at h_CA
            refine ⟨⟨triB o qB, triC o qC⟩, ?_, ?_⟩
            · simp
            · exact ray_hits_BC_of_dxneg o qB qC hqB0 hqB1 hqC0 hqC1 r hr_origin hdxneg h_CA h_AB
      · -- dx = 0
        push_neg at hdxneg
        have hdx_zero : r.direction.x = 0 := le_antisymm hdxpos hdxneg
        -- dy ≠ 0
        have hdy_ne : r.direction.y ≠ 0 := by
          intro h0
          apply r.direction_nonzero
          ext
          · exact hdx_zero
          · exact h0
        rcases lt_or_gt_of_ne hdy_ne with hdy_neg | hdy_pos
        · -- dy < 0: hits CA (use dxneg helper with dx=0 via trick? actually we need separate logic)
          -- When dx = 0, dy < 0: the ray goes straight down.
          -- Hits CA where (1-qA-qC)*dx - 2*dy*... let me use the existing ray_hits_CA_of_dxneg or dxpos?
          -- Actually, neither: those require dx != 0. Need new helper or direct.
          refine ⟨⟨triC o qC, triA o qA⟩, ?_, ?_⟩
          · simp
          · -- direct proof
            set α := r.direction.x * (1 + qA - qC) - 2 * r.direction.y with hα_def
            have hα_pos : 0 < α := by
              rw [hα_def, hdx_zero]
              linarith
            have hα_ne : α ≠ 0 := ne_of_gt hα_pos
            set t := (1 - qA - qC) / α
            have hqAC : 0 < 1 - qA - qC := by linarith
            have ht_nn : 0 ≤ t := div_nonneg hqAC.le hα_pos.le
            have h_tdx : t * r.direction.x = 0 := by rw [hdx_zero]; ring
            set s := (1 + t * r.direction.x) / 2 with hs_def
            have hs_half : s = 1/2 := by rw [hs_def, h_tdx]; ring
            have hs0 : 0 ≤ s := by rw [hs_half]; norm_num
            have hs1 : s ≤ 1 := by rw [hs_half]; norm_num
            apply ray_hits_seg_at r _ t s ht_nn hs0 hs1
            · simp only [triA, triC]; rw [hr_origin]
              rw [h_tdx]; rw [hs_half]; ring
            · simp only [triA, triC]; rw [hr_origin]
              rw [hs_half]
              have ht_mul : t * α = 1 - qA - qC := by
                show (1 - qA - qC) / α * α = 1 - qA - qC
                field_simp
              rw [hα_def, hdx_zero] at ht_mul
              linear_combination -ht_mul / 2
        · -- dy > 0: hits AB
          refine ⟨⟨triA o qA, triB o qB⟩, ?_, ?_⟩
          · simp
          · set α := 2 * r.direction.y + r.direction.x * (1 + qB - qA) with hα_def
            have hα_pos : 0 < α := by
              rw [hα_def, hdx_zero]
              linarith
            have hα_ne : α ≠ 0 := ne_of_gt hα_pos
            set t := (1 + qA + qB) / α
            have hqAB_nn : 0 ≤ 1 + qA + qB := by linarith
            have ht_nn : 0 ≤ t := div_nonneg hqAB_nn hα_pos.le
            have h_tdx : t * r.direction.x = 0 := by rw [hdx_zero]; ring
            set s := (1 - t * r.direction.x) / 2 with hs_def
            have hs_half : s = 1/2 := by rw [hs_def, h_tdx]; ring
            have hs0 : 0 ≤ s := by rw [hs_half]; norm_num
            have hs1 : s ≤ 1 := by rw [hs_half]; norm_num
            apply ray_hits_seg_at r _ t s ht_nn hs0 hs1
            · simp only [triA, triB]; rw [hr_origin]
              rw [h_tdx]; rw [hs_half]; ring
            · simp only [triA, triB]; rw [hr_origin]
              rw [hs_half]
              have ht_mul : t * α = 1 + qA + qB := by
                show (1 + qA + qB) / α * α = 1 + qA + qB
                field_simp
              rw [hα_def, hdx_zero] at ht_mul
              linear_combination ht_mul / 2
  · -- no segment contains origin
    intro seg hseg
    have hsegs : (⟨[triA o qA, triB o qB, triC o qC]⟩ : Polygon).segments =
        [⟨triA o qA, triB o qB⟩, ⟨triB o qB, triC o qC⟩, ⟨triC o qC, triA o qA⟩] := by
      simp [Polygon.segments, List.zip]
    rw [hsegs] at hseg
    simp at hseg
    intro ho
    rcases hseg with h1 | h2 | h3
    · -- seg = ⟨triA, triB⟩: o = (1-s)*triA + s*triB means 1-2s = 0 & qA+s(1+qB-qA) = 0
      subst h1
      obtain ⟨s, hs0, hs1, hx, hy⟩ := ho
      simp only [triA, triB] at hx hy
      have hs_half : s = 1/2 := by linarith
      rw [hs_half] at hy
      -- hy: o.y = (1 - 1/2) * (o.y + qA) + (1/2) * (o.y + 1 + qB)
      -- i.e., o.y = (o.y + qA)/2 + (o.y + 1 + qB)/2 = o.y + (qA + 1 + qB)/2
      -- so 0 = qA + qB + 1, but qA, qB ≥ 0.
      linarith
    · -- seg = ⟨triB, triC⟩: x-coord -1 ≠ 0.
      subst h2
      obtain ⟨s, hs0, hs1, hx, hy⟩ := ho
      simp only [triB, triC] at hx
      -- hx: o.x = (1-s)*(o.x - 1) + s*(o.x - 1) = o.x - 1. So 0 = -1, contradiction.
      linarith
    · -- seg = ⟨triC, triA⟩: similar to AB case.
      subst h3
      obtain ⟨s, hs0, hs1, hx, hy⟩ := ho
      simp only [triC, triA] at hx hy
      have hs_half : s = 1/2 := by linarith
      rw [hs_half] at hy
      linarith
  · -- uniqueness of the segment hit by each ray
    intro r hr seg1 hseg1 seg2 hseg2 h_r_seg1 h_r_seg2
    have hr_origin := h_origin r hr
    have hsegs : (⟨[triA o qA, triB o qB, triC o qC]⟩ : Polygon).segments =
        [⟨triA o qA, triB o qB⟩, ⟨triB o qB, triC o qC⟩, ⟨triC o qC, triA o qA⟩] := by
      simp [Polygon.segments, List.zip]
    rw [hsegs] at hseg1 hseg2
    simp at hseg1 hseg2
    have h_A_avoid : triA o qA ∉ r.toSet := triA_avoids_rays o qA rs h_origin hqA_good r hr
    have h_B_avoid : triB o qB ∉ r.toSet := triB_avoids_rays o qB rs h_origin hqB_good r hr
    have h_C_avoid : triC o qC ∉ r.toSet := triC_avoids_rays o qC rs h_origin hqC_good r hr
    rcases hseg1 with rfl | rfl | rfl <;>
      rcases hseg2 with rfl | rfl | rfl
    · rfl
    · exact absurd (not_both_AB_BC o qA qB qC hqA0 hqB0 hqC0 hqC1 r hr_origin h_B_avoid
        h_r_seg1 h_r_seg2) id
    · exact absurd (not_both_AB_CA o qA qB qC hqA0 hqB0 hqC0 hqA1 hqC1 r hr_origin h_A_avoid
        h_r_seg1 h_r_seg2) id
    · exact absurd (not_both_AB_BC o qA qB qC hqA0 hqB0 hqC0 hqC1 r hr_origin h_B_avoid
        h_r_seg2 h_r_seg1) id
    · rfl
    · exact absurd (not_both_BC_CA o qA qB qC hqA0 hqB0 hqC0 hqA1 hqC1 r hr_origin h_C_avoid
        h_r_seg1 h_r_seg2) id
    · exact absurd (not_both_AB_CA o qA qB qC hqA0 hqB0 hqC0 hqA1 hqC1 r hr_origin h_A_avoid
        h_r_seg2 h_r_seg1) id
    · exact absurd (not_both_BC_CA o qA qB qC hqA0 hqB0 hqC0 hqA1 hqC1 r hr_origin h_C_avoid
        h_r_seg2 h_r_seg1) id
    · rfl
  · -- Nodup: the three segments are distinct.
    have hsegs : (⟨[triA o qA, triB o qB, triC o qC]⟩ : Polygon).segments =
        [⟨triA o qA, triB o qB⟩, ⟨triB o qB, triC o qC⟩, ⟨triC o qC, triA o qA⟩] := by
      simp [Polygon.segments, List.zip]
    rw [hsegs]
    -- triA.x = o.x + 1, triB.x = o.x - 1, triC.x = o.x - 1.
    -- triB.y = o.y + 1 + qB, triC.y = o.y - 1 + qC, so triB.y ≠ triC.y.
    have hA_ne_B : triA o qA ≠ triB o qB := by
      intro h
      have : (triA o qA).x = (triB o qB).x := congrArg Vector2D.x h
      simp only [triA, triB] at this
      linarith
    have hA_ne_C : triA o qA ≠ triC o qC := by
      intro h
      have : (triA o qA).x = (triC o qC).x := congrArg Vector2D.x h
      simp only [triA, triC] at this
      linarith
    have hB_ne_C : triB o qB ≠ triC o qC := by
      intro h
      have : (triB o qB).y = (triC o qC).y := congrArg Vector2D.y h
      simp only [triB, triC] at this
      linarith
    have h1_ne_2 : (LineSegment.mk (triA o qA) (triB o qB)) ≠
        (LineSegment.mk (triB o qB) (triC o qC)) := by
      intro h
      have : triA o qA = triB o qB := (LineSegment.mk.injEq _ _ _ _).mp h |>.1
      exact hA_ne_B this
    have h1_ne_3 : (LineSegment.mk (triA o qA) (triB o qB)) ≠
        (LineSegment.mk (triC o qC) (triA o qA)) := by
      intro h
      have : triA o qA = triC o qC := (LineSegment.mk.injEq _ _ _ _).mp h |>.1
      exact hA_ne_C this
    have h2_ne_3 : (LineSegment.mk (triB o qB) (triC o qC)) ≠
        (LineSegment.mk (triC o qC) (triA o qA)) := by
      intro h
      have : triB o qB = triC o qC := (LineSegment.mk.injEq _ _ _ _).mp h |>.1
      exact hB_ne_C this
    simp [List.Nodup, h1_ne_2, h1_ne_3, h2_ne_3]
  · -- Line property: no segment's containing line passes through o.
    intro seg hseg t
    have hsegs : (⟨[triA o qA, triB o qB, triC o qC]⟩ : Polygon).segments =
        [⟨triA o qA, triB o qB⟩, ⟨triB o qB, triC o qC⟩, ⟨triC o qC, triA o qA⟩] := by
      simp [Polygon.segments, List.zip]
    rw [hsegs] at hseg
    simp at hseg
    intro ⟨hx, hy⟩
    rcases hseg with h1 | h2 | h3
    · -- seg = ⟨triA, triB⟩
      subst h1
      simp only [triA, triB] at hx hy
      -- hx: o.x = (1-t)*(o.x+1) + t*(o.x-1) → o.x = o.x + 1 - 2t → t = 1/2
      have ht_half : t = 1/2 := by linarith
      rw [ht_half] at hy
      -- hy: o.y = (1/2)*(o.y+qA) + (1/2)*(o.y+1+qB) → 0 = (qA + 1 + qB)/2
      linarith
    · -- seg = ⟨triB, triC⟩: x-coord -1 ≠ 0 regardless of t.
      subst h2
      simp only [triB, triC] at hx
      -- hx: o.x = (1-t)*(o.x-1) + t*(o.x-1) = o.x - 1 → 0 = -1
      linarith
    · -- seg = ⟨triC, triA⟩
      subst h3
      simp only [triC, triA] at hx hy
      -- hx: o.x = (1-t)*(o.x-1) + t*(o.x+1) → t = 1/2
      have ht_half : t = 1/2 := by linarith
      rw [ht_half] at hy
      -- hy: o.y = (1/2)*(o.y-1+qC) + (1/2)*(o.y+qA) → qA + qC = 1
      linarith

/-! ### Helpers for refinement step -/

/-- Splitting a segment at an internal point. -/
private lemma segment_split_set (a b pt : Vector2D)
    (h_pt : pt ∈ (LineSegment.mk a b).toSet) :
    (LineSegment.mk a pt).toSet ∪ (LineSegment.mk pt b).toSet =
    (LineSegment.mk a b).toSet := by
  obtain ⟨s, hs0, hs1, hsx, hsy⟩ := h_pt
  ext p; simp only [LineSegment.toSet, Set.mem_setOf_eq, Set.mem_union]
  constructor
  · rintro (⟨u, hu0, hu1, hux, huy⟩ | ⟨u, hu0, hu1, hux, huy⟩)
    · exact ⟨u * s, mul_nonneg hu0 hs0, by nlinarith,
            by rw [hux, hsx]; ring, by rw [huy, hsy]; ring⟩
    · exact ⟨s + u * (1 - s), by nlinarith, by nlinarith,
            by rw [hux, hsx]; ring, by rw [huy, hsy]; ring⟩
  · intro ⟨t, ht0, ht1, htx, hty⟩
    by_cases hts : t ≤ s
    · by_cases hs_zero : s = 0
      · have ht_zero : t = 0 := le_antisymm (hs_zero ▸ hts) ht0
        left
        exact ⟨0, le_refl 0, zero_le_one, by simp [htx, ht_zero], by simp [hty, ht_zero]⟩
      · left
        have hs_pos : (0 : ℚ) < s := lt_of_le_of_ne hs0 (Ne.symm hs_zero)
        exact ⟨t / s, div_nonneg ht0 (le_of_lt hs_pos),
               div_le_one_of_le₀ hts (le_of_lt hs_pos),
               by rw [htx, hsx]; field_simp; ring,
               by rw [hty, hsy]; field_simp; ring⟩
    · push_neg at hts
      by_cases hs1' : s = 1
      · linarith
      · right
        have h1s_pos : (0 : ℚ) < 1 - s := by linarith [lt_of_le_of_ne hs1 hs1']
        exact ⟨(t - s) / (1 - s),
               div_nonneg (le_of_lt (sub_pos.mpr hts)) (le_of_lt h1s_pos),
               div_le_one_of_le₀ (by linarith) (le_of_lt h1s_pos),
               by rw [htx, hsx]; field_simp; ring,
               by rw [hty, hsy]; field_simp; ring⟩

/-- Ray hits seg(a,b) iff it hits seg(a,pt) or seg(pt,b), when pt ∈ seg(a,b). -/
private lemma segment_split_rayIntersects (r : Ray) (a b pt : Vector2D)
    (h_pt : pt ∈ (LineSegment.mk a b).toSet) :
    rayIntersectsSegment r ⟨a, b⟩ ↔
    (rayIntersectsSegment r ⟨a, pt⟩ ∨ rayIntersectsSegment r ⟨pt, b⟩) := by
  have h_union := segment_split_set a b pt h_pt
  constructor
  · intro ⟨q, hq_ray, hq_seg⟩
    have : q ∈ (LineSegment.mk a pt).toSet ∪ (LineSegment.mk pt b).toSet :=
      h_union ▸ hq_seg
    rcases this with h | h
    · exact Or.inl ⟨q, hq_ray, h⟩
    · exact Or.inr ⟨q, hq_ray, h⟩
  · rintro (⟨q, hq_ray, hq_seg⟩ | ⟨q, hq_ray, hq_seg⟩)
    · exact ⟨q, hq_ray, h_union ▸ Set.mem_union_left _ hq_seg⟩
    · exact ⟨q, hq_ray, h_union ▸ Set.mem_union_right _ hq_seg⟩

/-- When pt is not on the ray, the ray cannot intersect both sub-segments. -/
private lemma ray_not_both_sub (r : Ray) (a b pt : Vector2D)
    (h_pt : pt ∈ (LineSegment.mk a b).toSet)
    (h_avoids : pt ∉ r.toSet) :
    ¬(rayIntersectsSegment r ⟨a, pt⟩ ∧ rayIntersectsSegment r ⟨pt, b⟩) := by
  intro ⟨⟨q1, hq1_ray, hq1_seg⟩, ⟨q2, hq2_ray, hq2_seg⟩⟩
  apply h_avoids
  obtain ⟨t1, ht1_0, ht1_1, hq1x, hq1y⟩ := hq1_seg
  obtain ⟨t2, ht2_0, ht2_1, hq2x, hq2y⟩ := hq2_seg
  obtain ⟨s, hs0, hs1, hptx, hpty⟩ := h_pt
  obtain ⟨tr1, htr1_0, hq1x_r, hq1y_r⟩ := hq1_ray
  obtain ⟨tr2, htr2_0, hq2x_r, hq2y_r⟩ := hq2_ray
  dsimp only at hq1x hq1y hq2x hq2y hptx hpty
  by_cases ht1_eq_1 : t1 = 1
  · subst ht1_eq_1; simp at hq1x hq1y
    exact ⟨tr1, htr1_0, by linarith, by linarith⟩
  by_cases ht2_eq_0 : t2 = 0
  · subst ht2_eq_0; simp at hq2x hq2y
    exact ⟨tr2, htr2_0, by linarith, by linarith⟩
  have ht1_lt_1 : t1 < 1 := lt_of_le_of_ne ht1_1 ht1_eq_1
  have ht2_pos : (0 : ℚ) < t2 := lt_of_le_of_ne ht2_0 (Ne.symm ht2_eq_0)
  set D := s * (1 - t1) + t2 * (1 - s) with hD_def
  have hD_pos : 0 < D := by
    rw [hD_def]
    by_cases hs_eq_0 : s = 0
    · simp [hs_eq_0]; linarith
    · have : s > 0 := lt_of_le_of_ne hs0 (Ne.symm hs_eq_0)
      nlinarith
  have hD_ne : D ≠ 0 := ne_of_gt hD_pos
  set u := s * (1 - t1) / D with hu_def
  have hcomb_x : pt.x = (1 - u) * q1.x + u * q2.x := by
    rw [hq1x, hq2x, hu_def]; field_simp [hD_ne]; rw [hD_def, hptx]; ring
  have hcomb_y : pt.y = (1 - u) * q1.y + u * q2.y := by
    rw [hq1y, hq2y, hu_def]; field_simp [hD_ne]; rw [hD_def, hpty]; ring
  refine ⟨(1 - u) * tr1 + u * tr2, ?_, ?_, ?_⟩
  · have hu_0 : 0 ≤ u := div_nonneg (by nlinarith) (le_of_lt hD_pos)
    have hu_1 : u ≤ 1 := by
      rw [hu_def]; exact div_le_one_of_le₀ (by rw [hD_def]; nlinarith) (le_of_lt hD_pos)
    nlinarith
  · rw [hcomb_x, hq1x_r, hq2x_r]; ring
  · rw [hcomb_y, hq1y_r, hq2y_r]; ring

/-- Count: segRaysCount splits nicely when pt is on seg and not on any ray. -/
private lemma segRaysCount_split (rs : List Ray) (a b pt : Vector2D)
    (h_pt : pt ∈ (LineSegment.mk a b).toSet)
    (h_avoids : ∀ r ∈ rs, pt ∉ r.toSet) :
    segRaysCount ⟨a, pt⟩ rs + segRaysCount ⟨pt, b⟩ rs = segRaysCount ⟨a, b⟩ rs := by
  unfold segRaysCount
  induction rs with
  | nil => simp
  | cons r rest ih =>
    have h_avoids_rest : ∀ r' ∈ rest, pt ∉ r'.toSet :=
      fun r' hr' => h_avoids r' (List.mem_cons_of_mem _ hr')
    have h_avoids_r : pt ∉ r.toSet := h_avoids r (List.mem_cons_self _ _)
    have h_split := segment_split_rayIntersects r a b pt h_pt
    have h_not_both := ray_not_both_sub r a b pt h_pt h_avoids_r
    simp only [List.countP_cons]
    have ih' := ih h_avoids_rest
    by_cases h1 : rayIntersectsSegment r ⟨a, pt⟩ <;>
      by_cases h2 : rayIntersectsSegment r ⟨pt, b⟩ <;>
      simp_all <;> omega

/-- If two distinct rays both hit the segment, the count is ≥ 2. -/
private lemma segRaysCount_ge_two (rs : List Ray) (seg : LineSegment)
    (_h_distinct : rs.Pairwise (fun r1 r2 => r1.toSet ≠ r2.toSet))
    (r1 r2 : Ray) (hr1 : r1 ∈ rs) (hr2 : r2 ∈ rs) (hne : r1 ≠ r2)
    (hr1_int : rayIntersectsSegment r1 seg)
    (hr2_int : rayIntersectsSegment r2 seg) :
    2 ≤ segRaysCount seg rs := by
  unfold segRaysCount
  -- Count of the filter on [r1, r2] is 2 (assuming r1 ≠ r2 implies different).
  -- Actually we just need both r1 and r2 to be distinct elements in rs with the predicate true.
  -- Use List.Perm or a direct counting argument.
  -- We use: countP p rs ≥ countP p [r1, r2] when [r1, r2] is a "sublist".
  -- Actually a simpler argument: since r1 ≠ r2, they are distinct elements.
  -- Use List.Pairwise.sublist or similar.
  -- Direct: we show that the filter contains r1 and r2 as distinct.
  have h1_dec : decide (rayIntersectsSegment r1 seg) = true := by
    simp [hr1_int]
  have h2_dec : decide (rayIntersectsSegment r2 seg) = true := by
    simp [hr2_int]
  -- rs.filter ... contains r1 and r2 as distinct elements.
  -- Length of filter ≥ 2.
  have h_countP_ge : ∀ (l : List Ray) (ra rb : Ray),
      ra ∈ l → rb ∈ l → ra ≠ rb →
      decide (rayIntersectsSegment ra seg) = true →
      decide (rayIntersectsSegment rb seg) = true →
      2 ≤ l.countP (fun r => decide (rayIntersectsSegment r seg)) := by
    intro l
    induction l with
    | nil => intro ra rb h1 _ _ _ _; exact absurd h1 (List.not_mem_nil _)
    | cons x tail ih =>
      intro ra rb h1 h2 hne hd1 hd2
      rw [List.countP_cons]
      rcases List.mem_cons.mp h1 with rfl | h1'
      · -- ra = x
        rcases List.mem_cons.mp h2 with rfl | h2'
        · exact absurd rfl hne
        · -- ra = x, rb ∈ tail
          have hd : decide (rayIntersectsSegment ra seg) = true := hd1
          have hcount : 1 ≤ tail.countP (fun r => decide (rayIntersectsSegment r seg)) := by
            have hmem : rb ∈ tail.filter (fun r => decide (rayIntersectsSegment r seg)) := by
              rw [List.mem_filter]; exact ⟨h2', hd2⟩
            rw [List.countP_eq_length_filter]
            exact List.length_pos_of_mem hmem
          have hbool : (decide (rayIntersectsSegment ra seg) : Bool) = true := hd
          rw [if_pos hbool]
          omega
      · rcases List.mem_cons.mp h2 with rfl | h2'
        · -- rb = x, ra ∈ tail
          have hd : decide (rayIntersectsSegment rb seg) = true := hd2
          have hcount : 1 ≤ tail.countP (fun r => decide (rayIntersectsSegment r seg)) := by
            have hmem : ra ∈ tail.filter (fun r => decide (rayIntersectsSegment r seg)) := by
              rw [List.mem_filter]; exact ⟨h1', hd1⟩
            rw [List.countP_eq_length_filter]
            exact List.length_pos_of_mem hmem
          have hbool : (decide (rayIntersectsSegment rb seg) : Bool) = true := hd
          rw [if_pos hbool]
          omega
        · -- both ra, rb ∈ tail
          have hih := ih ra rb h1' h2' hne hd1 hd2
          split <;> omega
  exact h_countP_ge rs r1 r2 hr1 hr2 hne h1_dec h2_dec

/-- A point q on segment seg that is avoided by all rays and is not the origin. -/
private lemma exists_good_pt_on_seg (rs : List Ray) (o : Vector2D)
    (_h_origin : ∀ r ∈ rs, r.origin = o)
    (seg : LineSegment)
    (h_p1 : ∀ r ∈ rs, seg.p1 ∉ r.toSet)
    (h_p2 : ∀ r ∈ rs, seg.p2 ∉ r.toSet)
    (h_p1_ne : seg.p1 ≠ seg.p2)
    (h_no_origin : o ∉ seg.toSet) :
    ∃ pt : Vector2D, pt ∈ seg.toSet ∧
      (∀ r ∈ rs, pt ∉ r.toSet) ∧
      pt ≠ o ∧
      pt ≠ seg.p1 ∧ pt ≠ seg.p2 := by
  -- Parameterize pt(s) = (1-s)*p1 + s*p2 for s ∈ (0, 1).
  -- For each ray r, the bad s values form a set. If the segment's line equals the ray's line,
  -- then seg endpoints are on line, but must have t < 0 in ray's parameterization (since not on ray),
  -- so NO bad s. Otherwise, at most one bad s.
  -- Plus: bad s where o is on seg, but we know o ∉ seg.toSet so no such bad s.
  -- So collect finitely many bad rationals in [0, 1] and pick a good one using exists_rat_in_open_ioo.
  -- For simplicity, we'll compute bad s values as follows:
  -- For ray r, if ray intersects segment, pick the s value(s).
  -- Actually, just take rs.length + 1 bad s-values (one per ray, pick whatever s works).
  -- Use exists_rat_in_open_ioo 0 1 with a finite bad set of size |rs|.
  -- Build the bad finset: for each ray that hits the segment, find ONE bad s.
  -- For the argument, we use a noncomputable bad set. Simpler to just use exists_rat_in_open_ioo
  -- with a bad set that's a "witness" for ray intersections. But we need to prove disjointness.
  -- Alternative cleaner approach:
  -- For each ray r, define bad_s(r) = {s : 0 ≤ s ≤ 1, (1-s)*p1 + s*p2 ∈ r.toSet} ∪ {0, 1 if necessary}.
  -- We claim |bad_s(r)| ≤ 1 when the segment's line differs from ray's line.
  -- If segment's line = ray's line, then since seg.p1 ∉ ray, there's no bad s.
  -- So |bad_s(r)| ≤ 1 for each ray.
  -- Bad set: union over rays, plus origin point (if any).
  -- Concrete approach: For each ray r, use the filterMap technique.
  -- For each ray that INTERSECTS segment, determine the unique bad s.
  -- Use: for a ray r with pt = (1-s)*p1 + s*p2 ∈ r.toSet, we have:
  --   (1-s)*p1.x + s*p2.x = r.origin.x + t*r.direction.x
  --   (1-s)*p1.y + s*p2.y = r.origin.y + t*r.direction.y for some t ≥ 0.
  -- Cross: r.direction.y * ((1-s)*p1.x + s*p2.x - r.origin.x) = r.direction.x * ((1-s)*p1.y + s*p2.y - r.origin.y)
  -- Simplify: this is linear in s (with coefficients involving seg endpoints and ray).
  -- The coefficient of s:
  -- r.direction.y * (p2.x - p1.x) - r.direction.x * (p2.y - p1.y)
  -- = r.direction.y * dx_seg - r.direction.x * dy_seg, where dx_seg = p2.x - p1.x, dy_seg = p2.y - p1.y.
  -- When this is nonzero, s is uniquely determined.
  -- When this is zero, the ray is parallel to the segment, and the bad s set is either empty (seg not on ray's line) or possibly not finite.
  -- But in the second case, seg.p1 would be on ray (since it's on the same line and we need t ≥ 0 eventually)... well actually not necessarily.
  -- This is getting complex. Let me use a VERY different approach:
  -- We don't need to FULLY avoid all rays. We just need to avoid finitely many specific BAD rationals.
  -- Approach: Use that each ray intersects the segment set in at most one "inner point",
  -- and collect those.
  -- Actually, let me use the cleaner approach of concrete bad s values:
  -- For each ray r in rs, define a specific bad s = f(r) where f returns a rational if the ray's direction is "transverse",
  -- and None otherwise (in which case we claim no bad s exists for this ray).
  -- This requires case analysis. Let me just define the bad set as:
  -- bad_s = {s ∈ ℚ : 0 ≤ s ≤ 1 ∧ ∃ r ∈ rs, (1-s)*p1 + s*p2 ∈ r.toSet}
  -- We show this is finite by mapping each ray to a specific s-value (or nothing).
  -- Let me take the approach of the initial triangle: define a bad finset by filterMap.
  --
  -- Specifically, for each ray r, compute:
  --   det = r.direction.x * (p2.y - p1.y) - r.direction.y * (p2.x - p1.x)
  -- If det ≠ 0, the bad s is:
  --   s = (r.direction.y * (p1.x - r.origin.x) - r.direction.x * (p1.y - r.origin.y)) /
  --       (r.direction.y * (p2.x - p1.x) - r.direction.x * (p2.y - p1.y))
  -- (Note sign: the coefficient of s in the cross product is -det.)
  -- If det = 0: the segment is parallel to ray. Bad s set is empty by h_p1 (seg.p1 ∉ r.toSet).
  --   Wait, not true. If det=0, could be parallel but offset OR same line.
  --   If same line, seg.p1 is on line, but we also need t ≥ 0 for ray to include seg.p1.
  --   Given h_p1: seg.p1 ∉ r.toSet, so if on same line, t < 0 for seg.p1.
  --   Similarly for seg.p2.
  --   Then whether any interior point could have t ≥ 0? Convex combo of two points with t < 0 gives t < 0, so no intermediate point has t ≥ 0. So no bad s.
  -- If different lines but parallel, then 0 intersections.
  -- So if det = 0, no bad s. Great.
  set denom : Ray → ℚ := fun r =>
    r.direction.x * (seg.p2.y - seg.p1.y) - r.direction.y * (seg.p2.x - seg.p1.x)
  set badSFor : Ray → Option ℚ := fun r =>
    if h : denom r ≠ 0 then
      some ((r.direction.y * (seg.p1.x - r.origin.x) - r.direction.x * (seg.p1.y - r.origin.y)) / denom r)
    else none
  set badS : Finset ℚ := (rs.filterMap badSFor).toFinset
  have h_lt : (0 : ℚ) < 1 := by norm_num
  obtain ⟨s, hs_pos, hs_lt, hs_good⟩ := exists_rat_in_open_ioo 0 1 h_lt badS
  refine ⟨⟨(1 - s) * seg.p1.x + s * seg.p2.x, (1 - s) * seg.p1.y + s * seg.p2.y⟩, ?_, ?_, ?_, ?_, ?_⟩
  · -- pt ∈ seg.toSet
    refine ⟨s, hs_pos.le, hs_lt.le, rfl, rfl⟩
  · -- ∀ r ∈ rs, pt ∉ r.toSet
    intro r hr h_on_r
    obtain ⟨t, ht_nn, htx, hty⟩ := h_on_r
    -- pt.x = r.origin.x + t * r.direction.x, and pt.x = (1-s)*p1.x + s*p2.x
    dsimp only at htx hty
    -- Cross: r.direction.y * pt.x - r.direction.x * pt.y = r.direction.y * r.origin.x - r.direction.x * r.origin.y
    -- Substituting pt.x:
    -- r.direction.y * ((1-s)*p1.x + s*p2.x) - r.direction.x * ((1-s)*p1.y + s*p2.y) =
    -- r.direction.y * r.origin.x - r.direction.x * r.origin.y
    -- Rearranging for s:
    -- s * (r.direction.y * (p2.x - p1.x) - r.direction.x * (p2.y - p1.y)) =
    -- r.direction.y * r.origin.x - r.direction.x * r.origin.y - r.direction.y * p1.x + r.direction.x * p1.y
    -- s * (-denom r) = r.direction.y * (r.origin.x - p1.x) - r.direction.x * (r.origin.y - p1.y)
    -- s * (-denom r) = -(r.direction.y * (p1.x - r.origin.x) - r.direction.x * (p1.y - r.origin.y))
    -- i.e., s * denom r = r.direction.y * (p1.x - r.origin.x) - r.direction.x * (p1.y - r.origin.y).
    have h_key : s * denom r =
        r.direction.y * (seg.p1.x - r.origin.x) - r.direction.x * (seg.p1.y - r.origin.y) := by
      have hcross : r.direction.y * ((1-s)*seg.p1.x + s*seg.p2.x) -
                    r.direction.x * ((1-s)*seg.p1.y + s*seg.p2.y) =
                    r.direction.y * r.origin.x - r.direction.x * r.origin.y := by
        rw [htx, hty]; ring
      show s * denom r = _
      simp only [denom]
      linarith
    -- Case on denom r = 0 or not
    by_cases hdenom : denom r = 0
    · -- denom = 0: then RHS of h_key must also be 0.
      -- Then: r.direction.y * (p1.x - r.origin.x) = r.direction.x * (p1.y - r.origin.y)
      -- This means seg.p1 is on the line of the ray.
      -- Given h_p1 (seg.p1 ∉ r.toSet), we derive contradiction.
      -- Let's first derive that RHS of h_key is 0.
      rw [hdenom] at h_key
      have hrhs_zero : r.direction.y * (seg.p1.x - r.origin.x) - r.direction.x * (seg.p1.y - r.origin.y) = 0 := by linarith
      -- Now seg.p1 is on ray's line.
      -- To derive seg.p1 ∈ r.toSet, we need t' ≥ 0 such that:
      --   seg.p1.x = r.origin.x + t' * r.direction.x
      --   seg.p1.y = r.origin.y + t' * r.direction.y
      -- From hrhs_zero:
      --   r.direction.y * (seg.p1.x - r.origin.x) = r.direction.x * (seg.p1.y - r.origin.y).
      -- Also, denom r = 0 means:
      --   r.direction.x * (seg.p2.y - seg.p1.y) = r.direction.y * (seg.p2.x - seg.p1.x).
      -- The ray's direction is nonzero: r.direction ≠ 0. Pick a nonzero coordinate.
      have hdir := r.direction_nonzero
      by_cases hdx : r.direction.x = 0
      · have hdy_ne : r.direction.y ≠ 0 := by
          intro h
          apply hdir
          ext; exact hdx; exact h
        -- seg.p1.x = r.origin.x (from hrhs_zero with direction_x = 0).
        have h_p1x : seg.p1.x = r.origin.x := by
          rw [hdx] at hrhs_zero
          have : r.direction.y * (seg.p1.x - r.origin.x) = 0 := by linarith
          have := (mul_eq_zero.mp this).resolve_left hdy_ne
          linarith
        -- Also seg.p2.x = seg.p1.x from denom = 0 (with direction_x = 0).
        have h_p2x : seg.p2.x = seg.p1.x := by
          simp only [denom] at hdenom
          rw [hdx] at hdenom
          have : r.direction.y * (seg.p2.x - seg.p1.x) = 0 := by linarith
          have := (mul_eq_zero.mp this).resolve_left hdy_ne
          linarith
        -- Now pt.x = r.origin.x.
        -- pt.y = (1-s)*p1.y + s*p2.y = r.origin.y + t * r.direction.y
        -- We need t ≥ 0. But we already HAVE t from the assumption h_on_r.
        -- Wait, we have t ≥ 0. So pt is in r.toSet (which is what we assumed, contradiction to prove).
        -- Actually we need the CONTRADICTION, not just to show pt ∉ r.toSet.
        -- We're proving: pt ∉ r.toSet. The assumption is h_on_r : pt ∈ r.toSet, with witness t.
        -- To derive a contradiction, we use: seg.p1 is on r.
        -- Specifically, since seg.p1 has the same x as o, we need:
        -- seg.p1.x - r.origin.x = 0 = 0 * r.direction.x. ✓
        -- seg.p1.y - r.origin.y = t' * r.direction.y for some t'.
        -- Since r.direction.y ≠ 0, we get t' = (seg.p1.y - r.origin.y) / r.direction.y.
        -- Sign of t': same as sign of seg.p1.y - r.origin.y (assuming r.direction.y > 0 or < 0).
        -- Hmm, we don't know t' ≥ 0 directly. We need more info.
        -- Let's use t ≥ 0 (from h_on_r) and derive contradiction.
        -- pt.y is between p1.y and p2.y (as convex combo, if s ∈ [0,1]).
        -- In particular, if both p1.y ≥ r.origin.y and p2.y ≥ r.origin.y, then pt.y ≥ r.origin.y too.
        -- But this doesn't immediately yield what we want.
        -- Different tactic: we SHOW seg.p1 ∈ r.toSet, contradicting h_p1.
        -- The key insight: if seg.p1 is on the same line as the ray AND pt = (1-s)*seg.p1 + s*seg.p2 ∈ r.toSet,
        -- AND seg.p2 is also on the same line, then both seg.p1 and seg.p2 are either on the ray or not.
        -- If pt ∈ r.toSet, with s ∈ (0, 1), then... we need a linear combination argument.
        -- pt.y = (1-s)*p1.y + s*p2.y = r.origin.y + t*r.direction.y.
        -- If seg.p1 is at ray parameter t1, seg.p2 at t2 (could be negative or positive), then:
        -- pt.y - r.origin.y = (1-s)*(p1.y - r.origin.y) + s*(p2.y - r.origin.y) = t*r.direction.y
        -- i.e., (1-s)*t1 + s*t2 = t ≥ 0.
        -- But we DON'T know t1 and t2 are ≥ 0... they could be negative.
        -- Actually this argument isn't immediately giving contradiction.
        -- Wait, let me re-examine h_p1: seg.p1 ∉ r.toSet.
        -- r.toSet = {o' + t' * r.direction | t' ≥ 0}.
        -- If seg.p1 on line (t1 exists such that p1 = o' + t1 * r.direction), and t1 ≥ 0, then p1 ∈ r.toSet.
        -- So h_p1 gives us: either p1 is not on the line at all (but we derived that's false) OR t1 < 0.
        -- Similarly for p2: either p2 not on line, or t2 < 0.
        -- Since p1 and p2 ARE on the line (we're in this case), t1 < 0 and t2 < 0.
        -- Then (1-s)*t1 + s*t2 = t < 0 (convex combo of negatives is negative). But t ≥ 0. Contradiction!
        -- Let me formalize this.
        -- t = (pt.y - r.origin.y) / r.direction.y
        -- pt.y - r.origin.y = (1-s)*(p1.y - r.origin.y) + s*(p2.y - r.origin.y).
        -- So t * r.direction.y = (1-s)*(p1.y - r.origin.y) + s*(p2.y - r.origin.y).
        -- Let t1 = (p1.y - r.origin.y) / r.direction.y, t2 = (p2.y - r.origin.y) / r.direction.y.
        -- Then p1 = r.origin + t1 * r.direction (since p1.x = r.origin.x and p1.y = r.origin.y + t1 * r.direction.y).
        -- And t = (1-s)*t1 + s*t2.
        -- We need t1 ≥ 0 OR t1 < 0.
        -- Since p1 ∉ r.toSet, and p1 matches the parameterization form with t1, we need t1 < 0.
        -- Similarly t2 < 0. Then (1-s)*t1 + s*t2 < 0, but t ≥ 0. Contradiction.
        -- Let me try to formalize this. But first: we need s ∈ (0, 1) for the strict convex combo argument.
        -- Actually, s ∈ (0, 1) by hs_pos and hs_lt.
        set t1 := (seg.p1.y - r.origin.y) / r.direction.y with ht1_def
        set t2 := (seg.p2.y - r.origin.y) / r.direction.y with ht2_def
        -- Verify p1 = r.origin + t1 * r.direction
        have hp1_param_x : seg.p1.x = r.origin.x + t1 * r.direction.x := by
          rw [hdx]; rw [h_p1x]; ring
        have hp1_param_y : seg.p1.y = r.origin.y + t1 * r.direction.y := by
          rw [ht1_def]; field_simp; try linarith
        have hp2_param_x : seg.p2.x = r.origin.x + t2 * r.direction.x := by
          rw [hdx]; rw [h_p2x, h_p1x]; ring
        have hp2_param_y : seg.p2.y = r.origin.y + t2 * r.direction.y := by
          rw [ht2_def]; field_simp; try linarith
        -- Since p1 ∉ r.toSet, t1 < 0.
        have ht1_neg : t1 < 0 := by
          by_contra h
          push_neg at h
          exact h_p1 r hr ⟨t1, h, hp1_param_x, hp1_param_y⟩
        have ht2_neg : t2 < 0 := by
          by_contra h
          push_neg at h
          exact h_p2 r hr ⟨t2, h, hp2_param_x, hp2_param_y⟩
        -- Now t = (1-s)*t1 + s*t2 (using hty).
        have ht_eq : t * r.direction.y = (1-s)*t1*r.direction.y + s*t2*r.direction.y := by
          have := hty
          rw [hp1_param_y, hp2_param_y] at this
          linarith
        have ht_val : t = (1-s)*t1 + s*t2 := by
          have : r.direction.y * (t - ((1-s)*t1 + s*t2)) = 0 := by linarith
          have : t - ((1-s)*t1 + s*t2) = 0 := by
            rcases mul_eq_zero.mp this with h | h
            · exact absurd h hdy_ne
            · exact h
          linarith
        have : t < 0 := by
          rw [ht_val]
          have : (1 - s) * t1 < 0 := mul_neg_of_pos_of_neg (by linarith) ht1_neg
          have : s * t2 < 0 := mul_neg_of_pos_of_neg hs_pos ht2_neg
          linarith
        linarith
      · -- direction.x ≠ 0: use x-coordinates similarly
        have hdx_ne : r.direction.x ≠ 0 := hdx
        -- From hrhs_zero:
        -- r.direction.y * (seg.p1.x - r.origin.x) = r.direction.x * (seg.p1.y - r.origin.y).
        -- seg.p1 is on line.
        set t1 := (seg.p1.x - r.origin.x) / r.direction.x with ht1_def
        set t2 := (seg.p2.x - r.origin.x) / r.direction.x with ht2_def
        have hp1_param_x : seg.p1.x = r.origin.x + t1 * r.direction.x := by
          rw [ht1_def]; field_simp; try linarith
        have hp1_param_y : seg.p1.y = r.origin.y + t1 * r.direction.y := by
          -- From hrhs_zero: r.direction.y * (p1.x - r.origin.x) = r.direction.x * (p1.y - r.origin.y)
          -- So (p1.y - r.origin.y) = r.direction.y * (p1.x - r.origin.x) / r.direction.x = r.direction.y * t1.
          have : r.direction.x * (seg.p1.y - r.origin.y) = r.direction.y * (seg.p1.x - r.origin.x) := by linarith
          rw [ht1_def]
          field_simp
          linarith
        have hp2_param_x : seg.p2.x = r.origin.x + t2 * r.direction.x := by
          rw [ht2_def]; field_simp; try linarith
        have hp2_param_y : seg.p2.y = r.origin.y + t2 * r.direction.y := by
          -- denom r = 0 gives: r.direction.x * (p2.y - p1.y) = r.direction.y * (p2.x - p1.x)
          simp only [denom] at hdenom
          have hdenom' : r.direction.x * (seg.p2.y - seg.p1.y) =
                         r.direction.y * (seg.p2.x - seg.p1.x) := by linarith
          -- (p2.y - r.origin.y) = (p2.y - p1.y) + (p1.y - r.origin.y)
          --                    = r.direction.y / r.direction.x * (p2.x - p1.x) + r.direction.y * t1
          --                    = r.direction.y * (t2 - t1) + r.direction.y * t1 = r.direction.y * t2.
          have h_diff : r.direction.x * (seg.p2.y - r.origin.y) = r.direction.y * (seg.p2.x - r.origin.x) := by
            have h_p1_rel : r.direction.x * (seg.p1.y - r.origin.y) = r.direction.y * (seg.p1.x - r.origin.x) := by linarith
            linarith
          rw [ht2_def]
          field_simp
          linarith
        have ht1_neg : t1 < 0 := by
          by_contra h
          push_neg at h
          exact h_p1 r hr ⟨t1, h, hp1_param_x, hp1_param_y⟩
        have ht2_neg : t2 < 0 := by
          by_contra h
          push_neg at h
          exact h_p2 r hr ⟨t2, h, hp2_param_x, hp2_param_y⟩
        have ht_eq : t * r.direction.x = (1-s)*t1*r.direction.x + s*t2*r.direction.x := by
          have := htx
          rw [hp1_param_x, hp2_param_x] at this
          linarith
        have ht_val : t = (1-s)*t1 + s*t2 := by
          have : r.direction.x * (t - ((1-s)*t1 + s*t2)) = 0 := by linarith
          have : t - ((1-s)*t1 + s*t2) = 0 := by
            rcases mul_eq_zero.mp this with h | h
            · exact absurd h hdx_ne
            · exact h
          linarith
        have : t < 0 := by
          rw [ht_val]
          have h1 : (1 - s) * t1 < 0 := mul_neg_of_pos_of_neg (by linarith) ht1_neg
          have h2 : s * t2 < 0 := mul_neg_of_pos_of_neg hs_pos ht2_neg
          linarith
        linarith
    · -- denom r ≠ 0: then s is uniquely determined by h_key.
      -- s should equal badSFor r which is in badS, contradicting hs_good.
      have h_s_eq : s = (r.direction.y * (seg.p1.x - r.origin.x) -
                         r.direction.x * (seg.p1.y - r.origin.y)) / denom r := by
        have h_denom_ne := hdenom
        field_simp
        linarith
      have h_s_in : s ∈ badS := by
        simp only [badS, List.mem_toFinset, List.mem_filterMap]
        refine ⟨r, hr, ?_⟩
        simp only [badSFor]
        rw [dif_pos hdenom]
        exact congrArg some h_s_eq.symm
      exact hs_good h_s_in
  · -- pt ≠ o: suppose pt = o, then o ∈ seg.toSet, contradicting h_no_origin.
    intro hpt_eq
    apply h_no_origin
    refine ⟨s, hs_pos.le, hs_lt.le, ?_, ?_⟩
    · exact (congrArg Vector2D.x hpt_eq).symm
    · exact (congrArg Vector2D.y hpt_eq).symm
  · -- pt ≠ seg.p1: since s > 0.
    intro hpt_eq
    have hx_eq : (1 - s) * seg.p1.x + s * seg.p2.x = seg.p1.x := congrArg Vector2D.x hpt_eq
    have hy_eq : (1 - s) * seg.p1.y + s * seg.p2.y = seg.p1.y := congrArg Vector2D.y hpt_eq
    have h_x : s * (seg.p2.x - seg.p1.x) = 0 := by linarith
    have h_y : s * (seg.p2.y - seg.p1.y) = 0 := by linarith
    have hs_ne : s ≠ 0 := ne_of_gt hs_pos
    have hx' : seg.p2.x = seg.p1.x := by
      rcases mul_eq_zero.mp h_x with h | h
      · exact absurd h hs_ne
      · linarith
    have hy' : seg.p2.y = seg.p1.y := by
      rcases mul_eq_zero.mp h_y with h | h
      · exact absurd h hs_ne
      · linarith
    apply h_p1_ne
    ext; exact hx'.symm; exact hy'.symm
  · -- pt ≠ seg.p2: since s < 1.
    intro hpt_eq
    have hx_eq : (1 - s) * seg.p1.x + s * seg.p2.x = seg.p2.x := congrArg Vector2D.x hpt_eq
    have hy_eq : (1 - s) * seg.p1.y + s * seg.p2.y = seg.p2.y := congrArg Vector2D.y hpt_eq
    have h_x : (1 - s) * (seg.p1.x - seg.p2.x) = 0 := by linarith
    have h_y : (1 - s) * (seg.p1.y - seg.p2.y) = 0 := by linarith
    have h1s_ne : (1 - s) ≠ 0 := by
      intro h; linarith
    have hx' : seg.p1.x = seg.p2.x := by
      rcases mul_eq_zero.mp h_x with h | h
      · exact absurd h h1s_ne
      · linarith
    have hy' : seg.p1.y = seg.p2.y := by
      rcases mul_eq_zero.mp h_y with h | h
      · exact absurd h h1s_ne
      · linarith
    apply h_p1_ne
    ext; exact hx'; exact hy'

/-- Helper: If seg ∈ poly.segments, then seg.p1, seg.p2 ∈ poly.vertices. -/
private lemma segment_endpoints_in_vertices (poly : Polygon) (seg : LineSegment)
    (hseg : seg ∈ poly.segments) : seg.p1 ∈ poly.vertices ∧ seg.p2 ∈ poly.vertices := by
  unfold Polygon.segments at hseg
  match hvs : poly.vertices with
  | [] => rw [hvs] at hseg; simp at hseg
  | [v] => rw [hvs] at hseg; simp at hseg
  | v :: w :: rest =>
    rw [hvs] at hseg
    simp only [List.mem_map, Prod.exists] at hseg
    obtain ⟨a, b, hab_zip, rfl⟩ := hseg
    have ha : a ∈ v :: w :: rest := List.of_mem_zip hab_zip |>.1
    have hb : b ∈ (w :: rest) ++ [v] := List.of_mem_zip hab_zip |>.2
    rw [List.mem_append] at hb
    simp only []
    refine ⟨ha, ?_⟩
    rcases hb with hb | hb
    · exact List.mem_cons_of_mem _ hb
    · simp at hb; subst hb; exact (List.mem_cons_self _ _)

/-- polyRaysExcess in terms of segments list. -/
private lemma polyRaysExcess_unfold (poly : Polygon) (rs : List Ray) :
    polyRaysExcess poly rs = (poly.segments.map fun seg => segRaysCount seg rs - 1).sum := rfl

/-- Existence of a point pt ∈ seg.toSet strictly between two intersection points, avoiding all rays.
    This is the key lemma for strict decrease in the measure. -/
private lemma exists_good_pt_between (rs : List Ray) (o : Vector2D)
    (h_origin : ∀ r ∈ rs, r.origin = o)
    (h_toSet_ne : ∀ r1_in r2_in : Ray, r1_in ∈ rs → r2_in ∈ rs → r1_in ≠ r2_in → r1_in.toSet ≠ r2_in.toSet)
    (seg : LineSegment)
    (h_p1 : ∀ r ∈ rs, seg.p1 ∉ r.toSet)
    (h_p2 : ∀ r ∈ rs, seg.p2 ∉ r.toSet)
    (h_p1_ne : seg.p1 ≠ seg.p2)
    (h_no_origin : o ∉ seg.toSet)
    (r1 r2 : Ray) (hr1 : r1 ∈ rs) (hr2 : r2 ∈ rs) (hne : r1 ≠ r2)
    (hr1_int : rayIntersectsSegment r1 seg) (hr2_int : rayIntersectsSegment r2 seg)
    (excluded : List Vector2D) :
    ∃ pt : Vector2D, pt ∈ seg.toSet ∧
      (∀ r ∈ rs, pt ∉ r.toSet) ∧
      pt ≠ o ∧
      pt ≠ seg.p1 ∧ pt ≠ seg.p2 ∧
      (∀ v ∈ excluded, pt ≠ v) ∧
      ((rayIntersectsSegment r1 ⟨seg.p1, pt⟩ ∧ rayIntersectsSegment r2 ⟨pt, seg.p2⟩) ∨
       (rayIntersectsSegment r2 ⟨seg.p1, pt⟩ ∧ rayIntersectsSegment r1 ⟨pt, seg.p2⟩)) := by
  -- Step 1: extract q1 ∈ r1 ∩ seg with parameter s1, and similarly q2, s2.
  obtain ⟨q1, hq1_r1, hq1_seg⟩ := hr1_int
  obtain ⟨q2, hq2_r2, hq2_seg⟩ := hr2_int
  obtain ⟨s1, hs1_0, hs1_1, hs1x, hs1y⟩ := hq1_seg
  obtain ⟨s2, hs2_0, hs2_1, hs2x, hs2y⟩ := hq2_seg
  -- Step 2: s1 ≠ s2 because q1 ≠ q2 (distinct rays → common point is o, but o ∉ seg).
  have hs_ne : s1 ≠ s2 := by
    intro h_eq
    have hq_eq : q1 = q2 := by
      ext
      · rw [hs1x, hs2x, h_eq]
      · rw [hs1y, hs2y, h_eq]
    have hq1_r2 : q1 ∈ r2.toSet := hq_eq ▸ hq2_r2
    have h_tsne : r1.toSet ≠ r2.toSet := h_toSet_ne r1 r2 hr1 hr2 hne
    have h_same_origin : sameOrigin r1 r2 := by
      unfold sameOrigin
      rw [h_origin r1 hr1, h_origin r2 hr2]
    have h_q1_is_o := distinct_common_point_is_origin r1 r2 h_same_origin h_tsne q1 hq1_r1 hq1_r2
    apply h_no_origin
    have h_q1_eq_o : q1 = o := by rw [h_q1_is_o]; exact h_origin r1 hr1
    rw [← h_q1_eq_o]
    refine ⟨s1, hs1_0, hs1_1, hs1x, hs1y⟩
  -- Step 3: WLOG s1 < s2 (possibly swap).
  -- Actually, we need a more uniform statement. Let me introduce α = min(s1, s2), β = max(s1, s2).
  set α := min s1 s2 with hα_def
  set β := max s1 s2 with hβ_def
  have hαβ_lt : α < β := by
    rcases lt_or_gt_of_ne hs_ne with h | h
    · rw [hα_def, hβ_def, min_eq_left h.le, max_eq_right h.le]; exact h
    · rw [hα_def, hβ_def, min_eq_right h.le, max_eq_left h.le]; exact h
  -- Step 4: Define the bad set for each ray using segment parameterization.
  -- bad s: s gives a point on some ray. Use the formula from exists_good_pt_on_seg.
  set denom : Ray → ℚ := fun r =>
    r.direction.x * (seg.p2.y - seg.p1.y) - r.direction.y * (seg.p2.x - seg.p1.x) with hdenom_def
  set badSFor : Ray → Option ℚ := fun r =>
    if h : denom r ≠ 0 then
      some ((r.direction.y * (seg.p1.x - r.origin.x) - r.direction.x * (seg.p1.y - r.origin.y)) / denom r)
    else none
  -- For each excluded vertex v, the parameter s such that pt = v (if it exists on the line).
  -- Since seg.p1 ≠ seg.p2, at least one of the coordinates differs. Use x if p2.x ≠ p1.x,
  -- otherwise use y.
  set excludedSFor : Vector2D → Option ℚ := fun v =>
    if seg.p2.x - seg.p1.x ≠ 0 then
      some ((v.x - seg.p1.x) / (seg.p2.x - seg.p1.x))
    else if seg.p2.y - seg.p1.y ≠ 0 then
      some ((v.y - seg.p1.y) / (seg.p2.y - seg.p1.y))
    else
      none
  set badS : Finset ℚ := ((rs.filterMap badSFor) ++ (excluded.filterMap excludedSFor)).toFinset
  -- Find s strictly between α and β, not in badS.
  obtain ⟨s, hs_α, hs_β, hs_good⟩ := exists_rat_in_open_ioo α β hαβ_lt badS
  -- Verify hs_pos: 0 ≤ s.
  have hs_pos : 0 ≤ s := by
    have hα_nn : 0 ≤ α := le_min hs1_0 hs2_0
    linarith
  have hs_lt : s ≤ 1 := by
    have hβ_le : β ≤ 1 := max_le hs1_1 hs2_1
    linarith
  -- In fact, we need s > 0 (strictly) and s < 1 (strictly) for pt ≠ p1, p2.
  -- Actually α > 0 is not given. But if s > 0 since α = 0 or α > 0? Hmm, s > α, which could be 0. So s could be 0 or positive.
  -- Wait, we derived s > α (strict). If α = 0, then s > 0. If α > 0, also s > 0.
  -- So s > 0. Good.
  have hs_pos_strict : 0 < s := by
    have hα_nn : 0 ≤ α := le_min hs1_0 hs2_0
    linarith
  have hs_lt_strict : s < 1 := by
    have hβ_le : β ≤ 1 := max_le hs1_1 hs2_1
    linarith
  -- Define pt as the point at parameter s.
  let pt : Vector2D := ⟨(1 - s) * seg.p1.x + s * seg.p2.x, (1 - s) * seg.p1.y + s * seg.p2.y⟩
  have hpt_seg : pt ∈ seg.toSet := ⟨s, hs_pos, hs_lt, rfl, rfl⟩
  -- Prove pt avoids all rays.
  have hpt_avoids : ∀ r ∈ rs, pt ∉ r.toSet := by
    intro r hr h_on_r
    obtain ⟨t, ht_nn, htx, hty⟩ := h_on_r
    dsimp only [pt] at htx hty
    have h_key : s * denom r =
        r.direction.y * (seg.p1.x - r.origin.x) - r.direction.x * (seg.p1.y - r.origin.y) := by
      have hcross : r.direction.y * ((1-s)*seg.p1.x + s*seg.p2.x) -
                    r.direction.x * ((1-s)*seg.p1.y + s*seg.p2.y) =
                    r.direction.y * r.origin.x - r.direction.x * r.origin.y := by
        rw [htx, hty]; ring
      show s * denom r = _
      simp only [denom]
      linarith
    by_cases hdenom : denom r = 0
    · -- Same analysis as before: seg.p1 would be on the ray's line with t1 < 0. Contradiction.
      rw [hdenom] at h_key
      have hrhs_zero : r.direction.y * (seg.p1.x - r.origin.x) - r.direction.x * (seg.p1.y - r.origin.y) = 0 := by linarith
      have hdir := r.direction_nonzero
      by_cases hdx : r.direction.x = 0
      · have hdy_ne : r.direction.y ≠ 0 := by
          intro h; apply hdir; ext; exact hdx; exact h
        have h_p1x : seg.p1.x = r.origin.x := by
          rw [hdx] at hrhs_zero
          have : r.direction.y * (seg.p1.x - r.origin.x) = 0 := by linarith
          have := (mul_eq_zero.mp this).resolve_left hdy_ne
          linarith
        have h_p2x : seg.p2.x = seg.p1.x := by
          simp only [denom] at hdenom
          rw [hdx] at hdenom
          have : r.direction.y * (seg.p2.x - seg.p1.x) = 0 := by linarith
          have := (mul_eq_zero.mp this).resolve_left hdy_ne
          linarith
        set t1 := (seg.p1.y - r.origin.y) / r.direction.y with ht1_def
        set t2 := (seg.p2.y - r.origin.y) / r.direction.y with ht2_def
        have hp1_param_x : seg.p1.x = r.origin.x + t1 * r.direction.x := by
          rw [hdx]; rw [h_p1x]; ring
        have hp1_param_y : seg.p1.y = r.origin.y + t1 * r.direction.y := by
          rw [ht1_def]; field_simp; try linarith
        have hp2_param_x : seg.p2.x = r.origin.x + t2 * r.direction.x := by
          rw [hdx]; rw [h_p2x, h_p1x]; ring
        have hp2_param_y : seg.p2.y = r.origin.y + t2 * r.direction.y := by
          rw [ht2_def]; field_simp; try linarith
        have ht1_neg : t1 < 0 := by
          by_contra h
          push_neg at h
          exact h_p1 r hr ⟨t1, h, hp1_param_x, hp1_param_y⟩
        have ht2_neg : t2 < 0 := by
          by_contra h
          push_neg at h
          exact h_p2 r hr ⟨t2, h, hp2_param_x, hp2_param_y⟩
        have ht_eq : t * r.direction.y = (1-s)*t1*r.direction.y + s*t2*r.direction.y := by
          have := hty
          rw [hp1_param_y, hp2_param_y] at this
          linarith
        have ht_val : t = (1-s)*t1 + s*t2 := by
          have : r.direction.y * (t - ((1-s)*t1 + s*t2)) = 0 := by linarith
          have : t - ((1-s)*t1 + s*t2) = 0 := by
            rcases mul_eq_zero.mp this with h | h
            · exact absurd h hdy_ne
            · exact h
          linarith
        have h_neg : t < 0 := by
          rw [ht_val]
          have h1 : (1 - s) * t1 < 0 := mul_neg_of_pos_of_neg (by linarith) ht1_neg
          have h2 : s * t2 < 0 := mul_neg_of_pos_of_neg hs_pos_strict ht2_neg
          linarith
        linarith
      · have hdx_ne : r.direction.x ≠ 0 := hdx
        set t1 := (seg.p1.x - r.origin.x) / r.direction.x with ht1_def
        set t2 := (seg.p2.x - r.origin.x) / r.direction.x with ht2_def
        have hp1_param_x : seg.p1.x = r.origin.x + t1 * r.direction.x := by
          rw [ht1_def]; field_simp; try linarith
        have hp1_param_y : seg.p1.y = r.origin.y + t1 * r.direction.y := by
          have : r.direction.x * (seg.p1.y - r.origin.y) = r.direction.y * (seg.p1.x - r.origin.x) := by linarith
          rw [ht1_def]
          field_simp
          linarith
        have hp2_param_x : seg.p2.x = r.origin.x + t2 * r.direction.x := by
          rw [ht2_def]; field_simp; try linarith
        have hp2_param_y : seg.p2.y = r.origin.y + t2 * r.direction.y := by
          simp only [denom] at hdenom
          have hdenom' : r.direction.x * (seg.p2.y - seg.p1.y) =
                         r.direction.y * (seg.p2.x - seg.p1.x) := by linarith
          have h_diff : r.direction.x * (seg.p2.y - r.origin.y) = r.direction.y * (seg.p2.x - r.origin.x) := by
            have h_p1_rel : r.direction.x * (seg.p1.y - r.origin.y) = r.direction.y * (seg.p1.x - r.origin.x) := by linarith
            linarith
          rw [ht2_def]
          field_simp
          linarith
        have ht1_neg : t1 < 0 := by
          by_contra h
          push_neg at h
          exact h_p1 r hr ⟨t1, h, hp1_param_x, hp1_param_y⟩
        have ht2_neg : t2 < 0 := by
          by_contra h
          push_neg at h
          exact h_p2 r hr ⟨t2, h, hp2_param_x, hp2_param_y⟩
        have ht_eq : t * r.direction.x = (1-s)*t1*r.direction.x + s*t2*r.direction.x := by
          have := htx
          rw [hp1_param_x, hp2_param_x] at this
          linarith
        have ht_val : t = (1-s)*t1 + s*t2 := by
          have : r.direction.x * (t - ((1-s)*t1 + s*t2)) = 0 := by linarith
          have : t - ((1-s)*t1 + s*t2) = 0 := by
            rcases mul_eq_zero.mp this with h | h
            · exact absurd h hdx_ne
            · exact h
          linarith
        have h_neg : t < 0 := by
          rw [ht_val]
          have h1 : (1 - s) * t1 < 0 := mul_neg_of_pos_of_neg (by linarith) ht1_neg
          have h2 : s * t2 < 0 := mul_neg_of_pos_of_neg hs_pos_strict ht2_neg
          linarith
        linarith
    · have h_s_eq : s = (r.direction.y * (seg.p1.x - r.origin.x) -
                         r.direction.x * (seg.p1.y - r.origin.y)) / denom r := by
        field_simp
        linarith
      have h_s_in : s ∈ badS := by
        simp only [badS, List.mem_toFinset, List.mem_append, List.mem_filterMap]
        left
        refine ⟨r, hr, ?_⟩
        simp only [badSFor]
        rw [dif_pos hdenom]
        exact congrArg some h_s_eq.symm
      exact hs_good h_s_in
  -- pt ≠ o
  have hpt_ne_o : pt ≠ o := by
    intro hpt_eq
    apply h_no_origin
    refine ⟨s, hs_pos, hs_lt, ?_, ?_⟩
    · exact (congrArg Vector2D.x hpt_eq).symm
    · exact (congrArg Vector2D.y hpt_eq).symm
  -- pt ≠ seg.p1
  have hpt_ne_p1 : pt ≠ seg.p1 := by
    intro hpt_eq
    have hx_eq : (1 - s) * seg.p1.x + s * seg.p2.x = seg.p1.x := congrArg Vector2D.x hpt_eq
    have hy_eq : (1 - s) * seg.p1.y + s * seg.p2.y = seg.p1.y := congrArg Vector2D.y hpt_eq
    have h_x : s * (seg.p2.x - seg.p1.x) = 0 := by linarith
    have h_y : s * (seg.p2.y - seg.p1.y) = 0 := by linarith
    have hs_ne' : s ≠ 0 := ne_of_gt hs_pos_strict
    have hx' : seg.p2.x = seg.p1.x := by
      rcases mul_eq_zero.mp h_x with h | h
      · exact absurd h hs_ne'
      · linarith
    have hy' : seg.p2.y = seg.p1.y := by
      rcases mul_eq_zero.mp h_y with h | h
      · exact absurd h hs_ne'
      · linarith
    apply h_p1_ne
    ext; exact hx'.symm; exact hy'.symm
  have hpt_ne_p2 : pt ≠ seg.p2 := by
    intro hpt_eq
    have hx_eq : (1 - s) * seg.p1.x + s * seg.p2.x = seg.p2.x := congrArg Vector2D.x hpt_eq
    have hy_eq : (1 - s) * seg.p1.y + s * seg.p2.y = seg.p2.y := congrArg Vector2D.y hpt_eq
    have h_x : (1 - s) * (seg.p1.x - seg.p2.x) = 0 := by linarith
    have h_y : (1 - s) * (seg.p1.y - seg.p2.y) = 0 := by linarith
    have h1s_ne : (1 - s) ≠ 0 := by intro h; linarith
    have hx' : seg.p1.x = seg.p2.x := by
      rcases mul_eq_zero.mp h_x with h | h
      · exact absurd h h1s_ne
      · linarith
    have hy' : seg.p1.y = seg.p2.y := by
      rcases mul_eq_zero.mp h_y with h | h
      · exact absurd h h1s_ne
      · linarith
    apply h_p1_ne
    ext; exact hx'; exact hy'
  -- pt ≠ any excluded vertex v
  have hpt_ne_excluded : ∀ v ∈ excluded, pt ≠ v := by
    intro v hv_ex hpt_eq
    have hx_eq : (1 - s) * seg.p1.x + s * seg.p2.x = v.x := congrArg Vector2D.x hpt_eq
    have hy_eq : (1 - s) * seg.p1.y + s * seg.p2.y = v.y := congrArg Vector2D.y hpt_eq
    -- Since seg.p1 ≠ seg.p2, either p2.x - p1.x ≠ 0 or p2.y - p1.y ≠ 0.
    by_cases hdx : seg.p2.x - seg.p1.x ≠ 0
    · -- Use x-coord to derive s = (v.x - p1.x)/(p2.x - p1.x).
      have hs_val : s = (v.x - seg.p1.x) / (seg.p2.x - seg.p1.x) := by
        field_simp
        linarith
      have h_s_in : s ∈ badS := by
        simp only [badS, List.mem_toFinset, List.mem_append, List.mem_filterMap]
        right
        refine ⟨v, hv_ex, ?_⟩
        simp only [excludedSFor]
        rw [if_pos hdx]
        exact congrArg some hs_val.symm
      exact hs_good h_s_in
    · -- seg.p2.x - seg.p1.x = 0, so seg.p1.x = seg.p2.x.
      push_neg at hdx
      -- Then seg.p1 ≠ seg.p2 implies seg.p1.y ≠ seg.p2.y.
      have hdy : seg.p2.y - seg.p1.y ≠ 0 := by
        intro hdy_zero
        apply h_p1_ne
        ext
        · linarith
        · linarith
      have hs_val : s = (v.y - seg.p1.y) / (seg.p2.y - seg.p1.y) := by
        field_simp
        linarith
      have h_s_in : s ∈ badS := by
        simp only [badS, List.mem_toFinset, List.mem_append, List.mem_filterMap]
        right
        refine ⟨v, hv_ex, ?_⟩
        simp only [excludedSFor]
        rw [if_neg (by push_neg; exact hdx)]
        rw [if_pos hdy]
        exact congrArg some hs_val.symm
      exact hs_good h_s_in
  -- Now show r1 hits sub1 and r2 hits sub2, using s1 ≤ s or s2 ≤ s (based on WLOG).
  -- Case: s1 < s2. Then s1 ≤ s (since s > α = s1) and s ≤ s2 (since s < β = s2).
  -- So q1 (at param s1) ∈ sub1 ([0, s]). And q2 (at param s2) ∈ sub2 ([s, 1]).
  -- We show this by computing: ⟨seg.p1, pt⟩'s parameterization.
  -- Sub1 = ⟨seg.p1, pt⟩. A point q has form (1-u)*seg.p1 + u*pt = (1-u)*seg.p1 + u*((1-s)*seg.p1 + s*seg.p2)
  --   = (1 - us)*seg.p1 + us*seg.p2. So q ∈ sub1 iff param u ∈ [0, 1], i.e., point has seg-parameter u*s ∈ [0, s].
  -- We want q1 ∈ sub1, i.e., s1 ≤ s. Then u = s1/s ∈ [0, 1].
  -- Case analysis based on which of s1, s2 is smaller:
  refine ⟨pt, hpt_seg, hpt_avoids, hpt_ne_o, hpt_ne_p1, hpt_ne_p2, hpt_ne_excluded, ?_⟩
  rcases lt_or_gt_of_ne hs_ne with hs12 | hs12
  · -- s1 < s2: α = s1, β = s2. Left disjunct.
    have hα_eq : α = s1 := min_eq_left hs12.le
    have hβ_eq : β = s2 := max_eq_right hs12.le
    have hs1_lt_s : s1 < s := by rw [hα_eq] at hs_α; exact hs_α
    have hs_lt_s2 : s < s2 := by rw [hβ_eq] at hs_β; exact hs_β
    have hs_ne_0 : s ≠ 0 := ne_of_gt hs_pos_strict
    have h1s_ne : 1 - s ≠ 0 := by intro h; linarith
    left
    refine ⟨?_, ?_⟩
    · -- r1 hits sub1 at q1 (via u1 = s1/s)
      refine ⟨q1, hq1_r1, ?_⟩
      refine ⟨s1 / s, div_nonneg hs1_0 hs_pos_strict.le, ?_, ?_, ?_⟩
      · exact div_le_one_of_le₀ hs1_lt_s.le hs_pos_strict.le
      · show q1.x = (1 - s1 / s) * seg.p1.x + s1 / s * pt.x
        rw [hs1x]
        show (1 - s1) * seg.p1.x + s1 * seg.p2.x = (1 - s1 / s) * seg.p1.x + s1 / s * pt.x
        dsimp only [pt]
        field_simp
        ring
      · show q1.y = (1 - s1 / s) * seg.p1.y + s1 / s * pt.y
        rw [hs1y]
        show (1 - s1) * seg.p1.y + s1 * seg.p2.y = (1 - s1 / s) * seg.p1.y + s1 / s * pt.y
        dsimp only [pt]
        field_simp
        ring
    · -- r2 hits sub2 at q2 (via u2 = (s2 - s)/(1 - s))
      refine ⟨q2, hq2_r2, ?_⟩
      refine ⟨(s2 - s) / (1 - s), div_nonneg (by linarith) (by linarith), ?_, ?_, ?_⟩
      · apply div_le_one_of_le₀ _ (by linarith)
        linarith
      · show q2.x = (1 - (s2 - s) / (1 - s)) * pt.x + (s2 - s) / (1 - s) * seg.p2.x
        rw [hs2x]
        show (1 - s2) * seg.p1.x + s2 * seg.p2.x = (1 - (s2 - s) / (1 - s)) * pt.x + (s2 - s) / (1 - s) * seg.p2.x
        dsimp only [pt]
        field_simp
        ring
      · show q2.y = (1 - (s2 - s) / (1 - s)) * pt.y + (s2 - s) / (1 - s) * seg.p2.y
        rw [hs2y]
        show (1 - s2) * seg.p1.y + s2 * seg.p2.y = (1 - (s2 - s) / (1 - s)) * pt.y + (s2 - s) / (1 - s) * seg.p2.y
        dsimp only [pt]
        field_simp
        ring
  · -- s2 < s1: right disjunct (r2 on sub1, r1 on sub2).
    have hα_eq : α = s2 := min_eq_right hs12.le
    have hβ_eq : β = s1 := max_eq_left hs12.le
    have hs2_lt_s : s2 < s := by rw [hα_eq] at hs_α; exact hs_α
    have hs_lt_s1 : s < s1 := by rw [hβ_eq] at hs_β; exact hs_β
    have hs_ne_0 : s ≠ 0 := ne_of_gt hs_pos_strict
    have h1s_ne : 1 - s ≠ 0 := by intro h; linarith
    right
    refine ⟨?_, ?_⟩
    · -- r2 hits sub1 at q2 (via u2 = s2/s)
      refine ⟨q2, hq2_r2, ?_⟩
      refine ⟨s2 / s, div_nonneg hs2_0 hs_pos_strict.le, ?_, ?_, ?_⟩
      · exact div_le_one_of_le₀ hs2_lt_s.le hs_pos_strict.le
      · show q2.x = (1 - s2 / s) * seg.p1.x + s2 / s * pt.x
        rw [hs2x]
        show (1 - s2) * seg.p1.x + s2 * seg.p2.x = (1 - s2 / s) * seg.p1.x + s2 / s * pt.x
        dsimp only [pt]
        field_simp
        ring
      · show q2.y = (1 - s2 / s) * seg.p1.y + s2 / s * pt.y
        rw [hs2y]
        show (1 - s2) * seg.p1.y + s2 * seg.p2.y = (1 - s2 / s) * seg.p1.y + s2 / s * pt.y
        dsimp only [pt]
        field_simp
        ring
    · -- r1 hits sub2 at q1 (via u1 = (s1 - s)/(1 - s))
      refine ⟨q1, hq1_r1, ?_⟩
      refine ⟨(s1 - s) / (1 - s), div_nonneg (by linarith) (by linarith), ?_, ?_, ?_⟩
      · apply div_le_one_of_le₀ _ (by linarith)
        linarith
      · show q1.x = (1 - (s1 - s) / (1 - s)) * pt.x + (s1 - s) / (1 - s) * seg.p2.x
        rw [hs1x]
        show (1 - s1) * seg.p1.x + s1 * seg.p2.x = (1 - (s1 - s) / (1 - s)) * pt.x + (s1 - s) / (1 - s) * seg.p2.x
        dsimp only [pt]
        field_simp
        ring
      · show q1.y = (1 - (s1 - s) / (1 - s)) * pt.y + (s1 - s) / (1 - s) * seg.p2.y
        rw [hs1y]
        show (1 - s1) * seg.p1.y + s1 * seg.p2.y = (1 - (s1 - s) / (1 - s)) * pt.y + (s1 - s) / (1 - s) * seg.p2.y
        dsimp only [pt]
        field_simp
        ring

/-! ### Refinement step

Given a polygon satisfying base invariants plus a "bad" segment hit by ≥ 2 rays,
there exists a refined polygon with strictly smaller measure preserving the
invariants. -/

private lemma refinement_step
    (rs : List Ray) (o : Vector2D)
    (h_origin : ∀ r ∈ rs, r.origin = o)
    (h_distinct : rs.Pairwise (fun r1 r2 => r1.toSet ≠ r2.toSet))
    (poly : Polygon)
    (h_len : poly.vertices.length ≥ 2)
    (h_verts : ∀ v ∈ poly.toVertices, ∀ r ∈ rs, v ∉ r.toSet)
    (h_every : ∀ r ∈ rs, ∃ seg ∈ poly.segments, rayIntersectsSegment r seg)
    (h_no_origin : ∀ seg ∈ poly.segments, o ∉ seg.toSet)
    (h_nodup : poly.segments.Nodup)
    (h_unique : ∀ r ∈ rs, ∀ seg1 ∈ poly.segments, ∀ seg2 ∈ poly.segments,
        rayIntersectsSegment r seg1 → rayIntersectsSegment r seg2 → seg1 = seg2)
    (h_lines : ∀ seg ∈ poly.segments, ∀ t : ℚ,
        ¬ (o.x = (1-t)*seg.p1.x + t*seg.p2.x ∧ o.y = (1-t)*seg.p1.y + t*seg.p2.y))
    (h_bad : ∃ seg ∈ poly.segments, ∃ r1 ∈ rs, ∃ r2 ∈ rs, r1 ≠ r2 ∧
       rayIntersectsSegment r1 seg ∧ rayIntersectsSegment r2 seg) :
    ∃ poly' : Polygon,
      polyRaysExcess poly' rs < polyRaysExcess poly rs ∧
      poly'.vertices.length ≥ 2 ∧
      (∀ v ∈ poly'.toVertices, ∀ r ∈ rs, v ∉ r.toSet) ∧
      (∀ r ∈ rs, ∃ seg ∈ poly'.segments, rayIntersectsSegment r seg) ∧
      (∀ seg ∈ poly'.segments, o ∉ seg.toSet) ∧
      poly'.segments.Nodup ∧
      (∀ r ∈ rs, ∀ seg1 ∈ poly'.segments, ∀ seg2 ∈ poly'.segments,
          rayIntersectsSegment r seg1 → rayIntersectsSegment r seg2 → seg1 = seg2) ∧
      (∀ seg ∈ poly'.segments, ∀ t : ℚ,
          ¬ (o.x = (1-t)*seg.p1.x + t*seg.p2.x ∧ o.y = (1-t)*seg.p1.y + t*seg.p2.y)) := by
  -- Convert h_distinct (Pairwise) into the form needed by exists_good_pt_between.
  have h_sym : Symmetric (fun r1 r2 : Ray => r1.toSet ≠ r2.toSet) := by
    intro r1 r2 h; exact h.symm
  have h_toSet_ne : ∀ r1 r2 : Ray, r1 ∈ rs → r2 ∈ rs → r1 ≠ r2 → r1.toSet ≠ r2.toSet := by
    intro r1 r2 hr1 hr2 hne
    exact h_distinct.forall h_sym hr1 hr2 hne
  -- Extract witness segment and rays from h_bad.
  obtain ⟨seg, hseg, r1, hr1, r2, hr2, hne, hr1_int, hr2_int⟩ := h_bad
  -- Step 1: Set up assumptions for exists_good_pt_between.
  obtain ⟨hp1_in, hp2_in⟩ := segment_endpoints_in_vertices poly seg hseg
  have hp1_verts : seg.p1 ∈ poly.toVertices := hp1_in
  have hp2_verts : seg.p2 ∈ poly.toVertices := hp2_in
  have h_p1_rays : ∀ r ∈ rs, seg.p1 ∉ r.toSet := h_verts seg.p1 hp1_verts
  have h_p2_rays : ∀ r ∈ rs, seg.p2 ∉ r.toSet := h_verts seg.p2 hp2_verts
  have h_no_origin_seg : o ∉ seg.toSet := h_no_origin seg hseg
  -- seg.p1 ≠ seg.p2: since seg has a ray hitting it (r1), and r1 has origin o, and some points
  -- of seg are ≠ o (because o ∉ seg.toSet, so at least one non-degenerate point).
  -- If p1 = p2 then seg.toSet = {p1}, but r1 hits seg, so the unique point p1 ∈ r1.toSet,
  -- contradicting h_p1_rays.
  have h_p1_ne : seg.p1 ≠ seg.p2 := by
    intro hp_eq
    obtain ⟨q, hq_ray, hq_seg⟩ := hr1_int
    obtain ⟨s, hs0, hs1, hsx, hsy⟩ := hq_seg
    have hqx : q.x = seg.p1.x := by rw [hsx, hp_eq]; ring
    have hqy : q.y = seg.p1.y := by rw [hsy, hp_eq]; ring
    have hq_eq_p1 : q = seg.p1 := by
      ext
      · exact hqx
      · exact hqy
    have : seg.p1 ∈ r1.toSet := hq_eq_p1 ▸ hq_ray
    exact h_p1_rays r1 hr1 this
  -- Apply exists_good_pt_between to get pt.
  obtain ⟨pt, hpt_seg, hpt_avoids, hpt_ne_o, hpt_ne_p1, hpt_ne_p2, hpt_ne_verts, hpt_splits⟩ :=
    exists_good_pt_between rs o h_origin h_toSet_ne seg h_p1_rays h_p2_rays h_p1_ne
      h_no_origin_seg r1 r2 hr1 hr2 hne hr1_int hr2_int poly.vertices
  -- Get segRaysCount sub-segment counts ≥ 1.
  have h_sub1_count : 1 ≤ segRaysCount ⟨seg.p1, pt⟩ rs := by
    rcases hpt_splits with ⟨h_r1_sub1, _⟩ | ⟨h_r2_sub1, _⟩
    · unfold segRaysCount
      have hmem : r1 ∈ rs.filter (fun r => decide (rayIntersectsSegment r ⟨seg.p1, pt⟩)) := by
        rw [List.mem_filter]
        refine ⟨hr1, ?_⟩
        exact decide_eq_true h_r1_sub1
      rw [List.countP_eq_length_filter]
      exact List.length_pos_of_mem hmem
    · unfold segRaysCount
      have hmem : r2 ∈ rs.filter (fun r => decide (rayIntersectsSegment r ⟨seg.p1, pt⟩)) := by
        rw [List.mem_filter]
        refine ⟨hr2, ?_⟩
        exact decide_eq_true h_r2_sub1
      rw [List.countP_eq_length_filter]
      exact List.length_pos_of_mem hmem
  have h_sub2_count : 1 ≤ segRaysCount ⟨pt, seg.p2⟩ rs := by
    rcases hpt_splits with ⟨_, h_r2_sub2⟩ | ⟨_, h_r1_sub2⟩
    · unfold segRaysCount
      have hmem : r2 ∈ rs.filter (fun r => decide (rayIntersectsSegment r ⟨pt, seg.p2⟩)) := by
        rw [List.mem_filter]
        refine ⟨hr2, ?_⟩
        exact decide_eq_true h_r2_sub2
      rw [List.countP_eq_length_filter]
      exact List.length_pos_of_mem hmem
    · unfold segRaysCount
      have hmem : r1 ∈ rs.filter (fun r => decide (rayIntersectsSegment r ⟨pt, seg.p2⟩)) := by
        rw [List.mem_filter]
        refine ⟨hr1, ?_⟩
        exact decide_eq_true h_r1_sub2
      rw [List.countP_eq_length_filter]
      exact List.length_pos_of_mem hmem
  -- seg itself has count ≥ 2.
  have h_seg_count : 2 ≤ segRaysCount seg rs := by
    apply segRaysCount_ge_two rs seg h_distinct r1 r2 hr1 hr2 hne hr1_int hr2_int
  -- Define poly'.
  refine ⟨polygonRefinement poly seg pt, ?_, ?_, ?_, ?_, ?_, ?_, ?_, ?_⟩
  -- (a) Strict decrease of polyRaysExcess.
  · -- Use the permutation identity.
    have h_perm := polygonRefinement_segments_perm poly seg pt hseg hpt_seg
    -- Let f = (segRaysCount s rs - 1).
    let f : LineSegment → ℕ := fun s => segRaysCount s rs - 1
    -- Apply map to both sides of Perm, then sum_eq.
    have h_perm_map := h_perm.map f
    have h_sum_eq := h_perm_map.sum_eq
    -- Simplify h_sum_eq.
    simp only [List.map_append, List.sum_append, List.map_cons, List.map_nil,
               List.sum_cons, List.sum_nil, add_zero] at h_sum_eq
    -- h_sum_eq: (polygonRefinement..segments.map f).sum + f seg =
    --              (poly.segments.map f).sum + (f ⟨p1, pt⟩ + f ⟨pt, p2⟩)
    -- Unfold f in h_sum_eq.
    have hfdef : ∀ s, f s = segRaysCount s rs - 1 := fun _ => rfl
    rw [hfdef seg, hfdef (LineSegment.mk seg.p1 pt), hfdef (LineSegment.mk pt seg.p2)] at h_sum_eq
    -- Split count identity: segRaysCount ⟨p1, pt⟩ + segRaysCount ⟨pt, p2⟩ = segRaysCount ⟨p1, p2⟩.
    have hsplit := segRaysCount_split rs seg.p1 seg.p2 pt hpt_seg hpt_avoids
    -- Rewrite segRaysCount ⟨seg.p1, seg.p2⟩ rs = segRaysCount seg rs via seg = ⟨seg.p1, seg.p2⟩.
    have hseg_eq : LineSegment.mk seg.p1 seg.p2 = seg := by cases seg; rfl
    rw [hseg_eq] at hsplit
    -- hsplit : segRaysCount ⟨p1, pt⟩ rs + segRaysCount ⟨pt, p2⟩ rs = segRaysCount seg rs
    unfold polyRaysExcess
    show ((polygonRefinement poly seg pt).segments.map f).sum < (poly.segments.map f).sum
    omega
  -- (b) vertices.length ≥ 2.
  · rw [polygonRefinement_vertices_length poly seg pt hseg]
    omega
  -- (c) Vertex avoidance.
  · intro v hv_verts r hr
    have hv : v ∈ (polygonRefinement poly seg pt).vertices := hv_verts
    rcases polygonRefinement_vertex_mem_or_eq poly seg pt v hv with hv_old | hv_pt
    · exact h_verts v hv_old r hr
    · rw [hv_pt]; exact hpt_avoids r hr
  -- (d) Every ray hits some segment.
  · intro r hr
    obtain ⟨seg', hseg', hr_int_seg'⟩ := h_every r hr
    obtain ⟨q, hq_r, hq_seg'⟩ := hr_int_seg'
    -- q is on poly boundary via seg'.
    have hq_boundary_old : q ∈ poly.toBoundarySet := ⟨seg', hseg', hq_seg'⟩
    have hq_boundary_new : q ∈ (polygonRefinement poly seg pt).toBoundarySet := by
      rw [polygonRefinement_boundary_eq poly seg pt hseg hpt_seg]
      exact hq_boundary_old
    obtain ⟨seg'', hseg'', hq_seg''⟩ := hq_boundary_new
    exact ⟨seg'', hseg'', q, hq_r, hq_seg''⟩
  -- (e) No segment contains origin.
  · intro seg'' hseg'' ho_on
    have ho_boundary_new : o ∈ (polygonRefinement poly seg pt).toBoundarySet := ⟨seg'', hseg'', ho_on⟩
    rw [polygonRefinement_boundary_eq poly seg pt hseg hpt_seg] at ho_boundary_new
    obtain ⟨seg''', hseg''', ho_seg'''⟩ := ho_boundary_new
    exact h_no_origin seg''' hseg''' ho_seg'''
  -- Now we prove several helper facts about poly'.segments that we use in both (f) and (g).
  · -- (f) Nodup of poly'.segments.
    -- Strategy:
    --   poly'.segments ++ [seg] ~ poly.segments ++ [sub1, sub2]  (h_perm)
    -- RHS is Nodup if poly.segments.Nodup, sub1 ∉ poly.segments, sub2 ∉ poly.segments,
    -- sub1 ≠ sub2.
    -- Then LHS is Nodup, so poly'.segments.Nodup and seg ∉ poly'.segments.
    have h_perm := polygonRefinement_segments_perm poly seg pt hseg hpt_seg
    have h_sub1_ne_sub2 : (LineSegment.mk seg.p1 pt) ≠ (LineSegment.mk pt seg.p2) := by
      intro h_eq
      have h_p1 : seg.p1 = pt := (LineSegment.mk.injEq _ _ _ _).mp h_eq |>.1
      exact hpt_ne_p1 h_p1.symm
    have h_sub1_notin : (LineSegment.mk seg.p1 pt) ∉ poly.segments := by
      intro h_mem
      obtain ⟨_, hp2_v⟩ := segment_endpoints_in_vertices poly _ h_mem
      -- hp2_v : (LineSegment.mk seg.p1 pt).p2 ∈ poly.vertices, i.e., pt ∈ poly.vertices.
      exact hpt_ne_verts pt hp2_v rfl
    have h_sub2_notin : (LineSegment.mk pt seg.p2) ∉ poly.segments := by
      intro h_mem
      obtain ⟨hp1_v, _⟩ := segment_endpoints_in_vertices poly _ h_mem
      exact hpt_ne_verts pt hp1_v rfl
    have h_rhs_nodup : (poly.segments ++ [LineSegment.mk seg.p1 pt, LineSegment.mk pt seg.p2]).Nodup := by
      rw [List.nodup_append]
      refine ⟨h_nodup, ?_, ?_⟩
      · -- Nodup of [sub1, sub2]
        simp [List.Nodup, h_sub1_ne_sub2]
      · -- v4.15: `nodup_append`'s third conjunct is `Disjoint poly.segments
        --        [sub1, sub2]`, i.e. `s ∈ poly.segments → s ∉ [sub1, sub2]`.
        intro s hs_left hs_right
        rw [List.mem_cons] at hs_right
        rcases hs_right with h_eq | h_eq
        · exact h_sub1_notin (h_eq ▸ hs_left)
        · rw [List.mem_cons] at h_eq
          rcases h_eq with h_eq2 | h_eq2
          · exact h_sub2_notin (h_eq2 ▸ hs_left)
          · exact absurd h_eq2 ((List.not_mem_nil _))
    have h_lhs_nodup : ((polygonRefinement poly seg pt).segments ++ [seg]).Nodup :=
      h_perm.symm.nodup h_rhs_nodup
    rw [List.nodup_append] at h_lhs_nodup
    exact h_lhs_nodup.1
  · -- (g) Uniqueness: each ray hits at most one segment in poly'.segments.
    -- From (f)-proof setup we re-establish the key facts.
    have h_perm := polygonRefinement_segments_perm poly seg pt hseg hpt_seg
    have h_sub1_ne_sub2 : (LineSegment.mk seg.p1 pt) ≠ (LineSegment.mk pt seg.p2) := by
      intro h_eq
      have h_p1 : seg.p1 = pt := (LineSegment.mk.injEq _ _ _ _).mp h_eq |>.1
      exact hpt_ne_p1 h_p1.symm
    have h_sub1_notin : (LineSegment.mk seg.p1 pt) ∉ poly.segments := by
      intro h_mem
      obtain ⟨_, hp2_v⟩ := segment_endpoints_in_vertices poly _ h_mem
      exact hpt_ne_verts pt hp2_v rfl
    have h_sub2_notin : (LineSegment.mk pt seg.p2) ∉ poly.segments := by
      intro h_mem
      obtain ⟨hp1_v, _⟩ := segment_endpoints_in_vertices poly _ h_mem
      exact hpt_ne_verts pt hp1_v rfl
    have h_rhs_nodup : (poly.segments ++ [LineSegment.mk seg.p1 pt, LineSegment.mk pt seg.p2]).Nodup := by
      rw [List.nodup_append]
      refine ⟨h_nodup, ?_, ?_⟩
      · simp [List.Nodup, h_sub1_ne_sub2]
      · -- v4.15: Disjoint poly.segments [sub1, sub2].
        intro s hs_left hs_right
        rw [List.mem_cons] at hs_right
        rcases hs_right with h_eq | h_eq
        · exact h_sub1_notin (h_eq ▸ hs_left)
        · rw [List.mem_cons] at h_eq
          rcases h_eq with h_eq2 | h_eq2
          · exact h_sub2_notin (h_eq2 ▸ hs_left)
          · exact absurd h_eq2 ((List.not_mem_nil _))
    have h_lhs_nodup : ((polygonRefinement poly seg pt).segments ++ [seg]).Nodup :=
      h_perm.symm.nodup h_rhs_nodup
    have h_seg_notin_poly' : seg ∉ (polygonRefinement poly seg pt).segments := by
      rw [List.nodup_append] at h_lhs_nodup
      intro h
      exact h_lhs_nodup.2.2 h (List.mem_singleton.mpr rfl)
    -- For each s ∈ poly'.segments, s is either in poly.segments or equals sub1 or sub2.
    have h_classify : ∀ s ∈ (polygonRefinement poly seg pt).segments,
        s ∈ poly.segments ∨ s = LineSegment.mk seg.p1 pt ∨ s = LineSegment.mk pt seg.p2 := by
      intro s hs
      have hs_lhs : s ∈ (polygonRefinement poly seg pt).segments ++ [seg] := by
        exact List.mem_append_left _ hs
      have hs_rhs : s ∈ poly.segments ++ [LineSegment.mk seg.p1 pt, LineSegment.mk pt seg.p2] :=
        h_perm.mem_iff.mp hs_lhs
      rw [List.mem_append] at hs_rhs
      rcases hs_rhs with h_in_poly | h_in_subs
      · exact Or.inl h_in_poly
      · simp only [List.mem_cons, (List.not_mem_nil _), or_false] at h_in_subs
        rcases h_in_subs with h | h
        · exact Or.inr (Or.inl h)
        · exact Or.inr (Or.inr h)
    -- Helper: seg.toSet = sub1.toSet ∪ sub2.toSet.
    have h_sub_union : (LineSegment.mk seg.p1 pt).toSet ∪ (LineSegment.mk pt seg.p2).toSet =
        seg.toSet := by
      have := segment_split_set seg.p1 seg.p2 pt hpt_seg
      have hseg_eq : LineSegment.mk seg.p1 seg.p2 = seg := by cases seg; rfl
      rw [hseg_eq] at this
      exact this
    -- Helper: r hits sub (sub1 or sub2) → r hits seg.
    have h_sub_hits_seg : ∀ (sub : LineSegment) (r : Ray),
        (sub = LineSegment.mk seg.p1 pt ∨ sub = LineSegment.mk pt seg.p2) →
        rayIntersectsSegment r sub → rayIntersectsSegment r seg := by
      intro sub r h_sub h_r
      rcases h_r with ⟨q, hq_r, hq_sub⟩
      have hq_seg : q ∈ seg.toSet := by
        rw [← h_sub_union]
        rcases h_sub with rfl | rfl
        · exact Set.mem_union_left _ hq_sub
        · exact Set.mem_union_right _ hq_sub
      exact ⟨q, hq_r, hq_seg⟩
    -- Now prove uniqueness.
    intro r hr seg1' hseg1' seg2' hseg2' h_r_seg1' h_r_seg2'
    rcases h_classify seg1' hseg1' with hc1 | hc1 | hc1 <;>
      rcases h_classify seg2' hseg2' with hc2 | hc2 | hc2
    · -- Both in poly.segments. Apply h_unique.
      exact h_unique r hr seg1' hc1 seg2' hc2 h_r_seg1' h_r_seg2'
    · -- seg1' ∈ poly.segments, seg2' = sub1.
      -- r hits sub1 → r hits seg. By h_unique, seg1' = seg.
      -- But seg ∉ poly'.segments, and seg1' ∈ poly'.segments (via hseg1'). Contradiction.
      have h_r_seg : rayIntersectsSegment r seg :=
        h_sub_hits_seg seg2' r (Or.inl hc2) h_r_seg2'
      have h_eq : seg1' = seg := h_unique r hr seg1' hc1 seg hseg h_r_seg1' h_r_seg
      exfalso
      rw [h_eq] at hseg1'
      exact h_seg_notin_poly' hseg1'
    · -- seg1' ∈ poly.segments, seg2' = sub2.
      have h_r_seg : rayIntersectsSegment r seg :=
        h_sub_hits_seg seg2' r (Or.inr hc2) h_r_seg2'
      have h_eq : seg1' = seg := h_unique r hr seg1' hc1 seg hseg h_r_seg1' h_r_seg
      exfalso
      rw [h_eq] at hseg1'
      exact h_seg_notin_poly' hseg1'
    · -- seg1' = sub1, seg2' ∈ poly.segments. Symmetric to case 2.
      have h_r_seg : rayIntersectsSegment r seg :=
        h_sub_hits_seg seg1' r (Or.inl hc1) h_r_seg1'
      have h_eq : seg2' = seg := h_unique r hr seg2' hc2 seg hseg h_r_seg2' h_r_seg
      exfalso
      rw [h_eq] at hseg2'
      exact h_seg_notin_poly' hseg2'
    · -- Both sub1.
      rw [hc1, hc2]
    · -- seg1' = sub1, seg2' = sub2. Both hit by r → contradiction via ray_not_both_sub.
      exfalso
      rw [hc1] at h_r_seg1'
      rw [hc2] at h_r_seg2'
      have h_pt_avoids_r : pt ∉ r.toSet := hpt_avoids r hr
      exact ray_not_both_sub r seg.p1 seg.p2 pt hpt_seg h_pt_avoids_r
        ⟨h_r_seg1', h_r_seg2'⟩
    · -- seg1' = sub2, seg2' ∈ poly.segments.
      have h_r_seg : rayIntersectsSegment r seg :=
        h_sub_hits_seg seg1' r (Or.inr hc1) h_r_seg1'
      have h_eq : seg2' = seg := h_unique r hr seg2' hc2 seg hseg h_r_seg2' h_r_seg
      exfalso
      rw [h_eq] at hseg2'
      exact h_seg_notin_poly' hseg2'
    · -- seg1' = sub2, seg2' = sub1. Symmetric to case 6.
      exfalso
      rw [hc1] at h_r_seg1'
      rw [hc2] at h_r_seg2'
      have h_pt_avoids_r : pt ∉ r.toSet := hpt_avoids r hr
      exact ray_not_both_sub r seg.p1 seg.p2 pt hpt_seg h_pt_avoids_r
        ⟨h_r_seg2', h_r_seg1'⟩
    · -- Both sub2.
      rw [hc1, hc2]
  · -- (h) Line invariant: every poly'-segment's containing line avoids o.
    -- Re-establish the classification of poly'-segments.
    have h_perm := polygonRefinement_segments_perm poly seg pt hseg hpt_seg
    have h_classify : ∀ s ∈ (polygonRefinement poly seg pt).segments,
        s ∈ poly.segments ∨ s = LineSegment.mk seg.p1 pt ∨ s = LineSegment.mk pt seg.p2 := by
      intro s hs
      have hs_lhs : s ∈ (polygonRefinement poly seg pt).segments ++ [seg] := by
        exact List.mem_append_left _ hs
      have hs_rhs : s ∈ poly.segments ++ [LineSegment.mk seg.p1 pt, LineSegment.mk pt seg.p2] :=
        h_perm.mem_iff.mp hs_lhs
      rw [List.mem_append] at hs_rhs
      rcases hs_rhs with h_in_poly | h_in_subs
      · exact Or.inl h_in_poly
      · simp only [List.mem_cons, (List.not_mem_nil _), or_false] at h_in_subs
        rcases h_in_subs with h | h
        · exact Or.inr (Or.inl h)
        · exact Or.inr (Or.inr h)
    -- Get s ∈ (0,1) parametrizing pt on seg.
    obtain ⟨s, hs0, hs1, hsx, hsy⟩ := hpt_seg
    have hs_lt_1 : s < 1 := by
      rcases lt_or_eq_of_le hs1 with hlt | heq
      · exact hlt
      · exfalso; apply hpt_ne_p2
        subst heq
        ext
        · rw [hsx]; ring
        · rw [hsy]; ring
    have hs_pos : 0 < s := by
      rcases lt_or_eq_of_le hs0 with hlt | heq
      · exact hlt
      · exfalso; apply hpt_ne_p1
        rw [← heq] at hsx hsy
        ext
        · rw [hsx]; ring
        · rw [hsy]; ring
    -- Now prove the line invariant.
    intro seg' hseg' u ⟨hxu, hyu⟩
    rcases h_classify seg' hseg' with h_old | h_sub1 | h_sub2
    · -- Old segment: directly contradicts h_lines.
      exact h_lines seg' h_old u ⟨hxu, hyu⟩
    · -- seg' = ⟨seg.p1, pt⟩.
      rw [h_sub1] at hxu hyu
      -- hxu: o.x = (1-u)*seg.p1.x + u*pt.x
      -- pt.x = (1-s)*seg.p1.x + s*seg.p2.x
      -- ⇒ o.x = (1 - u*s)*seg.p1.x + (u*s)*seg.p2.x
      apply h_lines seg hseg (u * s)
      refine ⟨?_, ?_⟩
      · rw [hxu]
        show (1 - u) * seg.p1.x + u * pt.x = (1 - u * s) * seg.p1.x + u * s * seg.p2.x
        rw [hsx]; ring
      · rw [hyu]
        show (1 - u) * seg.p1.y + u * pt.y = (1 - u * s) * seg.p1.y + u * s * seg.p2.y
        rw [hsy]; ring
    · -- seg' = ⟨pt, seg.p2⟩.
      rw [h_sub2] at hxu hyu
      -- hxu: o.x = (1-u)*pt.x + u*seg.p2.x
      -- pt.x = (1-s)*seg.p1.x + s*seg.p2.x
      -- ⇒ o.x = (1-u)*(1-s)*seg.p1.x + ((1-u)*s + u)*seg.p2.x
      -- Let t' = (1-u)*s + u = s + u*(1-s). Then 1 - t' = (1-u)*(1-s).
      apply h_lines seg hseg (s + u * (1 - s))
      refine ⟨?_, ?_⟩
      · rw [hxu]
        show (1 - u) * pt.x + u * seg.p2.x =
            (1 - (s + u * (1 - s))) * seg.p1.x + (s + u * (1 - s)) * seg.p2.x
        rw [hsx]; ring
      · rw [hyu]
        show (1 - u) * pt.y + u * seg.p2.y =
            (1 - (s + u * (1 - s))) * seg.p1.y + (s + u * (1 - s)) * seg.p2.y
        rw [hsy]; ring

/-! ### Main theorem -/

private theorem exists_polygon_separating_rays_aux
    (rs : List Ray)
    (h_origin : ∀ r1 ∈ rs, ∀ r2 ∈ rs, sameOrigin r1 r2)
    (h_distinct : rs.Pairwise (fun r1 r2 => r1.toSet ≠ r2.toSet)) :
    ∃ poly : Polygon,
      (∀ v ∈ poly.toVertices, ∀ r ∈ rs, v ∉ r.toSet) ∧
      (∀ seg ∈ poly.segments, ∀ r1 ∈ rs, ∀ r2 ∈ rs,
         rayIntersectsSegment r1 seg → rayIntersectsSegment r2 seg → r1 = r2) ∧
      (∀ r ∈ rs, ∃ seg ∈ poly.segments, rayIntersectsSegment r seg) ∧
      (∀ r ∈ rs, ∀ seg1 ∈ poly.segments, ∀ seg2 ∈ poly.segments,
         rayIntersectsSegment r seg1 → rayIntersectsSegment r seg2 → seg1 = seg2) ∧
      (∀ seg ∈ poly.segments, ∀ r ∈ rs, ∀ t : ℚ,
         ¬ (r.origin.x = (1-t)*seg.p1.x + t*seg.p2.x ∧
            r.origin.y = (1-t)*seg.p1.y + t*seg.p2.y)) ∧
      poly.segments.Nodup := by
  -- Case on rs empty vs non-empty.
  by_cases h_empty : rs = []
  · -- Empty rs: use empty polygon.
    subst h_empty
    refine ⟨⟨[]⟩, ?_, ?_, ?_, ?_, ?_, ?_⟩
    · intro v hv r hr; exact absurd hr (List.not_mem_nil _)
    · intro seg hseg r1 hr1; exact absurd hr1 (List.not_mem_nil _)
    · intro r hr; exact absurd hr (List.not_mem_nil _)
    · intro r hr; exact absurd hr (List.not_mem_nil _)
    · intro seg hseg r hr; exact absurd hr (List.not_mem_nil _)
    · simp [Polygon.segments]
  -- Non-empty rs: extract common origin.
  have h_nonempty : ∃ r₀, r₀ ∈ rs := by
    cases hrs : rs with
    | nil => exact absurd hrs h_empty
    | cons r₀ rest => exact ⟨r₀, (List.mem_cons_self _ _)⟩
  obtain ⟨r₀, hr₀⟩ := h_nonempty
  set o := r₀.origin with ho_def
  have h_all_origin : ∀ r ∈ rs, r.origin = o := by
    intro r hr
    have := h_origin r hr r₀ hr₀
    unfold sameOrigin at this
    exact this
  -- Get initial triangle polygon.
  obtain ⟨poly₀, hlen₀, hverts₀, hevery₀, hno_origin₀, hunique₀, h_nodup₀, hlines₀⟩ :=
    exists_initial_triangle rs o h_all_origin
  have h_base : poly₀.vertices.length ≥ 2 := by omega
  -- Strong induction on the measure.
  suffices h : ∀ (m : ℕ) (poly : Polygon),
      polyRaysExcess poly rs = m →
      poly.vertices.length ≥ 2 →
      (∀ v ∈ poly.toVertices, ∀ r ∈ rs, v ∉ r.toSet) →
      (∀ r ∈ rs, ∃ seg ∈ poly.segments, rayIntersectsSegment r seg) →
      (∀ seg ∈ poly.segments, o ∉ seg.toSet) →
      poly.segments.Nodup →
      (∀ r ∈ rs, ∀ seg1 ∈ poly.segments, ∀ seg2 ∈ poly.segments,
          rayIntersectsSegment r seg1 → rayIntersectsSegment r seg2 → seg1 = seg2) →
      (∀ seg ∈ poly.segments, ∀ t : ℚ,
          ¬ (o.x = (1-t)*seg.p1.x + t*seg.p2.x ∧ o.y = (1-t)*seg.p1.y + t*seg.p2.y)) →
      ∃ poly' : Polygon,
        (∀ v ∈ poly'.toVertices, ∀ r ∈ rs, v ∉ r.toSet) ∧
        (∀ seg ∈ poly'.segments, ∀ r1 ∈ rs, ∀ r2 ∈ rs,
           rayIntersectsSegment r1 seg → rayIntersectsSegment r2 seg → r1 = r2) ∧
        (∀ r ∈ rs, ∃ seg ∈ poly'.segments, rayIntersectsSegment r seg) ∧
        (∀ r ∈ rs, ∀ seg1 ∈ poly'.segments, ∀ seg2 ∈ poly'.segments,
           rayIntersectsSegment r seg1 → rayIntersectsSegment r seg2 → seg1 = seg2) ∧
        (∀ seg ∈ poly'.segments, ∀ r ∈ rs, ∀ t : ℚ,
           ¬ (r.origin.x = (1-t)*seg.p1.x + t*seg.p2.x ∧
              r.origin.y = (1-t)*seg.p1.y + t*seg.p2.y)) ∧
        poly'.segments.Nodup by
    exact h (polyRaysExcess poly₀ rs) poly₀ rfl h_base hverts₀ hevery₀ hno_origin₀ h_nodup₀
      hunique₀ hlines₀
  intro m
  induction m using Nat.strong_induction_on with
  | _ m ih =>
    intro poly h_m h_len h_verts h_every h_no_origin h_nodup h_unique h_lines
    by_cases h_good : ∀ seg ∈ poly.segments, ∀ r1 ∈ rs, ∀ r2 ∈ rs,
        rayIntersectsSegment r1 seg → rayIntersectsSegment r2 seg → r1 = r2
    · refine ⟨poly, h_verts, h_good, h_every, h_unique, ?_, h_nodup⟩
      intro seg hseg r hr t
      rw [h_all_origin r hr]
      exact h_lines seg hseg t
    · push_neg at h_good
      obtain ⟨seg, hseg, r1, hr1, r2, hr2, hr1_int, hr2_int, hne⟩ := h_good
      have h_bad : ∃ seg ∈ poly.segments, ∃ r1 ∈ rs, ∃ r2 ∈ rs, r1 ≠ r2 ∧
          rayIntersectsSegment r1 seg ∧ rayIntersectsSegment r2 seg :=
        ⟨seg, hseg, r1, hr1, r2, hr2, hne, hr1_int, hr2_int⟩
      obtain ⟨poly', h_smaller, h_len', h_verts', h_every', h_no_origin', h_nodup', h_unique',
              h_lines'⟩ :=
        refinement_step rs o h_all_origin h_distinct poly h_len h_verts h_every h_no_origin
          h_nodup h_unique h_lines h_bad
      subst h_m
      exact ih (polyRaysExcess poly' rs) h_smaller poly' rfl h_len' h_verts' h_every' h_no_origin'
        h_nodup' h_unique' h_lines'

/-- Main theorem: given rays with distinct directions and common origin, there exists a polygon
    whose vertices avoid the rays, each segment intersects at most one ray, every ray is
    intersected by some segment, AND each ray intersects at most one segment. -/
theorem exists_polygon_separating_rays
    (rs : List Ray)
    (h_origin : ∀ r1 ∈ rs, ∀ r2 ∈ rs, sameOrigin r1 r2)
    (h_distinct : rs.Pairwise (fun r1 r2 => r1.toSet ≠ r2.toSet)) :
    ∃ poly : Polygon,
      (∀ v ∈ poly.toVertices, ∀ r ∈ rs, v ∉ r.toSet) ∧
      (∀ seg ∈ poly.segments, ∀ r1 ∈ rs, ∀ r2 ∈ rs,
         rayIntersectsSegment r1 seg → rayIntersectsSegment r2 seg → r1 = r2) ∧
      (∀ r ∈ rs, ∃ seg ∈ poly.segments, rayIntersectsSegment r seg) ∧
      (∀ r ∈ rs, ∀ seg1 ∈ poly.segments, ∀ seg2 ∈ poly.segments,
         rayIntersectsSegment r seg1 → rayIntersectsSegment r seg2 → seg1 = seg2) ∧
      (∀ seg ∈ poly.segments, ∀ r ∈ rs, ∀ t : ℚ,
         ¬ (r.origin.x = (1-t)*seg.p1.x + t*seg.p2.x ∧
            r.origin.y = (1-t)*seg.p1.y + t*seg.p2.y)) ∧
      poly.segments.Nodup := by
  exact exists_polygon_separating_rays_aux rs h_origin h_distinct

/-! ### Vertex neighborhood -/

private lemma dist_sq_pos_of_ne (p q : Vector2D) (h : p ≠ q) :
    0 < (p.x - q.x)^2 + (p.y - q.y)^2 := by
  by_contra h_nn
  push_neg at h_nn
  have h_x_sq : (p.x - q.x)^2 ≥ 0 := sq_nonneg _
  have h_y_sq : (p.y - q.y)^2 ≥ 0 := sq_nonneg _
  have h_x_zero : (p.x - q.x)^2 = 0 := by linarith
  have h_y_zero : (p.y - q.y)^2 = 0 := by linarith
  have hx : p.x = q.x := by
    have := sq_eq_zero_iff.mp h_x_zero
    linarith
  have hy : p.y = q.y := by
    have := sq_eq_zero_iff.mp h_y_zero
    linarith
  exact h (Vector2D.ext hx hy)

/-- Distance squared between the origin `v` and a point on a segment,
    parametrized by `t ∈ [0,1]`. -/
private lemma seg_dist_sq_eq (seg : LineSegment) (v : Vector2D)
    (t : ℚ) (p : Vector2D)
    (hpx : p.x = (1 - t) * seg.p1.x + t * seg.p2.x)
    (hpy : p.y = (1 - t) * seg.p1.y + t * seg.p2.y) :
    (p.x - v.x)^2 + (p.y - v.y)^2 =
      ((seg.p1.x - seg.p2.x)^2 + (seg.p1.y - seg.p2.y)^2) * t^2 +
      2 * ((seg.p1.x - v.x) * (seg.p2.x - v.x) +
           (seg.p1.y - v.y) * (seg.p2.y - v.y) -
           ((seg.p1.x - v.x)^2 + (seg.p1.y - v.y)^2)) * t +
      ((seg.p1.x - v.x)^2 + (seg.p1.y - v.y)^2) := by
  rw [hpx, hpy]; ring

/-- Lower bound on the squared distance from `v` to any point on a non-degenerate
    segment with both endpoints distinct from `v` and `v` not on the segment. -/
private lemma segment_lower_bound (seg : LineSegment) (v : Vector2D)
    (h_nondeg : seg.p1 ≠ seg.p2) (h1 : seg.p1 ≠ v) (h2 : seg.p2 ≠ v)
    (h_not_on : v ∉ seg.toSet) :
    ∃ e : ℚ, 0 < e ∧ ∀ p ∈ seg.toSet, e ≤ (p.x - v.x)^2 + (p.y - v.y)^2 := by
  set A := (seg.p1.x - v.x)^2 + (seg.p1.y - v.y)^2 with hA_def
  set C := (seg.p2.x - v.x)^2 + (seg.p2.y - v.y)^2 with hC_def
  set B := (seg.p1.x - v.x) * (seg.p2.x - v.x) +
           (seg.p1.y - v.y) * (seg.p2.y - v.y) with hB_def
  set α := (seg.p1.x - seg.p2.x)^2 + (seg.p1.y - seg.p2.y)^2 with hα_def
  have hA_pos : 0 < A := dist_sq_pos_of_ne seg.p1 v h1
  have hC_pos : 0 < C := dist_sq_pos_of_ne seg.p2 v h2
  have hα_pos : 0 < α := dist_sq_pos_of_ne seg.p1 seg.p2 h_nondeg
  -- Expand d²(p(t), v) = α*t² + 2(B-A)*t + A
  have h_expand : ∀ p ∈ seg.toSet,
      ∃ t : ℚ, 0 ≤ t ∧ t ≤ 1 ∧
        (p.x - v.x)^2 + (p.y - v.y)^2 = α * t^2 + 2 * (B - A) * t + A := by
    intro p hp
    obtain ⟨t, ht0, ht1, hpx, hpy⟩ := hp
    refine ⟨t, ht0, ht1, ?_⟩
    rw [hpx, hpy]
    simp only [hA_def, hB_def, hα_def]
    ring
  by_cases hBA : A ≤ B
  · -- Case 1: B ≥ A. Use A as lower bound. f(t) - A = t*(α*t + 2*(B-A)) ≥ 0.
    refine ⟨A, hA_pos, ?_⟩
    intro p hp
    obtain ⟨t, ht0, ht1, hf⟩ := h_expand p hp
    rw [hf]
    have h1 : 0 ≤ α * t^2 := mul_nonneg hα_pos.le (sq_nonneg _)
    have h2 : 0 ≤ 2 * (B - A) * t := by
      apply mul_nonneg
      · linarith
      · exact ht0
    linarith
  · push_neg at hBA
    by_cases hBC : C ≤ B
    · -- Case 2: B ≥ C. Use C as lower bound. f(t) - C = (t-1)*(α*t + C - A) ≥ 0.
      refine ⟨C, hC_pos, ?_⟩
      intro p hp
      obtain ⟨t, ht0, ht1, hf⟩ := h_expand p hp
      rw [hf]
      -- α*t² + 2(B-A)*t + A - C = (t-1) * (α*t + (C - A))
      -- For t ∈ [0,1]: (t-1) ≤ 0.
      -- α*t + (C - A): at t=0 is C-A; at t=1 is α + C - A = 2(C - B).
      -- Since A > B ≥ C, C - A < 0. Since B ≥ C, 2(C - B) ≤ 0.
      -- Linear, nonpositive at both ends ⟹ nonpositive on [0,1].
      have h_factor : α * t^2 + 2 * (B - A) * t + A - C = (t - 1) * (α * t + (C - A)) := by
        have hα_expand : α = A + C - 2 * B := by
          simp only [hA_def, hC_def, hB_def, hα_def]; ring
        rw [hα_expand]; ring
      have h_tm1 : t - 1 ≤ 0 := by linarith
      have h_CmA : C - A < 0 := by linarith
      have h_αpCmA : α + (C - A) ≤ 0 := by
        have hα_expand : α = A + C - 2 * B := by
          simp only [hA_def, hC_def, hB_def, hα_def]; ring
        rw [hα_expand]; linarith
      have h_lin_nonpos : α * t + (C - A) ≤ 0 := by
        have : α * t + (C - A) = (1 - t) * (C - A) + t * (α + (C - A)) := by ring
        rw [this]
        have h1t : 0 ≤ 1 - t := by linarith
        have ha : (1 - t) * (C - A) ≤ 0 := mul_nonpos_of_nonneg_of_nonpos h1t h_CmA.le
        have hb : t * (α + (C - A)) ≤ 0 := mul_nonpos_of_nonneg_of_nonpos ht0 h_αpCmA
        linarith
      have h_prod : 0 ≤ (t - 1) * (α * t + (C - A)) := by
        have hh : (t - 1) * (α * t + (C - A)) = (1 - t) * (-(α * t + (C - A))) := by ring
        rw [hh]
        apply mul_nonneg
        · linarith
        · linarith
      linarith [h_factor ▸ h_prod]
    · push_neg at hBC
      -- Case 3: B < A and B < C.
      -- f(t) ≥ (A*C - B²)/α. Use this.
      -- Need A*C > B² (strict).
      have h_AC_gt_BB : B^2 < A * C := by
        -- α * f(t) = (α*t - (A-B))² + (A*C - B²). So f(t) ≥ (AC-B²)/α.
        -- C-S gives A*C ≥ B². Equality iff p1-v, p2-v parallel.
        -- Suppose A*C = B². Then f(t*) = 0 at t* = (A-B)/α. Since B < A and B < C,
        -- t* ∈ (0,1), so p(t*) ∈ seg.toSet and p(t*) = v. Contradiction with h_not_on.
        by_contra h_le
        push_neg at h_le
        -- h_le : A*C ≤ B². But C-S gives A*C ≥ B². So A*C = B².
        have h_CS : B^2 ≤ A * C := by
          -- (a.x*b.y - a.y*b.x)² ≥ 0 gives A*C ≥ B² via Lagrange
          have : (A * C - B^2) =
              ((seg.p1.x - v.x) * (seg.p2.y - v.y) -
               (seg.p1.y - v.y) * (seg.p2.x - v.x))^2 := by
            simp only [hA_def, hB_def, hC_def]; ring
          linarith [sq_nonneg ((seg.p1.x - v.x) * (seg.p2.y - v.y) -
                               (seg.p1.y - v.y) * (seg.p2.x - v.x))]
        have h_eq : A * C = B^2 := le_antisymm h_le h_CS
        -- Consider t* = (A - B)/α. Show t* ∈ (0,1) and p(t*) = v.
        set t_star := (A - B) / α with ht_star_def
        have ht_star_pos : 0 < t_star := by
          rw [ht_star_def]
          exact div_pos (by linarith) hα_pos
        have ht_star_lt_one : t_star < 1 := by
          rw [ht_star_def, div_lt_one hα_pos]
          have : α = A + C - 2 * B := by
            simp only [hA_def, hC_def, hB_def, hα_def]; ring
          linarith
        -- Let p = (1 - t_star) * seg.p1 + t_star * seg.p2. Show p = v.
        let px := (1 - t_star) * seg.p1.x + t_star * seg.p2.x
        let py := (1 - t_star) * seg.p1.y + t_star * seg.p2.y
        let p : Vector2D := ⟨px, py⟩
        have hp_in_seg : p ∈ seg.toSet := ⟨t_star, ht_star_pos.le, ht_star_lt_one.le, rfl, rfl⟩
        -- Compute (p.x - v.x)² + (p.y - v.y)² and show it equals 0.
        have h_fts : (p.x - v.x)^2 + (p.y - v.y)^2 = α * t_star^2 + 2 * (B - A) * t_star + A := by
          show ((1 - t_star) * seg.p1.x + t_star * seg.p2.x - v.x)^2 +
               ((1 - t_star) * seg.p1.y + t_star * seg.p2.y - v.y)^2 = _
          simp only [hA_def, hB_def, hα_def]
          ring
        have hα_ne : (α : ℚ) ≠ 0 := ne_of_gt hα_pos
        have hα_val : α = A + C - 2 * B := by
          simp only [hA_def, hC_def, hα_def, hB_def]; ring
        have h_Aα : A * α = (A - B)^2 := by
          rw [hα_val]; linear_combination h_eq
        have h_αts : α * t_star = A - B := by
          rw [ht_star_def]; field_simp
        have h_fts_zero : α * t_star^2 + 2 * (B - A) * t_star + A = 0 := by
          have h_mul : α * (α * t_star^2 + 2 * (B - A) * t_star + A) = α * 0 := by
            have key : α * (α * t_star^2 + 2 * (B - A) * t_star + A)
                     = (α * t_star) * (α * t_star) + 2 * (B - A) * (α * t_star) + A * α := by
              ring
            rw [key, h_αts, h_Aα]; ring
          exact mul_left_cancel₀ hα_ne h_mul
        have h_dist_zero : (p.x - v.x)^2 + (p.y - v.y)^2 = 0 := by
          rw [h_fts]; exact h_fts_zero
        -- Since squared distances are nonneg and sum to zero, each is zero.
        have h_x_sq_zero : (p.x - v.x)^2 = 0 := by
          have hx_nn := sq_nonneg (p.x - v.x)
          have hy_nn := sq_nonneg (p.y - v.y)
          linarith
        have h_y_sq_zero : (p.y - v.y)^2 = 0 := by
          have hx_nn := sq_nonneg (p.x - v.x)
          have hy_nn := sq_nonneg (p.y - v.y)
          linarith
        have h_px : p.x = v.x := by
          have := sq_eq_zero_iff.mp h_x_sq_zero
          linarith
        have h_py : p.y = v.y := by
          have := sq_eq_zero_iff.mp h_y_sq_zero
          linarith
        have h_p_eq_v : p = v := Vector2D.ext h_px h_py
        exact h_not_on (h_p_eq_v ▸ hp_in_seg)
      -- Now use (A*C - B²)/α as lower bound.
      refine ⟨(A * C - B^2) / α, ?_, ?_⟩
      · exact div_pos (by linarith) hα_pos
      · intro p hp
        obtain ⟨t, ht0, ht1, hf⟩ := h_expand p hp
        -- α * (f(t)) = (α*t - (A - B))² + (A*C - B²)
        have h_key : α * (α * t^2 + 2 * (B - A) * t + A) =
                     (α * t - (A - B))^2 + (A * C - B^2) := by
          have hα_val : α = A + C - 2 * B := by
            simp only [hA_def, hC_def, hα_def, hB_def]; ring
          rw [hα_val]; ring
        have h_sq_nn : 0 ≤ (α * t - (A - B))^2 := sq_nonneg _
        have h_key2 : A * C - B^2 ≤ α * ((p.x - v.x)^2 + (p.y - v.y)^2) := by
          rw [hf, h_key]; linarith
        rw [div_le_iff₀ hα_pos]
        linarith [h_key2]

/-- Induction helper: process a list of segments, producing a rational lower
    bound `m` valid for all segments in the list. -/
private lemma exists_sq_bound_list (ss : List LineSegment) (v : Vector2D)
    (h_nondeg : ∀ seg ∈ ss, seg.p1 ≠ seg.p2)
    (h_no_segment_interior_vertices : ∀ seg ∈ ss, seg.p1 ≠ v → seg.p2 ≠ v → v ∉ seg.toSet) :
    ∃ m : ℚ, 0 < m ∧
      (∀ seg ∈ ss, seg.p1 ≠ v → seg.p2 ≠ v →
         ∀ p ∈ seg.toSet, m ≤ (p.x - v.x)^2 + (p.y - v.y)^2) ∧
      (∀ seg ∈ ss, ∀ w : Vector2D,
         (w = seg.p1 ∨ w = seg.p2) → w ≠ v →
         m ≤ (w.x - v.x)^2 + (w.y - v.y)^2) := by
  induction ss with
  | nil =>
    refine ⟨1, by norm_num, ?_, ?_⟩ <;> intro seg hseg <;> simp at hseg
  | cons seg rest ih =>
    have h_nondeg_seg : seg.p1 ≠ seg.p2 := h_nondeg seg ((List.mem_cons_self _ _))
    have h_nondeg_rest : ∀ s ∈ rest, s.p1 ≠ s.p2 :=
      fun s hs => h_nondeg s (List.mem_cons_of_mem _ hs)
    have h_no_segment_interior_vertices_rest : ∀ s ∈ rest, s.p1 ≠ v → s.p2 ≠ v → v ∉ s.toSet :=
      fun s hs => h_no_segment_interior_vertices s (List.mem_cons_of_mem _ hs)
    obtain ⟨m_rest, hm_rest_pos, hm_rest_seg, hm_rest_end⟩ :=
      ih h_nondeg_rest h_no_segment_interior_vertices_rest
    -- Compute a positive bound m_seg for `seg` covering both seg-interior and endpoints.
    have h_mseg : ∃ m_seg : ℚ, 0 < m_seg ∧
        (seg.p1 ≠ v → seg.p2 ≠ v →
           ∀ p ∈ seg.toSet, m_seg ≤ (p.x - v.x)^2 + (p.y - v.y)^2) ∧
        (∀ w : Vector2D, (w = seg.p1 ∨ w = seg.p2) → w ≠ v →
           m_seg ≤ (w.x - v.x)^2 + (w.y - v.y)^2) := by
      by_cases hp1_v : seg.p1 = v
      · -- p1 = v, so p2 ≠ v (by non-deg).
        have hp2_v : seg.p2 ≠ v := by
          intro h; apply h_nondeg_seg; rw [hp1_v, h]
        refine ⟨(seg.p2.x - v.x)^2 + (seg.p2.y - v.y)^2,
                dist_sq_pos_of_ne seg.p2 v hp2_v, ?_, ?_⟩
        · intro h1 _; exact absurd hp1_v h1
        · intro w hw hw_ne
          rcases hw with hwp1 | hwp2
          · rw [hwp1, hp1_v] at hw_ne; exact absurd rfl hw_ne
          · rw [hwp2]
      · by_cases hp2_v : seg.p2 = v
        · -- p2 = v, p1 ≠ v.
          refine ⟨(seg.p1.x - v.x)^2 + (seg.p1.y - v.y)^2,
                  dist_sq_pos_of_ne seg.p1 v hp1_v, ?_, ?_⟩
          · intro _ h2; exact absurd hp2_v h2
          · intro w hw hw_ne
            rcases hw with hwp1 | hwp2
            · rw [hwp1]
            · rw [hwp2, hp2_v] at hw_ne; exact absurd rfl hw_ne
        · -- Both p1 ≠ v and p2 ≠ v.
          have h_v_not_on : v ∉ seg.toSet :=
            h_no_segment_interior_vertices seg ((List.mem_cons_self _ _)) hp1_v hp2_v
          obtain ⟨e_seg, he_pos, he_bound⟩ :=
            segment_lower_bound seg v h_nondeg_seg hp1_v hp2_v h_v_not_on
          refine ⟨e_seg, he_pos, ?_, ?_⟩
          · intro _ _ p hp; exact he_bound p hp
          · intro w hw _
            rcases hw with hwp1 | hwp2
            · rw [hwp1]; apply he_bound
              exact ⟨0, le_refl _, by norm_num, by ring, by ring⟩
            · rw [hwp2]; apply he_bound
              exact ⟨1, by norm_num, le_refl _, by ring, by ring⟩
    obtain ⟨m_seg, hm_seg_pos, hm_seg_int, hm_seg_end⟩ := h_mseg
    refine ⟨min m_rest m_seg, lt_min hm_rest_pos hm_seg_pos, ?_, ?_⟩
    · intro s hs hs1 hs2 p hp
      rcases List.mem_cons.mp hs with rfl | hs_rest
      · exact le_trans (min_le_right _ _) (hm_seg_int hs1 hs2 p hp)
      · exact le_trans (min_le_left _ _) (hm_rest_seg s hs_rest hs1 hs2 p hp)
    · intro s hs w hw hw_ne
      rcases List.mem_cons.mp hs with rfl | hs_rest
      · exact le_trans (min_le_right _ _) (hm_seg_end w hw hw_ne)
      · exact le_trans (min_le_left _ _) (hm_rest_end s hs_rest w hw hw_ne)

/-- Given a vertex of a graph, there is a positive radius `r` such that the open
    ball of radius `r` around the vertex avoids all other vertices of the graph
    and all segments of the graph that are not incident to the vertex. -/
theorem exists_vertex_neighborhood_avoiding_non_incident
    (G : Graph) (v : Vector2D)
    (_hv : ∃ seg ∈ G.segments, seg.p1 = v ∨ seg.p2 = v)
    (h_no_segment_interior_vertices : ∀ seg ∈ G.segments,
      seg.p1 ≠ v → seg.p2 ≠ v → v ∉ seg.toSet) :
    ∃ r : ℚ, 0 < r ∧
      (∀ seg ∈ G.segments, seg.p1 ≠ v → seg.p2 ≠ v →
         ∀ p ∈ seg.toSet, r^2 ≤ (p.x - v.x)^2 + (p.y - v.y)^2) ∧
      (∀ seg ∈ G.segments, ∀ w : Vector2D,
         (w = seg.p1 ∨ w = seg.p2) → w ≠ v →
         r^2 ≤ (w.x - v.x)^2 + (w.y - v.y)^2) := by
  obtain ⟨m, hm_pos, hm_seg, hm_end⟩ :=
    exists_sq_bound_list G.segments v
      (fun seg hseg => G.segments_nondegenerate seg hseg) h_no_segment_interior_vertices
  refine ⟨min 1 m, lt_min (by norm_num) hm_pos, ?_, ?_⟩
  all_goals
    have h_r_pos : 0 < min (1:ℚ) m := lt_min (by norm_num) hm_pos
    have h_r_le_one : min (1:ℚ) m ≤ 1 := min_le_left _ _
    have h_r_le_m : min (1:ℚ) m ≤ m := min_le_right _ _
    have h_rsq_le_m : (min (1:ℚ) m)^2 ≤ m := by
      calc (min (1:ℚ) m)^2
          = min (1:ℚ) m * min 1 m := sq _
        _ ≤ min (1:ℚ) m * 1 := by
            apply mul_le_mul_of_nonneg_left h_r_le_one h_r_pos.le
        _ = min (1:ℚ) m := by ring
        _ ≤ m := h_r_le_m
  · intro seg hseg h1 h2 p hp
    exact le_trans h_rsq_le_m (hm_seg seg hseg h1 h2 p hp)
  · intro seg hseg w hw hw_ne
    exact le_trans h_rsq_le_m (hm_end seg hseg w hw hw_ne)

end GraphVertexNeighborhoodProofs

