/-! ### Segment splitting for graphs -/

/-- Split a segment at a point: the union of the two sub-segments equals the original. -/
private theorem segment_split (a b pt : Vector2D)
    (h_pt : pt ∈ (LineSegment.mk a b).toSet) :
    (LineSegment.mk a pt).toSet ∪ (LineSegment.mk pt b).toSet =
    (LineSegment.mk a b).toSet := by
  obtain ⟨s, hs0, hs1, hsx, hsy⟩ := h_pt
  ext p; simp only [LineSegment.toSet, Set.mem_setOf_eq, Set.mem_union]
  constructor
  · rintro (⟨u, hu0, hu1, hux, huy⟩ | ⟨u, hu0, hu1, hux, huy⟩)
    · exact ⟨u * s, mul_nonneg hu0 hs0, by nlinarith,
            by rw [hux, hsx]; ring, by rw [huy, hsy]; ring⟩
    · exact ⟨s + u * (1 - s), by nlinarith, by nlinarith,
            by rw [hux, hsx]; ring, by rw [huy, hsy]; ring⟩
  · intro ⟨t, ht0, ht1, htx, hty⟩
    by_cases hts : t ≤ s
    · by_cases hs_zero : s = 0
      · have ht_zero : t = 0 := le_antisymm (hs_zero ▸ hts) ht0
        left
        exact ⟨0, le_refl 0, zero_le_one, by simp [htx, ht_zero], by simp [hty, ht_zero]⟩
      · left
        have hs_pos : (0 : ℚ) < s := lt_of_le_of_ne hs0 (Ne.symm hs_zero)
        exact ⟨t / s, div_nonneg ht0 (le_of_lt hs_pos),
               div_le_one_of_le₀ hts (le_of_lt hs_pos),
               by rw [htx, hsx]; field_simp; ring,
               by rw [hty, hsy]; field_simp; ring⟩
    · push_neg at hts
      by_cases hs1' : s = 1
      · linarith
      · right
        have h1s_pos : (0 : ℚ) < 1 - s := by linarith [lt_of_le_of_ne hs1 hs1']
        exact ⟨(t - s) / (1 - s),
               div_nonneg (le_of_lt (sub_pos.mpr hts)) (le_of_lt h1s_pos),
               div_le_one_of_le₀ (by linarith) (le_of_lt h1s_pos),
               by rw [htx, hsx]; field_simp; ring,
               by rw [hty, hsy]; field_simp; ring⟩

/-! ### Replace a segment in a list -/

/-- Replace the first occurrence of `seg` in a list with `seg1` and `seg2`. -/
private def replaceSegment (segs : List LineSegment) (seg seg1 seg2 : LineSegment) :
    List LineSegment :=
  match segs with
  | [] => []
  | s :: rest =>
    if s = seg then seg1 :: seg2 :: rest
    else s :: replaceSegment rest seg seg1 seg2

/-- Any element of `replaceSegment segs seg seg1 seg2` is `seg1`, `seg2`, or
    an element of `segs`. -/
private lemma mem_replaceSegment (segs : List LineSegment) (seg seg1 seg2 : LineSegment)
    (s : LineSegment) (h : s ∈ replaceSegment segs seg seg1 seg2) :
    s = seg1 ∨ s = seg2 ∨ s ∈ segs := by
  induction segs with
  | nil => simp [replaceSegment] at h
  | cons hd tl ih =>
    simp only [replaceSegment] at h
    split_ifs at h with heq
    · simp only [List.mem_cons] at h
      rcases h with rfl | rfl | hmem
      · exact Or.inl rfl
      · exact Or.inr (Or.inl rfl)
      · exact Or.inr (Or.inr (List.mem_cons.mpr (Or.inr hmem)))
    · simp only [List.mem_cons] at h
      rcases h with rfl | hmem
      · exact Or.inr (Or.inr (List.mem_cons.mpr (Or.inl rfl)))
      · rcases ih hmem with h1 | h2 | h3
        · exact Or.inl h1
        · exact Or.inr (Or.inl h2)
        · exact Or.inr (Or.inr (List.mem_cons.mpr (Or.inr h3)))

/-- If `s ∈ segs` and `s ≠ seg`, then `s ∈ replaceSegment segs seg seg1 seg2`. -/
private lemma replaceSegment_of_mem_ne (segs : List LineSegment) (seg seg1 seg2 : LineSegment)
    (s : LineSegment) (h_mem : s ∈ segs) (h_ne : s ≠ seg) :
    s ∈ replaceSegment segs seg seg1 seg2 := by
  induction segs with
  | nil => simp at h_mem
  | cons hd tl ih =>
    simp only [List.mem_cons] at h_mem
    simp only [replaceSegment]
    split_ifs with heq
    · rcases h_mem with rfl | hmem
      · exact absurd heq h_ne
      · simp only [List.mem_cons]
        exact Or.inr (Or.inr hmem)
    · simp only [List.mem_cons]
      rcases h_mem with rfl | hmem
      · exact Or.inl rfl
      · exact Or.inr (ih hmem)

/-- `seg1` is in `replaceSegment segs seg seg1 seg2` when `seg ∈ segs`. -/
private lemma seg1_mem_replaceSegment (segs : List LineSegment) (seg seg1 seg2 : LineSegment)
    (h_mem : seg ∈ segs) : seg1 ∈ replaceSegment segs seg seg1 seg2 := by
  induction segs with
  | nil => simp at h_mem
  | cons hd tl ih =>
    simp only [replaceSegment]
    split_ifs with heq
    · simp [List.mem_cons]
    · simp only [List.mem_cons] at h_mem ⊢
      rcases h_mem with rfl | hmem
      · exact absurd rfl heq
      · exact Or.inr (ih hmem)

/-- `seg2` is in `replaceSegment segs seg seg1 seg2` when `seg ∈ segs`. -/
private lemma seg2_mem_replaceSegment (segs : List LineSegment) (seg seg1 seg2 : LineSegment)
    (h_mem : seg ∈ segs) : seg2 ∈ replaceSegment segs seg seg1 seg2 := by
  induction segs with
  | nil => simp at h_mem
  | cons hd tl ih =>
    simp only [replaceSegment]
    split_ifs with heq
    · simp [List.mem_cons]
    · simp only [List.mem_cons] at h_mem ⊢
      rcases h_mem with rfl | hmem
      · exact absurd rfl heq
      · exact Or.inr (ih hmem)

/-- The `countP` relation for `replaceSegment`. -/
private lemma replaceSegment_countP_relate (segs : List LineSegment) (seg seg1 seg2 : LineSegment)
    (h_mem : seg ∈ segs) (p : LineSegment → Bool) :
    (replaceSegment segs seg seg1 seg2).countP p + (if p seg then 1 else 0) =
    segs.countP p + (if p seg1 then 1 else 0) + (if p seg2 then 1 else 0) := by
  induction segs with
  | nil => simp at h_mem
  | cons hd tl ih =>
    simp only [List.mem_cons] at h_mem
    unfold replaceSegment
    by_cases heq : hd = seg
    · subst heq
      simp only [List.countP_cons]
      split_ifs <;> simp_all
    · rw [if_neg heq]
      have h_tl : seg ∈ tl := h_mem.resolve_left (fun h => heq h.symm)
      simp only [List.countP_cons]
      have ih' := ih h_tl
      cases hp : p hd <;> simp at ih' ⊢ <;> omega

/-- Boundary set of replaceSegment equals original when the replacement
    covers the same set. -/
private lemma replaceSegment_boundary_eq (segs : List LineSegment)
    (seg seg1 seg2 : LineSegment)
    (h_mem : seg ∈ segs) (h_split : seg1.toSet ∪ seg2.toSet = seg.toSet) :
    { p | ∃ s ∈ replaceSegment segs seg seg1 seg2, p ∈ s.toSet } =
    { p | ∃ s ∈ segs, p ∈ s.toSet } := by
  ext p
  simp only [Set.mem_setOf_eq]
  constructor
  · rintro ⟨s, hs_mem, hp⟩
    rcases mem_replaceSegment segs seg seg1 seg2 s hs_mem with rfl | rfl | hs_orig
    · exact ⟨seg, h_mem, h_split ▸ Set.mem_union_left _ hp⟩
    · exact ⟨seg, h_mem, h_split ▸ Set.mem_union_right _ hp⟩
    · exact ⟨s, hs_orig, hp⟩
  · rintro ⟨s, hs_mem, hp⟩
    by_cases h_eq : s = seg
    · rw [h_eq] at hp
      have hp' : p ∈ seg1.toSet ∪ seg2.toSet := h_split ▸ hp
      rcases hp' with hp1 | hp2
      · exact ⟨seg1, seg1_mem_replaceSegment segs seg seg1 seg2 h_mem, hp1⟩
      · exact ⟨seg2, seg2_mem_replaceSegment segs seg seg1 seg2 h_mem, hp2⟩
    · exact ⟨s, replaceSegment_of_mem_ne segs seg seg1 seg2 s hs_mem h_eq, hp⟩

/-! ### Ray intersection and segment splitting -/

/-- Ray hits seg(a,b) iff it hits seg(a,pt) or seg(pt,b), when pt ∈ seg(a,b). -/
private lemma segment_split_rayIntersects (r : Ray) (a b pt : Vector2D)
    (h_pt : pt ∈ (LineSegment.mk a b).toSet) :
    rayIntersectsSegment r ⟨a, b⟩ ↔
    (rayIntersectsSegment r ⟨a, pt⟩ ∨ rayIntersectsSegment r ⟨pt, b⟩) := by
  have h_union := segment_split a b pt h_pt
  constructor
  · intro ⟨q, hq_ray, hq_seg⟩
    have : q ∈ (LineSegment.mk a pt).toSet ∪ (LineSegment.mk pt b).toSet :=
      h_union ▸ hq_seg
    rcases this with h | h
    · exact Or.inl ⟨q, hq_ray, h⟩
    · exact Or.inr ⟨q, hq_ray, h⟩
  · rintro (⟨q, hq_ray, hq_seg⟩ | ⟨q, hq_ray, hq_seg⟩)
    · exact ⟨q, hq_ray, h_union ▸ Set.mem_union_left _ hq_seg⟩
    · exact ⟨q, hq_ray, h_union ▸ Set.mem_union_right _ hq_seg⟩

/-- A ray can't hit both sub-segments if it avoids the split point. -/
private lemma ray_not_both_sub_segments (r : Ray) (a b pt : Vector2D)
    (h_pt : pt ∈ (LineSegment.mk a b).toSet)
    (h_avoids : pt ∉ r.toSet) :
    ¬(rayIntersectsSegment r ⟨a, pt⟩ ∧ rayIntersectsSegment r ⟨pt, b⟩) := by
  intro ⟨⟨q1, hq1_ray, hq1_seg⟩, ⟨q2, hq2_ray, hq2_seg⟩⟩
  apply h_avoids
  obtain ⟨t1, ht1_0, ht1_1, hq1x, hq1y⟩ := hq1_seg
  obtain ⟨t2, ht2_0, ht2_1, hq2x, hq2y⟩ := hq2_seg
  obtain ⟨s, hs0, hs1, hptx, hpty⟩ := h_pt
  obtain ⟨tr1, htr1_0, hq1x_r, hq1y_r⟩ := hq1_ray
  obtain ⟨tr2, htr2_0, hq2x_r, hq2y_r⟩ := hq2_ray
  dsimp only at hq1x hq1y hq2x hq2y hptx hpty
  by_cases ht1_eq_1 : t1 = 1
  · subst ht1_eq_1; simp at hq1x hq1y
    exact ⟨tr1, htr1_0, by linarith, by linarith⟩
  by_cases ht2_eq_0 : t2 = 0
  · subst ht2_eq_0; simp at hq2x hq2y
    exact ⟨tr2, htr2_0, by linarith, by linarith⟩
  have ht1_lt_1 : t1 < 1 := lt_of_le_of_ne ht1_1 ht1_eq_1
  have ht2_pos : (0 : ℚ) < t2 := lt_of_le_of_ne ht2_0 (Ne.symm ht2_eq_0)
  set D := s * (1 - t1) + t2 * (1 - s) with hD_def
  have hD_pos : 0 < D := by
    rw [hD_def]
    by_cases hs_eq_0 : s = 0
    · simp [hs_eq_0]; linarith
    · have : s > 0 := lt_of_le_of_ne hs0 (Ne.symm hs_eq_0)
      nlinarith
  have hD_ne : D ≠ 0 := ne_of_gt hD_pos
  set u := s * (1 - t1) / D with hu_def
  have hu_0 : 0 ≤ u := div_nonneg (by nlinarith) (le_of_lt hD_pos)
  have hu_1 : u ≤ 1 := by
    rw [hu_def]; exact div_le_one_of_le₀ (by rw [hD_def]; nlinarith) (le_of_lt hD_pos)
  have hcomb_x : pt.x * D = ((1 - u) * q1.x + u * q2.x) * D := by
    rw [hq1x, hq2x, hptx, hu_def]; field_simp; rw [hD_def]; ring
  have hcomb_y : pt.y * D = ((1 - u) * q1.y + u * q2.y) * D := by
    rw [hq1y, hq2y, hpty, hu_def]; field_simp; rw [hD_def]; ring
  have hcomb_x' : pt.x = (1 - u) * q1.x + u * q2.x :=
    mul_right_cancel₀ hD_ne hcomb_x
  have hcomb_y' : pt.y = (1 - u) * q1.y + u * q2.y :=
    mul_right_cancel₀ hD_ne hcomb_y
  exact ⟨(1 - u) * tr1 + u * tr2, by nlinarith,
         by rw [hcomb_x', hq1x_r, hq2x_r]; ring,
         by rw [hcomb_y', hq1y_r, hq2y_r]; ring⟩

/-- If ray avoids pt, the boolean count for sub-segments equals that for the original segment. -/
private lemma segment_split_xor (r : Ray) (a b pt : Vector2D)
    (h_pt : pt ∈ (LineSegment.mk a b).toSet)
    (h_avoids : pt ∉ r.toSet) :
    (if decide (rayIntersectsSegment r ⟨a, pt⟩) then 1 else 0) +
    (if decide (rayIntersectsSegment r ⟨pt, b⟩) then 1 else 0) =
    (if decide (rayIntersectsSegment r ⟨a, b⟩) then (1 : ℕ) else 0) := by
  have h_split := segment_split_rayIntersects r a b pt h_pt
  have h_not_both := ray_not_both_sub_segments r a b pt h_pt h_avoids
  by_cases h1 : rayIntersectsSegment r ⟨a, pt⟩ <;>
  by_cases h2 : rayIntersectsSegment r ⟨pt, b⟩ <;>
  simp_all

/-- `intersectionRayGraphSegmentsNumber` is preserved by `replaceSegment` when
    the ray avoids the split point. -/
private lemma replaceSegment_crossing_eq (r : Ray) (segs : List LineSegment)
    (seg : LineSegment) (pt : Vector2D)
    (h_mem : seg ∈ segs)
    (h_pt : pt ∈ seg.toSet)
    (h_avoids : pt ∉ r.toSet) :
    (replaceSegment segs seg ⟨seg.p1, pt⟩ ⟨pt, seg.p2⟩).countP
      (fun s => decide (rayIntersectsSegment r s)) =
    segs.countP (fun s => decide (rayIntersectsSegment r s)) := by
  have hcrel := replaceSegment_countP_relate segs seg ⟨seg.p1, pt⟩ ⟨pt, seg.p2⟩
    h_mem (fun s => decide (rayIntersectsSegment r s))
  have hxor := segment_split_xor r seg.p1 seg.p2 pt h_pt h_avoids
  have h_eta : (⟨seg.p1, seg.p2⟩ : LineSegment) = seg := by
    cases seg; rfl
  rw [h_eta] at hxor
  simp only at hcrel hxor
  omega

/-- Given a point p not in a list of vertices, there exists a ray from p
    that avoids all vertices in the list. -/
private lemma exists_ray_avoiding_list (p : Vector2D) (verts : List Vector2D)
    (h_not_vert : ∀ v ∈ verts, v ≠ p) :
    ∃ r : Ray, r.origin = p ∧ r.toSet ∩ { q | q ∈ verts } = ∅ := by
  have : Infinite ℚ := Infinite.of_injective (fun n : ℕ => (n : ℚ)) Nat.cast_injective
  let badSlopes : Finset ℚ := (verts.filterMap fun v =>
    if v.x > p.x then some ((v.y - p.y) / (v.x - p.x)) else none).toFinset
  obtain ⟨q, hq⟩ := Finset.exists_not_mem badSlopes
  have h_nonzero : (⟨1, q⟩ : Vector2D) ≠ ⟨0, 0⟩ := by
    intro h; exact absurd (congrArg Vector2D.x h) (by norm_num)
  refine ⟨⟨p, ⟨1, q⟩, h_nonzero⟩, rfl, ?_⟩
  rw [Set.eq_empty_iff_forall_not_mem]
  intro v hv
  obtain ⟨hv_ray, hv_vert⟩ := hv
  simp only [Set.mem_setOf_eq] at hv_vert
  obtain ⟨t, ht_nonneg, hvx, hvy⟩ := hv_ray
  simp only [mul_one] at hvx
  have hne : v ≠ p := h_not_vert v hv_vert
  have ht_eq : t = v.x - p.x := by linarith
  by_cases h_gt : v.x > p.x
  · have h_slope_mem : (v.y - p.y) / (v.x - p.x) ∈ badSlopes := by
      simp only [badSlopes, List.mem_toFinset, List.mem_filterMap]
      exact ⟨v, hv_vert, by simp [if_pos h_gt]⟩
    have hvmy : v.y - p.y = t * q := by linarith
    rw [ht_eq] at hvmy
    have hvx_ne : v.x - p.x ≠ 0 := ne_of_gt (by linarith : v.x - p.x > 0)
    have hq_eq : q = (v.y - p.y) / (v.x - p.x) := by
      rw [eq_div_iff hvx_ne, mul_comm]; linarith
    exact hq (hq_eq ▸ h_slope_mem)
  · push_neg at h_gt
    by_cases h_eq : v.x = p.x
    · have ht_zero : t = 0 := by linarith
      have hvy_eq : v.y = p.y := by
        have := hvy; rw [ht_zero] at this; simp at this; exact this
      exact hne (by cases v; cases p; simp_all)
    · linarith [lt_of_le_of_ne h_gt h_eq]

/-! ### Single-point refinement -/

/-- Refine an even graph by inserting a point on an existing segment.
    If the point is already an endpoint, returns the graph unchanged.
    Otherwise, replaces the segment with two sub-segments and adds the point as a vertex. -/
def graphRefinement
    (G : EvenGraph) (seg : LineSegment) (pt : Vector2D)
    (h_seg : seg ∈ G.segments) (_h_pt : pt ∈ seg.toSet) : EvenGraph :=
  if h : pt = seg.p1 ∨ pt = seg.p2 then G
  else
    { segments := replaceSegment G.segments seg ⟨seg.p1, pt⟩ ⟨pt, seg.p2⟩
      segments_nondegenerate := by
        push_neg at h
        obtain ⟨h_ne1, h_ne2⟩ := h
        intro s hs
        rcases mem_replaceSegment G.segments seg ⟨seg.p1, pt⟩ ⟨pt, seg.p2⟩ s hs with rfl | rfl | hs_orig
        · show seg.p1 ≠ pt; exact h_ne1.symm
        · show pt ≠ seg.p2; exact h_ne2
        · exact G.segments_nondegenerate s hs_orig
      even_degree := by
        push_neg at h
        obtain ⟨h_ne1, h_ne2⟩ := h
        have h_ne1' : seg.p1 ≠ pt := Ne.symm h_ne1
        have h_ne2' : seg.p2 ≠ pt := Ne.symm h_ne2
        have h_nd : seg.p1 ≠ seg.p2 := G.segments_nondegenerate seg h_seg
        intro v
        -- Use replaceSegment_countP_relate
        set p := (fun s : LineSegment => decide (s.p1 = v ∨ s.p2 = v)) with hp_def
        have hcrel := replaceSegment_countP_relate G.segments seg ⟨seg.p1, pt⟩ ⟨pt, seg.p2⟩ h_seg p
        by_cases heq_v : v = pt
        · -- v = pt
          have hp_seg_val : p seg = false := by
            rw [hp_def]; show decide (seg.p1 = v ∨ seg.p2 = v) = false
            rw [heq_v]; exact decide_eq_false (by push_neg; exact ⟨h_ne1', h_ne2'⟩)
          have hp_seg1_val : p ⟨seg.p1, pt⟩ = true := by
            rw [hp_def]; show decide (seg.p1 = v ∨ pt = v) = true
            rw [heq_v]; exact decide_eq_true (Or.inr rfl)
          have hp_seg2_val : p ⟨pt, seg.p2⟩ = true := by
            rw [hp_def]; show decide (pt = v ∨ seg.p2 = v) = true
            rw [heq_v]; exact decide_eq_true (Or.inl rfl)
          rw [hp_seg_val, hp_seg1_val, hp_seg2_val] at hcrel
          simp at hcrel
          have h_even : Even (G.segments.countP p) := by
            have := G.even_degree pt
            convert this using 1
            congr 1; ext s; simp [hp_def, heq_v]
          have h_eq : (replaceSegment G.segments seg ⟨seg.p1, pt⟩ ⟨pt, seg.p2⟩).countP p =
            G.segments.countP p + 2 := by omega
          rw [h_eq]; exact Even.add h_even ⟨1, rfl⟩
        · -- v ≠ pt
          have h_even := G.even_degree v
          have hpv_false : pt ≠ v := fun heq => heq_v heq.symm
          by_cases hv1 : seg.p1 = v <;> by_cases hv2 : seg.p2 = v
          -- Eliminate impossible case: hv1 ∧ hv2 would give seg.p1 = seg.p2
          all_goals (try (exfalso; exact h_nd (by rw [hv1, hv2])))
          · -- hv1, ¬hv2
            rw [show p seg = decide (seg.p1 = v ∨ seg.p2 = v) from rfl,
                show p ⟨seg.p1, pt⟩ = decide (seg.p1 = v ∨ pt = v) from rfl,
                show p ⟨pt, seg.p2⟩ = decide (pt = v ∨ seg.p2 = v) from rfl,
                decide_eq_true (Or.inl hv1 : seg.p1 = v ∨ seg.p2 = v),
                decide_eq_true (Or.inl hv1 : seg.p1 = v ∨ pt = v),
                decide_eq_false (show ¬(pt = v ∨ seg.p2 = v) from by push_neg; exact ⟨hpv_false, hv2⟩)] at hcrel
            simp at hcrel
            have : (replaceSegment G.segments seg ⟨seg.p1, pt⟩ ⟨pt, seg.p2⟩).countP p = G.segments.countP p := by omega
            rw [this]; exact h_even
          · -- ¬hv1, hv2
            rw [show p seg = decide (seg.p1 = v ∨ seg.p2 = v) from rfl,
                show p ⟨seg.p1, pt⟩ = decide (seg.p1 = v ∨ pt = v) from rfl,
                show p ⟨pt, seg.p2⟩ = decide (pt = v ∨ seg.p2 = v) from rfl,
                decide_eq_true (Or.inr hv2 : seg.p1 = v ∨ seg.p2 = v),
                decide_eq_false (show ¬(seg.p1 = v ∨ pt = v) from by push_neg; exact ⟨hv1, hpv_false⟩),
                decide_eq_true (Or.inr hv2 : pt = v ∨ seg.p2 = v)] at hcrel
            simp at hcrel
            have : (replaceSegment G.segments seg ⟨seg.p1, pt⟩ ⟨pt, seg.p2⟩).countP p = G.segments.countP p := by omega
            rw [this]; exact h_even
          · -- ¬hv1, ¬hv2
            rw [show p seg = decide (seg.p1 = v ∨ seg.p2 = v) from rfl,
                show p ⟨seg.p1, pt⟩ = decide (seg.p1 = v ∨ pt = v) from rfl,
                show p ⟨pt, seg.p2⟩ = decide (pt = v ∨ seg.p2 = v) from rfl,
                decide_eq_false (show ¬(seg.p1 = v ∨ seg.p2 = v) from by push_neg; exact ⟨hv1, hv2⟩),
                decide_eq_false (show ¬(seg.p1 = v ∨ pt = v) from by push_neg; exact ⟨hv1, hpv_false⟩),
                decide_eq_false (show ¬(pt = v ∨ seg.p2 = v) from by push_neg; exact ⟨hpv_false, hv2⟩)] at hcrel
            simp at hcrel
            have : (replaceSegment G.segments seg ⟨seg.p1, pt⟩ ⟨pt, seg.p2⟩).countP p = G.segments.countP p := by omega
            rw [this]; exact h_even }

/-- The segments of `graphRefinement G seg pt _ _` are obtained from `G.segments`
    by replacing `seg` with two halves `⟨seg.p1, pt⟩` and `⟨pt, seg.p2⟩`. -/
theorem graphRefinement_segments_eq
    (G : EvenGraph) (seg : LineSegment) (pt : Vector2D)
    (h_seg : seg ∈ G.segments) (h_pt : pt ∈ seg.toSet)
    (h_ne1 : pt ≠ seg.p1) (h_ne2 : pt ≠ seg.p2) :
    (graphRefinement G seg pt h_seg h_pt).segments =
    replaceSegment G.segments seg ⟨seg.p1, pt⟩ ⟨pt, seg.p2⟩ := by
  unfold graphRefinement
  rw [dif_neg (by push_neg; exact ⟨h_ne1, h_ne2⟩)]

/-- Membership in the vertex list of the refined graph: a point is a vertex of the
    refinement iff it is `pt` or a vertex of the original graph. -/
private lemma graphRefinement_mem_toVertices
    (G : EvenGraph) (seg : LineSegment) (pt : Vector2D)
    (h_seg : seg ∈ G.segments) (h_pt : pt ∈ seg.toSet) (v : Vector2D) :
    v ∈ (graphRefinement G seg pt h_seg h_pt).toVertices ↔
    v = pt ∨ v ∈ G.toVertices := by
  constructor
  · intro hv
    rw [EvenGraph.mem_toVertices_iff] at hv
    obtain ⟨s, hs_mem, h_ep⟩ := hv
    unfold graphRefinement at hs_mem
    split_ifs at hs_mem with h_branch
    · exact Or.inr ((EvenGraph.mem_toVertices_iff G v).mpr ⟨s, hs_mem, h_ep⟩)
    · rcases mem_replaceSegment G.segments seg ⟨seg.p1, pt⟩ ⟨pt, seg.p2⟩ s hs_mem with
        rfl | rfl | hs_orig
      · simp only at h_ep
        rcases h_ep with h_p1 | h_p2
        · refine Or.inr ?_
          rw [← h_p1]
          exact G.p1_mem_toVertices h_seg
        · exact Or.inl h_p2.symm
      · simp only at h_ep
        rcases h_ep with h_p1 | h_p2
        · exact Or.inl h_p1.symm
        · refine Or.inr ?_
          rw [← h_p2]
          exact G.p2_mem_toVertices h_seg
      · exact Or.inr ((EvenGraph.mem_toVertices_iff G v).mpr ⟨s, hs_orig, h_ep⟩)
  · rintro (rfl | hv)
    · rw [EvenGraph.mem_toVertices_iff]
      unfold graphRefinement
      split_ifs with h_branch
      · rcases h_branch with rfl | rfl
        · exact ⟨seg, h_seg, Or.inl rfl⟩
        · exact ⟨seg, h_seg, Or.inr rfl⟩
      · exact ⟨⟨seg.p1, v⟩,
          seg1_mem_replaceSegment G.segments seg _ _ h_seg, Or.inr rfl⟩
    · rw [EvenGraph.mem_toVertices_iff] at hv
      obtain ⟨s, hs_mem, h_ep⟩ := hv
      rw [EvenGraph.mem_toVertices_iff]
      unfold graphRefinement
      split_ifs with h_branch
      · exact ⟨s, hs_mem, h_ep⟩
      · by_cases h_eq : s = seg
        · subst h_eq
          rcases h_ep with h_p1 | h_p2
          · exact ⟨⟨s.p1, pt⟩, seg1_mem_replaceSegment G.segments s _ _ hs_mem, Or.inl h_p1⟩
          · exact ⟨⟨pt, s.p2⟩, seg2_mem_replaceSegment G.segments s _ _ hs_mem, Or.inr h_p2⟩
        · exact ⟨s, replaceSegment_of_mem_ne G.segments seg _ _ s hs_mem h_eq, h_ep⟩

/-- The vertex set of the refined graph equals the insertion of `pt` into the
    original vertex set. -/
private lemma graphRefinement_toVertexSet_eq
    (G : EvenGraph) (seg : LineSegment) (pt : Vector2D)
    (h_seg : seg ∈ G.segments) (h_pt : pt ∈ seg.toSet) :
    (graphRefinement G seg pt h_seg h_pt).toVertexSet =
    insert pt G.toVertexSet := by
  ext v
  simp only [Graph.toVertexSet, Set.mem_insert_iff, Set.mem_setOf_eq,
             graphRefinement_mem_toVertices G seg pt h_seg h_pt v]

/-- The boundary of the refined graph equals the boundary of the original. -/
theorem refinement_boundary_eq
    (G : EvenGraph) (seg : LineSegment) (pt : Vector2D)
    (h_seg : seg ∈ G.segments) (h_pt : pt ∈ seg.toSet) :
    (graphRefinement G seg pt h_seg h_pt).toBoundarySet =
    G.toBoundarySet := by
  simp only [graphRefinement]
  split_ifs with h
  · rfl
  · simp only [Graph.toBoundarySet]
    exact replaceSegment_boundary_eq G.segments seg ⟨seg.p1, pt⟩ ⟨pt, seg.p2⟩
      h_seg (segment_split seg.p1 seg.p2 pt h_pt)

/-- The interior of the refined graph equals the interior of the original. -/
theorem refinement_interior_eq
    (G : EvenGraph) (seg : LineSegment) (pt : Vector2D)
    (h_seg : seg ∈ G.segments) (h_pt : pt ∈ seg.toSet) :
    (graphRefinement G seg pt h_seg h_pt).interior =
    G.interior := by
  by_cases h : pt = seg.p1 ∨ pt = seg.p2
  · have : graphRefinement G seg pt h_seg h_pt = G := by
      simp only [graphRefinement, dif_pos h]
    rw [this]
  · push_neg at h
    set G' := graphRefinement G seg pt h_seg h_pt with hG'_def
    have hG'_segs : G'.segments = replaceSegment G.segments seg ⟨seg.p1, pt⟩ ⟨pt, seg.p2⟩ := by
      simp only [hG'_def, graphRefinement,
                 dif_neg (not_or.mpr ⟨h.1, h.2⟩)]
    have h_vset : G'.toVertexSet = insert pt G.toVertexSet :=
      graphRefinement_toVertexSet_eq G seg pt h_seg h_pt
    have h_bdy_eq : G'.toBoundarySet = G.toBoundarySet :=
      refinement_boundary_eq G seg pt h_seg h_pt
    have h_avoid_iff : ∀ p', (∀ s ∈ G'.segments, pointAvoidsSegment p' s) ↔
        (∀ s ∈ G.segments, pointAvoidsSegment p' s) := by
      intro p'
      simp only [pointAvoidsSegment]
      constructor
      · intro h_new s hs hp
        have : p' ∈ G.toBoundarySet := ⟨s, hs, hp⟩
        rw [← h_bdy_eq] at this
        obtain ⟨s', hs', hp'⟩ := this
        exact h_new s' hs' hp'
      · intro h_old s hs hp
        have : p' ∈ G'.toBoundarySet := ⟨s, hs, hp⟩
        rw [h_bdy_eq] at this
        obtain ⟨s', hs', hp'⟩ := this
        exact h_old s' hs' hp'
    have h_avoids_G'_to_G : ∀ r, rayAvoidsGraphVertices r G' → rayAvoidsGraphVertices r G := by
      intro r h_avoids
      rw [rayAvoidsGraphVertices, h_vset] at h_avoids
      rw [rayAvoidsGraphVertices, Set.eq_empty_iff_forall_not_mem]
      rw [Set.eq_empty_iff_forall_not_mem] at h_avoids
      intro v ⟨hv_ray, hv_mem⟩
      exact h_avoids v ⟨hv_ray, Set.mem_insert_of_mem _ hv_mem⟩
    have h_avoids_G'_pt : ∀ r, rayAvoidsGraphVertices r G' → pt ∉ r.toSet := by
      intro r h_avoids h_mem
      rw [rayAvoidsGraphVertices, h_vset] at h_avoids
      exact Set.eq_empty_iff_forall_not_mem.mp h_avoids pt ⟨h_mem, Set.mem_insert pt _⟩
    have h_crossing_eq : ∀ r, pt ∉ r.toSet →
        intersectionRayGraphSegmentsNumber r G' = intersectionRayGraphSegmentsNumber r G := by
      intro r h_r_pt
      simp only [intersectionRayGraphSegmentsNumber, hG'_segs]
      exact replaceSegment_crossing_eq r G.segments seg pt h_seg h_pt h_r_pt
    ext p'
    simp only [EvenGraph.interior, Set.mem_setOf_eq]
    constructor
    · intro ⟨h_avoid, h_cross⟩
      rw [h_avoid_iff] at h_avoid
      refine ⟨h_avoid, fun r hr h_avoids_G => ?_⟩
      by_cases h_r_pt : pt ∈ r.toSet
      · have h_p_on_r : p' ∈ r.toSet := by
          simp only [Ray.toSet, Set.mem_setOf_eq]
          exact ⟨0, le_refl 0, by rw [hr]; ring, by rw [hr]; ring⟩
        have h_p_ne_pt : pt ≠ p' := by
          intro heq
          exact (h_avoid seg h_seg) (heq ▸ h_pt)
        have h_p_not_vert : ∀ v ∈ G.toVertices, v ≠ p' := by
          intro v hv heq
          exact Set.eq_empty_iff_forall_not_mem.mp h_avoids_G p'
            ⟨h_p_on_r, heq ▸ hv⟩
        have h_p_not_vert' : ∀ v ∈ (pt :: G.toVertices), v ≠ p' := by
          intro v hv
          simp only [List.mem_cons] at hv
          rcases hv with rfl | hv
          · exact h_p_ne_pt
          · exact h_p_not_vert v hv
        obtain ⟨r', hr'_origin, hr'_avoids⟩ :=
          exists_ray_avoiding_list p' (pt :: G.toVertices) h_p_not_vert'
        have hr'_avoids_G' : rayAvoidsGraphVertices r' G' := by
          rw [rayAvoidsGraphVertices, h_vset, Set.eq_empty_iff_forall_not_mem]
          intro v ⟨hv_ray, hv_mem⟩
          rcases hv_mem with rfl | hv_mem
          · exact Set.eq_empty_iff_forall_not_mem.mp hr'_avoids v
              ⟨hv_ray, (List.mem_cons_self _ _)⟩
          · exact Set.eq_empty_iff_forall_not_mem.mp hr'_avoids v
              ⟨hv_ray, List.mem_cons_of_mem _ hv_mem⟩
        have h_cross_G' := h_cross r' hr'_origin hr'_avoids_G'
        have h_r'_pt := h_avoids_G'_pt r' hr'_avoids_G'
        rw [h_crossing_eq r' h_r'_pt] at h_cross_G'
        have hr'_avoids_G := h_avoids_G'_to_G r' hr'_avoids_G'
        have h_same_origin : sameOrigin r r' := by
          simp only [sameOrigin]; rw [hr, hr'_origin]
        have h_avoids_segs : ∀ s ∈ G.segments, pointAvoidsSegment r.origin s := by
          rw [hr]; exact h_avoid
        rw [intersectionParity_eq_of_sameOrigin_avoidsGraphVertices
          r r' G h_same_origin h_avoids_G hr'_avoids_G h_avoids_segs]
        exact h_cross_G'
      · have h_avoids_G' : rayAvoidsGraphVertices r G' := by
          rw [rayAvoidsGraphVertices, h_vset, Set.eq_empty_iff_forall_not_mem]
          intro v ⟨hv_ray, hv_mem⟩
          rcases hv_mem with rfl | hv_mem
          · exact h_r_pt hv_ray
          · exact Set.eq_empty_iff_forall_not_mem.mp h_avoids_G v ⟨hv_ray, hv_mem⟩
        have h_cross_G' := h_cross r hr h_avoids_G'
        rw [h_crossing_eq r h_r_pt] at h_cross_G'
        exact h_cross_G'
    · intro ⟨h_avoid, h_cross⟩
      rw [h_avoid_iff]
      refine ⟨h_avoid, fun r hr h_avoids_G' => ?_⟩
      have h_r_pt := h_avoids_G'_pt r h_avoids_G'
      have h_avoids_G := h_avoids_G'_to_G r h_avoids_G'
      rw [h_crossing_eq r h_r_pt]
      exact h_cross r hr h_avoids_G

/-! ### Iterative refinement -/

/-! #### Sub-segment endpoint lemmas -/

/-- A point is not in the interior of a sub-segment if it is an endpoint of the
    parent segment that is beyond the split point. -/
private lemma sub_segment_far_endpoint_not_mem (a b pt : Vector2D)
    (h_pt : pt ∈ (LineSegment.mk a b).toSet)
    (h_ne_a : pt ≠ a) (h_ne_b : pt ≠ b) (h_ab : a ≠ b) :
    b ∉ (LineSegment.mk a pt).toSet := by
  -- pt = (1-s)*a + s*b for s ∈ (0,1) strictly
  -- If b ∈ ⟨a, pt⟩, then b = (1-t)*a + t*pt for t ∈ [0,1]
  -- Substituting: b = ((1-t) + t*(1-s))*a + t*s*b
  -- (1 - t*s)*b = (1 - t*s)*a, so (since a ≠ b) t*s = 1, t = s = 1, but s < 1. Contradiction.
  obtain ⟨s, hs0, hs1, hptx, hpty⟩ := h_pt
  have hs_ne0 : s ≠ 0 := by
    intro hs; simp [hs] at hptx hpty
    exact h_ne_a (Vector2D.ext hptx hpty)
  have hs_ne1 : s ≠ 1 := by
    intro hs; simp [hs] at hptx hpty
    exact h_ne_b (Vector2D.ext hptx hpty)
  have hs_pos : (0 : ℚ) < s := lt_of_le_of_ne hs0 (Ne.symm hs_ne0)
  have hs_lt1 : s < 1 := lt_of_le_of_ne hs1 hs_ne1
  intro ⟨t, ht0, ht1, hbx, hby⟩
  -- b = (1-t)*a + t*pt
  -- bx = (1-t)*ax + t*ptx = (1-t)*ax + t*((1-s)*ax + s*bx)
  --    = ((1-t) + t*(1-s))*ax + t*s*bx
  -- bx*(1-t*s) = ax*(1-t*s)
  -- similarly for y
  have hbx_eq : b.x * (1 - t * s) = a.x * (1 - t * s) := by
    have := hbx; rw [hptx] at this; nlinarith [mul_comm t s]
  have hby_eq : b.y * (1 - t * s) = a.y * (1 - t * s) := by
    have := hby; rw [hpty] at this; nlinarith [mul_comm t s]
  have hts : t * s < 1 := by nlinarith
  have hts_ne : (1 - t * s) ≠ 0 := by linarith
  have hbx_a : b.x = a.x := mul_right_cancel₀ hts_ne (by linarith)
  have hby_a : b.y = a.y := mul_right_cancel₀ hts_ne (by linarith)
  exact h_ab (Vector2D.ext hbx_a.symm hby_a.symm)

/-- Similarly, `a ∉ ⟨pt, b⟩` when pt is strictly inside ⟨a,b⟩. -/
private lemma sub_segment_near_endpoint_not_mem (a b pt : Vector2D)
    (h_pt : pt ∈ (LineSegment.mk a b).toSet)
    (h_ne_a : pt ≠ a) (h_ne_b : pt ≠ b) (h_ab : a ≠ b) :
    a ∉ (LineSegment.mk pt b).toSet := by
  obtain ⟨s, hs0, hs1, hptx, hpty⟩ := h_pt
  have hs_ne0 : s ≠ 0 := by
    intro hs; simp [hs] at hptx hpty
    exact h_ne_a (Vector2D.ext hptx hpty)
  have hs_ne1 : s ≠ 1 := by
    intro hs; simp [hs] at hptx hpty
    exact h_ne_b (Vector2D.ext hptx hpty)
  have hs_pos : (0 : ℚ) < s := lt_of_le_of_ne hs0 (Ne.symm hs_ne0)
  have hs_lt1 : s < 1 := lt_of_le_of_ne hs1 hs_ne1
  intro ⟨t, ht0, ht1, hax, hay⟩
  -- a = (1-t)*pt + t*b
  -- ax = (1-t)*ptx + t*bx = (1-t)*((1-s)*ax + s*bx) + t*bx
  --    = (1-t)*(1-s)*ax + ((1-t)*s + t)*bx
  -- ax*(1 - (1-t)*(1-s)) = bx*(1-(1-t)*(1-s)) ... let's compute
  -- ax*(1-t)*(1-s) = ax - bx*((1-t)*s + t)
  -- Actually: ax = (1-t)*((1-s)*ax + s*bx) + t*bx
  --         = (1-t)*(1-s)*ax + (1-t)*s*bx + t*bx
  --         = (1-t)*(1-s)*ax + ((1-t)*s + t)*bx
  -- ax - (1-t)*(1-s)*ax = ((1-t)*s + t)*bx
  -- ax*(1 - (1-t)*(1-s)) = bx*(1 - (1-t)*(1-s))
  -- And 1 - (1-t)*(1-s) = t + s - t*s = t*(1-s) + s > 0 (since s > 0)
  have hax_eq : a.x * (1 - (1 - t) * (1 - s)) = b.x * (1 - (1 - t) * (1 - s)) := by
    have := hax; rw [hptx] at this; nlinarith [mul_comm t s, mul_comm (1 - t) (1 - s)]
  have hay_eq : a.y * (1 - (1 - t) * (1 - s)) = b.y * (1 - (1 - t) * (1 - s)) := by
    have := hay; rw [hpty] at this; nlinarith [mul_comm t s, mul_comm (1 - t) (1 - s)]
  have hfactor_pos : (0 : ℚ) < 1 - (1 - t) * (1 - s) := by nlinarith
  have hfactor_ne : (1 - (1 - t) * (1 - s)) ≠ 0 := ne_of_gt hfactor_pos
  have hax_b : a.x = b.x := mul_right_cancel₀ hfactor_ne (by linarith)
  have hay_b : a.y = b.y := mul_right_cancel₀ hfactor_ne (by linarith)
  exact h_ab (Vector2D.ext hax_b hay_b)

/-- After `graphRefinement` at `pt` on `seg`, if `q ≠ pt` was an endpoint of all
    G-segments containing it, it is still an endpoint of all refined-graph segments
    containing it. -/
private lemma graphRefinement_preserves_endpoint
    (G : EvenGraph) (seg : LineSegment) (pt q : Vector2D)
    (h_seg : seg ∈ G.segments) (h_pt : pt ∈ seg.toSet)
    (h_q_ep : ∀ s ∈ G.segments, q ∈ s.toSet → q = s.p1 ∨ q = s.p2) :
    ∀ s ∈ (graphRefinement G seg pt h_seg h_pt).segments,
      q ∈ s.toSet → q = s.p1 ∨ q = s.p2 := by
  simp only [graphRefinement]
  split_ifs with h_ep
  · -- pt is already an endpoint: G unchanged
    exact h_q_ep
  · -- pt is strictly interior: G' has replaced seg with ⟨seg.p1, pt⟩ and ⟨pt, seg.p2⟩
    push_neg at h_ep
    obtain ⟨h_ne1, h_ne2⟩ := h_ep
    have h_nd : seg.p1 ≠ seg.p2 := G.segments_nondegenerate seg h_seg
    intro s hs h_q_s
    rcases mem_replaceSegment G.segments seg ⟨seg.p1, pt⟩ ⟨pt, seg.p2⟩ s hs with rfl | rfl | hs_orig
    · -- s = ⟨seg.p1, pt⟩
      -- q ∈ ⟨seg.p1, pt⟩.toSet ⊆ seg.toSet
      have h_q_seg : q ∈ seg.toSet := by
        have := segment_split seg.p1 seg.p2 pt h_pt
        rw [← this]
        exact Set.mem_union_left _ h_q_s
      rcases h_q_ep seg h_seg h_q_seg with rfl | rfl
      · exact Or.inl rfl
      · -- q = seg.p2, but seg.p2 ∉ ⟨seg.p1, pt⟩.toSet
        exfalso
        exact sub_segment_far_endpoint_not_mem seg.p1 seg.p2 pt h_pt h_ne1 h_ne2 h_nd h_q_s
    · -- s = ⟨pt, seg.p2⟩
      have h_q_seg : q ∈ seg.toSet := by
        have := segment_split seg.p1 seg.p2 pt h_pt
        rw [← this]
        exact Set.mem_union_right _ h_q_s
      rcases h_q_ep seg h_seg h_q_seg with rfl | rfl
      · -- q = seg.p1, but seg.p1 ∉ ⟨pt, seg.p2⟩.toSet
        exfalso
        exact sub_segment_near_endpoint_not_mem seg.p1 seg.p2 pt h_pt h_ne1 h_ne2 h_nd h_q_s
      · exact Or.inr rfl
    · -- s ∈ G.segments: use h_q_ep
      exact h_q_ep s hs_orig h_q_s

/-- The number of segments of G that strictly contain pt (pt is not an endpoint). -/
private def strictPtCount (G : EvenGraph) (pt : Vector2D) : ℕ :=
  G.segments.countP (fun s => decide (pt ∈ s.toSet) && !decide (pt = s.p1 ∨ pt = s.p2))

/-- Refine G at pt with a fuel bound (structurally recursive on Nat).
    When fuel = 0, return G unchanged. Each step decreases strictPtCount. -/
private def refineAllPtBounded : ℕ → EvenGraph → Vector2D → EvenGraph
  | 0, G, _ => G
  | n + 1, G, pt =>
    match h_find : G.segments.find? (fun s =>
        decide (pt ∈ s.toSet) && !decide (pt = s.p1 ∨ pt = s.p2)) with
    | none => G
    | some seg =>
      have h_seg : seg ∈ G.segments := List.mem_of_find?_eq_some h_find
      have h_pred := List.find?_some h_find
      have h_pt : pt ∈ seg.toSet := by
        simp only [Bool.and_eq_true, decide_eq_true_eq] at h_pred; exact h_pred.1
      refineAllPtBounded n (graphRefinement G seg pt h_seg h_pt) pt

/-- Helper: strictPtCount strictly decreases after one refinement step. -/
private lemma strictPtCount_decreases (G : EvenGraph) (pt : Vector2D)
    (seg : LineSegment)
    (h_find : G.segments.find? (fun s => decide (pt ∈ s.toSet) && !decide (pt = s.p1 ∨ pt = s.p2)) = some seg)
    (h_seg : seg ∈ G.segments)
    (h_pt : pt ∈ seg.toSet) :
    strictPtCount (graphRefinement G seg pt h_seg h_pt) pt <
    strictPtCount G pt := by
  simp only [strictPtCount]
  set p : LineSegment → Bool := fun s => decide (pt ∈ s.toSet) && !decide (pt = s.p1 ∨ pt = s.p2)
  have h_pred := List.find?_some h_find
  have h_strict : ¬(pt = seg.p1 ∨ pt = seg.p2) := by
    intro h
    simp only [p, Bool.and_eq_true, decide_eq_true_eq] at h_pred
    simp [decide_eq_true_eq.mpr h] at h_pred
  simp only [graphRefinement, dif_neg h_strict]
  have hcrel := replaceSegment_countP_relate G.segments seg ⟨seg.p1, pt⟩ ⟨pt, seg.p2⟩ h_seg p
  have hp_seg : p seg = true := by
    simp only [p, Bool.and_eq_true, decide_eq_true_eq]
    exact ⟨h_pt, by simp [decide_eq_false_iff_not.mpr h_strict]⟩
  have hp_seg1 : p ⟨seg.p1, pt⟩ = false := by simp [p]
  have hp_seg2 : p ⟨pt, seg.p2⟩ = false := by simp [p]
  simp [hp_seg, hp_seg1, hp_seg2] at hcrel
  omega

/-- Refine G at pt until every segment containing pt has pt as an endpoint. -/
private def refineAllPt (G : EvenGraph) (pt : Vector2D) : EvenGraph :=
  refineAllPtBounded (strictPtCount G pt) G pt

/-- For a point `pt` on EXACTLY ONE segment `seg` of `G` (in interior, not endpoint),
    `refineAllPt G pt` replaces `seg` with two halves `⟨seg.p1, pt⟩, ⟨pt, seg.p2⟩`.
    The hypothesis `h_count_one` ensures `seg` appears uniquely in the list,
    so `strictPtCount G pt = 1`. -/
private theorem refineAllPt_segments_unique_seg
    (G : EvenGraph) (pt : Vector2D) (seg : LineSegment)
    (h_seg : seg ∈ G.segments)
    (h_pt : pt ∈ seg.toSet)
    (h_pt_ne_p1 : pt ≠ seg.p1)
    (h_pt_ne_p2 : pt ≠ seg.p2)
    (h_unique : ∀ s ∈ G.segments, pt ∈ s.toSet → ¬(pt = s.p1 ∨ pt = s.p2) → s = seg)
    (h_count_one : G.segments.countP
        (fun s => decide (pt ∈ s.toSet) && !decide (pt = s.p1 ∨ pt = s.p2)) = 1) :
    (refineAllPt G pt).segments =
      replaceSegment G.segments seg ⟨seg.p1, pt⟩ ⟨pt, seg.p2⟩ := by
  -- The predicate counted by strictPtCount.
  set p : LineSegment → Bool :=
    fun s => decide (pt ∈ s.toSet) && !decide (pt = s.p1 ∨ pt = s.p2) with hp_def
  -- seg satisfies the predicate.
  have h_p_seg : p seg = true := by
    simp only [p, Bool.and_eq_true, decide_eq_true_eq, Bool.not_eq_true',
               decide_eq_false_iff_not]
    refine ⟨h_pt, ?_⟩
    push_neg
    exact ⟨h_pt_ne_p1, h_pt_ne_p2⟩
  -- Any segment satisfying the predicate equals seg.
  have h_pred_eq : ∀ s ∈ G.segments, p s = true → s = seg := by
    intro s hs hps
    simp only [p, Bool.and_eq_true, decide_eq_true_eq, Bool.not_eq_true',
               decide_eq_false_iff_not] at hps
    exact h_unique s hs hps.1 hps.2
  -- strictPtCount G pt = 1, so refineAllPt = refineAllPtBounded 1 G pt.
  have h_strictPtCount : strictPtCount G pt = 1 := h_count_one
  -- find? returns some seg.
  have h_find : G.segments.find? p = some seg := by
    have h_isSome : (G.segments.find? p).isSome :=
      List.find?_isSome.mpr ⟨seg, h_seg, h_p_seg⟩
    rcases h_eq : G.segments.find? p with _ | s
    · rw [h_eq] at h_isSome; simp at h_isSome
    · have h_s_mem : s ∈ G.segments := List.mem_of_find?_eq_some h_eq
      have h_p_s : p s = true := List.find?_some h_eq
      rw [h_pred_eq s h_s_mem h_p_s]
  -- The graph after one refinement step.
  set G' := graphRefinement G seg pt h_seg h_pt with hG'_def
  -- Its segments are replaceSegment.
  have h_G'_segs : G'.segments =
      replaceSegment G.segments seg ⟨seg.p1, pt⟩ ⟨pt, seg.p2⟩ :=
    graphRefinement_segments_eq G seg pt h_seg h_pt h_pt_ne_p1 h_pt_ne_p2
  -- Unfold refineAllPt.
  unfold refineAllPt
  rw [h_strictPtCount]
  -- refineAllPtBounded 1 G pt: find? returns some seg, then recurse with 0 fuel.
  show (refineAllPtBounded 1 G pt).segments = _
  unfold refineAllPtBounded
  -- Match on find? = some seg.
  split
  · -- find? = none case: contradicts h_find.
    rename_i h_none
    rw [h_find] at h_none
    exact absurd h_none (Option.some_ne_none seg)
  · -- find? = some seg' case.
    rename_i seg' h_find'
    -- seg' = seg.
    have h_seg'_eq : seg' = seg := by
      rw [h_find] at h_find'
      exact ((Option.some.injEq _ _).mp h_find').symm
    -- After refinement, refineAllPtBounded 0 returns the graph unchanged.
    subst h_seg'_eq
    simp only [refineAllPtBounded]
    exact h_G'_segs

/-- The flatMap function that splits a segment containing `pt` strictly in its
    interior into its two halves' endpoint-multisets, leaving other segments
    represented by their own endpoint-multiset. -/
private def splitFlatMapFn (pt : Vector2D) : LineSegment → List (Multiset Vector2D) :=
  fun s =>
    if (pt ∈ s.toSet ∧ pt ≠ s.p1 ∧ pt ≠ s.p2) then
      [(⟨s.p1, pt⟩ : LineSegment).toEndpointsMultiset,
       (⟨pt, s.p2⟩ : LineSegment).toEndpointsMultiset]
    else
      [s.toEndpointsMultiset]

/-- When no segment of `segs` strictly contains `pt`, the flatMap collapses
    to `map toEndpointsMultiset`. -/
private lemma splitFlatMapFn_no_split (pt : Vector2D) (segs : List LineSegment)
    (h_all : ∀ s ∈ segs, ¬ (pt ∈ s.toSet ∧ pt ≠ s.p1 ∧ pt ≠ s.p2)) :
    segs.flatMap (splitFlatMapFn pt) =
    segs.map LineSegment.toEndpointsMultiset := by
  induction segs with
  | nil => simp
  | cons hd tl ih =>
    have h_hd := h_all hd (by simp)
    have h_tl : ∀ s ∈ tl, ¬ (pt ∈ s.toSet ∧ pt ≠ s.p1 ∧ pt ≠ s.p2) :=
      fun s hs => h_all s (List.mem_cons_of_mem _ hs)
    have h_hd_eq : splitFlatMapFn pt hd = [hd.toEndpointsMultiset] := by
      unfold splitFlatMapFn; rw [if_neg h_hd]
    simp only [List.flatMap_cons, List.map_cons, h_hd_eq, List.singleton_append]
    rw [ih h_tl]

/-- Evaluation of `splitFlatMapFn pt` on the first half `⟨seg.p1, pt⟩`:
    the predicate fails since `pt` is now `p2`, so the result is the singleton. -/
private lemma splitFlatMapFn_left_half (pt p1 : Vector2D) :
    splitFlatMapFn pt ⟨p1, pt⟩ =
    [(⟨p1, pt⟩ : LineSegment).toEndpointsMultiset] := by
  unfold splitFlatMapFn
  have h : ¬ (pt ∈ (⟨p1, pt⟩ : LineSegment).toSet ∧
              pt ≠ (⟨p1, pt⟩ : LineSegment).p1 ∧
              pt ≠ (⟨p1, pt⟩ : LineSegment).p2) := by
    intro ⟨_, _, h⟩
    exact h rfl
  rw [if_neg h]

/-- Evaluation of `splitFlatMapFn pt` on the second half `⟨pt, seg.p2⟩`:
    the predicate fails since `pt` is now `p1`, so the result is the singleton. -/
private lemma splitFlatMapFn_right_half (pt p2 : Vector2D) :
    splitFlatMapFn pt ⟨pt, p2⟩ =
    [(⟨pt, p2⟩ : LineSegment).toEndpointsMultiset] := by
  unfold splitFlatMapFn
  have h : ¬ (pt ∈ (⟨pt, p2⟩ : LineSegment).toSet ∧
              pt ≠ (⟨pt, p2⟩ : LineSegment).p1 ∧
              pt ≠ (⟨pt, p2⟩ : LineSegment).p2) := by
    intro ⟨_, h, _⟩
    exact h rfl
  rw [if_neg h]

/-- Evaluation of `splitFlatMapFn pt` on a segment `seg` strictly containing `pt`. -/
private lemma splitFlatMapFn_seg_pos (pt : Vector2D) (seg : LineSegment)
    (h_pt : pt ∈ seg.toSet) (h_ne1 : pt ≠ seg.p1) (h_ne2 : pt ≠ seg.p2) :
    splitFlatMapFn pt seg =
    [(⟨seg.p1, pt⟩ : LineSegment).toEndpointsMultiset,
     (⟨pt, seg.p2⟩ : LineSegment).toEndpointsMultiset] := by
  unfold splitFlatMapFn
  rw [if_pos ⟨h_pt, h_ne1, h_ne2⟩]

/-- `replaceSegment` of the segment list, when flat-mapped with `splitFlatMapFn`,
    equals the original list flat-mapped with the same function — provided `seg`
    strictly contains `pt`. -/
private lemma replaceSegment_flatMap_eq (segs : List LineSegment) (seg : LineSegment)
    (pt : Vector2D) (h_mem : seg ∈ segs)
    (h_pt : pt ∈ seg.toSet) (h_ne1 : pt ≠ seg.p1) (h_ne2 : pt ≠ seg.p2) :
    (replaceSegment segs seg ⟨seg.p1, pt⟩ ⟨pt, seg.p2⟩).flatMap (splitFlatMapFn pt) =
    segs.flatMap (splitFlatMapFn pt) := by
  induction segs with
  | nil => simp at h_mem
  | cons hd tl ih =>
    simp only [replaceSegment]
    by_cases heq : hd = seg
    · subst heq
      rw [if_pos rfl]
      simp only [List.flatMap_cons]
      rw [splitFlatMapFn_left_half, splitFlatMapFn_right_half,
          splitFlatMapFn_seg_pos pt hd h_pt h_ne1 h_ne2]
      rfl
    · rw [if_neg heq]
      simp only [List.flatMap_cons]
      simp only [List.mem_cons] at h_mem
      have h_tl : seg ∈ tl := h_mem.resolve_left (fun h => heq h.symm)
      rw [ih h_tl]

/-- Helper: characterization of `refineAllPtBounded` segments as a multiset
    perm with respect to a flatMap that splits segments containing `pt`. -/
private lemma refineAllPtBounded_segments_perm
    (n : ℕ) (G : EvenGraph) (pt : Vector2D)
    (h_n : strictPtCount G pt ≤ n) :
    List.Perm
      ((refineAllPtBounded n G pt).segments.map LineSegment.toEndpointsMultiset)
      (G.segments.flatMap (splitFlatMapFn pt)) := by
  induction n generalizing G with
  | zero =>
    -- strictPtCount G pt = 0, so no segment satisfies the predicate.
    have h0 : strictPtCount G pt = 0 := Nat.le_zero.mp h_n
    simp only [refineAllPtBounded]
    -- For every s ∈ G.segments, the predicate is false.
    have h_all : ∀ s ∈ G.segments,
        ¬ (pt ∈ s.toSet ∧ pt ≠ s.p1 ∧ pt ≠ s.p2) := by
      intro s hs ⟨h_in, h_ne1, h_ne2⟩
      have hc : (fun s => decide (pt ∈ s.toSet) && !decide (pt = s.p1 ∨ pt = s.p2)) s = true := by
        have h_not_or : ¬(pt = s.p1 ∨ pt = s.p2) := by push_neg; exact ⟨h_ne1, h_ne2⟩
        simp [decide_eq_true_eq.mpr h_in, decide_eq_false_iff_not.mpr h_not_or]
      have hpos : 0 < strictPtCount G pt := by
        simp only [strictPtCount]; exact List.countP_pos_iff.mpr ⟨s, hs, hc⟩
      omega
    rw [splitFlatMapFn_no_split pt G.segments h_all]
  | succ n ih =>
    simp only [refineAllPtBounded]
    split
    · -- find? = none case: every segment fails the predicate.
      rename_i h_none
      have h_all : ∀ s ∈ G.segments,
          ¬ (pt ∈ s.toSet ∧ pt ≠ s.p1 ∧ pt ≠ s.p2) := by
        intro s hs ⟨h_in, h_ne1, h_ne2⟩
        rw [List.find?_eq_none] at h_none
        have h_not_or : ¬(pt = s.p1 ∨ pt = s.p2) := by push_neg; exact ⟨h_ne1, h_ne2⟩
        have hc : (fun s => decide (pt ∈ s.toSet) && !decide (pt = s.p1 ∨ pt = s.p2)) s = true := by
          simp [decide_eq_true_eq.mpr h_in, decide_eq_false_iff_not.mpr h_not_or]
        exact absurd hc (h_none s hs)
      rw [splitFlatMapFn_no_split pt G.segments h_all]
    · rename_i seg h_find
      have h_seg := List.mem_of_find?_eq_some h_find
      have h_pred := List.find?_some h_find
      have h_pt : pt ∈ seg.toSet := by
        simp only [Bool.and_eq_true, decide_eq_true_eq] at h_pred; exact h_pred.1
      have h_strict : ¬(pt = seg.p1 ∨ pt = seg.p2) := by
        have := h_pred
        simp only [Bool.and_eq_true, decide_eq_true_eq, Bool.not_eq_true',
                   decide_eq_false_iff_not] at this
        exact this.2
      push_neg at h_strict
      obtain ⟨h_ne1, h_ne2⟩ := h_strict
      -- Apply IH to G' = graphRefinement G seg pt.
      set G' := graphRefinement G seg pt h_seg h_pt with hG'_def
      have h_dec := strictPtCount_decreases G pt seg h_find h_seg h_pt
      have h_n' : strictPtCount G' pt ≤ n :=
        Nat.lt_succ_iff.mp (Nat.lt_of_lt_of_le h_dec h_n)
      have h_ih := ih G' h_n'
      -- G'.segments = replaceSegment G.segments seg ⟨seg.p1, pt⟩ ⟨pt, seg.p2⟩
      have h_G'_segs : G'.segments =
          replaceSegment G.segments seg ⟨seg.p1, pt⟩ ⟨pt, seg.p2⟩ :=
        graphRefinement_segments_eq G seg pt h_seg h_pt h_ne1 h_ne2
      -- Use replaceSegment_flatMap_eq to rewrite G'.flatMap = G.flatMap.
      have h_eq := replaceSegment_flatMap_eq G.segments seg pt h_seg h_pt h_ne1 h_ne2
      rw [h_G'_segs] at h_ih
      rw [h_eq] at h_ih
      exact h_ih

/-- The segments of `refineAllPt G pt`, viewed as a multiset of unordered
    endpoint pairs, equal what you get by replacing each segment of `G`
    that contains `pt` strictly in its interior with the two halves
    `⟨s.p1, pt⟩` and `⟨pt, s.p2⟩`, leaving other segments unchanged. -/
private theorem refineAllPt_segments_perm (G : EvenGraph) (pt : Vector2D) :
    List.Perm
      ((refineAllPt G pt).segments.map LineSegment.toEndpointsMultiset)
      (G.segments.flatMap (fun s =>
        if (pt ∈ s.toSet ∧ pt ≠ s.p1 ∧ pt ≠ s.p2) then
          [(⟨s.p1, pt⟩ : LineSegment).toEndpointsMultiset,
           (⟨pt, s.p2⟩ : LineSegment).toEndpointsMultiset]
        else
          [s.toEndpointsMultiset])) := by
  have h := refineAllPtBounded_segments_perm (strictPtCount G pt) G pt (le_refl _)
  unfold refineAllPt
  unfold splitFlatMapFn at h
  exact h

private lemma refineAllPtBounded_boundary_eq (n : ℕ) (G : EvenGraph) (pt : Vector2D) :
    (refineAllPtBounded n G pt).toBoundarySet = G.toBoundarySet := by
  induction n generalizing G with
  | zero => simp only [refineAllPtBounded]
  | succ n ih =>
    simp only [refineAllPtBounded]
    split
    · rfl
    · rename_i seg h_find
      have h_seg := List.mem_of_find?_eq_some h_find
      have h_pt : pt ∈ seg.toSet := by
        have h_pred := List.find?_some h_find
        simp only [Bool.and_eq_true, decide_eq_true_eq] at h_pred; exact h_pred.1
      rw [ih, refinement_boundary_eq]

/-- `refineAllPtBounded` preserves the interior for any fuel. -/
private lemma refineAllPtBounded_interior_eq (n : ℕ) (G : EvenGraph) (pt : Vector2D) :
    (refineAllPtBounded n G pt).interior = G.interior := by
  induction n generalizing G with
  | zero => simp only [refineAllPtBounded]
  | succ n ih =>
    simp only [refineAllPtBounded]
    split
    · rfl
    · rename_i seg h_find
      have h_seg := List.mem_of_find?_eq_some h_find
      have h_pt : pt ∈ seg.toSet := by
        have h_pred := List.find?_some h_find
        simp only [Bool.and_eq_true, decide_eq_true_eq] at h_pred; exact h_pred.1
      rw [ih, refinement_interior_eq]

/-- After `refineAllPtBounded n G pt` with n ≥ strictPtCount G pt,
    pt is an endpoint of every segment containing it. -/
private lemma refineAllPtBounded_pt_endpoint (n : ℕ) (G : EvenGraph) (pt : Vector2D)
    (h_n : strictPtCount G pt ≤ n) :
    ∀ s ∈ (refineAllPtBounded n G pt).segments, pt ∈ s.toSet → pt = s.p1 ∨ pt = s.p2 := by
  induction n generalizing G with
  | zero =>
    simp only [refineAllPtBounded]
    intro s hs h_pt_s
    by_contra h_not_ep
    have h0 : strictPtCount G pt = 0 := Nat.le_zero.mp h_n
    have hc : (fun s => decide (pt ∈ s.toSet) && !decide (pt = s.p1 ∨ pt = s.p2)) s = true := by
      simp [decide_eq_true_eq.mpr h_pt_s, decide_eq_false_iff_not.mpr h_not_ep]
    have hpos : 0 < strictPtCount G pt := by
      simp only [strictPtCount]; exact List.countP_pos_iff.mpr ⟨s, hs, hc⟩
    omega
  | succ n ih =>
    simp only [refineAllPtBounded]
    split
    · -- none case: no segment strictly contains pt
      rename_i h_none
      intro s hs h_pt_s
      by_contra h_not_ep
      have hc : (fun s => decide (pt ∈ s.toSet) && !decide (pt = s.p1 ∨ pt = s.p2)) s = true := by
        simp [decide_eq_true_eq.mpr h_pt_s, decide_eq_false_iff_not.mpr h_not_ep]
      rw [List.find?_eq_none] at h_none
      exact absurd hc (h_none s hs)
    · rename_i seg h_find
      have h_seg := List.mem_of_find?_eq_some h_find
      have h_pred := List.find?_some h_find
      have h_pt : pt ∈ seg.toSet := by
        simp only [Bool.and_eq_true, decide_eq_true_eq] at h_pred; exact h_pred.1
      have h_dec := strictPtCount_decreases G pt seg h_find h_seg h_pt
      have h_n' : strictPtCount (graphRefinement G seg pt h_seg h_pt) pt ≤ n :=
        Nat.lt_succ_iff.mp (Nat.lt_of_lt_of_le h_dec h_n)
      exact ih _ h_n'

/-- `refineAllPtBounded` preserves the endpoint property for a different point q. -/
private lemma refineAllPtBounded_preserves_endpoint (n : ℕ) (G : EvenGraph) (pt q : Vector2D)
    (h_q_ep : ∀ s ∈ G.segments, q ∈ s.toSet → q = s.p1 ∨ q = s.p2) :
    ∀ s ∈ (refineAllPtBounded n G pt).segments, q ∈ s.toSet → q = s.p1 ∨ q = s.p2 := by
  induction n generalizing G with
  | zero => simpa only [refineAllPtBounded]
  | succ n ih =>
    simp only [refineAllPtBounded]
    split
    · exact h_q_ep
    · rename_i seg h_find
      have h_seg := List.mem_of_find?_eq_some h_find
      have h_pred := List.find?_some h_find
      have h_pt : pt ∈ seg.toSet := by
        simp only [Bool.and_eq_true, decide_eq_true_eq] at h_pred; exact h_pred.1
      exact ih _ (graphRefinement_preserves_endpoint G seg pt q h_seg h_pt h_q_ep)

/-- Structural form of segments in `refineAllPtBounded`: every segment of the
    result is either a segment of the original graph (unchanged) or one of the
    two halves obtained by splitting some original segment at `pt`. -/
private lemma refineAllPtBounded_segment_form (n : ℕ) (G : EvenGraph) (pt : Vector2D) :
    ∀ s' ∈ (refineAllPtBounded n G pt).segments,
      ∃ s ∈ G.segments,
        s' = s ∨
        (s' = ⟨s.p1, pt⟩ ∧ pt ∈ s.toSet ∧ pt ≠ s.p1 ∧ pt ≠ s.p2) ∨
        (s' = ⟨pt, s.p2⟩ ∧ pt ∈ s.toSet ∧ pt ≠ s.p1 ∧ pt ≠ s.p2) := by
  induction n generalizing G with
  | zero =>
    intro s' hs'
    exact ⟨s', hs', Or.inl rfl⟩
  | succ n ih =>
    intro s' hs'
    simp only [refineAllPtBounded] at hs'
    split at hs'
    · -- find? returned none: result = G
      exact ⟨s', hs', Or.inl rfl⟩
    · rename_i seg h_find
      have h_seg_mem := List.mem_of_find?_eq_some h_find
      have h_pred := List.find?_some h_find
      have h_pt_in : pt ∈ seg.toSet := by
        simp only [Bool.and_eq_true, decide_eq_true_eq] at h_pred
        exact h_pred.1
      have h_pt_strict : ¬(pt = seg.p1 ∨ pt = seg.p2) := by
        have := h_pred
        simp only [Bool.and_eq_true, decide_eq_true_eq, Bool.not_eq_true',
                   decide_eq_false_iff_not] at this
        exact this.2
      push_neg at h_pt_strict
      obtain ⟨h_pt_ne_p1, h_pt_ne_p2⟩ := h_pt_strict
      -- Apply IH to G_1 = graphRefinement G seg pt
      obtain ⟨s_1, h_s_1_in, h_s_1_form⟩ :=
        ih (graphRefinement G seg pt h_seg_mem h_pt_in) s' hs'
      -- s_1 ∈ G_1.segments. Use replaceSegment structure to relate to G.
      have h_s_1_in_replace :
          s_1 ∈ replaceSegment G.segments seg ⟨seg.p1, pt⟩ ⟨pt, seg.p2⟩ := by
        unfold graphRefinement at h_s_1_in
        rw [dif_neg (not_or.mpr ⟨h_pt_ne_p1, h_pt_ne_p2⟩)] at h_s_1_in
        exact h_s_1_in
      rcases mem_replaceSegment G.segments seg ⟨seg.p1, pt⟩ ⟨pt, seg.p2⟩ s_1 h_s_1_in_replace
        with h_s_1_eq | h_s_1_eq | h_s_1_orig
      · -- s_1 = ⟨seg.p1, pt⟩
        refine ⟨seg, h_seg_mem, ?_⟩
        rcases h_s_1_form with h_eq |
            ⟨h_eq, h_pt_in_s_1, h_pt_ne_s_1_p1, h_pt_ne_s_1_p2⟩ |
            ⟨h_eq, h_pt_in_s_1, h_pt_ne_s_1_p1, h_pt_ne_s_1_p2⟩
        · -- s' = s_1 = ⟨seg.p1, pt⟩
          right; left
          refine ⟨h_eq.trans h_s_1_eq, h_pt_in, h_pt_ne_p1, h_pt_ne_p2⟩
        · -- s' = ⟨s_1.p1, pt⟩ with pt ≠ s_1.p2 = pt: contradiction
          exfalso
          apply h_pt_ne_s_1_p2
          rw [h_s_1_eq]
        · -- s' = ⟨pt, s_1.p2⟩ with pt ≠ s_1.p2 = pt: contradiction
          exfalso
          apply h_pt_ne_s_1_p2
          rw [h_s_1_eq]
      · -- s_1 = ⟨pt, seg.p2⟩
        refine ⟨seg, h_seg_mem, ?_⟩
        rcases h_s_1_form with h_eq |
            ⟨h_eq, h_pt_in_s_1, h_pt_ne_s_1_p1, h_pt_ne_s_1_p2⟩ |
            ⟨h_eq, h_pt_in_s_1, h_pt_ne_s_1_p1, h_pt_ne_s_1_p2⟩
        · -- s' = s_1 = ⟨pt, seg.p2⟩
          right; right
          refine ⟨h_eq.trans h_s_1_eq, h_pt_in, h_pt_ne_p1, h_pt_ne_p2⟩
        · -- s' = ⟨s_1.p1, pt⟩ with pt ≠ s_1.p1 = pt: contradiction
          exfalso
          apply h_pt_ne_s_1_p1
          rw [h_s_1_eq]
        · -- s' = ⟨pt, s_1.p2⟩ with pt ≠ s_1.p1 = pt: contradiction
          exfalso
          apply h_pt_ne_s_1_p1
          rw [h_s_1_eq]
      · -- s_1 ∈ G.segments unchanged
        refine ⟨s_1, h_s_1_orig, ?_⟩
        rcases h_s_1_form with h_eq |
            ⟨h_eq, h_pt_in_s_1, h_pt_ne_s_1_p1, h_pt_ne_s_1_p2⟩ |
            ⟨h_eq, h_pt_in_s_1, h_pt_ne_s_1_p1, h_pt_ne_s_1_p2⟩
        · exact Or.inl h_eq
        · exact Or.inr (Or.inl ⟨h_eq, h_pt_in_s_1, h_pt_ne_s_1_p1, h_pt_ne_s_1_p2⟩)
        · exact Or.inr (Or.inr ⟨h_eq, h_pt_in_s_1, h_pt_ne_s_1_p1, h_pt_ne_s_1_p2⟩)

/-- The "front-half" sub-segment is contained in the original segment. -/
private lemma subseg_p1_subset (s : LineSegment) (pt : Vector2D) (h_pt : pt ∈ s.toSet) :
    (LineSegment.mk s.p1 pt).toSet ⊆ s.toSet := by
  intro x hx
  have h_split := segment_split s.p1 s.p2 pt h_pt
  have hx_union : x ∈ (LineSegment.mk s.p1 pt).toSet ∪ (LineSegment.mk pt s.p2).toSet :=
    Set.mem_union_left _ hx
  rw [h_split] at hx_union
  exact hx_union

/-- The "back-half" sub-segment is contained in the original segment. -/
private lemma subseg_p2_subset (s : LineSegment) (pt : Vector2D) (h_pt : pt ∈ s.toSet) :
    (LineSegment.mk pt s.p2).toSet ⊆ s.toSet := by
  intro x hx
  have h_split := segment_split s.p1 s.p2 pt h_pt
  have hx_union : x ∈ (LineSegment.mk s.p1 pt).toSet ∪ (LineSegment.mk pt s.p2).toSet :=
    Set.mem_union_right _ hx
  rw [h_split] at hx_union
  exact hx_union

/-- Structural form of segments in `refineAllPt`. -/
private lemma refineAllPt_segment_form (G : EvenGraph) (pt : Vector2D) :
    ∀ s' ∈ (refineAllPt G pt).segments,
      ∃ s ∈ G.segments,
        s' = s ∨
        (s' = ⟨s.p1, pt⟩ ∧ pt ∈ s.toSet ∧ pt ≠ s.p1 ∧ pt ≠ s.p2) ∨
        (s' = ⟨pt, s.p2⟩ ∧ pt ∈ s.toSet ∧ pt ≠ s.p1 ∧ pt ≠ s.p2) :=
  refineAllPtBounded_segment_form _ G pt

private lemma refineAllPt_boundary_eq (G : EvenGraph) (pt : Vector2D) :
    (refineAllPt G pt).toBoundarySet = G.toBoundarySet :=
  refineAllPtBounded_boundary_eq _ G pt

private lemma refineAllPt_interior_eq (G : EvenGraph) (pt : Vector2D) :
    (refineAllPt G pt).interior = G.interior :=
  refineAllPtBounded_interior_eq _ G pt

/-- After `refineAllPt G pt`, pt is an endpoint of every segment containing it. -/
private lemma refineAllPt_pt_endpoint (G : EvenGraph) (pt : Vector2D) :
    ∀ s ∈ (refineAllPt G pt).segments, pt ∈ s.toSet → pt = s.p1 ∨ pt = s.p2 :=
  refineAllPtBounded_pt_endpoint _ G pt (le_refl _)

/-- `refineAllPt` preserves the endpoint property for a different point q. -/
private lemma refineAllPt_preserves_endpoint (G : EvenGraph) (pt q : Vector2D)
    (h_q_ep : ∀ s ∈ G.segments, q ∈ s.toSet → q = s.p1 ∨ q = s.p2) :
    ∀ s ∈ (refineAllPt G pt).segments, q ∈ s.toSet → q = s.p1 ∨ q = s.p2 :=
  refineAllPtBounded_preserves_endpoint _ G pt q h_q_ep

/-- Iteratively refine a graph at a list of points on its boundary. -/
def refineGraphWithPoints : (G : EvenGraph) →
    (pts : List Vector2D) →
    (h_all : ∀ pt ∈ pts, pt ∈ G.toBoundarySet) →
    EvenGraph
  | G, [], _ => G
  | G, pt :: rest, h_all =>
    let G' := refineAllPt G pt
    refineGraphWithPoints G' rest (by
      intro q hq
      rw [refineAllPt_boundary_eq]
      exact h_all q (List.mem_cons.mpr (.inr hq)))

private lemma refineGraphWithPoints_boundary_eq :
    ∀ (G : EvenGraph) (pts : List Vector2D)
      (h_all : ∀ pt ∈ pts, pt ∈ G.toBoundarySet),
    (refineGraphWithPoints G pts h_all).toBoundarySet = G.toBoundarySet
  | _, [], _ => rfl
  | G, pt :: rest, h_all => by
    simp only [refineGraphWithPoints]
    have h_bdy_step : (refineAllPt G pt).toBoundarySet = G.toBoundarySet :=
      refineAllPt_boundary_eq G pt
    have h_all' : ∀ q ∈ rest, q ∈ (refineAllPt G pt).toBoundarySet := by
      intro q hq; rw [h_bdy_step]; exact h_all q (List.mem_cons.mpr (.inr hq))
    have h_ih := refineGraphWithPoints_boundary_eq (refineAllPt G pt) rest h_all'
    rw [h_ih, h_bdy_step]

private lemma refineGraphWithPoints_interior_eq :
    ∀ (G : EvenGraph) (pts : List Vector2D)
      (h_all : ∀ pt ∈ pts, pt ∈ G.toBoundarySet),
    (refineGraphWithPoints G pts h_all).interior = G.interior
  | _, [], _ => rfl
  | G, pt :: rest, h_all => by
    simp only [refineGraphWithPoints]
    have h_int_step : (refineAllPt G pt).interior = G.interior :=
      refineAllPt_interior_eq G pt
    have h_bdy_step : (refineAllPt G pt).toBoundarySet = G.toBoundarySet :=
      refineAllPt_boundary_eq G pt
    have h_all' : ∀ q ∈ rest, q ∈ (refineAllPt G pt).toBoundarySet := by
      intro q hq; rw [h_bdy_step]; exact h_all q (List.mem_cons.mpr (.inr hq))
    have h_ih := refineGraphWithPoints_interior_eq (refineAllPt G pt) rest h_all'
    rw [h_ih, h_int_step]

/-- `refineGraphWithPoints` preserves the endpoint property for any fixed point `q`. -/
private lemma refineGraphWithPoints_preserves_endpoint :
    ∀ (G : EvenGraph) (pts : List Vector2D) (h_all : ∀ pt ∈ pts, pt ∈ G.toBoundarySet)
      (q : Vector2D),
    (∀ s ∈ G.segments, q ∈ s.toSet → q = s.p1 ∨ q = s.p2) →
    ∀ s ∈ (refineGraphWithPoints G pts h_all).segments, q ∈ s.toSet → q = s.p1 ∨ q = s.p2
  | _, [], _, _, h => h
  | G, pt :: rest, h_all, q, h => by
    simp only [refineGraphWithPoints]
    apply refineGraphWithPoints_preserves_endpoint
    exact refineAllPt_preserves_endpoint G pt q h

/-- Unfolding lemma: refining at `pt :: rest` is refining at `pt`, then at `rest`. -/
private theorem refineGraphWithPoints_cons (G : EvenGraph) (pt : Vector2D)
    (rest : List Vector2D) (h_all : ∀ q ∈ pt :: rest, q ∈ G.toBoundarySet) :
    refineGraphWithPoints G (pt :: rest) h_all =
    refineGraphWithPoints (refineAllPt G pt) rest (by
      intro q hq
      rw [refineAllPt_boundary_eq]
      exact h_all q (List.mem_cons.mpr (.inr hq))) := by
  rfl

/-- Refining at empty list is identity. -/
private theorem refineGraphWithPoints_nil (G : EvenGraph)
    (h_all : ∀ q ∈ ([] : List Vector2D), q ∈ G.toBoundarySet) :
    refineGraphWithPoints G [] h_all = G := rfl

private lemma refineGraphWithPoints_pts_endpoint :
    ∀ (G : EvenGraph) (pts : List Vector2D)
      (h_all : ∀ pt ∈ pts, pt ∈ G.toBoundarySet)
      (q : Vector2D) (_ : q ∈ pts)
      (seg : LineSegment) (_ : seg ∈ (refineGraphWithPoints G pts h_all).segments)
      (_ : q ∈ seg.toSet),
    q = seg.p1 ∨ q = seg.p2
  | _, [], _, _, hq, _, _, _ => nomatch hq
  | G, pt :: rest, h_all, q, hq, seg, hseg, hon => by
    simp only [refineGraphWithPoints] at hseg
    have h_bdy_step : (refineAllPt G pt).toBoundarySet = G.toBoundarySet :=
      refineAllPt_boundary_eq G pt
    have h_all' : ∀ q' ∈ rest, q' ∈ (refineAllPt G pt).toBoundarySet := by
      intro q' hq'; rw [h_bdy_step]; exact h_all q' (List.mem_cons.mpr (.inr hq'))
    simp only [List.mem_cons] at hq
    rcases hq with h_eq | hq_rest
    · -- h_eq : q = pt
      rw [h_eq]
      exact refineGraphWithPoints_preserves_endpoint
        (refineAllPt G pt) rest h_all' pt
        (refineAllPt_pt_endpoint G pt) seg hseg (h_eq ▸ hon)
    · -- q ∈ rest: use IH
      exact refineGraphWithPoints_pts_endpoint (refineAllPt G pt) rest h_all'
        q hq_rest seg hseg hon

/-! ### Iterative per-segment splitting characterization -/

/-- Iteratively split a single segment `seg` at the points in `pts` (in order):
    skip points not strictly interior; otherwise split into two halves and
    recurse independently on each half. Returns a list of sub-segments. -/
def iterativeSplit : LineSegment → List Vector2D → List LineSegment
  | seg, [] => [seg]
  | seg, pt :: rest =>
    if pt ∈ seg.toSet ∧ pt ≠ seg.p1 ∧ pt ≠ seg.p2 then
      iterativeSplit ⟨seg.p1, pt⟩ rest ++ iterativeSplit ⟨pt, seg.p2⟩ rest
    else
      iterativeSplit seg rest

/-- `iterativeSplit` is invariant under endpoint swap, modulo `toEndpointsMultiset`. -/
private lemma iterativeSplit_swap_perm (s : LineSegment) (pts : List Vector2D) :
    List.Perm
      ((iterativeSplit s pts).map LineSegment.toEndpointsMultiset)
      ((iterativeSplit ⟨s.p2, s.p1⟩ pts).map LineSegment.toEndpointsMultiset) := by
  induction pts generalizing s with
  | nil =>
    simp only [iterativeSplit, List.map_cons, List.map_nil]
    -- {s.p1, s.p2} = {s.p2, s.p1}
    have : LineSegment.toEndpointsMultiset s =
        LineSegment.toEndpointsMultiset (⟨s.p2, s.p1⟩ : LineSegment) := by
      simp only [LineSegment.toEndpointsMultiset]
      exact Multiset.cons_swap _ _ _
    rw [this]
  | cons pt rest ih =>
    simp only [iterativeSplit]
    -- The split predicate is the same for s and swap s, because
    -- (1) toSet is symmetric under endpoint swap,
    -- (2) p1 ↔ p2 in the predicate.
    have h_toSet_eq : (⟨s.p2, s.p1⟩ : LineSegment).toSet = s.toSet := by
      cases s with
      | mk a b => exact EvenGraphProofs.lineSegment_toSet_swap b a
    by_cases h : pt ∈ s.toSet ∧ pt ≠ s.p1 ∧ pt ≠ s.p2
    · -- predicate true on s; show it's also true on swap s
      have h' : pt ∈ (⟨s.p2, s.p1⟩ : LineSegment).toSet ∧
                  pt ≠ (⟨s.p2, s.p1⟩ : LineSegment).p1 ∧
                  pt ≠ (⟨s.p2, s.p1⟩ : LineSegment).p2 := by
        refine ⟨?_, ?_, ?_⟩
        · rw [h_toSet_eq]; exact h.1
        · exact h.2.2
        · exact h.2.1
      rw [if_pos h, if_pos h']
      -- LHS halves: ⟨s.p1, pt⟩ ++ ⟨pt, s.p2⟩
      -- RHS halves: ⟨s.p2, pt⟩ ++ ⟨pt, s.p1⟩
      -- Use ih to swap each half and reorder.
      have ih1 := ih (⟨s.p1, pt⟩ : LineSegment)
      have ih2 := ih (⟨pt, s.p2⟩ : LineSegment)
      simp only at ih1 ih2
      -- ih1 : iterativeSplit ⟨s.p1, pt⟩ rest ~ iterativeSplit ⟨pt, s.p1⟩ rest (under map toEM)
      -- ih2 : iterativeSplit ⟨pt, s.p2⟩ rest ~ iterativeSplit ⟨s.p2, pt⟩ rest (under map toEM)
      rw [List.map_append, List.map_append]
      -- Goal: (A ++ B) ~ (C ++ D) where A ~ D' and B ~ C' and we swap order
      -- A = (iterativeSplit ⟨s.p1,pt⟩ rest).map toEM
      -- B = (iterativeSplit ⟨pt,s.p2⟩ rest).map toEM
      -- C = (iterativeSplit ⟨s.p2,pt⟩ rest).map toEM
      -- D = (iterativeSplit ⟨pt,s.p1⟩ rest).map toEM
      -- ih1 : A ~ D, ih2 : B ~ C
      -- So A ++ B ~ D ++ C ~ C ++ D
      exact (ih1.append ih2).trans (List.perm_append_comm)
    · -- predicate false on s; show it's also false on swap s
      have h' : ¬ (pt ∈ (⟨s.p2, s.p1⟩ : LineSegment).toSet ∧
                  pt ≠ (⟨s.p2, s.p1⟩ : LineSegment).p1 ∧
                  pt ≠ (⟨s.p2, s.p1⟩ : LineSegment).p2) := by
        intro hh
        apply h
        refine ⟨?_, ?_, ?_⟩
        · rw [← h_toSet_eq]; exact hh.1
        · exact hh.2.2
        · exact hh.2.1
      rw [if_neg h, if_neg h']
      exact ih s

/-- `iterativeSplit` respects the toEndpointsMultiset on its input segment:
    if two segments have the same toEM, their iterative splits do too. -/
private lemma iterativeSplit_perm_of_toEM_eq (s s' : LineSegment) (pts : List Vector2D)
    (h : s.toEndpointsMultiset = s'.toEndpointsMultiset) :
    List.Perm
      ((iterativeSplit s pts).map LineSegment.toEndpointsMultiset)
      ((iterativeSplit s' pts).map LineSegment.toEndpointsMultiset) := by
  -- {s.p1, s.p2} = {s'.p1, s'.p2}, so either s = s' or s = swap s'.
  cases s with
  | mk a b =>
  cases s' with
  | mk c d =>
  simp only [LineSegment.toEndpointsMultiset] at h
  have ha_cases : a = c ∨ a = d := by
    have ha : a ∈ ({c, d} : Multiset Vector2D) := by
      rw [← h]; exact Multiset.mem_cons_self _ _
    rcases Multiset.mem_cons.mp ha with hc | hd
    · exact Or.inl hc
    · exact Or.inr (Multiset.mem_singleton.mp hd)
  rcases ha_cases with ha_eq | ha_eq
  · subst ha_eq
    -- Then b = d via a similar erase argument.
    have h_eq : ({b} : Multiset Vector2D) = {d} := by
      have step :
          Multiset.erase ({a, b} : Multiset Vector2D) a =
          Multiset.erase ({a, d} : Multiset Vector2D) a := by rw [h]
      have l1 : ({a, b} : Multiset Vector2D) = a ::ₘ ({b} : Multiset Vector2D) := rfl
      have l2 : ({a, d} : Multiset Vector2D) = a ::ₘ ({d} : Multiset Vector2D) := rfl
      rw [l1, l2, Multiset.erase_cons_head, Multiset.erase_cons_head] at step
      exact step
    have hbd : b = d := by
      have : b ∈ ({d} : Multiset Vector2D) := by
        rw [← h_eq]; exact Multiset.mem_singleton.mpr rfl
      exact Multiset.mem_singleton.mp this
    subst hbd
    exact List.Perm.refl _
  · subst ha_eq
    -- s = ⟨a, b⟩ with a = d. So s = ⟨d, b⟩, s' = ⟨c, d⟩.
    -- {d, b} = {c, d} = {d, c}, so b = c, i.e. s = ⟨d, b⟩, s' = ⟨b, d⟩, swap.
    have h_swap : ({c, a} : Multiset Vector2D) = ({a, c} : Multiset Vector2D) :=
      Multiset.cons_swap _ _ _
    rw [h_swap] at h
    have h_eq : ({b} : Multiset Vector2D) = {c} := by
      have step :
          Multiset.erase ({a, b} : Multiset Vector2D) a =
          Multiset.erase ({a, c} : Multiset Vector2D) a := by rw [h]
      have l1 : ({a, b} : Multiset Vector2D) = a ::ₘ ({b} : Multiset Vector2D) := rfl
      have l2 : ({a, c} : Multiset Vector2D) = a ::ₘ ({c} : Multiset Vector2D) := rfl
      rw [l1, l2, Multiset.erase_cons_head, Multiset.erase_cons_head] at step
      exact step
    have hbc : b = c := by
      have : b ∈ ({c} : Multiset Vector2D) := by
        rw [← h_eq]; exact Multiset.mem_singleton.mpr rfl
      exact Multiset.mem_singleton.mp this
    subst hbc
    -- Now s = ⟨a, b⟩, s' = ⟨b, a⟩.
    exact iterativeSplit_swap_perm ⟨a, b⟩ pts

/-- `iterativeSplit seg (l1 ++ l2)` decomposes as: first split `seg` at `l1`,
    then for each resulting sub-segment, split it at `l2`. -/
theorem iterativeSplit_append (seg : LineSegment) (l1 l2 : List Vector2D) :
    iterativeSplit seg (l1 ++ l2) =
    (iterativeSplit seg l1).flatMap (fun s => iterativeSplit s l2) := by
  induction l1 generalizing seg with
  | nil =>
    -- iterativeSplit seg ([] ++ l2) = iterativeSplit seg l2
    -- (iterativeSplit seg []).flatMap fn = [seg].flatMap fn = iterativeSplit seg l2
    simp only [List.nil_append, iterativeSplit, List.flatMap_cons,
      List.flatMap_nil, List.append_nil]
  | cons pt rest ih =>
    -- Case split on whether pt is strictly interior to seg.
    by_cases hpt : pt ∈ seg.toSet ∧ pt ≠ seg.p1 ∧ pt ≠ seg.p2
    · have hLHS : iterativeSplit seg ((pt :: rest) ++ l2) =
          iterativeSplit ⟨seg.p1, pt⟩ (rest ++ l2) ++
            iterativeSplit ⟨pt, seg.p2⟩ (rest ++ l2) := by
        show iterativeSplit seg (pt :: (rest ++ l2)) = _
        show (if _ then _ else _) = _
        rw [if_pos hpt]
      have hRHS_step : iterativeSplit seg (pt :: rest) =
          iterativeSplit ⟨seg.p1, pt⟩ rest ++ iterativeSplit ⟨pt, seg.p2⟩ rest := by
        show (if _ then _ else _) = _
        rw [if_pos hpt]
      rw [hLHS, hRHS_step]
      rw [ih ⟨seg.p1, pt⟩, ih ⟨pt, seg.p2⟩]
      rw [List.flatMap_append]
    · have hLHS : iterativeSplit seg ((pt :: rest) ++ l2) =
          iterativeSplit seg (rest ++ l2) := by
        show iterativeSplit seg (pt :: (rest ++ l2)) = _
        show (if _ then _ else _) = _
        rw [if_neg hpt]
      have hRHS_step : iterativeSplit seg (pt :: rest) = iterativeSplit seg rest := by
        show (if _ then _ else _) = _
        rw [if_neg hpt]
      rw [hLHS, hRHS_step]
      exact ih seg

/-- Transfer a `toEM`-perm through `flatMap iterativeSplit · pts`. -/
private lemma flatMap_iterativeSplit_perm_of_perm_toEM
    (pts : List Vector2D) :
    ∀ (L1 L2 : List LineSegment),
      List.Perm (L1.map LineSegment.toEndpointsMultiset)
                (L2.map LineSegment.toEndpointsMultiset) →
      List.Perm
        ((L1.flatMap (fun s => iterativeSplit s pts)).map LineSegment.toEndpointsMultiset)
        ((L2.flatMap (fun s => iterativeSplit s pts)).map LineSegment.toEndpointsMultiset) := by
  intro L1
  induction L1 with
  | nil =>
    intro L2 h_perm
    -- L1 = []: L2.map toEM is also []
    simp only [List.map_nil] at h_perm
    have hL2 : L2.map LineSegment.toEndpointsMultiset = [] :=
      (List.Perm.nil_eq h_perm).symm
    have hL2' : L2 = [] := by
      cases L2 with
      | nil => rfl
      | cons _ _ => exact absurd hL2 (by simp)
    subst hL2'
    exact List.Perm.refl _
  | cons s L1' ih =>
    intro L2 h_perm
    -- s.toEM ∈ L2.map toEM
    simp only [List.map_cons] at h_perm
    have hmem : s.toEndpointsMultiset ∈ L2.map LineSegment.toEndpointsMultiset := by
      have := h_perm.mem_iff (a := s.toEndpointsMultiset)
      exact this.mp (List.mem_cons_self _ _)
    obtain ⟨s', hs'_mem, hs'_eq⟩ := List.mem_map.mp hmem
    -- Split L2 around s'.
    obtain ⟨L2a, L2b, hL2_eq⟩ := List.append_of_mem hs'_mem
    subst hL2_eq
    -- flatMap on (L2a ++ s' :: L2b) = L2a.flatMap _ ++ iterativeSplit s' pts ++ L2b.flatMap _
    -- We will show: (s :: L1').flatMap fn ~ (L2a ++ s' :: L2b).flatMap fn (under toEM map).
    -- LHS map: iterativeSplit s pts ++ L1'.flatMap fn, mapped to toEM
    --       ~ iterativeSplit s' pts ++ L1'.flatMap fn  (using iterativeSplit_perm_of_toEM_eq)
    -- We then perm-rotate to put iterativeSplit s' pts in the middle.
    -- For the IH on L1', we need:
    --   L1'.map toEM ~ (L2a ++ L2b).map toEM
    have h_perm' : List.Perm (L1'.map LineSegment.toEndpointsMultiset)
        ((L2a ++ L2b).map LineSegment.toEndpointsMultiset) := by
      -- From: s.toEM :: L1'.map toEM ~ (L2a ++ s' :: L2b).map toEM
      -- And s.toEM = s'.toEM
      have h_full : List.Perm
          (s.toEndpointsMultiset :: L1'.map LineSegment.toEndpointsMultiset)
          ((L2a ++ s' :: L2b).map LineSegment.toEndpointsMultiset) := h_perm
      rw [List.map_append, List.map_cons, ← hs'_eq] at h_full
      -- h_full : s'.toEM :: L1'.map toEM ~ L2a.map toEM ++ (s'.toEM :: L2b.map toEM)
      -- middle perm to: s'.toEM :: (L2a ++ L2b).map toEM
      have h_middle : List.Perm
          (L2a.map LineSegment.toEndpointsMultiset ++
            (s'.toEndpointsMultiset :: L2b.map LineSegment.toEndpointsMultiset))
          (s'.toEndpointsMultiset ::
            (L2a.map LineSegment.toEndpointsMultiset ++
              L2b.map LineSegment.toEndpointsMultiset)) := by
        exact List.perm_middle
      have h_combined := h_full.trans h_middle
      -- s'.toEM :: L1'.map toEM ~ s'.toEM :: ((L2a ++ L2b).map toEM)
      have := List.Perm.cons_inv h_combined
      rw [List.map_append]
      exact this
    have h_ih := ih (L2a ++ L2b) h_perm'
    -- (L1'.flatMap fn).map toEM ~ ((L2a ++ L2b).flatMap fn).map toEM
    -- Now combine.
    -- LHS = (s :: L1').flatMap fn = iterativeSplit s pts ++ L1'.flatMap fn
    -- RHS = (L2a ++ s' :: L2b).flatMap fn = L2a.flatMap fn ++ iterativeSplit s' pts ++ L2b.flatMap fn
    -- Goal: LHS.map toEM ~ RHS.map toEM
    show List.Perm
      (((s :: L1').flatMap (fun s => iterativeSplit s pts)).map LineSegment.toEndpointsMultiset)
      (((L2a ++ s' :: L2b).flatMap (fun s => iterativeSplit s pts)).map LineSegment.toEndpointsMultiset)
    simp only [List.flatMap_cons, List.flatMap_append]
    rw [List.map_append, List.map_append, List.map_append]
    -- Goal: (iterativeSplit s pts).map toEM ++ (L1'.flatMap fn).map toEM ~
    --       (L2a.flatMap fn).map toEM ++ (iterativeSplit s' pts).map toEM ++ (L2b.flatMap fn).map toEM
    -- Step 1: replace iterativeSplit s by iterativeSplit s' (using toEM equality).
    have h_swap_split : List.Perm
        ((iterativeSplit s pts).map LineSegment.toEndpointsMultiset)
        ((iterativeSplit s' pts).map LineSegment.toEndpointsMultiset) :=
      iterativeSplit_perm_of_toEM_eq s s' pts hs'_eq.symm
    -- Step 2: from h_ih, decompose (L2a ++ L2b).flatMap.
    have h_ih' : List.Perm
        ((L1'.flatMap (fun s => iterativeSplit s pts)).map LineSegment.toEndpointsMultiset)
        (((L2a.flatMap (fun s => iterativeSplit s pts)) ++
          (L2b.flatMap (fun s => iterativeSplit s pts))).map LineSegment.toEndpointsMultiset) := by
      have := h_ih
      simp only [List.flatMap_append] at this
      exact this
    rw [List.map_append] at h_ih'
    -- LHS_after_step1 = (iterativeSplit s' pts).map toEM ++ (L1'.flatMap fn).map toEM
    -- After step 2: (iterativeSplit s' pts).map toEM ++ (L2a.flatMap).map toEM ++ (L2b.flatMap).map toEM
    -- RHS = (L2a.flatMap).map toEM ++ (iterativeSplit s' pts).map toEM ++ (L2b.flatMap).map toEM
    -- These differ only by reordering of the first two blocks; use perm_middle.
    -- Compose: h_swap_split.append h_ih' : LHS ~ (iterSplit s' ).map ++ (L2a ++ L2b).flatMap.map
    -- Then perm-shift.
    refine (h_swap_split.append h_ih').trans ?_
    -- Now need: (iter s').map ++ ((L2a.flatMap).map ++ (L2b.flatMap).map) ~
    --          ((L2a.flatMap).map ++ (iter s').map) ++ (L2b.flatMap).map
    -- This is just rearranging by associativity and perm_middle.
    -- Goal: iter s'.map ++ (L2a.flatMap.map ++ L2b.flatMap.map) ~
    --       L2a.flatMap.map ++ (iter s'.map ++ L2b.flatMap.map)
    rw [← List.append_assoc, ← List.append_assoc]
    -- Goal: (iter s'.map ++ L2a.flatMap.map) ++ L2b.flatMap.map ~
    --       (L2a.flatMap.map ++ iter s'.map) ++ L2b.flatMap.map
    exact (List.perm_append_comm).append_right _

/-- The segments of `refineGraphWithPoints G pts h_all`, viewed as a multiset of
    unordered endpoint pairs, equal `G.segments.flatMap (fun s => iterativeSplit s pts)`
    mapped to endpoint multisets. -/
theorem refineGraphWithPoints_segments_perm
    (G : EvenGraph) (pts : List Vector2D) (h_all : ∀ pt ∈ pts, pt ∈ G.toBoundarySet) :
    List.Perm
      ((refineGraphWithPoints G pts h_all).segments.map LineSegment.toEndpointsMultiset)
      ((G.segments.flatMap (fun s => iterativeSplit s pts)).map
        LineSegment.toEndpointsMultiset) := by
  induction pts generalizing G with
  | nil =>
    rw [refineGraphWithPoints_nil]
    -- iterativeSplit s [] = [s]
    have h_eq : G.segments.flatMap (fun s => iterativeSplit s ([] : List Vector2D)) =
        G.segments := by
      have : (fun s : LineSegment => iterativeSplit s ([] : List Vector2D)) =
          (fun s => [s]) := by
        funext s; rfl
      rw [this]
      induction G.segments with
      | nil => rfl
      | cons a t ih => simp only [List.flatMap_cons, List.singleton_append, List.cons.injEq, true_and]; exact ih
    rw [h_eq]
  | cons pt rest ih =>
    have h_all' : ∀ q ∈ rest, q ∈ (refineAllPt G pt).toBoundarySet := by
      intro q hq
      rw [refineAllPt_boundary_eq]
      exact h_all q (List.mem_cons.mpr (.inr hq))
    rw [refineGraphWithPoints_cons]
    have h_ih := ih (refineAllPt G pt) h_all'
    -- h_ih : (refineGraphWithPoints (refineAllPt G pt) rest h_all').segments.map toEM ~
    --        ((refineAllPt G pt).segments.flatMap (fun s => iterativeSplit s rest)).map toEM
    refine h_ih.trans ?_
    -- Now: ((refineAllPt G pt).segments.flatMap (· iterativeSplit · rest)).map toEM
    --     ~ (G.segments.flatMap (· iterativeSplit · (pt :: rest))).map toEM
    -- Strategy: use refineAllPt_segments_perm to get a toEM-perm between
    --   (refineAllPt G pt).segments and G.segments.flatMap (single-step split).
    -- Then transfer through flatMap iterativeSplit · rest using
    -- flatMap_iterativeSplit_perm_of_perm_toEM. Then unfold:
    --   single-step-split's flatMap of iterativeSplit rest = iterativeSplit (pt :: rest).
    have h_single :=
      refineAllPt_segments_perm G pt
    -- h_single : (refineAllPt G pt).segments.map toEM ~
    --            G.segments.flatMap (fun s => if ... then [⟨s.p1,pt⟩.toEM, ⟨pt,s.p2⟩.toEM] else [s.toEM])
    -- We now want to convert that flatMap to a flatMap into LineSegment, then map toEM.
    -- Define the "single-step segment list": for each s, list of LineSegments.
    let singleStep : LineSegment → List LineSegment := fun s =>
      if pt ∈ s.toSet ∧ pt ≠ s.p1 ∧ pt ≠ s.p2 then
        [⟨s.p1, pt⟩, ⟨pt, s.p2⟩]
      else
        [s]
    -- (G.segments.flatMap singleStep).map toEM = the RHS of h_single
    have h_singleStep_map :
        (G.segments.flatMap singleStep).map LineSegment.toEndpointsMultiset =
        G.segments.flatMap (fun s =>
          if (pt ∈ s.toSet ∧ pt ≠ s.p1 ∧ pt ≠ s.p2) then
            [(⟨s.p1, pt⟩ : LineSegment).toEndpointsMultiset,
             (⟨pt, s.p2⟩ : LineSegment).toEndpointsMultiset]
          else
            [s.toEndpointsMultiset]) := by
      rw [List.map_flatMap]
      congr 1
      funext s
      by_cases h : pt ∈ s.toSet ∧ pt ≠ s.p1 ∧ pt ≠ s.p2
      · simp only [singleStep, if_pos h, List.map_cons, List.map_nil]
      · simp only [singleStep, if_neg h, List.map_cons, List.map_nil]
    -- Hence: (refineAllPt G pt).segments.map toEM ~ (G.segments.flatMap singleStep).map toEM
    have h_single' : List.Perm
        ((refineAllPt G pt).segments.map LineSegment.toEndpointsMultiset)
        ((G.segments.flatMap singleStep).map LineSegment.toEndpointsMultiset) := by
      rw [h_singleStep_map]
      exact h_single
    -- Apply flatMap_iterativeSplit_perm_of_perm_toEM to lift this perm.
    have h_lift := flatMap_iterativeSplit_perm_of_perm_toEM rest _ _ h_single'
    refine h_lift.trans ?_
    -- Goal: ((G.segments.flatMap singleStep).flatMap (· iterativeSplit · rest)).map toEM
    --     ~ (G.segments.flatMap (· iterativeSplit · (pt :: rest))).map toEM
    -- LHS: G.segments.flatMap (fun s => (singleStep s).flatMap (· iterativeSplit · rest))
    -- For each s:
    --   if predicate true: singleStep s = [⟨s.p1,pt⟩, ⟨pt, s.p2⟩]
    --     (singleStep s).flatMap (· iterativeSplit · rest)
    --     = iterativeSplit ⟨s.p1, pt⟩ rest ++ iterativeSplit ⟨pt, s.p2⟩ rest
    --     = iterativeSplit s (pt :: rest)
    --   if predicate false: singleStep s = [s]
    --     (singleStep s).flatMap (· iterativeSplit · rest)
    --     = iterativeSplit s rest
    --     = iterativeSplit s (pt :: rest)  (since predicate false in def)
    have h_eq_lists :
        G.segments.flatMap (fun s => (singleStep s).flatMap (fun s' => iterativeSplit s' rest)) =
        G.segments.flatMap (fun s => iterativeSplit s (pt :: rest)) := by
      congr 1
      funext s
      by_cases h : pt ∈ s.toSet ∧ pt ≠ s.p1 ∧ pt ≠ s.p2
      · simp only [singleStep, if_pos h, List.flatMap_cons, List.flatMap_nil, List.append_nil,
          iterativeSplit]
      · simp only [singleStep, if_neg h, List.flatMap_cons, List.flatMap_nil, List.append_nil,
          iterativeSplit]
    rw [List.flatMap_assoc]
    rw [h_eq_lists]

/-! ### Self-refinement (eliminating vertices in segment interiors) -/

/-- Vertex set bound for `refineAllPtBounded`: every vertex of the result is
    either `pt` or a vertex of `G`. -/
private lemma refineAllPtBounded_toVertexSet_subset (n : ℕ) (G : EvenGraph) (pt : Vector2D) :
    (refineAllPtBounded n G pt).toVertexSet ⊆ insert pt G.toVertexSet := by
  induction n generalizing G with
  | zero =>
    simp only [refineAllPtBounded]
    exact Set.subset_insert _ _
  | succ n ih =>
    simp only [refineAllPtBounded]
    split
    · exact Set.subset_insert _ _
    · rename_i seg h_find
      have h_seg := List.mem_of_find?_eq_some h_find
      have h_pred := List.find?_some h_find
      have h_pt : pt ∈ seg.toSet := by
        simp only [Bool.and_eq_true, decide_eq_true_eq] at h_pred; exact h_pred.1
      have h_step :=
        graphRefinement_toVertexSet_eq G seg pt h_seg h_pt
      have h_ih := ih (graphRefinement G seg pt h_seg h_pt)
      intro v hv
      have h_mem : v ∈ insert pt (graphRefinement G seg pt h_seg h_pt).toVertexSet :=
        h_ih hv
      rw [Set.mem_insert_iff] at h_mem
      rcases h_mem with h_eq | h_in
      · exact h_eq ▸ Set.mem_insert _ _
      · rw [h_step] at h_in
        rcases h_in with h_eq2 | h_orig
        · exact h_eq2 ▸ Set.mem_insert _ _
        · exact Set.mem_insert_of_mem _ h_orig

/-- Vertex set bound for `refineAllPt`: every vertex of the result is either
    `pt` or a vertex of `G`. -/
private lemma refineAllPt_toVertexSet_subset (G : EvenGraph) (pt : Vector2D) :
    (refineAllPt G pt).toVertexSet ⊆ insert pt G.toVertexSet :=
  refineAllPtBounded_toVertexSet_subset _ G pt

/-- Vertex set bound for `refineGraphWithPoints`: every vertex of the result is
    either in `pts` or a vertex of `G`. -/
private lemma refineGraphWithPoints_toVertexSet_subset :
    ∀ (G : EvenGraph) (pts : List Vector2D)
      (h_all : ∀ pt ∈ pts, pt ∈ G.toBoundarySet),
    (refineGraphWithPoints G pts h_all).toVertexSet ⊆ G.toVertexSet ∪ { p | p ∈ pts }
  | _, [], _ => by
    simp only [refineGraphWithPoints]
    intro v hv
    exact Or.inl hv
  | G, pt :: rest, h_all => by
    simp only [refineGraphWithPoints]
    have h_bdy_step : (refineAllPt G pt).toBoundarySet = G.toBoundarySet :=
      refineAllPt_boundary_eq G pt
    have h_all' : ∀ q ∈ rest, q ∈ (refineAllPt G pt).toBoundarySet := by
      intro q hq; rw [h_bdy_step]; exact h_all q (List.mem_cons.mpr (.inr hq))
    have h_ih := refineGraphWithPoints_toVertexSet_subset (refineAllPt G pt) rest h_all'
    intro v hv
    rcases h_ih hv with h_step | h_rest
    · -- v ∈ (refineAllPt G pt).toVertexSet
      rcases refineAllPt_toVertexSet_subset G pt h_step with h_eq | h_orig
      · exact Or.inr (List.mem_cons.mpr (.inl h_eq))
      · exact Or.inl h_orig
    · -- v ∈ rest
      exact Or.inr (List.mem_cons.mpr (.inr h_rest))

/-- `refineAllPt` preserves the h_no_segment_interior_vertices property: if no vertex of `G` lies
    strictly interior to a segment of `G`, the same holds in `refineAllPt G pt`. -/
private lemma refineAllPt_preserves_no_segment_interior_vertices (G : EvenGraph) (pt : Vector2D)
    (h_G : ∀ v ∈ G.toVertices, ∀ seg ∈ G.segments,
      seg.p1 ≠ v → seg.p2 ≠ v → v ∉ seg.toSet) :
    ∀ v ∈ (refineAllPt G pt).toVertices, ∀ seg ∈ (refineAllPt G pt).segments,
      seg.p1 ≠ v → seg.p2 ≠ v → v ∉ seg.toSet := by
  intro v hv_vert seg h_seg h_p1_ne h_p2_ne h_v_in
  -- Use vertex set bound to split on v = pt or v ∈ G.
  have h_v_set : v ∈ (refineAllPt G pt).toVertexSet := hv_vert
  have h_v_insert : v ∈ insert pt G.toVertexSet :=
    refineAllPt_toVertexSet_subset G pt h_v_set
  -- Use segment form to split on the form of seg.
  obtain ⟨s, hs, h_form⟩ := refineAllPt_segment_form G pt seg h_seg
  have h_s_nondeg : s.p1 ≠ s.p2 := G.segments_nondegenerate s hs
  rcases Set.mem_insert_iff.mp h_v_insert with h_v_pt | h_v_G
  · -- Case v = pt: pt cannot lie in seg.toSet (other than as endpoint).
    have h_pt_in : pt ∈ seg.toSet := h_v_pt ▸ h_v_in
    have h_pt_ep : pt = seg.p1 ∨ pt = seg.p2 :=
      refineAllPt_pt_endpoint G pt seg h_seg h_pt_in
    rcases h_pt_ep with h | h
    · exact h_p1_ne (h.symm.trans h_v_pt.symm)
    · exact h_p2_ne (h.symm.trans h_v_pt.symm)
  · -- Case v ∈ G.toVertexSet, i.e. v ∈ G.toVertices.
    have h_v_in_G : v ∈ G.toVertices := h_v_G
    rcases h_form with h_eq | ⟨h_eq, h_pt_in_s, h_pt_ne_p1, h_pt_ne_p2⟩ |
        ⟨h_eq, h_pt_in_s, h_pt_ne_p1, h_pt_ne_p2⟩
    · -- Form A: seg = s ∈ G.segments. Apply h_G directly.
      have h_p1_ne' : s.p1 ≠ v := by rw [← h_eq]; exact h_p1_ne
      have h_p2_ne' : s.p2 ≠ v := by rw [← h_eq]; exact h_p2_ne
      have h_v_in_s : v ∈ s.toSet := by rw [← h_eq]; exact h_v_in
      exact h_G v h_v_in_G s hs h_p1_ne' h_p2_ne' h_v_in_s
    · -- Form B: seg = ⟨s.p1, pt⟩.  v ∈ ⟨s.p1, pt⟩.toSet ⊆ s.toSet.
      have h_v_in_seg : v ∈ (LineSegment.mk s.p1 pt).toSet := by rw [← h_eq]; exact h_v_in
      have h_v_in_s : v ∈ s.toSet := subseg_p1_subset s pt h_pt_in_s h_v_in_seg
      -- seg.p1 = s.p1, seg.p2 = pt; so seg.p1 ≠ v ↔ s.p1 ≠ v.
      have h_s_p1_ne : s.p1 ≠ v := by
        intro h; apply h_p1_ne; rw [h_eq]; exact h
      -- Case-split on whether v = s.p2.
      by_cases h_v_eq_p2 : v = s.p2
      · -- v = s.p2: v ∈ ⟨s.p1, pt⟩.toSet, but s.p2 ∉ ⟨s.p1, pt⟩.toSet.
        have h_p2_in_seg : s.p2 ∈ (LineSegment.mk s.p1 pt).toSet := h_v_eq_p2 ▸ h_v_in_seg
        exact sub_segment_far_endpoint_not_mem s.p1 s.p2 pt h_pt_in_s
          h_pt_ne_p1 h_pt_ne_p2 h_s_nondeg h_p2_in_seg
      · -- v ≠ s.p2 and v ≠ s.p1; apply h_G to v, s.
        have h_s_p2_ne : s.p2 ≠ v := fun h => h_v_eq_p2 h.symm
        exact h_G v h_v_in_G s hs h_s_p1_ne h_s_p2_ne h_v_in_s
    · -- Form C: seg = ⟨pt, s.p2⟩.  Symmetric to form B.
      have h_v_in_seg : v ∈ (LineSegment.mk pt s.p2).toSet := by rw [← h_eq]; exact h_v_in
      have h_v_in_s : v ∈ s.toSet := subseg_p2_subset s pt h_pt_in_s h_v_in_seg
      have h_s_p2_ne : s.p2 ≠ v := by
        intro h; apply h_p2_ne; rw [h_eq]; exact h
      by_cases h_v_eq_p1 : v = s.p1
      · -- v = s.p1: v ∈ ⟨pt, s.p2⟩.toSet, but s.p1 ∉ ⟨pt, s.p2⟩.toSet.
        have h_p1_in_seg : s.p1 ∈ (LineSegment.mk pt s.p2).toSet := h_v_eq_p1 ▸ h_v_in_seg
        exact sub_segment_near_endpoint_not_mem s.p1 s.p2 pt h_pt_in_s
          h_pt_ne_p1 h_pt_ne_p2 h_s_nondeg h_p1_in_seg
      · have h_s_p1_ne : s.p1 ≠ v := fun h => h_v_eq_p1 h.symm
        exact h_G v h_v_in_G s hs h_s_p1_ne h_s_p2_ne h_v_in_s

/-- `refineGraphWithPoints` preserves the h_no_segment_interior_vertices property: iterate
    `refineAllPt_preserves_no_segment_interior_vertices` over the list of points. -/
private lemma refineGraphWithPoints_preserves_no_segment_interior_vertices :
    ∀ (G : EvenGraph) (pts : List Vector2D)
      (h_all : ∀ pt ∈ pts, pt ∈ G.toBoundarySet),
    (∀ v ∈ G.toVertices, ∀ seg ∈ G.segments,
      seg.p1 ≠ v → seg.p2 ≠ v → v ∉ seg.toSet) →
    ∀ v ∈ (refineGraphWithPoints G pts h_all).toVertices,
      ∀ seg ∈ (refineGraphWithPoints G pts h_all).segments,
        seg.p1 ≠ v → seg.p2 ≠ v → v ∉ seg.toSet
  | _, [], _, h => h
  | G, pt :: rest, h_all, h => by
    simp only [refineGraphWithPoints]
    apply refineGraphWithPoints_preserves_no_segment_interior_vertices
    exact refineAllPt_preserves_no_segment_interior_vertices G pt h

/-- The set of vertices of `G` that lie strictly in the interior of
    some segment of `G`. -/
def selfSegmentInteriorVertices (G : EvenGraph) : Set Vector2D :=
  { v : Vector2D | v ∈ G.toVertexSet ∧
    ∃ s ∈ G.segments, v ∈ s.toSet ∧ v ≠ s.p1 ∧ v ≠ s.p2 }

theorem selfSegmentInteriorVertices_finite (G : EvenGraph) :
    Set.Finite (selfSegmentInteriorVertices G) := by
  apply Set.Finite.subset (s := G.toVertexSet) ?_ ?_
  · -- G.toVertexSet is finite
    apply Set.Finite.ofFinset G.toVertices.toFinset
    intro x
    simp only [List.mem_toFinset, Graph.toVertexSet, Set.mem_setOf_eq]
  · intro v hv
    exact hv.1

theorem selfSegmentInteriorVertices_subset_boundary (G : EvenGraph) :
    selfSegmentInteriorVertices G ⊆ G.toBoundarySet := by
  intro v hv
  obtain ⟨_, s, hs, h_on, _, _⟩ := hv
  exact ⟨s, hs, h_on⟩

/-- Refine `G` at all vertices lying in segment interiors, making them
    endpoints of every segment that contained them in its interior. -/
def graphRefinementSelf (G : EvenGraph) : EvenGraph :=
  let h_fin := selfSegmentInteriorVertices_finite G
  refineGraphWithPoints G h_fin.toFinset.toList (fun pt h_mem => by
    have h1 : pt ∈ h_fin.toFinset := Finset.mem_toList.mp h_mem
    exact selfSegmentInteriorVertices_subset_boundary G (h_fin.mem_toFinset.mp h1))

theorem refinementSelf_boundary_eq (G : EvenGraph) :
    (graphRefinementSelf G).toBoundarySet = G.toBoundarySet :=
  refineGraphWithPoints_boundary_eq G _ _

theorem refinementSelf_interior_eq (G : EvenGraph) :
    (graphRefinementSelf G).interior = G.interior :=
  refineGraphWithPoints_interior_eq G _ _

/-- After self-refinement, the h_no_segment_interior_vertices condition holds. -/
theorem refinementSelf_no_segment_interior_vertices (G : EvenGraph) :
    ∀ v ∈ (graphRefinementSelf G).toVertices,
      ∀ seg ∈ (graphRefinementSelf G).segments,
        seg.p1 ≠ v → seg.p2 ≠ v → v ∉ seg.toSet := by
  intro v hv_vert seg h_seg h_p1_ne h_p2_ne h_v_in
  set h_fin := selfSegmentInteriorVertices_finite G with h_fin_def
  set pts := h_fin.toFinset.toList with h_pts_def
  set G' := graphRefinementSelf G with hG'_def
  have h_all : ∀ pt ∈ pts, pt ∈ G.toBoundarySet := fun pt h_mem => by
    have h1 : pt ∈ h_fin.toFinset := Finset.mem_toList.mp h_mem
    exact selfSegmentInteriorVertices_subset_boundary G (h_fin.mem_toFinset.mp h1)
  have h_pts_eq : pts = h_fin.toFinset.toList := rfl
  -- Two cases: either v ∈ pts or v ∉ pts.
  by_cases h_v_pts : v ∈ pts
  · -- v lies in a segment interior: refineGraphWithPoints_pts_endpoint applies.
    have h_ep : v = seg.p1 ∨ v = seg.p2 :=
      refineGraphWithPoints_pts_endpoint G pts h_all v h_v_pts seg h_seg h_v_in
    rcases h_ep with h | h
    · exact h_p1_ne h.symm
    · exact h_p2_ne h.symm
  · -- v ∉ pts. Show v ∈ G.toVertexSet (since v ∈ G'.toVertices and pts ⊆ G.toVertexSet).
    have h_v_vset : v ∈ G.toVertexSet := by
      have h_v_in_G' : v ∈ G'.toVertexSet := hv_vert
      have h_subset := refineGraphWithPoints_toVertexSet_subset G pts h_all
      rcases h_subset h_v_in_G' with h | h_in_pts
      · exact h
      · -- v ∈ pts, contradicts h_v_pts
        exact absurd h_in_pts h_v_pts
    -- v ∉ selfSegmentInteriorVertices G (since pts is exactly that finite set).
    have h_v_not_tj : v ∉ selfSegmentInteriorVertices G := by
      intro h_tj
      apply h_v_pts
      rw [h_pts_def]
      exact Finset.mem_toList.mpr (h_fin.mem_toFinset.mpr h_tj)
    -- Hence v is endpoint of every G segment containing v.
    have h_v_ep_G : ∀ s ∈ G.segments, v ∈ s.toSet → v = s.p1 ∨ v = s.p2 := by
      intro s hs h_v_s
      by_contra h_not_ep
      push_neg at h_not_ep
      apply h_v_not_tj
      exact ⟨h_v_vset, s, hs, h_v_s, h_not_ep.1, h_not_ep.2⟩
    -- Preserved through refinement.
    have h_v_ep_G' :=
      refineGraphWithPoints_preserves_endpoint G pts h_all v h_v_ep_G seg h_seg h_v_in
    rcases h_v_ep_G' with h | h
    · exact h_p1_ne h.symm
    · exact h_p2_ne h.symm

/-! ### Refinement wrt another graph -/

/-- Refine an even graph by inserting all boundary intersection points
    with another graph as new vertices. -/
def graphRefinementWrt
    (G1 G2 : EvenGraph)
    (h_fin : Set.Finite (G1.toBoundarySet ∩ G2.toBoundarySet)) : EvenGraph :=
  refineGraphWithPoints G1 h_fin.toFinset.toList (fun pt h_mem => by
    have h1 : pt ∈ h_fin.toFinset := Finset.mem_toList.mp h_mem
    exact (h_fin.mem_toFinset.mp h1).1)

theorem refinementWrt_boundary_eq
    (G1 G2 : EvenGraph)
    (h_fin : Set.Finite (G1.toBoundarySet ∩ G2.toBoundarySet)) :
    (graphRefinementWrt G1 G2 h_fin).toBoundarySet =
    G1.toBoundarySet :=
  refineGraphWithPoints_boundary_eq G1 h_fin.toFinset.toList _

theorem refinementWrt_interior_eq
    (G1 G2 : EvenGraph)
    (h_fin : Set.Finite (G1.toBoundarySet ∩ G2.toBoundarySet)) :
    (graphRefinementWrt G1 G2 h_fin).interior =
    G1.interior :=
  refineGraphWithPoints_interior_eq G1 h_fin.toFinset.toList _

theorem refinementWrt_seg_inter_boundary_subset
    (G1 G2 : EvenGraph)
    (h_fin : Set.Finite (G1.toBoundarySet ∩ G2.toBoundarySet))
    (seg : LineSegment)
    (h_seg : seg ∈ (graphRefinementWrt G1 G2 h_fin).segments) :
    seg.toSet ∩ G2.toBoundarySet ⊆ ({seg.p1, seg.p2} : Set Vector2D) := by
  intro q ⟨hq_seg, hq_bdy⟩
  have h_bdy_eq := refinementWrt_boundary_eq G1 G2 h_fin
  have hq_G1 : q ∈ G1.toBoundarySet := h_bdy_eq ▸ ⟨seg, h_seg, hq_seg⟩
  have hq_list : q ∈ h_fin.toFinset.toList :=
    Finset.mem_toList.mpr (h_fin.mem_toFinset.mpr ⟨hq_G1, hq_bdy⟩)
  have h_all : ∀ pt ∈ h_fin.toFinset.toList, pt ∈ G1.toBoundarySet :=
    fun pt h_mem => (h_fin.mem_toFinset.mp (Finset.mem_toList.mp h_mem)).1
  exact refineGraphWithPoints_pts_endpoint G1 h_fin.toFinset.toList h_all q hq_list seg h_seg hq_seg

/-- `graphRefinementWrt` preserves the h_no_segment_interior_vertices property. -/
theorem graphRefinementWrt_preserves_no_segment_interior_vertices
    (G1 G2 : EvenGraph)
    (h_fin : Set.Finite (G1.toBoundarySet ∩ G2.toBoundarySet))
    (h_G1 : ∀ v ∈ G1.toVertices, ∀ seg ∈ G1.segments,
      seg.p1 ≠ v → seg.p2 ≠ v → v ∉ seg.toSet) :
    ∀ v ∈ (graphRefinementWrt G1 G2 h_fin).toVertices,
      ∀ seg ∈ (graphRefinementWrt G1 G2 h_fin).segments,
        seg.p1 ≠ v → seg.p2 ≠ v → v ∉ seg.toSet :=
  refineGraphWithPoints_preserves_no_segment_interior_vertices G1 _ _ h_G1

/-! ### Combined self-and-wrt refinement -/

/-- First apply self-refinement to `G1` (eliminating vertices lying in
    segment interiors), then refine
    with respect to the boundary intersections with `G2`. -/
def graphRefinementSelfAndWrt
    (G1 G2 : EvenGraph)
    (h_fin12 : Set.Finite (G1.toBoundarySet ∩ G2.toBoundarySet)) : EvenGraph :=
  let G1' := graphRefinementSelf G1
  have h_fin12' : Set.Finite (G1'.toBoundarySet ∩ G2.toBoundarySet) := by
    rw [refinementSelf_boundary_eq G1]
    exact h_fin12
  graphRefinementWrt G1' G2 h_fin12'

theorem refinementSelfAndWrt_boundary_eq
    (G1 G2 : EvenGraph)
    (h_fin12 : Set.Finite (G1.toBoundarySet ∩ G2.toBoundarySet)) :
    (graphRefinementSelfAndWrt G1 G2 h_fin12).toBoundarySet =
    G1.toBoundarySet := by
  simp only [graphRefinementSelfAndWrt]
  rw [refinementWrt_boundary_eq,
      refinementSelf_boundary_eq]

theorem refinementSelfAndWrt_interior_eq
    (G1 G2 : EvenGraph)
    (h_fin12 : Set.Finite (G1.toBoundarySet ∩ G2.toBoundarySet)) :
    (graphRefinementSelfAndWrt G1 G2 h_fin12).interior =
    G1.interior := by
  simp only [graphRefinementSelfAndWrt]
  rw [refinementWrt_interior_eq,
      refinementSelf_interior_eq]

theorem refinementSelfAndWrt_seg_inter_boundary_subset
    (G1 G2 : EvenGraph)
    (h_fin12 : Set.Finite (G1.toBoundarySet ∩ G2.toBoundarySet))
    (seg : LineSegment)
    (h_seg : seg ∈
      (graphRefinementSelfAndWrt G1 G2 h_fin12).segments) :
    seg.toSet ∩ G2.toBoundarySet ⊆ ({seg.p1, seg.p2} : Set Vector2D) :=
  refinementWrt_seg_inter_boundary_subset
    (graphRefinementSelf G1) G2 _ seg h_seg

theorem refinementSelfAndWrt_no_segment_interior_vertices
    (G1 G2 : EvenGraph)
    (h_fin12 : Set.Finite (G1.toBoundarySet ∩ G2.toBoundarySet)) :
    ∀ v ∈ (graphRefinementSelfAndWrt G1 G2 h_fin12).toVertices,
      ∀ seg ∈ (graphRefinementSelfAndWrt G1 G2 h_fin12).segments,
        seg.p1 ≠ v → seg.p2 ≠ v → v ∉ seg.toSet :=
  graphRefinementWrt_preserves_no_segment_interior_vertices
    (graphRefinementSelf G1) G2 _
    (refinementSelf_no_segment_interior_vertices G1)

/-! ### Characterization of `graphRefinementSelfAndWrt` segments via combined points -/

/-- The combined point list (as a `Finset`) used by `graphRefinementSelfAndWrt`:
    the union of `selfSegmentInteriorVertices G1` and the boundary intersections
    `G1.toBoundarySet ∩ G2.toBoundarySet`. -/
theorem graphRefinementSelfAndWrt_segments_perm
    (G1 G2 : EvenGraph)
    (h_fin12 : Set.Finite (G1.toBoundarySet ∩ G2.toBoundarySet)) :
    let selfPts : List Vector2D :=
      (selfSegmentInteriorVertices_finite G1).toFinset.toList
    let wrtPts : List Vector2D :=
      (h_fin12.toFinset).toList
    List.Perm
      ((graphRefinementSelfAndWrt G1 G2 h_fin12).segments.map
        LineSegment.toEndpointsMultiset)
      ((G1.segments.flatMap
        (fun s => iterativeSplit s (selfPts ++ wrtPts))).map
          LineSegment.toEndpointsMultiset) := by
  -- Unfold graphRefinementSelfAndWrt = graphRefinementWrt (graphRefinementSelf G1) G2 _.
  -- Then graphRefinementWrt = refineGraphWithPoints _ wrtPts _.
  -- Then graphRefinementSelf = refineGraphWithPoints _ selfPts _.
  set selfPts : List Vector2D :=
    (selfSegmentInteriorVertices_finite G1).toFinset.toList with hselfPts_def
  set h_fin_self := selfSegmentInteriorVertices_finite G1 with h_fin_self_def
  -- (graphRefinementSelf G1) = refineGraphWithPoints G1 selfPts _.
  have h_self_eq : graphRefinementSelf G1 =
      refineGraphWithPoints G1 selfPts (fun pt h_mem => by
        have h1 : pt ∈ h_fin_self.toFinset := Finset.mem_toList.mp h_mem
        exact selfSegmentInteriorVertices_subset_boundary G1
          (h_fin_self.mem_toFinset.mp h1)) := rfl
  set G1' := graphRefinementSelf G1 with hG1'_def
  have hG1'_bnd : G1'.toBoundarySet = G1.toBoundarySet :=
    refinementSelf_boundary_eq G1
  set wrtPts : List Vector2D := h_fin12.toFinset.toList with hwrtPts_def
  -- The h_fin12' for graphRefinementWrt G1' G2 _:
  have h_fin12' : Set.Finite (G1'.toBoundarySet ∩ G2.toBoundarySet) := by
    rw [hG1'_bnd]; exact h_fin12
  -- (graphRefinementSelfAndWrt G1 G2 h_fin12).segments
  --   = (graphRefinementWrt G1' G2 h_fin12').segments
  --   = (refineGraphWithPoints G1' h_fin12'.toFinset.toList _).segments
  -- and h_fin12'.toFinset = h_fin12.toFinset (because the underlying sets are equal up to bdy eq).
  -- We need to use refineGraphWithPoints_segments_perm here.
  have h1 : List.Perm
      ((graphRefinementSelfAndWrt G1 G2 h_fin12).segments.map
        LineSegment.toEndpointsMultiset)
      ((G1'.segments.flatMap (fun s => iterativeSplit s wrtPts)).map
        LineSegment.toEndpointsMultiset) := by
    -- graphRefinementSelfAndWrt = graphRefinementWrt G1' G2 h_fin12' = refineGraphWithPoints G1' (h_fin12'.toFinset.toList) _.
    -- But we want refineGraphWithPoints G1' wrtPts _ where wrtPts = h_fin12.toFinset.toList.
    -- Since h_fin12.toFinset = h_fin12'.toFinset (same set under bdy_eq), the lists agree.
    have h_set_eq : G1'.toBoundarySet ∩ G2.toBoundarySet = G1.toBoundarySet ∩ G2.toBoundarySet := by
      rw [hG1'_bnd]
    -- We use the fact that the input lists are the same after Finset.toList.
    -- The proof: directly use refineGraphWithPoints_segments_perm on G1' and the wrtPts list.
    -- We need the h_all hypothesis for wrtPts ⊆ G1'.toBoundarySet.
    have h_all_wrt : ∀ pt ∈ wrtPts, pt ∈ G1'.toBoundarySet := by
      intro pt hpt
      rw [hwrtPts_def] at hpt
      have hpt' : pt ∈ h_fin12.toFinset := Finset.mem_toList.mp hpt
      have hpt_inter : pt ∈ G1.toBoundarySet ∩ G2.toBoundarySet := h_fin12.mem_toFinset.mp hpt'
      rw [hG1'_bnd]; exact hpt_inter.1
    -- (graphRefinementSelfAndWrt G1 G2 h_fin12) = refineGraphWithPoints G1' wrtPts h_all_wrt
    -- This is true definitionally if h_fin12.toFinset = h_fin12'.toFinset.
    have h_finset_eq : h_fin12.toFinset = h_fin12'.toFinset := by
      apply Finset.ext
      intro x
      rw [h_fin12.mem_toFinset, h_fin12'.mem_toFinset, h_set_eq]
    have h_def_eq :
        (graphRefinementSelfAndWrt G1 G2 h_fin12).segments =
        (refineGraphWithPoints G1' wrtPts h_all_wrt).segments := by
      show (graphRefinementWrt G1' G2 h_fin12').segments = _
      show (refineGraphWithPoints G1' h_fin12'.toFinset.toList _).segments =
        (refineGraphWithPoints G1' wrtPts h_all_wrt).segments
      -- These have the same input list (modulo h_finset_eq).
      -- Cast through h_finset_eq.
      have hL : h_fin12'.toFinset.toList = wrtPts := by
        rw [hwrtPts_def, ← h_finset_eq]
      -- The graph data depends only on the list (not the h_all proof).
      revert h_all_wrt
      rw [← hL]
      intro h_all_wrt
      rfl
    rw [h_def_eq]
    exact refineGraphWithPoints_segments_perm G1' wrtPts h_all_wrt
  refine h1.trans ?_
  -- Now compose with refineGraphWithPoints_segments_perm on G1.
  -- G1'.segments.map toEM ~ (G1.segments.flatMap (· iterativeSplit · selfPts)).map toEM
  have h2 : List.Perm
      (G1'.segments.map LineSegment.toEndpointsMultiset)
      ((G1.segments.flatMap (fun s => iterativeSplit s selfPts)).map
        LineSegment.toEndpointsMultiset) := by
    -- G1' = graphRefinementSelf G1 = refineGraphWithPoints G1 selfPts _.
    have h_all_self : ∀ pt ∈ selfPts, pt ∈ G1.toBoundarySet := fun pt h_mem => by
      have h1 : pt ∈ h_fin_self.toFinset := Finset.mem_toList.mp h_mem
      exact selfSegmentInteriorVertices_subset_boundary G1
        (h_fin_self.mem_toFinset.mp h1)
    have h_def_self : G1'.segments = (refineGraphWithPoints G1 selfPts h_all_self).segments := rfl
    rw [h_def_self]
    exact refineGraphWithPoints_segments_perm G1 selfPts h_all_self
  -- Apply flatMap_iterativeSplit_perm_of_perm_toEM to lift through wrtPts.
  have h_lift := flatMap_iterativeSplit_perm_of_perm_toEM wrtPts _ _ h2
  refine h_lift.trans ?_
  -- Now: ((G1.segments.flatMap (· iterativeSplit · selfPts)).flatMap (· iterativeSplit · wrtPts)).map toEM
  -- ~ (G1.segments.flatMap (· iterativeSplit · (selfPts ++ wrtPts))).map toEM
  -- Use List.flatMap_assoc and iterativeSplit_append.
  rw [List.flatMap_assoc]
  -- Goal: (G1.segments.flatMap (fun s => (iterativeSplit s selfPts).flatMap (fun s' => iterativeSplit s' wrtPts))).map toEM
  -- ~ (G1.segments.flatMap (fun s => iterativeSplit s (selfPts ++ wrtPts))).map toEM
  have h_eq : ∀ s : LineSegment,
      (iterativeSplit s selfPts).flatMap (fun s' => iterativeSplit s' wrtPts) =
      iterativeSplit s (selfPts ++ wrtPts) := by
    intro s
    rw [iterativeSplit_append]
  have h_funext :
      (fun (x : LineSegment) =>
        (iterativeSplit x selfPts).flatMap (fun s => iterativeSplit s wrtPts)) =
      (fun (s : LineSegment) => iterativeSplit s (selfPts ++ wrtPts)) := by
    funext s
    exact h_eq s
  rw [h_funext]

end EvenGraphRefinementProofs

