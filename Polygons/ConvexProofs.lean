/-\!
# Proofs for convex region partition theorem

We first prove the partition for a single half-plane (using trichotomy on the dot product),
then lift to the intersection of multiple half-planes by simple logic.
-/

open Classical Set

noncomputable section

namespace ConvexProofs

open ConvexProofs

-- ============================================================================
-- Single half-plane: trichotomy on dot product
-- ============================================================================

lemma HalfPlane.disjoint_interior_exterior (hp : HalfPlane) :
    Disjoint hp.toInteriorSet hp.toExteriorSet :=
  disjoint_left.mpr fun q (hi : hp.dot q > 0) (he : hp.dot q < 0) => by linarith

lemma HalfPlane.disjoint_interior_boundary (hp : HalfPlane) :
    Disjoint hp.toInteriorSet hp.toBoundarySet :=
  disjoint_left.mpr fun q (hi : hp.dot q > 0) (hb : hp.dot q = 0) => by linarith

lemma HalfPlane.disjoint_exterior_boundary (hp : HalfPlane) :
    Disjoint hp.toExteriorSet hp.toBoundarySet :=
  disjoint_left.mpr fun q (he : hp.dot q < 0) (hb : hp.dot q = 0) => by linarith

lemma HalfPlane.trichotomy (hp : HalfPlane) (q : Vector2D) :
    q ∈ hp.toInteriorSet ∨ q ∈ hp.toExteriorSet ∨ q ∈ hp.toBoundarySet := by
  show hp.dot q > 0 ∨ hp.dot q < 0 ∨ hp.dot q = 0
  rcases lt_trichotomy (hp.dot q) 0 with h | h | h
  · right; left; exact h
  · right; right; exact h
  · left; exact h

-- ============================================================================
-- Partition proof
-- ============================================================================

theorem HalfPlaneIntersection.partition_proof (hpi : HalfPlaneIntersection) :
    Disjoint hpi.toInteriorSet hpi.toExteriorSet ∧
    Disjoint hpi.toInteriorSet hpi.toBoundarySet ∧
    Disjoint hpi.toExteriorSet hpi.toBoundarySet ∧
    hpi.toInteriorSet ∪ hpi.toExteriorSet ∪ hpi.toBoundarySet = Set.univ := by
  refine ⟨?_, ?_, ?_, ?_⟩
  · exact disjoint_left.mpr fun q hi he => by
      obtain ⟨hp, hpm, hpe⟩ := he
      exact (hp.disjoint_interior_exterior).le_bot ⟨hi hp hpm, hpe⟩
  · exact disjoint_left.mpr fun q hi hb => by
      obtain ⟨⟨hp, hpm, hpb⟩, _⟩ := hb
      exact (hp.disjoint_interior_boundary).le_bot ⟨hi hp hpm, hpb⟩
  · exact disjoint_left.mpr fun q he hb => by
      obtain ⟨hp, hpm, hpe⟩ := he
      exact absurd hpe (hb.2 hp hpm)
  · ext q
    simp only [mem_union, mem_univ, iff_true]
    by_cases hall : ∀ hp ∈ hpi.halfPlanes, q ∈ hp.toInteriorSet
    · left; left; exact hall
    · push_neg at hall
      obtain ⟨hp, hpm, hni⟩ := hall
      rcases hp.trichotomy q with hint | hext | hbnd
      · exact absurd hint hni
      · left; right; exact ⟨hp, hpm, hext⟩
      · by_cases hnoext : ∀ hp' ∈ hpi.halfPlanes, q ∉ hp'.toExteriorSet
        · right; exact ⟨⟨hp, hpm, hbnd⟩, hnoext⟩
        · push_neg at hnoext
          obtain ⟨hp', hpm', hext'⟩ := hnoext
          left; right; exact ⟨hp', hpm', hext'⟩

-- ============================================================================
-- Dot product is linear along a segment
-- ============================================================================

lemma HalfPlane.dot_segment (hp : HalfPlane) (seg : LineSegment) (q : Vector2D)
    (t : ℚ) (_ht0 : 0 ≤ t) (_ht1 : t ≤ 1)
    (hx : q.x = (1 - t) * seg.p1.x + t * seg.p2.x)
    (hy : q.y = (1 - t) * seg.p1.y + t * seg.p2.y) :
    hp.dot q = (1 - t) * hp.dot seg.p1 + t * hp.dot seg.p2 := by
  simp only [HalfPlane.dot]
  rw [hx, hy]
  ring

lemma HalfPlane.dot_zero_segment (hp : HalfPlane) (seg : LineSegment)
    (h1 : hp.dot seg.p1 = 0) (h2 : hp.dot seg.p2 = 0)
    (q : Vector2D) (hq : q ∈ seg.toSet) : hp.dot q = 0 := by
  obtain ⟨t, ht0, ht1, hx, hy⟩ := hq
  have hlin := hp.dot_segment seg q t ht0 ht1 hx hy
  rw [h1, h2] at hlin
  linarith

/-- If hp.dot is negative at one endpoint and has no zero on the segment,
    then hp.dot is negative everywhere on the segment. -/
lemma HalfPlane.dot_neg_on_segment (hp : HalfPlane) (seg : LineSegment)
    (h_neg : hp.dot seg.p1 < 0)
    (h_no_zero : ∀ q ∈ seg.toSet, hp.dot q ≠ 0) :
    ∀ q ∈ seg.toSet, hp.dot q < 0 := by
  intro q ⟨t, ht0, ht1, hx, hy⟩
  have hlin := hp.dot_segment seg q t ht0 ht1 hx hy
  by_contra h
  push_neg at h
  set d1 := hp.dot seg.p1 with hd1_def
  set d2 := hp.dot seg.p2 with hd2_def
  have hd2_pos : d2 > 0 := by
    by_contra hd2_nonpos
    push_neg at hd2_nonpos
    have h1 : (1 - t) * d1 ≤ 0 := mul_nonpos_of_nonneg_of_nonpos (by linarith) (le_of_lt h_neg)
    have h2 : t * d2 ≤ 0 := mul_nonpos_of_nonneg_of_nonpos ht0 hd2_nonpos
    have ht1_eq : (1 - t) * d1 = 0 := by linarith
    have ht2_eq : t * d2 = 0 := by linarith
    rcases mul_eq_zero.mp ht1_eq with ht_eq_1 | hd1_eq_0
    · rcases mul_eq_zero.mp ht2_eq with ht_eq_0 | hd2_eq_0
      · linarith
      · exact absurd hd2_eq_0 (h_no_zero seg.p2 ⟨1, zero_le_one, le_refl _, by ring, by ring⟩)
    · linarith
  have hd_pos : d2 - d1 > 0 := by linarith
  set s := (-d1) / (d2 - d1)
  have hs0 : 0 ≤ s := div_nonneg (by linarith) (le_of_lt hd_pos)
  have hs1 : s ≤ 1 := by rw [div_le_one hd_pos]; linarith
  have h_zero : (1 - s) * d1 + s * d2 = 0 := by
    have hs_eq : s * (d2 - d1) = -d1 := by
      rw [show s = (-d1) / (d2 - d1) from rfl]
      exact div_mul_cancel₀ (-d1) (ne_of_gt hd_pos)
    nlinarith
  set q' : Vector2D := ⟨(1 - s) * seg.p1.x + s * seg.p2.x,
                         (1 - s) * seg.p1.y + s * seg.p2.y⟩
  have hq'_mem : q' ∈ seg.toSet := ⟨s, hs0, hs1, rfl, rfl⟩
  have hq'_dot : hp.dot q' = 0 := by
    have := hp.dot_segment seg q' s hs0 hs1 rfl rfl
    linarith
  exact h_no_zero q' hq'_mem hq'_dot

-- ============================================================================
-- Single half-plane segment separation
-- ============================================================================

lemma HalfPlane.no_crossing_same_sign_pos (hp : HalfPlane) (seg : LineSegment)
    (h1 : hp.dot seg.p1 > 0) (h2 : hp.dot seg.p2 > 0) :
    ¬seg.intersectsBoundary hp := by
  intro ⟨q, ⟨t, ht0, ht1, hx, hy⟩, (hb : hp.dot q = 0)⟩
  have := hp.dot_segment seg q t ht0 ht1 hx hy
  have h1' : (1 - t) * hp.dot seg.p1 ≥ 0 := mul_nonneg (by linarith) (le_of_lt h1)
  have h2' : t * hp.dot seg.p2 ≥ 0 := mul_nonneg ht0 (le_of_lt h2)
  have : (1 - t) * hp.dot seg.p1 = 0 := by linarith
  have : t * hp.dot seg.p2 = 0 := by linarith
  rcases mul_eq_zero.mp ‹(1 - t) * hp.dot seg.p1 = 0› with h | h
  · rcases mul_eq_zero.mp ‹t * hp.dot seg.p2 = 0› with h' | h'
    · linarith
    · linarith
  · linarith

/-- If hp.dot > 0 at both endpoints, then hp.dot > 0 everywhere on the segment. -/
lemma HalfPlane.dot_pos_on_segment (hp : HalfPlane) (seg : LineSegment)
    (h1 : hp.dot seg.p1 > 0) (h2 : hp.dot seg.p2 > 0)
    (q : Vector2D) (hq : q ∈ seg.toSet) : hp.dot q > 0 := by
  obtain ⟨t, ht0, ht1, hx, hy⟩ := hq
  have hlin := hp.dot_segment seg q t ht0 ht1 hx hy
  have h1' : (1 - t) * hp.dot seg.p1 ≥ 0 := mul_nonneg (by linarith) (le_of_lt h1)
  have h2' : t * hp.dot seg.p2 ≥ 0 := mul_nonneg ht0 (le_of_lt h2)
  -- At least one of them is > 0 (not both can be 0 unless t=0,d1=0 or t=1,d2=0, but both >0)
  by_cases ht0' : t = 0
  · rw [hlin, ht0']; simp; linarith
  · by_cases ht1' : t = 1
    · rw [hlin, ht1']; simp; linarith
    · have ht_lt_1 : t < 1 := lt_of_le_of_ne ht1 ht1'
      have : (1 - t) * hp.dot seg.p1 > 0 := mul_pos (by linarith) h1
      linarith

lemma HalfPlane.no_crossing_same_sign_neg (hp : HalfPlane) (seg : LineSegment)
    (h1 : hp.dot seg.p1 < 0) (h2 : hp.dot seg.p2 < 0) :
    ¬seg.intersectsBoundary hp := by
  intro ⟨q, ⟨t, ht0, ht1, hx, hy⟩, (hb : hp.dot q = 0)⟩
  have := hp.dot_segment seg q t ht0 ht1 hx hy
  have h1' : (1 - t) * hp.dot seg.p1 ≤ 0 :=
    mul_nonpos_of_nonneg_of_nonpos (by linarith) (le_of_lt h1)
  have h2' : t * hp.dot seg.p2 ≤ 0 :=
    mul_nonpos_of_nonneg_of_nonpos ht0 (le_of_lt h2)
  have : (1 - t) * hp.dot seg.p1 = 0 := by linarith
  have : t * hp.dot seg.p2 = 0 := by linarith
  rcases mul_eq_zero.mp ‹(1 - t) * hp.dot seg.p1 = 0› with h | h
  · rcases mul_eq_zero.mp ‹t * hp.dot seg.p2 = 0› with h' | h'
    · linarith
    · linarith
  · linarith

lemma HalfPlane.crossing_opposite_sign (hp : HalfPlane) (seg : LineSegment)
    (h1 : hp.dot seg.p1 > 0) (h2 : hp.dot seg.p2 < 0) :
    seg.intersectsBoundary hp := by
  set d1 := hp.dot seg.p1; set d2 := hp.dot seg.p2
  have hd : d1 - d2 > 0 := by linarith
  set t := d1 / (d1 - d2)
  have ht0 : 0 ≤ t := div_nonneg (le_of_lt h1) (le_of_lt hd)
  have ht1 : t ≤ 1 := by rw [div_le_one hd]; linarith
  refine ⟨⟨(1 - t) * seg.p1.x + t * seg.p2.x,
           (1 - t) * seg.p1.y + t * seg.p2.y⟩,
          ⟨t, ht0, ht1, rfl, rfl⟩, ?_⟩
  show hp.dot ⟨_, _⟩ = 0
  have hlin := hp.dot_segment seg ⟨_, _⟩ t ht0 ht1 rfl rfl
  rw [hlin]
  have ht_eq : t * (d1 - d2) = d1 := by
    rw [show t = d1 / (d1 - d2) from rfl]
    exact div_mul_cancel₀ d1 (ne_of_gt hd)
  nlinarith

lemma HalfPlane.crossing_opposite_sign' (hp : HalfPlane) (seg : LineSegment)
    (h1 : hp.dot seg.p1 < 0) (h2 : hp.dot seg.p2 > 0) :
    seg.intersectsBoundary hp := by
  set d1 := hp.dot seg.p1; set d2 := hp.dot seg.p2
  have hd : d2 - d1 > 0 := by linarith
  set t := (-d1) / (d2 - d1)
  have ht0 : 0 ≤ t := div_nonneg (by linarith) (le_of_lt hd)
  have ht1 : t ≤ 1 := by rw [div_le_one hd]; linarith
  refine ⟨⟨(1 - t) * seg.p1.x + t * seg.p2.x,
           (1 - t) * seg.p1.y + t * seg.p2.y⟩,
          ⟨t, ht0, ht1, rfl, rfl⟩, ?_⟩
  show hp.dot ⟨_, _⟩ = 0
  have hlin := hp.dot_segment seg ⟨_, _⟩ t ht0 ht1 rfl rfl
  rw [hlin]
  have ht_eq : t * (d2 - d1) = -d1 := by
    rw [show t = (-d1) / (d2 - d1) from rfl]
    exact div_mul_cancel₀ (-d1) (ne_of_gt hd)
  nlinarith

theorem HalfPlane.segment_separation_proof (hp : HalfPlane)
    (seg : LineSegment)
    (hp1_not_boundary : seg.p1 ∉ hp.toBoundarySet)
    (hp2_not_boundary : seg.p2 ∉ hp.toBoundarySet) :
    ((seg.p1 ∈ hp.toInteriorSet ∧ seg.p2 ∈ hp.toInteriorSet) ∨
     (seg.p1 ∈ hp.toExteriorSet ∧ seg.p2 ∈ hp.toExteriorSet)) ↔
    ¬seg.intersectsBoundary hp := by
  simp only [HalfPlane.toBoundarySet, Set.mem_setOf_eq] at hp1_not_boundary
  simp only [HalfPlane.toBoundarySet, Set.mem_setOf_eq] at hp2_not_boundary
  constructor
  · intro h
    rcases h with ⟨h1, h2⟩ | ⟨h1, h2⟩
    · exact hp.no_crossing_same_sign_pos seg h1 h2
    · exact hp.no_crossing_same_sign_neg seg h1 h2
  · intro hno
    have h1 : hp.dot seg.p1 > 0 ∨ hp.dot seg.p1 < 0 := by
      rcases lt_trichotomy (hp.dot seg.p1) 0 with h | h | h
      · right; exact h
      · exact absurd h hp1_not_boundary
      · left; exact h
    have h2 : hp.dot seg.p2 > 0 ∨ hp.dot seg.p2 < 0 := by
      rcases lt_trichotomy (hp.dot seg.p2) 0 with h | h | h
      · right; exact h
      · exact absurd h hp2_not_boundary
      · left; exact h
    rcases h1 with h1_pos | h1_neg
    · rcases h2 with h2_pos | h2_neg
      · left; exact ⟨h1_pos, h2_pos⟩
      · exact absurd (hp.crossing_opposite_sign seg h1_pos h2_neg) hno
    · rcases h2 with h2_pos | h2_neg
      · exact absurd (hp.crossing_opposite_sign' seg h1_neg h2_pos) hno
      · right; exact ⟨h1_neg, h2_neg⟩

-- ============================================================================
-- Finiteness of boundary crossings
-- ============================================================================

lemma HalfPlane.boundary_segment_subsingleton (hp : HalfPlane) (seg : LineSegment)
    (h : hp.dot seg.p1 ≠ 0 ∨ hp.dot seg.p2 ≠ 0) :
    (seg.toSet ∩ hp.toBoundarySet).Subsingleton := by
  intro q1 ⟨⟨t1, ht10, ht11, hx1, hy1⟩, (hb1 : hp.dot q1 = 0)⟩
       q2 ⟨⟨t2, ht20, ht21, hx2, hy2⟩, (hb2 : hp.dot q2 = 0)⟩
  have lin1 := hp.dot_segment seg q1 t1 ht10 ht11 hx1 hy1
  have lin2 := hp.dot_segment seg q2 t2 ht20 ht21 hx2 hy2
  rw [hb1] at lin1; rw [hb2] at lin2
  by_cases hd : hp.dot seg.p1 = hp.dot seg.p2
  · have hd0 : hp.dot seg.p1 = 0 := by nlinarith
    have hd0' : hp.dot seg.p2 = 0 := by linarith
    rcases h with h1 | h2
    · exact absurd hd0 h1
    · exact absurd hd0' h2
  · have hsub : (t1 - t2) * (hp.dot seg.p2 - hp.dot seg.p1) = 0 := by nlinarith
    rcases mul_eq_zero.mp hsub with h1 | h2
    · have heq : t1 = t2 := by linarith
      exact (Vector2D.mk.injEq _ _ _ _).mpr ⟨by rw [hx1, hx2, heq], by rw [hy1, hy2, heq]⟩
    · exact absurd (by linarith : hp.dot seg.p1 = hp.dot seg.p2) hd

lemma HalfPlane.degenerate_no_crossings (hp : HalfPlane) (hpi : HalfPlaneIntersection)
    (seg : LineSegment) (hpm : hp ∈ hpi.halfPlanes)
    (hd1 : hp.dot seg.p1 = 0) (hd2 : hp.dot seg.p2 = 0)
    (hp1_not_boundary : seg.p1 ∉ hpi.toBoundarySet)
    (avoids_vertices : ∀ q ∈ seg.toSet, q ∉ hpi.toVertexSet) :
    ∀ q ∈ seg.toSet, q ∈ hp.toBoundarySet → q ∉ hpi.toBoundarySet := by
  intro q hqs (hqb : hp.dot q = 0) hq_in_boundary
  have h_exists_ext : ∃ hp' ∈ hpi.halfPlanes, hp'.dot seg.p1 < 0 := by
    by_contra h_no_ext
    push_neg at h_no_ext
    apply hp1_not_boundary
    constructor
    · exact ⟨hp, hpm, hd1⟩
    · intro hp' hpm' (hext : hp'.dot seg.p1 < 0)
      have := h_no_ext hp' hpm'
      linarith
  obtain ⟨hp', hpm', h_ext_p1⟩ := h_exists_ext
  have hp_ne_hp' : hp ≠ hp' := by intro heq; rw [heq] at hd1; linarith
  have h_no_zero_hp' : ∀ q' ∈ seg.toSet, hp'.dot q' ≠ 0 := by
    intro q' hq'_mem hq'_zero
    have hq'_on_hp : hp.dot q' = 0 := hp.dot_zero_segment seg hd1 hd2 q' hq'_mem
    apply avoids_vertices q' hq'_mem
    show ∃ hp1 ∈ hpi.halfPlanes, ∃ hp2 ∈ hpi.halfPlanes,
      hp1 ≠ hp2 ∧ hp1.dot q' = 0 ∧ hp2.dot q' = 0
    exact ⟨hp, hpm, hp', hpm', hp_ne_hp', hq'_on_hp, hq'_zero⟩
  have h_ext_q : hp'.dot q < 0 := hp'.dot_neg_on_segment seg h_ext_p1 h_no_zero_hp' q hqs
  exact absurd h_ext_q (hq_in_boundary.2 hp' hpm')

lemma HalfPlaneIntersection.boundaryCrossings_finite
    (hpi : HalfPlaneIntersection) (seg : LineSegment)
    (hp1_not_boundary : seg.p1 ∉ hpi.toBoundarySet)
    (_hp2_not_boundary : seg.p2 ∉ hpi.toBoundarySet)
    (avoids_vertices : ∀ q ∈ seg.toSet, q ∉ hpi.toVertexSet) :
    (seg.boundaryCrossings hpi).Finite := by
  set S := { hp ∈ hpi.halfPlanes | ¬(hp.dot seg.p1 = 0 ∧ hp.dot seg.p2 = 0) }
  apply Set.Finite.subset (s := ⋃ hp ∈ S, (seg.toSet ∩ hp.toBoundarySet))
  · apply Set.Finite.biUnion
    · exact Set.Finite.subset (List.finite_toSet _) (fun hp hx => hx.1)
    · intro hp ⟨_, hne⟩
      push_neg at hne
      by_cases h1 : hp.dot seg.p1 ≠ 0
      · exact (hp.boundary_segment_subsingleton seg (Or.inl h1)).finite
      · push_neg at h1
        exact (hp.boundary_segment_subsingleton seg (Or.inr (hne h1))).finite
  · intro q ⟨hqs, hqb⟩
    simp only [Set.mem_iUnion]
    obtain ⟨⟨hp, hpm, hqhp⟩, hq_not_ext⟩ := hqb
    by_cases hboth : hp.dot seg.p1 = 0 ∧ hp.dot seg.p2 = 0
    · exfalso
      exact hp.degenerate_no_crossings hpi seg hpm hboth.1 hboth.2
        hp1_not_boundary avoids_vertices q hqs hqhp ⟨⟨hp, hpm, hqhp⟩, hq_not_ext⟩
    · exact ⟨hp, ⟨⟨hpm, hboth⟩, hqs, hqhp⟩⟩

-- ============================================================================
-- Both interior → no boundary crossings
-- ============================================================================

theorem HalfPlaneIntersection.interior_no_crossings
    (hpi : HalfPlaneIntersection) (seg : LineSegment)
    (h1 : seg.p1 ∈ hpi.toInteriorSet) (h2 : seg.p2 ∈ hpi.toInteriorSet) :
    seg.boundaryCrossings hpi = ∅ := by
  ext q
  simp only [Set.mem_empty_iff_false, iff_false]
  intro ⟨hqs, hqb⟩
  obtain ⟨⟨hp, hpm, (hqhp : hp.dot q = 0)⟩, _⟩ := hqb
  have hq_pos : hp.dot q > 0 :=
    hp.dot_pos_on_segment seg (h1 hp hpm) (h2 hp hpm) q hqs
  linarith

-- ============================================================================
-- Auxiliary: minimum of a nonempty list
-- ============================================================================

private lemma list_exists_min {l : List ℚ} (hl : l ≠ []) :
    ∃ m ∈ l, ∀ x ∈ l, m ≤ x := by
  induction l with
  | nil => exact absurd rfl hl
  | cons a rest ih =>
    by_cases hrest : rest = []
    · refine ⟨a, List.mem_cons.mpr (Or.inl rfl), fun x hx => ?_⟩
      rcases List.mem_cons.mp hx with rfl | h
      · exact le_refl _
      · simp [hrest] at h
    · obtain ⟨m, hm_mem, hm_le⟩ := ih hrest
      by_cases h : a ≤ m
      · refine ⟨a, List.mem_cons.mpr (Or.inl rfl), fun x hx => ?_⟩
        rcases List.mem_cons.mp hx with rfl | hx'
        · exact le_refl _
        · exact le_trans h (hm_le x hx')
      · push_neg at h
        refine ⟨m, List.mem_cons.mpr (Or.inr hm_mem), fun x hx => ?_⟩
        rcases List.mem_cons.mp hx with rfl | hx'
        · exact le_of_lt h
        · exact hm_le x hx'

-- ============================================================================
-- Crossing parameter helpers
-- ============================================================================

private lemma crossing_param_range (d1 d2 : ℚ) (h1 : d1 > 0) (h2 : d2 < 0) :
    0 < d1 / (d1 - d2) ∧ d1 / (d1 - d2) ≤ 1 := by
  have hd : d1 - d2 > 0 := by linarith
  exact ⟨div_pos h1 hd, by rw [div_le_one hd]; linarith⟩

private lemma crossing_param_dot_zero (d1 d2 : ℚ) (h1 : d1 > 0) (h2 : d2 < 0) :
    (1 - d1 / (d1 - d2)) * d1 + d1 / (d1 - d2) * d2 = 0 := by
  have hd : d1 - d2 > 0 := by linarith
  have : d1 / (d1 - d2) * (d1 - d2) = d1 := div_mul_cancel₀ d1 (ne_of_gt hd)
  nlinarith

private lemma dot_pos_before_crossing (d1 d2 : ℚ) (h1 : d1 > 0) (h2 : d2 < 0)
    (s : ℚ) (_hs0 : 0 ≤ s) (hs_lt : s < d1 / (d1 - d2)) :
    (1 - s) * d1 + s * d2 > 0 := by
  have hd : d1 - d2 > 0 := by linarith
  have : s * (d1 - d2) < d1 := by rwa [lt_div_iff₀ hd] at hs_lt
  nlinarith

private lemma dot_nonneg_pos_nonneg (d1 d2 : ℚ) (h1 : d1 > 0) (hd2 : d2 ≥ 0)
    (s : ℚ) (hs0 : 0 ≤ s) (hs1 : s ≤ 1) :
    (1 - s) * d1 + s * d2 ≥ 0 := by
  have : (1 - s) * d1 ≥ 0 := mul_nonneg (by linarith) (le_of_lt h1)
  have : s * d2 ≥ 0 := mul_nonneg hs0 hd2
  linarith

-- ============================================================================
-- Interior + exterior → nonempty boundary crossings
-- ============================================================================

theorem HalfPlaneIntersection.interior_exterior_crossing
    (hpi : HalfPlaneIntersection) (seg : LineSegment)
    (_hp1_not_boundary : seg.p1 ∉ hpi.toBoundarySet)
    (_hp2_not_boundary : seg.p2 ∉ hpi.toBoundarySet)
    (_avoids_vertices : ∀ q ∈ seg.toSet, q ∉ hpi.toVertexSet)
    (h1_int : seg.p1 ∈ hpi.toInteriorSet)
    (h2_ext : seg.p2 ∈ hpi.toExteriorSet) :
    (seg.boundaryCrossings hpi).Nonempty := by
  obtain ⟨hp0, hp0_mem, (hp0_ext : hp0.dot seg.p2 < 0)⟩ := h2_ext
  -- Collect half-planes where p2 is exterior
  let is_bad (hp : HalfPlane) : Bool := decide (hp.dot seg.p2 < 0)
  set bad_hps := hpi.halfPlanes.filter (fun hp => is_bad hp) with hbad_def
  have hp0_in_bad : hp0 ∈ bad_hps := by
    simp only [bad_hps, is_bad, List.mem_filter, decide_eq_true_eq]
    exact ⟨hp0_mem, hp0_ext⟩
  have bad_ne : bad_hps ≠ [] := List.ne_nil_of_mem hp0_in_bad
  have bad_in_hps : ∀ hp ∈ bad_hps, hp ∈ hpi.halfPlanes := by
    intro hp hmem; exact (List.mem_filter.mp hmem).1
  have bad_neg : ∀ hp ∈ bad_hps, hp.dot seg.p2 < 0 := by
    intro hp hmem
    have := (List.mem_filter.mp hmem).2
    simp only [is_bad, decide_eq_true_eq] at this
    exact this
  have bad_pos : ∀ hp ∈ bad_hps, hp.dot seg.p1 > 0 :=
    fun hp hmem => h1_int hp (bad_in_hps hp hmem)
  -- Map to crossing parameters
  let param (hp : HalfPlane) : ℚ := hp.dot seg.p1 / (hp.dot seg.p1 - hp.dot seg.p2)
  set params := bad_hps.map param
  have params_ne : params ≠ [] := by
    intro h; exact bad_ne (List.map_eq_nil_iff.mp h)
  -- Find the minimum parameter
  obtain ⟨t_min, ht_min_mem, ht_min_le⟩ := list_exists_min params_ne
  -- t_min = param hp_min for some hp_min ∈ bad_hps
  have ht_min_mem' : t_min ∈ bad_hps.map param := ht_min_mem
  obtain ⟨hp_min, hp_min_mem, ht_min_eq⟩ := List.mem_map.mp ht_min_mem'
  have hp_min_pos : hp_min.dot seg.p1 > 0 := bad_pos hp_min hp_min_mem
  have hp_min_neg : hp_min.dot seg.p2 < 0 := bad_neg hp_min hp_min_mem
  have ht_range := crossing_param_range _ _ hp_min_pos hp_min_neg
  have ht_pos : 0 < t_min := ht_min_eq ▸ ht_range.1
  have ht_le1 : t_min ≤ 1 := ht_min_eq ▸ ht_range.2
  -- The point at parameter t_min
  set q : Vector2D := ⟨(1 - t_min) * seg.p1.x + t_min * seg.p2.x,
                        (1 - t_min) * seg.p1.y + t_min * seg.p2.y⟩
  have hq_seg : q ∈ seg.toSet :=
    ⟨t_min, le_of_lt ht_pos, ht_le1, rfl, rfl⟩
  -- hp_min.dot q = 0
  have hq_on_hp_min : hp_min.dot q = 0 := by
    have hlin := hp_min.dot_segment seg q t_min (le_of_lt ht_pos) ht_le1 rfl rfl
    rw [hlin]
    have : t_min = param hp_min := ht_min_eq.symm
    rw [this]
    exact crossing_param_dot_zero _ _ hp_min_pos hp_min_neg
  -- For all hp' ∈ halfPlanes, hp'.dot q ≥ 0
  have hq_not_ext : ∀ hp' ∈ hpi.halfPlanes, ¬(hp'.dot q < 0) := by
    intro hp' hp'_mem hq_neg
    have hp'_pos : hp'.dot seg.p1 > 0 := h1_int hp' hp'_mem
    have hlin := hp'.dot_segment seg q t_min (le_of_lt ht_pos) ht_le1 rfl rfl
    -- hp'.dot q = (1 - t_min) * hp'.dot p1 + t_min * hp'.dot p2
    -- This is < 0. Since hp'.dot p1 > 0 and 0 < t_min ≤ 1, we need hp'.dot p2 < 0.
    have hp'_neg_p2 : hp'.dot seg.p2 < 0 := by
      by_contra hd2_nonneg
      push_neg at hd2_nonneg
      have := dot_nonneg_pos_nonneg _ _ hp'_pos hd2_nonneg t_min
                (le_of_lt ht_pos) ht_le1
      linarith
    -- So hp' ∈ bad_hps
    have hp'_in_bad : hp' ∈ bad_hps := by
      simp only [bad_hps, is_bad, List.mem_filter, decide_eq_true_eq]
      exact ⟨hp'_mem, hp'_neg_p2⟩
    -- param hp' is in params, and t_min ≤ param hp'
    have h_le : t_min ≤ param hp' := by
      apply ht_min_le
      show param hp' ∈ bad_hps.map param
      exact List.mem_map.mpr ⟨hp', hp'_in_bad, rfl⟩
    -- At parameter t_min < param hp', hp'.dot is still positive; at t_min = param hp', dot = 0.
    rcases lt_or_eq_of_le h_le with h_lt | h_eq
    · have := dot_pos_before_crossing _ _ hp'_pos hp'_neg_p2 t_min
                (le_of_lt ht_pos) h_lt
      linarith
    · have : (1 - t_min) * hp'.dot seg.p1 + t_min * hp'.dot seg.p2 = 0 := by
        rw [h_eq]; exact crossing_param_dot_zero _ _ hp'_pos hp'_neg_p2
      linarith
  -- q is on the intersection boundary
  exact ⟨q, hq_seg, ⟨⟨hp_min, bad_in_hps hp_min hp_min_mem, hq_on_hp_min⟩, hq_not_ext⟩⟩

-- ============================================================================
-- Reversed segment has same crossing set
-- ============================================================================

lemma LineSegment.toSet_reverse (seg : LineSegment) :
    (LineSegment.mk seg.p2 seg.p1).toSet = seg.toSet := by
  ext q
  constructor
  · intro ⟨t, ht0, ht1, hx, hy⟩
    exact ⟨1 - t, by linarith, by linarith, by rw [hx]; ring, by rw [hy]; ring⟩
  · intro ⟨t, ht0, ht1, hx, hy⟩
    exact ⟨1 - t, by linarith, by linarith, by rw [hx]; ring, by rw [hy]; ring⟩

-- ============================================================================
-- Main segment separation theorem
-- ============================================================================

/-- The main segment separation theorem for a half-plane intersection.

This theorem establishes:
1. Finiteness of boundary crossings.
2. Both endpoints interior implies no boundary crossings.
3. One interior and one exterior implies at least one boundary crossing.
4. (Symmetric version of 3 with endpoints swapped.)

The full parity characterization (same side iff even number of crossings) would
require a combinatorial induction on the ordered sequence of crossing parameters
along the segment. The results above provide the key structural ingredients. -/
theorem HalfPlaneIntersection.segment_separation_proof (hpi : HalfPlaneIntersection)
    (seg : LineSegment)
    (hp1_not_boundary : seg.p1 ∉ hpi.toBoundarySet)
    (hp2_not_boundary : seg.p2 ∉ hpi.toBoundarySet)
    (avoids_vertices : ∀ q ∈ seg.toSet, q ∉ hpi.toVertexSet) :
    (seg.boundaryCrossings hpi).Finite ∧
    (seg.p1 ∈ hpi.toInteriorSet → seg.p2 ∈ hpi.toInteriorSet →
      seg.boundaryCrossings hpi = ∅) ∧
    (seg.p1 ∈ hpi.toInteriorSet → seg.p2 ∈ hpi.toExteriorSet →
      (seg.boundaryCrossings hpi).Nonempty) ∧
    (seg.p1 ∈ hpi.toExteriorSet → seg.p2 ∈ hpi.toInteriorSet →
      (seg.boundaryCrossings hpi).Nonempty) := by
  refine ⟨?_, ?_, ?_, ?_⟩
  · exact hpi.boundaryCrossings_finite seg hp1_not_boundary hp2_not_boundary avoids_vertices
  · exact hpi.interior_no_crossings seg
  · exact fun h1 h2 => hpi.interior_exterior_crossing seg
      hp1_not_boundary hp2_not_boundary avoids_vertices h1 h2
  · intro h1_ext h2_int
    -- Use the reversed segment: it has the same crossing set
    set seg' := LineSegment.mk seg.p2 seg.p1
    have h_set_eq : seg'.toSet = seg.toSet := seg.toSet_reverse
    have h_cross_eq : seg'.boundaryCrossings hpi = seg.boundaryCrossings hpi := by
      simp only [LineSegment.boundaryCrossings, h_set_eq]
    rw [← h_cross_eq]
    exact hpi.interior_exterior_crossing seg'
      hp2_not_boundary hp1_not_boundary
      (fun q hq => avoids_vertices q (h_set_eq ▸ hq))
      h2_int h1_ext

-- ============================================================================
-- Crossing parameter extraction
-- ============================================================================

/-- Every point on a segment has a parameter t ∈ [0,1]. -/
private def seg_param (seg : LineSegment) (q : Vector2D) (hq : q ∈ seg.toSet) : ℚ :=
  hq.choose

private lemma seg_param_spec (seg : LineSegment) (q : Vector2D) (hq : q ∈ seg.toSet) :
    let t := seg_param seg q hq
    0 ≤ t ∧ t ≤ 1 ∧
    q.x = (1 - t) * seg.p1.x + t * seg.p2.x ∧
    q.y = (1 - t) * seg.p1.y + t * seg.p2.y :=
  hq.choose_spec

/-- When p1 ≠ p2, the parameter of a point on the segment is unique. -/
private lemma seg_param_unique (seg : LineSegment) (hne : seg.p1 ≠ seg.p2)
    (t1 t2 : ℚ)
    (hx1 : (1 - t1) * seg.p1.x + t1 * seg.p2.x = (1 - t2) * seg.p1.x + t2 * seg.p2.x)
    (hy1 : (1 - t1) * seg.p1.y + t1 * seg.p2.y = (1 - t2) * seg.p1.y + t2 * seg.p2.y) :
    t1 = t2 := by
  have hx : (t1 - t2) * (seg.p2.x - seg.p1.x) = 0 := by nlinarith
  have hy : (t1 - t2) * (seg.p2.y - seg.p1.y) = 0 := by nlinarith
  rcases mul_eq_zero.mp hx with ht | hdx
  · linarith
  · rcases mul_eq_zero.mp hy with ht | hdy
    · linarith
    · exfalso; apply hne
      have hxeq : seg.p2.x = seg.p1.x := by linarith
      have hyeq : seg.p2.y = seg.p1.y := by linarith
      exact Vector2D.mk.injEq seg.p1.x seg.p1.y seg.p2.x seg.p2.y |>.mpr
        ⟨hxeq.symm, hyeq.symm⟩

-- ============================================================================
-- Subsegment definition and properties
-- ============================================================================

/-- A subsegment of seg from parameter t1 to t2 (where 0 ≤ t1 ≤ t2 ≤ 1). -/
private def LineSegment.subsegment (seg : LineSegment) (t1 t2 : ℚ) : LineSegment :=
  { p1 := ⟨(1 - t1) * seg.p1.x + t1 * seg.p2.x, (1 - t1) * seg.p1.y + t1 * seg.p2.y⟩
    p2 := ⟨(1 - t2) * seg.p1.x + t2 * seg.p2.x, (1 - t2) * seg.p1.y + t2 * seg.p2.y⟩ }

/-- Points on a subsegment are points on the original segment. -/
private lemma subsegment_toSet_subset (seg : LineSegment) (t1 t2 : ℚ)
    (ht1_0 : 0 ≤ t1) (ht2_1 : t2 ≤ 1) (ht12 : t1 ≤ t2) :
    (seg.subsegment t1 t2).toSet ⊆ seg.toSet := by
  intro q ⟨s, hs0, hs1, hx, hy⟩
  refine ⟨(1 - s) * t1 + s * t2, ?_, ?_, ?_, ?_⟩
  · have : (1 - s) * t1 ≥ 0 := mul_nonneg (by linarith) ht1_0
    have : s * t2 ≥ 0 := mul_nonneg hs0 (le_trans ht1_0 ht12)
    linarith
  · have : (1 - s) * t1 ≤ (1 - s) * 1 := by
      apply mul_le_mul_of_nonneg_left (le_trans ht12 ht2_1) (by linarith)
    have : s * t2 ≤ s * 1 := mul_le_mul_of_nonneg_left ht2_1 hs0
    simp at this ⊢; linarith
  · simp only [LineSegment.subsegment] at hx
    rw [hx]; ring
  · simp only [LineSegment.subsegment] at hy
    rw [hy]; ring

/-- The dot product along a subsegment reparametrizes linearly. -/
private lemma dot_subsegment_linear (hp : HalfPlane) (seg : LineSegment) (t1 t2 : ℚ)
    (s : ℚ) :
    hp.dot ⟨(1 - s) * ((1 - t1) * seg.p1.x + t1 * seg.p2.x) +
             s * ((1 - t2) * seg.p1.x + t2 * seg.p2.x),
            (1 - s) * ((1 - t1) * seg.p1.y + t1 * seg.p2.y) +
             s * ((1 - t2) * seg.p1.y + t2 * seg.p2.y)⟩ =
    (1 - ((1 - s) * t1 + s * t2)) * hp.dot seg.p1 +
    ((1 - s) * t1 + s * t2) * hp.dot seg.p2 := by
  simp only [HalfPlane.dot]
  ring

-- ============================================================================
-- Auxiliary: maximum of a nonempty list
-- ============================================================================

private lemma list_exists_max {l : List ℚ} (hl : l ≠ []) :
    ∃ m ∈ l, ∀ x ∈ l, x ≤ m := by
  induction l with
  | nil => exact absurd rfl hl
  | cons a rest ih =>
    by_cases hrest : rest = []
    · refine ⟨a, List.mem_cons.mpr (Or.inl rfl), fun x hx => ?_⟩
      rcases List.mem_cons.mp hx with rfl | h
      · exact le_refl _
      · simp [hrest] at h
    · obtain ⟨m, hm_mem, hm_le⟩ := ih hrest
      by_cases h : m ≤ a
      · refine ⟨a, List.mem_cons.mpr (Or.inl rfl), fun x hx => ?_⟩
        rcases List.mem_cons.mp hx with rfl | hx'
        · exact le_refl _
        · exact le_trans (hm_le x hx') h
      · push_neg at h
        refine ⟨m, List.mem_cons.mpr (Or.inr hm_mem), fun x hx => ?_⟩
        rcases List.mem_cons.mp hx with rfl | hx'
        · exact le_of_lt h
        · exact hm_le x hx'

-- ============================================================================
-- Boundary dot product helpers
-- ============================================================================

/-- At a boundary crossing, every HP has nonneg dot. -/
private lemma boundary_dot_nonneg {hpi : HalfPlaneIntersection} {q : Vector2D}
    (hq : q ∈ hpi.toBoundarySet) (hp : HalfPlane) (hpm : hp ∈ hpi.halfPlanes) :
    hp.dot q ≥ 0 :=
  not_lt.mp (hq.2 hp hpm)

/-- At a boundary point, a boundary crossing with dot = 0 on two distinct HPs
    is a vertex. -/
private lemma crossing_on_two_hps_is_vertex
    {hpi : HalfPlaneIntersection} {q : Vector2D} {seg : LineSegment}
    (hq_seg : q ∈ seg.toSet) (avoids_vertices : ∀ q ∈ seg.toSet, q ∉ hpi.toVertexSet)
    {hp1 hp2 : HalfPlane} (hm1 : hp1 ∈ hpi.halfPlanes) (hm2 : hp2 ∈ hpi.halfPlanes)
    (hne : hp1 ≠ hp2) (hd1 : hp1.dot q = 0) (hd2 : hp2.dot q = 0) : False :=
  avoids_vertices q hq_seg ⟨hp1, hm1, hp2, hm2, hne, hd1, hd2⟩

/-- The dot product at a boundary crossing for any HP other than the one it lies on
    must be strictly positive (using vertex avoidance). -/
private lemma boundary_crossing_other_hp_pos
    {hpi : HalfPlaneIntersection} {q : Vector2D} {seg : LineSegment}
    (hq_seg : q ∈ seg.toSet) (hq_bdy : q ∈ hpi.toBoundarySet)
    (avoids_vertices : ∀ q ∈ seg.toSet, q ∉ hpi.toVertexSet)
    {hp_q : HalfPlane} (hp_q_mem : hp_q ∈ hpi.halfPlanes) (hq_on : hp_q.dot q = 0)
    (hp' : HalfPlane) (hp'_mem : hp' ∈ hpi.halfPlanes) (hne : hp' ≠ hp_q) :
    hp'.dot q > 0 := by
  have h_nonneg := boundary_dot_nonneg hq_bdy hp' hp'_mem
  rcases eq_or_lt_of_le h_nonneg with heq | hlt
  · exfalso
    exact crossing_on_two_hps_is_vertex hq_seg avoids_vertices hp'_mem hp_q_mem hne heq.symm hq_on
  · exact hlt

-- ============================================================================
-- Helper: dot product at a crossing point must be non-degenerate
-- ============================================================================

/-- If hp.dot p1 = 0 and there's a crossing at q on hp, derive contradiction
    (because hp.dot must also be 0 at p2, giving degenerate case). -/
private lemma crossing_hp_nondegenerate
    (hpi : HalfPlaneIntersection) (seg : LineSegment) (hp : HalfPlane)
    (hpm : hp ∈ hpi.halfPlanes)
    (hp1_not_boundary : seg.p1 ∉ hpi.toBoundarySet)
    (avoids_vertices : ∀ q ∈ seg.toSet, q ∉ hpi.toVertexSet)
    (q : Vector2D) (hq_seg : q ∈ seg.toSet) (hq_hp : hp.dot q = 0)
    (hq_bdy : q ∈ hpi.toBoundarySet)
    (hd1 : hp.dot seg.p1 = 0) : False := by
  have hd2 : hp.dot seg.p2 = 0 := by
    obtain ⟨t, ht0, ht1, hx, hy⟩ := hq_seg
    have hlin := hp.dot_segment seg q t ht0 ht1 hx hy
    rw [hq_hp, hd1] at hlin
    have : t * hp.dot seg.p2 = 0 := by linarith
    rcases mul_eq_zero.mp this with ht0' | hd2
    · have : q = seg.p1 := by
        have hx' : q.x = seg.p1.x := by rw [hx, ht0']; ring
        have hy' : q.y = seg.p1.y := by rw [hy, ht0']; ring
        exact (Vector2D.mk.injEq _ _ _ _).mpr ⟨hx', hy'⟩
      rw [this] at hq_bdy; exact absurd hq_bdy hp1_not_boundary
    · exact hd2
  exact hp.degenerate_no_crossings hpi seg hpm hd1 hd2 hp1_not_boundary avoids_vertices
    q hq_seg hq_hp hq_bdy

-- ============================================================================
-- Crossing parameter: d1/(d1-d2) when d1 > 0, d2 < 0
-- ============================================================================

private lemma crossing_param_neg_pos_range (d1 d2 : ℚ) (h1 : d1 < 0) (h2 : d2 > 0) :
    0 < (-d1) / (d2 - d1) ∧ (-d1) / (d2 - d1) ≤ 1 := by
  have hd : d2 - d1 > 0 := by linarith
  exact ⟨div_pos (by linarith) hd, by rw [div_le_one hd]; linarith⟩

private lemma crossing_param_neg_pos_dot_zero (d1 d2 : ℚ) (h1 : d1 < 0) (h2 : d2 > 0) :
    (1 - (-d1) / (d2 - d1)) * d1 + (-d1) / (d2 - d1) * d2 = 0 := by
  have hd : d2 - d1 > 0 := by linarith
  have : (-d1) / (d2 - d1) * (d2 - d1) = -d1 := div_mul_cancel₀ (-d1) (ne_of_gt hd)
  nlinarith

private lemma dot_neg_after_crossing (d1 d2 : ℚ) (h1 : d1 < 0) (h2 : d2 > 0)
    (s : ℚ) (hs_gt : (-d1) / (d2 - d1) < s) (_hs1 : s ≤ 1) :
    (1 - s) * d1 + s * d2 > 0 := by
  have hd : d2 - d1 > 0 := by linarith
  have : (-d1) / (d2 - d1) * (d2 - d1) < s * (d2 - d1) := by
    exact mul_lt_mul_of_pos_right hs_gt hd
  have : -d1 < s * (d2 - d1) := by
    rwa [div_mul_cancel₀ (-d1) (ne_of_gt hd)] at this
  nlinarith

-- ============================================================================
-- Both exterior, card ≠ 1: the key combinatorial lemma
-- ============================================================================

set_option maxHeartbeats 800000 in
/-- When both endpoints are exterior, the number of boundary crossings cannot be 1.

The proof works by case split on the sign of hp_q.dot p2:
- If hp_q.dot p2 ≥ 0: Apply minimum-parameter technique from q1 towards p2.
  All "bad" HPs (dot q1 > 0, dot p2 < 0) have their zeros after q1, and hp_q.dot
  stays ≥ 0 on [t_q, 1], so the minimum zero gives a second boundary crossing.
- If hp_q.dot p2 < 0: Then hp_q.dot p1 > 0. Apply maximum-parameter technique
  from q1 towards p1, finding a second crossing before q1. -/
private lemma both_exterior_card_ne_one
    (hpi : HalfPlaneIntersection) (seg : LineSegment)
    (hp1_not_boundary : seg.p1 ∉ hpi.toBoundarySet)
    (hp2_not_boundary : seg.p2 ∉ hpi.toBoundarySet)
    (avoids_vertices : ∀ q ∈ seg.toSet, q ∉ hpi.toVertexSet)
    (h1_ext : seg.p1 ∈ hpi.toExteriorSet)
    (h2_ext : seg.p2 ∈ hpi.toExteriorSet)
    (hfin : (seg.boundaryCrossings hpi).Finite) :
    hfin.toFinset.card ≠ 1 := by
  intro hcard
  -- Extract the unique crossing q1
  obtain ⟨q1, hq1_eq⟩ := Finset.card_eq_one.mp hcard
  have hq1_mem : q1 ∈ hfin.toFinset := by rw [hq1_eq]; exact Finset.mem_singleton_self _
  have hq1_cross : q1 ∈ seg.boundaryCrossings hpi := hfin.mem_toFinset.mp hq1_mem
  obtain ⟨hq1_seg, hq1_bdy⟩ := hq1_cross
  obtain ⟨⟨hp_q, hp_q_mem, (hq1_on_hpq : hp_q.dot q1 = 0)⟩, hq1_not_ext⟩ := hq1_bdy
  have hq1_bdy : q1 ∈ hpi.toBoundarySet := ⟨⟨hp_q, hp_q_mem, hq1_on_hpq⟩, hq1_not_ext⟩
  -- Any boundary crossing must equal q1
  have hq1_unique : ∀ q ∈ seg.boundaryCrossings hpi, q = q1 := by
    intro q hq
    have hq_fin : q ∈ hfin.toFinset := hfin.mem_toFinset.mpr hq
    rw [hq1_eq] at hq_fin; exact Finset.mem_singleton.mp hq_fin
  -- At q1, every HP other than hp_q has dot > 0
  have hq1_other_pos : ∀ hp' ∈ hpi.halfPlanes, hp' ≠ hp_q → hp'.dot q1 > 0 :=
    fun hp' hm hne => boundary_crossing_other_hp_pos hq1_seg hq1_bdy avoids_vertices
      hp_q_mem hq1_on_hpq hp' hm hne
  -- q1 has a parameter t_q ∈ (0, 1) on the segment
  obtain ⟨t_q, ht_q0, ht_q1, hx_q, hy_q⟩ := hq1_seg
  -- For every HP, hp.dot at parameter t = (1-t)*d1 + t*d2
  -- hp.dot q1 = (1-t_q)*d1 + t_q*d2
  -- Case split on hp_q.dot p2
  by_cases hpq_p2 : hp_q.dot seg.p2 ≥ 0
  · -- Case 1: hp_q.dot p2 ≥ 0
    -- hp_q.dot goes from 0 at q1 to ≥ 0 at p2, so ≥ 0 on [t_q, 1]
    -- Collect bad HPs: dot q1 > 0 and dot p2 < 0
    obtain ⟨hp_b, hp_b_mem, (hp_b_ext_p2 : hp_b.dot seg.p2 < 0)⟩ := h2_ext
    -- hp_b ≠ hp_q (since hp_q.dot p2 ≥ 0 but hp_b.dot p2 < 0)
    have hb_ne_q : hp_b ≠ hp_q := by intro heq; rw [heq] at hp_b_ext_p2; linarith
    -- hp_b.dot q1 > 0
    have hb_q1_pos : hp_b.dot q1 > 0 := hq1_other_pos hp_b hp_b_mem hb_ne_q
    -- Minimum-parameter technique on subsegment q1 → p2
    -- Use "bad" = HPs with dot p2 < 0 (all of which have dot q1 > 0)
    let is_bad (hp : HalfPlane) : Bool := decide (hp.dot seg.p2 < 0)
    set bad_hps := hpi.halfPlanes.filter (fun hp => is_bad hp) with hbad_def
    have hp_b_in_bad : hp_b ∈ bad_hps := by
      simp only [bad_hps, is_bad, List.mem_filter, decide_eq_true_eq]
      exact ⟨hp_b_mem, hp_b_ext_p2⟩
    have bad_ne : bad_hps ≠ [] := List.ne_nil_of_mem hp_b_in_bad
    have bad_in_hps : ∀ hp ∈ bad_hps, hp ∈ hpi.halfPlanes :=
      fun hp hm => (List.mem_filter.mp hm).1
    have bad_neg : ∀ hp ∈ bad_hps, hp.dot seg.p2 < 0 := by
      intro hp hm; have := (List.mem_filter.mp hm).2
      simp only [is_bad, decide_eq_true_eq] at this; exact this
    -- Every bad HP has dot q1 > 0 (it's ≠ hp_q since hp_q.dot p2 ≥ 0)
    have bad_q1_pos : ∀ hp ∈ bad_hps, hp.dot q1 > 0 := by
      intro hp hm
      have hp_neg := bad_neg hp hm
      have hp_ne_q : hp ≠ hp_q := by intro heq; rw [heq] at hp_neg; linarith
      exact hq1_other_pos hp (bad_in_hps hp hm) hp_ne_q
    -- Every bad HP has dot p1 > 0 (dot q1 > 0 and dot p2 < 0, unique zero at d1/(d1-d2))
    -- Actually we need dot at the endpoint of the seg, not q1. The dot is linear:
    -- hp.dot q1 = (1-t_q)*hp.dot p1 + t_q*hp.dot p2 > 0
    -- hp.dot p2 < 0
    -- Need hp.dot p1 sign: from (1-t_q)*d1 + t_q*d2 > 0 and d2 < 0,
    -- if t_q < 1, then d1 > 0 is forced (otherwise (1-t_q)*d1 ≤ 0 and t_q*d2 < 0, sum ≤ t_q*d2 < 0).
    -- If t_q = 1, then q1 = p2, and hp.dot p2 = hp.dot q1 = 0 by boundary, but hp.dot q1 > 0. Contradiction.
    have bad_p1_pos : ∀ hp ∈ bad_hps, hp.dot seg.p1 > 0 := by
      intro hp hm
      have hq1_pos := bad_q1_pos hp hm
      have hp_neg := bad_neg hp hm
      have hlin := hp.dot_segment seg q1 t_q ht_q0 ht_q1 hx_q hy_q
      -- hlin: hp.dot q1 = (1-t_q)*d1 + t_q*d2
      by_contra h; push_neg at h
      have h1 : (1 - t_q) * hp.dot seg.p1 ≤ 0 :=
        mul_nonpos_of_nonneg_of_nonpos (by linarith) h
      have h2 : t_q * hp.dot seg.p2 ≤ 0 := mul_nonpos_of_nonneg_of_nonpos ht_q0 (le_of_lt hp_neg)
      linarith
    -- Map bad HPs to crossing parameters
    let param (hp : HalfPlane) : ℚ := hp.dot seg.p1 / (hp.dot seg.p1 - hp.dot seg.p2)
    set params := bad_hps.map param
    have params_ne : params ≠ [] := by
      intro h; exact bad_ne (List.map_eq_nil_iff.mp h)
    -- Find the minimum parameter
    obtain ⟨t_min, ht_min_mem, ht_min_le⟩ := list_exists_min params_ne
    obtain ⟨hp_min, hp_min_mem, ht_min_eq⟩ := List.mem_map.mp ht_min_mem
    have hp_min_pos : hp_min.dot seg.p1 > 0 := bad_p1_pos hp_min hp_min_mem
    have hp_min_neg : hp_min.dot seg.p2 < 0 := bad_neg hp_min hp_min_mem
    have ht_range := crossing_param_range _ _ hp_min_pos hp_min_neg
    have ht_pos : 0 < t_min := ht_min_eq ▸ ht_range.1
    have ht_le1 : t_min ≤ 1 := ht_min_eq ▸ ht_range.2
    -- The crossing point q2
    set q2 : Vector2D := ⟨(1 - t_min) * seg.p1.x + t_min * seg.p2.x,
                           (1 - t_min) * seg.p1.y + t_min * seg.p2.y⟩
    have hq2_seg : q2 ∈ seg.toSet := ⟨t_min, le_of_lt ht_pos, ht_le1, rfl, rfl⟩
    -- hp_min.dot q2 = 0
    have hq2_on_min : hp_min.dot q2 = 0 := by
      have hlin := hp_min.dot_segment seg q2 t_min (le_of_lt ht_pos) ht_le1 rfl rfl
      rw [hlin, ← ht_min_eq]; exact crossing_param_dot_zero _ _ hp_min_pos hp_min_neg
    -- All HPs have dot q2 ≥ 0 (same argument as interior_exterior_crossing)
    have hq2_not_ext : ∀ hp' ∈ hpi.halfPlanes, ¬(hp'.dot q2 < 0) := by
      intro hp' hp'_mem hq2_neg
      have hlin := hp'.dot_segment seg q2 t_min (le_of_lt ht_pos) ht_le1 rfl rfl
      -- hp'.dot q2 = (1-t_min)*hp'.dot p1 + t_min*hp'.dot p2
      -- If hp'.dot p2 ≥ 0:
      have hp'_neg_p2 : hp'.dot seg.p2 < 0 := by
        by_contra hd2_nonneg; push_neg at hd2_nonneg
        -- (1-t_min)*d1 + t_min*d2 < 0 but d2 ≥ 0 and t_min ∈ (0,1]
        -- If d1 ≥ 0: both terms nonneg, sum ≥ 0. Contradiction.
        -- If d1 < 0: dot is linear, goes from d1 to d2 ≥ 0, zero at t0 = -d1/(d2-d1).
        --   dot at q1 (param t_q) ≥ 0 (boundary). So t_q ≥ t0 or dot=0 at t_q.
        --   dot at t_min: We need to know t_min vs t0.
        by_cases hd1_nonneg : hp'.dot seg.p1 ≥ 0
        · -- Both d1 ≥ 0 and d2 ≥ 0: dot ≥ 0 everywhere on [0,1]
          have h1 : (1 - t_min) * hp'.dot seg.p1 ≥ 0 :=
            mul_nonneg (by linarith) hd1_nonneg
          have h2 : t_min * hp'.dot seg.p2 ≥ 0 :=
            mul_nonneg (le_of_lt ht_pos) hd2_nonneg
          linarith
        · -- d1 < 0 and d2 ≥ 0
          push_neg at hd1_nonneg
          -- dot is linear: d1*(1-t) + d2*t. Zero at t0 = -d1/(d2-d1).
          -- If d2 = 0: dot = d1*(1-t) which is ≤ 0 for all t ∈ [0,1]. Then dot q1 ≤ 0.
          --   But dot q1 ≥ 0 (boundary), so dot q1 = 0. Then hp' is on boundary at q1.
          --   Also hp_q.dot q1 = 0. If hp' ≠ hp_q, vertex contradiction.
          --   If hp' = hp_q, then hp_q.dot p1 < 0 but we know hp_q.dot p2 ≥ 0.
          --   hp_q.dot q1 = 0 = (1-t_q)*hp_q.dot p1 + t_q*hp_q.dot p2.
          --   hp_q.dot q2 = (1-t_min)*hp_q.dot p1 + t_min*hp_q.dot p2.
          --   From the zero at q1: t_q = (-d1)/(d2-d1) where d1=hp_q.dot p1, d2=hp_q.dot p2.
          --   Actually with d2=0: dot at t = d1*(1-t), always ≤ 0 for t ∈ [0,1], and =0 only at t=1.
          --   So dot q1 = 0 → t_q = 1 → q1 = p2.
          --   Then p2 is on HPI boundary. Contradiction with hp2_not_boundary.
          by_cases hd2_zero : hp'.dot seg.p2 = 0
          · -- d2 = 0, d1 < 0: dot at t = d1*(1-t) ≤ 0.
            -- dot q1 ≥ 0 (boundary) means (1-t_q)*d1 + t_q*0 = (1-t_q)*d1 ≥ 0.
            -- Since d1 < 0: 1 - t_q ≤ 0, so t_q ≥ 1. But t_q ≤ 1, so t_q = 1.
            have hlin_q1 := hp'.dot_segment seg q1 t_q ht_q0 ht_q1 hx_q hy_q
            have hq1_nonneg := boundary_dot_nonneg hq1_bdy hp' hp'_mem
            rw [hd2_zero] at hlin_q1
            have : (1 - t_q) * hp'.dot seg.p1 ≥ 0 := by linarith
            have : 1 - t_q ≤ 0 := by
              by_contra h; push_neg at h
              have := mul_pos h (by linarith : -hp'.dot seg.p1 > 0)
              nlinarith
            have htq1 : t_q = 1 := by linarith
            have : q1 = seg.p2 := by
              have hx' : q1.x = seg.p2.x := by rw [hx_q, htq1]; ring
              have hy' : q1.y = seg.p2.y := by rw [hy_q, htq1]; ring
              exact (Vector2D.mk.injEq _ _ _ _).mpr ⟨hx', hy'⟩
            rw [this] at hq1_bdy; exact hp2_not_boundary hq1_bdy
          · -- d2 > 0 (d2 ≥ 0 and d2 ≠ 0)
            have hd2_pos : hp'.dot seg.p2 > 0 := lt_of_le_of_ne hd2_nonneg (Ne.symm hd2_zero)
            -- Zero at t0 = (-d1)/(d2-d1). For t ≥ t0, dot ≥ 0.
            -- dot q1 = (1-t_q)*d1 + t_q*d2 ≥ 0 (boundary).
            -- We need: dot q2 = (1-t_min)*d1 + t_min*d2 ≥ 0.
            -- Since d1 < 0, d2 > 0: zero at t0 = -d1/(d2-d1) ∈ (0,1).
            -- For t ≥ t0: dot ≥ 0.
            -- We know dot q1 ≥ 0, so t_q ≥ t0.
            -- Need t_min ≥ t0. Since d1 < 0 and d2 > 0, param = d1/(d1-d2) = d1/(d1-d2).
            -- Wait, hp' is NOT a bad HP (it has d2 ≥ 0, not < 0).
            -- We're trying to show dot at t_min ≥ 0 for a non-bad HP.
            -- The dot at param t is: (1-t)*d1 + t*d2 = d1 + t*(d2-d1).
            -- This is ≥ 0 iff t ≥ -d1/(d2-d1) = t0.
            -- dot at q1 ≥ 0 means t_q ≥ t0.
            -- But t_min could be < t_q! (t_min is min zero of BAD HPs, could be before q1.)
            -- However: actually bad_p1_pos says bad HPs have d1 > 0.
            -- Their zero is at d1/(d1-d2) > 0 (since d1 > 0, d2 < 0).
            -- And q1's HP hp_q has zero at t_q. hp_q.dot p1 unknown in Case 1 (hp_q.dot p2 ≥ 0).
            -- Actually wait: in Case 1, hp_q.dot q1 = 0, and hp_q.dot p2 ≥ 0.
            -- We need: does t_min ≥ t_q or t_min < t_q?
            -- hp_q is NOT bad (hp_q.dot p2 ≥ 0, not < 0). So t_min is min zero of bad HPs.
            -- Bad HPs all have d1 > 0, d2 < 0. Their zeros are at d1/(d1-d2) ∈ (0,1].
            -- At t=0, all bad HPs have dot = d1 > 0. At their zero, dot = 0.
            -- At t_q: all bad HPs have dot q1 > 0 (since they ≠ hp_q).
            -- So their zero must be > t_q (dot is positive at t_q, zero at their param > t_q).
            -- Therefore t_min > t_q ≥ t0. So dot at t_min ≥ 0.
            -- Actually let me verify: bad HP param = d1/(d1-d2), and dot at t_q > 0.
            -- dot at t_q = (1-t_q)*d1 + t_q*d2 > 0.
            -- dot at param = 0.
            -- dot is linear, positive at t_q and zero at param.
            -- Since d2 < 0: for large t, dot → d2 < 0. So param > t_q.
            -- Therefore t_min ≥ min of params > t_q ≥ t0.
            -- Now for this non-bad HP hp': d1 < 0, d2 > 0, zero at t0 = -d1/(d2-d1).
            -- t_min > t_q ≥ t0 → dot at t_min ≥ 0. Contradiction.
            -- Let me formalize: we need t_min > t_q.
            -- All bad HP zeros > t_q:
            have bad_zeros_gt_tq : ∀ hp'' ∈ bad_hps, param hp'' > t_q := by
              intro hp'' hm
              have hp''_pos := bad_p1_pos hp'' hm
              have hp''_neg := bad_neg hp'' hm
              have hp''_q1_pos := bad_q1_pos hp'' hm
              have hlin'' := hp''.dot_segment seg q1 t_q ht_q0 ht_q1 hx_q hy_q
              -- dot q1 = (1-t_q)*d1'' + t_q*d2'' > 0
              -- param hp'' = d1''/(d1''-d2'')
              -- dot at param = 0
              -- dot is linear and decreasing (d1'' > 0, d2'' < 0, so d2''-d1'' < 0).
              -- dot(t_q) > 0, dot(param) = 0 → param > t_q
              show hp''.dot seg.p1 / (hp''.dot seg.p1 - hp''.dot seg.p2) > t_q
              rw [gt_iff_lt, lt_div_iff₀ (by linarith : hp''.dot seg.p1 - hp''.dot seg.p2 > 0)]
              nlinarith
            have htmin_gt_tq : t_min > t_q := by
              have := bad_zeros_gt_tq hp_min hp_min_mem
              linarith [ht_min_eq]
            -- Now: t_min > t_q ≥ t0 = -d1/(d2-d1) for hp'
            have hd_diff : hp'.dot seg.p2 - hp'.dot seg.p1 > 0 := by linarith
            have t0_le_tq : (-hp'.dot seg.p1) / (hp'.dot seg.p2 - hp'.dot seg.p1) ≤ t_q := by
              rw [div_le_iff₀ hd_diff]
              nlinarith [boundary_dot_nonneg hq1_bdy hp' hp'_mem,
                         hp'.dot_segment seg q1 t_q ht_q0 ht_q1 hx_q hy_q]
            -- dot at t_min = d1 + t_min*(d2-d1) = (1-t_min)*d1 + t_min*d2
            -- = d1 + t_min*(d2-d1) ≥ d1 + t0*(d2-d1) = d1 + (-d1) = 0
            -- since t_min > t_q ≥ t0 and d2-d1 > 0
            have : (1 - t_min) * hp'.dot seg.p1 + t_min * hp'.dot seg.p2 ≥ 0 := by
              have : t_min * (hp'.dot seg.p2 - hp'.dot seg.p1) ≥
                     (-hp'.dot seg.p1) / (hp'.dot seg.p2 - hp'.dot seg.p1) *
                     (hp'.dot seg.p2 - hp'.dot seg.p1) := by
                apply mul_le_mul_of_nonneg_right _ (le_of_lt hd_diff)
                linarith
              have : (-hp'.dot seg.p1) / (hp'.dot seg.p2 - hp'.dot seg.p1) *
                     (hp'.dot seg.p2 - hp'.dot seg.p1) = -hp'.dot seg.p1 :=
                div_mul_cancel₀ _ (ne_of_gt hd_diff)
              nlinarith
            linarith
      -- So hp' ∈ bad_hps
      have hp'_in_bad : hp' ∈ bad_hps := by
        simp only [bad_hps, is_bad, List.mem_filter, decide_eq_true_eq]
        exact ⟨hp'_mem, hp'_neg_p2⟩
      -- hp'.dot p1 > 0 (since hp' is bad)
      have hp'_pos := bad_p1_pos hp' hp'_in_bad
      -- param hp' ≥ t_min
      have h_le : t_min ≤ param hp' := by
        apply ht_min_le; exact List.mem_map.mpr ⟨hp', hp'_in_bad, rfl⟩
      rcases lt_or_eq_of_le h_le with h_lt | h_eq
      · have := dot_pos_before_crossing _ _ hp'_pos hp'_neg_p2 t_min (le_of_lt ht_pos) h_lt
        linarith
      · have : (1 - t_min) * hp'.dot seg.p1 + t_min * hp'.dot seg.p2 = 0 := by
          rw [h_eq]; exact crossing_param_dot_zero _ _ hp'_pos hp'_neg_p2
        linarith
    -- q2 is a boundary crossing
    have hq2_bdy : q2 ∈ hpi.toBoundarySet :=
      ⟨⟨hp_min, bad_in_hps hp_min hp_min_mem, hq2_on_min⟩, hq2_not_ext⟩
    have hq2_cross : q2 ∈ seg.boundaryCrossings hpi := ⟨hq2_seg, hq2_bdy⟩
    -- q2 must equal q1
    have hq2_eq_q1 := hq1_unique q2 hq2_cross
    -- But hp_min.dot q1 > 0 ≠ 0 = hp_min.dot q2
    have : hp_min.dot q1 > 0 := bad_q1_pos hp_min hp_min_mem
    rw [hq2_eq_q1] at hq2_on_min
    linarith
  · -- Case 2: hp_q.dot p2 < 0
    push_neg at hpq_p2
    -- hp_q.dot q1 = 0 and hp_q.dot p2 < 0. Since dot is linear:
    -- (1-t_q)*hp_q.dot p1 + t_q*hp_q.dot p2 = 0
    -- With hp_q.dot p2 < 0, we need hp_q.dot p1 > 0 (otherwise sum ≤ 0, can't be 0 with t_q*d2 < 0)
    have hpq_p1_pos : hp_q.dot seg.p1 > 0 := by
      have hlin := hp_q.dot_segment seg q1 t_q ht_q0 ht_q1 hx_q hy_q
      rw [hq1_on_hpq] at hlin
      by_contra h; push_neg at h
      have h1 : (1 - t_q) * hp_q.dot seg.p1 ≤ 0 :=
        mul_nonpos_of_nonneg_of_nonpos (by linarith) h
      have h2 : t_q * hp_q.dot seg.p2 ≤ 0 := mul_nonpos_of_nonneg_of_nonpos ht_q0 (le_of_lt hpq_p2)
      -- 0 = h1 + h2 where both ≤ 0 → both = 0
      have heq1 : (1 - t_q) * hp_q.dot seg.p1 = 0 := by linarith
      have heq2 : t_q * hp_q.dot seg.p2 = 0 := by linarith
      -- t_q * d2 = 0 and d2 < 0 → t_q = 0
      rcases mul_eq_zero.mp heq2 with htq0 | hd20
      · -- t_q = 0, so q1 = p1, contradicting hp1_not_boundary
        have : q1 = seg.p1 := by
          have hx' : q1.x = seg.p1.x := by rw [hx_q, htq0]; ring
          have hy' : q1.y = seg.p1.y := by rw [hy_q, htq0]; ring
          exact (Vector2D.mk.injEq _ _ _ _).mpr ⟨hx', hy'⟩
        rw [this] at hq1_bdy; exact hp1_not_boundary hq1_bdy
      · linarith
    -- Since p1 exterior: ∃ hp_a with hp_a.dot p1 < 0
    obtain ⟨hp_a, hp_a_mem, (hp_a_ext_p1 : hp_a.dot seg.p1 < 0)⟩ := h1_ext
    -- hp_a ≠ hp_q (since hp_q.dot p1 > 0)
    have ha_ne_q : hp_a ≠ hp_q := by intro heq; rw [heq] at hp_a_ext_p1; linarith
    -- hp_a.dot q1 > 0
    have ha_q1_pos : hp_a.dot q1 > 0 := hq1_other_pos hp_a hp_a_mem ha_ne_q
    -- Use maximum-parameter technique from p1 towards q1
    -- Bad HPs: dot p1 < 0 (they all have dot q1 > 0 by vertex avoidance)
    let is_bad_a (hp : HalfPlane) : Bool := decide (hp.dot seg.p1 < 0)
    set bad_hps_a := hpi.halfPlanes.filter (fun hp => is_bad_a hp) with hbad_a_def
    have hp_a_in_bad : hp_a ∈ bad_hps_a := by
      simp only [bad_hps_a, is_bad_a, List.mem_filter, decide_eq_true_eq]
      exact ⟨hp_a_mem, hp_a_ext_p1⟩
    have bad_a_ne : bad_hps_a ≠ [] := List.ne_nil_of_mem hp_a_in_bad
    have bad_a_in_hps : ∀ hp ∈ bad_hps_a, hp ∈ hpi.halfPlanes :=
      fun hp hm => (List.mem_filter.mp hm).1
    have bad_a_neg : ∀ hp ∈ bad_hps_a, hp.dot seg.p1 < 0 := by
      intro hp hm; have := (List.mem_filter.mp hm).2
      simp only [is_bad_a, decide_eq_true_eq] at this; exact this
    -- Every bad_a HP has hp ≠ hp_q and dot q1 > 0
    have bad_a_ne_q : ∀ hp ∈ bad_hps_a, hp ≠ hp_q := by
      intro hp hm heq; have := bad_a_neg hp hm; rw [heq] at this; linarith
    have bad_a_q1_pos : ∀ hp ∈ bad_hps_a, hp.dot q1 > 0 := by
      intro hp hm; exact hq1_other_pos hp (bad_a_in_hps hp hm) (bad_a_ne_q hp hm)
    -- Every bad_a HP has dot p2 > 0 (deduced from dot p1 < 0 and dot q1 > 0)
    -- Actually we don't know this; d2 could be anything. But we need the zero parameter.
    -- For bad_a HP: d1 < 0, dot at q1 = (1-t_q)*d1 + t_q*d2 > 0.
    -- The zero is at t_zero = (-d1)/(d2-d1) ∈ (0, t_q].
    -- Actually the zero exists because dot goes from d1 < 0 at t=0 to > 0 at t=t_q.
    -- We need d2 - d1 > 0 for the parameter formula.
    -- From (1-t_q)*d1 + t_q*d2 > 0 and d1 < 0:
    --   t_q*d2 > -(1-t_q)*d1 = (1-t_q)*(-d1) ≥ 0
    --   So d2 > 0 (when t_q > 0) or we need to handle t_q = 0.
    -- If t_q = 0: q1 = p1 (at parameter 0). But p1 not on HPI boundary, q1 is. Contradiction.
    have ht_q_pos : t_q > 0 := by
      by_contra h; push_neg at h
      have h0 : t_q = 0 := le_antisymm h ht_q0
      have : q1 = seg.p1 := by
        have hx' : q1.x = seg.p1.x := by rw [hx_q, h0]; ring
        have hy' : q1.y = seg.p1.y := by rw [hy_q, h0]; ring
        exact (Vector2D.mk.injEq _ _ _ _).mpr ⟨hx', hy'⟩
      rw [this] at hq1_bdy; exact hp1_not_boundary hq1_bdy
    have bad_a_p2_pos : ∀ hp ∈ bad_hps_a, hp.dot seg.p2 > 0 := by
      intro hp hm
      have hd1 := bad_a_neg hp hm
      have hd_q1 := bad_a_q1_pos hp hm
      have hlin := hp.dot_segment seg q1 t_q ht_q0 ht_q1 hx_q hy_q
      -- (1-t_q)*d1 + t_q*d2 = hp.dot q1 > 0 and d1 < 0 and t_q > 0
      -- t_q * d2 > -(1-t_q)*d1 ≥ 0, so t_q * d2 > 0, and t_q > 0 gives d2 > 0
      have h1 : (1 - t_q) * hp.dot seg.p1 ≤ 0 :=
        mul_nonpos_of_nonneg_of_nonpos (by linarith) (le_of_lt hd1)
      have h2 : t_q * hp.dot seg.p2 > 0 := by linarith
      exact (mul_pos_iff.mp h2).elim (fun ⟨_, h⟩ => h) (fun ⟨h1, _⟩ => by linarith)
    -- Map bad_a HPs to crossing parameters (zero of hp.dot on segment, using neg-pos formula)
    let param_a (hp : HalfPlane) : ℚ := (-hp.dot seg.p1) / (hp.dot seg.p2 - hp.dot seg.p1)
    set params_a := bad_hps_a.map param_a
    have params_a_ne : params_a ≠ [] := by
      intro h; exact bad_a_ne (List.map_eq_nil_iff.mp h)
    -- Find the maximum parameter (closest to q1 from the left)
    obtain ⟨t_max, ht_max_mem, ht_max_ge⟩ := list_exists_max params_a_ne
    obtain ⟨hp_max, hp_max_mem, ht_max_eq⟩ := List.mem_map.mp ht_max_mem
    have hp_max_neg : hp_max.dot seg.p1 < 0 := bad_a_neg hp_max hp_max_mem
    have hp_max_pos : hp_max.dot seg.p2 > 0 := bad_a_p2_pos hp_max hp_max_mem
    have ht_a_range := crossing_param_neg_pos_range _ _ hp_max_neg hp_max_pos
    have ht_a_pos : 0 < t_max := ht_max_eq ▸ ht_a_range.1
    have ht_a_le1 : t_max ≤ 1 := ht_max_eq ▸ ht_a_range.2
    -- The crossing point q2
    set q2 : Vector2D := ⟨(1 - t_max) * seg.p1.x + t_max * seg.p2.x,
                           (1 - t_max) * seg.p1.y + t_max * seg.p2.y⟩
    have hq2_seg : q2 ∈ seg.toSet := ⟨t_max, le_of_lt ht_a_pos, ht_a_le1, rfl, rfl⟩
    -- hp_max.dot q2 = 0
    have hq2_on_max : hp_max.dot q2 = 0 := by
      have hlin := hp_max.dot_segment seg q2 t_max (le_of_lt ht_a_pos) ht_a_le1 rfl rfl
      rw [hlin, ← ht_max_eq]
      exact crossing_param_neg_pos_dot_zero _ _ hp_max_neg hp_max_pos
    -- All HPs have dot q2 ≥ 0
    have hq2_not_ext : ∀ hp' ∈ hpi.halfPlanes, ¬(hp'.dot q2 < 0) := by
      intro hp' hp'_mem hq2_neg
      have hlin := hp'.dot_segment seg q2 t_max (le_of_lt ht_a_pos) ht_a_le1 rfl rfl
      -- hp'.dot q2 = (1-t_max)*d1' + t_max*d2'
      -- Need to show d1' < 0
      have hp'_neg_p1 : hp'.dot seg.p1 < 0 := by
        by_contra hd1_nonneg; push_neg at hd1_nonneg
        -- d1 ≥ 0. Need d2 sign.
        by_cases hd2_nonneg : hp'.dot seg.p2 ≥ 0
        · -- d1 ≥ 0, d2 ≥ 0: dot ≥ 0 everywhere. Contradiction.
          have h1 : (1 - t_max) * hp'.dot seg.p1 ≥ 0 :=
            mul_nonneg (by linarith) hd1_nonneg
          have h2 : t_max * hp'.dot seg.p2 ≥ 0 :=
            mul_nonneg (le_of_lt ht_a_pos) hd2_nonneg
          linarith
        · push_neg at hd2_nonneg
          -- d1 ≥ 0 and d2 < 0. dot goes from d1 ≥ 0 to d2 < 0.
          -- Zero at t0 = d1/(d1-d2). For t < t0, dot > 0 (or ≥ 0 if d1 = 0).
          -- dot at q1 ≥ 0 (boundary), meaning t_q ≤ t0 (or d1=0 edge).
          -- dot at t_max: need t_max ≤ t0.
          -- All bad_a zeros < t_q (since bad_a HPs have d1 < 0, d2 > 0, zero is before q1).
          -- So t_max < t_q ≤ t0. Hence dot at t_max ≥ 0. Contradiction.
          -- Actually wait: we need to prove bad_a zeros < t_q.
          -- For bad_a HP hp'': d1'' < 0, d2'' > 0, zero at (-d1'')/(d2''-d1'') = param_a hp''.
          -- dot at q1 = (1-t_q)*d1'' + t_q*d2'' > 0 (since hp'' ≠ hp_q).
          -- Since d1'' < 0 and d2'' > 0, dot at param_a = 0. Dot is increasing on [0,1].
          -- For t > param_a, dot > 0. So dot at t_q > 0 means t_q > param_a, or t_q = param_a
          -- gives dot = 0, but dot > 0. So t_q > param_a.
          -- Therefore t_max ≤ max of param_a's < t_q.
          -- Actually we need all param_a < t_q, hence their max < t_q.
          have bad_a_zeros_lt_tq : ∀ hp'' ∈ bad_hps_a, param_a hp'' < t_q := by
            intro hp'' hm
            have hp''_neg := bad_a_neg hp'' hm
            have hp''_pos := bad_a_p2_pos hp'' hm
            have hp''_q1_pos := bad_a_q1_pos hp'' hm
            have hlin'' := hp''.dot_segment seg q1 t_q ht_q0 ht_q1 hx_q hy_q
            show (-hp''.dot seg.p1) / (hp''.dot seg.p2 - hp''.dot seg.p1) < t_q
            rw [div_lt_iff₀ (by linarith : hp''.dot seg.p2 - hp''.dot seg.p1 > 0)]
            nlinarith
          have htmax_lt_tq : t_max < t_q := by
            have := bad_a_zeros_lt_tq hp_max hp_max_mem
            linarith [ht_max_eq]
          -- Now: t_max < t_q. For hp' with d1 ≥ 0, d2 < 0:
          -- dot at q1 ≥ 0 (boundary), so (1-t_q)*d1 + t_q*d2 ≥ 0.
          -- dot decreases from d1 to d2. Zero at d1/(d1-d2).
          -- t_q ≤ d1/(d1-d2) (since dot at t_q ≥ 0).
          -- For d1 = 0: dot at t = t*d2 ≤ 0. dot at q1 ≥ 0 → t_q*d2 ≥ 0 → d2 ≥ 0.
          -- But d2 < 0. Contradiction. So d1 > 0.
          by_cases hd1_pos : hp'.dot seg.p1 = 0
          · -- d1 = 0, d2 < 0: dot at q1 = t_q*d2 ≤ 0. But ≥ 0 from boundary. So t_q*d2 = 0.
            -- t_q > 0 means d2 = 0. But d2 < 0. Contradiction.
            have hlin_q1 := hp'.dot_segment seg q1 t_q ht_q0 ht_q1 hx_q hy_q
            have hq1_nonneg := boundary_dot_nonneg hq1_bdy hp' hp'_mem
            rw [hd1_pos] at hlin_q1; simp at hlin_q1
            have : t_q * hp'.dot seg.p2 ≥ 0 := by linarith
            have : hp'.dot seg.p2 ≥ 0 :=
              (mul_nonneg_iff.mp this).elim (fun ⟨_, h⟩ => h) (fun ⟨h1, _⟩ => by linarith)
            linarith
          · have hd1_strict : hp'.dot seg.p1 > 0 := lt_of_le_of_ne hd1_nonneg (Ne.symm hd1_pos)
            -- dot at t_q ≥ 0 means t_q ≤ d1/(d1-d2)
            -- t_max < t_q ≤ d1/(d1-d2)
            -- dot at t_max = (1-t_max)*d1 + t_max*d2 > 0 (since t_max < zero)
            -- Using dot_pos_before_crossing
            have : t_max < hp'.dot seg.p1 / (hp'.dot seg.p1 - hp'.dot seg.p2) := by
              have hd : hp'.dot seg.p1 - hp'.dot seg.p2 > 0 := by linarith
              have hlin_q1 := hp'.dot_segment seg q1 t_q ht_q0 ht_q1 hx_q hy_q
              have hq1_nonneg := boundary_dot_nonneg hq1_bdy hp' hp'_mem
              -- (1-t_q)*d1 + t_q*d2 ≥ 0
              -- t_q*(d1-d2) ≤ d1 (rearranging)
              have htq_le_param : t_q ≤ hp'.dot seg.p1 / (hp'.dot seg.p1 - hp'.dot seg.p2) := by
                rw [le_div_iff₀ hd]; nlinarith
              linarith
            have := dot_pos_before_crossing _ _ hd1_strict hd2_nonneg t_max
                      (le_of_lt ht_a_pos) this
            linarith
      -- So hp' ∈ bad_hps_a
      have hp'_in_bad : hp' ∈ bad_hps_a := by
        simp only [bad_hps_a, is_bad_a, List.mem_filter, decide_eq_true_eq]
        exact ⟨hp'_mem, hp'_neg_p1⟩
      -- hp'.dot p2 > 0 (since hp' is bad_a)
      have hp'_pos := bad_a_p2_pos hp' hp'_in_bad
      -- param_a hp' ≤ t_max
      have h_le : param_a hp' ≤ t_max := by
        apply ht_max_ge; exact List.mem_map.mpr ⟨hp', hp'_in_bad, rfl⟩
      rcases lt_or_eq_of_le h_le with h_lt | h_eq
      · -- At t_max > param_a hp': dot > 0 (past the zero)
        have := dot_neg_after_crossing _ _ hp'_neg_p1 hp'_pos t_max h_lt ht_a_le1
        linarith
      · have : (1 - t_max) * hp'.dot seg.p1 + t_max * hp'.dot seg.p2 = 0 := by
          rw [← h_eq]; exact crossing_param_neg_pos_dot_zero _ _ hp'_neg_p1 hp'_pos
        linarith
    -- q2 is a boundary crossing
    have hq2_bdy : q2 ∈ hpi.toBoundarySet :=
      ⟨⟨hp_max, bad_a_in_hps hp_max hp_max_mem, hq2_on_max⟩, hq2_not_ext⟩
    have hq2_cross : q2 ∈ seg.boundaryCrossings hpi := ⟨hq2_seg, hq2_bdy⟩
    -- q2 must equal q1
    have hq2_eq_q1 := hq1_unique q2 hq2_cross
    -- But hp_max.dot q1 > 0 ≠ 0 = hp_max.dot q2
    have : hp_max.dot q1 > 0 := bad_a_q1_pos hp_max hp_max_mem
    rw [hq2_eq_q1] at hq2_on_max
    linarith

-- ============================================================================
-- Helper: nonneg dot at both endpoints means nonneg everywhere
-- ============================================================================

private lemma dot_nonneg_on_segment (hp : HalfPlane) (seg : LineSegment)
    (h1 : hp.dot seg.p1 ≥ 0) (h2 : hp.dot seg.p2 ≥ 0)
    (q : Vector2D) (hq : q ∈ seg.toSet) : hp.dot q ≥ 0 := by
  obtain ⟨t, ht0, ht1, hx, hy⟩ := hq
  have hlin := hp.dot_segment seg q t ht0 ht1 hx hy
  have : (1 - t) * hp.dot seg.p1 ≥ 0 := mul_nonneg (by linarith) h1
  have : t * hp.dot seg.p2 ≥ 0 := mul_nonneg ht0 h2
  linarith

-- ============================================================================
-- Helper: if endpoint not on boundary and not interior, then exterior
-- ============================================================================

private lemma not_boundary_not_interior_exterior
    (hpi : HalfPlaneIntersection) (p : Vector2D)
    (h_not_bdy : p ∉ hpi.toBoundarySet) (h_not_int : p ∉ hpi.toInteriorSet) :
    p ∈ hpi.toExteriorSet := by
  have := (hpi.partition_proof).2.2.2
  have hp : p ∈ hpi.toInteriorSet ∪ hpi.toExteriorSet ∪ hpi.toBoundarySet := by
    rw [this]; exact Set.mem_univ _
  rcases hp with (hp | hp) | hp
  · exact absurd hp h_not_int
  · exact hp
  · exact absurd hp h_not_bdy

-- ============================================================================
-- Helper: subsegment boundary/vertex conditions
-- ============================================================================

private lemma subsegment_not_boundary (seg : LineSegment) (hpi : HalfPlaneIntersection)
    (t1 t2 : ℚ) (_ht1_0 : 0 ≤ t1) (_ht2_1 : t2 ≤ 1) (_ht12 : t1 ≤ t2)
    (hp_not_bdy : ∀ q ∈ seg.toSet, q ∈ hpi.toBoundarySet → False)
    -- Relaxed: just say the subseg endpoints are not on boundary
    (p : Vector2D) (_hp_eq : p = (seg.subsegment t1 t2).p1 ∨ p = (seg.subsegment t1 t2).p2)
    (hp_on_seg : p ∈ seg.toSet) :
    p ∉ hpi.toBoundarySet :=
  fun hbdy => hp_not_bdy p hp_on_seg hbdy

private lemma subsegment_avoids_vertices (seg : LineSegment)
    (hpi : HalfPlaneIntersection)
    (t1 t2 : ℚ) (ht1_0 : 0 ≤ t1) (ht2_1 : t2 ≤ 1) (ht12 : t1 ≤ t2)
    (avoids : ∀ q ∈ seg.toSet, q ∉ hpi.toVertexSet) :
    ∀ q ∈ (seg.subsegment t1 t2).toSet, q ∉ hpi.toVertexSet :=
  fun q hq => avoids q (subsegment_toSet_subset seg t1 t2 ht1_0 ht2_1 ht12 hq)

-- ============================================================================
-- Helper: subsegment crossings are subset of parent crossings
-- ============================================================================

private lemma subsegment_crossings_subset (seg : LineSegment) (hpi : HalfPlaneIntersection)
    (t1 t2 : ℚ) (ht1_0 : 0 ≤ t1) (ht2_1 : t2 ≤ 1) (ht12 : t1 ≤ t2) :
    (seg.subsegment t1 t2).boundaryCrossings hpi ⊆ seg.boundaryCrossings hpi := by
  intro q ⟨hqs, hqb⟩
  exact ⟨subsegment_toSet_subset seg t1 t2 ht1_0 ht2_1 ht12 hqs, hqb⟩

-- ============================================================================
-- Helper: midpoint of a segment at parameter t
-- ============================================================================

private def seg_at (seg : LineSegment) (t : ℚ) : Vector2D :=
  ⟨(1 - t) * seg.p1.x + t * seg.p2.x, (1 - t) * seg.p1.y + t * seg.p2.y⟩

private lemma seg_at_mem (seg : LineSegment) (t : ℚ) (ht0 : 0 ≤ t) (ht1 : t ≤ 1) :
    seg_at seg t ∈ seg.toSet :=
  ⟨t, ht0, ht1, rfl, rfl⟩

private lemma seg_at_zero (seg : LineSegment) : seg_at seg 0 = seg.p1 := by
  simp only [seg_at]
  cases seg.p1 with | mk x y => exact (Vector2D.mk.injEq _ _ _ _).mpr ⟨by ring, by ring⟩

private lemma seg_at_one (seg : LineSegment) : seg_at seg 1 = seg.p2 := by
  simp only [seg_at]
  cases seg.p2 with | mk x y => exact (Vector2D.mk.injEq _ _ _ _).mpr ⟨by ring, by ring⟩

-- ============================================================================
-- Helper: finding a rational between two with specific properties
-- ============================================================================

/-- Given a < b and a finite set S of rationals, there exists a rational in (a, b)
    not in S. -/
private lemma exists_rat_between_not_in_finset (a b : ℚ) (hab : a < b)
    (S : Finset ℚ) : ∃ t : ℚ, a < t ∧ t < b ∧ t ∉ S := by
  -- Filter S to elements in (a, b)
  set S' := S.filter (fun t => a < t ∧ t < b) with hS'_def
  by_cases hS'_empty : S' = ∅
  · -- No elements of S in (a,b). Use midpoint.
    refine ⟨(a + b) / 2, by linarith, by linarith, ?_⟩
    intro hmem
    have : (a + b) / 2 ∈ S' := by
      rw [Finset.mem_filter]; exact ⟨hmem, by linarith, by linarith⟩
    simp [hS'_empty] at this
  · -- S' is nonempty. Find its min. Use midpoint of a and min.
    have hS'_ne : S'.Nonempty := Finset.nonempty_iff_ne_empty.mpr hS'_empty
    set t_min := S'.min' hS'_ne with ht_min_def
    have ht_min_mem : t_min ∈ S' := Finset.min'_mem S' hS'_ne
    have ht_min_gt_a : a < t_min := ((Finset.mem_filter.mp ht_min_mem).2).1
    have ht_min_lt_b : t_min < b := ((Finset.mem_filter.mp ht_min_mem).2).2
    refine ⟨(a + t_min) / 2, by linarith, by linarith, ?_⟩
    intro hmem
    have h_in_S' : (a + t_min) / 2 ∈ S' := by
      rw [Finset.mem_filter]
      exact ⟨hmem, by linarith, by linarith [((Finset.mem_filter.mp ht_min_mem).2).2]⟩
    have : t_min ≤ (a + t_min) / 2 := Finset.min'_le S' _ h_in_S'
    linarith

-- ============================================================================
-- Helper: point on segment not in a finite set of crossings → not on boundary
-- ============================================================================

/-- If a point on the segment is not equal to any crossing (i.e., not in hfin.toFinset),
    and the point is on the segment, then it's not on the HPI boundary.
    (Because if it were on boundary AND on the segment, it would be a crossing.) -/
private lemma seg_point_not_crossing_not_boundary
    (hpi : HalfPlaneIntersection) (seg : LineSegment)
    (hfin : (seg.boundaryCrossings hpi).Finite)
    (q : Vector2D) (hq_seg : q ∈ seg.toSet) (hq_not_fin : q ∉ hfin.toFinset) :
    q ∉ hpi.toBoundarySet := by
  intro hqb
  exact hq_not_fin (hfin.mem_toFinset.mpr ⟨hq_seg, hqb⟩)

-- ============================================================================
-- Helper: parameter uniqueness implies crossing uniqueness
-- ============================================================================

/-- If p1 ≠ p2 and two crossings have the same parameter, they are equal. -/
private lemma crossing_param_eq_implies_eq
    (seg : LineSegment) (_hne : seg.p1 ≠ seg.p2)
    (q1 q2 : Vector2D)
    (_hq1 : q1 ∈ seg.toSet) (_hq2 : q2 ∈ seg.toSet)
    (t1 t2 : ℚ) (_ht1_0 : 0 ≤ t1) (_ht1_1 : t1 ≤ 1)
    (hx1 : q1.x = (1 - t1) * seg.p1.x + t1 * seg.p2.x)
    (hy1 : q1.y = (1 - t1) * seg.p1.y + t1 * seg.p2.y)
    (_ht2_0 : 0 ≤ t2) (_ht2_1 : t2 ≤ 1)
    (hx2 : q2.x = (1 - t2) * seg.p1.x + t2 * seg.p2.x)
    (hy2 : q2.y = (1 - t2) * seg.p1.y + t2 * seg.p2.y)
    (heq : t1 = t2) : q1 = q2 :=
  (Vector2D.mk.injEq _ _ _ _).mpr ⟨by rw [hx1, hx2, heq], by rw [hy1, hy2, heq]⟩

-- ============================================================================
-- Helper: subsegment endpoint is on parent segment
-- ============================================================================

private lemma subseg_p1_on_seg (seg : LineSegment) (t1 t2 : ℚ)
    (ht1_0 : 0 ≤ t1) (ht1_1 : t1 ≤ 1) :
    (seg.subsegment t1 t2).p1 ∈ seg.toSet :=
  ⟨t1, ht1_0, ht1_1, rfl, rfl⟩

private lemma subseg_p2_on_seg (seg : LineSegment) (t1 t2 : ℚ)
    (ht2_0 : 0 ≤ t2) (ht2_1 : t2 ≤ 1) :
    (seg.subsegment t1 t2).p2 ∈ seg.toSet :=
  ⟨t2, ht2_0, ht2_1, rfl, rfl⟩

-- ============================================================================
-- Helper: subsegment p1 = seg_at t1, subseg p2 = seg_at t2
-- ============================================================================

private lemma subseg_p1_eq (seg : LineSegment) (t1 t2 : ℚ) :
    (seg.subsegment t1 t2).p1 = seg_at seg t1 := rfl

private lemma subseg_p2_eq (seg : LineSegment) (t1 t2 : ℚ) :
    (seg.subsegment t1 t2).p2 = seg_at seg t2 := rfl

-- ============================================================================
-- Helper: subsegment 0 t has p1 = seg.p1
-- ============================================================================

private lemma subseg_zero_p1 (seg : LineSegment) (t : ℚ) :
    (seg.subsegment 0 t).p1 = seg.p1 := by
  simp only [LineSegment.subsegment]
  exact (Vector2D.mk.injEq _ _ _ _).mpr ⟨by ring, by ring⟩

-- ============================================================================
-- Helper: subsegment t 1 has p2 = seg.p2
-- ============================================================================

private lemma subseg_one_p2 (seg : LineSegment) (t : ℚ) :
    (seg.subsegment t 1).p2 = seg.p2 := by
  simp only [LineSegment.subsegment]
  exact (Vector2D.mk.injEq _ _ _ _).mpr ⟨by ring, by ring⟩

-- ============================================================================
-- Helper: point at parent parameter lies in left/right subsegment
-- ============================================================================

/-- A point with parent parameter t ∈ [0, t_m] lies in subsegment(0, t_m). -/
private lemma parent_param_in_subseg_left (seg : LineSegment) (t_m : ℚ)
    (ht_m_pos : 0 < t_m)
    (t : ℚ) (ht_0 : 0 ≤ t) (ht_tm : t ≤ t_m) :
    seg_at seg t ∈ (seg.subsegment 0 t_m).toSet := by
  have htm_ne : t_m ≠ 0 := ne_of_gt ht_m_pos
  set s := t / t_m
  have hs_tm : s * t_m = t := div_mul_cancel₀ t htm_ne
  have hstm_x : s * (t_m * seg.p2.x) = t * seg.p2.x := by
    rw [← mul_assoc, hs_tm]
  have hstm_x' : s * (t_m * seg.p1.x) = t * seg.p1.x := by
    rw [← mul_assoc, hs_tm]
  have hstm_y : s * (t_m * seg.p2.y) = t * seg.p2.y := by
    rw [← mul_assoc, hs_tm]
  have hstm_y' : s * (t_m * seg.p1.y) = t * seg.p1.y := by
    rw [← mul_assoc, hs_tm]
  exact ⟨s, div_nonneg ht_0 (le_of_lt ht_m_pos),
    (div_le_one (by linarith)).mpr ht_tm,
    by simp only [LineSegment.subsegment, seg_at]; nlinarith,
    by simp only [LineSegment.subsegment, seg_at]; nlinarith⟩

/-- A point with parent parameter t ∈ [t_m, 1] lies in subsegment(t_m, 1). -/
private lemma parent_param_in_subseg_right (seg : LineSegment) (t_m : ℚ)
    (ht_m_lt1 : t_m < 1)
    (t : ℚ) (ht_tm : t_m ≤ t) (ht_1 : t ≤ 1) :
    seg_at seg t ∈ (seg.subsegment t_m 1).toSet := by
  have h1mt_pos : (0 : ℚ) < 1 - t_m := by linarith
  have h1mt_ne : (1 : ℚ) - t_m ≠ 0 := ne_of_gt h1mt_pos
  set s := (t - t_m) / (1 - t_m)
  have hs_key : s * (1 - t_m) = t - t_m := div_mul_cancel₀ (t - t_m) h1mt_ne
  have hsk_x : s * ((1 - t_m) * seg.p1.x) = (t - t_m) * seg.p1.x := by
    rw [← mul_assoc, hs_key]
  have hsk_x' : s * ((1 - t_m) * seg.p2.x) = (t - t_m) * seg.p2.x := by
    rw [← mul_assoc, hs_key]
  have hsk_y : s * ((1 - t_m) * seg.p1.y) = (t - t_m) * seg.p1.y := by
    rw [← mul_assoc, hs_key]
  have hsk_y' : s * ((1 - t_m) * seg.p2.y) = (t - t_m) * seg.p2.y := by
    rw [← mul_assoc, hs_key]
  exact ⟨s, div_nonneg (by linarith) (by linarith),
    (div_le_one h1mt_pos).mpr (by linarith),
    by simp only [LineSegment.subsegment, seg_at]; nlinarith,
    by simp only [LineSegment.subsegment, seg_at]; nlinarith⟩

/-- A crossing on the parent segment with parameter < t_m is a crossing on subseg_L. -/
private lemma crossing_in_subseg_left (seg : LineSegment) (hpi : HalfPlaneIntersection)
    (t_m : ℚ) (ht_m_pos : 0 < t_m)
    (q : Vector2D) (hq_cross : q ∈ seg.boundaryCrossings hpi)
    (t : ℚ) (ht_0 : 0 ≤ t) (_ht_1 : t ≤ 1)
    (hx : q.x = (1 - t) * seg.p1.x + t * seg.p2.x)
    (hy : q.y = (1 - t) * seg.p1.y + t * seg.p2.y)
    (ht_lt : t ≤ t_m) :
    q ∈ (seg.subsegment 0 t_m).boundaryCrossings hpi := by
  have hq_eq : q = seg_at seg t :=
    show q = ⟨(1 - t) * seg.p1.x + t * seg.p2.x, (1 - t) * seg.p1.y + t * seg.p2.y⟩ from
    (Vector2D.mk.injEq _ _ _ _).mpr ⟨hx, hy⟩
  constructor
  · rw [hq_eq]; exact parent_param_in_subseg_left seg t_m ht_m_pos t ht_0 ht_lt
  · exact hq_cross.2

/-- A crossing on the parent segment with parameter > t_m is a crossing on subseg_R. -/
private lemma crossing_in_subseg_right (seg : LineSegment) (hpi : HalfPlaneIntersection)
    (t_m : ℚ) (ht_m_lt1 : t_m < 1)
    (q : Vector2D) (hq_cross : q ∈ seg.boundaryCrossings hpi)
    (t : ℚ) (_ht_0 : 0 ≤ t) (ht_1 : t ≤ 1)
    (hx : q.x = (1 - t) * seg.p1.x + t * seg.p2.x)
    (hy : q.y = (1 - t) * seg.p1.y + t * seg.p2.y)
    (ht_gt : t_m ≤ t) :
    q ∈ (seg.subsegment t_m 1).boundaryCrossings hpi := by
  have hq_eq : q = seg_at seg t :=
    show q = ⟨(1 - t) * seg.p1.x + t * seg.p2.x, (1 - t) * seg.p1.y + t * seg.p2.y⟩ from
    (Vector2D.mk.injEq _ _ _ _).mpr ⟨hx, hy⟩
  constructor
  · rw [hq_eq]; exact parent_param_in_subseg_right seg t_m ht_m_lt1 t ht_gt ht_1
  · exact hq_cross.2

-- ============================================================================
-- Helper: crossings of left/right subsegment correspond to parent crossings
-- with param in the appropriate range
-- ============================================================================

/-- Any crossing on subseg_L = subsegment(0, t_m) is a parent crossing. -/
private lemma crossing_of_subseg_left (seg : LineSegment) (hpi : HalfPlaneIntersection)
    (t_m : ℚ) (ht_m_0 : 0 ≤ t_m) (ht_m_1 : t_m ≤ 1)
    (q : Vector2D) (hq : q ∈ (seg.subsegment 0 t_m).boundaryCrossings hpi) :
    q ∈ seg.boundaryCrossings hpi :=
  subsegment_crossings_subset seg hpi 0 t_m (le_refl 0) ht_m_1 ht_m_0 hq

/-- Any crossing on subseg_R = subsegment(t_m, 1) is a parent crossing. -/
private lemma crossing_of_subseg_right (seg : LineSegment) (hpi : HalfPlaneIntersection)
    (t_m : ℚ) (ht_m_0 : 0 ≤ t_m) (ht_m_1 : t_m ≤ 1)
    (q : Vector2D) (hq : q ∈ (seg.subsegment t_m 1).boundaryCrossings hpi) :
    q ∈ seg.boundaryCrossings hpi :=
  subsegment_crossings_subset seg hpi t_m 1 ht_m_0 (le_refl 1) ht_m_1 hq

-- ============================================================================
-- Unified parity: Even (card + ext_count)
-- ============================================================================

/-- ext_count: number of exterior endpoints (0, 1, or 2). -/
private noncomputable def ext_count (hpi : HalfPlaneIntersection) (seg : LineSegment) : ℕ :=
  (if seg.p1 ∈ hpi.toExteriorSet then 1 else 0) +
  (if seg.p2 ∈ hpi.toExteriorSet then 1 else 0)

/-- Auxiliary: unified parity by strong induction on n.
    For any segment with n boundary crossings, n + ext_count is even. -/
private lemma unified_parity_aux (hpi : HalfPlaneIntersection) :
    ∀ (n : ℕ) (seg : LineSegment)
    (_hp1_nb : seg.p1 ∉ hpi.toBoundarySet) (_hp2_nb : seg.p2 ∉ hpi.toBoundarySet)
    (_av : ∀ q ∈ seg.toSet, q ∉ hpi.toVertexSet)
    (hfin : (seg.boundaryCrossings hpi).Finite),
    hfin.toFinset.card = n →
    Even (n + ext_count hpi seg) := by
  intro n
  induction n using Nat.strongRecOn with
  | ind n ih =>
    intro seg hp1_nb hp2_nb av hfin hcard
    -- Helper: classify an endpoint that's not boundary and not exterior as interior
    have classify_int : ∀ p : Vector2D, p ∉ hpi.toBoundarySet → p ∉ hpi.toExteriorSet →
        p ∈ hpi.toInteriorSet := by
      intro p hnb hne
      have := (hpi.partition_proof).2.2.2
      have hp : p ∈ hpi.toInteriorSet ∪ hpi.toExteriorSet ∪ hpi.toBoundarySet := by
        rw [this]; exact Set.mem_univ _
      rcases hp with (hp | hp) | hp
      · exact hp
      · exact absurd hp hne
      · exact absurd hp hnb
    -- Base case: n = 0
    by_cases hn0 : n = 0
    · subst hn0
      -- ext_count ∈ {0, 2}: both same side (by 0 crossings)
      -- If one int one ext: interior_exterior_crossing gives ≥ 1 crossing.
      by_cases h1e : seg.p1 ∈ hpi.toExteriorSet <;> by_cases h2e : seg.p2 ∈ hpi.toExteriorSet
      · -- Both ext: ext_count = 2
        show Even (0 + ext_count hpi seg)
        simp only [Nat.zero_add, ext_count, if_pos h1e, if_pos h2e]
        exact ⟨1, by ring⟩
      · -- p1 ext, p2 int
        exfalso
        have h2i := classify_int seg.p2 hp2_nb h2e
        set seg' := LineSegment.mk seg.p2 seg.p1
        have h_set_eq : seg'.toSet = seg.toSet := seg.toSet_reverse
        have h_cross_eq : seg'.boundaryCrossings hpi = seg.boundaryCrossings hpi := by
          simp only [LineSegment.boundaryCrossings, h_set_eq]
        have hcross := hpi.interior_exterior_crossing seg'
          hp2_nb hp1_nb (fun q hq => av q (h_set_eq ▸ hq)) h2i h1e
        rw [h_cross_eq] at hcross
        have : hfin.toFinset.card ≥ 1 := by
          obtain ⟨q, hq⟩ := hcross
          exact Finset.card_pos.mpr ⟨q, hfin.mem_toFinset.mpr hq⟩
        omega
      · -- p1 int, p2 ext
        exfalso
        have h1i := classify_int seg.p1 hp1_nb h1e
        have hcross := hpi.interior_exterior_crossing seg hp1_nb hp2_nb av h1i h2e
        have : hfin.toFinset.card ≥ 1 := by
          obtain ⟨q, hq⟩ := hcross
          exact Finset.card_pos.mpr ⟨q, hfin.mem_toFinset.mpr hq⟩
        omega
      · -- Both not ext: ext_count = 0
        show Even (0 + ext_count hpi seg)
        simp only [Nat.zero_add, ext_count, if_neg h1e, if_neg h2e]
        exact ⟨0, by ring⟩
    -- Base case: n = 1
    by_cases hn1 : n = 1
    · subst hn1
      by_cases h1e : seg.p1 ∈ hpi.toExteriorSet <;> by_cases h2e : seg.p2 ∈ hpi.toExteriorSet
      · -- Both exterior: contradicts card ≠ 1
        exfalso
        exact both_exterior_card_ne_one hpi seg hp1_nb hp2_nb av h1e h2e hfin hcard
      · -- p1 ext, p2 not ext: ext_count = 1
        show Even (1 + ext_count hpi seg)
        simp only [ext_count, if_pos h1e, if_neg h2e]
        exact ⟨1, by ring⟩
      · -- p1 not ext, p2 ext: ext_count = 1
        show Even (1 + ext_count hpi seg)
        simp only [ext_count, if_neg h1e, if_pos h2e]
        exact ⟨1, by ring⟩
      · -- Both not exterior: both interior (since not boundary).
        -- interior_no_crossings gives card = 0. But card = 1. Contradiction.
        exfalso
        have h1i := classify_int seg.p1 hp1_nb h1e
        have h2i := classify_int seg.p2 hp2_nb h2e
        have hzero := hpi.interior_no_crossings seg h1i h2i
        -- hzero : boundaryCrossings = ∅
        have hempty : hfin.toFinset.card = 0 := by
          apply Finset.card_eq_zero.mpr
          rw [Finset.eq_empty_iff_forall_not_mem]
          intro q hqm
          have hq := hfin.mem_toFinset.mp hqm
          rw [hzero] at hq; exact hq
        omega
    -- Step: n ≥ 2.
    -- Degenerate segment gives 0 crossings.
    by_cases hne : seg.p1 = seg.p2
    · exfalso
      have hall : ∀ q ∈ seg.toSet, q = seg.p1 := by
        intro q ⟨t, _, _, hx, hy⟩
        exact (Vector2D.mk.injEq _ _ _ _).mpr
          ⟨by rw [hx, ← hne]; ring, by rw [hy, ← hne]; ring⟩
      have hempty : seg.boundaryCrossings hpi = ∅ := by
        ext q; simp only [Set.mem_empty_iff_false, iff_false]
        intro ⟨hqs, hqb⟩; rw [hall q hqs] at hqb; exact hp1_nb hqb
      have : hfin.toFinset.card = 0 := by
        rw [Finset.card_eq_zero, Finset.eq_empty_iff_forall_not_mem]
        intro q hqm
        have hq := hfin.mem_toFinset.mp hqm
        rw [hempty] at hq; exact hq
      omega
    -- n ≥ 2, p1 ≠ p2. Split segment at a gap between two crossings.
    -- Step 1: Get two distinct crossings with distinct parameters.
    have hn_ge2 : n ≥ 2 := by omega
    have hne' : seg.p1 ≠ seg.p2 := hne
    have hC_ne : hfin.toFinset.Nonempty := by
      rw [Finset.nonempty_iff_ne_empty]; intro h; rw [Finset.card_eq_zero.mpr h] at hcard; omega
    -- Pick q1 (first crossing) and extract its parameter
    obtain ⟨q1, hq1_mem⟩ := hC_ne
    have hq1_cross := hfin.mem_toFinset.mp hq1_mem
    have hq1_seg : q1 ∈ seg.toSet := hq1_cross.1
    have hq1_bdy : q1 ∈ hpi.toBoundarySet := hq1_cross.2
    obtain ⟨t1, ht1_0, ht1_1, hx1, hy1⟩ := hq1_seg
    -- t1 ∈ (0, 1) since q1 ≠ p1 and q1 ≠ p2
    have ht1_pos : 0 < t1 := by
      rcases eq_or_lt_of_le ht1_0 with h | h
      · exfalso; subst h; apply hp1_nb
        have : q1 = seg.p1 := (Vector2D.mk.injEq _ _ _ _).mpr ⟨by linarith [hx1], by linarith [hy1]⟩
        rwa [this] at hq1_bdy
      · exact h
    have ht1_lt1 : t1 < 1 := by
      rcases eq_or_lt_of_le ht1_1 with h | h
      · exfalso; subst h; apply hp2_nb
        have : q1 = seg.p2 := (Vector2D.mk.injEq _ _ _ _).mpr ⟨by linarith [hx1], by linarith [hy1]⟩
        rwa [this] at hq1_bdy
      · exact h
    -- Since card ≥ 2, there's another crossing q2 ≠ q1
    have hC_card_ge2 : hfin.toFinset.card ≥ 2 := by omega
    have ⟨q2, hq2_mem, hq2_ne⟩ : ∃ q2 ∈ hfin.toFinset, q2 ≠ q1 := by
      by_contra h
      push_neg at h
      have : hfin.toFinset ⊆ {q1} := by
        intro q hq; rw [Finset.mem_singleton]; exact h q hq
      have : hfin.toFinset.card ≤ 1 := le_trans (Finset.card_le_card this) (le_of_eq (Finset.card_singleton q1))
      omega
    have hq2_cross := hfin.mem_toFinset.mp hq2_mem
    have hq2_seg : q2 ∈ seg.toSet := hq2_cross.1
    have hq2_bdy : q2 ∈ hpi.toBoundarySet := hq2_cross.2
    obtain ⟨t2, ht2_0, ht2_1, hx2, hy2⟩ := hq2_seg
    have ht2_pos : 0 < t2 := by
      rcases eq_or_lt_of_le ht2_0 with h | h
      · exfalso; subst h; apply hp1_nb
        have : q2 = seg.p1 := (Vector2D.mk.injEq _ _ _ _).mpr ⟨by linarith [hx2], by linarith [hy2]⟩
        rwa [this] at hq2_bdy
      · exact h
    have ht2_lt1 : t2 < 1 := by
      rcases eq_or_lt_of_le ht2_1 with h | h
      · exfalso; subst h; apply hp2_nb
        have : q2 = seg.p2 := (Vector2D.mk.injEq _ _ _ _).mpr ⟨by linarith [hx2], by linarith [hy2]⟩
        rwa [this] at hq2_bdy
      · exact h
    -- t1 ≠ t2 since q1 ≠ q2 and seg parametrization is injective
    have ht_ne : t1 ≠ t2 := by
      intro h; apply hq2_ne
      exact (Vector2D.mk.injEq _ _ _ _).mpr ⟨by rw [hx1, hx2, h], by rw [hy1, hy2, h]⟩
    -- Step 2: Find split point t_m strictly between min(t1,t2) and max(t1,t2)
    -- We need t_m ∈ (0, 1) with t_m not a crossing parameter.
    -- Use: find t_m between t1 and t2 (or t2 and t1), not equal to any crossing param.
    -- First, build a finset of all crossing parameters.
    -- For simplicity, pick the min and max of {t1, t2} and find t_m between them.
    have ht_lt : t1 < t2 ∨ t2 < t1 := lt_or_gt_of_ne ht_ne
    -- We'll use min(t1,t2) < max(t1,t2) and find t_m between them.
    set t_lo := min t1 t2
    set t_hi := max t1 t2
    have ht_lo_lt_hi : t_lo < t_hi := by
      simp only [t_lo, t_hi, min_def, max_def]
      rcases ht_lt with h | h <;> simp [le_of_lt h, not_le.mpr h] <;> linarith
    have ht_lo_pos : 0 < t_lo := lt_min ht1_pos ht2_pos
    have ht_hi_lt1 : t_hi < 1 := max_lt ht1_lt1 ht2_lt1
    -- Step 3: Find a split parameter t_m ∈ (t_lo, t_hi) avoiding all crossing params.
    -- Build finset of crossing parameters
    let get_param : Vector2D → ℚ := fun q =>
      if h : q ∈ seg.toSet then seg_param seg q h else 0
    set param_finset := hfin.toFinset.image get_param with hpf_def
    -- Find t_m in (t_lo, t_hi) not in param_finset
    obtain ⟨t_m, ht_m_gt_lo, ht_m_lt_hi, ht_m_not_param⟩ :=
      exists_rat_between_not_in_finset t_lo t_hi ht_lo_lt_hi param_finset
    have ht_m_pos : 0 < t_m := lt_trans ht_lo_pos ht_m_gt_lo
    have ht_m_lt1 : t_m < 1 := lt_trans ht_m_lt_hi ht_hi_lt1
    -- The point m = seg_at(t_m) is on the segment but NOT on the boundary.
    set m := seg_at seg t_m with hm_def
    have hm_seg : m ∈ seg.toSet := seg_at_mem seg t_m (le_of_lt ht_m_pos) (le_of_lt ht_m_lt1)
    -- Show m is not a crossing (not in hfin.toFinset)
    have hm_not_cross : m ∉ hfin.toFinset := by
      intro hm_mem
      apply ht_m_not_param
      -- We need t_m ∈ param_finset.
      -- get_param m ∈ param_finset (by image), and get_param m = t_m (by param uniqueness).
      have hgp_eq : get_param m = t_m := by
        -- get_param m = seg_param seg m hm_seg (since m ∈ seg.toSet)
        have hgp : get_param m = seg_param seg m hm_seg := dif_pos hm_seg
        -- seg_param gives some t'. By uniqueness (since p1 ≠ p2), t' = t_m.
        have hsp := seg_param_spec seg m hm_seg
        rw [hgp]
        exact seg_param_unique seg hne' (seg_param seg m hm_seg) t_m
          (by rw [← hsp.2.2.1]; simp [seg_at, hm_def])
          (by rw [← hsp.2.2.2]; simp [seg_at, hm_def])
      rw [hpf_def, ← hgp_eq]
      exact Finset.mem_image_of_mem get_param hm_mem
    -- Therefore m is not on the boundary
    have hm_not_bdy : m ∉ hpi.toBoundarySet := by
      intro hm_bdy
      exact hm_not_cross (hfin.mem_toFinset.mpr ⟨hm_seg, hm_bdy⟩)
    -- Step 4: Define left and right subsegments
    set seg_L := seg.subsegment 0 t_m with hsL_def
    set seg_R := seg.subsegment t_m 1 with hsR_def
    -- Step 5: Verify hypotheses for IH
    -- 5a: endpoints not on boundary
    have hL_p1_eq : seg_L.p1 = seg.p1 := subseg_zero_p1 seg t_m
    have hL_p2_eq : seg_L.p2 = m := by simp only [hsL_def, subseg_p2_eq, hm_def]
    have hR_p1_eq : seg_R.p1 = m := by simp only [hsR_def, subseg_p1_eq, hm_def]
    have hR_p2_eq : seg_R.p2 = seg.p2 := subseg_one_p2 seg t_m
    have hL_p1_nb : seg_L.p1 ∉ hpi.toBoundarySet := hL_p1_eq ▸ hp1_nb
    have hL_p2_nb : seg_L.p2 ∉ hpi.toBoundarySet := hL_p2_eq ▸ hm_not_bdy
    have hR_p1_nb : seg_R.p1 ∉ hpi.toBoundarySet := hR_p1_eq ▸ hm_not_bdy
    have hR_p2_nb : seg_R.p2 ∉ hpi.toBoundarySet := hR_p2_eq ▸ hp2_nb
    -- 5b: avoids vertices
    have hL_av : ∀ q ∈ seg_L.toSet, q ∉ hpi.toVertexSet :=
      subsegment_avoids_vertices seg hpi 0 t_m (le_refl 0) (le_of_lt ht_m_lt1)
        (le_of_lt ht_m_pos) av
    have hR_av : ∀ q ∈ seg_R.toSet, q ∉ hpi.toVertexSet :=
      subsegment_avoids_vertices seg hpi t_m 1 (le_of_lt ht_m_pos) (le_refl 1)
        (le_of_lt ht_m_lt1) av
    -- 5c: finiteness
    have hL_fin : (seg_L.boundaryCrossings hpi).Finite :=
      hfin.subset (subsegment_crossings_subset seg hpi 0 t_m (le_refl 0)
        (le_of_lt ht_m_lt1) (le_of_lt ht_m_pos))
    have hR_fin : (seg_R.boundaryCrossings hpi).Finite :=
      hfin.subset (subsegment_crossings_subset seg hpi t_m 1 (le_of_lt ht_m_pos)
        (le_refl 1) (le_of_lt ht_m_lt1))
    -- Step 6: Show that crossings partition.
    -- Every parent crossing is either in left or right.
    -- Key: for any crossing q with parameter t, t < t_m → in left, t > t_m → in right.
    -- And t ≠ t_m because seg_at(t_m) is not a crossing.
    -- 6a: Every parent crossing is in left or right
    have h_partition_into : ∀ q ∈ hfin.toFinset,
        q ∈ hL_fin.toFinset ∨ q ∈ hR_fin.toFinset := by
      intro q hq_mem
      have hq_cross := hfin.mem_toFinset.mp hq_mem
      have hq_seg := hq_cross.1
      obtain ⟨t, ht_0, ht_1, hx, hy⟩ := hq_seg
      -- t ≠ t_m because q ≠ seg_at(t_m) = m
      have ht_ne_tm : t ≠ t_m := by
        intro heq
        -- Then q = seg_at(t) = seg_at(t_m) = m
        have hq_eq_m : q = m := by
          rw [hm_def]; unfold seg_at
          exact (Vector2D.mk.injEq _ _ _ _).mpr ⟨by rw [hx, heq], by rw [hy, heq]⟩
        rw [hq_eq_m] at hq_mem
        exact hm_not_cross hq_mem
      rcases lt_or_gt_of_ne ht_ne_tm with ht_lt | ht_gt
      · -- t < t_m: crossing is in left subseg
        left
        exact hL_fin.mem_toFinset.mpr
          (crossing_in_subseg_left seg hpi t_m ht_m_pos q hq_cross t ht_0 ht_1 hx hy (le_of_lt ht_lt))
      · -- t > t_m: crossing is in right subseg
        right
        exact hR_fin.mem_toFinset.mpr
          (crossing_in_subseg_right seg hpi t_m ht_m_lt1 q hq_cross t ht_0 ht_1 hx hy (le_of_lt ht_gt))
    -- 6b: Left and right crossings are subsets of parent crossings
    have hL_sub : hL_fin.toFinset ⊆ hfin.toFinset := by
      intro q hq
      exact hfin.mem_toFinset.mpr
        (crossing_of_subseg_left seg hpi t_m (le_of_lt ht_m_pos) (le_of_lt ht_m_lt1) q
          (hL_fin.mem_toFinset.mp hq))
    have hR_sub : hR_fin.toFinset ⊆ hfin.toFinset := by
      intro q hq
      exact hfin.mem_toFinset.mpr
        (crossing_of_subseg_right seg hpi t_m (le_of_lt ht_m_pos) (le_of_lt ht_m_lt1) q
          (hR_fin.mem_toFinset.mp hq))
    -- 6c: Left and right are disjoint
    have hLR_disj : Disjoint hL_fin.toFinset hR_fin.toFinset := by
      rw [Finset.disjoint_left]
      intro q hqL hqR
      have hq_crossL := hL_fin.mem_toFinset.mp hqL
      have hq_crossR := hR_fin.mem_toFinset.mp hqR
      -- q is on both subsegments
      have hq_segL := hq_crossL.1
      have hq_segR := hq_crossR.1
      -- Get parameters on parent seg
      obtain ⟨sL, hsL_0, hsL_1, hxL, hyL⟩ := hq_segL
      obtain ⟨sR, hsR_0, hsR_1, hxR, hyR⟩ := hq_segR
      -- Convert subseg params to parent params
      -- For left subseg(0, t_m), parent param = sL * t_m (by subseg definition)
      have hxL' : q.x = (1 - sL * t_m) * seg.p1.x + (sL * t_m) * seg.p2.x := by
        simp only [hsL_def, LineSegment.subsegment] at hxL; linarith
      have hyL' : q.y = (1 - sL * t_m) * seg.p1.y + (sL * t_m) * seg.p2.y := by
        simp only [hsL_def, LineSegment.subsegment] at hyL; linarith
      -- For right subseg(t_m, 1), parent param = t_m + sR * (1 - t_m)
      have hxR' : q.x = (1 - (t_m + sR * (1 - t_m))) * seg.p1.x +
          (t_m + sR * (1 - t_m)) * seg.p2.x := by
        simp only [hsR_def, LineSegment.subsegment] at hxR; linarith
      have hyR' : q.y = (1 - (t_m + sR * (1 - t_m))) * seg.p1.y +
          (t_m + sR * (1 - t_m)) * seg.p2.y := by
        simp only [hsR_def, LineSegment.subsegment] at hyR; linarith
      -- By uniqueness, sL * t_m = t_m + sR * (1 - t_m)
      have h_param_eq := seg_param_unique seg hne'
        (sL * t_m) (t_m + sR * (1 - t_m))
        (by linarith [hxL', hxR']) (by linarith [hyL', hyR'])
      -- sL * t_m = t_m + sR * (1 - t_m) means sL * t_m ≥ t_m (since sR ≥ 0)
      -- and sL * t_m ≤ t_m (since sL ≤ 1).
      -- So sL * t_m = t_m, hence sL = 1 and sR = 0.
      -- Then q = seg_at(t_m) = m, contradicting m not being a crossing.
      have hpL := h_param_eq
      -- sL * t_m ≤ t_m (since sL ≤ 1 and t_m > 0)
      have : sL * t_m ≤ 1 * t_m := mul_le_mul_of_nonneg_right hsL_1 (le_of_lt ht_m_pos)
      -- t_m + sR * (1 - t_m) ≥ t_m (since sR ≥ 0)
      have : t_m ≤ t_m + sR * (1 - t_m) := by linarith [mul_nonneg hsR_0 (by linarith : (0:ℚ) ≤ 1 - t_m)]
      -- From h_param_eq: sL * t_m = t_m + sR * (1 - t_m)
      -- Combined: t_m ≤ sL * t_m ≤ t_m. So sL * t_m = t_m.
      have hsLtm_eq : sL * t_m = t_m := by linarith
      -- So sL = 1 (since t_m > 0)
      have hsL_eq1 : sL = 1 := by
        have h := hsLtm_eq  -- sL * t_m = t_m
        have : (sL - 1) * t_m = 0 := by linarith
        rcases mul_eq_zero.mp this with h | h
        · linarith
        · linarith [ht_m_pos]
      -- Then q = subseg_L.p2 = m
      have hq_eq_m : q = m := by
        rw [hsL_eq1] at hxL' hyL'
        rw [hm_def]; unfold seg_at
        exact (Vector2D.mk.injEq _ _ _ _).mpr ⟨by linarith [hxL'], by linarith [hyL']⟩
      -- But q is a parent crossing (from hqL), and m is not
      rw [hq_eq_m] at hqL
      exact hm_not_cross (hL_sub hqL)
    -- 6d: Union equals parent
    have hLR_union : hfin.toFinset = hL_fin.toFinset ∪ hR_fin.toFinset := by
      ext q
      constructor
      · intro hq
        rcases h_partition_into q hq with h | h
        · exact Finset.mem_union_left _ h
        · exact Finset.mem_union_right _ h
      · intro hq
        rcases Finset.mem_union.mp hq with h | h
        · exact hL_sub h
        · exact hR_sub h
    -- 6e: card equation
    have hcard_sum : hfin.toFinset.card = hL_fin.toFinset.card + hR_fin.toFinset.card := by
      rw [hLR_union]; exact Finset.card_union_of_disjoint hLR_disj
    -- Step 7: Show both sides have < n crossings
    -- q1 is in the subseg containing the lower parameter
    -- q2 is in the other subseg
    -- More precisely: the crossing with param t_lo < t_m is in L, and with param t_hi > t_m is in R
    -- t_lo < t_m < t_hi
    have hq_lo_in_L : ∃ q ∈ hL_fin.toFinset, True := by
      -- The crossing at t_lo is in L
      -- t_lo = min(t1, t2) < t_m
      rcases ht_lt with h | h
      · -- t1 < t2, so t_lo = t1
        refine ⟨q1, ?_, trivial⟩
        have : t_lo = t1 := min_eq_left (le_of_lt h)
        have ht1_lt_tm : t1 < t_m := by linarith [ht_m_gt_lo, this]
        exact hL_fin.mem_toFinset.mpr
          (crossing_in_subseg_left seg hpi t_m ht_m_pos q1 hq1_cross
            t1 ht1_0 ht1_1 hx1 hy1 (le_of_lt ht1_lt_tm))
      · -- t2 < t1, so t_lo = t2
        refine ⟨q2, ?_, trivial⟩
        have : t_lo = t2 := min_eq_right (le_of_lt h)
        have ht2_lt_tm : t2 < t_m := by linarith [ht_m_gt_lo, this]
        exact hL_fin.mem_toFinset.mpr
          (crossing_in_subseg_left seg hpi t_m ht_m_pos q2 hq2_cross
            t2 ht2_0 ht2_1 hx2 hy2 (le_of_lt ht2_lt_tm))
    have hq_hi_in_R : ∃ q ∈ hR_fin.toFinset, True := by
      rcases ht_lt with h | h
      · -- t1 < t2, so t_hi = t2
        refine ⟨q2, ?_, trivial⟩
        have : t_hi = t2 := max_eq_right (le_of_lt h)
        have ht2_gt_tm : t_m < t2 := by linarith [ht_m_lt_hi, this]
        exact hR_fin.mem_toFinset.mpr
          (crossing_in_subseg_right seg hpi t_m ht_m_lt1 q2 hq2_cross
            t2 ht2_0 ht2_1 hx2 hy2 (le_of_lt ht2_gt_tm))
      · -- t2 < t1, so t_hi = t1
        refine ⟨q1, ?_, trivial⟩
        have : t_hi = t1 := max_eq_left (le_of_lt h)
        have ht1_gt_tm : t_m < t1 := by linarith [ht_m_lt_hi, this]
        exact hR_fin.mem_toFinset.mpr
          (crossing_in_subseg_right seg hpi t_m ht_m_lt1 q1 hq1_cross
            t1 ht1_0 ht1_1 hx1 hy1 (le_of_lt ht1_gt_tm))
    have hL_pos : hL_fin.toFinset.card ≥ 1 := by
      obtain ⟨q, hq, _⟩ := hq_lo_in_L; exact Finset.card_pos.mpr ⟨q, hq⟩
    have hR_pos : hR_fin.toFinset.card ≥ 1 := by
      obtain ⟨q, hq, _⟩ := hq_hi_in_R; exact Finset.card_pos.mpr ⟨q, hq⟩
    have hL_lt : hL_fin.toFinset.card < n := by omega
    have hR_lt : hR_fin.toFinset.card < n := by omega
    -- Step 8: Apply IH to both subsegments
    set nL := hL_fin.toFinset.card
    set nR := hR_fin.toFinset.card
    have ihL := ih nL hL_lt seg_L hL_p1_nb hL_p2_nb hL_av hL_fin rfl
    have ihR := ih nR hR_lt seg_R hR_p1_nb hR_p2_nb hR_av hR_fin rfl
    -- Step 9: Combine parities
    -- ihL: Even (nL + ext_count hpi seg_L)
    -- ihR: Even (nR + ext_count hpi seg_R)
    -- ext_count hpi seg_L = (if seg_L.p1 ∈ ext then 1 else 0) + (if seg_L.p2 ∈ ext then 1 else 0)
    --                     = (if p1 ∈ ext then 1 else 0) + (if m ∈ ext then 1 else 0)
    -- ext_count hpi seg_R = (if m ∈ ext then 1 else 0) + (if p2 ∈ ext then 1 else 0)
    -- Sum: nL + nR + ext_count(L) + ext_count(R)
    --    = n + (if p1 ext then 1 else 0) + 2*(if m ext then 1 else 0) + (if p2 ext then 1 else 0)
    --    = n + ext_count(seg) + 2*(if m ext then 1 else 0)
    -- Sum of two even numbers is even, so n + ext_count(seg) + 2*m_ext is even
    -- Therefore n + ext_count(seg) is even.
    have h_ext_L : ext_count hpi seg_L =
        (if seg.p1 ∈ hpi.toExteriorSet then 1 else 0) +
        (if m ∈ hpi.toExteriorSet then 1 else 0) := by
      simp only [ext_count, hL_p1_eq, hL_p2_eq]
    have h_ext_R : ext_count hpi seg_R =
        (if m ∈ hpi.toExteriorSet then 1 else 0) +
        (if seg.p2 ∈ hpi.toExteriorSet then 1 else 0) := by
      simp only [ext_count, hR_p1_eq, hR_p2_eq]
    -- Sum is even
    have hsum_even : Even (nL + ext_count hpi seg_L + (nR + ext_count hpi seg_R)) := by
      exact Even.add ihL ihR
    rw [h_ext_L, h_ext_R] at hsum_even
    -- nL + nR = n
    have hn_sum : nL + nR = n := by omega
    -- The sum simplifies
    set m_ext := if m ∈ hpi.toExteriorSet then 1 else 0 with hm_ext_def
    have hsum_rw : nL + ((if seg.p1 ∈ hpi.toExteriorSet then 1 else 0) + m_ext) +
        (nR + (m_ext + (if seg.p2 ∈ hpi.toExteriorSet then 1 else 0))) =
        n + ext_count hpi seg + 2 * m_ext := by
      simp only [ext_count]; omega
    rw [hsum_rw] at hsum_even
    -- n + ext_count + 2*m_ext is even, and 2*m_ext is even,
    -- so n + ext_count is even.
    have hm_ext_even : Even (2 * m_ext) := ⟨m_ext, by ring⟩
    obtain ⟨k, hk⟩ := hsum_even
    obtain ⟨j, hj⟩ := hm_ext_even
    exact ⟨k - j, by omega⟩

/-- The unified parity theorem: card(crossings) + ext_count is always even. -/
private theorem unified_parity
    (hpi : HalfPlaneIntersection) (seg : LineSegment)
    (hp1_not_boundary : seg.p1 ∉ hpi.toBoundarySet)
    (hp2_not_boundary : seg.p2 ∉ hpi.toBoundarySet)
    (avoids_vertices : ∀ q ∈ seg.toSet, q ∉ hpi.toVertexSet)
    (hfin : (seg.boundaryCrossings hpi).Finite) :
    Even (hfin.toFinset.card + ext_count hpi seg) :=
  unified_parity_aux hpi _ seg hp1_not_boundary hp2_not_boundary avoids_vertices hfin rfl

/-- If both endpoints are exterior, then the boundary crossings are finite and even. -/
theorem HalfPlaneIntersection.exterior_exterior_even
    (hpi : HalfPlaneIntersection) (seg : LineSegment)
    (hp1_not_boundary : seg.p1 ∉ hpi.toBoundarySet)
    (hp2_not_boundary : seg.p2 ∉ hpi.toBoundarySet)
    (avoids_vertices : ∀ q ∈ seg.toSet, q ∉ hpi.toVertexSet)
    (h1_ext : seg.p1 ∈ hpi.toExteriorSet)
    (h2_ext : seg.p2 ∈ hpi.toExteriorSet) :
    ∃ (hfin : (seg.boundaryCrossings hpi).Finite), Even hfin.toFinset.card := by
  have hfin := (hpi.segment_separation_proof seg hp1_not_boundary hp2_not_boundary
    avoids_vertices).1
  refine ⟨hfin, ?_⟩
  have h := unified_parity hpi seg hp1_not_boundary hp2_not_boundary avoids_vertices hfin
  simp only [ext_count, if_pos h1_ext, if_pos h2_ext] at h
  obtain ⟨k, hk⟩ := h
  exact ⟨k - 1, by omega⟩

-- ============================================================================
-- Polygon crossing parity
-- ============================================================================

/-- Indicator: 1 if point is exterior, 0 otherwise. -/
private def ext_indicator (hpi : HalfPlaneIntersection) (v : Vector2D) : ℕ :=
  if v ∈ hpi.toExteriorSet then 1 else 0

/-- Segments of an open polyline. -/
private def polylineSegs : List Vector2D → List LineSegment
  | [] => []
  | [_] => []
  | a :: b :: rest => ⟨a, b⟩ :: polylineSegs (b :: rest)

/-- Total crossing count for a polyline. -/
private noncomputable def polylineCrossings (hpi : HalfPlaneIntersection) :
    List Vector2D → ℕ
  | [] => 0
  | [_] => 0
  | a :: b :: rest => segCrossingCount ⟨a, b⟩ hpi + polylineCrossings hpi (b :: rest)

@[simp] private theorem polylineSegs_cons_cons (a b : Vector2D) (rest : List Vector2D) :
    polylineSegs (a :: b :: rest) = ⟨a, b⟩ :: polylineSegs (b :: rest) := rfl

private lemma segCrossingCount_eq_card (seg : LineSegment) (hpi : HalfPlaneIntersection)
    (hfin : (seg.boundaryCrossings hpi).Finite) :
    segCrossingCount seg hpi = hfin.toFinset.card := by
  simp [segCrossingCount, dif_pos hfin]

/-- Polyline crossings parity: total crossings + ext_indicator(first) + ext_indicator(last)
    is always even. -/
private theorem polyline_crossings_parity
    (hpi : HalfPlaneIntersection)
    (vs : List Vector2D) (hvs : vs ≠ [])
    (h_not_boundary : ∀ v ∈ vs, v ∉ hpi.toBoundarySet)
    (h_avoids : ∀ seg ∈ polylineSegs vs, ∀ q ∈ seg.toSet, q ∉ hpi.toVertexSet) :
    Even (polylineCrossings hpi vs +
      ext_indicator hpi (vs.head hvs) + ext_indicator hpi (vs.getLast hvs)) := by
  induction vs with
  | nil => contradiction
  | cons a tl ih =>
    cases tl with
    | nil =>
      -- Base: [a], total = 0, Even(0 + ext(a) + ext(a))
      simp only [polylineCrossings, Nat.zero_add]
      have hh : [a].head hvs = a := rfl
      have hl : [a].getLast hvs = a := rfl
      rw [hh, hl]
      exact ⟨ext_indicator hpi a, by omega⟩
    | cons b rest =>
      have h_tl_ne : b :: rest ≠ [] := List.cons_ne_nil b rest
      have h_not_boundary_tl : ∀ v ∈ (b :: rest), v ∉ hpi.toBoundarySet :=
        fun v hv => h_not_boundary v (List.mem_cons_of_mem a hv)
      have h_avoids_tl : ∀ seg ∈ polylineSegs (b :: rest),
          ∀ q ∈ seg.toSet, q ∉ hpi.toVertexSet := by
        intro seg hseg q hq
        exact h_avoids seg (by simp; right; exact hseg) q hq
      have ih_applied := ih h_tl_ne h_not_boundary_tl h_avoids_tl
      -- Simplify head/last
      have h_ne : a :: b :: rest ≠ [] := List.cons_ne_nil _ _
      have h_head : (a :: b :: rest).head h_ne = a := rfl
      have h_last : (a :: b :: rest).getLast h_ne = (b :: rest).getLast h_tl_ne := by
        simp [List.getLast_cons]
      have h_head_tl : (b :: rest).head h_tl_ne = b := rfl
      rw [h_head, h_last]
      -- Simplify polylineCrossings
      show Even (segCrossingCount ⟨a, b⟩ hpi + polylineCrossings hpi (b :: rest) +
        ext_indicator hpi a + ext_indicator hpi ((b :: rest).getLast h_tl_ne))
      -- Per-segment parity for ⟨a, b⟩
      have ha_nb : a ∉ hpi.toBoundarySet := h_not_boundary a ((List.mem_cons_self _ _))
      have hb_nb : b ∉ hpi.toBoundarySet :=
        h_not_boundary b (List.mem_cons_of_mem _ ((List.mem_cons_self _ _)))
      have h_avoids_ab : ∀ q ∈ (LineSegment.mk a b).toSet, q ∉ hpi.toVertexSet :=
        h_avoids ⟨a, b⟩ (by simp)
      have hfin_ab := (hpi.segment_separation_proof ⟨a, b⟩ ha_nb hb_nb h_avoids_ab).1
      have h_seg_parity := unified_parity hpi ⟨a, b⟩ ha_nb hb_nb h_avoids_ab hfin_ab
      -- Relate segCrossingCount to hfin.toFinset.card
      have h_cc_eq : segCrossingCount ⟨a, b⟩ hpi = hfin_ab.toFinset.card :=
        segCrossingCount_eq_card ⟨a, b⟩ hpi hfin_ab
      -- ext_count for ⟨a,b⟩ = ext_indicator a + ext_indicator b
      have h_ext_eq : ext_count hpi ⟨a, b⟩ = ext_indicator hpi a + ext_indicator hpi b := by
        simp [ext_count, ext_indicator]
      rw [h_cc_eq]
      rw [h_ext_eq] at h_seg_parity
      -- h_seg_parity : Even (hfin_ab.card + (ext_indicator a + ext_indicator b))
      -- ih_applied : Even (polylineCrossings (b::rest) + ext_indicator b + ext_indicator last)
      rw [h_head_tl] at ih_applied
      -- Combine two Even facts
      obtain ⟨k1, hk1⟩ := h_seg_parity
      obtain ⟨k2, hk2⟩ := ih_applied
      -- ext_indicator hpi b ∈ {0, 1}
      have hb01 : ext_indicator hpi b = 0 ∨ ext_indicator hpi b = 1 := by
        unfold ext_indicator; split <;> omega
      rcases hb01 with hb0 | hb1
      · rw [hb0] at hk1 hk2; exact ⟨k1 + k2, by omega⟩
      · rw [hb1] at hk1 hk2; exact ⟨k1 + k2 - 1, by omega⟩

-- ============================================================================
-- Polygon segments = polyline segments of closed path
-- ============================================================================

/-- polylineSegs equals zip with tail. -/
private theorem polylineSegs_eq_zip_tail (l : List Vector2D) :
    polylineSegs l = (List.zip l l.tail).map fun p => (⟨p.1, p.2⟩ : LineSegment) := by
  induction l with
  | nil => simp [polylineSegs]
  | cons a tl ih =>
    cases tl with
    | nil => simp [polylineSegs]
    | cons b rest =>
      simp only [polylineSegs_cons_cons, List.tail_cons, List.zip_cons_cons, List.map_cons]
      congr 1

/-- zip (l₁ ++ [x]) l₂ = zip l₁ l₂ when l₂.length ≤ l₁.length -/
private theorem zip_append_left {α β : Type} (l₁ : List α) (l₂ : List β) (x : α)
    (h : l₂.length ≤ l₁.length) :
    List.zip (l₁ ++ [x]) l₂ = List.zip l₁ l₂ := by
  induction l₁ generalizing l₂ with
  | nil => simp at h; simp [h]
  | cons a rest ih =>
    cases l₂ with
    | nil => simp
    | cons b tl =>
      simp only [List.cons_append, List.zip_cons_cons]
      congr 1
      apply ih
      simp at h
      omega

/-- Polygon segments equal polyline segments of closed polyline. -/
private theorem polygon_segments_eq_polylineSegs (v : Vector2D) (vs : List Vector2D)
    (hvs : vs ≠ []) :
    (Polygon.mk (v :: vs)).segments = polylineSegs (v :: vs ++ [v]) := by
  rw [polylineSegs_eq_zip_tail]
  unfold Polygon.segments
  simp only [List.cons_append, List.tail_cons]
  congr 1
  symm
  show List.zip ((v :: vs) ++ [v]) (vs ++ [v]) = List.zip (v :: vs) (vs ++ [v])
  apply zip_append_left
  simp

/-- polylineCrossings equals the sum of mapped crossings. -/
private theorem polylineCrossings_eq_map_sum (hpi : HalfPlaneIntersection) (vs : List Vector2D) :
    polylineCrossings hpi vs =
      ((polylineSegs vs).map fun seg => segCrossingCount seg hpi).sum := by
  induction vs with
  | nil => simp [polylineCrossings, polylineSegs]
  | cons a tl ih =>
    cases tl with
    | nil => simp [polylineCrossings, polylineSegs]
    | cons b rest =>
      simp only [polylineCrossings, polylineSegs_cons_cons, List.map_cons, List.sum_cons]
      congr 1

/-- Closed polyline vertices are all polygon vertices. -/
private lemma closed_pl_verts_mem (v : Vector2D) (vs : List Vector2D) :
    ∀ v' ∈ (v :: vs ++ [v]), v' ∈ (v :: vs) := by
  intro v' hv'
  simp only [List.mem_cons, List.mem_append] at hv' ⊢
  tauto

/-- First endpoint of a polyline segment is a vertex of the polyline. -/
private lemma polylineSegs_p1_mem (vs : List Vector2D) (seg : LineSegment)
    (hseg : seg ∈ polylineSegs vs) : seg.p1 ∈ vs := by
  induction vs with
  | nil => simp [polylineSegs] at hseg
  | cons a tl ih =>
    cases tl with
    | nil => simp [polylineSegs] at hseg
    | cons b rest =>
      simp only [polylineSegs_cons_cons, List.mem_cons] at hseg
      rcases hseg with rfl | htl
      · simp
      · exact List.mem_cons_of_mem a (ih htl)

/-- Second endpoint of a polyline segment is a vertex of the polyline. -/
private lemma polylineSegs_p2_mem (vs : List Vector2D) (seg : LineSegment)
    (hseg : seg ∈ polylineSegs vs) : seg.p2 ∈ vs := by
  induction vs with
  | nil => simp [polylineSegs] at hseg
  | cons a tl ih =>
    cases tl with
    | nil => simp [polylineSegs] at hseg
    | cons b rest =>
      simp only [polylineSegs_cons_cons, List.mem_cons] at hseg
      rcases hseg with rfl | htl
      · simp
      · exact List.mem_cons_of_mem a (ih htl)

theorem HalfPlaneIntersection.polygon_crossings_even_proof
    (hpi : HalfPlaneIntersection) (poly : Polygon)
    (h_vertices_not_boundary : ∀ v ∈ poly.vertices, v ∉ hpi.toBoundarySet)
    (h_avoids_vertices : ∀ seg ∈ poly.segments, ∀ q ∈ seg.toSet, q ∉ hpi.toVertexSet) :
    (∀ seg ∈ poly.segments, (seg.boundaryCrossings hpi).Finite) ∧
    Even ((poly.segments.map fun seg => segCrossingCount seg hpi).sum) := by
  cases hv : poly.vertices with
  | nil =>
    constructor
    · intro seg hseg; simp [Polygon.segments, hv] at hseg
    · simp [Polygon.segments, hv]
  | cons v vs =>
    cases vs with
    | nil =>
      constructor
      · intro seg hseg; simp [Polygon.segments, hv] at hseg
      · simp [Polygon.segments, hv]
    | cons w ws =>
      -- poly.vertices = v :: w :: ws
      have hvs_ne : w :: ws ≠ [] := List.cons_ne_nil w ws
      have h_poly_eq : poly.segments = polylineSegs (v :: (w :: ws) ++ [v]) := by
        have : poly = Polygon.mk (v :: w :: ws) := by
          cases poly; simp at hv; simp [hv]
        rw [this]
        exact polygon_segments_eq_polylineSegs v (w :: ws) hvs_ne
      constructor
      · -- Finiteness for each segment
        intro seg hseg
        -- Use polylineSegs helpers to find that endpoints are polygon vertices
        have hseg_pl : seg ∈ polylineSegs (v :: (w :: ws) ++ [v]) := h_poly_eq ▸ hseg
        have h_p1_in := polylineSegs_p1_mem _ seg hseg_pl
        have h_p2_in := polylineSegs_p2_mem _ seg hseg_pl
        have h_p1_vert : seg.p1 ∈ poly.vertices := by
          rw [hv]; exact closed_pl_verts_mem v (w :: ws) seg.p1 h_p1_in
        have h_p2_vert : seg.p2 ∈ poly.vertices := by
          rw [hv]; exact closed_pl_verts_mem v (w :: ws) seg.p2 h_p2_in
        have h_p1_nb := h_vertices_not_boundary seg.p1 h_p1_vert
        have h_p2_nb := h_vertices_not_boundary seg.p2 h_p2_vert
        have h_av := h_avoids_vertices seg hseg
        exact (hpi.segment_separation_proof seg h_p1_nb h_p2_nb h_av).1
      · -- Evenness of total crossings
        rw [h_poly_eq]
        rw [← polylineCrossings_eq_map_sum]
        -- Apply polyline_crossings_parity to closed polyline v :: (w :: ws) ++ [v]
        set closed_pl := v :: (w :: ws) ++ [v] with h_closed_pl
        have h_ne : closed_pl ≠ [] := by simp [h_closed_pl]
        have h_head : closed_pl.head h_ne = v := rfl
        have h_last : closed_pl.getLast h_ne = v := by
          simp [h_closed_pl, List.getLast_append_of_ne_nil]
        -- All vertices of closed polyline are polygon vertices
        have h_nb_pl : ∀ v' ∈ closed_pl, v' ∉ hpi.toBoundarySet := by
          intro v' hv'
          apply h_vertices_not_boundary
          rw [hv]
          exact closed_pl_verts_mem v (w :: ws) v' (by rw [← h_closed_pl]; exact hv')
        -- Avoids vertices for polyline segments = polygon segments
        have h_av_pl : ∀ seg ∈ polylineSegs closed_pl, ∀ q ∈ seg.toSet,
            q ∉ hpi.toVertexSet := by
          rw [h_closed_pl, ← polygon_segments_eq_polylineSegs v (w :: ws) hvs_ne]
          intro seg hseg
          have : poly = Polygon.mk (v :: w :: ws) := by
            cases poly; simp at hv; simp [hv]
          rw [this] at h_avoids_vertices
          exact h_avoids_vertices seg hseg
        have h_parity := polyline_crossings_parity hpi closed_pl h_ne h_nb_pl h_av_pl
        rw [h_head, h_last] at h_parity
        -- h_parity : Even (polylineCrossings + ext_indicator v + ext_indicator v)
        -- ext_indicator v + ext_indicator v is even
        obtain ⟨k, hk⟩ := h_parity
        have hv01 : ext_indicator hpi v = 0 ∨ ext_indicator hpi v = 1 := by
          unfold ext_indicator; split <;> omega
        rcases hv01 with hv0 | hv1
        · rw [hv0] at hk; exact ⟨k, by omega⟩
        · rw [hv1] at hk; exact ⟨k - 1, by omega⟩

/-- The number of exterior endpoints of a segment. -/
noncomputable def HalfPlaneIntersection.segExtCount (hpi : HalfPlaneIntersection)
    (seg : LineSegment) : ℕ :=
  (if seg.p1 ∈ hpi.toExteriorSet then 1 else 0) +
  (if seg.p2 ∈ hpi.toExteriorSet then 1 else 0)

/-- Per-segment parity: the number of boundary crossings plus the number
    of exterior endpoints is always even. -/
theorem HalfPlaneIntersection.segment_parity
    (hpi : HalfPlaneIntersection) (seg : LineSegment)
    (hp1_not_boundary : seg.p1 ∉ hpi.toBoundarySet)
    (hp2_not_boundary : seg.p2 ∉ hpi.toBoundarySet)
    (avoids_vertices : ∀ q ∈ seg.toSet, q ∉ hpi.toVertexSet) :
    (seg.boundaryCrossings hpi).Finite ∧
    Even (segCrossingCount seg hpi + hpi.segExtCount seg) := by
  have hfin := (hpi.segment_separation_proof seg hp1_not_boundary hp2_not_boundary
    avoids_vertices).1
  refine ⟨hfin, ?_⟩
  have h := unified_parity hpi seg hp1_not_boundary hp2_not_boundary avoids_vertices hfin
  have h_cc : segCrossingCount seg hpi = hfin.toFinset.card :=
    segCrossingCount_eq_card seg hpi hfin
  rw [h_cc]
  convert h using 1

end ConvexProofs

end
