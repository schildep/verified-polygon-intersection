/-! ### Algebraic helper lemmas -/

/-- If both parametric equations hold, then `t * D = tNum`. -/
private lemma tD_eq_tNum
    (r : Ray) (seg : LineSegment) (t s : ℚ)
    (heq1 : t * r.direction.x + s * (seg.p1.x - seg.p2.x) = seg.p1.x - r.origin.x)
    (heq2 : t * r.direction.y + s * (seg.p1.y - seg.p2.y) = seg.p1.y - r.origin.y) :
    t * raySegDet r seg = raySegTNum r seg := by
  show t * (r.direction.x * (seg.p1.y - seg.p2.y) - r.direction.y * (seg.p1.x - seg.p2.x)) =
    (seg.p1.x - r.origin.x) * (seg.p1.y - seg.p2.y) -
      (seg.p1.y - r.origin.y) * (seg.p1.x - seg.p2.x)
  linear_combination (seg.p1.y - seg.p2.y) * heq1 - (seg.p1.x - seg.p2.x) * heq2

/-- If both parametric equations hold, then `s * D = sNum`. -/
private lemma sD_eq_sNum
    (r : Ray) (seg : LineSegment) (t s : ℚ)
    (heq1 : t * r.direction.x + s * (seg.p1.x - seg.p2.x) = seg.p1.x - r.origin.x)
    (heq2 : t * r.direction.y + s * (seg.p1.y - seg.p2.y) = seg.p1.y - r.origin.y) :
    s * raySegDet r seg = raySegSNum r seg := by
  show s * (r.direction.x * (seg.p1.y - seg.p2.y) - r.direction.y * (seg.p1.x - seg.p2.x)) =
    r.direction.x * (seg.p1.y - r.origin.y) - r.direction.y * (seg.p1.x - r.origin.x)
  linear_combination (-r.direction.y) * heq1 + r.direction.x * heq2

