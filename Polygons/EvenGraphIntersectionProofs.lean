import Polygons.EvenGraphRefinement
import Polygons.EvenGraphCharacterization

/-!
# Even Graph Intersection – Implementation

Given two even graphs G₁ and G₂ whose boundaries intersect finitely:
1. Refine each graph with respect to the other so every segment is either
   completely inside or completely outside the other graph's interior.
2. Select the segments from each refined graph that lie inside the other
   graph's interior — this is the **intersection graph**.
3. Prove that the ray-crossing parity for the intersection graph is odd
   if and only if it is odd for both input graphs, via an elementary
   pair-counting argument over ray-crossing parameters (`Σ f + Σ g = n₁·n₂`
   under no-ties), combined with sub-ray parity invariance and the
   connectivity of `segmentOpenInteriorSubset` across G₂.interior.
4. Conclude that the ray-parity interior of the intersection graph equals
   `G₁.interior ∩ G₂.interior`.
-/

open Classical Set

noncomputable section

namespace EvenGraphIntersectionProofs

/-- Flip the order of the intersection in a finiteness hypothesis on a pair of
    even-graph boundaries. Used so that public APIs only need to take the
    `G1 ∩ G2` finiteness hypothesis. -/
lemma flipFin {G1 G2 : EvenGraph}
    (h_fin12 : Set.Finite (G1.toBoundarySet ∩ G2.toBoundarySet)) :
    Set.Finite (G2.toBoundarySet ∩ G1.toBoundarySet) := by
  rw [Set.inter_comm]; exact h_fin12

/-! ### Internal scaffolding for the intersection-graph proofs

The user-facing definition of the intersection graph lives at the top of the
hierarchy in `EvenGraphIntersection.lean` as `evenGraphIntersection`. The
helpers below are the same construction in list form, used only as
proof scaffolding inside this file. They are kept `private` so they cannot be
mistaken for the public API. -/

/-- Internal scaffolding: list of segments of the intersection graph. -/
def intersectionSegments (G1 G2 : EvenGraph)
    (h_fin12 : Set.Finite (G1.toBoundarySet ∩ G2.toBoundarySet))
    (h_fin21 : Set.Finite (G2.toBoundarySet ∩ G1.toBoundarySet)) :
    List LineSegment :=
  selectSegmentsInside (graphRefinementSelfAndWrt G1 G2 h_fin12).segments G2.interior ++
    selectSegmentsInside (graphRefinementSelfAndWrt G2 G1 h_fin21).segments G1.interior

/-- Internal scaffolding: ray-crossing count for the intersection graph. -/
noncomputable def intersectionRayCount (r : Ray) (G1 G2 : EvenGraph)
    (h_fin12 : Set.Finite (G1.toBoundarySet ∩ G2.toBoundarySet))
    (h_fin21 : Set.Finite (G2.toBoundarySet ∩ G1.toBoundarySet)) : ℕ :=
  (intersectionSegments G1 G2 h_fin12 h_fin21).countP
    fun seg => decide (rayIntersectsSegment r seg)

/-- Internal scaffolding: ray-parity interior of the intersection graph. -/
def intersectionInterior (G1 G2 : EvenGraph)
    (h_fin12 : Set.Finite (G1.toBoundarySet ∩ G2.toBoundarySet))
    (h_fin21 : Set.Finite (G2.toBoundarySet ∩ G1.toBoundarySet)) :
    Set Vector2D :=
  { p : Vector2D |
    (∀ seg ∈ (graphRefinementSelfAndWrt G1 G2 h_fin12).segments, pointAvoidsSegment p seg) ∧
    (∀ seg ∈ (graphRefinementSelfAndWrt G2 G1 h_fin21).segments, pointAvoidsSegment p seg) ∧
    ∀ r : Ray, r.origin = p →
      rayAvoidsGraphVertices r (graphRefinementSelfAndWrt G1 G2 h_fin12) →
      rayAvoidsGraphVertices r (graphRefinementSelfAndWrt G2 G1 h_fin21) →
      intersectionRayCount r G1 G2 h_fin12 h_fin21 % 2 = 1 }

/-- Internal scaffolding: ∃-ray version of the ray-parity interior of the
    intersection graph. Same avoidance conditions on `p` but only requires
    the existence of one ray (avoiding both refined graph vertices) with
    odd intersection-graph parity. -/
def intersectionInteriorExists (G1 G2 : EvenGraph)
    (h_fin12 : Set.Finite (G1.toBoundarySet ∩ G2.toBoundarySet))
    (h_fin21 : Set.Finite (G2.toBoundarySet ∩ G1.toBoundarySet)) :
    Set Vector2D :=
  { p : Vector2D |
    (∀ seg ∈ (graphRefinementSelfAndWrt G1 G2 h_fin12).segments, pointAvoidsSegment p seg) ∧
    (∀ seg ∈ (graphRefinementSelfAndWrt G2 G1 h_fin21).segments, pointAvoidsSegment p seg) ∧
    ∃ r : Ray, r.origin = p ∧
      rayAvoidsGraphVertices r (graphRefinementSelfAndWrt G1 G2 h_fin12) ∧
      rayAvoidsGraphVertices r (graphRefinementSelfAndWrt G2 G1 h_fin21) ∧
      intersectionRayCount r G1 G2 h_fin12 h_fin21 % 2 = 1 }

/-! ### Helper lemmas -/

/-- Not on boundary of refined graph ↔ not on boundary of original graph. -/
lemma not_boundary_refined_iff
    (p : Vector2D) (G1 G2 : EvenGraph)
    (h_fin : Set.Finite (G1.toBoundarySet ∩ G2.toBoundarySet)) :
    p ∉ (graphRefinementSelfAndWrt G1 G2 h_fin).toBoundarySet ↔ p ∉ G1.toBoundarySet := by
  rw [graphRefinementSelfAndWrt_boundary_eq]

/-- Boundary avoidance for refined graph ↔ boundary avoidance for original. -/
lemma avoids_refined_iff_avoids_original
    (p : Vector2D) (G1 G2 : EvenGraph)
    (h_fin : Set.Finite (G1.toBoundarySet ∩ G2.toBoundarySet)) :
    (∀ seg ∈ (graphRefinementSelfAndWrt G1 G2 h_fin).segments, pointAvoidsSegment p seg) ↔
    (∀ seg ∈ G1.segments, pointAvoidsSegment p seg) := by
  have h_bnd := graphRefinementSelfAndWrt_boundary_eq G1 G2 h_fin
  constructor <;> intro h seg hmem h_on
  · have : p ∈ G1.toBoundarySet := ⟨seg, hmem, h_on⟩
    rw [← h_bnd] at this
    obtain ⟨seg', hmem', hin'⟩ := this
    exact h seg' hmem' hin'
  · have : p ∈ (graphRefinementSelfAndWrt G1 G2 h_fin).toBoundarySet := ⟨seg, hmem, h_on⟩
    rw [h_bnd] at this
    obtain ⟨seg', hmem', hin'⟩ := this
    exact h seg' hmem' hin'

/-- Given a point that is not a vertex of either refined graph, there exists
    a ray from it avoiding the vertices of both refined graphs. -/
lemma exists_ray_avoiding_both_vertices
    (p : Vector2D)
    (G1' G2' : EvenGraph)
    (h_not_vertex : ∀ v ∈ G1'.toVertices ++ G2'.toVertices, v ≠ p) :
    ∃ r : Ray, r.origin = p ∧
      rayAvoidsGraphVertices r G1' ∧ rayAvoidsGraphVertices r G2' := by
  have h_inf : Infinite ℚ := Infinite.of_injective (fun n : ℕ => (n : ℚ)) Nat.cast_injective
  let allVerts := G1'.toVertices ++ G2'.toVertices
  let badSlopes : Finset ℚ := (allVerts.filterMap fun v =>
    if v.x > p.x then some ((v.y - p.y) / (v.x - p.x)) else none).toFinset
  obtain ⟨q, hq⟩ := Finset.exists_not_mem badSlopes
  have h_nonzero : (⟨1, q⟩ : Vector2D) ≠ ⟨0, 0⟩ := by
    intro h; exact absurd (congrArg Vector2D.x h) (by norm_num)
  refine ⟨⟨p, ⟨1, q⟩, h_nonzero⟩, rfl, ?_, ?_⟩ <;> {
    rw [rayAvoidsGraphVertices, Set.eq_empty_iff_forall_not_mem]
    intro v hv
    simp only [Set.mem_inter_iff, Ray.toSet, Graph.toVertexSet,
      Set.mem_setOf_eq] at hv
    obtain ⟨⟨t, ht_nonneg, hvx, hvy⟩, hv_vert⟩ := hv
    simp only [mul_one] at hvx
    have hv_all : v ∈ allVerts := by
      simp only [allVerts, List.mem_append]
      first | left; exact hv_vert | right; exact hv_vert
    have hne : v ≠ p := h_not_vertex v hv_all
    have ht_eq : t = v.x - p.x := by linarith
    by_cases h_gt : v.x > p.x
    · have h_slope_mem : (v.y - p.y) / (v.x - p.x) ∈ badSlopes := by
        simp only [badSlopes, List.mem_toFinset, List.mem_filterMap]
        exact ⟨v, hv_all, by simp [if_pos h_gt]⟩
      have hvmy : v.y - p.y = t * q := by linarith
      rw [ht_eq] at hvmy
      have hvx_ne : v.x - p.x ≠ 0 := ne_of_gt (by linarith : v.x - p.x > 0)
      have hq_eq : q = (v.y - p.y) / (v.x - p.x) := by
        rw [eq_div_iff hvx_ne, mul_comm]; linarith
      exact hq (hq_eq ▸ h_slope_mem)
    · push_neg at h_gt
      by_cases h_eq : v.x = p.x
      · have ht_zero : t = 0 := by linarith
        have hvy_eq : v.y = p.y := by
          have := hvy; rw [ht_zero] at this; simp at this; exact this
        exact hne (by cases v; cases p; simp_all)
      · linarith [lt_of_le_of_ne h_gt h_eq]
  }

/-- If p avoids all segments of a graph whose vertices all have positive degree,
    then p is not a vertex of that graph. -/
lemma not_vertex_of_avoids_segments (p : Vector2D) (G : EvenGraph)
    (h_pos : ∀ v ∈ G.toVertices,
      (G.segments.countP fun seg => seg.p1 = v ∨ seg.p2 = v) > 0)
    (h_avoids : ∀ seg ∈ G.segments, pointAvoidsSegment p seg)
    (v : Vector2D) (hv : v ∈ G.toVertices) : v ≠ p := by
  intro h_eq
  have ⟨seg, h_seg, h_pred⟩ := List.countP_pos_iff.mp (h_pos v hv)
  simp only [decide_eq_true_eq] at h_pred
  have h_on : v ∈ seg.toSet := by
    rcases h_pred with rfl | rfl
    · exact ⟨0, le_refl 0, zero_le_one, by ring, by ring⟩
    · exact ⟨1, zero_le_one, le_refl 1, by ring, by ring⟩
  exact h_avoids seg h_seg (h_eq ▸ h_on)

/-- If a vertex has positive degree, it lies on some segment of the graph. -/
lemma vertex_on_some_segment (G : EvenGraph) (v : Vector2D)
    (h_degree_pos : (G.segments.countP fun seg => seg.p1 = v ∨ seg.p2 = v) > 0) :
    ∃ seg ∈ G.segments, v ∈ seg.toSet := by
  have ⟨seg, h_mem, h_pred⟩ := List.countP_pos_iff.mp h_degree_pos
  simp only [decide_eq_true_eq] at h_pred
  refine ⟨seg, h_mem, ?_⟩
  rcases h_pred with rfl | rfl
  · exact ⟨0, le_refl 0, zero_le_one, by ring, by ring⟩
  · exact ⟨1, zero_le_one, le_refl 1, by ring, by ring⟩

/-- Any point not on a graph vertex admits a ray that avoids all vertices. -/
lemma exists_ray_avoiding_graph_verts (p : Vector2D) (G : EvenGraph)
    (h_not_vertex : ∀ v ∈ G.toVertices, v ≠ p) :
    ∃ r : Ray, r.origin = p ∧ rayAvoidsGraphVertices r G := by
  obtain ⟨r, h_orig, h_avoids, _⟩ :=
    exists_ray_avoiding_both_vertices p G G (by
      intro v hv
      rcases List.mem_append.mp hv with h | h
      · exact h_not_vertex v h
      · exact h_not_vertex v h)
  exact ⟨r, h_orig, h_avoids⟩

/-! ### Ray–segment crossing parameter -/

/-- The crossing parameter for a ray–segment intersection.
    Returns the parameter t ≥ 0 such that `r.origin + t * r.direction` lies on
    both the ray and the segment. When the ray avoids segment endpoints and is
    not collinear with the segment, this parameter is unique. -/
noncomputable def rayCrossingParam (r : Ray) (seg : LineSegment)
    (h : rayIntersectsSegment r seg) : ℚ :=
  h.choose_spec.1.choose

/-! #### Core geometric helper lemmas -/

/-- Auxiliary: `countP` distributes over `filter` — counting elements of a filtered
    list that satisfy Q equals counting elements that satisfy both predicates. -/
lemma countP_filter_eq {α : Type*} (P Q : α → Bool) (l : List α) :
    (l.filter P).countP Q = l.countP (fun x => P x && Q x) := by
  induction l with
  | nil => simp
  | cons a rest ih =>
    simp only [List.filter_cons]
    by_cases hP : P a = true
    · simp only [hP, ↓reduceIte, List.countP_cons, ih, Bool.true_and]
    · push_neg at hP
      simp only [Bool.not_eq_true] at hP
      simp [hP, ih]

/-- Core geometric fact: For a ray that avoids both refined graphs' vertices,
    the number of G₁'-segments that the ray crosses AND that lie inside G₂
    plus the number of G₂'-segments that the ray crosses AND that lie inside G₁
    equals `intersectionRayCount`.

    This follows directly from the definition of `intersectionRayCount` as
    `countP rayIntersects (selectSegmentsInside G1'.segs G2.int ++ selectSegmentsInside G2'.segs G1.int)`,
    using `List.countP_append` and the fact that `selectSegmentsInside` is `filter`. -/
lemma intersectionRayCount_eq_sum_inside_crossing_counts
    (r : Ray) (G1 G2 : EvenGraph)
    (h_fin12 : Set.Finite (G1.toBoundarySet ∩ G2.toBoundarySet))
    (h_fin21 : Set.Finite (G2.toBoundarySet ∩ G1.toBoundarySet)) :
    intersectionRayCount r G1 G2 h_fin12 h_fin21 =
      (selectSegmentsInside (graphRefinementSelfAndWrt G1 G2 h_fin12).segments G2.interior).countP
        (fun seg => decide (rayIntersectsSegment r seg)) +
      (selectSegmentsInside (graphRefinementSelfAndWrt G2 G1 h_fin21).segments G1.interior).countP
        (fun seg => decide (rayIntersectsSegment r seg)) := by
  simp only [intersectionRayCount, intersectionSegments, List.countP_append]

/-! #### Ray parameter extraction and sub-ray construction -/

/-- The crossing point of a ray and segment (chosen via classical choice). -/
noncomputable def rayCrossingPoint (r : Ray) (seg : LineSegment)
    (h : rayIntersectsSegment r seg) : Vector2D := h.choose

lemma rayCrossingPoint_mem_ray (r : Ray) (seg : LineSegment)
    (h : rayIntersectsSegment r seg) :
    rayCrossingPoint r seg h ∈ r.toSet := h.choose_spec.1

lemma rayCrossingPoint_mem_seg (r : Ray) (seg : LineSegment)
    (h : rayIntersectsSegment r seg) :
    rayCrossingPoint r seg h ∈ seg.toSet := h.choose_spec.2

lemma rayCrossingParam_nonneg (r : Ray) (seg : LineSegment)
    (h : rayIntersectsSegment r seg) :
    0 ≤ rayCrossingParam r seg h :=
  h.choose_spec.1.choose_spec.1

lemma rayCrossingPoint_x (r : Ray) (seg : LineSegment)
    (h : rayIntersectsSegment r seg) :
    (rayCrossingPoint r seg h).x =
      r.origin.x + rayCrossingParam r seg h * r.direction.x :=
  h.choose_spec.1.choose_spec.2.1

lemma rayCrossingPoint_y (r : Ray) (seg : LineSegment)
    (h : rayIntersectsSegment r seg) :
    (rayCrossingPoint r seg h).y =
      r.origin.y + rayCrossingParam r seg h * r.direction.y :=
  h.choose_spec.1.choose_spec.2.2

/-- Sub-ray starting at `r.origin + t₀ * r.direction`, same direction as `r`. -/
def subRay (r : Ray) (t₀ : ℚ) : Ray :=
  ⟨⟨r.origin.x + t₀ * r.direction.x, r.origin.y + t₀ * r.direction.y⟩,
   r.direction, r.direction_nonzero⟩

lemma subRay_toSet_mem_iff (r : Ray) (t₀ : ℚ) (p : Vector2D) :
    p ∈ (subRay r t₀).toSet ↔ ∃ s : ℚ, 0 ≤ s ∧
      p.x = r.origin.x + (t₀ + s) * r.direction.x ∧
      p.y = r.origin.y + (t₀ + s) * r.direction.y := by
  constructor
  · rintro ⟨s, hs, hx, hy⟩
    refine ⟨s, hs, ?_, ?_⟩
    · show p.x = r.origin.x + (t₀ + s) * r.direction.x
      rw [hx]; show r.origin.x + t₀ * r.direction.x + s * r.direction.x = _; ring
    · show p.y = r.origin.y + (t₀ + s) * r.direction.y
      rw [hy]; show r.origin.y + t₀ * r.direction.y + s * r.direction.y = _; ring
  · rintro ⟨s, hs, hx, hy⟩
    refine ⟨s, hs, ?_, ?_⟩
    · show p.x = r.origin.x + t₀ * r.direction.x + s * r.direction.x
      rw [hx]; ring
    · show p.y = r.origin.y + t₀ * r.direction.y + s * r.direction.y
      rw [hy]; ring

lemma subRay_toSet_subset (r : Ray) (t₀ : ℚ) (ht₀ : 0 ≤ t₀) :
    (subRay r t₀).toSet ⊆ r.toSet := by
  intro p hp
  rw [subRay_toSet_mem_iff] at hp
  obtain ⟨s, hs, hx, hy⟩ := hp
  exact ⟨t₀ + s, by linarith, hx, hy⟩

/-- Ray self-injectivity: if two parameters give the same point, they're equal. -/
lemma ray_param_inj (r : Ray) (t u : ℚ)
    (hx : r.origin.x + t * r.direction.x = r.origin.x + u * r.direction.x)
    (hy : r.origin.y + t * r.direction.y = r.origin.y + u * r.direction.y) :
    t = u := by
  have hdx : (t - u) * r.direction.x = 0 := by linarith
  have hdy : (t - u) * r.direction.y = 0 := by linarith
  rcases mul_eq_zero.mp hdx with h | h
  · linarith
  · rcases mul_eq_zero.mp hdy with h' | h'
    · linarith
    · exact absurd ((Vector2D.mk.injEq _ _ _ _).mpr ⟨h, h'⟩) r.direction_nonzero

/-- If `rayIntersectsSegment r seg`, the point on the ray at parameter
    `rayCrossingParam r seg h` lies on `seg`. -/
lemma rayCrossingParam_point_mem_seg (r : Ray) (seg : LineSegment)
    (h : rayIntersectsSegment r seg) :
    (⟨r.origin.x + rayCrossingParam r seg h * r.direction.x,
       r.origin.y + rayCrossingParam r seg h * r.direction.y⟩ : Vector2D) ∈ seg.toSet := by
  have h_pt_on_seg := rayCrossingPoint_mem_seg r seg h
  have h_eq : (⟨r.origin.x + rayCrossingParam r seg h * r.direction.x,
                 r.origin.y + rayCrossingParam r seg h * r.direction.y⟩ : Vector2D) =
              rayCrossingPoint r seg h := by
    ext
    · exact (rayCrossingPoint_x r seg h).symm
    · exact (rayCrossingPoint_y r seg h).symm
  rw [h_eq]
  exact h_pt_on_seg

/-- Ray-segment intersection via parameters: `rayIntersectsSegment r seg` iff
    there is some `t ≥ 0` whose point on the ray lies on the segment. -/
lemma rayIntersectsSegment_iff_exists_param (r : Ray) (seg : LineSegment) :
    rayIntersectsSegment r seg ↔ ∃ t : ℚ, 0 ≤ t ∧
      (⟨r.origin.x + t * r.direction.x,
         r.origin.y + t * r.direction.y⟩ : Vector2D) ∈ seg.toSet := by
  constructor
  · intro h
    refine ⟨rayCrossingParam r seg h, rayCrossingParam_nonneg r seg h, ?_⟩
    exact rayCrossingParam_point_mem_seg r seg h
  · rintro ⟨t, ht, hmem⟩
    refine ⟨⟨r.origin.x + t * r.direction.x, r.origin.y + t * r.direction.y⟩, ?_, hmem⟩
    exact ⟨t, ht, rfl, rfl⟩

/-- Sub-ray crosses segment iff there exists a ray parameter `≥ t₀` hitting the segment. -/
lemma subRay_crosses_iff (r : Ray) (t₀ : ℚ) (seg : LineSegment) :
    rayIntersectsSegment (subRay r t₀) seg ↔
    ∃ t : ℚ, t ≥ t₀ ∧
      (⟨r.origin.x + t * r.direction.x,
         r.origin.y + t * r.direction.y⟩ : Vector2D) ∈ seg.toSet := by
  rw [rayIntersectsSegment_iff_exists_param]
  constructor
  · rintro ⟨s, hs, hmem⟩
    refine ⟨t₀ + s, by linarith, ?_⟩
    convert hmem using 2
    · show r.origin.x + (t₀ + s) * r.direction.x =
          (subRay r t₀).origin.x + s * (subRay r t₀).direction.x
      show r.origin.x + (t₀ + s) * r.direction.x = r.origin.x + t₀ * r.direction.x + s * r.direction.x
      ring
    · show r.origin.y + (t₀ + s) * r.direction.y =
          (subRay r t₀).origin.y + s * (subRay r t₀).direction.y
      show r.origin.y + (t₀ + s) * r.direction.y = r.origin.y + t₀ * r.direction.y + s * r.direction.y
      ring
  · rintro ⟨t, ht, hmem⟩
    refine ⟨t - t₀, by linarith, ?_⟩
    convert hmem using 2
    · show (subRay r t₀).origin.x + (t - t₀) * (subRay r t₀).direction.x =
          r.origin.x + t * r.direction.x
      show r.origin.x + t₀ * r.direction.x + (t - t₀) * r.direction.x =
           r.origin.x + t * r.direction.x
      ring
    · show (subRay r t₀).origin.y + (t - t₀) * (subRay r t₀).direction.y =
          r.origin.y + t * r.direction.y
      show r.origin.y + t₀ * r.direction.y + (t - t₀) * r.direction.y =
           r.origin.y + t * r.direction.y
      ring

/-! #### Uniqueness of ray crossing parameter -/

/-- If a ray's origin is not on a segment, and the ray avoids both segment endpoints,
    then the ray's crossing parameter with the segment is unique:
    any `t ≥ 0` with the corresponding point on the segment equals `rayCrossingParam`. -/
lemma rayCrossingParam_unique (r : Ray) (seg : LineSegment)
    (h : rayIntersectsSegment r seg)
    (_h_origin : pointAvoidsSegment r.origin seg)
    (h_p1 : seg.p1 ∉ r.toSet) (h_p2 : seg.p2 ∉ r.toSet)
    (t : ℚ) (ht : 0 ≤ t)
    (hmem : (⟨r.origin.x + t * r.direction.x,
               r.origin.y + t * r.direction.y⟩ : Vector2D) ∈ seg.toSet) :
    t = rayCrossingParam r seg h := by
  -- Let t' = rayCrossingParam r seg h. Both t and t' correspond to points on seg.
  -- If t ≠ t', the line through r.origin + t * d and r.origin + t' * d is the ray's line,
  -- which would mean both segment endpoints are on this line — but endpoints off the ray
  -- combined with the segment endpoints being distinct leads to contradiction.
  set t' := rayCrossingParam r seg h with ht'_def
  have ht'_nn : 0 ≤ t' := rayCrossingParam_nonneg r seg h
  have hmem' : (⟨r.origin.x + t' * r.direction.x,
                 r.origin.y + t' * r.direction.y⟩ : Vector2D) ∈ seg.toSet :=
    rayCrossingParam_point_mem_seg r seg h
  -- Extract segment parameters s, s' for the two points
  obtain ⟨s, hs0, hs1, hsx, hsy⟩ := hmem
  obtain ⟨s', hs'0, hs'1, hs'x, hs'y⟩ := hmem'
  -- Goal: t = t'
  by_contra h_ne
  -- Suppose t ≠ t'. Then s ≠ s' (else points equal, so t = t' by ray_param_inj).
  have hs_ne_s' : s ≠ s' := by
    intro hs_eq
    apply h_ne
    apply ray_param_inj r t t'
    · -- hsx : ...x = (1-s)*p1.x + s*p2.x, hs'x : ...x = (1-s')*p1.x + s'*p2.x
      -- With s = s', both RHSs equal, so LHSs equal.
      have h1 : r.origin.x + t * r.direction.x = (1 - s) * seg.p1.x + s * seg.p2.x := hsx
      have h2 : r.origin.x + t' * r.direction.x = (1 - s') * seg.p1.x + s' * seg.p2.x := hs'x
      rw [hs_eq] at h1
      linarith
    · have h1 : r.origin.y + t * r.direction.y = (1 - s) * seg.p1.y + s * seg.p2.y := hsy
      have h2 : r.origin.y + t' * r.direction.y = (1 - s') * seg.p1.y + s' * seg.p2.y := hs'y
      rw [hs_eq] at h1
      linarith
  -- From the two equations, extract seg.p1 and seg.p2 in terms of r-parameters.
  -- hsx: r.o.x + t*r.d.x = (1-s)*seg.p1.x + s*seg.p2.x
  -- hs'x: r.o.x + t'*r.d.x = (1-s')*seg.p1.x + s'*seg.p2.x
  -- Subtract: (t - t')*r.d.x = (s - s')*(seg.p2.x - seg.p1.x)
  -- Similarly for y.
  have hdx : (t - t') * r.direction.x = (s - s') * (seg.p2.x - seg.p1.x) := by ring_linarith
  have hdy : (t - t') * r.direction.y = (s - s') * (seg.p2.y - seg.p1.y) := by ring_linarith
  -- Let α = (t - t')/(s - s'). Then (seg.p2.x - seg.p1.x, seg.p2.y - seg.p1.y) is parallel to r.direction.
  have hss_ne : s - s' ≠ 0 := sub_ne_zero.mpr hs_ne_s'
  set α := (t - t') / (s - s') with hα_def
  have hα_dx : seg.p2.x - seg.p1.x = α * r.direction.x := by
    rw [hα_def]
    field_simp
    linarith
  have hα_dy : seg.p2.y - seg.p1.y = α * r.direction.y := by
    rw [hα_def]
    field_simp
    linarith
  -- Now seg.p1 is at r-parameter t - s*α (from hsx), and seg.p2 at t - s*α + α = t + (1-s)*α.
  -- Or more directly: r.o + (t - s*α)*d = seg.p1, r.o + (t + (1-s)*α)*d = seg.p2.
  have h_p1_param : seg.p1 = ⟨r.origin.x + (t - s * α) * r.direction.x,
                              r.origin.y + (t - s * α) * r.direction.y⟩ := by
    ext
    · show seg.p1.x = r.origin.x + (t - s * α) * r.direction.x
      have : (1 - s) * seg.p1.x + s * seg.p2.x = r.origin.x + t * r.direction.x := by ring_linarith
      have hexp : s * (seg.p2.x - seg.p1.x) = s * α * r.direction.x := by
        rw [hα_dx]; ring
      have : seg.p1.x + s * α * r.direction.x = r.origin.x + t * r.direction.x := by linarith
      linarith
    · show seg.p1.y = r.origin.y + (t - s * α) * r.direction.y
      have : (1 - s) * seg.p1.y + s * seg.p2.y = r.origin.y + t * r.direction.y := by ring_linarith
      have hexp : s * (seg.p2.y - seg.p1.y) = s * α * r.direction.y := by
        rw [hα_dy]; ring
      have : seg.p1.y + s * α * r.direction.y = r.origin.y + t * r.direction.y := by linarith
      linarith
  have h_p2_param : seg.p2 = ⟨r.origin.x + (t + (1 - s) * α) * r.direction.x,
                              r.origin.y + (t + (1 - s) * α) * r.direction.y⟩ := by
    ext
    · show seg.p2.x = r.origin.x + (t + (1 - s) * α) * r.direction.x
      have hsx' : (1 - s) * seg.p1.x + s * seg.p2.x = r.origin.x + t * r.direction.x := by ring_linarith
      have hexp : (1 - s) * (seg.p2.x - seg.p1.x) = (1 - s) * α * r.direction.x := by
        rw [hα_dx]; ring
      have : seg.p2.x - (1 - s) * α * r.direction.x = r.origin.x + t * r.direction.x := by linarith
      linarith
    · show seg.p2.y = r.origin.y + (t + (1 - s) * α) * r.direction.y
      have hsy' : (1 - s) * seg.p1.y + s * seg.p2.y = r.origin.y + t * r.direction.y := by ring_linarith
      have hexp : (1 - s) * (seg.p2.y - seg.p1.y) = (1 - s) * α * r.direction.y := by
        rw [hα_dy]; ring
      have : seg.p2.y - (1 - s) * α * r.direction.y = r.origin.y + t * r.direction.y := by linarith
      linarith
  -- Since seg.p1 ∉ r.toSet and seg.p2 ∉ r.toSet, their r-parameters must be negative.
  have h_p1_neg : t - s * α < 0 := by
    by_contra hn
    push_neg at hn
    apply h_p1
    refine ⟨t - s * α, hn, ?_, ?_⟩ <;>
    · rw [h_p1_param]
  have h_p2_neg : t + (1 - s) * α < 0 := by
    by_contra hn
    push_neg at hn
    apply h_p2
    refine ⟨t + (1 - s) * α, hn, ?_, ?_⟩ <;>
    · rw [h_p2_param]
  -- But then r.origin is at seg-parameter s/(s-1+s) ... actually we derive contradiction
  -- via origin avoiding seg.
  -- From h_p1_neg and h_p2_neg, we have t < s*α and t < -(1-s)*α, i.e., t < s*α and t < (s-1)*α.
  -- Case analysis on sign of α (nonzero by s ≠ s').
  have hα_ne : α ≠ 0 := by
    intro hα_zero
    have ht_eq : t = t' := by
      simp [hα_def, div_eq_zero_iff, hss_ne] at hα_zero
      exact sub_eq_zero.mp hα_zero
    exact h_ne ht_eq
  -- The ray parameter for the origin-to-origin: r.origin is at r-param 0.
  -- Points at param < 0 on the line: seg.p1 and seg.p2.
  -- Point at param 0: r.origin.
  -- Since seg.p1 and seg.p2 are both at negative r-param, and s ∈ [0, 1],
  -- the point at seg-param s (which is r.o + t*d with t ≥ 0) cannot be on seg UNLESS
  -- α has specific sign properties. Let me show origin is on the seg line by
  -- interpolating between p1 and p2 at seg-param t / (t - (t + (1-s)*α + ... )).
  -- Actually simpler: the point r.origin = ⟨r.o.x, r.o.y⟩ = ⟨r.o.x + 0 * d.x, r.o.y + 0 * d.y⟩
  -- is at r-parameter 0. We have seg.p1 at r-param u₁ := t - s*α < 0 and
  -- seg.p2 at r-param u₂ := t + (1-s)*α < 0.
  -- If u₁ and u₂ are both negative, then 0 is not between them (since both < 0).
  -- So the seg doesn't cross r-param 0, meaning origin is NOT on seg. But wait, that
  -- aligns with h_origin, no contradiction yet.
  -- Hmm, we need a contradiction somehow. Let me reconsider.
  -- Actually the contradiction comes from: point at r-param t (with 0 ≤ t) is on seg.
  -- Seg = line through p1, p2. Seg's r-parameters range between u₁ and u₂ (both < 0).
  -- But t ≥ 0, and we also need t = (1-s)*u₁ + s*u₂ for the seg-param to give t.
  -- Let me check this interpolation:
  -- seg-param s gives point (1-s)*p1 + s*p2.
  -- p1 at r-param u₁, p2 at r-param u₂.
  -- (1-s)*p1 + s*p2 at r-param (1-s)*u₁ + s*u₂ (by linearity in r-param of line).
  -- We have this equal to r.o + t*d, so r-param is t.
  -- So t = (1-s)*u₁ + s*u₂. But u₁, u₂ < 0 and s ∈ [0,1], so (1-s)*u₁ + s*u₂ < 0.
  -- Contradiction with t ≥ 0.
  have h_param_interp : t = (1 - s) * (t - s * α) + s * (t + (1 - s) * α) := by ring
  have hu1_neg : t - s * α < 0 := h_p1_neg
  have hu2_neg : t + (1 - s) * α < 0 := h_p2_neg
  have h_conv_neg : (1 - s) * (t - s * α) + s * (t + (1 - s) * α) < 0 := by
    have h_1s : 0 ≤ 1 - s := by linarith
    have hs_nn : 0 ≤ s := hs0
    by_cases hs_one : s = 1
    · subst hs_one
      have : (1 - 1 : ℚ) * (t - 1 * α) + 1 * (t + (1 - 1) * α) = t := by ring
      linarith
    · by_cases hs_zero : s = 0
      · subst hs_zero
        have : (1 - 0 : ℚ) * (t - 0 * α) + 0 * (t + (1 - 0) * α) = t := by ring
        linarith
      · have hs_pos : 0 < s := lt_of_le_of_ne hs_nn (Ne.symm hs_zero)
        have h1s_pos : 0 < 1 - s := lt_of_le_of_ne h_1s (fun h => hs_one (by linarith))
        nlinarith
  linarith [h_param_interp.symm ▸ h_conv_neg, ht]

/-! #### Crossing point avoids the other graph's boundary -/

/-- For any segment of a refined graph crossed by a vertex-avoiding ray, the crossing point
    lies in the open interior of the segment. -/
lemma rayCrossingPoint_not_endpoint
    (r : Ray) (G : EvenGraph)
    (seg : LineSegment) (hseg : seg ∈ G.segments)
    (h_avoids : rayAvoidsGraphVertices r G)
    (h : rayIntersectsSegment r seg) :
    rayCrossingPoint r seg h ≠ seg.p1 ∧ rayCrossingPoint r seg h ≠ seg.p2 := by
  refine ⟨?_, ?_⟩
  · intro heq
    have h_on_ray := rayCrossingPoint_mem_ray r seg h
    have h_p1_on_ray : seg.p1 ∈ r.toSet := heq ▸ h_on_ray
    have h_p1_vert : seg.p1 ∈ G.toVertices := (G.segments_endpoints seg hseg).1
    have : seg.p1 ∈ r.toSet ∩ G.toVertexSet := ⟨h_p1_on_ray, h_p1_vert⟩
    rw [h_avoids] at this
    exact this
  · intro heq
    have h_on_ray := rayCrossingPoint_mem_ray r seg h
    have h_p2_on_ray : seg.p2 ∈ r.toSet := heq ▸ h_on_ray
    have h_p2_vert : seg.p2 ∈ G.toVertices := (G.segments_endpoints seg hseg).2
    have : seg.p2 ∈ r.toSet ∩ G.toVertexSet := ⟨h_p2_on_ray, h_p2_vert⟩
    rw [h_avoids] at this
    exact this

/-- For any G1' segment crossed by a ray that avoids G1' vertices, the crossing point is not
    in G2's boundary set (by the refinement property). -/
lemma crossingPoint_avoids_other_boundary
    (r : Ray) (G1 G2 : EvenGraph)
    (h_fin12 : Set.Finite (G1.toBoundarySet ∩ G2.toBoundarySet))
    (s₁ : LineSegment) (hs₁ : s₁ ∈ (graphRefinementSelfAndWrt G1 G2 h_fin12).segments)
    (h_avoids : rayAvoidsGraphVertices r (graphRefinementSelfAndWrt G1 G2 h_fin12))
    (h_int : rayIntersectsSegment r s₁) :
    rayCrossingPoint r s₁ h_int ∉ G2.toBoundarySet := by
  intro h_mem
  have h_on_s₁ := rayCrossingPoint_mem_seg r s₁ h_int
  have h_subset := graphRefinementSelfAndWrt_seg_inter_boundary_subset G1 G2 h_fin12 s₁ hs₁
  have h_ne := rayCrossingPoint_not_endpoint r _ s₁ hs₁ h_avoids h_int
  have hmem_pair : rayCrossingPoint r s₁ h_int ∈ ({s₁.p1, s₁.p2} : Set Vector2D) :=
    h_subset ⟨h_on_s₁, h_mem⟩
  simp only [Set.mem_insert_iff, Set.mem_singleton_iff] at hmem_pair
  rcases hmem_pair with h | h
  · exact h_ne.1 h
  · exact h_ne.2 h

/-! #### Sub-ray cross count equals past-param count -/

/-- If the origin of a sub-ray is not on any segment of `G`, then the sub-ray's crossing
    count of `G` equals the count of `G`-segments crossed by the original ray at parameter
    strictly greater than `t₀`. -/
lemma subRay_count_eq_past_count
    (r : Ray) (t₀ : ℚ) (G : EvenGraph)
    (h_p₀_not : (⟨r.origin.x + t₀ * r.direction.x,
                   r.origin.y + t₀ * r.direction.y⟩ : Vector2D) ∉ G.toBoundarySet) :
    intersectionRayGraphSegmentsNumber (subRay r t₀) G =
    G.segments.countP (fun s => decide (∃ t : ℚ, t > t₀ ∧
      (⟨r.origin.x + t * r.direction.x,
         r.origin.y + t * r.direction.y⟩ : Vector2D) ∈ s.toSet)) := by
  unfold intersectionRayGraphSegmentsNumber
  apply List.countP_congr
  intro s hs
  have h_p_not_s : (⟨r.origin.x + t₀ * r.direction.x,
                    r.origin.y + t₀ * r.direction.y⟩ : Vector2D) ∉ s.toSet := by
    intro h_on_s
    exact h_p₀_not ⟨s, hs, h_on_s⟩
  have h_iff : rayIntersectsSegment (subRay r t₀) s ↔
      ∃ t : ℚ, t > t₀ ∧
        (⟨r.origin.x + t * r.direction.x,
           r.origin.y + t * r.direction.y⟩ : Vector2D) ∈ s.toSet := by
    rw [subRay_crosses_iff]
    constructor
    · rintro ⟨t, ht_ge, hmem⟩
      refine ⟨t, ?_, hmem⟩
      rcases lt_or_eq_of_le ht_ge with h_lt | h_eq
      · exact h_lt
      · exfalso; apply h_p_not_s
        have h_point_eq :
            (⟨r.origin.x + t₀ * r.direction.x, r.origin.y + t₀ * r.direction.y⟩ : Vector2D) =
            ⟨r.origin.x + t * r.direction.x, r.origin.y + t * r.direction.y⟩ := by
          ext
          · show r.origin.x + t₀ * r.direction.x = r.origin.x + t * r.direction.x
            rw [h_eq]
          · show r.origin.y + t₀ * r.direction.y = r.origin.y + t * r.direction.y
            rw [h_eq]
        rw [h_point_eq]; exact hmem
    · rintro ⟨t, ht_gt, hmem⟩
      exact ⟨t, le_of_lt ht_gt, hmem⟩
  simp only [decide_eq_true_iff]
  exact h_iff

/-! #### The point-inside-interior ↔ odd sub-ray count equivalence -/

/-- If a ray's origin avoids the segments of `G` and the ray avoids `G`'s vertices, then
    the origin is in `G.interior` iff the ray has odd crossing count. -/
lemma point_in_interior_iff_odd_count
    (r : Ray) (G : EvenGraph)
    (h_origin_avoids : ∀ seg ∈ G.segments, pointAvoidsSegment r.origin seg)
    (h_r_avoids_verts : rayAvoidsGraphVertices r G) :
    r.origin ∈ G.interior ↔ intersectionRayGraphSegmentsNumber r G % 2 = 1 := by
  constructor
  · intro h_int
    exact h_int.2 r rfl h_r_avoids_verts
  · intro h_odd
    refine ⟨h_origin_avoids, fun r' h_origin' h_avoids' => ?_⟩
    have h_same : sameOrigin r r' := by simp [sameOrigin, h_origin']
    have h_origin_avoids' : ∀ seg ∈ G.segments, pointAvoidsSegment r.origin seg :=
      h_origin_avoids
    have h_eq := intersectionParity_eq_of_sameOrigin_avoidsGraphVertices
      r r' G h_same h_r_avoids_verts h_avoids' h_origin_avoids'
    linarith

/-! #### Connectivity: segment inside iff crossing point inside -/

/-- If two points lie in the open interior of a segment, the line segment between them
    is contained in that open interior. -/
lemma segment_in_open_interior
    (seg : LineSegment) (p q : Vector2D)
    (hp : p ∈ seg.toSet) (hp1 : p ≠ seg.p1) (hp2 : p ≠ seg.p2)
    (hq : q ∈ seg.toSet) (hq1 : q ≠ seg.p1) (hq2 : q ≠ seg.p2)
    (x : Vector2D) (hx : x ∈ (LineSegment.mk p q).toSet) :
    x ∈ seg.toSet ∧ x ≠ seg.p1 ∧ x ≠ seg.p2 := by
  obtain ⟨sp, hsp0, hsp1, hspx, hspy⟩ := hp
  obtain ⟨sq, hsq0, hsq1, hsqx, hsqy⟩ := hq
  obtain ⟨u, hu0, hu1, hux, huy⟩ := hx
  set s := (1 - u) * sp + u * sq with hs_def
  have hs0 : 0 ≤ s := by rw [hs_def]; nlinarith
  have hs1 : s ≤ 1 := by rw [hs_def]; nlinarith
  have hxx : x.x = (1 - s) * seg.p1.x + s * seg.p2.x := by
    rw [hux, hspx, hsqx, hs_def]; ring
  have hxy : x.y = (1 - s) * seg.p1.y + s * seg.p2.y := by
    rw [huy, hspy, hsqy, hs_def]; ring
  have hx_mem : x ∈ seg.toSet := ⟨s, hs0, hs1, hxx, hxy⟩
  -- Auxiliary: case when seg is degenerate (p1 = p2)
  by_cases h_deg : seg.p1 = seg.p2
  · -- seg.p1 = seg.p2, so every point on seg equals seg.p1. But hp1 says p ≠ seg.p1.
    exfalso
    have h_p1p2_x : seg.p2.x = seg.p1.x := by rw [h_deg]
    have h_p1p2_y : seg.p2.y = seg.p1.y := by rw [h_deg]
    apply hp1
    ext
    · rw [hspx, h_p1p2_x]; ring
    · rw [hspy, h_p1p2_y]; ring
  · refine ⟨hx_mem, ?_, ?_⟩
    · intro hx_eq
      -- x = seg.p1 → s = 0 (via (seg.p2 - seg.p1) ≠ 0 or otherwise)
      -- But s > 0 since sp, sq > 0.
      have hsp_pos : 0 < sp := by
        rcases lt_or_eq_of_le hsp0 with h | h
        · exact h
        · exfalso; apply hp1; ext
          · show p.x = seg.p1.x; rw [hspx, ← h]; ring
          · show p.y = seg.p1.y; rw [hspy, ← h]; ring
      have hsq_pos : 0 < sq := by
        rcases lt_or_eq_of_le hsq0 with h | h
        · exact h
        · exfalso; apply hq1; ext
          · show q.x = seg.p1.x; rw [hsqx, ← h]; ring
          · show q.y = seg.p1.y; rw [hsqy, ← h]; ring
      have hs_pos : 0 < s := by
        rw [hs_def]
        by_cases hu_one : u = 1
        · rw [hu_one]; linarith
        · have h1u_pos : 0 < 1 - u := by
            rcases lt_or_eq_of_le hu1 with h | h
            · linarith
            · exfalso; exact hu_one h
          nlinarith
      have hxx_eq : seg.p1.x = (1 - s) * seg.p1.x + s * seg.p2.x := by
        rw [← hxx]; exact (congrArg Vector2D.x hx_eq).symm
      have hxy_eq : seg.p1.y = (1 - s) * seg.p1.y + s * seg.p2.y := by
        rw [← hxy]; exact (congrArg Vector2D.y hx_eq).symm
      have hdx : s * (seg.p2.x - seg.p1.x) = 0 := by linarith
      have hdy : s * (seg.p2.y - seg.p1.y) = 0 := by linarith
      have hs_ne : s ≠ 0 := ne_of_gt hs_pos
      have hpx_eq : seg.p2.x = seg.p1.x := by
        rcases mul_eq_zero.mp hdx with h | h
        · exact absurd h hs_ne
        · linarith
      have hpy_eq : seg.p2.y = seg.p1.y := by
        rcases mul_eq_zero.mp hdy with h | h
        · exact absurd h hs_ne
        · linarith
      apply h_deg
      ext
      · rw [hpx_eq]
      · rw [hpy_eq]
    · intro hx_eq
      have hsp_lt : sp < 1 := by
        rcases lt_or_eq_of_le hsp1 with h | h
        · exact h
        · exfalso; apply hp2; ext
          · show p.x = seg.p2.x; rw [hspx, h]; ring
          · show p.y = seg.p2.y; rw [hspy, h]; ring
      have hsq_lt : sq < 1 := by
        rcases lt_or_eq_of_le hsq1 with h | h
        · exact h
        · exfalso; apply hq2; ext
          · show q.x = seg.p2.x; rw [hsqx, h]; ring
          · show q.y = seg.p2.y; rw [hsqy, h]; ring
      have hs_lt : s < 1 := by
        rw [hs_def]
        by_cases hu_zero : u = 0
        · rw [hu_zero]; linarith
        · have hu_pos : 0 < u := lt_of_le_of_ne hu0 (Ne.symm hu_zero)
          nlinarith
      have hxx_eq : seg.p2.x = (1 - s) * seg.p1.x + s * seg.p2.x := by
        rw [← hxx]; exact (congrArg Vector2D.x hx_eq).symm
      have hxy_eq : seg.p2.y = (1 - s) * seg.p1.y + s * seg.p2.y := by
        rw [← hxy]; exact (congrArg Vector2D.y hx_eq).symm
      have hdx : (1 - s) * (seg.p2.x - seg.p1.x) = 0 := by linarith
      have hdy : (1 - s) * (seg.p2.y - seg.p1.y) = 0 := by linarith
      have h1s_ne : (1 - s) ≠ 0 := by intro heq; linarith
      have hpx_eq : seg.p2.x = seg.p1.x := by
        rcases mul_eq_zero.mp hdx with h | h
        · exact absurd h h1s_ne
        · linarith
      have hpy_eq : seg.p2.y = seg.p1.y := by
        rcases mul_eq_zero.mp hdy with h | h
        · exact absurd h h1s_ne
        · linarith
      apply h_deg
      ext
      · rw [hpx_eq]
      · rw [hpy_eq]

/-- Connectivity: if two points lie in the open interior of a G1'-segment, they have the
    same G2-interior status, provided all G2' vertices are on G2's boundary (positive degree). -/
lemma same_G2_interior_status_on_segment
    (G1 G2 : EvenGraph)
    (h_fin12 : Set.Finite (G1.toBoundarySet ∩ G2.toBoundarySet))
    (h_fin21 : Set.Finite (G2.toBoundarySet ∩ G1.toBoundarySet))
    (h_pos2 : ∀ v ∈ (graphRefinementSelfAndWrt G2 G1 h_fin21).toVertices,
      ((graphRefinementSelfAndWrt G2 G1 h_fin21).segments.countP
        fun seg => seg.p1 = v ∨ seg.p2 = v) > 0)
    (s₁ : LineSegment) (hs₁ : s₁ ∈ (graphRefinementSelfAndWrt G1 G2 h_fin12).segments)
    (p q : Vector2D)
    (hp : p ∈ s₁.toSet) (hp1 : p ≠ s₁.p1) (hp2 : p ≠ s₁.p2)
    (hq : q ∈ s₁.toSet) (hq1 : q ≠ s₁.p1) (hq2 : q ≠ s₁.p2) :
    p ∈ G2.interior → q ∈ G2.interior := by
  intro hp_int
  -- Use graphRefinementSelfAndWrt_interior_eq G2 G1 : G2'.interior = G2.interior
  set G2' := graphRefinementSelfAndWrt G2 G1 h_fin21 with hG2'_def
  have h_int_eq : G2'.interior = G2.interior := graphRefinementSelfAndWrt_interior_eq G2 G1 h_fin21
  rw [← h_int_eq] at hp_int ⊢
  -- First show p and q both avoid G2' segments
  have h_bnd_eq : G2'.toBoundarySet = G2.toBoundarySet :=
    graphRefinementSelfAndWrt_boundary_eq G2 G1 h_fin21
  have h_open_disj : ∀ x ∈ s₁.toSet, x ≠ s₁.p1 → x ≠ s₁.p2 → x ∉ G2.toBoundarySet := by
    intro x hx hx1 hx2 h_mem
    have := graphRefinementSelfAndWrt_seg_inter_boundary_subset G1 G2 h_fin12 s₁ hs₁
      ⟨hx, h_mem⟩
    simp only [Set.mem_insert_iff, Set.mem_singleton_iff] at this
    rcases this with h | h
    · exact hx1 h
    · exact hx2 h
  have h_p_not_G2 : p ∉ G2.toBoundarySet := h_open_disj p hp hp1 hp2
  have h_q_not_G2 : q ∉ G2.toBoundarySet := h_open_disj q hq hq1 hq2
  have h_p_not_G2' : p ∉ G2'.toBoundarySet := by rw [h_bnd_eq]; exact h_p_not_G2
  have h_q_not_G2' : q ∉ G2'.toBoundarySet := by rw [h_bnd_eq]; exact h_q_not_G2
  have h_p_avoids_G2'_segs : ∀ seg ∈ G2'.segments, pointAvoidsSegment p seg := by
    intro seg hseg h_mem
    exact h_p_not_G2' ⟨seg, hseg, h_mem⟩
  have h_q_avoids_G2'_segs : ∀ seg ∈ G2'.segments, pointAvoidsSegment q seg := by
    intro seg hseg h_mem
    exact h_q_not_G2' ⟨seg, hseg, h_mem⟩
  refine ⟨h_q_avoids_G2'_segs, fun r_q h_r_q_origin h_r_q_avoids_verts => ?_⟩
  -- Now get a ray from p avoiding G2' vertices (which are ≠ p since they're in G2.boundary)
  have h_p_not_G2'_verts : ∀ v ∈ G2'.toVertices, v ≠ p := by
    intro v hv heq
    have h_v_on_seg : ∃ s ∈ G2'.segments, v ∈ s.toSet :=
      vertex_on_some_segment G2' v (h_pos2 v hv)
    obtain ⟨s, hs_mem, hs_v⟩ := h_v_on_seg
    have : p ∈ G2'.toBoundarySet := ⟨s, hs_mem, heq ▸ hs_v⟩
    exact h_p_not_G2' this
  -- Similarly q
  have h_q_not_G2'_verts : ∀ v ∈ G2'.toVertices, v ≠ q := by
    intro v hv heq
    have h_v_on_seg : ∃ s ∈ G2'.segments, v ∈ s.toSet :=
      vertex_on_some_segment G2' v (h_pos2 v hv)
    obtain ⟨s, hs_mem, hs_v⟩ := h_v_on_seg
    have : q ∈ G2'.toBoundarySet := ⟨s, hs_mem, heq ▸ hs_v⟩
    exact h_q_not_G2' this
  -- Get a ray from p avoiding G2' vertices
  obtain ⟨r_p, h_r_p_origin, h_r_p_avoids_verts⟩ :=
    exists_ray_avoiding_graph_verts p G2' h_p_not_G2'_verts
  -- Apply parity invariance for rays with origins on segment [p, q]
  -- First, show segment [p, q] avoids G2' segments and vertices
  have h_seg_pq_avoids : ∀ seg ∈ G2'.segments,
      segmentDoesNotIntersectSegment ⟨p, q⟩ seg := by
    intro seg hseg
    ext x
    simp only [Set.mem_inter_iff, Set.mem_empty_iff_false, iff_false, not_and]
    intro hx_pq hx_seg
    have ⟨hx_s₁, hx_ne_p1, hx_ne_p2⟩ := segment_in_open_interior s₁ p q
      hp hp1 hp2 hq hq1 hq2 x hx_pq
    have h_x_not_G2 : x ∉ G2.toBoundarySet := h_open_disj x hx_s₁ hx_ne_p1 hx_ne_p2
    have hx_G2' : x ∈ G2'.toBoundarySet := ⟨seg, hseg, hx_seg⟩
    have hx_G2 : x ∈ G2.toBoundarySet := h_bnd_eq ▸ hx_G2'
    exact h_x_not_G2 hx_G2
  have h_verts_avoid_pq : ∀ v ∈ G2'.toVertices,
      v ∉ (LineSegment.mk p q).toSet := by
    intro v hv hv_mem
    have h_v_on_seg : ∃ s ∈ G2'.segments, v ∈ s.toSet :=
      vertex_on_some_segment G2' v (h_pos2 v hv)
    obtain ⟨s, hs_mem, hs_v⟩ := h_v_on_seg
    have ⟨hv_s₁, hv_ne_p1, hv_ne_p2⟩ := segment_in_open_interior s₁ p q
      hp hp1 hp2 hq hq1 hq2 v hv_mem
    have h_v_not_G2 : v ∉ G2.toBoundarySet := h_open_disj v hv_s₁ hv_ne_p1 hv_ne_p2
    have hv_G2' : v ∈ G2'.toBoundarySet := ⟨s, hs_mem, hs_v⟩
    have hv_G2 : v ∈ G2.toBoundarySet := h_bnd_eq ▸ hv_G2'
    exact h_v_not_G2 hv_G2
  -- Fix r_p, r_q: r_p has origin p, r_q has origin q
  have h_r_p_orig : r_p.origin = p := h_r_p_origin
  have h_r_q_orig : r_q.origin = q := h_r_q_origin
  -- Segment from r_p.origin to r_q.origin is [p, q]
  have h_sego_avoids : ∀ seg ∈ G2'.segments,
      segmentDoesNotIntersectSegment ⟨r_p.origin, r_q.origin⟩ seg := by
    rw [h_r_p_orig, h_r_q_orig]; exact h_seg_pq_avoids
  have h_verts_avoid_sego : ∀ v ∈ G2'.toVertices,
      v ∉ (LineSegment.mk r_p.origin r_q.origin).toSet := by
    rw [h_r_p_orig, h_r_q_orig]; exact h_verts_avoid_pq
  have h_parity := intersectionParity_eq_of_originSegmentAvoidsGraphSegments
    r_p r_q G2' h_r_p_avoids_verts h_r_q_avoids_verts h_sego_avoids h_verts_avoid_sego
  -- Apply the G2'.interior definition at p
  have h_p_odd : intersectionRayGraphSegmentsNumber r_p G2' % 2 = 1 := by
    have := hp_int.2 r_p h_r_p_origin h_r_p_avoids_verts
    exact this
  -- Transfer to q
  rw [h_parity] at h_p_odd
  exact h_p_odd

/-! #### Combined: segment-inside iff odd past count -/

/-- For a G1' segment crossed by the ray, its open interior lies in G2.interior iff
    the sub-ray from the crossing point crosses G2' an odd number of times. -/
lemma seg_inside_iff_subRay_odd
    (r : Ray) (G1 G2 : EvenGraph)
    (h_fin12 : Set.Finite (G1.toBoundarySet ∩ G2.toBoundarySet))
    (h_fin21 : Set.Finite (G2.toBoundarySet ∩ G1.toBoundarySet))
    (h_avoids1 : rayAvoidsGraphVertices r (graphRefinementSelfAndWrt G1 G2 h_fin12))
    (h_avoids2 : rayAvoidsGraphVertices r (graphRefinementSelfAndWrt G2 G1 h_fin21))
    (_h_origin_avoids2 : ∀ seg ∈ (graphRefinementSelfAndWrt G2 G1 h_fin21).segments,
      pointAvoidsSegment r.origin seg)
    (h_pos2 : ∀ v ∈ (graphRefinementSelfAndWrt G2 G1 h_fin21).toVertices,
      ((graphRefinementSelfAndWrt G2 G1 h_fin21).segments.countP
        fun seg => seg.p1 = v ∨ seg.p2 = v) > 0)
    (s₁ : LineSegment) (hs₁ : s₁ ∈ (graphRefinementSelfAndWrt G1 G2 h_fin12).segments)
    (h_int : rayIntersectsSegment r s₁) :
    segmentOpenInteriorSubset s₁ G2.interior ↔
    intersectionRayGraphSegmentsNumber
      (subRay r (rayCrossingParam r s₁ h_int)) (graphRefinementSelfAndWrt G2 G1 h_fin21) % 2 = 1 := by
  set G1' := graphRefinementSelfAndWrt G1 G2 h_fin12
  set G2' := graphRefinementSelfAndWrt G2 G1 h_fin21
  set t₁ := rayCrossingParam r s₁ h_int
  set p₁ := rayCrossingPoint r s₁ h_int with hp₁_def
  -- p₁ has coordinates (r.o.x + t₁ * r.d.x, r.o.y + t₁ * r.d.y)
  have h_p₁_x : p₁.x = r.origin.x + t₁ * r.direction.x := rayCrossingPoint_x r s₁ h_int
  have h_p₁_y : p₁.y = r.origin.y + t₁ * r.direction.y := rayCrossingPoint_y r s₁ h_int
  have h_p₁_eq : p₁ = ⟨r.origin.x + t₁ * r.direction.x, r.origin.y + t₁ * r.direction.y⟩ := by
    ext; exact h_p₁_x; exact h_p₁_y
  -- p₁ on s₁
  have h_p₁_on_s₁ : p₁ ∈ s₁.toSet := rayCrossingPoint_mem_seg r s₁ h_int
  -- p₁ ≠ endpoints
  have ⟨h_p₁_ne_p₁, h_p₁_ne_p₂⟩ :=
    rayCrossingPoint_not_endpoint r G1' s₁ hs₁ h_avoids1 h_int
  -- p₁ ∉ G2.toBoundarySet (hence ∉ G2'.toBoundarySet)
  have h_p₁_not_G2 : p₁ ∉ G2.toBoundarySet :=
    crossingPoint_avoids_other_boundary r G1 G2 h_fin12 s₁ hs₁ h_avoids1 h_int
  have h_bnd_eq2 : G2'.toBoundarySet = G2.toBoundarySet :=
    graphRefinementSelfAndWrt_boundary_eq G2 G1 h_fin21
  have h_p₁_not_G2' : p₁ ∉ G2'.toBoundarySet := by rw [h_bnd_eq2]; exact h_p₁_not_G2
  -- Sub-ray from p₁ avoids G2' vertices (since sub-ray ⊆ r, and r avoids G2' vertices)
  have ht₁_nn : 0 ≤ t₁ := rayCrossingParam_nonneg r s₁ h_int
  have h_subRay_avoids : rayAvoidsGraphVertices (subRay r t₁) G2' := by
    rw [rayAvoidsGraphVertices]
    rw [Set.eq_empty_iff_forall_not_mem]
    intro v hv
    obtain ⟨hv_ray, hv_vert⟩ := hv
    have hv_r : v ∈ r.toSet := subRay_toSet_subset r t₁ ht₁_nn hv_ray
    have : v ∈ r.toSet ∩ G2'.toVertexSet := ⟨hv_r, hv_vert⟩
    rw [h_avoids2] at this
    exact this
  -- (subRay r t₁).origin = p₁
  have h_subRay_origin : (subRay r t₁).origin = p₁ := by
    show (⟨r.origin.x + t₁ * r.direction.x, r.origin.y + t₁ * r.direction.y⟩ : Vector2D) = p₁
    rw [h_p₁_eq]
  -- Sub-ray origin avoids G2' segments (since p₁ ∉ G2'.toBoundarySet)
  have h_subRay_origin_avoids : ∀ seg ∈ G2'.segments, pointAvoidsSegment (subRay r t₁).origin seg := by
    intro seg hseg h_mem
    rw [h_subRay_origin] at h_mem
    exact h_p₁_not_G2' ⟨seg, hseg, h_mem⟩
  -- Apply point_in_interior_iff_odd_count at subRay
  have h_iff1 : (subRay r t₁).origin ∈ G2'.interior ↔
                intersectionRayGraphSegmentsNumber (subRay r t₁) G2' % 2 = 1 :=
    point_in_interior_iff_odd_count (subRay r t₁) G2' h_subRay_origin_avoids h_subRay_avoids
  rw [h_subRay_origin] at h_iff1
  have h_int_eq : G2'.interior = G2.interior := graphRefinementSelfAndWrt_interior_eq G2 G1 h_fin21
  rw [h_int_eq] at h_iff1
  -- Now link p₁ ∈ G2.interior to segmentOpenInteriorSubset s₁ G2.interior
  constructor
  · -- segmentOpenInteriorSubset s₁ G2.interior → odd count
    intro h_sub
    apply h_iff1.mp
    exact h_sub p₁ h_p₁_on_s₁ h_p₁_ne_p₁ h_p₁_ne_p₂
  · intro h_odd
    have h_p₁_mem : p₁ ∈ G2.interior := h_iff1.mpr h_odd
    intro q hq hq1 hq2
    exact same_G2_interior_status_on_segment G1 G2 h_fin12 h_fin21 h_pos2 s₁ hs₁ p₁ q
      h_p₁_on_s₁ h_p₁_ne_p₁ h_p₁_ne_p₂ hq hq1 hq2 h_p₁_mem

/-! ### Parity theorem -/

set_option maxHeartbeats 4000000 in
/-- The parity of intersection-segment crossings equals 1 iff
    the parity of G₁-crossings and G₂-crossings are both 1. -/
theorem intersectionRayCount_parity
    (r : Ray) (G1 G2 : EvenGraph)
    (h_fin12 : Set.Finite (G1.toBoundarySet ∩ G2.toBoundarySet))
    (h_avoids1 : rayAvoidsGraphVertices r (graphRefinementSelfAndWrt G1 G2 h_fin12))
    (h_avoids2 : rayAvoidsGraphVertices r (graphRefinementSelfAndWrt G2 G1 (flipFin h_fin12)))
    (h_origin_avoids1 : ∀ seg ∈ (graphRefinementSelfAndWrt G1 G2 h_fin12).segments,
      pointAvoidsSegment r.origin seg)
    (h_origin_avoids2 : ∀ seg ∈ (graphRefinementSelfAndWrt G2 G1 (flipFin h_fin12)).segments,
      pointAvoidsSegment r.origin seg) :
    intersectionRayCount r G1 G2 h_fin12 (flipFin h_fin12) % 2 = 1 ↔
    (intersectionRayGraphSegmentsNumber r (graphRefinementSelfAndWrt G1 G2 h_fin12) % 2 = 1 ∧
     intersectionRayGraphSegmentsNumber r (graphRefinementSelfAndWrt G2 G1 (flipFin h_fin12)) % 2 = 1) := by
  have h_fin21 : Set.Finite (G2.toBoundarySet ∩ G1.toBoundarySet) := flipFin h_fin12
  set G1' := graphRefinementSelfAndWrt G1 G2 h_fin12 with hG1'_def
  set G2' := graphRefinementSelfAndWrt G2 G1 h_fin21 with hG2'_def
  -- Every vertex of an even graph has at least one incident segment, trivially.
  have h_pos1 := G1'.incident_count_pos
  have h_pos2 := G2'.incident_count_pos
  -- Main plan: prove intersectionRayCount % 2 = (n₁ * n₂) % 2, then use Nat.odd_mul.
  suffices h_mod : intersectionRayCount r G1 G2 h_fin12 h_fin21 % 2 =
      (intersectionRayGraphSegmentsNumber r G1' *
       intersectionRayGraphSegmentsNumber r G2') % 2 by
    rw [h_mod, Nat.mul_mod]
    constructor
    · intro h
      set a := intersectionRayGraphSegmentsNumber r G1' % 2 with ha_def
      set b := intersectionRayGraphSegmentsNumber r G2' % 2 with hb_def
      have ha : a < 2 := Nat.mod_lt _ (by norm_num)
      have hb : b < 2 := Nat.mod_lt _ (by norm_num)
      refine ⟨?_, ?_⟩
      · by_contra hna
        have ha_eq : a = 0 := by omega
        rw [ha_eq, Nat.zero_mul, Nat.zero_mod] at h
        exact absurd h (by norm_num)
      · by_contra hnb
        have hb_eq : b = 0 := by omega
        rw [hb_eq, Nat.mul_zero, Nat.zero_mod] at h
        exact absurd h (by norm_num)
    · intro ⟨h1, h2⟩; rw [h1, h2]
  -- Prove h_mod. We show both sides equal the parity of the sum of "past counts".
  -- Use `intersectionRayCount_eq_sum_inside_crossing_counts` to split into k₁ + k₂.
  rw [intersectionRayCount_eq_sum_inside_crossing_counts]
  -- Define abbreviations.
  set crossedPast : ℚ → LineSegment → Bool := fun t₀ s₂ =>
    decide (∃ t : ℚ, t > t₀ ∧
      (⟨r.origin.x + t * r.direction.x,
         r.origin.y + t * r.direction.y⟩ : Vector2D) ∈ s₂.toSet) with hCP_def
  -- f(s₁) = # G2'-past count if crossed, else 0
  set f : LineSegment → ℕ := fun s₁ =>
    if h : rayIntersectsSegment r s₁ then
      G2'.segments.countP (crossedPast (rayCrossingParam r s₁ h))
    else 0 with hf_def
  -- Similarly g(s₂) = # G1'-past count if crossed, else 0
  set g : LineSegment → ℕ := fun s₂ =>
    if h : rayIntersectsSegment r s₂ then
      G1'.segments.countP (crossedPast (rayCrossingParam r s₂ h))
    else 0 with hg_def
  -- Key Step A: k₁_count = Σ f % 2
  set k₁_count := (selectSegmentsInside G1'.segments G2.interior).countP
                    (fun seg => decide (rayIntersectsSegment r seg))
  set k₂_count := (selectSegmentsInside G2'.segments G1.interior).countP
                    (fun seg => decide (rayIntersectsSegment r seg))
  -- For each s₁ ∈ G1'.segments, "crossed AND inside G2" parity equals f(s₁) parity.
  have h_per_seg_1 : ∀ s₁ ∈ G1'.segments,
      (if (decide (rayIntersectsSegment r s₁) &&
           decide (segmentOpenInteriorSubset s₁ G2.interior)) then 1 else 0) % 2 =
      (f s₁) % 2 := by
    intro s₁ hs₁
    by_cases h_cr : rayIntersectsSegment r s₁
    · have h_iff : segmentOpenInteriorSubset s₁ G2.interior ↔
          intersectionRayGraphSegmentsNumber
            (subRay r (rayCrossingParam r s₁ h_cr)) G2' % 2 = 1 :=
        seg_inside_iff_subRay_odd r G1 G2 h_fin12 h_fin21
          h_avoids1 h_avoids2 h_origin_avoids2 h_pos2 s₁ hs₁ h_cr
      have h_p₁_not : (⟨r.origin.x + (rayCrossingParam r s₁ h_cr) * r.direction.x,
                        r.origin.y + (rayCrossingParam r s₁ h_cr) * r.direction.y⟩ : Vector2D) ∉
                      G2.toBoundarySet := by
        have h_p₁_eq : (⟨r.origin.x + (rayCrossingParam r s₁ h_cr) * r.direction.x,
                        r.origin.y + (rayCrossingParam r s₁ h_cr) * r.direction.y⟩ : Vector2D) =
                      rayCrossingPoint r s₁ h_cr := by
          ext
          · exact (rayCrossingPoint_x r s₁ h_cr).symm
          · exact (rayCrossingPoint_y r s₁ h_cr).symm
        rw [h_p₁_eq]
        exact crossingPoint_avoids_other_boundary r G1 G2 h_fin12 s₁ hs₁ h_avoids1 h_cr
      have h_bnd_eq : G2'.toBoundarySet = G2.toBoundarySet :=
        graphRefinementSelfAndWrt_boundary_eq G2 G1 h_fin21
      have h_p₁_not' : (⟨r.origin.x + (rayCrossingParam r s₁ h_cr) * r.direction.x,
                        r.origin.y + (rayCrossingParam r s₁ h_cr) * r.direction.y⟩ : Vector2D) ∉
                      G2'.toBoundarySet := by rw [h_bnd_eq]; exact h_p₁_not
      have h_sr := subRay_count_eq_past_count r (rayCrossingParam r s₁ h_cr) G2' h_p₁_not'
      have hf_val : f s₁ = G2'.segments.countP (crossedPast (rayCrossingParam r s₁ h_cr)) := by
        simp only [hf_def, dif_pos h_cr]
      rw [hf_val]
      rw [← h_sr]
      have hd_cr : decide (rayIntersectsSegment r s₁) = true := decide_eq_true h_cr
      by_cases h_in : segmentOpenInteriorSubset s₁ G2.interior
      · have hd_in : decide (segmentOpenInteriorSubset s₁ G2.interior) = true := decide_eq_true h_in
        rw [hd_cr, hd_in]
        simp only [Bool.and_self, ↓reduceIte]
        have h_odd : intersectionRayGraphSegmentsNumber
            (subRay r (rayCrossingParam r s₁ h_cr)) G2' % 2 = 1 := h_iff.mp h_in
        omega
      · have hd_in : decide (segmentOpenInteriorSubset s₁ G2.interior) = false := decide_eq_false h_in
        rw [hd_cr, hd_in]
        show (0 : ℕ) % 2 = _
        have h_not_odd : ¬ intersectionRayGraphSegmentsNumber
            (subRay r (rayCrossingParam r s₁ h_cr)) G2' % 2 = 1 :=
          fun h_odd => h_in (h_iff.mpr h_odd)
        have h_mod_lt := Nat.mod_lt (intersectionRayGraphSegmentsNumber
          (subRay r (rayCrossingParam r s₁ h_cr)) G2') (by norm_num : (0:ℕ) < 2)
        omega
    · have hd_cr : decide (rayIntersectsSegment r s₁) = false := decide_eq_false h_cr
      rw [hd_cr]
      show (0 : ℕ) % 2 = f s₁ % 2
      simp only [hf_def, dif_neg h_cr]
  -- Sum the parities
  have h_k1_mod_eq_sumf_mod :
      k₁_count % 2 = (G1'.segments.map f).sum % 2 := by
    -- First, unfold k₁_count via countP_filter_eq
    have h_k1_alt : k₁_count =
        G1'.segments.countP
          (fun s => decide (rayIntersectsSegment r s) &&
                    decide (segmentOpenInteriorSubset s G2.interior)) := by
      show (G1'.segments.filter
              (fun s => decide (segmentOpenInteriorSubset s G2.interior))).countP
             (fun seg => decide (rayIntersectsSegment r seg)) = _
      rw [countP_filter_eq]
      apply List.countP_congr
      intro x _
      simp [Bool.and_comm]
    -- countP as sum of indicators
    have h_countP_as_sum : ∀ (L : List LineSegment) (pred : LineSegment → Bool),
        L.countP pred = (L.map (fun s => if pred s then 1 else 0)).sum := by
      intro L pred
      induction L with
      | nil => simp
      | cons a rest ih =>
        simp only [List.countP_cons, List.map_cons, List.sum_cons, ih]
        split <;> omega
    rw [h_k1_alt, h_countP_as_sum]
    -- Now (Σ indicator) % 2 vs (Σ f) % 2
    -- Use the per-segment parity equality
    have h_sum_parity : ∀ (L : List LineSegment),
        (∀ s ∈ L, (if (decide (rayIntersectsSegment r s) &&
                       decide (segmentOpenInteriorSubset s G2.interior)) then 1 else 0) % 2 =
                  (f s) % 2) →
        (L.map (fun s => if (decide (rayIntersectsSegment r s) &&
                             decide (segmentOpenInteriorSubset s G2.interior)) then 1 else 0)).sum % 2 =
        (L.map f).sum % 2 := by
      intro L hL
      induction L with
      | nil => simp
      | cons a rest ih =>
        simp only [List.map_cons, List.sum_cons]
        have hL_a : (if (decide (rayIntersectsSegment r a) &&
                         decide (segmentOpenInteriorSubset a G2.interior)) then 1 else 0) % 2 =
                    (f a) % 2 := hL a ((List.mem_cons_self _ _))
        have hL_rest : ∀ s ∈ rest, _ := fun s hs => hL s (List.mem_cons_of_mem _ hs)
        have ih_rest := ih hL_rest
        omega
    exact h_sum_parity _ h_per_seg_1
  -- Similarly for k₂
  have h_per_seg_2 : ∀ s₂ ∈ G2'.segments,
      (if (decide (rayIntersectsSegment r s₂) &&
           decide (segmentOpenInteriorSubset s₂ G1.interior)) then 1 else 0) % 2 =
      (g s₂) % 2 := by
    intro s₂ hs₂
    by_cases h_cr : rayIntersectsSegment r s₂
    · -- By symmetry: swap roles of G1 and G2
      have h_iff : segmentOpenInteriorSubset s₂ G1.interior ↔
          intersectionRayGraphSegmentsNumber
            (subRay r (rayCrossingParam r s₂ h_cr)) G1' % 2 = 1 :=
        seg_inside_iff_subRay_odd r G2 G1 h_fin21 h_fin12
          h_avoids2 h_avoids1 h_origin_avoids1 h_pos1 s₂ hs₂ h_cr
      have h_p₂_not : (⟨r.origin.x + (rayCrossingParam r s₂ h_cr) * r.direction.x,
                        r.origin.y + (rayCrossingParam r s₂ h_cr) * r.direction.y⟩ : Vector2D) ∉
                      G1.toBoundarySet := by
        have h_p₂_eq : (⟨r.origin.x + (rayCrossingParam r s₂ h_cr) * r.direction.x,
                        r.origin.y + (rayCrossingParam r s₂ h_cr) * r.direction.y⟩ : Vector2D) =
                      rayCrossingPoint r s₂ h_cr := by
          ext
          · exact (rayCrossingPoint_x r s₂ h_cr).symm
          · exact (rayCrossingPoint_y r s₂ h_cr).symm
        rw [h_p₂_eq]
        exact crossingPoint_avoids_other_boundary r G2 G1 h_fin21 s₂ hs₂ h_avoids2 h_cr
      have h_bnd_eq : G1'.toBoundarySet = G1.toBoundarySet :=
        graphRefinementSelfAndWrt_boundary_eq G1 G2 h_fin12
      have h_p₂_not' : (⟨r.origin.x + (rayCrossingParam r s₂ h_cr) * r.direction.x,
                        r.origin.y + (rayCrossingParam r s₂ h_cr) * r.direction.y⟩ : Vector2D) ∉
                      G1'.toBoundarySet := by rw [h_bnd_eq]; exact h_p₂_not
      have h_sr := subRay_count_eq_past_count r (rayCrossingParam r s₂ h_cr) G1' h_p₂_not'
      have hg_val : g s₂ = G1'.segments.countP (crossedPast (rayCrossingParam r s₂ h_cr)) := by
        simp only [hg_def, dif_pos h_cr]
      rw [hg_val, ← h_sr]
      have hd_cr : decide (rayIntersectsSegment r s₂) = true := decide_eq_true h_cr
      by_cases h_in : segmentOpenInteriorSubset s₂ G1.interior
      · have hd_in : decide (segmentOpenInteriorSubset s₂ G1.interior) = true := decide_eq_true h_in
        rw [hd_cr, hd_in]
        simp only [Bool.and_self, ↓reduceIte]
        have h_odd : intersectionRayGraphSegmentsNumber
            (subRay r (rayCrossingParam r s₂ h_cr)) G1' % 2 = 1 := h_iff.mp h_in
        omega
      · have hd_in : decide (segmentOpenInteriorSubset s₂ G1.interior) = false := decide_eq_false h_in
        rw [hd_cr, hd_in]
        show (0 : ℕ) % 2 = _
        have h_not_odd : ¬ intersectionRayGraphSegmentsNumber
            (subRay r (rayCrossingParam r s₂ h_cr)) G1' % 2 = 1 :=
          fun h_odd => h_in (h_iff.mpr h_odd)
        have h_mod_lt := Nat.mod_lt (intersectionRayGraphSegmentsNumber
          (subRay r (rayCrossingParam r s₂ h_cr)) G1') (by norm_num : (0:ℕ) < 2)
        omega
    · have hd_cr : decide (rayIntersectsSegment r s₂) = false := decide_eq_false h_cr
      rw [hd_cr]
      show (0 : ℕ) % 2 = g s₂ % 2
      simp only [hg_def, dif_neg h_cr]
  have h_k2_mod_eq_sumg_mod :
      k₂_count % 2 = (G2'.segments.map g).sum % 2 := by
    have h_k2_alt : k₂_count =
        G2'.segments.countP
          (fun s => decide (rayIntersectsSegment r s) &&
                    decide (segmentOpenInteriorSubset s G1.interior)) := by
      show (G2'.segments.filter
              (fun s => decide (segmentOpenInteriorSubset s G1.interior))).countP
             (fun seg => decide (rayIntersectsSegment r seg)) = _
      rw [countP_filter_eq]
      apply List.countP_congr
      intro x _
      simp [Bool.and_comm]
    have h_countP_as_sum : ∀ (L : List LineSegment) (pred : LineSegment → Bool),
        L.countP pred = (L.map (fun s => if pred s then 1 else 0)).sum := by
      intro L pred
      induction L with
      | nil => simp
      | cons a rest ih =>
        simp only [List.countP_cons, List.map_cons, List.sum_cons, ih]
        split <;> omega
    rw [h_k2_alt, h_countP_as_sum]
    have h_sum_parity : ∀ (L : List LineSegment),
        (∀ s ∈ L, (if (decide (rayIntersectsSegment r s) &&
                       decide (segmentOpenInteriorSubset s G1.interior)) then 1 else 0) % 2 =
                  (g s) % 2) →
        (L.map (fun s => if (decide (rayIntersectsSegment r s) &&
                             decide (segmentOpenInteriorSubset s G1.interior)) then 1 else 0)).sum % 2 =
        (L.map g).sum % 2 := by
      intro L hL
      induction L with
      | nil => simp
      | cons a rest ih =>
        simp only [List.map_cons, List.sum_cons]
        have hL_a : (if (decide (rayIntersectsSegment r a) &&
                         decide (segmentOpenInteriorSubset a G1.interior)) then 1 else 0) % 2 =
                    (g a) % 2 := hL a ((List.mem_cons_self _ _))
        have hL_rest : ∀ s ∈ rest, _ := fun s hs => hL s (List.mem_cons_of_mem _ hs)
        have ih_rest := ih hL_rest
        omega
    exact h_sum_parity _ h_per_seg_2
  -- Now compute Σ f and Σ g.
  -- Claim: Σ f + Σ g = n₁ * n₂ (exactly, under no-ties)
  -- Derive no-ties: for any crossed s₁ ∈ G1', s₂ ∈ G2', rayCrossingParam r s₁ h₁ ≠ rayCrossingParam r s₂ h₂.
  have h_no_ties : ∀ s₁ ∈ G1'.segments, ∀ s₂ ∈ G2'.segments,
      ∀ (h₁ : rayIntersectsSegment r s₁) (h₂ : rayIntersectsSegment r s₂),
        rayCrossingParam r s₁ h₁ ≠ rayCrossingParam r s₂ h₂ := by
    intro s₁ hs₁ s₂ hs₂ h₁ h₂ h_eq
    have h_p₁_eq_p₂ :
        rayCrossingPoint r s₁ h₁ = rayCrossingPoint r s₂ h₂ := by
      ext
      · rw [rayCrossingPoint_x r s₁ h₁, rayCrossingPoint_x r s₂ h₂, h_eq]
      · rw [rayCrossingPoint_y r s₁ h₁, rayCrossingPoint_y r s₂ h₂, h_eq]
    have h_p₁_on_s₂ : rayCrossingPoint r s₁ h₁ ∈ s₂.toSet := by
      rw [h_p₁_eq_p₂]; exact rayCrossingPoint_mem_seg r s₂ h₂
    have h_p₁_G2 : rayCrossingPoint r s₁ h₁ ∈ G2.toBoundarySet := by
      have h_bnd_eq : G2'.toBoundarySet = G2.toBoundarySet :=
        graphRefinementSelfAndWrt_boundary_eq G2 G1 h_fin21
      rw [← h_bnd_eq]
      exact ⟨s₂, hs₂, h_p₁_on_s₂⟩
    exact crossingPoint_avoids_other_boundary r G1 G2 h_fin12 s₁ hs₁ h_avoids1 h₁ h_p₁_G2
  -- Uniqueness of rayCrossingParam for segments in G2' (resp. G1'): any `t ≥ 0` with
  -- point on the segment equals `rayCrossingParam`.
  have h_unique_G2' : ∀ s ∈ G2'.segments, ∀ (h : rayIntersectsSegment r s) (t : ℚ),
      0 ≤ t →
      (⟨r.origin.x + t * r.direction.x, r.origin.y + t * r.direction.y⟩ : Vector2D) ∈ s.toSet →
      t = rayCrossingParam r s h := by
    intro s hs h t ht hmem
    apply rayCrossingParam_unique r s h (h_origin_avoids2 s hs) _ _ t ht hmem
    · intro h_p1
      have : s.p1 ∈ r.toSet ∩ G2'.toVertexSet :=
        ⟨h_p1, (G2'.segments_endpoints s hs).1⟩
      rw [h_avoids2] at this; exact this
    · intro h_p2
      have : s.p2 ∈ r.toSet ∩ G2'.toVertexSet :=
        ⟨h_p2, (G2'.segments_endpoints s hs).2⟩
      rw [h_avoids2] at this; exact this
  have h_unique_G1' : ∀ s ∈ G1'.segments, ∀ (h : rayIntersectsSegment r s) (t : ℚ),
      0 ≤ t →
      (⟨r.origin.x + t * r.direction.x, r.origin.y + t * r.direction.y⟩ : Vector2D) ∈ s.toSet →
      t = rayCrossingParam r s h := by
    intro s hs h t ht hmem
    apply rayCrossingParam_unique r s h (h_origin_avoids1 s hs) _ _ t ht hmem
    · intro h_p1
      have : s.p1 ∈ r.toSet ∩ G1'.toVertexSet :=
        ⟨h_p1, (G1'.segments_endpoints s hs).1⟩
      rw [h_avoids1] at this; exact this
    · intro h_p2
      have : s.p2 ∈ r.toSet ∩ G1'.toVertexSet :=
        ⟨h_p2, (G1'.segments_endpoints s hs).2⟩
      rw [h_avoids1] at this; exact this
  -- Abbreviation for "crossed" predicate (as a Bool).
  set crossed : LineSegment → Bool := fun s => decide (rayIntersectsSegment r s) with hcrossed_def
  -- Key: for s ∈ G2' and any `t₀ ≥ 0`, `crossedPast t₀ s` iff s crossed with param > t₀.
  have h_crossedPast_G2' : ∀ s ∈ G2'.segments, ∀ (t₀ : ℚ), 0 ≤ t₀ →
      (crossedPast t₀ s = true ↔
       ∃ (h : rayIntersectsSegment r s), rayCrossingParam r s h > t₀) := by
    intro s hs t₀ ht₀
    simp only [hCP_def, decide_eq_true_iff]
    constructor
    · rintro ⟨t, ht_gt, hmem⟩
      have ht_nn : 0 ≤ t := le_of_lt (lt_of_le_of_lt ht₀ ht_gt)
      have h_cr : rayIntersectsSegment r s :=
        (rayIntersectsSegment_iff_exists_param r s).mpr ⟨t, ht_nn, hmem⟩
      refine ⟨h_cr, ?_⟩
      have h_teq : t = rayCrossingParam r s h_cr := h_unique_G2' s hs h_cr t ht_nn hmem
      linarith
    · rintro ⟨h, hgt⟩
      refine ⟨rayCrossingParam r s h, hgt, rayCrossingParam_point_mem_seg r s h⟩
  have h_crossedPast_G1' : ∀ s ∈ G1'.segments, ∀ (t₀ : ℚ), 0 ≤ t₀ →
      (crossedPast t₀ s = true ↔
       ∃ (h : rayIntersectsSegment r s), rayCrossingParam r s h > t₀) := by
    intro s hs t₀ ht₀
    simp only [hCP_def, decide_eq_true_iff]
    constructor
    · rintro ⟨t, ht_gt, hmem⟩
      have ht_nn : 0 ≤ t := le_of_lt (lt_of_le_of_lt ht₀ ht_gt)
      have h_cr : rayIntersectsSegment r s :=
        (rayIntersectsSegment_iff_exists_param r s).mpr ⟨t, ht_nn, hmem⟩
      refine ⟨h_cr, ?_⟩
      have h_teq : t = rayCrossingParam r s h_cr := h_unique_G1' s hs h_cr t ht_nn hmem
      linarith
    · rintro ⟨h, hgt⟩
      refine ⟨rayCrossingParam r s h, hgt, rayCrossingParam_point_mem_seg r s h⟩
  -- Define an auxiliary g_L that uses L instead of G1'.segments.
  set g_L : List LineSegment → LineSegment → ℕ := fun L s₂ =>
    if h : rayIntersectsSegment r s₂ then
      L.countP (crossedPast (rayCrossingParam r s₂ h))
    else 0 with hg_L_def
  have hg_is_g_L : g = g_L G1'.segments := by
    funext s₂; simp [hg_L_def, hg_def]
  -- Helper lemma via induction on L: for any sublist L ⊆ G1'.segments,
  -- (L.map f).sum + (G2'.segments.map (g_L L)).sum = (L.countP crossed) * (G2'.segments.countP crossed).
  have h_sum_induction : ∀ (L : List LineSegment), (∀ s ∈ L, s ∈ G1'.segments) →
      (L.map f).sum + (G2'.segments.map (g_L L)).sum =
      (L.countP crossed) * (G2'.segments.countP crossed) := by
    intro L hL_sub
    induction L with
    | nil =>
      simp only [List.map_nil, List.sum_nil, List.countP_nil, Nat.zero_mul, Nat.zero_add]
      -- Need (G2'.segments.map (g_L [])).sum = 0
      have h_gL_nil : ∀ s₂, g_L [] s₂ = 0 := by
        intro s₂
        simp only [hg_L_def]
        split <;> simp
      have h_gL_nil_fn : g_L [] = fun _ => 0 := funext h_gL_nil
      rw [h_gL_nil_fn]
      simp
    | cons a rest ih =>
      have ha_in_G1' : a ∈ G1'.segments := hL_sub a ((List.mem_cons_self _ _))
      have h_rest_sub : ∀ s ∈ rest, s ∈ G1'.segments :=
        fun s hs => hL_sub s (List.mem_cons_of_mem _ hs)
      have ih_eq := ih h_rest_sub
      -- The key identity we need: for each s₂ ∈ G2'.segments,
      --   g_L (a :: rest) s₂ = g_L rest s₂ + (if cross s₂ ∧ crossedPast t_{s₂} a then 1 else 0)
      -- Equivalently the increment per s₂ is given by a predicate `postPred`.
      set postPred : LineSegment → Bool := fun s₂ =>
        if h : rayIntersectsSegment r s₂ then
          crossedPast (rayCrossingParam r s₂ h) a
        else false with hpostPred_def
      have h_gL_step : ∀ s₂, g_L (a :: rest) s₂ = g_L rest s₂ + (if postPred s₂ then 1 else 0) := by
        intro s₂
        simp only [hg_L_def, hpostPred_def]
        by_cases hcr : rayIntersectsSegment r s₂
        · simp only [dif_pos hcr, List.countP_cons]
        · simp only [dif_neg hcr]; simp
      -- So (G2'.map (g_L (a :: rest))).sum = (G2'.map (g_L rest)).sum + G2'.countP postPred
      have h_map_step :
          (G2'.segments.map (g_L (a :: rest))).sum =
          (G2'.segments.map (g_L rest)).sum +
          (G2'.segments.countP postPred) := by
        have : ∀ (L : List LineSegment),
            (L.map (g_L (a :: rest))).sum =
            (L.map (g_L rest)).sum + (L.countP postPred) := by
          intro L
          induction L with
          | nil => simp
          | cons b rest' ih' =>
            simp only [List.map_cons, List.sum_cons, List.countP_cons, ih', h_gL_step]
            split <;> omega
        exact this G2'.segments
      rw [List.map_cons, List.sum_cons, List.countP_cons, h_map_step]
      -- Now handle f(a) by cases on whether a is crossed.
      by_cases h_cr_a : rayIntersectsSegment r a
      · -- a is crossed with param t_a
        have hfa : f a = G2'.segments.countP (crossedPast (rayCrossingParam r a h_cr_a)) := by
          simp only [hf_def, dif_pos h_cr_a]
        set t_a := rayCrossingParam r a h_cr_a with ht_a_def
        have ht_a_nn : 0 ≤ t_a := rayCrossingParam_nonneg r a h_cr_a
        have h_crossed_a : crossed a = true := by
          simp [hcrossed_def, h_cr_a]
        -- f(a) counts # s₂ ∈ G2' with crossedPast t_a s₂.
        -- postPred(s₂) counts # s₂ ∈ G2' with s₂ crossed ∧ t_a > t_{s₂}.
        -- Together: G2'.countP ((crossedPast t_a s₂) OR postPred s₂) = # s₂ crossed (by no-ties).
        -- Key claim: for each s₂ ∈ G2', EXACTLY one of {s₂ not crossed, crossedPast t_a s₂, postPred s₂} holds.
        -- Let's express f(a) + G2'.countP postPred = G2'.countP crossed.
        -- Decompose G2'.segments into 3 disjoint sets using countP.
        have h_sum_decomp : G2'.segments.countP (crossedPast t_a) + G2'.segments.countP postPred =
            G2'.segments.countP crossed := by
          -- We'll show the pointwise identity for each s₂ ∈ G2':
          -- [crossedPast t_a s₂] + [postPred s₂] = [crossed s₂]
          have h_pt : ∀ s₂ ∈ G2'.segments,
              (if (crossedPast t_a s₂) then 1 else 0) + (if (postPred s₂) then 1 else 0) =
              (if (crossed s₂) then 1 else 0) := by
            intro s₂ hs₂
            by_cases h_cr_s₂ : rayIntersectsSegment r s₂
            · -- s₂ crossed with param t_{s₂}. Uniqueness + no-ties: exactly one of
              -- {t_a < t_{s₂}, t_a > t_{s₂}} holds.
              set t_s₂ := rayCrossingParam r s₂ h_cr_s₂ with ht_s₂_def
              have ht_s₂_nn : 0 ≤ t_s₂ := rayCrossingParam_nonneg r s₂ h_cr_s₂
              have h_ne : t_a ≠ t_s₂ := h_no_ties a ha_in_G1' s₂ hs₂ h_cr_a h_cr_s₂
              have h_cp_iff : crossedPast t_a s₂ = true ↔ t_s₂ > t_a := by
                rw [h_crossedPast_G2' s₂ hs₂ t_a ht_a_nn]
                constructor
                · rintro ⟨h', hgt⟩
                  have : h' = h_cr_s₂ := rfl
                  rw [this] at hgt
                  exact hgt
                · intro h; exact ⟨h_cr_s₂, h⟩
              have h_pp_iff : postPred s₂ = true ↔ t_a > t_s₂ := by
                simp only [hpostPred_def, dif_pos h_cr_s₂]
                rw [h_crossedPast_G1' a ha_in_G1' t_s₂ ht_s₂_nn]
                constructor
                · rintro ⟨h', hgt⟩
                  have : h' = h_cr_a := rfl
                  rw [this] at hgt
                  exact hgt
                · intro h; exact ⟨h_cr_a, h⟩
              have h_crossed_s₂ : crossed s₂ = true := by
                simp [hcrossed_def, h_cr_s₂]
              rcases lt_or_gt_of_ne h_ne with hlt | hgt
              · -- t_a < t_s₂
                have hcp : crossedPast t_a s₂ = true := h_cp_iff.mpr hlt
                have hpp : postPred s₂ ≠ true := fun h => by
                  have := h_pp_iff.mp h; linarith
                simp only [Bool.not_eq_true] at hpp
                simp [hcp, hpp, h_crossed_s₂]
              · -- t_a > t_s₂
                have hpp : postPred s₂ = true := h_pp_iff.mpr hgt
                have hcp : crossedPast t_a s₂ ≠ true := fun h => by
                  have := h_cp_iff.mp h; linarith
                simp only [Bool.not_eq_true] at hcp
                simp [hcp, hpp, h_crossed_s₂]
            · -- s₂ not crossed
              have h_crossed_s₂ : crossed s₂ = false := by
                simp [hcrossed_def, h_cr_s₂]
              have hcp : crossedPast t_a s₂ = false := by
                by_contra h_tr
                push_neg at h_tr
                simp only [Bool.not_eq_false] at h_tr
                have := (h_crossedPast_G2' s₂ hs₂ t_a ht_a_nn).mp h_tr
                obtain ⟨h_cr', _⟩ := this
                exact h_cr_s₂ h_cr'
              have hpp : postPred s₂ = false := by
                simp only [hpostPred_def]
                split
                · -- s₂ crossed — contradiction
                  next h => exact absurd h h_cr_s₂
                · rfl
              simp [hcp, hpp, h_crossed_s₂]
          -- Convert pointwise equality to countP equality.
          have h_cP_eq : ∀ (pred : LineSegment → Bool) (L : List LineSegment),
              L.countP pred = (L.map (fun s => if pred s then 1 else 0)).sum := by
            intro pred L
            induction L with
            | nil => simp
            | cons b rest ih =>
              simp only [List.countP_cons, List.map_cons, List.sum_cons, ih]
              split <;> omega
          rw [h_cP_eq (crossedPast t_a), h_cP_eq postPred, h_cP_eq crossed]
          -- Sum of two maps = map of sums
          have h_map_add : ∀ (L : List LineSegment),
              (∀ s ∈ L, (if (crossedPast t_a s) then 1 else 0) + (if (postPred s) then 1 else 0) =
                        (if (crossed s) then 1 else 0)) →
              (L.map (fun s => if (crossedPast t_a s) then 1 else 0)).sum +
              (L.map (fun s => if (postPred s) then 1 else 0)).sum =
              (L.map (fun s => if (crossed s) then 1 else 0)).sum := by
            intro L hL
            induction L with
            | nil => simp
            | cons b rest ih =>
              simp only [List.map_cons, List.sum_cons]
              have hb := hL b ((List.mem_cons_self _ _))
              have h_rest : ∀ s ∈ rest, _ := fun s hs => hL s (List.mem_cons_of_mem _ hs)
              have := ih h_rest
              omega
          exact h_map_add G2'.segments h_pt
        -- RHS: ((a::rest).countP crossed) * G2'.countP crossed = (1 + rest.countP crossed) * G2'.countP crossed
        -- LHS: f(a) + (rest.map f).sum + ((G2'.map g_L rest).sum + G2'.countP postPred)
        -- Using: h_sum_decomp (f(a) + G2'.countP postPred = G2'.countP crossed),
        --        ih_eq ((rest.map f).sum + (G2'.map g_L rest).sum = rest.countP crossed * G2'.countP crossed).
        rw [hfa]
        have h_if_one : (if crossed a = true then (1 : ℕ) else 0) = 1 := by
          rw [if_pos h_crossed_a]
        rw [h_if_one]
        rw [Nat.add_mul, Nat.one_mul]
        linarith [h_sum_decomp, ih_eq]
      · -- a not crossed. f(a) = 0, and G2'.countP postPred = 0.
        have hfa : f a = 0 := by simp [hf_def, h_cr_a]
        have h_crossed_a : crossed a = false := by simp [hcrossed_def, h_cr_a]
        -- postPred(s₂) = false for all s₂ when a is not crossed:
        have hpp_all_false : ∀ s₂ ∈ G2'.segments, postPred s₂ = false := by
          intro s₂ hs₂
          simp only [hpostPred_def]
          by_cases h_cr_s₂ : rayIntersectsSegment r s₂
          · simp only [dif_pos h_cr_s₂]
            set t_s₂ := rayCrossingParam r s₂ h_cr_s₂
            have ht_s₂_nn : 0 ≤ t_s₂ := rayCrossingParam_nonneg r s₂ h_cr_s₂
            by_contra htr
            push_neg at htr
            simp only [Bool.not_eq_false] at htr
            have := (h_crossedPast_G1' a ha_in_G1' t_s₂ ht_s₂_nn).mp htr
            obtain ⟨h_cr', _⟩ := this
            exact h_cr_a h_cr'
          · simp [dif_neg h_cr_s₂]
        have h_cP_pp_zero : G2'.segments.countP postPred = 0 := by
          rw [List.countP_eq_zero]
          intro s₂ hs₂
          simp [hpp_all_false s₂ hs₂]
        have h_if_zero : (if crossed a = true then (1 : ℕ) else 0) = 0 := by
          rw [if_neg]; intro h; rw [h_crossed_a] at h; exact Bool.false_ne_true h
        rw [h_if_zero, hfa, h_cP_pp_zero]
        linarith [ih_eq]
  -- Apply to L = G1'.segments.
  have h_sum_identity :
      (G1'.segments.map f).sum + (G2'.segments.map g).sum =
      intersectionRayGraphSegmentsNumber r G1' *
      intersectionRayGraphSegmentsNumber r G2' := by
    rw [hg_is_g_L]
    have h_apply := h_sum_induction G1'.segments (fun s hs => hs)
    show _ = G1'.segments.countP crossed * G2'.segments.countP crossed
    exact h_apply
  -- Now combine with h_k1_mod_eq_sumf_mod and h_k2_mod_eq_sumg_mod.
  -- k₁_count + k₂_count ≡ (Σf + Σg) (mod 2) = n₁ * n₂ (mod 2).
  calc (k₁_count + k₂_count) % 2
      = ((k₁_count % 2) + (k₂_count % 2)) % 2 := by rw [Nat.add_mod]
    _ = (((G1'.segments.map f).sum % 2) + ((G2'.segments.map g).sum % 2)) % 2 := by
          rw [h_k1_mod_eq_sumf_mod, h_k2_mod_eq_sumg_mod]
    _ = ((G1'.segments.map f).sum + (G2'.segments.map g).sum) % 2 := by
          rw [← Nat.add_mod]
    _ = (intersectionRayGraphSegmentsNumber r G1' *
          intersectionRayGraphSegmentsNumber r G2') % 2 := by rw [h_sum_identity]

/-! ### Main theorem: intersection interior equals set intersection -/

/-- The interior of the intersection graph equals the intersection of
    the interiors of the two input graphs. -/
theorem intersectionInterior_eq_helper
    (G1 G2 : EvenGraph)
    (h_fin12 : Set.Finite (G1.toBoundarySet ∩ G2.toBoundarySet)) :
    intersectionInterior G1 G2 h_fin12 (flipFin h_fin12) = G1.interior ∩ G2.interior := by
  have h_fin21 : Set.Finite (G2.toBoundarySet ∩ G1.toBoundarySet) := flipFin h_fin12
  set G1' := graphRefinementSelfAndWrt G1 G2 h_fin12 with hG1'_def
  set G2' := graphRefinementSelfAndWrt G2 G1 h_fin21 with hG2'_def
  -- Every vertex of an even graph has at least one incident segment, trivially.
  have h_pos1 := G1'.incident_count_pos
  have h_pos2 := G2'.incident_count_pos
  have h_int1 : G1'.interior = G1.interior := graphRefinementSelfAndWrt_interior_eq G1 G2 h_fin12
  have h_int2 : G2'.interior = G2.interior := graphRefinementSelfAndWrt_interior_eq G2 G1 h_fin21
  ext p
  simp only [intersectionInterior, Set.mem_setOf_eq, Set.mem_inter_iff]
  constructor
  · -- (→) intersectionInterior → G1.interior ∩ G2.interior
    intro ⟨h_avoids_G1', h_avoids_G2', h_parity_all⟩
    -- p is not a vertex of either refined graph
    have h_nv : ∀ v ∈ G1'.toVertices ++ G2'.toVertices, v ≠ p := by
      intro v hv
      rcases List.mem_append.mp hv with h | h
      · exact not_vertex_of_avoids_segments p G1' h_pos1 h_avoids_G1' v h
      · exact not_vertex_of_avoids_segments p G2' h_pos2 h_avoids_G2' v h
    -- Find a ray from p avoiding both G1' and G2' vertices
    obtain ⟨r₀, h_origin₀, h_r₀_avoids1, h_r₀_avoids2⟩ :=
      exists_ray_avoiding_both_vertices p G1' G2' h_nv
    -- This ray has odd intersection crossing parity
    have h_origin_segs1 : ∀ seg ∈ G1'.segments, pointAvoidsSegment r₀.origin seg := by
      rw [h_origin₀]; exact h_avoids_G1'
    have h_origin_segs2 : ∀ seg ∈ G2'.segments, pointAvoidsSegment r₀.origin seg := by
      rw [h_origin₀]; exact h_avoids_G2'
    have h_int_parity := h_parity_all r₀ h_origin₀ h_r₀_avoids1 h_r₀_avoids2
    -- By parity theorem: odd G1' crossings ∧ odd G2' crossings
    have ⟨h_G1'_odd, h_G2'_odd⟩ := (intersectionRayCount_parity r₀ G1 G2 h_fin12
      h_r₀_avoids1 h_r₀_avoids2 h_origin_segs1 h_origin_segs2).mp h_int_parity
    -- Show p ∈ G1.interior ∧ p ∈ G2.interior via refined graph interiors
    constructor
    · -- p ∈ G1.interior
      rw [← h_int1]
      exact ⟨h_avoids_G1', fun r h_origin h_avoids_r => by
        have h_eq := intersectionParity_eq_of_sameOrigin_avoidsGraphVertices
          r₀ r G1' (show sameOrigin r₀ r by simp [sameOrigin, h_origin₀, h_origin])
          h_r₀_avoids1 h_avoids_r (by rw [h_origin₀]; exact h_avoids_G1')
        rw [← hG1'_def] at h_G1'_odd; linarith⟩
    · -- p ∈ G2.interior
      rw [← h_int2]
      exact ⟨h_avoids_G2', fun r h_origin h_avoids_r => by
        have h_eq := intersectionParity_eq_of_sameOrigin_avoidsGraphVertices
          r₀ r G2' (show sameOrigin r₀ r by simp [sameOrigin, h_origin₀, h_origin])
          h_r₀_avoids2 h_avoids_r (by rw [h_origin₀]; exact h_avoids_G2')
        rw [← hG2'_def] at h_G2'_odd; linarith⟩
  · -- (←) G1.interior ∩ G2.interior → intersectionInterior
    intro ⟨hG1, hG2⟩
    -- Convert to refined graph interiors
    have h_G1'_mem : p ∈ G1'.interior := by rw [h_int1]; exact hG1
    have h_G2'_mem : p ∈ G2'.interior := by rw [h_int2]; exact hG2
    refine ⟨h_G1'_mem.1, h_G2'_mem.1, fun r h_origin h_r_avoids1 h_r_avoids2 => ?_⟩
    exact (intersectionRayCount_parity r G1 G2 h_fin12
      h_r_avoids1 h_r_avoids2
      (by rw [h_origin]; exact h_G1'_mem.1)
      (by rw [h_origin]; exact h_G2'_mem.1)).mpr
      ⟨h_G1'_mem.2 r (by rw [h_origin]) h_r_avoids1,
       h_G2'_mem.2 r (by rw [h_origin]) h_r_avoids2⟩

/-- ∃-ray version of the intersection interior helper. -/
theorem intersectionInteriorExists_eq_helper
    (G1 G2 : EvenGraph)
    (h_fin12 : Set.Finite (G1.toBoundarySet ∩ G2.toBoundarySet)) :
    intersectionInteriorExists G1 G2 h_fin12 (flipFin h_fin12) = G1.interior ∩ G2.interior := by
  have h_fin21 : Set.Finite (G2.toBoundarySet ∩ G1.toBoundarySet) := flipFin h_fin12
  set G1' := graphRefinementSelfAndWrt G1 G2 h_fin12 with hG1'_def
  set G2' := graphRefinementSelfAndWrt G2 G1 h_fin21 with hG2'_def
  have h_pos1 := G1'.incident_count_pos
  have h_pos2 := G2'.incident_count_pos
  have h_int1 : G1'.interior = G1.interior := graphRefinementSelfAndWrt_interior_eq G1 G2 h_fin12
  have h_int2 : G2'.interior = G2.interior := graphRefinementSelfAndWrt_interior_eq G2 G1 h_fin21
  ext p
  simp only [intersectionInteriorExists, Set.mem_setOf_eq, Set.mem_inter_iff]
  constructor
  · -- (→) ∃-form → G1.interior ∩ G2.interior
    intro ⟨h_avoids_G1', h_avoids_G2', r₀, h_origin₀, h_r₀_avoids1, h_r₀_avoids2,
           h_int_parity⟩
    have h_origin_segs1 : ∀ seg ∈ G1'.segments, pointAvoidsSegment r₀.origin seg := by
      rw [h_origin₀]; exact h_avoids_G1'
    have h_origin_segs2 : ∀ seg ∈ G2'.segments, pointAvoidsSegment r₀.origin seg := by
      rw [h_origin₀]; exact h_avoids_G2'
    have ⟨h_G1'_odd, h_G2'_odd⟩ := (intersectionRayCount_parity r₀ G1 G2 h_fin12
      h_r₀_avoids1 h_r₀_avoids2 h_origin_segs1 h_origin_segs2).mp h_int_parity
    constructor
    · rw [← h_int1]
      exact ⟨h_avoids_G1', fun r h_origin h_avoids_r => by
        have h_eq := intersectionParity_eq_of_sameOrigin_avoidsGraphVertices
          r₀ r G1' (show sameOrigin r₀ r by simp [sameOrigin, h_origin₀, h_origin])
          h_r₀_avoids1 h_avoids_r (by rw [h_origin₀]; exact h_avoids_G1')
        rw [← hG1'_def] at h_G1'_odd; linarith⟩
    · rw [← h_int2]
      exact ⟨h_avoids_G2', fun r h_origin h_avoids_r => by
        have h_eq := intersectionParity_eq_of_sameOrigin_avoidsGraphVertices
          r₀ r G2' (show sameOrigin r₀ r by simp [sameOrigin, h_origin₀, h_origin])
          h_r₀_avoids2 h_avoids_r (by rw [h_origin₀]; exact h_avoids_G2')
        rw [← hG2'_def] at h_G2'_odd; linarith⟩
  · -- (←) G1.interior ∩ G2.interior → ∃-form
    intro ⟨hG1, hG2⟩
    have h_G1'_mem : p ∈ G1'.interior := by rw [h_int1]; exact hG1
    have h_G2'_mem : p ∈ G2'.interior := by rw [h_int2]; exact hG2
    refine ⟨h_G1'_mem.1, h_G2'_mem.1, ?_⟩
    have h_nv : ∀ v ∈ G1'.toVertices ++ G2'.toVertices, v ≠ p := by
      intro v hv
      rcases List.mem_append.mp hv with h | h
      · exact not_vertex_of_avoids_segments p G1' h_pos1 h_G1'_mem.1 v h
      · exact not_vertex_of_avoids_segments p G2' h_pos2 h_G2'_mem.1 v h
    obtain ⟨r₀, h_origin₀, h_r₀_avoids1, h_r₀_avoids2⟩ :=
      exists_ray_avoiding_both_vertices p G1' G2' h_nv
    refine ⟨r₀, h_origin₀, h_r₀_avoids1, h_r₀_avoids2, ?_⟩
    exact (intersectionRayCount_parity r₀ G1 G2 h_fin12
      h_r₀_avoids1 h_r₀_avoids2
      (by rw [h_origin₀]; exact h_G1'_mem.1)
      (by rw [h_origin₀]; exact h_G2'_mem.1)).mpr
      ⟨h_G1'_mem.2 r₀ h_origin₀ h_r₀_avoids1,
       h_G2'_mem.2 r₀ h_origin₀ h_r₀_avoids2⟩

/-- Parity-iff-I property at a single ray: for `r` with origin off both refined
    boundaries and `r` avoiding both refined graph vertex sets, the parity of the
    number of intersection-graph crossings is odd iff `r.origin ∈ G1.interior ∩
    G2.interior`. Reusable building block. -/
lemma intersectionParity_iff_in_interiors
    (r : Ray) (G1 G2 : EvenGraph)
    (h_fin12 : Set.Finite (G1.toBoundarySet ∩ G2.toBoundarySet))
    (h_fin21 : Set.Finite (G2.toBoundarySet ∩ G1.toBoundarySet))
    (h_avoids1 : rayAvoidsGraphVertices r (graphRefinementSelfAndWrt G1 G2 h_fin12))
    (h_avoids2 : rayAvoidsGraphVertices r (graphRefinementSelfAndWrt G2 G1 h_fin21))
    (h_origin_avoids1 : ∀ seg ∈ (graphRefinementSelfAndWrt G1 G2 h_fin12).segments,
      pointAvoidsSegment r.origin seg)
    (h_origin_avoids2 : ∀ seg ∈ (graphRefinementSelfAndWrt G2 G1 h_fin21).segments,
      pointAvoidsSegment r.origin seg) :
    intersectionRayCount r G1 G2 h_fin12 h_fin21 % 2 = 1 ↔
    r.origin ∈ G1.interior ∩ G2.interior := by
  constructor
  · intro h_parity
    have h_in_exists : r.origin ∈ intersectionInteriorExists G1 G2 h_fin12 h_fin21 :=
      ⟨h_origin_avoids1, h_origin_avoids2,
        r, rfl, h_avoids1, h_avoids2, h_parity⟩
    rw [intersectionInteriorExists_eq_helper] at h_in_exists
    exact h_in_exists
  · intro h_in
    rw [← intersectionInterior_eq_helper] at h_in
    exact h_in.2.2 r rfl h_avoids1 h_avoids2

/-- Given a point `p` not on any line segment in a finite list `L`, there exists
    a perturbed point `p'` near `p` such that the segment from `p` to `p'` is
    disjoint from every segment in `L`. -/
lemma exists_perturbation
    (p : Vector2D) (L : List LineSegment)
    (h_p_not_in_L : ∀ seg ∈ L, p ∉ seg.toSet) :
    ∃ p' : Vector2D, p' ≠ p ∧
      (∀ seg ∈ L, segmentDoesNotIntersectSegment ⟨p, p'⟩ seg) := by
  -- Step 1: Pick a slope q so that direction (1, q) is not parallel to any
  -- non-degenerate seg, and not directed at any degenerate seg's point.
  have h_inf : Infinite ℚ :=
    Infinite.of_injective (fun n : ℕ => (n : ℚ)) Nat.cast_injective
  let badSlopes : Finset ℚ := (L.filterMap fun seg =>
    if seg.p1 = seg.p2 then
      (if seg.p1.x = p.x then none
       else some ((seg.p1.y - p.y) / (seg.p1.x - p.x)))
    else
      (if seg.p2.x = seg.p1.x then none
       else some ((seg.p2.y - seg.p1.y) / (seg.p2.x - seg.p1.x)))).toFinset
  obtain ⟨q, hq⟩ := Finset.exists_not_mem badSlopes
  -- For any non-degenerate seg, denominator ≠ 0
  have h_denom_ne : ∀ seg ∈ L, seg.p1 ≠ seg.p2 →
      (seg.p2.y - seg.p1.y) - q * (seg.p2.x - seg.p1.x) ≠ 0 := by
    intro seg hmem hne hdenom
    by_cases hx : seg.p2.x = seg.p1.x
    · have hxsub : seg.p2.x - seg.p1.x = 0 := by linarith
      have hy_eq : seg.p2.y - seg.p1.y = 0 := by rw [hxsub] at hdenom; linarith
      have hxv : seg.p1.x = seg.p2.x := hx.symm
      have hyv : seg.p1.y = seg.p2.y := by linarith
      apply hne
      have : seg.p1 = seg.p2 := Vector2D.ext hxv hyv
      exact this
    · -- q = (p2.y - p1.y)/(p2.x - p1.x), so q ∈ badSlopes
      apply hq
      simp only [badSlopes, List.mem_toFinset, List.mem_filterMap]
      refine ⟨seg, hmem, ?_⟩
      have hxne : seg.p2.x - seg.p1.x ≠ 0 := sub_ne_zero.mpr hx
      have hq_eq : q = (seg.p2.y - seg.p1.y) / (seg.p2.x - seg.p1.x) := by
        rw [eq_div_iff hxne]; linarith
      simp only [if_neg hne, if_neg hx]
      exact hq_eq ▸ rfl
  -- Degenerate seg case: line never reaches the point
  have h_deg_no_hit : ∀ seg ∈ L, seg.p1 = seg.p2 →
      ∀ t : ℚ, ¬ (p.x + t = seg.p1.x ∧ p.y + t * q = seg.p1.y) := by
    intro seg hmem heq t ⟨hxeq, hyeq⟩
    by_cases hxc : seg.p1.x = p.x
    · -- t = 0, then p.y = seg.p1.y, so p = seg.p1
      have ht0 : t = 0 := by linarith
      have hye : p.y = seg.p1.y := by rw [ht0] at hyeq; linarith
      have hp_eq : p = seg.p1 := Vector2D.ext hxc.symm hye
      apply h_p_not_in_L seg hmem
      rw [hp_eq]
      exact ⟨0, le_refl 0, zero_le_one, by rw [heq]; ring, by rw [heq]; ring⟩
    · have ht_eq : t = seg.p1.x - p.x := by linarith
      have hxne : seg.p1.x - p.x ≠ 0 := sub_ne_zero.mpr hxc
      have hq_eq : q = (seg.p1.y - p.y) / (seg.p1.x - p.x) := by
        rw [eq_div_iff hxne]
        rw [ht_eq] at hyeq
        linarith
      apply hq
      simp only [badSlopes, List.mem_toFinset, List.mem_filterMap]
      refine ⟨seg, hmem, ?_⟩
      simp only [if_pos heq, if_neg hxc]
      exact hq_eq ▸ rfl
  -- Step 2: Define the (would-be) crossing parameter for each seg.
  let tSeg : LineSegment → ℚ := fun seg =>
    ((seg.p1.x - p.x) * (seg.p2.y - seg.p1.y) -
     (seg.p1.y - p.y) * (seg.p2.x - seg.p1.x)) /
    ((seg.p2.y - seg.p1.y) - q * (seg.p2.x - seg.p1.x))
  -- Step 3: Compute M = min positive tSeg with default 1.
  let M : ℚ := L.foldr (fun seg acc =>
    if 0 < tSeg seg then min acc (tSeg seg) else acc) 1
  have hM_pos_aux : ∀ (L' : List LineSegment),
      0 < L'.foldr (fun seg acc => if 0 < tSeg seg then min acc (tSeg seg) else acc) 1 := by
    intro L'
    induction L' with
    | nil => norm_num
    | cons s rest ih =>
      simp only [List.foldr_cons]
      split_ifs with h
      · exact lt_min ih h
      · exact ih
  have hM_pos : 0 < M := hM_pos_aux L
  have hM_le_aux : ∀ (L' : List LineSegment) (seg : LineSegment),
      seg ∈ L' → 0 < tSeg seg →
      L'.foldr (fun seg acc => if 0 < tSeg seg then min acc (tSeg seg) else acc) 1 ≤ tSeg seg := by
    intro L'
    induction L' with
    | nil => intro seg hmem _; exact ((List.not_mem_nil _) hmem).elim
    | cons s rest ih =>
      intro seg hmem hpos
      simp only [List.foldr_cons]
      rcases List.mem_cons.mp hmem with rfl | hmem'
      · rw [if_pos hpos]; exact min_le_right _ _
      · split_ifs with h
        · exact (min_le_left _ _).trans (ih seg hmem' hpos)
        · exact ih seg hmem' hpos
  have hM_le : ∀ seg ∈ L, 0 < tSeg seg → M ≤ tSeg seg :=
    fun seg hmem hpos => hM_le_aux L seg hmem hpos
  -- Step 4: Pick m = M / 2, so 0 < m < M.
  set m : ℚ := M / 2 with hm_def
  have hm_pos : 0 < m := by rw [hm_def]; positivity
  have hm_lt_M : m < M := by rw [hm_def]; linarith
  -- Define p'
  let p' : Vector2D := ⟨p.x + m, p.y + m * q⟩
  refine ⟨p', ?_, ?_⟩
  · -- p' ≠ p
    intro h_eq
    have : p'.x = p.x := congrArg Vector2D.x h_eq
    show False
    have : p.x + m = p.x := this
    linarith
  · -- For each seg in L, segment from p to p' is disjoint from seg.
    intro seg hmem
    show (LineSegment.mk p p').toSet ∩ seg.toSet = ∅
    rw [Set.eq_empty_iff_forall_not_mem]
    intro x ⟨hx_pp', hx_seg⟩
    -- Extract t parameter for x on segment p to p'
    obtain ⟨tt, htt0, htt1, hxx, hxy⟩ := hx_pp'
    -- p'.x = p.x + m, p'.y = p.y + m*q, so x.x = p.x + tt*m, x.y = p.y + tt*m*q
    have hxx' : x.x = p.x + tt * m := by
      show x.x = p.x + tt * m
      rw [hxx]
      show (1 - tt) * p.x + tt * (p.x + m) = p.x + tt * m
      ring
    have hxy' : x.y = p.y + (tt * m) * q := by
      show x.y = p.y + (tt * m) * q
      rw [hxy]
      show (1 - tt) * p.y + tt * (p.y + m * q) = p.y + (tt * m) * q
      ring
    set s : ℚ := tt * m with hs_def
    have hs_nn : 0 ≤ s := mul_nonneg htt0 (le_of_lt hm_pos)
    have hs_le_m : s ≤ m := by
      rw [hs_def]
      have : tt * m ≤ 1 * m := by
        exact mul_le_mul_of_nonneg_right htt1 (le_of_lt hm_pos)
      linarith
    have hxx'' : x.x = p.x + s := hxx'
    have hxy'' : x.y = p.y + s * q := hxy'
    -- x is on seg.toSet, so there's u ∈ [0, 1] with seg.p1, seg.p2 expressions
    obtain ⟨u, hu0, hu1, hsx, hsy⟩ := hx_seg
    -- p.x + s = (1-u)*seg.p1.x + u*seg.p2.x
    -- p.y + s*q = (1-u)*seg.p1.y + u*seg.p2.y
    have hsx' : p.x + s = (1 - u) * seg.p1.x + u * seg.p2.x := hxx'' ▸ hsx
    have hsy' : p.y + s * q = (1 - u) * seg.p1.y + u * seg.p2.y := hxy'' ▸ hsy
    by_cases h_deg : seg.p1 = seg.p2
    · -- Degenerate seg: line doesn't hit it.
      apply h_deg_no_hit seg hmem h_deg s
      refine ⟨?_, ?_⟩
      · rw [hsx']; rw [h_deg]; ring
      · rw [hsy']; rw [h_deg]; ring
    · -- Non-degenerate. Show s = tSeg seg.
      have hdenom_ne := h_denom_ne seg hmem h_deg
      -- From hsx', hsy', derive: s * denom = numer, and u * denom = ...
      -- s * ((p2.y - p1.y) - q*(p2.x - p1.x))
      --   = (p1.x - p.x)*(p2.y - p1.y) - (p1.y - p.y)*(p2.x - p1.x)
      have h_s_denom :
          s * ((seg.p2.y - seg.p1.y) - q * (seg.p2.x - seg.p1.x)) =
          (seg.p1.x - p.x) * (seg.p2.y - seg.p1.y) -
          (seg.p1.y - p.y) * (seg.p2.x - seg.p1.x) := by
        -- From hsx': s = seg.p1.x - p.x + u*(seg.p2.x - seg.p1.x)
        have h1 : s = (seg.p1.x - p.x) + u * (seg.p2.x - seg.p1.x) := by linarith
        -- From hsy': s*q = seg.p1.y - p.y + u*(seg.p2.y - seg.p1.y)
        have h2 : s * q = (seg.p1.y - p.y) + u * (seg.p2.y - seg.p1.y) := by linarith
        have e1 : s * (seg.p2.y - seg.p1.y) =
                  ((seg.p1.x - p.x) + u * (seg.p2.x - seg.p1.x)) *
                  (seg.p2.y - seg.p1.y) := by rw [h1]
        have e2 : (s * q) * (seg.p2.x - seg.p1.x) =
                  ((seg.p1.y - p.y) + u * (seg.p2.y - seg.p1.y)) *
                  (seg.p2.x - seg.p1.x) := by rw [h2]
        linear_combination e1 - e2
      have hs_eq : s = tSeg seg := by
        rw [show tSeg seg = _ from rfl]
        rw [eq_div_iff hdenom_ne]
        linarith
      -- Now s = tSeg seg, and s ≤ m, but tSeg seg > 0 (since s > 0... but is s > 0?)
      -- Actually we just need s ≥ 0 and s ≤ m. If s = 0, then x = p, but
      -- p ∉ seg.toSet contradicts x ∈ seg.toSet.
      have h_s_pos : 0 < s := by
        rcases lt_or_eq_of_le hs_nn with h | h
        · exact h
        · -- s = 0 case: x = p, contradicting p ∉ seg.toSet
          exfalso
          apply h_p_not_in_L seg hmem
          have hxp : x = p := by
            ext
            · rw [hxx'']; rw [← h]; ring
            · rw [hxy'']; rw [← h]; ring
          rw [← hxp]
          exact ⟨u, hu0, hu1, hsx, hsy⟩
      have h_tSeg_pos : 0 < tSeg seg := hs_eq ▸ h_s_pos
      have hM_le_tSeg : M ≤ tSeg seg := hM_le seg hmem h_tSeg_pos
      -- s ≤ m < M ≤ tSeg seg = s. Contradiction.
      linarith

lemma exists_perturbation_off_segs
    (p : Vector2D) (L : List LineSegment)
    (h_seg_nondeg : ∀ seg ∈ L, seg.p1 ≠ seg.p2) :
    ∃ p' : Vector2D, p' ≠ p ∧
      (∀ seg ∈ L, p' ∉ seg.toSet) ∧
      (∀ seg ∈ L, p ∉ seg.toSet → segmentDoesNotIntersectSegment ⟨p, p'⟩ seg) := by
  -- Step 1: Pick a slope q so that direction (1, q) is not parallel to any
  -- (non-degenerate) seg in L.
  have h_inf : Infinite ℚ :=
    Infinite.of_injective (fun n : ℕ => (n : ℚ)) Nat.cast_injective
  let badSlopes : Finset ℚ := (L.filterMap fun seg =>
    if seg.p2.x = seg.p1.x then none
    else some ((seg.p2.y - seg.p1.y) / (seg.p2.x - seg.p1.x))).toFinset
  obtain ⟨q, hq⟩ := Finset.exists_not_mem badSlopes
  -- For any seg in L, denominator ≠ 0
  have h_denom_ne : ∀ seg ∈ L,
      (seg.p2.y - seg.p1.y) - q * (seg.p2.x - seg.p1.x) ≠ 0 := by
    intro seg hmem hdenom
    have hne : seg.p1 ≠ seg.p2 := h_seg_nondeg seg hmem
    by_cases hx : seg.p2.x = seg.p1.x
    · have hxsub : seg.p2.x - seg.p1.x = 0 := by linarith
      have hy_eq : seg.p2.y - seg.p1.y = 0 := by rw [hxsub] at hdenom; linarith
      have hxv : seg.p1.x = seg.p2.x := hx.symm
      have hyv : seg.p1.y = seg.p2.y := by linarith
      apply hne
      exact Vector2D.ext hxv hyv
    · apply hq
      simp only [badSlopes, List.mem_toFinset, List.mem_filterMap]
      refine ⟨seg, hmem, ?_⟩
      have hxne : seg.p2.x - seg.p1.x ≠ 0 := sub_ne_zero.mpr hx
      have hq_eq : q = (seg.p2.y - seg.p1.y) / (seg.p2.x - seg.p1.x) := by
        rw [eq_div_iff hxne]; linarith
      simp only [if_neg hx]
      exact hq_eq ▸ rfl
  -- Step 2: Define the (would-be) crossing parameter for each seg.
  let tSeg : LineSegment → ℚ := fun seg =>
    ((seg.p1.x - p.x) * (seg.p2.y - seg.p1.y) -
     (seg.p1.y - p.y) * (seg.p2.x - seg.p1.x)) /
    ((seg.p2.y - seg.p1.y) - q * (seg.p2.x - seg.p1.x))
  -- For seg with p ∈ seg.toSet, tSeg seg = 0.
  have h_tSeg_zero_of_mem : ∀ seg ∈ L, p ∈ seg.toSet → tSeg seg = 0 := by
    intro seg hmem hp_in
    obtain ⟨s, hs0, hs1, hpx, hpy⟩ := hp_in
    have h_numer :
        (seg.p1.x - p.x) * (seg.p2.y - seg.p1.y) -
        (seg.p1.y - p.y) * (seg.p2.x - seg.p1.x) = 0 := by
      have hpx' : p.x - seg.p1.x = s * (seg.p2.x - seg.p1.x) := by
        rw [hpx]; ring
      have hpy' : p.y - seg.p1.y = s * (seg.p2.y - seg.p1.y) := by
        rw [hpy]; ring
      linear_combination
        -(seg.p2.y - seg.p1.y) * hpx' + (seg.p2.x - seg.p1.x) * hpy'
    show ((seg.p1.x - p.x) * (seg.p2.y - seg.p1.y) -
       (seg.p1.y - p.y) * (seg.p2.x - seg.p1.x)) /
      ((seg.p2.y - seg.p1.y) - q * (seg.p2.x - seg.p1.x)) = 0
    rw [h_numer, zero_div]
  -- Step 3: Compute M = min positive tSeg with default 1.
  let M : ℚ := L.foldr (fun seg acc =>
    if 0 < tSeg seg then min acc (tSeg seg) else acc) 1
  have hM_pos_aux : ∀ (L' : List LineSegment),
      0 < L'.foldr (fun seg acc => if 0 < tSeg seg then min acc (tSeg seg) else acc) 1 := by
    intro L'
    induction L' with
    | nil => norm_num
    | cons s rest ih =>
      simp only [List.foldr_cons]
      split_ifs with h
      · exact lt_min ih h
      · exact ih
  have hM_pos : 0 < M := hM_pos_aux L
  have hM_le_aux : ∀ (L' : List LineSegment) (seg : LineSegment),
      seg ∈ L' → 0 < tSeg seg →
      L'.foldr (fun seg acc => if 0 < tSeg seg then min acc (tSeg seg) else acc) 1 ≤ tSeg seg := by
    intro L'
    induction L' with
    | nil => intro seg hmem _; exact ((List.not_mem_nil _) hmem).elim
    | cons s rest ih =>
      intro seg hmem hpos
      simp only [List.foldr_cons]
      rcases List.mem_cons.mp hmem with rfl | hmem'
      · rw [if_pos hpos]; exact min_le_right _ _
      · split_ifs with h
        · exact (min_le_left _ _).trans (ih seg hmem' hpos)
        · exact ih seg hmem' hpos
  have hM_le : ∀ seg ∈ L, 0 < tSeg seg → M ≤ tSeg seg :=
    fun seg hmem hpos => hM_le_aux L seg hmem hpos
  -- Step 4: Pick m = M / 2.
  set m : ℚ := M / 2 with hm_def
  have hm_pos : 0 < m := by rw [hm_def]; positivity
  have hm_lt_M : m < M := by rw [hm_def]; linarith
  -- Define p'
  let p' : Vector2D := ⟨p.x + m, p.y + m * q⟩
  -- Helper: if x ∈ seg.toSet at parameter (s, u) then s = tSeg seg.
  have h_param_eq : ∀ seg ∈ L, ∀ s u : ℚ,
      p.x + s = (1 - u) * seg.p1.x + u * seg.p2.x →
      p.y + s * q = (1 - u) * seg.p1.y + u * seg.p2.y →
      s = tSeg seg := by
    intro seg hmem s u hsx hsy
    have hdenom_ne := h_denom_ne seg hmem
    have h1 : s = (seg.p1.x - p.x) + u * (seg.p2.x - seg.p1.x) := by linarith
    have h2 : s * q = (seg.p1.y - p.y) + u * (seg.p2.y - seg.p1.y) := by linarith
    have e1 : s * (seg.p2.y - seg.p1.y) =
              ((seg.p1.x - p.x) + u * (seg.p2.x - seg.p1.x)) *
              (seg.p2.y - seg.p1.y) := by rw [h1]
    have e2 : (s * q) * (seg.p2.x - seg.p1.x) =
              ((seg.p1.y - p.y) + u * (seg.p2.y - seg.p1.y)) *
              (seg.p2.x - seg.p1.x) := by rw [h2]
    have h_s_denom :
        s * ((seg.p2.y - seg.p1.y) - q * (seg.p2.x - seg.p1.x)) =
        (seg.p1.x - p.x) * (seg.p2.y - seg.p1.y) -
        (seg.p1.y - p.y) * (seg.p2.x - seg.p1.x) := by
      linear_combination e1 - e2
    show s = ((seg.p1.x - p.x) * (seg.p2.y - seg.p1.y) -
       (seg.p1.y - p.y) * (seg.p2.x - seg.p1.x)) /
      ((seg.p2.y - seg.p1.y) - q * (seg.p2.x - seg.p1.x))
    rw [eq_div_iff hdenom_ne]; linarith
  refine ⟨p', ?_, ?_, ?_⟩
  · -- p' ≠ p
    intro h_eq
    have hxe : p'.x = p.x := congrArg Vector2D.x h_eq
    have : p.x + m = p.x := hxe
    linarith
  · -- ∀ seg ∈ L, p' ∉ seg.toSet
    intro seg hmem hp'_in
    obtain ⟨u, hu0, hu1, hp'x, hp'y⟩ := hp'_in
    -- p'.x = p.x + m, p'.y = p.y + m*q
    have hp'x' : p.x + m = (1 - u) * seg.p1.x + u * seg.p2.x := hp'x
    have hp'y' : p.y + m * q = (1 - u) * seg.p1.y + u * seg.p2.y := hp'y
    have hm_eq : m = tSeg seg := h_param_eq seg hmem m u hp'x' hp'y'
    by_cases hp_in : p ∈ seg.toSet
    · have htSeg0 : tSeg seg = 0 := h_tSeg_zero_of_mem seg hmem hp_in
      have : m = 0 := hm_eq.trans htSeg0
      linarith
    · -- p ∉ seg.toSet. tSeg seg may be ≤ 0 or > 0.
      by_cases hpos : 0 < tSeg seg
      · have hM_le_t : M ≤ tSeg seg := hM_le seg hmem hpos
        -- m < M ≤ tSeg seg = m. Contradiction.
        linarith
      · -- tSeg seg ≤ 0; but m = tSeg seg and m > 0. Contradiction.
        push_neg at hpos
        linarith
  · -- ∀ seg ∈ L, p ∉ seg.toSet → segmentDoesNotIntersectSegment ⟨p, p'⟩ seg
    intro seg hmem hp_not_in
    show (LineSegment.mk p p').toSet ∩ seg.toSet = ∅
    rw [Set.eq_empty_iff_forall_not_mem]
    intro x ⟨hx_pp', hx_seg⟩
    obtain ⟨tt, htt0, htt1, hxx, hxy⟩ := hx_pp'
    have hxx' : x.x = p.x + tt * m := by
      rw [hxx]; show (1 - tt) * p.x + tt * (p.x + m) = p.x + tt * m; ring
    have hxy' : x.y = p.y + (tt * m) * q := by
      rw [hxy]; show (1 - tt) * p.y + tt * (p.y + m * q) = p.y + (tt * m) * q; ring
    set s : ℚ := tt * m with hs_def
    have hs_nn : 0 ≤ s := mul_nonneg htt0 (le_of_lt hm_pos)
    have hs_le_m : s ≤ m := by
      rw [hs_def]
      have : tt * m ≤ 1 * m :=
        mul_le_mul_of_nonneg_right htt1 (le_of_lt hm_pos)
      linarith
    have hxx'' : x.x = p.x + s := hxx'
    have hxy'' : x.y = p.y + s * q := hxy'
    obtain ⟨u, hu0, hu1, hsx, hsy⟩ := hx_seg
    have hsx' : p.x + s = (1 - u) * seg.p1.x + u * seg.p2.x := hxx'' ▸ hsx
    have hsy' : p.y + s * q = (1 - u) * seg.p1.y + u * seg.p2.y := hxy'' ▸ hsy
    have hs_eq : s = tSeg seg := h_param_eq seg hmem s u hsx' hsy'
    have h_s_pos : 0 < s := by
      rcases lt_or_eq_of_le hs_nn with h | h
      · exact h
      · exfalso
        apply hp_not_in
        have hxp : x = p := by
          ext
          · rw [hxx'']; rw [← h]; ring
          · rw [hxy'']; rw [← h]; ring
        rw [← hxp]
        exact ⟨u, hu0, hu1, hsx, hsy⟩
    have h_tSeg_pos : 0 < tSeg seg := hs_eq ▸ h_s_pos
    have hM_le_tSeg : M ≤ tSeg seg := hM_le seg hmem h_tSeg_pos
    linarith

/-- Transport `G2.interior` membership across a segment that avoids `G2`'s
    boundary: if `p ∈ G2.interior` and the segment from `p` to `q` is disjoint
    from `G2.toBoundarySet`, then `q ∈ G2.interior` (provided `q ∉ G2`'s
    boundary). -/
lemma G2_interior_via_segment
    (G1 G2 : EvenGraph)
    (_h_fin12 : Set.Finite (G1.toBoundarySet ∩ G2.toBoundarySet))
    (h_fin21 : Set.Finite (G2.toBoundarySet ∩ G1.toBoundarySet))
    (p q : Vector2D)
    (h_p_int : p ∈ G2.interior)
    (h_q_not_G2 : q ∉ G2.toBoundarySet)
    (h_segpq_avoids : ∀ x ∈ (LineSegment.mk p q).toSet, x ∉ G2.toBoundarySet) :
    q ∈ G2.interior := by
  set G2' := graphRefinementSelfAndWrt G2 G1 h_fin21 with hG2'_def
  have h_int_eq : G2'.interior = G2.interior :=
    graphRefinementSelfAndWrt_interior_eq G2 G1 h_fin21
  have h_bnd_eq : G2'.toBoundarySet = G2.toBoundarySet :=
    graphRefinementSelfAndWrt_boundary_eq G2 G1 h_fin21
  have h_pos2 := G2'.incident_count_pos
  rw [← h_int_eq] at h_p_int ⊢
  have h_p_not_G2' : p ∉ G2'.toBoundarySet := by
    intro h_in
    obtain ⟨seg', hseg', h_in_seg⟩ := h_in
    exact h_p_int.1 seg' hseg' h_in_seg
  have h_q_not_G2' : q ∉ G2'.toBoundarySet := by rw [h_bnd_eq]; exact h_q_not_G2
  have h_q_avoids_G2'_segs : ∀ seg ∈ G2'.segments, pointAvoidsSegment q seg := by
    intro seg' hseg' h_in
    exact h_q_not_G2' ⟨seg', hseg', h_in⟩
  refine ⟨h_q_avoids_G2'_segs, fun r_q h_r_q_origin h_r_q_avoids_verts => ?_⟩
  have h_p_not_G2'_verts : ∀ v ∈ G2'.toVertices, v ≠ p := by
    intro v hv heq
    have h_v_on_seg : ∃ s ∈ G2'.segments, v ∈ s.toSet :=
      vertex_on_some_segment G2' v (h_pos2 v hv)
    obtain ⟨s, hs_mem, hs_v⟩ := h_v_on_seg
    exact h_p_not_G2' ⟨s, hs_mem, heq ▸ hs_v⟩
  obtain ⟨r_p, h_r_p_origin, h_r_p_avoids_verts⟩ :=
    exists_ray_avoiding_graph_verts p G2' h_p_not_G2'_verts
  have h_segpq_avoids_G2'_bnd : ∀ x ∈ (LineSegment.mk p q).toSet,
      x ∉ G2'.toBoundarySet := by
    intro x hx h_x_in
    rw [h_bnd_eq] at h_x_in
    exact h_segpq_avoids x hx h_x_in
  have h_seg_pq_avoids_segs : ∀ seg ∈ G2'.segments,
      segmentDoesNotIntersectSegment ⟨p, q⟩ seg := by
    intro seg hseg
    ext x
    simp only [Set.mem_inter_iff, Set.mem_empty_iff_false, iff_false, not_and]
    intro hx_pq hx_seg
    exact h_segpq_avoids_G2'_bnd x hx_pq ⟨seg, hseg, hx_seg⟩
  have h_verts_avoid_pq : ∀ v ∈ G2'.toVertices, v ∉ (LineSegment.mk p q).toSet := by
    intro v hv hv_mem
    have h_v_on_seg : ∃ s ∈ G2'.segments, v ∈ s.toSet :=
      vertex_on_some_segment G2' v (h_pos2 v hv)
    obtain ⟨s, hs_mem, hs_v⟩ := h_v_on_seg
    exact h_segpq_avoids_G2'_bnd v hv_mem ⟨s, hs_mem, hs_v⟩
  have h_sego_avoids : ∀ seg ∈ G2'.segments,
      segmentDoesNotIntersectSegment ⟨r_p.origin, r_q.origin⟩ seg := by
    rw [h_r_p_origin, h_r_q_origin]; exact h_seg_pq_avoids_segs
  have h_verts_avoid_sego : ∀ v ∈ G2'.toVertices,
      v ∉ (LineSegment.mk r_p.origin r_q.origin).toSet := by
    rw [h_r_p_origin, h_r_q_origin]; exact h_verts_avoid_pq
  have h_parity := intersectionParity_eq_of_originSegmentAvoidsGraphSegments
    r_p r_q G2' h_r_p_avoids_verts h_r_q_avoids_verts h_sego_avoids h_verts_avoid_sego
  have h_p_odd : intersectionRayGraphSegmentsNumber r_p G2' % 2 = 1 :=
    h_p_int.2 r_p h_r_p_origin h_r_p_avoids_verts
  rw [h_parity] at h_p_odd
  exact h_p_odd

/-- For a refined-G1 segment `seg` containing `p` and `q ∈ seg.openInterior`,
    the segment from `p` to `q` is contained in `seg.toSet`. -/
lemma segment_pq_subset_refined_seg
    (seg : LineSegment) (p q : Vector2D)
    (hp_seg : p ∈ seg.toSet) (hq_seg : q ∈ seg.toSet) :
    ∀ x ∈ (LineSegment.mk p q).toSet, x ∈ seg.toSet := by
  intro x hx
  obtain ⟨u, hu0, hu1, hux, huy⟩ := hx
  obtain ⟨t_p, ht_p0, ht_p1, htpx, htpy⟩ := hp_seg
  obtain ⟨t_q, ht_q0, ht_q1, htqx, htqy⟩ := hq_seg
  set s := (1 - u) * t_p + u * t_q with hs_def
  have hs0 : 0 ≤ s := by rw [hs_def]; nlinarith
  have hs1 : s ≤ 1 := by rw [hs_def]; nlinarith
  refine ⟨s, hs0, hs1, ?_, ?_⟩
  · rw [hux, htpx, htqx, hs_def]; ring
  · rw [huy, htpy, htqy, hs_def]; ring

/-- Case 1: If `p ∈ G1.toBoundarySet ∩ G2.interior`, then `p` lies on the
    intersection graph's boundary (because the refined-G1 segment containing `p`
    has its open interior in `G2.interior` and is therefore selected). -/
lemma case1_G1_bnd_G2_int_in_inter_bnd
    (G1 G2 : EvenGraph)
    (h_fin12 : Set.Finite (G1.toBoundarySet ∩ G2.toBoundarySet))
    (h_fin21 : Set.Finite (G2.toBoundarySet ∩ G1.toBoundarySet))
    (p : Vector2D)
    (h_p_on_G1 : p ∈ G1.toBoundarySet)
    (h_p_in_G2_int : p ∈ G2.interior) :
    p ∈ (((graphRefinementSelfAndWrt G1 G2 h_fin12).toGraph.selectSegmentsInside
            G2.interior).append
        ((graphRefinementSelfAndWrt G2 G1 h_fin21).toGraph.selectSegmentsInside
            G1.interior)).toBoundarySet := by
  set G1' := graphRefinementSelfAndWrt G1 G2 h_fin12 with hG1'_def
  have hG1'_bnd : G1'.toBoundarySet = G1.toBoundarySet :=
    graphRefinementSelfAndWrt_boundary_eq G1 G2 h_fin12
  have h_p_G1' : p ∈ G1'.toBoundarySet := by rw [hG1'_bnd]; exact h_p_on_G1
  obtain ⟨seg, hseg, hp_seg⟩ := h_p_G1'
  have h_seg_nondeg : seg.p1 ≠ seg.p2 := G1'.segments_nondegenerate seg hseg
  have h_p_not_G2 : p ∉ G2.toBoundarySet := by
    intro h_in
    obtain ⟨seg', hseg', h_in_seg⟩ := h_in
    exact h_p_in_G2_int.1 seg' hseg' h_in_seg
  -- Show seg.openInterior ⊆ G2.interior, hence seg is selected.
  have h_seg_selected : segmentOpenInteriorSubset seg G2.interior := by
    intro q hq_seg hq_p1 hq_p2
    -- Show segment p-q avoids G2.boundary, then apply G2_interior_via_segment.
    have h_q_not_G2 : q ∉ G2.toBoundarySet := by
      intro h_in
      have h_subset := graphRefinementSelfAndWrt_seg_inter_boundary_subset G1 G2 h_fin12 seg hseg
      have hq_endpts : q ∈ ({seg.p1, seg.p2} : Set Vector2D) := h_subset ⟨hq_seg, h_in⟩
      rcases hq_endpts with h | h
      · exact hq_p1 h
      · exact hq_p2 h
    -- segment p-q ⊆ seg.toSet
    have h_segpq_subset_seg : ∀ x ∈ (LineSegment.mk p q).toSet, x ∈ seg.toSet :=
      segment_pq_subset_refined_seg seg p q hp_seg hq_seg
    -- segment p-q avoids G2.boundary
    have h_segpq_avoids_G2 : ∀ x ∈ (LineSegment.mk p q).toSet, x ∉ G2.toBoundarySet := by
      intro x hx h_x_G2
      have hx_seg : x ∈ seg.toSet := h_segpq_subset_seg x hx
      have h_subset := graphRefinementSelfAndWrt_seg_inter_boundary_subset G1 G2 h_fin12 seg hseg
      have hx_endpts : x ∈ ({seg.p1, seg.p2} : Set Vector2D) := h_subset ⟨hx_seg, h_x_G2⟩
      -- x = seg.p1 or seg.p2. Derive contradiction.
      -- The argument: x in segment p-q at parameter u, x on seg at parameter s.
      -- x = seg.p1 means s = 0, i.e., (1-u)*t_p + u*t_q = 0.
      -- From q ≠ seg.p1: t_q ≠ 0. From hu0, hu1, ht_p0, ht_q0: signs analysis.
      obtain ⟨u, hu0, hu1, hux, huy⟩ := hx
      obtain ⟨t_p, ht_p0, ht_p1, htpx, htpy⟩ := hp_seg
      obtain ⟨t_q, ht_q0, ht_q1, htqx, htqy⟩ := hq_seg
      -- t_q ≠ 0: from q ≠ seg.p1.
      have h_t_q_ne : t_q ≠ 0 := by
        intro ht_q_zero
        apply hq_p1
        have hqx_eq : q.x = seg.p1.x := by rw [htqx, ht_q_zero]; ring
        have hqy_eq : q.y = seg.p1.y := by rw [htqy, ht_q_zero]; ring
        exact Vector2D.ext hqx_eq hqy_eq
      -- t_q ≠ 1: from q ≠ seg.p2.
      have h_t_q_ne_one : t_q ≠ 1 := by
        intro ht_q_one
        apply hq_p2
        have hqx_eq : q.x = seg.p2.x := by rw [htqx, ht_q_one]; ring
        have hqy_eq : q.y = seg.p2.y := by rw [htqy, ht_q_one]; ring
        exact Vector2D.ext hqx_eq hqy_eq
      rcases hx_endpts with hxp1 | hxp2
      · -- x = seg.p1. Want contradiction.
        -- x.x = seg.p1.x and x.x = (1-s) * seg.p1.x + s * seg.p2.x.
        -- Hmm, simpler: x = (1-u)*p + u*q. Compute parameter s on seg.
        -- s such that x = (1-s)*seg.p1 + s*seg.p2.
        -- s = (1-u)*t_p + u*t_q.
        set s := (1 - u) * t_p + u * t_q with hs_def
        have hs0 : 0 ≤ s := by rw [hs_def]; nlinarith
        have hxx : x.x = (1 - s) * seg.p1.x + s * seg.p2.x := by
          rw [hux, htpx, htqx, hs_def]; ring
        have hxy : x.y = (1 - s) * seg.p1.y + s * seg.p2.y := by
          rw [huy, htpy, htqy, hs_def]; ring
        -- x = seg.p1, so s = 0.
        have hxx_eq : seg.p1.x = (1 - s) * seg.p1.x + s * seg.p2.x := by
          rw [← hxx]; exact (congrArg Vector2D.x hxp1).symm
        have hxy_eq : seg.p1.y = (1 - s) * seg.p1.y + s * seg.p2.y := by
          rw [← hxy]; exact (congrArg Vector2D.y hxp1).symm
        have hdx : s * (seg.p2.x - seg.p1.x) = 0 := by linarith
        have hdy : s * (seg.p2.y - seg.p1.y) = 0 := by linarith
        have hs_zero : s = 0 := by
          by_contra h_s_ne
          have hpx_eq : seg.p2.x = seg.p1.x := by
            rcases mul_eq_zero.mp hdx with h | h
            · exact absurd h h_s_ne
            · linarith
          have hpy_eq : seg.p2.y = seg.p1.y := by
            rcases mul_eq_zero.mp hdy with h | h
            · exact absurd h h_s_ne
            · linarith
          exact h_seg_nondeg (Vector2D.ext hpx_eq.symm hpy_eq.symm)
        -- s = (1-u)*t_p + u*t_q = 0, with all ≥ 0.
        have h_sum_zero : (1 - u) * t_p + u * t_q = 0 := by rw [← hs_def]; exact hs_zero
        have h_1mu_nn : 0 ≤ 1 - u := by linarith
        have h_lhs_nn : 0 ≤ (1 - u) * t_p := mul_nonneg h_1mu_nn ht_p0
        have h_rhs_nn : 0 ≤ u * t_q := mul_nonneg hu0 ht_q0
        have h_lhs_zero : (1 - u) * t_p = 0 := by linarith
        have h_rhs_zero : u * t_q = 0 := by linarith
        have h_u_zero : u = 0 := by
          rcases mul_eq_zero.mp h_rhs_zero with h | h
          · exact h
          · exact absurd h h_t_q_ne
        -- u = 0, so x = p.
        have h_x_eq_p : x = p := by
          have hxx' : x.x = p.x := by rw [hux, h_u_zero]; ring
          have hxy' : x.y = p.y := by rw [huy, h_u_zero]; ring
          exact Vector2D.ext hxx' hxy'
        rw [h_x_eq_p] at h_x_G2
        exact h_p_not_G2 h_x_G2
      · -- x = seg.p2. Symmetric to above.
        set s := (1 - u) * t_p + u * t_q with hs_def
        have hs1 : s ≤ 1 := by rw [hs_def]; nlinarith
        have hxx : x.x = (1 - s) * seg.p1.x + s * seg.p2.x := by
          rw [hux, htpx, htqx, hs_def]; ring
        have hxy : x.y = (1 - s) * seg.p1.y + s * seg.p2.y := by
          rw [huy, htpy, htqy, hs_def]; ring
        -- x = seg.p2, so s = 1.
        have hxx_eq : seg.p2.x = (1 - s) * seg.p1.x + s * seg.p2.x := by
          rw [← hxx]; exact (congrArg Vector2D.x hxp2).symm
        have hxy_eq : seg.p2.y = (1 - s) * seg.p1.y + s * seg.p2.y := by
          rw [← hxy]; exact (congrArg Vector2D.y hxp2).symm
        have hdx : (1 - s) * (seg.p2.x - seg.p1.x) = 0 := by linarith
        have hdy : (1 - s) * (seg.p2.y - seg.p1.y) = 0 := by linarith
        have hs_one : s = 1 := by
          by_contra h_s_ne
          have h_1ms_ne : 1 - s ≠ 0 := by
            intro h
            apply h_s_ne
            linarith
          have hpx_eq : seg.p2.x = seg.p1.x := by
            rcases mul_eq_zero.mp hdx with h | h
            · exact absurd h h_1ms_ne
            · linarith
          have hpy_eq : seg.p2.y = seg.p1.y := by
            rcases mul_eq_zero.mp hdy with h | h
            · exact absurd h h_1ms_ne
            · linarith
          exact h_seg_nondeg (Vector2D.ext hpx_eq.symm hpy_eq.symm)
        -- s = (1-u)*t_p + u*t_q = 1.
        have h_sum_one : (1 - u) * t_p + u * t_q = 1 := by rw [← hs_def]; exact hs_one
        have h_1mu_nn : 0 ≤ 1 - u := by linarith
        have h_1mtp_nn : 0 ≤ 1 - t_p := by linarith
        have h_1mtq_nn : 0 ≤ 1 - t_q := by linarith
        -- (1-u)*t_p + u*t_q = 1
        -- Equivalently: (1-u)*(1-t_p) + u*(1-t_q) = 0.
        have h_eq : (1 - u) * (1 - t_p) + u * (1 - t_q) = 0 := by linarith
        have h_lhs_nn : 0 ≤ (1 - u) * (1 - t_p) := mul_nonneg h_1mu_nn h_1mtp_nn
        have h_rhs_nn : 0 ≤ u * (1 - t_q) := mul_nonneg hu0 h_1mtq_nn
        have h_lhs_zero : (1 - u) * (1 - t_p) = 0 := by linarith
        have h_rhs_zero : u * (1 - t_q) = 0 := by linarith
        have h_u_zero : u = 0 := by
          rcases mul_eq_zero.mp h_rhs_zero with h | h
          · exact h
          · -- 1 - t_q = 0, so t_q = 1, contradicts h_t_q_ne_one.
            have : t_q = 1 := by linarith
            exact absurd this h_t_q_ne_one
        have h_x_eq_p : x = p := by
          have hxx' : x.x = p.x := by rw [hux, h_u_zero]; ring
          have hxy' : x.y = p.y := by rw [huy, h_u_zero]; ring
          exact Vector2D.ext hxx' hxy'
        rw [h_x_eq_p] at h_x_G2
        exact h_p_not_G2 h_x_G2
    -- Apply G2_interior_via_segment.
    exact G2_interior_via_segment G1 G2 h_fin12 h_fin21 p q
      h_p_in_G2_int h_q_not_G2 h_segpq_avoids_G2
  -- seg is selected
  have h_seg_in_selected :
      seg ∈ _root_.selectSegmentsInside G1'.segments G2.interior := by
    simp only [_root_.selectSegmentsInside, List.mem_filter, decide_eq_true_eq]
    exact ⟨hseg, h_seg_selected⟩
  -- Conclude p ∈ G_inter.toBoundarySet
  refine ⟨seg, ?_, hp_seg⟩
  rw [Graph.append_segments, List.mem_append]
  left
  exact h_seg_in_selected

/-- Case 2: If `p ∈ G1.toBoundarySet` but `p ∉ G2.toBoundarySet` and
    `p ∉ G2.interior`, while `p` avoids the intersection graph's segments and
    every ray from `p` (avoiding the intersection graph's vertices) has odd
    intersection-graph parity, we derive a contradiction. -/
lemma case2_contradiction
    (G1 G2 : EvenGraph)
    (h_fin12 : Set.Finite (G1.toBoundarySet ∩ G2.toBoundarySet))
    (h_fin21 : Set.Finite (G2.toBoundarySet ∩ G1.toBoundarySet))
    (h_even : (((graphRefinementSelfAndWrt G1 G2 h_fin12).toGraph.selectSegmentsInside
            G2.interior).append
        ((graphRefinementSelfAndWrt G2 G1 h_fin21).toGraph.selectSegmentsInside
            G1.interior)).IsEven)
    (p : Vector2D)
    (_h_p_on_G1 : p ∈ G1.toBoundarySet)
    (h_p_not_G2 : p ∉ G2.toBoundarySet)
    (h_p_not_G2_int : p ∉ G2.interior)
    (h_p_avoids_inter : ∀ seg ∈ (((graphRefinementSelfAndWrt G1 G2 h_fin12).toGraph.selectSegmentsInside
            G2.interior).append
        ((graphRefinementSelfAndWrt G2 G1 h_fin21).toGraph.selectSegmentsInside
            G1.interior)).segments, pointAvoidsSegment p seg)
    (h_p_inter_parity : ∀ r : Ray, r.origin = p →
       rayAvoidsGraphVertices r (((graphRefinementSelfAndWrt G1 G2 h_fin12).toGraph.selectSegmentsInside
            G2.interior).append
        ((graphRefinementSelfAndWrt G2 G1 h_fin21).toGraph.selectSegmentsInside
            G1.interior)) →
       intersectionRayGraphSegmentsNumber r (((graphRefinementSelfAndWrt G1 G2 h_fin12).toGraph.selectSegmentsInside
            G2.interior).append
        ((graphRefinementSelfAndWrt G2 G1 h_fin21).toGraph.selectSegmentsInside
            G1.interior)) % 2 = 1) :
    False := by
  set G1' := graphRefinementSelfAndWrt G1 G2 h_fin12 with hG1'_def
  set G2' := graphRefinementSelfAndWrt G2 G1 h_fin21 with hG2'_def
  set G_inter : Graph :=
    (G1'.toGraph.selectSegmentsInside G2.interior).append
      (G2'.toGraph.selectSegmentsInside G1.interior) with hG_inter_def
  let G_inter_E : EvenGraph := ⟨G_inter, h_even⟩
  have hG1'_bnd : G1'.toBoundarySet = G1.toBoundarySet :=
    graphRefinementSelfAndWrt_boundary_eq G1 G2 h_fin12
  have hG2'_bnd : G2'.toBoundarySet = G2.toBoundarySet :=
    graphRefinementSelfAndWrt_boundary_eq G2 G1 h_fin21
  have hG2'_int : G2'.interior = G2.interior := graphRefinementSelfAndWrt_interior_eq G2 G1 h_fin21
  have h_pos1 := G1'.incident_count_pos
  have h_pos2 := G2'.incident_count_pos
  -- p is not on G2'.toBoundarySet (since p ∉ G2.boundary).
  have h_p_not_G2' : p ∉ G2'.toBoundarySet := by rw [hG2'_bnd]; exact h_p_not_G2
  -- p avoids all G2' segments.
  have h_p_avoids_G2' : ∀ seg ∈ G2'.segments, pointAvoidsSegment p seg := by
    intro seg hseg h_on
    exact h_p_not_G2' ⟨seg, hseg, h_on⟩
  -- Each G_inter segment is in G1'.segments or G2'.segments.
  have hG_inter_segs : G_inter.segments =
      _root_.selectSegmentsInside G1'.segments G2.interior ++
      _root_.selectSegmentsInside G2'.segments G1.interior := rfl
  have h_inter_seg_origin : ∀ seg ∈ G_inter.segments,
      seg ∈ G1'.segments ∨ seg ∈ G2'.segments := by
    intro seg hseg
    rw [hG_inter_segs, List.mem_append] at hseg
    rcases hseg with h | h
    · left; exact List.mem_of_mem_filter h
    · right; exact List.mem_of_mem_filter h
  -- Vertices of G_inter are vertices of refined graphs.
  have h_inter_vert_in_refined : ∀ v ∈ G_inter.toVertices,
      v ∈ G1'.toVertices ∨ v ∈ G2'.toVertices := by
    intro v hv
    simp only [Graph.toVertices, List.mem_dedup, List.mem_flatMap, List.mem_cons,
               (List.not_mem_nil _), or_false] at hv
    obtain ⟨seg, hseg, h_or⟩ := hv
    have h_or' : seg.p1 = v ∨ seg.p2 = v := by
      rcases h_or with rfl | rfl
      · left; rfl
      · right; rfl
    rcases h_inter_seg_origin seg hseg with h1 | h2
    · left
      simp only [Graph.toVertices, List.mem_dedup, List.mem_flatMap, List.mem_cons,
                 (List.not_mem_nil _), or_false]
      rcases h_or' with rfl | rfl
      · exact ⟨seg, h1, Or.inl rfl⟩
      · exact ⟨seg, h1, Or.inr rfl⟩
    · right
      simp only [Graph.toVertices, List.mem_dedup, List.mem_flatMap, List.mem_cons,
                 (List.not_mem_nil _), or_false]
      rcases h_or' with rfl | rfl
      · exact ⟨seg, h2, Or.inl rfl⟩
      · exact ⟨seg, h2, Or.inr rfl⟩
  -- intersectionRayGraphSegmentsNumber for G_inter is intersectionRayCount.
  have h_inter_count_eq : ∀ r : Ray,
      intersectionRayGraphSegmentsNumber r G_inter =
      intersectionRayCount r G1 G2 h_fin12 h_fin21 := fun _ => rfl
  -- Step 1: Apply perturbation. Define L := G1'.segments ++ G2'.segments.
  let L : List LineSegment := G1'.segments ++ G2'.segments
  have hL_nondeg : ∀ seg ∈ L, seg.p1 ≠ seg.p2 := by
    intro seg hseg
    rcases List.mem_append.mp hseg with h | h
    · exact G1'.segments_nondegenerate seg h
    · exact G2'.segments_nondegenerate seg h
  obtain ⟨p', h_p'_ne, h_p'_off_L, h_seg_disjoint⟩ :=
    exists_perturbation_off_segs p L hL_nondeg
  -- p' is off G1' segments and G2' segments.
  have h_p'_off_G1' : ∀ seg ∈ G1'.segments, p' ∉ seg.toSet := by
    intro seg hseg
    exact h_p'_off_L seg (List.mem_append.mpr (Or.inl hseg))
  have h_p'_off_G2' : ∀ seg ∈ G2'.segments, p' ∉ seg.toSet := by
    intro seg hseg
    exact h_p'_off_L seg (List.mem_append.mpr (Or.inr hseg))
  have h_p'_avoids_G1' : ∀ seg ∈ G1'.segments, pointAvoidsSegment p' seg := h_p'_off_G1'
  have h_p'_avoids_G2' : ∀ seg ∈ G2'.segments, pointAvoidsSegment p' seg := h_p'_off_G2'
  -- p' is not on G1'.toBoundarySet, hence not a G1' vertex.
  have h_p'_not_G1'_bnd : p' ∉ G1'.toBoundarySet := by
    intro ⟨seg, hseg, hon⟩
    exact h_p'_off_G1' seg hseg hon
  have h_p'_not_G2'_bnd : p' ∉ G2'.toBoundarySet := by
    intro ⟨seg, hseg, hon⟩
    exact h_p'_off_G2' seg hseg hon
  -- p' is not a G1' vertex.
  have h_p'_not_G1'_vert : ∀ v ∈ G1'.toVertices, v ≠ p' := by
    intro v hv heq
    have h_v_on_seg : ∃ s ∈ G1'.segments, v ∈ s.toSet :=
      vertex_on_some_segment G1' v (h_pos1 v hv)
    obtain ⟨s, hs_mem, hs_v⟩ := h_v_on_seg
    exact h_p'_not_G1'_bnd ⟨s, hs_mem, heq ▸ hs_v⟩
  have h_p'_not_G2'_vert : ∀ v ∈ G2'.toVertices, v ≠ p' := by
    intro v hv heq
    have h_v_on_seg : ∃ s ∈ G2'.segments, v ∈ s.toSet :=
      vertex_on_some_segment G2' v (h_pos2 v hv)
    obtain ⟨s, hs_mem, hs_v⟩ := h_v_on_seg
    exact h_p'_not_G2'_bnd ⟨s, hs_mem, heq ▸ hs_v⟩
  -- Step 2: Show segment p-p' avoids G_inter segments.
  -- For each G_inter seg, p ∉ seg (by h_p_avoids_inter), so by h_seg_disjoint,
  -- segment ⟨p, p'⟩ is disjoint from seg.
  have h_segpp'_avoids_inter : ∀ seg ∈ G_inter.segments,
      segmentDoesNotIntersectSegment ⟨p, p'⟩ seg := by
    intro seg hseg
    -- seg is in L (as G1' or G2' segment).
    have h_seg_in_L : seg ∈ L := by
      rcases h_inter_seg_origin seg hseg with hg1 | hg2
      · exact List.mem_append.mpr (Or.inl hg1)
      · exact List.mem_append.mpr (Or.inr hg2)
    -- p ∉ seg by h_p_avoids_inter.
    have h_p_off_seg : p ∉ seg.toSet := h_p_avoids_inter seg hseg
    exact h_seg_disjoint seg h_seg_in_L h_p_off_seg
  -- Step 3: Show segment p-p' avoids G2' segments.
  have h_segpp'_avoids_G2' : ∀ seg ∈ G2'.segments,
      segmentDoesNotIntersectSegment ⟨p, p'⟩ seg := by
    intro seg hseg
    have h_seg_in_L : seg ∈ L := List.mem_append.mpr (Or.inr hseg)
    have h_p_off_seg : p ∉ seg.toSet := h_p_avoids_G2' seg hseg
    exact h_seg_disjoint seg h_seg_in_L h_p_off_seg
  -- Vertices of G2' don't lie on segment p-p' (since segment avoids G2' segments
  -- and vertices lie on G2' segments).
  have h_G2'_verts_off_segpp' : ∀ v ∈ G2'.toVertices,
      v ∉ (LineSegment.mk p p').toSet := by
    intro v hv hv_mem
    obtain ⟨s, hs_mem, hs_v⟩ := vertex_on_some_segment G2' v (h_pos2 v hv)
    have h_disj := h_segpp'_avoids_G2' s hs_mem
    have : v ∈ (LineSegment.mk p p').toSet ∩ s.toSet := ⟨hv_mem, hs_v⟩
    rw [h_disj] at this
    exact this
  -- Step 4: parity_G2' at any ray from p (avoiding G2' verts) is 0.
  -- p is not a G2' vertex (since p ∉ G2.boundary, vertices are on boundary).
  have h_p_not_G2'_vert : ∀ v ∈ G2'.toVertices, v ≠ p := by
    intro v hv heq
    obtain ⟨s, hs_mem, hs_v⟩ := vertex_on_some_segment G2' v (h_pos2 v hv)
    exact h_p_not_G2' ⟨s, hs_mem, heq ▸ hs_v⟩
  obtain ⟨r₁, h_r₁_orig, h_r₁_avoids_G2'⟩ :=
    exists_ray_avoiding_graph_verts p G2' h_p_not_G2'_vert
  have h_p_not_G2'_int : p ∉ G2'.interior := by rw [hG2'_int]; exact h_p_not_G2_int
  -- Show parity_G2'(r₁) = 0.
  have h_parity_G2'_r₁_zero :
      intersectionRayGraphSegmentsNumber r₁ G2' % 2 = 0 := by
    by_contra h_ne
    -- Otherwise parity is 1, hence p ∈ G2'.interior.
    have h_parity_one : intersectionRayGraphSegmentsNumber r₁ G2' % 2 = 1 := by
      have h_lt : intersectionRayGraphSegmentsNumber r₁ G2' % 2 < 2 :=
        Nat.mod_lt _ (by norm_num)
      omega
    apply h_p_not_G2'_int
    refine ⟨h_p_avoids_G2', ?_⟩
    intro r' h_r'_orig h_r'_avoids
    have h_origin_avoids' :
        ∀ seg ∈ G2'.segments, pointAvoidsSegment r₁.origin seg := by
      rw [h_r₁_orig]; exact h_p_avoids_G2'
    have h_eq := intersectionParity_eq_of_sameOrigin_avoidsGraphVertices
      r₁ r' G2'
      (show sameOrigin r₁ r' by simp [sameOrigin, h_r₁_orig, h_r'_orig])
      h_r₁_avoids_G2' h_r'_avoids h_origin_avoids'
    linarith
  -- Step 5: parity_G2'(r₂) = 0 where r₂ is from p' avoiding G2' verts.
  obtain ⟨r₂, h_r₂_orig, h_r₂_avoids_G2'⟩ :=
    exists_ray_avoiding_graph_verts p' G2' h_p'_not_G2'_vert
  have h_sego_avoids_G2' : ∀ seg ∈ G2'.segments,
      segmentDoesNotIntersectSegment ⟨r₁.origin, r₂.origin⟩ seg := by
    intro seg hseg
    rw [h_r₁_orig, h_r₂_orig]; exact h_segpp'_avoids_G2' seg hseg
  have h_verts_avoid_sego_G2' : ∀ v ∈ G2'.toVertices,
      v ∉ (LineSegment.mk r₁.origin r₂.origin).toSet := by
    intro v hv
    rw [h_r₁_orig, h_r₂_orig]; exact h_G2'_verts_off_segpp' v hv
  have h_parity_G2'_r₁_eq_r₂ :=
    intersectionParity_eq_of_originSegmentAvoidsGraphSegments
      r₁ r₂ G2' h_r₁_avoids_G2' h_r₂_avoids_G2'
      h_sego_avoids_G2' h_verts_avoid_sego_G2'
  have h_parity_G2'_r₂_zero :
      intersectionRayGraphSegmentsNumber r₂ G2' % 2 = 0 := by
    rw [← h_parity_G2'_r₁_eq_r₂]; exact h_parity_G2'_r₁_zero
  -- Step 6: Build a ray r₃ from p' avoiding both G1' and G2' vertices.
  have h_p'_not_both : ∀ v ∈ G1'.toVertices ++ G2'.toVertices, v ≠ p' := by
    intro v hv
    rcases List.mem_append.mp hv with h | h
    · exact h_p'_not_G1'_vert v h
    · exact h_p'_not_G2'_vert v h
  obtain ⟨r₃, h_r₃_orig, h_r₃_avoids_G1', h_r₃_avoids_G2'⟩ :=
    exists_ray_avoiding_both_vertices p' G1' G2' h_p'_not_both
  -- r₃ avoids G_inter vertices.
  have h_r₃_avoids_inter : rayAvoidsGraphVertices r₃ G_inter := by
    rw [rayAvoidsGraphVertices, Set.eq_empty_iff_forall_not_mem]
    intro v ⟨hv_ray, hv_vert⟩
    rcases h_inter_vert_in_refined v hv_vert with h1 | h2
    · have : v ∈ r₃.toSet ∩ G1'.toVertexSet := ⟨hv_ray, h1⟩
      rw [h_r₃_avoids_G1'] at this; exact this
    · have : v ∈ r₃.toSet ∩ G2'.toVertexSet := ⟨hv_ray, h2⟩
      rw [h_r₃_avoids_G2'] at this; exact this
  -- Step 6 cont: parity_inter(r₃) = 1 by transferring from p via r_p (some ray from p).
  -- Get a ray r_p from p avoiding G_inter vertices.
  -- p is not a G_inter vertex (since p avoids G_inter segments, and G_inter
  -- vertices lie on G_inter segments).
  have h_p_not_G_inter_vert : ∀ v ∈ G_inter.toVertices, v ≠ p := by
    intro v hv
    -- v is on some G_inter segment.
    rcases h_inter_vert_in_refined v hv with hv1 | hv2
    · -- v ∈ G1'.toVertices
      obtain ⟨s, hs_mem, hs_v⟩ := vertex_on_some_segment G1' v (h_pos1 v hv1)
      -- We know v is in some G1' segment; we need: is the G_inter parent segment of v one with v on it?
      -- Use the original graph structure of G_inter.
      simp only [Graph.toVertices, List.mem_dedup, List.mem_flatMap, List.mem_cons,
                 (List.not_mem_nil _), or_false] at hv
      obtain ⟨seg, hseg, h_or⟩ := hv
      intro heq
      rcases h_or with rfl | rfl
      · exact h_p_avoids_inter seg hseg
          (heq ▸ ⟨0, le_refl 0, zero_le_one, by ring, by ring⟩)
      · exact h_p_avoids_inter seg hseg
          (heq ▸ ⟨1, zero_le_one, le_refl 1, by ring, by ring⟩)
    · simp only [Graph.toVertices, List.mem_dedup, List.mem_flatMap, List.mem_cons,
                 (List.not_mem_nil _), or_false] at hv
      obtain ⟨seg, hseg, h_or⟩ := hv
      intro heq
      rcases h_or with rfl | rfl
      · exact h_p_avoids_inter seg hseg
          (heq ▸ ⟨0, le_refl 0, zero_le_one, by ring, by ring⟩)
      · exact h_p_avoids_inter seg hseg
          (heq ▸ ⟨1, zero_le_one, le_refl 1, by ring, by ring⟩)
  obtain ⟨r_p, h_r_p_orig, h_r_p_avoids_inter⟩ :=
    exists_ray_avoiding_graph_verts p G_inter_E h_p_not_G_inter_vert
  -- Apply h_p_inter_parity at r_p.
  have h_parity_inter_r_p : intersectionRayGraphSegmentsNumber r_p G_inter % 2 = 1 :=
    h_p_inter_parity r_p h_r_p_orig h_r_p_avoids_inter
  -- Now apply origin-segment parity invariance for G_inter_E to transfer parity_inter from r_p to r₃.
  have h_sego_avoids_inter : ∀ seg ∈ G_inter_E.segments,
      segmentDoesNotIntersectSegment ⟨r_p.origin, r₃.origin⟩ seg := by
    intro seg hseg
    rw [h_r_p_orig, h_r₃_orig]; exact h_segpp'_avoids_inter seg hseg
  have h_verts_avoid_sego_inter : ∀ v ∈ G_inter_E.toVertices,
      v ∉ (LineSegment.mk r_p.origin r₃.origin).toSet := by
    intro v hv hv_mem
    -- v is an endpoint of some G_inter segment; that segment is disjoint from p-p'.
    simp only [Graph.toVertices, List.mem_dedup, List.mem_flatMap, List.mem_cons,
               (List.not_mem_nil _), or_false] at hv
    obtain ⟨s, hs_mem, h_or⟩ := hv
    have hv_on_s : v ∈ s.toSet := by
      rcases h_or with rfl | rfl
      · exact ⟨0, le_refl 0, zero_le_one, by ring, by ring⟩
      · exact ⟨1, zero_le_one, le_refl 1, by ring, by ring⟩
    have h_disj := h_segpp'_avoids_inter s hs_mem
    have : v ∈ (LineSegment.mk p p').toSet ∩ s.toSet := by
      rw [h_r_p_orig, h_r₃_orig] at hv_mem
      exact ⟨hv_mem, hv_on_s⟩
    rw [h_disj] at this; exact this
  have h_parity_inter_eq :=
    intersectionParity_eq_of_originSegmentAvoidsGraphSegments
      r_p r₃ G_inter_E h_r_p_avoids_inter h_r₃_avoids_inter
      h_sego_avoids_inter h_verts_avoid_sego_inter
  have h_inter_eq_E_r_p : intersectionRayGraphSegmentsNumber r_p G_inter_E =
      intersectionRayGraphSegmentsNumber r_p G_inter := rfl
  have h_inter_eq_E_r₃ : intersectionRayGraphSegmentsNumber r₃ G_inter_E =
      intersectionRayGraphSegmentsNumber r₃ G_inter := rfl
  rw [h_inter_eq_E_r_p, h_inter_eq_E_r₃] at h_parity_inter_eq
  have h_parity_inter_r₃ : intersectionRayGraphSegmentsNumber r₃ G_inter % 2 = 1 := by
    rw [← h_parity_inter_eq]; exact h_parity_inter_r_p
  -- Step 7: Apply intersectionRayCount_parity at r₃.
  rw [h_inter_count_eq r₃] at h_parity_inter_r₃
  have h_iff := intersectionRayCount_parity r₃ G1 G2 h_fin12
    h_r₃_avoids_G1' h_r₃_avoids_G2'
    (by rw [h_r₃_orig]; exact h_p'_avoids_G1')
    (by rw [h_r₃_orig]; exact h_p'_avoids_G2')
  have ⟨_, h_G2'_odd_r₃⟩ := h_iff.mp h_parity_inter_r₃
  -- But parity_G2'(r₃) = parity_G2'(r₂) = 0. Contradiction.
  have h_origin_avoids_G2'_r₂ :
      ∀ seg ∈ G2'.segments, pointAvoidsSegment r₂.origin seg := by
    rw [h_r₂_orig]; exact h_p'_avoids_G2'
  have h_same_orig_r₂_r₃ : sameOrigin r₂ r₃ := by
    simp [sameOrigin, h_r₂_orig, h_r₃_orig]
  have h_parity_G2'_r₂_eq_r₃ :=
    intersectionParity_eq_of_sameOrigin_avoidsGraphVertices
      r₂ r₃ G2' h_same_orig_r₂_r₃ h_r₂_avoids_G2' h_r₃_avoids_G2'
      h_origin_avoids_G2'_r₂
  rw [← h_parity_G2'_r₂_eq_r₃] at h_G2'_odd_r₃
  rw [h_parity_G2'_r₂_zero] at h_G2'_odd_r₃
  exact absurd h_G2'_odd_r₃ (by norm_num)

/-- Case 3: If `p ∈ G1.toBoundarySet ∩ G2.toBoundarySet` (both refined graphs'
    boundaries) while `p` avoids the intersection graph's segments and every ray
    from `p` (avoiding the intersection graph's vertices) has odd
    intersection-graph parity, we derive a contradiction.

    The strategy: find an unselected refined-G1 segment `seg_e` incident to `p`,
    pick `p' = midpoint of seg_e`. Then `p' ∈ G1.boundary`, `p' ∉ G2.boundary`,
    `p' ∉ G_inter.boundary`, and `p'` inherits the parity property from `p` via
    parity-invariance through the segment `p-p'`. Apply Case 1 (if `p' ∈
    G2.interior`) or Case 2 (if `p' ∈ G2.exterior`) to derive a contradiction.

    The key insight that makes this clean: selected refined-G1 segments have
    open interior in `G2.interior`, while `seg_e` (unselected) has open interior
    in `G2.exterior` (by `same_G2_interior_status_on_segment`). These cannot
    overlap, so `p' ∈ seg_e.openInterior` is automatically off all selected
    refined-G1 segments. -/
lemma case3_contradiction
    (G1 G2 : EvenGraph)
    (h_fin12 : Set.Finite (G1.toBoundarySet ∩ G2.toBoundarySet))
    (h_fin21 : Set.Finite (G2.toBoundarySet ∩ G1.toBoundarySet))
    (h_no_segment_interior_vertices_G1' : ∀ v ∈ (graphRefinementSelfAndWrt G1 G2 h_fin12).toVertices,
      ∀ seg ∈ (graphRefinementSelfAndWrt G1 G2 h_fin12).segments,
        seg.p1 ≠ v → seg.p2 ≠ v → v ∉ seg.toSet)
    (h_even : (((graphRefinementSelfAndWrt G1 G2 h_fin12).toGraph.selectSegmentsInside
            G2.interior).append
        ((graphRefinementSelfAndWrt G2 G1 h_fin21).toGraph.selectSegmentsInside
            G1.interior)).IsEven)
    (p : Vector2D)
    (h_p_on_G1 : p ∈ G1.toBoundarySet)
    (h_p_on_G2 : p ∈ G2.toBoundarySet)
    (h_p_avoids_inter : ∀ seg ∈ (((graphRefinementSelfAndWrt G1 G2 h_fin12).toGraph.selectSegmentsInside
            G2.interior).append
        ((graphRefinementSelfAndWrt G2 G1 h_fin21).toGraph.selectSegmentsInside
            G1.interior)).segments, pointAvoidsSegment p seg)
    (h_p_inter_parity : ∀ r : Ray, r.origin = p →
       rayAvoidsGraphVertices r (((graphRefinementSelfAndWrt G1 G2 h_fin12).toGraph.selectSegmentsInside
            G2.interior).append
        ((graphRefinementSelfAndWrt G2 G1 h_fin21).toGraph.selectSegmentsInside
            G1.interior)) →
       intersectionRayGraphSegmentsNumber r (((graphRefinementSelfAndWrt G1 G2 h_fin12).toGraph.selectSegmentsInside
            G2.interior).append
        ((graphRefinementSelfAndWrt G2 G1 h_fin21).toGraph.selectSegmentsInside
            G1.interior)) % 2 = 1) :
    False := by
  set G1' := graphRefinementSelfAndWrt G1 G2 h_fin12 with hG1'_def
  set G2' := graphRefinementSelfAndWrt G2 G1 h_fin21 with hG2'_def
  set G_inter : Graph :=
    (G1'.toGraph.selectSegmentsInside G2.interior).append
      (G2'.toGraph.selectSegmentsInside G1.interior) with hG_inter_def
  let G_inter_E : EvenGraph := ⟨G_inter, h_even⟩
  have hG1'_bnd : G1'.toBoundarySet = G1.toBoundarySet :=
    graphRefinementSelfAndWrt_boundary_eq G1 G2 h_fin12
  have hG2'_bnd : G2'.toBoundarySet = G2.toBoundarySet :=
    graphRefinementSelfAndWrt_boundary_eq G2 G1 h_fin21
  -- Step 1: pick refined-G1 segment seg_e containing p; p is endpoint.
  have h_p_G1' : p ∈ G1'.toBoundarySet := by rw [hG1'_bnd]; exact h_p_on_G1
  obtain ⟨seg_e, hseg_e_mem, hp_seg_e⟩ := h_p_G1'
  have h_seg_e_nondeg : seg_e.p1 ≠ seg_e.p2 := G1'.segments_nondegenerate seg_e hseg_e_mem
  have h_subset := graphRefinementSelfAndWrt_seg_inter_boundary_subset G1 G2 h_fin12 seg_e hseg_e_mem
  have hp_endpts : p ∈ ({seg_e.p1, seg_e.p2} : Set Vector2D) := h_subset ⟨hp_seg_e, h_p_on_G2⟩
  have hp_endpts_or : p = seg_e.p1 ∨ p = seg_e.p2 := by
    rcases hp_endpts with h | h
    · left; exact h
    · right; exact h
  -- Step 2: seg_e is unselected.
  have h_seg_e_not_selected : ¬ segmentOpenInteriorSubset seg_e G2.interior := by
    intro h_selected
    have h_seg_e_selected_mem :
        seg_e ∈ _root_.selectSegmentsInside G1'.segments G2.interior := by
      simp only [_root_.selectSegmentsInside, List.mem_filter, decide_eq_true_eq]
      exact ⟨hseg_e_mem, h_selected⟩
    have h_seg_e_in_inter : seg_e ∈ G_inter.segments := by
      simp only [G_inter, Graph.append_segments, List.mem_append]
      left; exact h_seg_e_selected_mem
    exact h_p_avoids_inter seg_e h_seg_e_in_inter hp_seg_e
  -- Step 3: seg_e.openInterior ⊆ G2.exterior.
  have h_seg_e_openInt_not_G2_int : ∀ q ∈ seg_e.toSet,
      q ≠ seg_e.p1 → q ≠ seg_e.p2 → q ∉ G2.interior := by
    intro q hq_seg hq_p1 hq_p2 h_q_int
    apply h_seg_e_not_selected
    intro q' hq'_seg hq'_p1 hq'_p2
    exact same_G2_interior_status_on_segment G1 G2 h_fin12 h_fin21
      G2'.incident_count_pos seg_e hseg_e_mem q q' hq_seg hq_p1 hq_p2
      hq'_seg hq'_p1 hq'_p2 h_q_int
  -- seg_e.openInterior is also disjoint from G2.boundary (by refinement).
  have h_seg_e_openInt_not_G2_bnd : ∀ q ∈ seg_e.toSet,
      q ≠ seg_e.p1 → q ≠ seg_e.p2 → q ∉ G2.toBoundarySet := by
    intro q hq_seg hq_p1 hq_p2 h_q_bnd
    have hq_endpts : q ∈ ({seg_e.p1, seg_e.p2} : Set Vector2D) := h_subset ⟨hq_seg, h_q_bnd⟩
    rcases hq_endpts with h | h
    · exact hq_p1 h
    · exact hq_p2 h
  -- Step 4: pick p' = midpoint of seg_e.
  set p' : Vector2D :=
    ⟨(seg_e.p1.x + seg_e.p2.x) / 2, (seg_e.p1.y + seg_e.p2.y) / 2⟩ with hp'_def
  have hp'_seg : p' ∈ seg_e.toSet := by
    refine ⟨1/2, by norm_num, by norm_num, ?_, ?_⟩
    · show (seg_e.p1.x + seg_e.p2.x) / 2 = (1 - 1/2) * seg_e.p1.x + (1/2) * seg_e.p2.x
      ring
    · show (seg_e.p1.y + seg_e.p2.y) / 2 = (1 - 1/2) * seg_e.p1.y + (1/2) * seg_e.p2.y
      ring
  have hp'_ne_p1 : p' ≠ seg_e.p1 := by
    intro h
    apply h_seg_e_nondeg
    ext
    · have : (seg_e.p1.x + seg_e.p2.x) / 2 = seg_e.p1.x := congrArg Vector2D.x h
      linarith
    · have : (seg_e.p1.y + seg_e.p2.y) / 2 = seg_e.p1.y := congrArg Vector2D.y h
      linarith
  have hp'_ne_p2 : p' ≠ seg_e.p2 := by
    intro h
    apply h_seg_e_nondeg
    ext
    · have : (seg_e.p1.x + seg_e.p2.x) / 2 = seg_e.p2.x := congrArg Vector2D.x h
      linarith
    · have : (seg_e.p1.y + seg_e.p2.y) / 2 = seg_e.p2.y := congrArg Vector2D.y h
      linarith
  have hp'_ne_p : p' ≠ p := by
    rcases hp_endpts_or with h | h
    · rw [h]; exact hp'_ne_p1
    · rw [h]; exact hp'_ne_p2
  -- Step 5: p' ∈ G1.boundary, p' ∉ G2.boundary.
  have hp'_G1 : p' ∈ G1.toBoundarySet := by
    rw [← hG1'_bnd]
    exact ⟨seg_e, hseg_e_mem, hp'_seg⟩
  have hp'_not_G2 : p' ∉ G2.toBoundarySet :=
    h_seg_e_openInt_not_G2_bnd p' hp'_seg hp'_ne_p1 hp'_ne_p2
  have hp'_not_G2_int : ∀ b : Bool, p' ∈ G2.interior → b = b := fun _ _ => rfl
  -- p' ∉ G_inter.boundary.
  have hp'_not_inter : p' ∉ G_inter.toBoundarySet := by
    rintro ⟨seg, hseg, hp'_in⟩
    rw [hG_inter_def, Graph.append_segments, List.mem_append] at hseg
    rcases hseg with hseg_G1 | hseg_G2
    · -- seg ∈ selected refined-G1
      have hseg_in_filter : seg ∈ _root_.selectSegmentsInside G1'.segments G2.interior := hseg_G1
      have hseg_in_G1' : seg ∈ G1'.segments := List.mem_of_mem_filter hseg_in_filter
      have h_seg_selected : segmentOpenInteriorSubset seg G2.interior := by
        simp only [_root_.selectSegmentsInside, List.mem_filter, decide_eq_true_eq] at hseg_in_filter
        exact hseg_in_filter.2
      by_cases hp'_seg_p1 : p' = seg.p1
      · -- p' is a refined-G1 vertex
        have hp'_vertex : p' ∈ G1'.toVertices := by
          rw [hp'_seg_p1]
          exact G1'.p1_mem_toVertices hseg_in_G1'
        exact h_no_segment_interior_vertices_G1' p' hp'_vertex seg_e hseg_e_mem
          (fun h => hp'_ne_p1 h.symm) (fun h => hp'_ne_p2 h.symm) hp'_seg
      · by_cases hp'_seg_p2 : p' = seg.p2
        · have hp'_vertex : p' ∈ G1'.toVertices := by
            rw [hp'_seg_p2]
            exact G1'.p2_mem_toVertices hseg_in_G1'
          exact h_no_segment_interior_vertices_G1' p' hp'_vertex seg_e hseg_e_mem
            (fun h => hp'_ne_p1 h.symm) (fun h => hp'_ne_p2 h.symm) hp'_seg
        · -- p' ∈ seg.openInterior ⊆ G2.interior
          have hp'_in_G2_int : p' ∈ G2.interior :=
            h_seg_selected p' hp'_in hp'_seg_p1 hp'_seg_p2
          exact h_seg_e_openInt_not_G2_int p' hp'_seg hp'_ne_p1 hp'_ne_p2 hp'_in_G2_int
    · -- seg ∈ selected refined-G2
      have hseg_in_G2' : seg ∈ G2'.segments := List.mem_of_mem_filter hseg_G2
      have hp'_G2 : p' ∈ G2.toBoundarySet := by
        rw [← hG2'_bnd]
        exact ⟨seg, hseg_in_G2', hp'_in⟩
      exact hp'_not_G2 hp'_G2
  -- Step 6: segment p-p' ⊆ seg_e.toSet.
  have h_segpp'_sub_seg_e : ∀ x ∈ (LineSegment.mk p p').toSet, x ∈ seg_e.toSet :=
    segment_pq_subset_refined_seg seg_e p p' hp_seg_e hp'_seg
  -- Step 7: segment p-p' avoids G_inter.segments.
  have h_segpp'_avoids_inter : ∀ seg ∈ G_inter.segments,
      segmentDoesNotIntersectSegment ⟨p, p'⟩ seg := by
    intro seg hseg
    ext x
    simp only [Set.mem_inter_iff, Set.mem_empty_iff_false, iff_false, not_and]
    intro hx_pp' hx_seg
    have hx_seg_e : x ∈ seg_e.toSet := h_segpp'_sub_seg_e x hx_pp'
    -- Case split on x's position on seg_e.
    by_cases hx_p1 : x = seg_e.p1
    · -- x = seg_e.p1. Show x = p (else contradiction with parametrization).
      obtain ⟨u, hu0, hu1, hux, huy⟩ := hx_pp'
      rcases hp_endpts_or with hp_eq_p1 | hp_eq_p2
      · -- p = seg_e.p1 ⇒ x = seg_e.p1 = p.
        rw [hx_p1, ← hp_eq_p1] at hx_seg
        exact h_p_avoids_inter seg hseg hx_seg
      · -- p = seg_e.p2. Show u = 0 (so x = p), but actually need to derive u
        -- and check. x = seg_e.p1 means x.x = seg_e.p1.x.
        -- x = (1-u)*seg_e.p2 + u*p' (since p = seg_e.p2).
        -- x.x = (1-u)*seg_e.p2.x + u*(seg_e.p1.x + seg_e.p2.x)/2
        --     = (1 - u/2) * seg_e.p2.x + (u/2) * seg_e.p1.x.
        -- For x = seg_e.p1: x.x = seg_e.p1.x.
        -- So (1 - u/2) * seg_e.p2.x + (u/2) * seg_e.p1.x = seg_e.p1.x.
        -- (1 - u/2) * (seg_e.p2.x - seg_e.p1.x) = 0.
        -- Either u = 2 (not in [0,1]) or seg_e.p1.x = seg_e.p2.x.
        -- Symmetric for y.
        -- If both x and y of seg_e endpoints coincide, seg_e is degenerate. Contradiction.
        exfalso
        have hxx : x.x = (1 - u) * p.x + u * p'.x := hux
        have hxy : x.y = (1 - u) * p.y + u * p'.y := huy
        have hpx_eq : p.x = seg_e.p2.x := by rw [hp_eq_p2]
        have hpy_eq : p.y = seg_e.p2.y := by rw [hp_eq_p2]
        have hp'x : p'.x = (seg_e.p1.x + seg_e.p2.x) / 2 := rfl
        have hp'y : p'.y = (seg_e.p1.y + seg_e.p2.y) / 2 := rfl
        have hxx_eq : seg_e.p1.x = (1 - u) * seg_e.p2.x + u * ((seg_e.p1.x + seg_e.p2.x) / 2) := by
          calc seg_e.p1.x
              = x.x := (congrArg Vector2D.x hx_p1).symm
            _ = (1 - u) * p.x + u * p'.x := hxx
            _ = (1 - u) * seg_e.p2.x + u * ((seg_e.p1.x + seg_e.p2.x) / 2) := by
                rw [hpx_eq, hp'x]
        have hxy_eq : seg_e.p1.y = (1 - u) * seg_e.p2.y + u * ((seg_e.p1.y + seg_e.p2.y) / 2) := by
          calc seg_e.p1.y
              = x.y := (congrArg Vector2D.y hx_p1).symm
            _ = (1 - u) * p.y + u * p'.y := hxy
            _ = (1 - u) * seg_e.p2.y + u * ((seg_e.p1.y + seg_e.p2.y) / 2) := by
                rw [hpy_eq, hp'y]
        have hx_diff : (1 - u/2) * (seg_e.p2.x - seg_e.p1.x) = 0 := by linarith
        have hy_diff : (1 - u/2) * (seg_e.p2.y - seg_e.p1.y) = 0 := by linarith
        have h_u_ne_2 : 1 - u/2 ≠ 0 := by
          intro h
          have : u = 2 := by linarith
          linarith
        have hpx_xeq : seg_e.p2.x = seg_e.p1.x := by
          rcases mul_eq_zero.mp hx_diff with h | h
          · exact absurd h h_u_ne_2
          · linarith
        have hpy_xeq : seg_e.p2.y = seg_e.p1.y := by
          rcases mul_eq_zero.mp hy_diff with h | h
          · exact absurd h h_u_ne_2
          · linarith
        exact h_seg_e_nondeg (Vector2D.ext hpx_xeq.symm hpy_xeq.symm)
    · by_cases hx_p2 : x = seg_e.p2
      · -- Symmetric: show x = p (when p = seg_e.p2) or contradiction.
        obtain ⟨u, hu0, hu1, hux, huy⟩ := hx_pp'
        rcases hp_endpts_or with hp_eq_p1 | hp_eq_p2
        · -- p = seg_e.p1. Show contradiction: u = 2.
          exfalso
          have hxx : x.x = (1 - u) * p.x + u * p'.x := hux
          have hxy : x.y = (1 - u) * p.y + u * p'.y := huy
          have hpx_eq : p.x = seg_e.p1.x := by rw [hp_eq_p1]
          have hpy_eq : p.y = seg_e.p1.y := by rw [hp_eq_p1]
          have hp'x : p'.x = (seg_e.p1.x + seg_e.p2.x) / 2 := rfl
          have hp'y : p'.y = (seg_e.p1.y + seg_e.p2.y) / 2 := rfl
          have hxx_eq : seg_e.p2.x = (1 - u) * seg_e.p1.x + u * ((seg_e.p1.x + seg_e.p2.x) / 2) := by
            calc seg_e.p2.x
                = x.x := (congrArg Vector2D.x hx_p2).symm
              _ = (1 - u) * p.x + u * p'.x := hxx
              _ = (1 - u) * seg_e.p1.x + u * ((seg_e.p1.x + seg_e.p2.x) / 2) := by
                  rw [hpx_eq, hp'x]
          have hxy_eq : seg_e.p2.y = (1 - u) * seg_e.p1.y + u * ((seg_e.p1.y + seg_e.p2.y) / 2) := by
            calc seg_e.p2.y
                = x.y := (congrArg Vector2D.y hx_p2).symm
              _ = (1 - u) * p.y + u * p'.y := hxy
              _ = (1 - u) * seg_e.p1.y + u * ((seg_e.p1.y + seg_e.p2.y) / 2) := by
                  rw [hpy_eq, hp'y]
          have hx_diff : (1 - u/2) * (seg_e.p1.x - seg_e.p2.x) = 0 := by linarith
          have hy_diff : (1 - u/2) * (seg_e.p1.y - seg_e.p2.y) = 0 := by linarith
          have h_u_ne_2 : 1 - u/2 ≠ 0 := by
            intro h
            have : u = 2 := by linarith
            linarith
          have hpx_xeq : seg_e.p1.x = seg_e.p2.x := by
            rcases mul_eq_zero.mp hx_diff with h | h
            · exact absurd h h_u_ne_2
            · linarith
          have hpy_xeq : seg_e.p1.y = seg_e.p2.y := by
            rcases mul_eq_zero.mp hy_diff with h | h
            · exact absurd h h_u_ne_2
            · linarith
          exact h_seg_e_nondeg (Vector2D.ext hpx_xeq hpy_xeq)
        · rw [hx_p2, ← hp_eq_p2] at hx_seg
          exact h_p_avoids_inter seg hseg hx_seg
      · -- x ∈ seg_e.openInterior. Use selected/unselected argument.
        rw [hG_inter_def, Graph.append_segments, List.mem_append] at hseg
        rcases hseg with hseg_G1 | hseg_G2
        · have hseg_in_filter : seg ∈ _root_.selectSegmentsInside G1'.segments G2.interior := hseg_G1
          have hseg_in_G1' : seg ∈ G1'.segments := List.mem_of_mem_filter hseg_in_filter
          have h_seg_selected : segmentOpenInteriorSubset seg G2.interior := by
            simp only [_root_.selectSegmentsInside, List.mem_filter, decide_eq_true_eq] at hseg_in_filter
            exact hseg_in_filter.2
          by_cases hx_seg_p1 : x = seg.p1
          · have hx_vertex : x ∈ G1'.toVertices := by
              rw [hx_seg_p1]; exact G1'.p1_mem_toVertices hseg_in_G1'
            exact h_no_segment_interior_vertices_G1' x hx_vertex seg_e hseg_e_mem
              (fun heq => hx_p1 heq.symm) (fun heq => hx_p2 heq.symm) hx_seg_e
          · by_cases hx_seg_p2 : x = seg.p2
            · have hx_vertex : x ∈ G1'.toVertices := by
                rw [hx_seg_p2]; exact G1'.p2_mem_toVertices hseg_in_G1'
              exact h_no_segment_interior_vertices_G1' x hx_vertex seg_e hseg_e_mem
                (fun heq => hx_p1 heq.symm) (fun heq => hx_p2 heq.symm) hx_seg_e
            · -- x ∈ seg.openInterior ⊆ G2.interior
              have hx_in_G2_int : x ∈ G2.interior :=
                h_seg_selected x hx_seg hx_seg_p1 hx_seg_p2
              exact h_seg_e_openInt_not_G2_int x hx_seg_e hx_p1 hx_p2 hx_in_G2_int
        · have hseg_in_G2' : seg ∈ G2'.segments := List.mem_of_mem_filter hseg_G2
          have hx_G2_bnd : x ∈ G2.toBoundarySet := by
            rw [← hG2'_bnd]
            exact ⟨seg, hseg_in_G2', hx_seg⟩
          exact h_seg_e_openInt_not_G2_bnd x hx_seg_e hx_p1 hx_p2 hx_G2_bnd
  -- Step 8: parity transfer to p'.
  -- p' avoids G_inter segments (from Step 5).
  have hp'_avoids_inter : ∀ seg ∈ G_inter.segments, pointAvoidsSegment p' seg := by
    intro seg hseg h_in
    exact hp'_not_inter ⟨seg, hseg, h_in⟩
  -- p' avoids segment p-p' avoids G_inter vertices.
  have h_segpp'_avoids_inter_verts : ∀ v ∈ G_inter.toVertices,
      v ∉ (LineSegment.mk p p').toSet := by
    intro v hv hv_mem
    -- v ∈ G_inter.toVertices means v is an endpoint of some G_inter segment.
    simp only [Graph.toVertices, List.mem_dedup, List.mem_flatMap, List.mem_cons,
               (List.not_mem_nil _), or_false] at hv
    obtain ⟨seg, hseg, h_or⟩ := hv
    have hv_in_seg : v ∈ seg.toSet := by
      rcases h_or with rfl | rfl
      · exact ⟨0, le_refl 0, zero_le_one, by ring, by ring⟩
      · exact ⟨1, zero_le_one, le_refl 1, by ring, by ring⟩
    have h_disj := h_segpp'_avoids_inter seg hseg
    have : v ∈ (LineSegment.mk p p').toSet ∩ seg.toSet := ⟨hv_mem, hv_in_seg⟩
    rw [h_disj] at this
    exact this
  -- Get rays r_p (from p) and r_p' (from p') avoiding G_inter vertices.
  -- p is not a G_inter vertex (since p avoids G_inter segments).
  have h_p_not_inter_vert : ∀ v ∈ G_inter.toVertices, v ≠ p := by
    intro v hv heq
    simp only [Graph.toVertices, List.mem_dedup, List.mem_flatMap, List.mem_cons,
               (List.not_mem_nil _), or_false] at hv
    obtain ⟨seg, hseg, h_or⟩ := hv
    have hv_in_seg : v ∈ seg.toSet := by
      rcases h_or with rfl | rfl
      · exact ⟨0, le_refl 0, zero_le_one, by ring, by ring⟩
      · exact ⟨1, zero_le_one, le_refl 1, by ring, by ring⟩
    rw [heq] at hv_in_seg
    exact h_p_avoids_inter seg hseg hv_in_seg
  obtain ⟨r_p, hr_p_origin, hr_p_avoids_inter⟩ :=
    exists_ray_avoiding_graph_verts p G_inter_E h_p_not_inter_vert
  -- p' is not a G_inter vertex (since p' avoids G_inter segments).
  have h_p'_not_inter_vert : ∀ v ∈ G_inter.toVertices, v ≠ p' := by
    intro v hv heq
    simp only [Graph.toVertices, List.mem_dedup, List.mem_flatMap, List.mem_cons,
               (List.not_mem_nil _), or_false] at hv
    obtain ⟨seg, hseg, h_or⟩ := hv
    have hv_in_seg : v ∈ seg.toSet := by
      rcases h_or with rfl | rfl
      · exact ⟨0, le_refl 0, zero_le_one, by ring, by ring⟩
      · exact ⟨1, zero_le_one, le_refl 1, by ring, by ring⟩
    rw [heq] at hv_in_seg
    exact hp'_avoids_inter seg hseg hv_in_seg
  obtain ⟨r_p', hr_p'_origin, hr_p'_avoids_inter⟩ :=
    exists_ray_avoiding_graph_verts p' G_inter_E h_p'_not_inter_vert
  -- Apply parity invariance via origin segment for G_inter_E.
  have h_segpp'_avoids_inter_segs : ∀ seg ∈ G_inter_E.segments,
      segmentDoesNotIntersectSegment ⟨r_p.origin, r_p'.origin⟩ seg := by
    intro seg hseg
    rw [hr_p_origin, hr_p'_origin]
    exact h_segpp'_avoids_inter seg hseg
  have h_verts_avoid_segpp' : ∀ v ∈ G_inter_E.toVertices,
      v ∉ (LineSegment.mk r_p.origin r_p'.origin).toSet := by
    intro v hv
    rw [hr_p_origin, hr_p'_origin]
    exact h_segpp'_avoids_inter_verts v hv
  have h_parity_eq := intersectionParity_eq_of_originSegmentAvoidsGraphSegments
    r_p r_p' G_inter_E hr_p_avoids_inter hr_p'_avoids_inter
    h_segpp'_avoids_inter_segs h_verts_avoid_segpp'
  have h_r_p_odd := h_p_inter_parity r_p hr_p_origin hr_p_avoids_inter
  have h_r_p'_odd : intersectionRayGraphSegmentsNumber r_p' G_inter % 2 = 1 := by
    have : intersectionRayGraphSegmentsNumber r_p' G_inter_E % 2 = 1 := by
      rw [← h_parity_eq]; exact h_r_p_odd
    exact this
  -- Step 9: ∀ ray from p' avoiding G_inter verts, parity odd.
  have h_p'_inter_parity : ∀ r : Ray, r.origin = p' →
      rayAvoidsGraphVertices r G_inter →
      intersectionRayGraphSegmentsNumber r G_inter % 2 = 1 := by
    intro r h_origin h_avoids
    have h_same_orig : sameOrigin r_p' r := by
      simp [sameOrigin, hr_p'_origin, h_origin]
    have h_eq := intersectionParity_eq_of_sameOrigin_avoidsGraphVertices
      r_p' r G_inter_E h_same_orig hr_p'_avoids_inter h_avoids
      (by rw [hr_p'_origin]; exact hp'_avoids_inter)
    have h_eq' : intersectionRayGraphSegmentsNumber r_p' G_inter % 2 =
        intersectionRayGraphSegmentsNumber r G_inter % 2 := h_eq
    rw [← h_eq']; exact h_r_p'_odd
  -- Step 10: apply Case 1 or Case 2 to p'.
  by_cases hp'_in_G2_int : p' ∈ G2.interior
  · -- Case 1
    have h_p'_in_inter_bnd :=
      case1_G1_bnd_G2_int_in_inter_bnd G1 G2 h_fin12 h_fin21 p' hp'_G1 hp'_in_G2_int
    obtain ⟨seg, hseg, hp'_in⟩ := h_p'_in_inter_bnd
    exact hp'_not_inter ⟨seg, hseg, hp'_in⟩
  · -- Case 2
    exact case2_contradiction G1 G2 h_fin12 h_fin21 h_even p'
      hp'_G1 hp'_not_G2 hp'_in_G2_int hp'_avoids_inter h_p'_inter_parity

/-! ### Swap helpers for the symmetric application of cases 1, 2, 3 -/

/-- Swapping the order of `Graph.append` preserves IsEven (since `countP` is
    commutative under list append). -/
lemma append_isEven_iff (G1 G2 : Graph) :
    (G1.append G2).IsEven ↔ (G2.append G1).IsEven := by
  unfold Graph.IsEven
  constructor <;>
    (intro h v
     have := h v
     simp only [Graph.append_segments, List.countP_append] at this ⊢
     rw [Nat.add_comm]
     exact this)

/-- Swapping the order of `Graph.append` preserves the vertex set. -/
lemma append_toVertexSet_eq (G1 G2 : Graph) :
    (G1.append G2).toVertexSet = (G2.append G1).toVertexSet := by
  ext v
  simp only [Graph.toVertexSet, Set.mem_setOf_eq, Graph.toVertices, List.mem_dedup,
             List.mem_flatMap, Graph.append_segments, List.mem_append]
  constructor <;>
    (rintro ⟨a, ha_or, hv⟩
     refine ⟨a, ?_, hv⟩
     tauto)

/-- Swapping the order of `Graph.append` preserves the ray-segment crossing count. -/
lemma append_intersectionRayGraphSegmentsNumber_eq (r : Ray) (G1 G2 : Graph) :
    intersectionRayGraphSegmentsNumber r (G1.append G2) =
    intersectionRayGraphSegmentsNumber r (G2.append G1) := by
  unfold intersectionRayGraphSegmentsNumber
  simp only [Graph.append_segments, List.countP_append]
  exact Nat.add_comm _ _

/-- Swapping the order of `Graph.append` preserves segment membership. -/
lemma append_segments_mem_iff {G1 G2 : Graph} {seg : LineSegment} :
    seg ∈ (G1.append G2).segments ↔ seg ∈ (G2.append G1).segments := by
  simp only [Graph.append_segments, List.mem_append]
  tauto

/-- Swapping the order of `Graph.append` preserves `rayAvoidsGraphVertices`. -/
lemma append_rayAvoidsGraphVertices_iff (r : Ray) (G1 G2 : Graph) :
    rayAvoidsGraphVertices r (G1.append G2) ↔ rayAvoidsGraphVertices r (G2.append G1) := by
  unfold rayAvoidsGraphVertices
  rw [append_toVertexSet_eq]

/-- See `evenGraphIntersection_isEven_and_interior_eq` in
    `EvenGraphIntersection.lean` for the statement. -/
theorem intersection_isEven_and_interior_eq
    (G1 G2 : EvenGraph)
    (h_fin12 : Set.Finite (G1.toBoundarySet ∩ G2.toBoundarySet)) :
    ∃ h_even :
      (((graphRefinementSelfAndWrt G1 G2 h_fin12).toGraph.selectSegmentsInside
            G2.interior).append
        ((graphRefinementSelfAndWrt G2 G1 (flipFin h_fin12)).toGraph.selectSegmentsInside
            G1.interior)).IsEven,
      (⟨((graphRefinementSelfAndWrt G1 G2 h_fin12).toGraph.selectSegmentsInside
            G2.interior).append
          ((graphRefinementSelfAndWrt G2 G1 (flipFin h_fin12)).toGraph.selectSegmentsInside
            G1.interior),
        h_even⟩ : EvenGraph).interior =
        G1.interior ∩ G2.interior := by
  have h_fin21 : Set.Finite (G2.toBoundarySet ∩ G1.toBoundarySet) := flipFin h_fin12
  -- Setup
  have h_no_segment_interior_vertices_G1' := graphRefinementSelfAndWrt_no_segment_interior_vertices G1 G2 h_fin12
  have h_no_segment_interior_vertices_G2' := graphRefinementSelfAndWrt_no_segment_interior_vertices G2 G1 h_fin21
  set G1' := graphRefinementSelfAndWrt G1 G2 h_fin12 with hG1'_def
  set G2' := graphRefinementSelfAndWrt G2 G1 h_fin21 with hG2'_def
  set G_inter : Graph :=
    (G1'.toGraph.selectSegmentsInside G2.interior).append
      (G2'.toGraph.selectSegmentsInside G1.interior) with hG_inter_def
  have hG1'_int : G1'.interior = G1.interior := graphRefinementSelfAndWrt_interior_eq G1 G2 h_fin12
  have hG2'_int : G2'.interior = G2.interior := graphRefinementSelfAndWrt_interior_eq G2 G1 h_fin21
  have hG1'_bnd : G1'.toBoundarySet = G1.toBoundarySet :=
    graphRefinementSelfAndWrt_boundary_eq G1 G2 h_fin12
  have hG2'_bnd : G2'.toBoundarySet = G2.toBoundarySet :=
    graphRefinementSelfAndWrt_boundary_eq G2 G1 h_fin21
  -- G_inter.segments = selected G1' ++ selected G2'
  have hG_inter_segs : G_inter.segments =
      _root_.selectSegmentsInside G1'.segments G2.interior ++
      _root_.selectSegmentsInside G2'.segments G1.interior := rfl
  -- Each G_inter segment is in G1'.segments or G2'.segments.
  have h_inter_seg_origin : ∀ seg ∈ G_inter.segments,
      seg ∈ G1'.segments ∨ seg ∈ G2'.segments := by
    intro seg hseg
    rw [hG_inter_segs, List.mem_append] at hseg
    rcases hseg with h | h
    · left; exact List.mem_of_mem_filter h
    · right; exact List.mem_of_mem_filter h
  -- intersectionRayGraphSegmentsNumber for G_inter is intersectionRayCount.
  have h_inter_count_eq : ∀ r : Ray,
      intersectionRayGraphSegmentsNumber r G_inter =
      intersectionRayCount r G1 G2 h_fin12 h_fin21 := by
    intro r
    rfl
  -- A useful auxiliary: vertices of G_inter are vertices of refined graphs.
  have h_inter_vert_in_refined : ∀ v ∈ G_inter.toVertices,
      v ∈ G1'.toVertices ∨ v ∈ G2'.toVertices := by
    intro v hv
    simp only [Graph.toVertices, List.mem_dedup, List.mem_flatMap, List.mem_cons,
               (List.not_mem_nil _), or_false] at hv
    obtain ⟨seg, hseg, h_or⟩ := hv
    have h_or' : seg.p1 = v ∨ seg.p2 = v := by
      rcases h_or with rfl | rfl
      · left; rfl
      · right; rfl
    rcases h_inter_seg_origin seg hseg with h1 | h2
    · left
      simp only [Graph.toVertices, List.mem_dedup, List.mem_flatMap, List.mem_cons,
                 (List.not_mem_nil _), or_false]
      rcases h_or' with rfl | rfl
      · exact ⟨seg, h1, Or.inl rfl⟩
      · exact ⟨seg, h1, Or.inr rfl⟩
    · right
      simp only [Graph.toVertices, List.mem_dedup, List.mem_flatMap, List.mem_cons,
                 (List.not_mem_nil _), or_false]
      rcases h_or' with rfl | rfl
      · exact ⟨seg, h2, Or.inl rfl⟩
      · exact ⟨seg, h2, Or.inr rfl⟩
  -- Build V_extra and S_extra for the characterization theorem.
  let V_extra : Finset Vector2D := (G1'.toVertices ++ G2'.toVertices).toFinset
  let S_extra : Finset LineSegment := (G1'.segments ++ G2'.segments).toFinset
  -- Helper: every endpoint of a G1' or G2' segment is a vertex.
  have h_p1_mem_G1' : ∀ seg ∈ G1'.segments, seg.p1 ∈ G1'.toVertices := fun s hs =>
    G1'.p1_mem_toVertices hs
  have h_p2_mem_G1' : ∀ seg ∈ G1'.segments, seg.p2 ∈ G1'.toVertices := fun s hs =>
    G1'.p2_mem_toVertices hs
  have h_p1_mem_G2' : ∀ seg ∈ G2'.segments, seg.p1 ∈ G2'.toVertices := fun s hs =>
    G2'.p1_mem_toVertices hs
  have h_p2_mem_G2' : ∀ seg ∈ G2'.segments, seg.p2 ∈ G2'.toVertices := fun s hs =>
    G2'.p2_mem_toVertices hs
  -- Refined-graph vertices lie in the refined graph's boundary set.
  have h_vert_in_bnd : ∀ (G : EvenGraph) v, v ∈ G.toVertices → v ∈ G.toBoundarySet := by
    intro G v hv
    rw [EvenGraph.mem_toVertices_iff] at hv
    obtain ⟨seg, hseg, h_or⟩ := hv
    refine ⟨seg, hseg, ?_⟩
    rcases h_or with rfl | rfl
    · exact ⟨0, le_refl 0, zero_le_one, by ring, by ring⟩
    · exact ⟨1, zero_le_one, le_refl 1, by ring, by ring⟩
  -- A refined-G1' vertex is in G1.toBoundarySet (via boundary equality).
  have h_G1'_vert_in_G1_bnd : ∀ v ∈ G1'.toVertices, v ∈ G1.toBoundarySet := by
    intro v hv
    have := h_vert_in_bnd G1' v hv
    rw [hG1'_bnd] at this
    exact this
  have h_G2'_vert_in_G2_bnd : ∀ v ∈ G2'.toVertices, v ∈ G2.toBoundarySet := by
    intro v hv
    have := h_vert_in_bnd G2' v hv
    rw [hG2'_bnd] at this
    exact this
  -- Hypothesis (i): S_extra non-degenerate
  have h_S_extra_nondeg : ∀ seg ∈ S_extra, seg.p1 ≠ seg.p2 := by
    intro seg hseg
    simp only [S_extra, List.mem_toFinset, List.mem_append] at hseg
    rcases hseg with h | h
    · exact G1'.segments_nondegenerate seg h
    · exact G2'.segments_nondegenerate seg h
  -- Hypothesis (ii): no-cross.
  have h_no_segment_interior_vertices : ∀ v ∈ G_inter.toVertices,
      (∀ seg ∈ G_inter.segments, seg.p1 ≠ v → seg.p2 ≠ v → v ∉ seg.toSet) ∧
      (∀ seg ∈ S_extra, seg.p1 ≠ v → seg.p2 ≠ v → v ∉ seg.toSet) := by
    intro v hv
    have hv_refined := h_inter_vert_in_refined v hv
    -- Helper: v not on non-incident G1' or G2' segment.
    have h_not_on_G1' : ∀ seg ∈ G1'.segments, seg.p1 ≠ v → seg.p2 ≠ v → v ∉ seg.toSet := by
      intro seg hseg h1 h2
      rcases hv_refined with hv1 | hv2
      · -- same-graph case for G1'.
        exact h_no_segment_interior_vertices_G1' v hv1 seg hseg h1 h2
      · -- cross-graph: v ∈ G2'.toVertices, seg ∈ G1'.segments.
        intro h_on
        have hv_G2_bnd : v ∈ G2.toBoundarySet := h_G2'_vert_in_G2_bnd v hv2
        have h_subset := graphRefinementSelfAndWrt_seg_inter_boundary_subset G1 G2 h_fin12 seg hseg
        have hv_in : v ∈ ({seg.p1, seg.p2} : Set Vector2D) := h_subset ⟨h_on, hv_G2_bnd⟩
        rcases hv_in with hp1 | hp2
        · exact h1 hp1.symm
        · exact h2 hp2.symm
    have h_not_on_G2' : ∀ seg ∈ G2'.segments, seg.p1 ≠ v → seg.p2 ≠ v → v ∉ seg.toSet := by
      intro seg hseg h1 h2
      rcases hv_refined with hv1 | hv2
      · -- cross-graph: v ∈ G1'.toVertices, seg ∈ G2'.segments.
        intro h_on
        have hv_G1_bnd : v ∈ G1.toBoundarySet := h_G1'_vert_in_G1_bnd v hv1
        have h_subset := graphRefinementSelfAndWrt_seg_inter_boundary_subset G2 G1 h_fin21 seg hseg
        have hv_in : v ∈ ({seg.p1, seg.p2} : Set Vector2D) := h_subset ⟨h_on, hv_G1_bnd⟩
        rcases hv_in with hp1 | hp2
        · exact h1 hp1.symm
        · exact h2 hp2.symm
      · -- same-graph case for G2'.
        exact h_no_segment_interior_vertices_G2' v hv2 seg hseg h1 h2
    refine ⟨?_, ?_⟩
    · intro seg hseg h1 h2
      rcases h_inter_seg_origin seg hseg with hg1 | hg2
      · exact h_not_on_G1' seg hg1 h1 h2
      · exact h_not_on_G2' seg hg2 h1 h2
    · intro seg hseg h1 h2
      simp only [S_extra, List.mem_toFinset, List.mem_append] at hseg
      rcases hseg with h | h
      · exact h_not_on_G1' seg h h1 h2
      · exact h_not_on_G2' seg h h1 h2
  -- Hypothesis (iii): the parity ↔ I = G1.int ∩ G2.int property.
  have h_exists : ∃ I : Set Vector2D,
      I ∩ G_inter.toBoundarySet = ∅ ∧
      ∀ r : Ray,
        r.origin ∉ G_inter.toBoundarySet →
        (∀ s ∈ S_extra, r.origin ∉ s.toSet) →
        rayAvoidsGraphVertices r G_inter →
        (∀ v ∈ V_extra, v ∉ r.toSet) →
        (intersectionRayGraphSegmentsNumber r G_inter % 2 = 1 ↔
          r.origin ∈ I) := by
    refine ⟨G1.interior ∩ G2.interior, ?_, ?_⟩
    · -- I ∩ G_inter.boundary = ∅: G_inter.boundary ⊆ G1.bnd ∪ G2.bnd, but
      -- G1.int ⊆ ¬G1.bnd, etc.
      ext q
      simp only [Set.mem_inter_iff, Set.mem_empty_iff_false, iff_false, not_and]
      intro hq h_q_bnd
      obtain ⟨seg, hseg, h_on⟩ := h_q_bnd
      rcases h_inter_seg_origin seg hseg with hg1 | hg2
      · -- seg ∈ G1'.segments, so q ∈ G1.boundary.
        have h_q_in_G1 : q ∈ G1.toBoundarySet := by
          rw [← hG1'_bnd]; exact ⟨seg, hg1, h_on⟩
        obtain ⟨s', hs', hin'⟩ := h_q_in_G1
        -- hq.1 : q ∈ G1.interior, so q avoids G1.segments.
        exact hq.1.1 s' hs' hin'
      · have h_q_in_G2 : q ∈ G2.toBoundarySet := by
          rw [← hG2'_bnd]; exact ⟨seg, hg2, h_on⟩
        obtain ⟨s', hs', hin'⟩ := h_q_in_G2
        exact hq.2.1 s' hs' hin'
    · -- The parity ↔ membership property.
      intro r h_origin_off_G_inter h_origin_off_S r_avoids_G_inter h_verts_off_r
      -- Origin avoids both refined graphs (since S_extra ⊇ refined segments).
      have h_origin_avoids_G1' : ∀ seg ∈ G1'.segments, pointAvoidsSegment r.origin seg := by
        intro seg hseg
        apply h_origin_off_S
        simp only [S_extra, List.mem_toFinset, List.mem_append]
        exact Or.inl hseg
      have h_origin_avoids_G2' : ∀ seg ∈ G2'.segments, pointAvoidsSegment r.origin seg := by
        intro seg hseg
        apply h_origin_off_S
        simp only [S_extra, List.mem_toFinset, List.mem_append]
        exact Or.inr hseg
      -- Ray avoids both refined vertex sets (since V_extra ⊇ refined vertices).
      have h_ray_avoids_G1' : rayAvoidsGraphVertices r G1' := by
        rw [rayAvoidsGraphVertices, Set.eq_empty_iff_forall_not_mem]
        intro v ⟨hv_ray, hv_vert⟩
        have : v ∈ V_extra := by
          simp only [V_extra, List.mem_toFinset, List.mem_append]
          exact Or.inl hv_vert
        exact h_verts_off_r v this hv_ray
      have h_ray_avoids_G2' : rayAvoidsGraphVertices r G2' := by
        rw [rayAvoidsGraphVertices, Set.eq_empty_iff_forall_not_mem]
        intro v ⟨hv_ray, hv_vert⟩
        have : v ∈ V_extra := by
          simp only [V_extra, List.mem_toFinset, List.mem_append]
          exact Or.inr hv_vert
        exact h_verts_off_r v this hv_ray
      rw [h_inter_count_eq r]
      exact intersectionParity_iff_in_interiors r G1 G2 h_fin12 h_fin21
        h_ray_avoids_G1' h_ray_avoids_G2' h_origin_avoids_G1' h_origin_avoids_G2'
  -- Apply the characterization theorem.
  have h_even : G_inter.IsEven :=
    Graph.isEven_of_exists_interior_set G_inter V_extra S_extra
      h_S_extra_nondeg h_no_segment_interior_vertices h_exists
  refine ⟨h_even, ?_⟩
  -- Now prove interior equality.
  ext p
  rw [Set.mem_inter_iff]
  show ((∀ seg ∈ G_inter.segments, pointAvoidsSegment p seg) ∧
        ∀ r : Ray, r.origin = p → rayAvoidsGraphVertices r G_inter →
          intersectionRayGraphSegmentsNumber r G_inter % 2 = 1) ↔
        p ∈ G1.interior ∧ p ∈ G2.interior
  constructor
  · -- (⊆)
    intro ⟨h_p_avoids_inter, h_parity⟩
    -- Derive p ∉ G1.toBoundarySet and p ∉ G2.toBoundarySet via Cases 1, 2, 3.
    have h_p_off_G1 : p ∉ G1.toBoundarySet := by
      intro h_p_on_G1
      by_cases h_p_in_G2_int : p ∈ G2.interior
      · -- Case 1
        obtain ⟨seg, hseg, hp_seg⟩ :=
          case1_G1_bnd_G2_int_in_inter_bnd G1 G2 h_fin12 h_fin21 p h_p_on_G1 h_p_in_G2_int
        exact h_p_avoids_inter seg hseg hp_seg
      · by_cases h_p_on_G2 : p ∈ G2.toBoundarySet
        · -- Case 3
          exact case3_contradiction G1 G2 h_fin12 h_fin21 h_no_segment_interior_vertices_G1' h_even p
            h_p_on_G1 h_p_on_G2 h_p_avoids_inter h_parity
        · -- Case 2
          exact case2_contradiction G1 G2 h_fin12 h_fin21 h_even p
            h_p_on_G1 h_p_on_G2 h_p_in_G2_int h_p_avoids_inter h_parity
    have h_p_off_G2 : p ∉ G2.toBoundarySet := by
      intro h_p_on_G2
      by_cases h_p_in_G1_int : p ∈ G1.interior
      · -- Case 1 with G1, G2 swapped (gives p ∈ swap-G_inter.boundary).
        obtain ⟨seg, hseg_swap, hp_seg⟩ :=
          case1_G1_bnd_G2_int_in_inter_bnd G2 G1 h_fin21 h_fin12 p h_p_on_G2 h_p_in_G1_int
        -- Convert hseg_swap (membership in swap) to membership in G_inter.
        apply h_p_avoids_inter seg _ hp_seg
        rw [show G_inter.segments = _ from rfl]
        exact (append_segments_mem_iff (G1 := _) (G2 := _) (seg := seg)).mpr hseg_swap
      · by_cases h_p_on_G1 : p ∈ G1.toBoundarySet
        · -- Case 3 (symmetric in G1, G2).
          exact case3_contradiction G1 G2 h_fin12 h_fin21 h_no_segment_interior_vertices_G1' h_even p
            h_p_on_G1 h_p_on_G2 h_p_avoids_inter h_parity
        · -- Case 2 with G1, G2 swapped.
          have h_even_swap : (((graphRefinementSelfAndWrt G2 G1 h_fin21).toGraph.selectSegmentsInside
                G1.interior).append
              ((graphRefinementSelfAndWrt G1 G2 h_fin12).toGraph.selectSegmentsInside
                G2.interior)).IsEven :=
            (append_isEven_iff _ _).mp h_even
          have h_avoids_swap : ∀ seg ∈ (((graphRefinementSelfAndWrt G2 G1 h_fin21).toGraph.selectSegmentsInside
                G1.interior).append
              ((graphRefinementSelfAndWrt G1 G2 h_fin12).toGraph.selectSegmentsInside
                G2.interior)).segments, pointAvoidsSegment p seg := by
            intro seg hseg
            apply h_p_avoids_inter seg
            exact (append_segments_mem_iff (G1 := _) (G2 := _) (seg := seg)).mp hseg
          have h_parity_swap : ∀ r : Ray, r.origin = p →
              rayAvoidsGraphVertices r (((graphRefinementSelfAndWrt G2 G1 h_fin21).toGraph.selectSegmentsInside
                  G1.interior).append
                ((graphRefinementSelfAndWrt G1 G2 h_fin12).toGraph.selectSegmentsInside
                  G2.interior)) →
              intersectionRayGraphSegmentsNumber r
                (((graphRefinementSelfAndWrt G2 G1 h_fin21).toGraph.selectSegmentsInside
                    G1.interior).append
                  ((graphRefinementSelfAndWrt G1 G2 h_fin12).toGraph.selectSegmentsInside
                    G2.interior)) % 2 = 1 := by
            intro r h_origin h_avoids_swap_r
            have h_avoids_orig : rayAvoidsGraphVertices r G_inter :=
              (append_rayAvoidsGraphVertices_iff r _ _).mpr h_avoids_swap_r
            have := h_parity r h_origin h_avoids_orig
            rw [append_intersectionRayGraphSegmentsNumber_eq r] at this
            exact this
          exact case2_contradiction G2 G1 h_fin21 h_fin12 h_even_swap p
            h_p_on_G2 h_p_on_G1 h_p_in_G1_int h_avoids_swap h_parity_swap
    -- Hence p avoids both refined boundaries.
    have h_p_off_G1' : p ∉ G1'.toBoundarySet := by rw [hG1'_bnd]; exact h_p_off_G1
    have h_p_off_G2' : p ∉ G2'.toBoundarySet := by rw [hG2'_bnd]; exact h_p_off_G2
    have h_p_avoids_G1' : ∀ seg ∈ G1'.segments, pointAvoidsSegment p seg := by
      intro seg hseg h_on
      exact h_p_off_G1' ⟨seg, hseg, h_on⟩
    have h_p_avoids_G2' : ∀ seg ∈ G2'.segments, pointAvoidsSegment p seg := by
      intro seg hseg h_on
      exact h_p_off_G2' ⟨seg, hseg, h_on⟩
    -- p is not a vertex of either refined graph (vertices live in their boundaries).
    have h_p_not_G1'_vert : ∀ v ∈ G1'.toVertices, v ≠ p := by
      intro v hv heq
      apply h_p_off_G1'
      have := h_vert_in_bnd G1' v hv
      rw [heq] at this; exact this
    have h_p_not_G2'_vert : ∀ v ∈ G2'.toVertices, v ≠ p := by
      intro v hv heq
      apply h_p_off_G2'
      have := h_vert_in_bnd G2' v hv
      rw [heq] at this; exact this
    have h_p_not_both : ∀ v ∈ G1'.toVertices ++ G2'.toVertices, v ≠ p := by
      intro v hv
      rcases List.mem_append.mp hv with h | h
      · exact h_p_not_G1'_vert v h
      · exact h_p_not_G2'_vert v h
    -- Find a ray from p avoiding both refined graphs' vertices.
    obtain ⟨r₀, h_origin₀, h_r₀_avoids1, h_r₀_avoids2⟩ :=
      exists_ray_avoiding_both_vertices p G1' G2' h_p_not_both
    -- This ray also avoids G_inter vertices.
    have h_r₀_avoids_inter : rayAvoidsGraphVertices r₀ G_inter := by
      rw [rayAvoidsGraphVertices, Set.eq_empty_iff_forall_not_mem]
      intro v ⟨hv_ray, hv_vert⟩
      rcases h_inter_vert_in_refined v hv_vert with h1 | h2
      · have : v ∈ r₀.toSet ∩ G1'.toVertexSet := ⟨hv_ray, h1⟩
        rw [h_r₀_avoids1] at this; exact this
      · have : v ∈ r₀.toSet ∩ G2'.toVertexSet := ⟨hv_ray, h2⟩
        rw [h_r₀_avoids2] at this; exact this
    -- Ray r₀ has odd parity for G_inter by hypothesis.
    have h_r₀_inter_odd := h_parity r₀ h_origin₀ h_r₀_avoids_inter
    -- By intersectionRayCount_parity, both G1' and G2' counts are odd.
    rw [h_inter_count_eq] at h_r₀_inter_odd
    have h_origin_segs1 : ∀ seg ∈ G1'.segments, pointAvoidsSegment r₀.origin seg := by
      rw [h_origin₀]; exact h_p_avoids_G1'
    have h_origin_segs2 : ∀ seg ∈ G2'.segments, pointAvoidsSegment r₀.origin seg := by
      rw [h_origin₀]; exact h_p_avoids_G2'
    have ⟨h_G1'_odd, h_G2'_odd⟩ := (intersectionRayCount_parity r₀ G1 G2 h_fin12
      h_r₀_avoids1 h_r₀_avoids2 h_origin_segs1 h_origin_segs2).mp h_r₀_inter_odd
    -- Conclude p ∈ G1.interior ∩ G2.interior.
    have h_p_G1_int : p ∈ G1.interior := by
      rw [← hG1'_int]
      refine ⟨h_p_avoids_G1', ?_⟩
      intro r h_origin h_avoids
      have h_eq := intersectionParity_eq_of_sameOrigin_avoidsGraphVertices
        r₀ r G1' (by simp [sameOrigin, h_origin₀, h_origin])
        h_r₀_avoids1 h_avoids h_origin_segs1
      linarith
    have h_p_G2_int : p ∈ G2.interior := by
      rw [← hG2'_int]
      refine ⟨h_p_avoids_G2', ?_⟩
      intro r h_origin h_avoids
      have h_eq := intersectionParity_eq_of_sameOrigin_avoidsGraphVertices
        r₀ r G2' (by simp [sameOrigin, h_origin₀, h_origin])
        h_r₀_avoids2 h_avoids h_origin_segs2
      linarith
    exact ⟨h_p_G1_int, h_p_G2_int⟩
  · -- (⊇)
    intro ⟨hG1_int, hG2_int⟩
    -- Get refined-graph interior membership.
    have h_p_G1' : p ∈ G1'.interior := by rw [hG1'_int]; exact hG1_int
    have h_p_G2' : p ∈ G2'.interior := by rw [hG2'_int]; exact hG2_int
    have h_p_avoids_G1' := h_p_G1'.1
    have h_p_avoids_G2' := h_p_G2'.1
    -- Goal: p avoids G_inter.segments AND ∀ r avoiding G_inter vertices, parity odd.
    refine ⟨?_, ?_⟩
    · intro seg hseg
      rcases h_inter_seg_origin seg hseg with hg1 | hg2
      · exact h_p_avoids_G1' seg hg1
      · exact h_p_avoids_G2' seg hg2
    · intro r h_origin h_r_avoids_inter
      -- We need to find a ray r₀ from p avoiding both refined vertices, then transfer parity.
      have h_p_not_both : ∀ v ∈ G1'.toVertices ++ G2'.toVertices, v ≠ p := by
        intro v hv
        rcases List.mem_append.mp hv with h | h
        · exact not_vertex_of_avoids_segments p G1' G1'.incident_count_pos h_p_avoids_G1' v h
        · exact not_vertex_of_avoids_segments p G2' G2'.incident_count_pos h_p_avoids_G2' v h
      obtain ⟨r₀, h_origin₀, h_r₀_avoids1, h_r₀_avoids2⟩ :=
        exists_ray_avoiding_both_vertices p G1' G2' h_p_not_both
      -- r₀ avoids G_inter vertices.
      have h_r₀_avoids_inter : rayAvoidsGraphVertices r₀ G_inter := by
        rw [rayAvoidsGraphVertices, Set.eq_empty_iff_forall_not_mem]
        intro v ⟨hv_ray, hv_vert⟩
        rcases h_inter_vert_in_refined v hv_vert with h1 | h2
        · have : v ∈ r₀.toSet ∩ G1'.toVertexSet := ⟨hv_ray, h1⟩
          rw [h_r₀_avoids1] at this; exact this
        · have : v ∈ r₀.toSet ∩ G2'.toVertexSet := ⟨hv_ray, h2⟩
          rw [h_r₀_avoids2] at this; exact this
      -- For r₀: odd parity from p ∈ G1'.int ∩ G2'.int.
      have h_origin_segs1 : ∀ seg ∈ G1'.segments, pointAvoidsSegment r₀.origin seg := by
        rw [h_origin₀]; exact h_p_avoids_G1'
      have h_origin_segs2 : ∀ seg ∈ G2'.segments, pointAvoidsSegment r₀.origin seg := by
        rw [h_origin₀]; exact h_p_avoids_G2'
      have h_G1'_odd : intersectionRayGraphSegmentsNumber r₀ G1' % 2 = 1 :=
        h_p_G1'.2 r₀ h_origin₀ h_r₀_avoids1
      have h_G2'_odd : intersectionRayGraphSegmentsNumber r₀ G2' % 2 = 1 :=
        h_p_G2'.2 r₀ h_origin₀ h_r₀_avoids2
      have h_r₀_inter_odd : intersectionRayCount r₀ G1 G2 h_fin12 h_fin21 % 2 = 1 :=
        (intersectionRayCount_parity r₀ G1 G2 h_fin12
          h_r₀_avoids1 h_r₀_avoids2 h_origin_segs1 h_origin_segs2).mpr ⟨h_G1'_odd, h_G2'_odd⟩
      -- Now we want this for r, not r₀. Use parity invariance via G_inter.
      -- But for that we need G_inter even (we have h_even) and r₀, r both avoid G_inter vertices.
      have h_G_inter_even : G_inter.IsEven := h_even
      -- Rebuild as EvenGraph to apply parity invariance.
      let G_inter_E : EvenGraph := ⟨G_inter, h_G_inter_even⟩
      have h_segs : G_inter_E.segments = G_inter.segments := rfl
      have h_origin_segs_inter : ∀ seg ∈ G_inter_E.segments,
          pointAvoidsSegment r₀.origin seg := by
        intro seg hseg
        rw [h_origin₀]
        rcases h_inter_seg_origin seg hseg with hg1 | hg2
        · exact h_p_avoids_G1' seg hg1
        · exact h_p_avoids_G2' seg hg2
      have h_eq := intersectionParity_eq_of_sameOrigin_avoidsGraphVertices
        r₀ r G_inter_E (by simp [sameOrigin, h_origin₀, h_origin])
        h_r₀_avoids_inter h_r_avoids_inter h_origin_segs_inter
      have h_inter_eq_inter_E : intersectionRayGraphSegmentsNumber r₀ G_inter_E =
          intersectionRayGraphSegmentsNumber r₀ G_inter := rfl
      have h_inter_eq_inter_E2 : intersectionRayGraphSegmentsNumber r G_inter_E =
          intersectionRayGraphSegmentsNumber r G_inter := rfl
      rw [h_inter_eq_inter_E, h_inter_eq_inter_E2] at h_eq
      rw [h_inter_count_eq r₀] at h_eq
      -- h_eq : intersectionRayCount r₀ ... % 2 = intersectionRayGraphSegmentsNumber r G_inter % 2
      -- h_r₀_inter_odd : intersectionRayCount r₀ ... % 2 = 1
      -- Goal: intersectionRayGraphSegmentsNumber r G_inter % 2 = 1
      omega

end EvenGraphIntersectionProofs

end
