/-! ## Section 1 — Computable segment-segment intersection

The single rational point of intersection between two segments, if it
exists and is not collinear-overlap. Returns `none` if disjoint or
collinear (these will be handled separately by the algorithm). -/

/- The (single-point) intersection of two segments, returned as `some pt`
    if the segments meet at exactly one rational point in both their
    interiors-or-endpoints, and `none` otherwise. -/
-- moved: `segSegIntersect` lives in `Polygons.MultipolygonIntersectionAlgorithmImpl`
/-- Characterization of `segSegIntersect = some pt`: the determinant `D` must
    be nonzero, the parameter conditions must hold, and `pt` is determined by
    the formula. -/
private theorem segSegIntersect_some_iff (s1 s2 : LineSegment) (pt : Vector2D) :
    segSegIntersect s1 s2 = some pt ↔
    (let dx1 := s1.p2.x - s1.p1.x
     let dy1 := s1.p2.y - s1.p1.y
     let dx2 := s2.p2.x - s2.p1.x
     let dy2 := s2.p2.y - s2.p1.y
     let D := dx1 * dy2 - dy1 * dx2
     D ≠ 0 ∧
     let bx := s2.p1.x - s1.p1.x
     let by_ := s2.p1.y - s1.p1.y
     let t1Num := bx * dy2 - by_ * dx2
     let t2Num := bx * dy1 - by_ * dx1
     0 ≤ t1Num * D ∧ t1Num * D ≤ D * D ∧
     0 ≤ t2Num * D ∧ t2Num * D ≤ D * D ∧
     pt = ⟨s1.p1.x + (t1Num / D) * dx1, s1.p1.y + (t1Num / D) * dy1⟩) := by
  show segSegIntersect s1 s2 = some pt ↔ _
  unfold segSegIntersect
  set dx1 := s1.p2.x - s1.p1.x with hdx1_def
  set dy1 := s1.p2.y - s1.p1.y with hdy1_def
  set dx2 := s2.p2.x - s2.p1.x with hdx2_def
  set dy2 := s2.p2.y - s2.p1.y with hdy2_def
  set D := dx1 * dy2 - dy1 * dx2 with hD_def
  set bx := s2.p1.x - s1.p1.x with hbx_def
  set by_ := s2.p1.y - s1.p1.y with hby_def
  set t1Num := bx * dy2 - by_ * dx2 with ht1Num_def
  set t2Num := bx * dy1 - by_ * dx1 with ht2Num_def
  show (if D = 0 then none
        else if 0 ≤ t1Num * D ∧ t1Num * D ≤ D * D ∧
             0 ≤ t2Num * D ∧ t2Num * D ≤ D * D then
          some ⟨s1.p1.x + (t1Num / D) * dx1, s1.p1.y + (t1Num / D) * dy1⟩
        else none) = some pt ↔ _
  by_cases hDeq : D = 0
  · rw [if_pos hDeq]
    simp only [reduceCtorEq, false_iff]
    push_neg
    intro h; exact absurd hDeq h
  · rw [if_neg hDeq]
    by_cases hcond :
        0 ≤ t1Num * D ∧ t1Num * D ≤ D * D ∧
          0 ≤ t2Num * D ∧ t2Num * D ≤ D * D
    · rw [if_pos hcond]
      constructor
      · intro h
        rw [Option.some_inj] at h
        refine ⟨hDeq, hcond.1, hcond.2.1, hcond.2.2.1, hcond.2.2.2, h.symm⟩
      · rintro ⟨_, _, _, _, _, hpt⟩
        rw [Option.some_inj]
        exact hpt.symm
    · rw [if_neg hcond]
      simp only [reduceCtorEq, false_iff]
      rintro ⟨_, hc1, hc2, hc3, hc4, _⟩
      exact hcond ⟨hc1, hc2, hc3, hc4⟩

/-- Correctness of `segSegIntersect`: it either returns a point on both
    segments, or `none`. -/
private theorem segSegIntersect_correct (s1 s2 : LineSegment) :
    (∃ pt, segSegIntersect s1 s2 = some pt ∧ pt ∈ s1.toSet ∧ pt ∈ s2.toSet) ∨
    (segSegIntersect s1 s2 = none) := by
  -- Use abbreviations for the three core variables but treat them as local
  -- defs (without `set`) so that `nlinarith`/`linear_combination` see them.
  let dx1 := s1.p2.x - s1.p1.x
  let dy1 := s1.p2.y - s1.p1.y
  let dx2 := s2.p2.x - s2.p1.x
  let dy2 := s2.p2.y - s2.p1.y
  let D := dx1 * dy2 - dy1 * dx2
  let bx := s2.p1.x - s1.p1.x
  let by_ := s2.p1.y - s1.p1.y
  let t1Num := bx * dy2 - by_ * dx2
  let t2Num := bx * dy1 - by_ * dx1
  show (∃ pt, (if D = 0 then none
               else if 0 ≤ t1Num * D ∧ t1Num * D ≤ D * D ∧
                        0 ≤ t2Num * D ∧ t2Num * D ≤ D * D then
                      some (Vector2D.mk (s1.p1.x + (t1Num / D) * dx1)
                              (s1.p1.y + (t1Num / D) * dy1))
                    else none) = some pt ∧ pt ∈ s1.toSet ∧ pt ∈ s2.toSet) ∨
        (if D = 0 then none
         else if 0 ≤ t1Num * D ∧ t1Num * D ≤ D * D ∧
                  0 ≤ t2Num * D ∧ t2Num * D ≤ D * D then
                some (Vector2D.mk (s1.p1.x + (t1Num / D) * dx1)
                        (s1.p1.y + (t1Num / D) * dy1))
              else none) = none
  by_cases hDeq : D = 0
  · right; rw [if_pos hDeq]
  · by_cases hcond :
      0 ≤ t1Num * D ∧ t1Num * D ≤ D * D ∧
        0 ≤ t2Num * D ∧ t2Num * D ≤ D * D
    · left
      obtain ⟨ht1_lo, ht1_hi, ht2_lo, ht2_hi⟩ := hcond
      let t1 : ℚ := t1Num / D
      let t2 : ℚ := t2Num / D
      let pt : Vector2D := ⟨s1.p1.x + t1 * dx1, s1.p1.y + t1 * dy1⟩
      refine ⟨pt, ?_, ?_, ?_⟩
      · rw [if_neg hDeq, if_pos ⟨ht1_lo, ht1_hi, ht2_lo, ht2_hi⟩]
      · -- pt ∈ s1.toSet
        have ht1_nn : 0 ≤ t1 := by
          show 0 ≤ t1Num / D
          rcases lt_or_gt_of_ne hDeq with hDneg | hDpos
          · have ht1Num_le : t1Num ≤ 0 := by
              by_contra h
              push_neg at h
              have hh : t1Num * D < 0 := mul_neg_of_pos_of_neg h hDneg
              linarith [ht1_lo]
            exact div_nonneg_of_nonpos ht1Num_le (le_of_lt hDneg)
          · have ht1Num_nn : 0 ≤ t1Num := by
              by_contra h
              push_neg at h
              have hh : t1Num * D < 0 := mul_neg_of_neg_of_pos h hDpos
              linarith [ht1_lo]
            exact div_nonneg ht1Num_nn (le_of_lt hDpos)
        have ht1_le_one : t1 ≤ 1 := by
          show t1Num / D ≤ 1
          rcases lt_or_gt_of_ne hDeq with hDneg | hDpos
          · rw [div_le_one_of_neg hDneg]
            -- D < 0 and t1Num * D ≤ D * D means D ≤ t1Num.
            by_contra hcontra
            push_neg at hcontra  -- hcontra : t1Num < D
            -- D - t1Num > 0, -D > 0, so (D - t1Num) * (-D) > 0
            have hh : 0 < (D - t1Num) * (-D) :=
              mul_pos (by linarith) (neg_pos.mpr hDneg)
            have heq : (D - t1Num) * (-D) = t1Num * D - D * D := by ring
            linarith [ht1_hi]
          · rw [div_le_one hDpos]
            by_contra hcontra
            push_neg at hcontra
            have hh : D * D < t1Num * D :=
              mul_lt_mul_of_pos_right hcontra hDpos
            linarith [ht1_hi]
        refine ⟨t1, ht1_nn, ht1_le_one, ?_, ?_⟩
        · show s1.p1.x + t1 * dx1 = (1 - t1) * s1.p1.x + t1 * s1.p2.x
          show s1.p1.x + t1 * (s1.p2.x - s1.p1.x) =
                 (1 - t1) * s1.p1.x + t1 * s1.p2.x
          ring
        · show s1.p1.y + t1 * dy1 = (1 - t1) * s1.p1.y + t1 * s1.p2.y
          show s1.p1.y + t1 * (s1.p2.y - s1.p1.y) =
                 (1 - t1) * s1.p1.y + t1 * s1.p2.y
          ring
      · -- pt ∈ s2.toSet
        have ht2_nn : 0 ≤ t2 := by
          show 0 ≤ t2Num / D
          rcases lt_or_gt_of_ne hDeq with hDneg | hDpos
          · have ht2Num_le : t2Num ≤ 0 := by
              by_contra h
              push_neg at h
              have hh : t2Num * D < 0 := mul_neg_of_pos_of_neg h hDneg
              linarith [ht2_lo]
            exact div_nonneg_of_nonpos ht2Num_le (le_of_lt hDneg)
          · have ht2Num_nn : 0 ≤ t2Num := by
              by_contra h
              push_neg at h
              have hh : t2Num * D < 0 := mul_neg_of_neg_of_pos h hDpos
              linarith [ht2_lo]
            exact div_nonneg ht2Num_nn (le_of_lt hDpos)
        have ht2_le_one : t2 ≤ 1 := by
          show t2Num / D ≤ 1
          rcases lt_or_gt_of_ne hDeq with hDneg | hDpos
          · rw [div_le_one_of_neg hDneg]
            by_contra hcontra
            push_neg at hcontra  -- hcontra : t2Num < D
            have hh : 0 < (D - t2Num) * (-D) :=
              mul_pos (by linarith) (neg_pos.mpr hDneg)
            have heq : (D - t2Num) * (-D) = t2Num * D - D * D := by ring
            linarith [ht2_hi]
          · rw [div_le_one hDpos]
            by_contra hcontra
            push_neg at hcontra
            have hh : D * D < t2Num * D :=
              mul_lt_mul_of_pos_right hcontra hDpos
            linarith [ht2_hi]
        -- Now: pt.x = s1.p1.x + t1*dx1, want = (1-t2)*s2.p1.x + t2*s2.p2.x.
        -- The identity reduces (after multiplying by D ≠ 0) to a polynomial
        -- identity in t1Num, t2Num, and the polygon coordinates, which `ring`
        -- can verify. We use `field_simp`/algebraic manipulation.
        -- Key: t1 = t1Num/D, t2 = t2Num/D.
        -- D * pt.x = D*s1.p1.x + t1Num * dx1
        -- D * ((1-t2)*s2.p1.x + t2*s2.p2.x) = D*s2.p1.x + t2Num * dx2
        -- LHS - RHS = D*(s1.p1.x - s2.p1.x) + t1Num*dx1 - t2Num*dx2
        --           = -D*bx + (bx*dy2 - by_*dx2)*dx1 - (bx*dy1 - by_*dx1)*dx2
        --           = bx*(dx1*dy2 - dy1*dx2) - D*bx = bx*D - D*bx = 0
        have hkey_x : s1.p1.x + t1 * dx1 = (1 - t2) * s2.p1.x + t2 * s2.p2.x := by
          show s1.p1.x + (t1Num / D) * (s1.p2.x - s1.p1.x) =
            (1 - t2Num / D) * s2.p1.x + (t2Num / D) * s2.p2.x
          rw [show t1Num = (s2.p1.x - s1.p1.x) * (s2.p2.y - s2.p1.y) -
                (s2.p1.y - s1.p1.y) * (s2.p2.x - s2.p1.x) from rfl,
              show t2Num = (s2.p1.x - s1.p1.x) * (s1.p2.y - s1.p1.y) -
                (s2.p1.y - s1.p1.y) * (s1.p2.x - s1.p1.x) from rfl]
          have hDne : (s1.p2.x - s1.p1.x) * (s2.p2.y - s2.p1.y) -
                       (s1.p2.y - s1.p1.y) * (s2.p2.x - s2.p1.x) ≠ 0 := hDeq
          field_simp
          ring
        have hkey_y : s1.p1.y + t1 * dy1 = (1 - t2) * s2.p1.y + t2 * s2.p2.y := by
          show s1.p1.y + (t1Num / D) * (s1.p2.y - s1.p1.y) =
            (1 - t2Num / D) * s2.p1.y + (t2Num / D) * s2.p2.y
          rw [show t1Num = (s2.p1.x - s1.p1.x) * (s2.p2.y - s2.p1.y) -
                (s2.p1.y - s1.p1.y) * (s2.p2.x - s2.p1.x) from rfl,
              show t2Num = (s2.p1.x - s1.p1.x) * (s1.p2.y - s1.p1.y) -
                (s2.p1.y - s1.p1.y) * (s1.p2.x - s1.p1.x) from rfl]
          have hDne : (s1.p2.x - s1.p1.x) * (s2.p2.y - s2.p1.y) -
                       (s1.p2.y - s1.p1.y) * (s2.p2.x - s2.p1.x) ≠ 0 := hDeq
          field_simp
          ring
        refine ⟨t2, ht2_nn, ht2_le_one, ?_, ?_⟩
        · show s1.p1.x + t1 * dx1 = (1 - t2) * s2.p1.x + t2 * s2.p2.x
          exact hkey_x
        · show s1.p1.y + t1 * dy1 = (1 - t2) * s2.p1.y + t2 * s2.p2.y
          exact hkey_y
    · right; rw [if_neg hDeq, if_neg hcond]

/-- If `segSegIntersect s1 s2 = none` and the segments share a common point
    `q`, then the determinant `D` is zero. (In other words, the only way
    `segSegIntersect` can fail to find an intersection is if the segments are
    parallel/collinear.) -/
private theorem segSegIntersect_none_implies_D_zero
    (s1 s2 : LineSegment)
    (q : Vector2D) (hq1 : q ∈ s1.toSet) (hq2 : q ∈ s2.toSet)
    (h_none : segSegIntersect s1 s2 = none) :
    (s1.p2.x - s1.p1.x) * (s2.p2.y - s2.p1.y) -
    (s1.p2.y - s1.p1.y) * (s2.p2.x - s2.p1.x) = 0 := by
  by_contra hD_ne
  -- Set up the abbreviations matching the definition.
  set dx1 := s1.p2.x - s1.p1.x with hdx1_def
  set dy1 := s1.p2.y - s1.p1.y with hdy1_def
  set dx2 := s2.p2.x - s2.p1.x with hdx2_def
  set dy2 := s2.p2.y - s2.p1.y with hdy2_def
  set D := dx1 * dy2 - dy1 * dx2 with hD_def
  -- `hD_ne` becomes `D ≠ 0`.
  change D ≠ 0 at hD_ne
  set bx := s2.p1.x - s1.p1.x with hbx_def
  set by_ := s2.p1.y - s1.p1.y with hby_def
  set t1Num := bx * dy2 - by_ * dx2 with ht1Num_def
  set t2Num := bx * dy1 - by_ * dx1 with ht2Num_def
  -- Extract parameters from membership in each segment.
  obtain ⟨t1, ht1_nn, ht1_le, hqx1, hqy1⟩ := hq1
  obtain ⟨t2, ht2_nn, ht2_le, hqx2, hqy2⟩ := hq2
  -- From q.x equalities: t1 * dx1 - t2 * dx2 = bx.
  have hxrel : t1 * dx1 - t2 * dx2 = bx := by
    have : (1 - t1) * s1.p1.x + t1 * s1.p2.x =
           (1 - t2) * s2.p1.x + t2 * s2.p2.x := by
      rw [← hqx1, ← hqx2]
    show t1 * (s1.p2.x - s1.p1.x) - t2 * (s2.p2.x - s2.p1.x) =
         s2.p1.x - s1.p1.x
    linarith
  -- From q.y equalities: t1 * dy1 - t2 * dy2 = by_.
  have hyrel : t1 * dy1 - t2 * dy2 = by_ := by
    have : (1 - t1) * s1.p1.y + t1 * s1.p2.y =
           (1 - t2) * s2.p1.y + t2 * s2.p2.y := by
      rw [← hqy1, ← hqy2]
    show t1 * (s1.p2.y - s1.p1.y) - t2 * (s2.p2.y - s2.p1.y) =
         s2.p1.y - s1.p1.y
    linarith
  -- Hence t1Num = t1 * D.
  have ht1Num_eq : t1Num = t1 * D := by
    show bx * dy2 - by_ * dx2 = t1 * (dx1 * dy2 - dy1 * dx2)
    have hbx_eq : bx = t1 * dx1 - t2 * dx2 := by linarith [hxrel]
    have hby_eq : by_ = t1 * dy1 - t2 * dy2 := by linarith [hyrel]
    rw [hbx_eq, hby_eq]; ring
  -- Hence t2Num = t2 * D.
  have ht2Num_eq : t2Num = t2 * D := by
    show bx * dy1 - by_ * dx1 = t2 * (dx1 * dy2 - dy1 * dx2)
    have hbx_eq : bx = t1 * dx1 - t2 * dx2 := by linarith [hxrel]
    have hby_eq : by_ = t1 * dy1 - t2 * dy2 := by linarith [hyrel]
    rw [hbx_eq, hby_eq]; ring
  -- Show that the parameter conditions hold.
  have hDD_nn : 0 ≤ D * D := mul_self_nonneg D
  have hcond1 : 0 ≤ t1Num * D := by
    rw [ht1Num_eq]
    have : t1Num * D = t1 * (D * D) := by rw [ht1Num_eq]; ring
    calc 0 ≤ t1 * (D * D) := mul_nonneg ht1_nn hDD_nn
      _ = (t1 * D) * D := by ring
  have hcond2 : t1Num * D ≤ D * D := by
    have hcalc : t1Num * D = t1 * (D * D) := by rw [ht1Num_eq]; ring
    rw [hcalc]
    calc t1 * (D * D) ≤ 1 * (D * D) :=
            mul_le_mul_of_nonneg_right ht1_le hDD_nn
      _ = D * D := by ring
  have hcond3 : 0 ≤ t2Num * D := by
    have hcalc : t2Num * D = t2 * (D * D) := by rw [ht2Num_eq]; ring
    rw [hcalc]
    exact mul_nonneg ht2_nn hDD_nn
  have hcond4 : t2Num * D ≤ D * D := by
    have hcalc : t2Num * D = t2 * (D * D) := by rw [ht2Num_eq]; ring
    rw [hcalc]
    calc t2 * (D * D) ≤ 1 * (D * D) :=
            mul_le_mul_of_nonneg_right ht2_le hDD_nn
      _ = D * D := by ring
  -- Now `segSegIntersect s1 s2` must return `some _`, contradicting `h_none`.
  have h_unfold : segSegIntersect s1 s2 =
      some ⟨s1.p1.x + (t1Num / D) * dx1, s1.p1.y + (t1Num / D) * dy1⟩ := by
    show (if D = 0 then none
          else if 0 ≤ t1Num * D ∧ t1Num * D ≤ D * D ∧
                   0 ≤ t2Num * D ∧ t2Num * D ≤ D * D then
                some (Vector2D.mk (s1.p1.x + (t1Num / D) * dx1)
                                  (s1.p1.y + (t1Num / D) * dy1))
              else none) = _
    rw [if_neg hD_ne, if_pos ⟨hcond1, hcond2, hcond3, hcond4⟩]
  rw [h_unfold] at h_none
  exact Option.some_ne_none _ h_none

/-! ## Section 2 — Computable polygon refinement

For each segment of m1, compute all the points to be inserted and
produce the resulting sub-segments. -/

/- Membership-on-segment test (computable, given rational coordinates).

    A point `p` lies on segment from `a` to `b` iff
    `(p-a) × (b-a) = 0` and `0 ≤ (p-a)·(b-a) ≤ |b-a|²`. -/
-- moved: `pointOnSegmentBool` lives in `Polygons.MultipolygonIntersectionAlgorithmImpl`
private theorem pointOnSegmentBool_iff (p a b : Vector2D) (h_ne : a ≠ b) :
    pointOnSegmentBool p a b = true ↔ p ∈ (LineSegment.mk a b).toSet := by
  -- Non-degeneracy gives lenSq > 0.
  have hlenSq_pos : 0 < (b.x - a.x) * (b.x - a.x) + (b.y - a.y) * (b.y - a.y) := by
    have hxy : b.x - a.x ≠ 0 ∨ b.y - a.y ≠ 0 := by
      by_contra h
      push_neg at h
      obtain ⟨hx, hy⟩ := h
      apply h_ne
      have hbx : b.x = a.x := by linarith [hx]
      have hby : b.y = a.y := by linarith [hy]
      cases a; cases b
      simp_all
    have hx_sq : 0 ≤ (b.x - a.x) * (b.x - a.x) := mul_self_nonneg _
    have hy_sq : 0 ≤ (b.y - a.y) * (b.y - a.y) := mul_self_nonneg _
    rcases hxy with hx | hy
    · have : 0 < (b.x - a.x) * (b.x - a.x) :=
        lt_of_le_of_ne hx_sq (fun h => hx (by nlinarith))
      linarith
    · have : 0 < (b.y - a.y) * (b.y - a.y) :=
        lt_of_le_of_ne hy_sq (fun h => hy (by nlinarith))
      linarith
  have hlenSq_ne : (b.x - a.x) * (b.x - a.x) + (b.y - a.y) * (b.y - a.y) ≠ 0 :=
    ne_of_gt hlenSq_pos
  unfold pointOnSegmentBool
  simp only [Bool.and_eq_true, decide_eq_true_eq]
  constructor
  · -- Forward direction.
    rintro ⟨⟨hcross0, hdot0⟩, hdot1⟩
    -- Let t := dot / lenSq.
    refine ⟨((p.x - a.x) * (b.x - a.x) + (p.y - a.y) * (b.y - a.y)) /
              ((b.x - a.x) * (b.x - a.x) + (b.y - a.y) * (b.y - a.y)), ?_, ?_, ?_, ?_⟩
    · exact div_nonneg hdot0 (le_of_lt hlenSq_pos)
    · rw [div_le_one hlenSq_pos]; exact hdot1
    · -- p.x = (1 - t) * a.x + t * b.x
      -- equivalent to: p.x - a.x = t * (b.x - a.x)
      have hcm : (b.y - a.y) * ((p.x - a.x) * (b.y - a.y) - (p.y - a.y) * (b.x - a.x)) = 0 := by
        rw [hcross0]; ring
      have hkey : (p.x - a.x) *
            ((b.x - a.x) * (b.x - a.x) + (b.y - a.y) * (b.y - a.y))
          = ((p.x - a.x) * (b.x - a.x) + (p.y - a.y) * (b.y - a.y)) * (b.x - a.x) := by
        nlinarith [hcm]
      have htx : p.x - a.x =
          ((p.x - a.x) * (b.x - a.x) + (p.y - a.y) * (b.y - a.y)) /
            ((b.x - a.x) * (b.x - a.x) + (b.y - a.y) * (b.y - a.y)) * (b.x - a.x) := by
        rw [div_mul_eq_mul_div, eq_div_iff hlenSq_ne]
        linarith [hkey]
      show p.x = (1 - ((p.x - a.x) * (b.x - a.x) + (p.y - a.y) * (b.y - a.y)) /
              ((b.x - a.x) * (b.x - a.x) + (b.y - a.y) * (b.y - a.y))) * a.x +
            ((p.x - a.x) * (b.x - a.x) + (p.y - a.y) * (b.y - a.y)) /
              ((b.x - a.x) * (b.x - a.x) + (b.y - a.y) * (b.y - a.y)) * b.x
      linarith [htx]
    · -- p.y = (1 - t) * a.y + t * b.y
      have hcm : (b.x - a.x) * ((p.x - a.x) * (b.y - a.y) - (p.y - a.y) * (b.x - a.x)) = 0 := by
        rw [hcross0]; ring
      have hkey : (p.y - a.y) *
            ((b.x - a.x) * (b.x - a.x) + (b.y - a.y) * (b.y - a.y))
          = ((p.x - a.x) * (b.x - a.x) + (p.y - a.y) * (b.y - a.y)) * (b.y - a.y) := by
        nlinarith [hcm]
      have hty : p.y - a.y =
          ((p.x - a.x) * (b.x - a.x) + (p.y - a.y) * (b.y - a.y)) /
            ((b.x - a.x) * (b.x - a.x) + (b.y - a.y) * (b.y - a.y)) * (b.y - a.y) := by
        rw [div_mul_eq_mul_div, eq_div_iff hlenSq_ne]
        linarith [hkey]
      show p.y = (1 - ((p.x - a.x) * (b.x - a.x) + (p.y - a.y) * (b.y - a.y)) /
              ((b.x - a.x) * (b.x - a.x) + (b.y - a.y) * (b.y - a.y))) * a.y +
            ((p.x - a.x) * (b.x - a.x) + (p.y - a.y) * (b.y - a.y)) /
              ((b.x - a.x) * (b.x - a.x) + (b.y - a.y) * (b.y - a.y)) * b.y
      linarith [hty]
  · -- Backward direction.
    rintro ⟨t, ht0, ht1, hpx, hpy⟩
    -- From the parametric form: (p.x - a.x) = t * (b.x - a.x), similarly for y.
    have hapx_eq : p.x - a.x = t * (b.x - a.x) := by rw [hpx]; ring
    have hapy_eq : p.y - a.y = t * (b.y - a.y) := by rw [hpy]; ring
    refine ⟨⟨?_, ?_⟩, ?_⟩
    · -- cross = 0
      rw [hapx_eq, hapy_eq]; ring
    · -- 0 ≤ dot
      rw [hapx_eq, hapy_eq]
      have hrw : t * (b.x - a.x) * (b.x - a.x) + t * (b.y - a.y) * (b.y - a.y)
            = t * ((b.x - a.x) * (b.x - a.x) + (b.y - a.y) * (b.y - a.y)) := by ring
      rw [hrw]
      exact mul_nonneg ht0 (le_of_lt hlenSq_pos)
    · -- dot ≤ lenSq
      rw [hapx_eq, hapy_eq]
      have hrw : t * (b.x - a.x) * (b.x - a.x) + t * (b.y - a.y) * (b.y - a.y)
            = t * ((b.x - a.x) * (b.x - a.x) + (b.y - a.y) * (b.y - a.y)) := by ring
      rw [hrw]
      have h2 : t * ((b.x - a.x) * (b.x - a.x) + (b.y - a.y) * (b.y - a.y))
            ≤ 1 * ((b.x - a.x) * (b.x - a.x) + (b.y - a.y) * (b.y - a.y)) :=
        mul_le_mul_of_nonneg_right ht1 (le_of_lt hlenSq_pos)
      linarith [h2]

/- Insertion sort by `vecCmpAlongSeg` segment direction. -/
-- moved: `sortAlongSeg` lives in `Polygons.MultipolygonIntersectionAlgorithmImpl`
/- Remove consecutive duplicates from a list with DecidableEq. -/
-- moved: `dedupConsec` lives in `Polygons.MultipolygonIntersectionAlgorithmImpl`
/-- The parameter `t ∈ [0, 1]` such that a point `p` on segment `seg` satisfies
    `p = (1 - t) * seg.p1 + t * seg.p2`. Computed via either the x or y coordinate
    depending on which axis the segment is non-degenerate along. -/
private def paramOnSeg (seg : LineSegment) (p : Vector2D) : ℚ :=
  if seg.p2.x ≠ seg.p1.x then
    (p.x - seg.p1.x) / (seg.p2.x - seg.p1.x)
  else
    (p.y - seg.p1.y) / (seg.p2.y - seg.p1.y)

private theorem paramOnSeg_spec
    (seg : LineSegment) (h_nondeg : seg.p1 ≠ seg.p2)
    (p : Vector2D) (h_on : p ∈ seg.toSet) :
    p.x = (1 - paramOnSeg seg p) * seg.p1.x + paramOnSeg seg p * seg.p2.x ∧
    p.y = (1 - paramOnSeg seg p) * seg.p1.y + paramOnSeg seg p * seg.p2.y ∧
    0 ≤ paramOnSeg seg p ∧ paramOnSeg seg p ≤ 1 := by
  obtain ⟨t, ht_nn, ht_le, hx, hy⟩ := h_on
  unfold paramOnSeg
  by_cases hxne : seg.p2.x ≠ seg.p1.x
  · -- Case 1: x axis is non-degenerate.
    rw [if_pos hxne]
    have hdx_ne : seg.p2.x - seg.p1.x ≠ 0 := sub_ne_zero.mpr hxne
    -- From `hx` we get `p.x - seg.p1.x = t * (seg.p2.x - seg.p1.x)`.
    have hxt : p.x - seg.p1.x = t * (seg.p2.x - seg.p1.x) := by
      rw [hx]; ring
    -- Hence `t = (p.x - seg.p1.x) / (seg.p2.x - seg.p1.x)`.
    have ht_eq : (p.x - seg.p1.x) / (seg.p2.x - seg.p1.x) = t := by
      rw [hxt]
      field_simp
    refine ⟨?_, ?_, ?_, ?_⟩
    · rw [ht_eq]; exact hx
    · rw [ht_eq]; exact hy
    · rw [ht_eq]; exact ht_nn
    · rw [ht_eq]; exact ht_le
  · -- Case 2: x axis is degenerate, so use y axis.
    rw [if_neg hxne]
    push_neg at hxne
    -- Show `seg.p2.y ≠ seg.p1.y`.
    have hyne : seg.p2.y ≠ seg.p1.y := by
      intro hyeq
      apply h_nondeg
      apply Vector2D.ext
      · exact hxne.symm
      · exact hyeq.symm
    have hdy_ne : seg.p2.y - seg.p1.y ≠ 0 := sub_ne_zero.mpr hyne
    have hyt : p.y - seg.p1.y = t * (seg.p2.y - seg.p1.y) := by
      rw [hy]; ring
    have ht_eq : (p.y - seg.p1.y) / (seg.p2.y - seg.p1.y) = t := by
      rw [hyt]
      field_simp
    refine ⟨?_, ?_, ?_, ?_⟩
    · -- x equation: with seg.p2.x = seg.p1.x, both sides simplify.
      rw [ht_eq, hx, hxne]
    · rw [ht_eq]; exact hy
    · rw [ht_eq]; exact ht_nn
    · rw [ht_eq]; exact ht_le

private theorem paramOnSeg_injective
    (seg : LineSegment) (h_nondeg : seg.p1 ≠ seg.p2)
    {p q : Vector2D} (h_p : p ∈ seg.toSet) (h_q : q ∈ seg.toSet)
    (h_eq : paramOnSeg seg p = paramOnSeg seg q) : p = q := by
  obtain ⟨hpx, hpy, _, _⟩ := paramOnSeg_spec seg h_nondeg p h_p
  obtain ⟨hqx, hqy, _, _⟩ := paramOnSeg_spec seg h_nondeg q h_q
  ext
  · -- p.x = q.x
    rw [hpx, hqx, h_eq]
  · -- p.y = q.y
    rw [hpy, hqy, h_eq]

private theorem paramOnSeg_p1 (seg : LineSegment) (h_nondeg : seg.p1 ≠ seg.p2) :
    paramOnSeg seg seg.p1 = 0 := by
  unfold paramOnSeg
  by_cases hxne : seg.p2.x ≠ seg.p1.x
  · simp [hxne]
  · push_neg at hxne
    have hyne : seg.p2.y ≠ seg.p1.y := by
      intro hye
      apply h_nondeg
      ext
      · exact hxne.symm
      · exact hye.symm
    simp [hxne]

private theorem paramOnSeg_p2 (seg : LineSegment) (h_nondeg : seg.p1 ≠ seg.p2) :
    paramOnSeg seg seg.p2 = 1 := by
  unfold paramOnSeg
  by_cases hxne : seg.p2.x ≠ seg.p1.x
  · rw [if_pos hxne]
    have h_diff : seg.p2.x - seg.p1.x ≠ 0 := sub_ne_zero.mpr hxne
    field_simp
  · push_neg at hxne
    rw [if_neg (by simp [hxne])]
    have hyne : seg.p2.y ≠ seg.p1.y := by
      intro hye
      apply h_nondeg
      ext
      · exact hxne.symm
      · exact hye.symm
    have h_diff : seg.p2.y - seg.p1.y ≠ 0 := sub_ne_zero.mpr hyne
    field_simp

private theorem vecCmpAlongSeg_eq_compare_paramOnSeg
    (seg : LineSegment) (h_nondeg : seg.p1 ≠ seg.p2)
    {a b : Vector2D} (h_a : a ∈ seg.toSet) (h_b : b ∈ seg.toSet) :
    vecCmpAlongSeg seg.p1 seg.p2 a b =
    compare (paramOnSeg seg a) (paramOnSeg seg b) := by
  -- Set up named values.
  set t_a := paramOnSeg seg a with ht_a_def
  set t_b := paramOnSeg seg b with ht_b_def
  set dx := seg.p2.x - seg.p1.x with hdx_def
  set dy := seg.p2.y - seg.p1.y with hdy_def
  -- Parametric form for `a` and `b`.
  obtain ⟨hax, hay, _, _⟩ := paramOnSeg_spec seg h_nondeg a h_a
  obtain ⟨hbx, hby, _, _⟩ := paramOnSeg_spec seg h_nondeg b h_b
  -- Convert to offset form: `a.x = p1.x + t_a * dx`, etc.
  have hax' : a.x = seg.p1.x + t_a * dx := by rw [hax]; ring
  have hay' : a.y = seg.p1.y + t_a * dy := by rw [hay]; ring
  have hbx' : b.x = seg.p1.x + t_b * dx := by rw [hbx]; ring
  have hby' : b.y = seg.p1.y + t_b * dy := by rw [hby]; ring
  -- Unified comparison helper for ℚ that works regardless of the ambient
  -- `Ord ℚ` instance (Mathlib's `Tactic.Ring.instOrdRat_mathlib` and
  -- `Rat.linearOrder.toOrd` differ as instances but yield the same values).
  have cmp_of_lt : ∀ {x y : ℚ}, x < y → (compare x y : Ordering) = Ordering.lt :=
    fun hxy => compare_lt_iff_lt.mpr hxy
  have cmp_of_gt : ∀ {x y : ℚ}, y < x → (compare x y : Ordering) = Ordering.gt :=
    fun hxy => compare_gt_iff_gt.mpr hxy
  have cmp_of_eq : ∀ {x y : ℚ}, x = y → (compare x y : Ordering) = Ordering.eq :=
    fun hxy => compare_eq_iff_eq.mpr hxy
  -- General helper: compare offsets when scaling factor is positive.
  have compare_pos :
      ∀ (v k : ℚ), 0 < k →
        compare (v + t_a * k) (v + t_b * k) = compare t_a t_b := by
    intro v k hk
    rcases lt_trichotomy t_a t_b with hlt | heq | hgt
    · have hmul : t_a * k < t_b * k := mul_lt_mul_of_pos_right hlt hk
      have h1 : v + t_a * k < v + t_b * k := by linarith
      rw [cmp_of_lt h1, cmp_of_lt hlt]
    · rw [heq, cmp_of_eq rfl, cmp_of_eq rfl]
    · have hmul : t_b * k < t_a * k := mul_lt_mul_of_pos_right hgt hk
      have h1 : v + t_b * k < v + t_a * k := by linarith
      rw [cmp_of_gt h1, cmp_of_gt hgt]
  -- General helper: compare swapped offsets when scaling factor is negative.
  have compare_neg :
      ∀ (v k : ℚ), k < 0 →
        compare (v + t_b * k) (v + t_a * k) = compare t_a t_b := by
    intro v k hk
    rcases lt_trichotomy t_a t_b with hlt | heq | hgt
    · -- t_a < t_b and k < 0, so t_a * k > t_b * k.
      have hmul : t_b * k < t_a * k := mul_lt_mul_of_neg_right hlt hk
      have h1 : v + t_b * k < v + t_a * k := by linarith
      rw [cmp_of_lt h1, cmp_of_lt hlt]
    · rw [heq, cmp_of_eq rfl, cmp_of_eq rfl]
    · have hmul : t_a * k < t_b * k := mul_lt_mul_of_neg_right hgt hk
      have h1 : v + t_a * k < v + t_b * k := by linarith
      rw [cmp_of_gt h1, cmp_of_gt hgt]
  -- Unfold `vecCmpAlongSeg`.
  unfold vecCmpAlongSeg
  -- Substitute `dx` and `dy`.
  show (if (if dx < 0 then -dx else dx) ≥ (if dy < 0 then -dy else dy) then
          if dx ≥ 0 then compare a.x b.x else compare b.x a.x
        else
          if dy ≥ 0 then compare a.y b.y else compare b.y a.y) = compare t_a t_b
  -- Case on the abs comparison.
  by_cases h_abs : (if dx < 0 then -dx else dx) ≥ (if dy < 0 then -dy else dy)
  · rw [if_pos h_abs]
    by_cases hdx_nn : dx ≥ 0
    · rw [if_pos hdx_nn]
      -- Need: compare a.x b.x = compare t_a t_b.
      -- We have dx ≥ 0. Need dx > 0.
      have hdx_pos : dx > 0 := by
        rcases lt_or_eq_of_le hdx_nn with hpos | hzero
        · exact hpos
        · -- dx = 0 → contradiction.
          exfalso
          have hdx_eq : dx = 0 := hzero.symm
          -- From h_abs with dx = 0: |0| ≥ |dy|, so dy = 0.
          have habs_dx : (if dx < 0 then -dx else dx) = 0 := by
            rw [if_neg (by linarith : ¬ dx < 0), hdx_eq]
          rw [habs_dx] at h_abs
          have habs_dy_le : (if dy < 0 then -dy else dy) ≤ 0 := h_abs
          have hdy_zero : dy = 0 := by
            by_cases hdyneg : dy < 0
            · rw [if_pos hdyneg] at habs_dy_le; linarith
            · rw [if_neg hdyneg] at habs_dy_le
              push_neg at hdyneg
              linarith
          -- dx = 0 and dy = 0 give p1 = p2.
          apply h_nondeg
          apply Vector2D.ext
          · have : seg.p2.x - seg.p1.x = 0 := hdx_eq
            linarith
          · have : seg.p2.y - seg.p1.y = 0 := hdy_zero
            linarith
      rw [hax', hbx']
      exact compare_pos seg.p1.x dx hdx_pos
    · rw [if_neg hdx_nn]
      push_neg at hdx_nn
      -- dx < 0; need: compare b.x a.x = compare t_a t_b.
      rw [hax', hbx']
      exact compare_neg seg.p1.x dx hdx_nn
  · rw [if_neg h_abs]
    push_neg at h_abs
    -- |dx| < |dy|.
    by_cases hdy_nn : dy ≥ 0
    · rw [if_pos hdy_nn]
      -- Need: compare a.y b.y = compare t_a t_b.
      -- dy ≥ 0; need dy > 0.
      have hdy_pos : dy > 0 := by
        rcases lt_or_eq_of_le hdy_nn with hpos | hzero
        · exact hpos
        · exfalso
          -- dy = 0 ⇒ |dy| = 0 ≤ |dx|, contradicting h_abs.
          have hdy_eq : dy = 0 := hzero.symm
          have habs_dy : (if dy < 0 then -dy else dy) = 0 := by
            rw [if_neg (by linarith : ¬ dy < 0), hdy_eq]
          rw [habs_dy] at h_abs
          -- (if dx < 0 then -dx else dx) < 0, but absolute value is ≥ 0.
          have habs_dx_nn : (if dx < 0 then -dx else dx) ≥ 0 := by
            by_cases hdxneg : dx < 0
            · rw [if_pos hdxneg]; linarith
            · rw [if_neg hdxneg]; push_neg at hdxneg; exact hdxneg
          linarith
      rw [hay', hby']
      exact compare_pos seg.p1.y dy hdy_pos
    · rw [if_neg hdy_nn]
      push_neg at hdy_nn
      -- dy < 0; need: compare b.y a.y = compare t_a t_b.
      rw [hay', hby']
      exact compare_neg seg.p1.y dy hdy_nn

/- Given a segment `seg` and a list of points in `seg.toSet`, produce the
    list of consecutive sub-segments after sorting and dedup. -/
-- moved: `splitSegmentAtPoints` lives in `Polygons.MultipolygonIntersectionAlgorithmImpl`
/-- If `pts1 = pts2`, then `splitSegmentAtPoints seg pts1` and
`splitSegmentAtPoints seg pts2` produce the same list of sub-segments
(a fortiori a permutation of endpoint multisets). This is a stub stating
the (provably) weakest hypothesis under which the conclusion always
holds; in full generality, requiring only that `pts1` and `pts2` have
the same set of elements is not sufficient because `vecCmpAlongSeg`
can return `Ordering.eq` for two distinct points whose projection onto
the longer axis coincides, and `mergeSort` is stable. -/
private theorem splitSegmentAtPoints_perm_iff
    (seg : LineSegment) (pts1 pts2 : List Vector2D)
    (h_pts_eq : pts1 = pts2) :
    List.Perm ((splitSegmentAtPoints seg pts1).map LineSegment.toEndpointsMultiset)
      ((splitSegmentAtPoints seg pts2).map LineSegment.toEndpointsMultiset) := by
  subst h_pts_eq
  exact List.Perm.refl _

/- Computable list of insertion points for a segment of `m`, refined wrt
    `other` polygon. Includes all rational intersections with `other`'s
    segments and all of `m`'s own vertices that lie strictly inside `seg`. -/
-- moved: `refinementPointsForSegment` lives in `Polygons.MultipolygonIntersectionAlgorithmImpl`
/- Refined segments of `m` wrt `other`. -/
-- moved: `refinedSegments` lives in `Polygons.MultipolygonIntersectionAlgorithmImpl`
/-! ### Helper lemmas about `dedupConsec`, `splitSegmentAtPoints`, and
    `refinedSegments`. -/

private theorem dedupConsec_mem_iff {α : Type*} [DecidableEq α] :
    ∀ (l : List α) (x : α), x ∈ dedupConsec l ↔ x ∈ l
  | [], x => by simp [dedupConsec]
  | [a], x => by simp [dedupConsec]
  | a :: b :: rest, x => by
    simp only [dedupConsec]
    by_cases hab : a = b
    · rw [if_pos hab]
      rw [dedupConsec_mem_iff (b :: rest) x]
      simp only [List.mem_cons]
      constructor
      · rintro (h | h)
        · right; left; exact h
        · right; right; exact h
      · rintro (h | h | h)
        · left; rw [h]; exact hab
        · left; exact h
        · right; exact h
    · rw [if_neg hab]
      simp only [List.mem_cons]
      rw [dedupConsec_mem_iff (b :: rest) x]
      simp only [List.mem_cons]

private theorem dedupConsec_subset {α : Type*} [DecidableEq α] (l : List α) :
    ∀ x ∈ dedupConsec l, x ∈ l := fun x => (dedupConsec_mem_iff l x).mp

/-- Membership in `mergeSort` is the same as in the original list. -/
private theorem sortAlongSeg_mem_iff (p1 p2 : Vector2D) (l : List Vector2D) (x : Vector2D) :
    x ∈ sortAlongSeg p1 p2 l ↔ x ∈ l := by
  unfold sortAlongSeg
  exact List.mem_mergeSort

/-! ### Strict-total-order properties of `vecCmpAlongSeg` on a segment -/

/-- For ℚ (using the Mathlib `Ord` instance), `(compare a b).isLE = true ↔ a ≤ b`. -/
private theorem rat_compare_isLE_iff (a b : ℚ) : (compare a b).isLE = true ↔ a ≤ b := by
  rw [← compare_le_iff_le]
  cases compare a b <;> simp [Ordering.isLE]

/-- The Boolean comparator `(vecCmpAlongSeg p1 p2 a b).isLE = true` is
    equivalent to a ≤-comparison on one of the coordinates of `a` and `b`. -/
private theorem vecCmpAlongSeg_isLE_iff (p1 p2 a b : Vector2D) :
    (vecCmpAlongSeg p1 p2 a b).isLE = true ↔
    (if (if p2.x - p1.x < 0 then -(p2.x - p1.x) else p2.x - p1.x)
        ≥ (if p2.y - p1.y < 0 then -(p2.y - p1.y) else p2.y - p1.y) then
      (if p2.x - p1.x ≥ 0 then a.x ≤ b.x else b.x ≤ a.x)
     else
      (if p2.y - p1.y ≥ 0 then a.y ≤ b.y else b.y ≤ a.y)) := by
  unfold vecCmpAlongSeg
  by_cases hX :
      (if p2.x - p1.x < 0 then -(p2.x - p1.x) else p2.x - p1.x)
        ≥ (if p2.y - p1.y < 0 then -(p2.y - p1.y) else p2.y - p1.y)
  · rw [if_pos hX, if_pos hX]
    by_cases hdx : p2.x - p1.x ≥ 0
    · rw [if_pos hdx, if_pos hdx]; exact rat_compare_isLE_iff a.x b.x
    · rw [if_neg hdx, if_neg hdx]; exact rat_compare_isLE_iff b.x a.x
  · rw [if_neg hX, if_neg hX]
    by_cases hdy : p2.y - p1.y ≥ 0
    · rw [if_pos hdy, if_pos hdy]; exact rat_compare_isLE_iff a.y b.y
    · rw [if_neg hdy, if_neg hdy]; exact rat_compare_isLE_iff b.y a.y

/-- Total order property of the `vecCmpAlongSeg` Boolean comparator. -/
private theorem vecCmpAlongSeg_isLE_total (p1 p2 a b : Vector2D) :
    (vecCmpAlongSeg p1 p2 a b).isLE = true ∨ (vecCmpAlongSeg p1 p2 b a).isLE = true := by
  rw [vecCmpAlongSeg_isLE_iff, vecCmpAlongSeg_isLE_iff]
  by_cases hX :
      (if p2.x - p1.x < 0 then -(p2.x - p1.x) else p2.x - p1.x)
        ≥ (if p2.y - p1.y < 0 then -(p2.y - p1.y) else p2.y - p1.y)
  · rw [if_pos hX, if_pos hX]
    by_cases hdx : p2.x - p1.x ≥ 0
    · rw [if_pos hdx, if_pos hdx]; exact le_total a.x b.x
    · rw [if_neg hdx, if_neg hdx]; exact le_total b.x a.x
  · rw [if_neg hX, if_neg hX]
    by_cases hdy : p2.y - p1.y ≥ 0
    · rw [if_pos hdy, if_pos hdy]; exact le_total a.y b.y
    · rw [if_neg hdy, if_neg hdy]; exact le_total b.y a.y

/-- Transitivity of the `vecCmpAlongSeg` Boolean comparator. -/
private theorem vecCmpAlongSeg_isLE_trans (p1 p2 a b c : Vector2D)
    (hab : (vecCmpAlongSeg p1 p2 a b).isLE = true)
    (hbc : (vecCmpAlongSeg p1 p2 b c).isLE = true) :
    (vecCmpAlongSeg p1 p2 a c).isLE = true := by
  rw [vecCmpAlongSeg_isLE_iff] at hab hbc ⊢
  by_cases hX :
      (if p2.x - p1.x < 0 then -(p2.x - p1.x) else p2.x - p1.x)
        ≥ (if p2.y - p1.y < 0 then -(p2.y - p1.y) else p2.y - p1.y)
  · rw [if_pos hX] at hab hbc ⊢
    by_cases hdx : p2.x - p1.x ≥ 0
    · rw [if_pos hdx] at hab hbc ⊢; exact le_trans hab hbc
    · rw [if_neg hdx] at hab hbc ⊢; exact le_trans hbc hab
  · rw [if_neg hX] at hab hbc ⊢
    by_cases hdy : p2.y - p1.y ≥ 0
    · rw [if_pos hdy] at hab hbc ⊢; exact le_trans hab hbc
    · rw [if_neg hdy] at hab hbc ⊢; exact le_trans hbc hab

/-- Antisymmetry of `vecCmpAlongSeg` for two points lying on a non-degenerate
    segment. -/
private theorem vecCmpAlongSeg_isLE_antisymm_on_seg
    (seg : LineSegment) (a b : Vector2D)
    (h_seg_nondeg : seg.p1 ≠ seg.p2)
    (ha : a ∈ seg.toSet) (hb : b ∈ seg.toSet)
    (hab : (vecCmpAlongSeg seg.p1 seg.p2 a b).isLE = true)
    (hba : (vecCmpAlongSeg seg.p1 seg.p2 b a).isLE = true) :
    a = b := by
  obtain ⟨s, _hs0, _hs1, hax, hay⟩ := ha
  obtain ⟨t, _ht0, _ht1, hbx, hby⟩ := hb
  have hax' : a.x = seg.p1.x + s * (seg.p2.x - seg.p1.x) := by rw [hax]; ring
  have hay' : a.y = seg.p1.y + s * (seg.p2.y - seg.p1.y) := by rw [hay]; ring
  have hbx' : b.x = seg.p1.x + t * (seg.p2.x - seg.p1.x) := by rw [hbx]; ring
  have hby' : b.y = seg.p1.y + t * (seg.p2.y - seg.p1.y) := by rw [hby]; ring
  rw [vecCmpAlongSeg_isLE_iff] at hab hba
  have hst : s = t := by
    by_cases hX :
        (if seg.p2.x - seg.p1.x < 0 then -(seg.p2.x - seg.p1.x)
         else seg.p2.x - seg.p1.x)
          ≥ (if seg.p2.y - seg.p1.y < 0 then -(seg.p2.y - seg.p1.y)
             else seg.p2.y - seg.p1.y)
    · rw [if_pos hX] at hab hba
      have hdx_ne : seg.p2.x - seg.p1.x ≠ 0 := by
        intro hdx0
        have hxbranch : (if seg.p2.x - seg.p1.x < 0 then -(seg.p2.x - seg.p1.x)
                          else seg.p2.x - seg.p1.x) = 0 := by
          rw [hdx0]; simp
        rw [hxbranch] at hX
        have hybranch_nonneg :
            (if seg.p2.y - seg.p1.y < 0 then -(seg.p2.y - seg.p1.y)
             else seg.p2.y - seg.p1.y) ≥ 0 := by
          by_cases hdy : seg.p2.y - seg.p1.y < 0
          · rw [if_pos hdy]; linarith
          · rw [if_neg hdy]; linarith
        have hy_eq : (if seg.p2.y - seg.p1.y < 0 then -(seg.p2.y - seg.p1.y)
                          else seg.p2.y - seg.p1.y) = 0 := le_antisymm hX hybranch_nonneg
        have hdy_eq : seg.p2.y - seg.p1.y = 0 := by
          by_cases hdy : seg.p2.y - seg.p1.y < 0
          · rw [if_pos hdy] at hy_eq; linarith
          · rw [if_neg hdy] at hy_eq; exact hy_eq
        have : seg.p1 = seg.p2 := by
          ext
          · linarith
          · linarith
        exact h_seg_nondeg this
      by_cases hdx_pos : seg.p2.x - seg.p1.x ≥ 0
      · rw [if_pos hdx_pos] at hab hba
        have hxeq : a.x = b.x := le_antisymm hab hba
        rw [hax', hbx'] at hxeq
        have : s * (seg.p2.x - seg.p1.x) = t * (seg.p2.x - seg.p1.x) := by linarith
        exact mul_right_cancel₀ hdx_ne this
      · rw [if_neg hdx_pos] at hab hba
        have hxeq : b.x = a.x := le_antisymm hab hba
        rw [hax', hbx'] at hxeq
        have : t * (seg.p2.x - seg.p1.x) = s * (seg.p2.x - seg.p1.x) := by linarith
        exact (mul_right_cancel₀ hdx_ne this).symm
    · rw [if_neg hX] at hab hba
      push_neg at hX
      have hdy_ne : seg.p2.y - seg.p1.y ≠ 0 := by
        intro hdy0
        have hybranch : (if seg.p2.y - seg.p1.y < 0 then -(seg.p2.y - seg.p1.y)
                          else seg.p2.y - seg.p1.y) = 0 := by
          rw [hdy0]; simp
        rw [hybranch] at hX
        have hxbranch_nonneg :
            (if seg.p2.x - seg.p1.x < 0 then -(seg.p2.x - seg.p1.x)
             else seg.p2.x - seg.p1.x) ≥ 0 := by
          by_cases hdx : seg.p2.x - seg.p1.x < 0
          · rw [if_pos hdx]; linarith
          · rw [if_neg hdx]; linarith
        linarith
      by_cases hdy_pos : seg.p2.y - seg.p1.y ≥ 0
      · rw [if_pos hdy_pos] at hab hba
        have hyeq : a.y = b.y := le_antisymm hab hba
        rw [hay', hby'] at hyeq
        have : s * (seg.p2.y - seg.p1.y) = t * (seg.p2.y - seg.p1.y) := by linarith
        exact mul_right_cancel₀ hdy_ne this
      · rw [if_neg hdy_pos] at hab hba
        have hyeq : b.y = a.y := le_antisymm hab hba
        rw [hay', hby'] at hyeq
        have : t * (seg.p2.y - seg.p1.y) = s * (seg.p2.y - seg.p1.y) := by linarith
        exact (mul_right_cancel₀ hdy_ne this).symm
  ext
  · rw [hax', hbx', hst]
  · rw [hay', hby', hst]


/-- The result of `sortAlongSeg` is sorted by the comparator. -/
private theorem sortAlongSeg_pairwise_isLE (p1 p2 : Vector2D) (l : List Vector2D) :
    (sortAlongSeg p1 p2 l).Pairwise
      (fun a b => (vecCmpAlongSeg p1 p2 a b).isLE = true) := by
  unfold sortAlongSeg
  exact List.sorted_mergeSort
    (le := fun a b => (vecCmpAlongSeg p1 p2 a b).isLE)
    (fun a b c hab hbc => vecCmpAlongSeg_isLE_trans p1 p2 a b c hab hbc)
    (fun a b => by
      rcases vecCmpAlongSeg_isLE_total p1 p2 a b with h | h
      · simp [h]
      · simp [h])
    l

/-- After `dedupConsec`, a sorted list with antisymmetric comparator on its
    elements is `Nodup`. -/
private theorem dedupConsec_nodup_of_sorted_antisymm
    {α : Type*} [DecidableEq α] (le : α → α → Bool) :
    ∀ (l : List α),
      l.Pairwise (fun a b => le a b = true) →
      (∀ a ∈ l, ∀ b ∈ l, le a b = true → le b a = true → a = b) →
      (dedupConsec l).Nodup
  | [], _, _ => by simp [dedupConsec]
  | [a], _, _ => by simp [dedupConsec]
  | a :: b :: rest, h_sorted, h_antisymm => by
    simp only [dedupConsec]
    have h_sorted_tail : (b :: rest).Pairwise (fun a b => le a b = true) :=
      (List.pairwise_cons.mp h_sorted).2
    have h_antisymm_tail :
        ∀ x ∈ (b :: rest), ∀ y ∈ (b :: rest),
            le x y = true → le y x = true → x = y := fun x hx y hy =>
      h_antisymm x (List.mem_cons_of_mem _ hx) y (List.mem_cons_of_mem _ hy)
    have ih := dedupConsec_nodup_of_sorted_antisymm le (b :: rest)
                  h_sorted_tail h_antisymm_tail
    by_cases hab : a = b
    · rw [if_pos hab]; exact ih
    · rw [if_neg hab]
      have h_a_le_all : ∀ x ∈ (b :: rest), le a x = true :=
        fun x hx => (List.pairwise_cons.mp h_sorted).1 x hx
      have h_b_le_rest : ∀ x ∈ rest, le b x = true :=
        fun x hx => (List.pairwise_cons.mp h_sorted_tail).1 x hx
      have ha_notin : a ∉ dedupConsec (b :: rest) := by
        intro h_in
        have h_in' : a ∈ b :: rest := dedupConsec_subset _ a h_in
        rcases List.mem_cons.mp h_in' with hab_eq | har
        · exact hab hab_eq
        · have h_le_ba : le b a = true := h_b_le_rest a har
          have h_le_ab : le a b = true :=
            h_a_le_all b (List.mem_cons_self _ _)
          have ha_in_orig : a ∈ a :: b :: rest := (List.mem_cons_self _ _)
          have hb_in_orig : b ∈ a :: b :: rest :=
            List.mem_cons_of_mem _ (List.mem_cons_self _ _)
          exact hab (h_antisymm a ha_in_orig b hb_in_orig h_le_ab h_le_ba)
      exact List.nodup_cons.mpr ⟨ha_notin, ih⟩

/-- `dedupConsec` preserves `Pairwise`. -/
private theorem dedupConsec_pairwise {α : Type*} [DecidableEq α]
    {R : α → α → Prop} : ∀ (l : List α), l.Pairwise R → (dedupConsec l).Pairwise R
  | [], _ => by simp [dedupConsec]
  | [a], h => h
  | a :: b :: rest, h => by
    simp only [dedupConsec]
    have h_tail : (b :: rest).Pairwise R := (List.pairwise_cons.mp h).2
    by_cases hab : a = b
    · rw [if_pos hab]; exact dedupConsec_pairwise (b :: rest) h_tail
    · rw [if_neg hab]
      refine List.pairwise_cons.mpr ⟨?_, dedupConsec_pairwise (b :: rest) h_tail⟩
      intro x hx
      have hx_orig : x ∈ b :: rest := dedupConsec_subset _ x hx
      exact (List.pairwise_cons.mp h).1 x hx_orig

/-- Two `Nodup` lists with the same set of elements are permutations of each
    other. -/
private theorem perm_of_nodup_same_mem {α : Type*} [DecidableEq α]
    (l1 l2 : List α) (h1 : l1.Nodup) (h2 : l2.Nodup)
    (h_mem : ∀ a, a ∈ l1 ↔ a ∈ l2) : List.Perm l1 l2 := by
  rw [List.perm_iff_count]
  intro a
  by_cases ha1 : a ∈ l1
  · have ha2 : a ∈ l2 := (h_mem a).mp ha1
    rw [List.count_eq_one_of_mem h1 ha1, List.count_eq_one_of_mem h2 ha2]
  · have ha2 : a ∉ l2 := fun h => ha1 ((h_mem a).mpr h)
    rw [List.count_eq_zero_of_not_mem ha1, List.count_eq_zero_of_not_mem ha2]

/-! ### Main canonical-form theorem -/

/-- If two point lists `pts1`, `pts2` have the same set of elements (each
    element of either list lies on `seg`), then `splitSegmentAtPoints seg pts1`
    and `splitSegmentAtPoints seg pts2` are EQUAL (and a fortiori produce the
    same list of endpoint multisets).

    The hypothesis `seg.p1 ≠ seg.p2` ensures the comparator induces a strict
    total order on `seg.toSet`. -/
private theorem splitSegmentAtPoints_perm_iff_collinear
    (seg : LineSegment) (pts1 pts2 : List Vector2D)
    (h_seg_nondeg : seg.p1 ≠ seg.p2)
    (h_on_seg1 : ∀ p ∈ pts1, p ∈ seg.toSet)
    (h_on_seg2 : ∀ p ∈ pts2, p ∈ seg.toSet)
    (h_pts_eq : ∀ p, p ∈ pts1 ↔ p ∈ pts2) :
    List.Perm ((splitSegmentAtPoints seg pts1).map LineSegment.toEndpointsMultiset)
              ((splitSegmentAtPoints seg pts2).map LineSegment.toEndpointsMultiset) := by
  -- Reduce to equality of the deduped sorted lists.
  suffices h : dedupConsec (sortAlongSeg seg.p1 seg.p2 (seg.p1 :: seg.p2 :: pts1))
             = dedupConsec (sortAlongSeg seg.p1 seg.p2 (seg.p1 :: seg.p2 :: pts2)) by
    have hsplit : splitSegmentAtPoints seg pts1 = splitSegmentAtPoints seg pts2 := by
      show ((dedupConsec (sortAlongSeg seg.p1 seg.p2 (seg.p1 :: seg.p2 :: pts1))).zip
            (dedupConsec (sortAlongSeg seg.p1 seg.p2 (seg.p1 :: seg.p2 :: pts1))).tail).map
            (fun (ab : Vector2D × Vector2D) => (⟨ab.1, ab.2⟩ : LineSegment)) =
            ((dedupConsec (sortAlongSeg seg.p1 seg.p2 (seg.p1 :: seg.p2 :: pts2))).zip
            (dedupConsec (sortAlongSeg seg.p1 seg.p2 (seg.p1 :: seg.p2 :: pts2))).tail).map
            (fun (ab : Vector2D × Vector2D) => (⟨ab.1, ab.2⟩ : LineSegment))
      rw [h]
    rw [hsplit]
  set L1 := sortAlongSeg seg.p1 seg.p2 (seg.p1 :: seg.p2 :: pts1) with hL1
  set L2 := sortAlongSeg seg.p1 seg.p2 (seg.p1 :: seg.p2 :: pts2) with hL2
  have hPw1 : L1.Pairwise (fun a b => (vecCmpAlongSeg seg.p1 seg.p2 a b).isLE = true) := by
    rw [hL1]; exact sortAlongSeg_pairwise_isLE _ _ _
  have hPw2 : L2.Pairwise (fun a b => (vecCmpAlongSeg seg.p1 seg.p2 a b).isLE = true) := by
    rw [hL2]; exact sortAlongSeg_pairwise_isLE _ _ _
  have hPwD1 : (dedupConsec L1).Pairwise
                  (fun a b => (vecCmpAlongSeg seg.p1 seg.p2 a b).isLE = true) :=
    dedupConsec_pairwise L1 hPw1
  have hPwD2 : (dedupConsec L2).Pairwise
                  (fun a b => (vecCmpAlongSeg seg.p1 seg.p2 a b).isLE = true) :=
    dedupConsec_pairwise L2 hPw2
  have hMemL1 : ∀ x, x ∈ L1 ↔ x ∈ seg.p1 :: seg.p2 :: pts1 := by
    intro x; rw [hL1]; exact sortAlongSeg_mem_iff _ _ _ _
  have hMemL2 : ∀ x, x ∈ L2 ↔ x ∈ seg.p1 :: seg.p2 :: pts2 := by
    intro x; rw [hL2]; exact sortAlongSeg_mem_iff _ _ _ _
  have hMemD1 : ∀ x, x ∈ dedupConsec L1 ↔ x ∈ seg.p1 :: seg.p2 :: pts1 := fun x =>
    Iff.trans (dedupConsec_mem_iff L1 x) (hMemL1 x)
  have hMemD2 : ∀ x, x ∈ dedupConsec L2 ↔ x ∈ seg.p1 :: seg.p2 :: pts2 := fun x =>
    Iff.trans (dedupConsec_mem_iff L2 x) (hMemL2 x)
  have hMemSame : ∀ x, x ∈ dedupConsec L1 ↔ x ∈ dedupConsec L2 := by
    intro x
    rw [hMemD1 x, hMemD2 x]
    simp only [List.mem_cons]
    constructor
    · rintro (h | h | h)
      · exact Or.inl h
      · exact Or.inr (Or.inl h)
      · exact Or.inr (Or.inr ((h_pts_eq x).mp h))
    · rintro (h | h | h)
      · exact Or.inl h
      · exact Or.inr (Or.inl h)
      · exact Or.inr (Or.inr ((h_pts_eq x).mpr h))
  have hp1_seg : seg.p1 ∈ seg.toSet :=
    ⟨0, by norm_num, by norm_num, by ring, by ring⟩
  have hp2_seg : seg.p2 ∈ seg.toSet :=
    ⟨1, by norm_num, by norm_num, by ring, by ring⟩
  have hAntisymmL1 :
      ∀ a ∈ L1, ∀ b ∈ L1,
        (vecCmpAlongSeg seg.p1 seg.p2 a b).isLE = true →
        (vecCmpAlongSeg seg.p1 seg.p2 b a).isLE = true → a = b := by
    intro a ha b hb hab hba
    have ha_in : a ∈ seg.p1 :: seg.p2 :: pts1 := (hMemL1 a).mp ha
    have hb_in : b ∈ seg.p1 :: seg.p2 :: pts1 := (hMemL1 b).mp hb
    have ha_seg : a ∈ seg.toSet := by
      rcases List.mem_cons.mp ha_in with hp | hr
      · rw [hp]; exact hp1_seg
      · rcases List.mem_cons.mp hr with hp | hr2
        · rw [hp]; exact hp2_seg
        · exact h_on_seg1 a hr2
    have hb_seg : b ∈ seg.toSet := by
      rcases List.mem_cons.mp hb_in with hp | hr
      · rw [hp]; exact hp1_seg
      · rcases List.mem_cons.mp hr with hp | hr2
        · rw [hp]; exact hp2_seg
        · exact h_on_seg1 b hr2
    exact vecCmpAlongSeg_isLE_antisymm_on_seg seg a b h_seg_nondeg ha_seg hb_seg hab hba
  have hAntisymmL2 :
      ∀ a ∈ L2, ∀ b ∈ L2,
        (vecCmpAlongSeg seg.p1 seg.p2 a b).isLE = true →
        (vecCmpAlongSeg seg.p1 seg.p2 b a).isLE = true → a = b := by
    intro a ha b hb hab hba
    have ha_in : a ∈ seg.p1 :: seg.p2 :: pts2 := (hMemL2 a).mp ha
    have hb_in : b ∈ seg.p1 :: seg.p2 :: pts2 := (hMemL2 b).mp hb
    have ha_seg : a ∈ seg.toSet := by
      rcases List.mem_cons.mp ha_in with hp | hr
      · rw [hp]; exact hp1_seg
      · rcases List.mem_cons.mp hr with hp | hr2
        · rw [hp]; exact hp2_seg
        · exact h_on_seg2 a hr2
    have hb_seg : b ∈ seg.toSet := by
      rcases List.mem_cons.mp hb_in with hp | hr
      · rw [hp]; exact hp1_seg
      · rcases List.mem_cons.mp hr with hp | hr2
        · rw [hp]; exact hp2_seg
        · exact h_on_seg2 b hr2
    exact vecCmpAlongSeg_isLE_antisymm_on_seg seg a b h_seg_nondeg ha_seg hb_seg hab hba
  have hNodup1 : (dedupConsec L1).Nodup :=
    dedupConsec_nodup_of_sorted_antisymm _ L1 hPw1 hAntisymmL1
  have hNodup2 : (dedupConsec L2).Nodup :=
    dedupConsec_nodup_of_sorted_antisymm _ L2 hPw2 hAntisymmL2
  have hPerm : List.Perm (dedupConsec L1) (dedupConsec L2) :=
    perm_of_nodup_same_mem _ _ hNodup1 hNodup2 hMemSame
  have hAntisymmD :
      ∀ a b, a ∈ dedupConsec L1 → b ∈ dedupConsec L2 →
        (vecCmpAlongSeg seg.p1 seg.p2 a b).isLE = true →
        (vecCmpAlongSeg seg.p1 seg.p2 b a).isLE = true → a = b := by
    intro a b ha hb hab hba
    have ha_in : a ∈ seg.p1 :: seg.p2 :: pts1 := (hMemD1 a).mp ha
    have hb_in : b ∈ seg.p1 :: seg.p2 :: pts2 := (hMemD2 b).mp hb
    have ha_seg : a ∈ seg.toSet := by
      rcases List.mem_cons.mp ha_in with hp | hr
      · rw [hp]; exact hp1_seg
      · rcases List.mem_cons.mp hr with hp | hr2
        · rw [hp]; exact hp2_seg
        · exact h_on_seg1 a hr2
    have hb_seg : b ∈ seg.toSet := by
      rcases List.mem_cons.mp hb_in with hp | hr
      · rw [hp]; exact hp1_seg
      · rcases List.mem_cons.mp hr with hp | hr2
        · rw [hp]; exact hp2_seg
        · exact h_on_seg2 b hr2
    exact vecCmpAlongSeg_isLE_antisymm_on_seg seg a b h_seg_nondeg ha_seg hb_seg hab hba
  exact perm_eq_of_pairwise_local hAntisymmD hPwD1 hPwD2 hPerm

/-- The endpoints of a sub-segment from `splitSegmentAtPoints seg pts` belong to
    `seg.p1 :: seg.p2 :: pts`. -/
private theorem splitSegmentAtPoints_endpoints_mem
    (seg : LineSegment) (pts : List Vector2D)
    (rs : LineSegment) (h_rs : rs ∈ splitSegmentAtPoints seg pts) :
    rs.p1 ∈ seg.p1 :: seg.p2 :: pts ∧ rs.p2 ∈ seg.p1 :: seg.p2 :: pts := by
  unfold splitSegmentAtPoints at h_rs
  simp only [List.mem_map] at h_rs
  obtain ⟨⟨a, b⟩, hab_mem, hab_eq⟩ := h_rs
  -- rs = ⟨a, b⟩
  have hrs1 : rs.p1 = a := by rw [← hab_eq]
  have hrs2 : rs.p2 = b := by rw [← hab_eq]
  -- (a, b) ∈ deduped.zip deduped.tail
  have ha_in_deduped : a ∈ dedupConsec (sortAlongSeg seg.p1 seg.p2 (seg.p1 :: seg.p2 :: pts)) := by
    have := List.of_mem_zip hab_mem
    exact this.1
  have hb_in_deduped : b ∈ dedupConsec (sortAlongSeg seg.p1 seg.p2 (seg.p1 :: seg.p2 :: pts)) := by
    have := List.of_mem_zip hab_mem
    exact List.mem_of_mem_tail this.2
  have ha_in_sorted : a ∈ sortAlongSeg seg.p1 seg.p2 (seg.p1 :: seg.p2 :: pts) :=
    dedupConsec_subset _ a ha_in_deduped
  have hb_in_sorted : b ∈ sortAlongSeg seg.p1 seg.p2 (seg.p1 :: seg.p2 :: pts) :=
    dedupConsec_subset _ b hb_in_deduped
  refine ⟨?_, ?_⟩
  · rw [hrs1]; exact (sortAlongSeg_mem_iff _ _ _ _).mp ha_in_sorted
  · rw [hrs2]; exact (sortAlongSeg_mem_iff _ _ _ _).mp hb_in_sorted

/-- A sub-segment from `splitSegmentAtPoints seg pts`, with all `pts` lying on
    `seg`, is itself contained in `seg.toSet`. -/
private theorem splitSegmentAtPoints_toSet_subset
    (seg : LineSegment) (pts : List Vector2D)
    (h_pts : ∀ p ∈ pts, p ∈ seg.toSet)
    (rs : LineSegment) (h_rs : rs ∈ splitSegmentAtPoints seg pts) :
    rs.toSet ⊆ seg.toSet := by
  -- The endpoints of rs are in seg.p1 :: seg.p2 :: pts, all of which are in seg.toSet.
  obtain ⟨h1, h2⟩ := splitSegmentAtPoints_endpoints_mem seg pts rs h_rs
  have hp1 : seg.p1 ∈ seg.toSet := ⟨0, by norm_num, by norm_num, by ring, by ring⟩
  have hp2 : seg.p2 ∈ seg.toSet := ⟨1, by norm_num, by norm_num, by ring, by ring⟩
  have hrs_p1_seg : rs.p1 ∈ seg.toSet := by
    simp only [List.mem_cons] at h1
    rcases h1 with h | h | h
    · rw [h]; exact hp1
    · rw [h]; exact hp2
    · exact h_pts _ h
  have hrs_p2_seg : rs.p2 ∈ seg.toSet := by
    simp only [List.mem_cons] at h2
    rcases h2 with h | h | h
    · rw [h]; exact hp1
    · rw [h]; exact hp2
    · exact h_pts _ h
  -- Now show rs.toSet ⊆ seg.toSet via convex combination.
  intro q ⟨t, ht0, ht1, hqx, hqy⟩
  obtain ⟨s1, hs1_0, hs1_1, hp1x, hp1y⟩ := hrs_p1_seg
  obtain ⟨s2, hs2_0, hs2_1, hp2x, hp2y⟩ := hrs_p2_seg
  -- q.x = (1-t) * rs.p1.x + t * rs.p2.x
  --     = (1-t) * ((1-s1) seg.p1.x + s1 seg.p2.x) + t * ((1-s2) seg.p1.x + s2 seg.p2.x)
  --     = (1 - ((1-t) s1 + t s2)) seg.p1.x + ((1-t) s1 + t s2) seg.p2.x
  refine ⟨(1 - t) * s1 + t * s2, ?_, ?_, ?_, ?_⟩
  · have h1 : 0 ≤ (1 - t) * s1 := mul_nonneg (by linarith) hs1_0
    have h2 : 0 ≤ t * s2 := mul_nonneg ht0 hs2_0
    linarith
  · have h1 : (1 - t) * s1 ≤ (1 - t) * 1 := by
      apply mul_le_mul_of_nonneg_left hs1_1 (by linarith)
    have h2 : t * s2 ≤ t * 1 := mul_le_mul_of_nonneg_left hs2_1 ht0
    linarith
  · rw [hqx, hp1x, hp2x]; ring
  · rw [hqy, hp1y, hp2y]; ring

/-- The refinement points for a non-degenerate segment all lie on that segment. -/
private theorem refinementPointsForSegment_mem_toSet
    (seg : LineSegment) (m other : Multipolygon) (h_ne : seg.p1 ≠ seg.p2) :
    ∀ p ∈ refinementPointsForSegment seg m other, p ∈ seg.toSet := by
  intro p hp
  unfold refinementPointsForSegment at hp
  simp only [List.mem_append] at hp
  rcases hp with hpc | hpv
  · -- p is a crossing
    simp only [List.mem_filterMap] at hpc
    obtain ⟨seg2, _, hint⟩ := hpc
    rcases segSegIntersect_correct seg seg2 with ⟨pt, hpt_eq, hpt_seg, _⟩ | hnone
    · rw [hpt_eq] at hint
      rw [Option.some_inj] at hint
      rw [hint] at hpt_seg; exact hpt_seg
    · rw [hint] at hnone; exact absurd hnone (by simp)
  · -- p is a self-vertex on seg
    simp only [List.mem_filter, Bool.and_eq_true, decide_eq_true_eq] at hpv
    obtain ⟨_, ⟨⟨h_on, _⟩, _⟩⟩ := hpv
    exact (pointOnSegmentBool_iff p seg.p1 seg.p2 h_ne).mp h_on

/-- Crossings are exactly the rational intersection points returned by
    `segSegIntersect`. If `q` is a transverse crossing of `seg` with some
    `m2.segment`, then `q` is in the crossings list. -/
private theorem mem_crossings_of_segSegIntersect
    (seg : LineSegment) (m2 : Multipolygon) (seg2 : LineSegment) (q : Vector2D)
    (h_seg2 : seg2 ∈ m2.segments)
    (h_int : segSegIntersect seg seg2 = some q) :
    q ∈ m2.segments.filterMap (segSegIntersect seg) := by
  simp only [List.mem_filterMap]
  exact ⟨seg2, h_seg2, h_int⟩

/-- If `seg.p1 ≠ seg.p2` and `q ∈ seg.toSet`, then `pointOnSegmentBool q seg.p1 seg.p2 = true`. -/
private theorem pointOnSegmentBool_of_mem_toSet
    (seg : LineSegment) (q : Vector2D) (h_ne : seg.p1 ≠ seg.p2)
    (hq : q ∈ seg.toSet) :
    pointOnSegmentBool q seg.p1 seg.p2 = true :=
  (pointOnSegmentBool_iff q seg.p1 seg.p2 h_ne).mpr hq

/-- **Structural property** (packaged as a hypothesis; discharged below by
    `splitStructuralProperty_holds`): Within a refined sub-segment, no
    point of the original split-points list lies in `rs.toSet` other than the
    endpoints `rs.p1` and `rs.p2`. This is the geometric "consecutivity"
    property of `splitSegmentAtPoints`. -/
private def splitStructuralProperty (m1 m2 : Multipolygon) : Prop :=
  ∀ seg ∈ m1.segments,
    ∀ rs ∈ splitSegmentAtPoints seg (refinementPointsForSegment seg m1 m2),
      ∀ q ∈ (seg.p1 :: seg.p2 :: refinementPointsForSegment seg m1 m2),
        q ∈ rs.toSet → q = rs.p1 ∨ q = rs.p2

/-! ### Discharging `splitStructuralProperty` -/

/-- For `a, b ∈ seg.toSet` and `q ∈ (LineSegment.mk a b).toSet`, the parameter
    `paramOnSeg seg q` is the corresponding affine combination of
    `paramOnSeg seg a` and `paramOnSeg seg b`. -/
private theorem paramOnSeg_affine_of_mem_toSet
    (seg : LineSegment) (h_nondeg : seg.p1 ≠ seg.p2)
    (a b : Vector2D) (_h_a : a ∈ seg.toSet) (_h_b : b ∈ seg.toSet)
    (q : Vector2D) (h_q : q ∈ (LineSegment.mk a b).toSet) :
    ∃ s : ℚ, 0 ≤ s ∧ s ≤ 1 ∧
      paramOnSeg seg q = (1 - s) * paramOnSeg seg a + s * paramOnSeg seg b := by
  obtain ⟨s, hs0, hs1, hqx, hqy⟩ := h_q
  refine ⟨s, hs0, hs1, ?_⟩
  by_cases hxne : seg.p2.x ≠ seg.p1.x
  · -- Use the x-formula on each side.
    have hpa : paramOnSeg seg a = (a.x - seg.p1.x) / (seg.p2.x - seg.p1.x) := by
      unfold paramOnSeg; rw [if_pos hxne]
    have hpb : paramOnSeg seg b = (b.x - seg.p1.x) / (seg.p2.x - seg.p1.x) := by
      unfold paramOnSeg; rw [if_pos hxne]
    have hpq : paramOnSeg seg q = (q.x - seg.p1.x) / (seg.p2.x - seg.p1.x) := by
      unfold paramOnSeg; rw [if_pos hxne]
    have hdx_ne : seg.p2.x - seg.p1.x ≠ 0 := sub_ne_zero.mpr hxne
    rw [hpa, hpb, hpq]
    have hkey : q.x - seg.p1.x = (1 - s) * (a.x - seg.p1.x) + s * (b.x - seg.p1.x) := by
      show q.x - seg.p1.x = (1 - s) * (a.x - seg.p1.x) + s * (b.x - seg.p1.x)
      rw [hqx]; ring
    rw [hkey]
    field_simp
  · push_neg at hxne
    have hyne : seg.p2.y ≠ seg.p1.y := by
      intro hye
      apply h_nondeg
      ext
      · exact hxne.symm
      · exact hye.symm
    have hxne' : ¬ seg.p2.x ≠ seg.p1.x := by push_neg; exact hxne
    have hpa : paramOnSeg seg a = (a.y - seg.p1.y) / (seg.p2.y - seg.p1.y) := by
      unfold paramOnSeg; rw [if_neg hxne']
    have hpb : paramOnSeg seg b = (b.y - seg.p1.y) / (seg.p2.y - seg.p1.y) := by
      unfold paramOnSeg; rw [if_neg hxne']
    have hpq : paramOnSeg seg q = (q.y - seg.p1.y) / (seg.p2.y - seg.p1.y) := by
      unfold paramOnSeg; rw [if_neg hxne']
    have hdy_ne : seg.p2.y - seg.p1.y ≠ 0 := sub_ne_zero.mpr hyne
    rw [hpa, hpb, hpq]
    have hkey : q.y - seg.p1.y = (1 - s) * (a.y - seg.p1.y) + s * (b.y - seg.p1.y) := by
      show q.y - seg.p1.y = (1 - s) * (a.y - seg.p1.y) + s * (b.y - seg.p1.y)
      rw [hqy]; ring
    rw [hkey]
    field_simp

/-- For `a, b ∈ seg.toSet` with `paramOnSeg seg a ≤ paramOnSeg seg b`, every
    point `q` of `(LineSegment.mk a b).toSet` has its parameter in
    `[paramOnSeg seg a, paramOnSeg seg b]`. -/
private theorem paramOnSeg_in_range_of_mem_subSeg
    (seg : LineSegment) (h_nondeg : seg.p1 ≠ seg.p2)
    (a b : Vector2D) (h_a : a ∈ seg.toSet) (h_b : b ∈ seg.toSet)
    (h_le : paramOnSeg seg a ≤ paramOnSeg seg b)
    (q : Vector2D) (h_q : q ∈ (LineSegment.mk a b).toSet) :
    paramOnSeg seg a ≤ paramOnSeg seg q ∧ paramOnSeg seg q ≤ paramOnSeg seg b := by
  obtain ⟨s, hs0, hs1, ht_eq⟩ := paramOnSeg_affine_of_mem_toSet seg h_nondeg a b h_a h_b q h_q
  set ta := paramOnSeg seg a
  set tb := paramOnSeg seg b
  set tq := paramOnSeg seg q
  -- tq = (1-s) * ta + s * tb = ta + s * (tb - ta)
  have h1 : tq = ta + s * (tb - ta) := by rw [ht_eq]; ring
  refine ⟨?_, ?_⟩
  · have hs_nn : 0 ≤ s * (tb - ta) := mul_nonneg hs0 (by linarith)
    linarith
  · have hs_le : s * (tb - ta) ≤ 1 * (tb - ta) :=
      mul_le_mul_of_nonneg_right hs1 (by linarith)
    linarith

/-- Sub-segments from `splitSegmentAtPoints` lie inside `seg.toSet` (when all
    `pts` are on `seg`); the endpoints of such a sub-segment are also in
    `seg.toSet`. We extract the latter as a small helper. -/
private theorem splitSegmentAtPoints_endpoints_on_seg
    (seg : LineSegment) (pts : List Vector2D)
    (h_pts : ∀ p ∈ pts, p ∈ seg.toSet)
    (rs : LineSegment) (h_rs : rs ∈ splitSegmentAtPoints seg pts) :
    rs.p1 ∈ seg.toSet ∧ rs.p2 ∈ seg.toSet := by
  obtain ⟨h1, h2⟩ := splitSegmentAtPoints_endpoints_mem seg pts rs h_rs
  have hp1 : seg.p1 ∈ seg.toSet := ⟨0, by norm_num, by norm_num, by ring, by ring⟩
  have hp2 : seg.p2 ∈ seg.toSet := ⟨1, by norm_num, by norm_num, by ring, by ring⟩
  refine ⟨?_, ?_⟩
  · simp only [List.mem_cons] at h1
    rcases h1 with h | h | h
    · rw [h]; exact hp1
    · rw [h]; exact hp2
    · exact h_pts _ h
  · simp only [List.mem_cons] at h2
    rcases h2 with h | h | h
    · rw [h]; exact hp1
    · rw [h]; exact hp2
    · exact h_pts _ h

/-- The result of `sortAlongSeg` followed by `dedupConsec`, restricted to
    points of `seg`, has its `paramOnSeg` values strictly increasing. -/
private theorem dedupConsec_sortAlongSeg_pairwise_strict
    (seg : LineSegment) (h_nondeg : seg.p1 ≠ seg.p2)
    (l : List Vector2D) (h_l : ∀ p ∈ l, p ∈ seg.toSet) :
    let L := dedupConsec (sortAlongSeg seg.p1 seg.p2 l)
    L.Pairwise (fun a b => paramOnSeg seg a < paramOnSeg seg b) := by
  intro L
  set Lsorted := sortAlongSeg seg.p1 seg.p2 l with hLsorted_def
  have h_l_sorted : ∀ p ∈ Lsorted, p ∈ seg.toSet := by
    intro p hp
    rw [hLsorted_def, sortAlongSeg_mem_iff] at hp
    exact h_l p hp
  have h_l_dedup : ∀ p ∈ L, p ∈ seg.toSet := by
    intro p hp
    have hp_sorted : p ∈ Lsorted := dedupConsec_subset _ p hp
    exact h_l_sorted p hp_sorted
  have hPw_sorted : Lsorted.Pairwise
      (fun a b => (vecCmpAlongSeg seg.p1 seg.p2 a b).isLE = true) := by
    rw [hLsorted_def]; exact sortAlongSeg_pairwise_isLE _ _ _
  have hPw_dedup : L.Pairwise
      (fun a b => (vecCmpAlongSeg seg.p1 seg.p2 a b).isLE = true) :=
    dedupConsec_pairwise Lsorted hPw_sorted
  -- Antisymmetry: convert sorted+antisymm to Nodup.
  have hAntisymm : ∀ a ∈ Lsorted, ∀ b ∈ Lsorted,
        (vecCmpAlongSeg seg.p1 seg.p2 a b).isLE = true →
        (vecCmpAlongSeg seg.p1 seg.p2 b a).isLE = true → a = b := by
    intro a ha b hb hab hba
    exact vecCmpAlongSeg_isLE_antisymm_on_seg seg a b h_nondeg
      (h_l_sorted a ha) (h_l_sorted b hb) hab hba
  have hNodup : L.Nodup :=
    dedupConsec_nodup_of_sorted_antisymm _ Lsorted hPw_sorted hAntisymm
  -- Combine pairwise + nodup to get strict pairwise on paramOnSeg.
  have hNe : L.Pairwise (fun a b => a ≠ b) := hNodup
  -- Combine the two Pairwise relations.
  have hAnd : L.Pairwise (fun a b =>
      (vecCmpAlongSeg seg.p1 seg.p2 a b).isLE = true ∧ a ≠ b) :=
    hPw_dedup.and hNe
  refine hAnd.imp_of_mem ?_
  rintro a b ha hb ⟨hab_le, hab_ne⟩
  -- Convert isLE on vecCmpAlongSeg to ≤ on paramOnSeg.
  have ha_seg : a ∈ seg.toSet := h_l_dedup a ha
  have hb_seg : b ∈ seg.toSet := h_l_dedup b hb
  have h_cmp := vecCmpAlongSeg_eq_compare_paramOnSeg seg h_nondeg ha_seg hb_seg
  rw [h_cmp] at hab_le
  have hab_param : paramOnSeg seg a ≤ paramOnSeg seg b :=
    (rat_compare_isLE_iff _ _).mp hab_le
  rcases lt_or_eq_of_le hab_param with hlt | heq
  · exact hlt
  · exfalso
    exact hab_ne (paramOnSeg_injective seg h_nondeg ha_seg hb_seg heq)

/-- Pairwise + zip-consecutive: from a strictly-pairwise list, consecutive
    pairs satisfy the relation. -/
private theorem pairwise_zip_consecutive_param
    (seg : LineSegment) (L : List Vector2D)
    (hPw : L.Pairwise (fun a b => paramOnSeg seg a < paramOnSeg seg b))
    (a b : Vector2D) (hab : (a, b) ∈ L.zip L.tail) :
    paramOnSeg seg a < paramOnSeg seg b := by
  induction L generalizing a b with
  | nil => simp at hab
  | cons head tail ih =>
    cases htail : tail with
    | nil =>
      rw [htail] at hab
      simp at hab
    | cons h2 rest =>
      rw [htail] at hab hPw ih
      -- (a, b) ∈ (head :: h2 :: rest).zip (h2 :: rest)
      --       = (head, h2) :: (h2 :: rest).zip rest
      rw [show (head :: h2 :: rest).zip (head :: h2 :: rest).tail =
            (head, h2) :: (h2 :: rest).zip rest from rfl] at hab
      rcases List.mem_cons.mp hab with hab_eq | hab_tail
      · have ha_eq : a = head := (Prod.mk.inj hab_eq).1
        have hb_eq : b = h2 := (Prod.mk.inj hab_eq).2
        rw [ha_eq, hb_eq]
        exact (List.pairwise_cons.mp hPw).1 h2 (List.mem_cons_self _ _)
      · have hab_zip : (a, b) ∈ (h2 :: rest).zip (h2 :: rest).tail := hab_tail
        have hPw_tail : (h2 :: rest).Pairwise
            (fun a b => paramOnSeg seg a < paramOnSeg seg b) :=
          (List.pairwise_cons.mp hPw).2
        exact ih hPw_tail a b hab_zip

/-- For a list `L` of points on `seg` which is `Pairwise` strictly increasing
    in `paramOnSeg seg`, given a consecutive pair `(a, b) ∈ L.zip L.tail`,
    every `q ∈ L` lying on the sub-segment `⟨a, b⟩` must equal `a` or `b`. -/
private theorem mem_consecutive_subSeg_endpoint_of_mem_strict
    (seg : LineSegment) (h_nondeg : seg.p1 ≠ seg.p2)
    (L : List Vector2D)
    (h_on_seg : ∀ p ∈ L, p ∈ seg.toSet)
    (hPw : L.Pairwise (fun a b => paramOnSeg seg a < paramOnSeg seg b))
    (a b : Vector2D) (hab : (a, b) ∈ L.zip L.tail)
    (q : Vector2D) (hq_mem : q ∈ L) (hq_ab : q ∈ (LineSegment.mk a b).toSet) :
    q = a ∨ q = b := by
  induction L generalizing a b q with
  | nil => simp at hab
  | cons head tail ih =>
    cases htail : tail with
    | nil =>
      rw [htail] at hab
      simp at hab
    | cons h2 rest =>
      rw [htail] at hab h_on_seg hPw hq_mem ih
      rw [show (head :: h2 :: rest).zip (head :: h2 :: rest).tail =
            (head, h2) :: (h2 :: rest).zip rest from rfl] at hab
      rcases List.mem_cons.mp hab with hab_eq | hab_tail
      · -- Case: (a, b) = (head, h2).
        have ha_eq : a = head := (Prod.mk.inj hab_eq).1
        have hb_eq : b = h2 := (Prod.mk.inj hab_eq).2
        rcases List.mem_cons.mp hq_mem with hq_head | hq_tail
        · left; rw [ha_eq, hq_head]
        · rcases List.mem_cons.mp hq_tail with hq_h2 | hq_rest
          · right; rw [hb_eq, hq_h2]
          · exfalso
            have hPw_tail : (h2 :: rest).Pairwise
                (fun a b => paramOnSeg seg a < paramOnSeg seg b) :=
              (List.pairwise_cons.mp hPw).2
            have h_h2_lt_q : paramOnSeg seg h2 < paramOnSeg seg q :=
              (List.pairwise_cons.mp hPw_tail).1 q hq_rest
            have h_head_lt_h2 : paramOnSeg seg head < paramOnSeg seg h2 :=
              (List.pairwise_cons.mp hPw).1 h2 (List.mem_cons_self _ _)
            have ha_seg : a ∈ seg.toSet := by
              rw [ha_eq]; exact h_on_seg head (List.mem_cons_self _ _)
            have hb_seg : b ∈ seg.toSet := by
              rw [hb_eq]
              exact h_on_seg h2 (List.mem_cons_of_mem _ (List.mem_cons_self _ _))
            have h_ta_lt_tb : paramOnSeg seg a < paramOnSeg seg b := by
              rw [ha_eq, hb_eq]; exact h_head_lt_h2
            have h_ta_le_tb : paramOnSeg seg a ≤ paramOnSeg seg b := le_of_lt h_ta_lt_tb
            obtain ⟨_h_lo, h_hi⟩ :=
              paramOnSeg_in_range_of_mem_subSeg seg h_nondeg a b ha_seg hb_seg
                h_ta_le_tb q hq_ab
            have h_tb_eq : paramOnSeg seg b = paramOnSeg seg h2 := by rw [hb_eq]
            rw [h_tb_eq] at h_hi
            linarith
      · have hab_zip : (a, b) ∈ (h2 :: rest).zip (h2 :: rest).tail := hab_tail
        have h_on_seg_tail : ∀ p ∈ (h2 :: rest), p ∈ seg.toSet := by
          intro p hp; exact h_on_seg p (List.mem_cons_of_mem _ hp)
        have hPw_tail : (h2 :: rest).Pairwise
            (fun a b => paramOnSeg seg a < paramOnSeg seg b) :=
          (List.pairwise_cons.mp hPw).2
        rcases List.mem_cons.mp hq_mem with hq_head | hq_tail
        · exfalso
          have ha_in_tail : a ∈ (h2 :: rest) := (List.of_mem_zip hab_zip).1
          have hb_in_tail : b ∈ (h2 :: rest) := by
            have := (List.of_mem_zip hab_zip).2
            exact List.mem_of_mem_tail this
          have ha_seg : a ∈ seg.toSet := h_on_seg_tail a ha_in_tail
          have hb_seg : b ∈ seg.toSet := h_on_seg_tail b hb_in_tail
          have h_ta_lt_tb : paramOnSeg seg a < paramOnSeg seg b :=
            pairwise_zip_consecutive_param seg (h2 :: rest) hPw_tail a b hab_zip
          have h_ta_le_tb : paramOnSeg seg a ≤ paramOnSeg seg b := le_of_lt h_ta_lt_tb
          obtain ⟨h_lo, _⟩ :=
            paramOnSeg_in_range_of_mem_subSeg seg h_nondeg a b ha_seg hb_seg
              h_ta_le_tb q hq_ab
          have h_head_lt_a : paramOnSeg seg head < paramOnSeg seg a :=
            (List.pairwise_cons.mp hPw).1 a ha_in_tail
          rw [hq_head] at h_lo
          linarith
        · exact ih h_on_seg_tail hPw_tail a b hab_zip q hq_tail hq_ab

/-- Discharge of `splitStructuralProperty`: under non-degeneracy of `m1`'s
    segments, the property holds unconditionally. -/
private theorem splitStructuralProperty_holds (m1 m2 : Multipolygon)
    (h1_nondeg : ∀ s ∈ m1.segments, s.p1 ≠ s.p2) :
    splitStructuralProperty m1 m2 := by
  intro seg h_seg rs h_rs q hq_mem hq_rs
  have h_seg_ne : seg.p1 ≠ seg.p2 := h1_nondeg seg h_seg
  set pts := refinementPointsForSegment seg m1 m2 with hpts_def
  set inputList := seg.p1 :: seg.p2 :: pts with hinput_def
  -- Points on seg.
  have h_pts_on_seg : ∀ p ∈ pts, p ∈ seg.toSet :=
    refinementPointsForSegment_mem_toSet seg m1 m2 h_seg_ne
  have h_input_on_seg : ∀ p ∈ inputList, p ∈ seg.toSet := by
    intro p hp
    rcases List.mem_cons.mp hp with h | hp'
    · rw [h]; exact ⟨0, by norm_num, by norm_num, by ring, by ring⟩
    · rcases List.mem_cons.mp hp' with h | hp''
      · rw [h]; exact ⟨1, by norm_num, by norm_num, by ring, by ring⟩
      · exact h_pts_on_seg p hp''
  -- L = dedupConsec (sortAlongSeg seg.p1 seg.p2 inputList).
  set L := dedupConsec (sortAlongSeg seg.p1 seg.p2 inputList) with hL_def
  have hL_on_seg : ∀ p ∈ L, p ∈ seg.toSet := by
    intro p hp
    have hp_input : p ∈ inputList := by
      have hp_sorted : p ∈ sortAlongSeg seg.p1 seg.p2 inputList :=
        dedupConsec_subset _ p hp
      rwa [sortAlongSeg_mem_iff] at hp_sorted
    exact h_input_on_seg p hp_input
  have hL_pairwise : L.Pairwise
      (fun a b => paramOnSeg seg a < paramOnSeg seg b) :=
    dedupConsec_sortAlongSeg_pairwise_strict seg h_seg_ne inputList h_input_on_seg
  -- Decompose rs.
  unfold splitSegmentAtPoints at h_rs
  simp only [List.mem_map] at h_rs
  obtain ⟨⟨a, b⟩, hab_zip, hab_eq⟩ := h_rs
  have hrs1 : rs.p1 = a := by rw [← hab_eq]
  have hrs2 : rs.p2 = b := by rw [← hab_eq]
  have hrs_eq : rs = ⟨a, b⟩ := by rw [← hab_eq]
  -- Show q ∈ L: q ∈ inputList, hence in sorted, hence in deduped.
  have hq_L : q ∈ L := by
    have hq_sorted : q ∈ sortAlongSeg seg.p1 seg.p2 inputList := by
      rw [sortAlongSeg_mem_iff]; exact hq_mem
    exact (dedupConsec_mem_iff _ q).mpr hq_sorted
  -- Translate hq_rs : q ∈ rs.toSet to q ∈ ⟨a, b⟩.toSet.
  have hq_ab : q ∈ (LineSegment.mk a b).toSet := by rw [hrs_eq] at hq_rs; exact hq_rs
  -- Apply main lemma.
  have h_zip : (a, b) ∈ L.zip L.tail := hab_zip
  have hres := mem_consecutive_subSeg_endpoint_of_mem_strict seg h_seg_ne
    L hL_on_seg hL_pairwise a b h_zip q hq_L hq_ab
  rcases hres with h | h
  · left; rw [hrs1]; exact h
  · right; rw [hrs2]; exact h

/-! ### Connecting `iterativeSplit` with `splitSegmentAtPoints` -/

/-- For `a, b ∈ seg.toSet` with `paramOnSeg seg a ≤ paramOnSeg seg b`, every
    `q ∈ seg.toSet` whose parameter is in `[paramOnSeg seg a, paramOnSeg seg b]`
    lies on the sub-segment `⟨a, b⟩.toSet`. -/
private theorem mem_subSeg_of_paramOnSeg_in_range
    (seg : LineSegment) (h_nondeg : seg.p1 ≠ seg.p2)
    (a b : Vector2D) (h_a : a ∈ seg.toSet) (h_b : b ∈ seg.toSet)
    (h_le : paramOnSeg seg a ≤ paramOnSeg seg b)
    (q : Vector2D) (h_q_seg : q ∈ seg.toSet)
    (h_q_lo : paramOnSeg seg a ≤ paramOnSeg seg q)
    (h_q_hi : paramOnSeg seg q ≤ paramOnSeg seg b) :
    q ∈ (LineSegment.mk a b).toSet := by
  set ta := paramOnSeg seg a with hta_def
  set tb := paramOnSeg seg b with htb_def
  set tq := paramOnSeg seg q with htq_def
  obtain ⟨hax, hay, _, _⟩ := paramOnSeg_spec seg h_nondeg a h_a
  obtain ⟨hbx, hby, _, _⟩ := paramOnSeg_spec seg h_nondeg b h_b
  obtain ⟨hqx, hqy, _, _⟩ := paramOnSeg_spec seg h_nondeg q h_q_seg
  by_cases h_ab_eq : ta = tb
  · -- ta = tb means a = b. Then tq must equal both, so q = a.
    have hq_eq_ta : tq = ta := le_antisymm (h_ab_eq ▸ h_q_hi) h_q_lo
    have ha_eq_q : a = q := paramOnSeg_injective seg h_nondeg h_a h_q_seg hq_eq_ta.symm
    refine ⟨0, by norm_num, by norm_num, ?_, ?_⟩
    · rw [← ha_eq_q]; ring
    · rw [← ha_eq_q]; ring
  · -- ta ≠ tb. Define s := (tq - ta) / (tb - ta).
    have h_lt : ta < tb := lt_of_le_of_ne h_le h_ab_eq
    have h_diff_pos : tb - ta > 0 := by linarith
    set s := (tq - ta) / (tb - ta) with hs_def
    refine ⟨s, ?_, ?_, ?_, ?_⟩
    · rw [hs_def]; apply div_nonneg <;> linarith
    · rw [hs_def, div_le_one h_diff_pos]; linarith
    · rw [hax, hbx, hqx]
      have h_s_eq : s * (tb - ta) = tq - ta := by
        rw [hs_def]; field_simp
      have h_dx : (tq - ta) * (seg.p2.x - seg.p1.x) =
                  s * (tb - ta) * (seg.p2.x - seg.p1.x) := by rw [h_s_eq]
      have key : ((1 - tq) * seg.p1.x + tq * seg.p2.x) -
                 ((1 - s) * ((1 - ta) * seg.p1.x + ta * seg.p2.x)
                  + s * ((1 - tb) * seg.p1.x + tb * seg.p2.x)) =
                 (tq - ta) * (seg.p2.x - seg.p1.x)
                  - s * (tb - ta) * (seg.p2.x - seg.p1.x) := by ring
      linarith [key, h_dx]
    · rw [hay, hby, hqy]
      have h_s_eq : s * (tb - ta) = tq - ta := by
        rw [hs_def]; field_simp
      have h_dy : (tq - ta) * (seg.p2.y - seg.p1.y) =
                  s * (tb - ta) * (seg.p2.y - seg.p1.y) := by rw [h_s_eq]
      have key : ((1 - tq) * seg.p1.y + tq * seg.p2.y) -
                 ((1 - s) * ((1 - ta) * seg.p1.y + ta * seg.p2.y)
                  + s * ((1 - tb) * seg.p1.y + tb * seg.p2.y)) =
                 (tq - ta) * (seg.p2.y - seg.p1.y)
                  - s * (tb - ta) * (seg.p2.y - seg.p1.y) := by ring
      linarith [key, h_dy]

/-- The toSet of `⟨seg.p1, pt⟩` is the set of points on `seg` with parameter
    `≤ paramOnSeg seg pt`. -/
private theorem mem_left_subSeg_iff
    (seg : LineSegment) (h_nondeg : seg.p1 ≠ seg.p2)
    (pt : Vector2D) (h_pt : pt ∈ seg.toSet)
    (q : Vector2D) (h_q : q ∈ seg.toSet) :
    q ∈ (LineSegment.mk seg.p1 pt).toSet ↔ paramOnSeg seg q ≤ paramOnSeg seg pt := by
  have hp1_seg : seg.p1 ∈ seg.toSet :=
    ⟨0, by norm_num, by norm_num, by ring, by ring⟩
  have hp1_param : paramOnSeg seg seg.p1 = 0 := paramOnSeg_p1 seg h_nondeg
  obtain ⟨_, _, h_pt_nn, _⟩ := paramOnSeg_spec seg h_nondeg pt h_pt
  obtain ⟨_, _, h_q_nn, _⟩ := paramOnSeg_spec seg h_nondeg q h_q
  constructor
  · intro h_mem
    have h_le : paramOnSeg seg seg.p1 ≤ paramOnSeg seg pt := by rw [hp1_param]; exact h_pt_nn
    have := paramOnSeg_in_range_of_mem_subSeg seg h_nondeg seg.p1 pt hp1_seg h_pt h_le q h_mem
    exact this.2
  · intro h_le_pt
    have h_le : paramOnSeg seg seg.p1 ≤ paramOnSeg seg pt := by rw [hp1_param]; exact h_pt_nn
    have h_q_lo : paramOnSeg seg seg.p1 ≤ paramOnSeg seg q := by rw [hp1_param]; exact h_q_nn
    exact mem_subSeg_of_paramOnSeg_in_range seg h_nondeg seg.p1 pt hp1_seg h_pt h_le
      q h_q h_q_lo h_le_pt

/-- The toSet of `⟨pt, seg.p2⟩` is the set of points on `seg` with parameter
    `≥ paramOnSeg seg pt`. -/
private theorem mem_right_subSeg_iff
    (seg : LineSegment) (h_nondeg : seg.p1 ≠ seg.p2)
    (pt : Vector2D) (h_pt : pt ∈ seg.toSet)
    (q : Vector2D) (h_q : q ∈ seg.toSet) :
    q ∈ (LineSegment.mk pt seg.p2).toSet ↔ paramOnSeg seg pt ≤ paramOnSeg seg q := by
  have hp2_seg : seg.p2 ∈ seg.toSet :=
    ⟨1, by norm_num, by norm_num, by ring, by ring⟩
  have hp2_param : paramOnSeg seg seg.p2 = 1 := paramOnSeg_p2 seg h_nondeg
  obtain ⟨_, _, _, h_pt_le⟩ := paramOnSeg_spec seg h_nondeg pt h_pt
  obtain ⟨_, _, _, h_q_le⟩ := paramOnSeg_spec seg h_nondeg q h_q
  constructor
  · intro h_mem
    have h_le : paramOnSeg seg pt ≤ paramOnSeg seg seg.p2 := by rw [hp2_param]; exact h_pt_le
    have := paramOnSeg_in_range_of_mem_subSeg seg h_nondeg pt seg.p2 h_pt hp2_seg h_le q h_mem
    exact this.1
  · intro h_ge_pt
    have h_le : paramOnSeg seg pt ≤ paramOnSeg seg seg.p2 := by rw [hp2_param]; exact h_pt_le
    have h_q_hi : paramOnSeg seg q ≤ paramOnSeg seg seg.p2 := by rw [hp2_param]; exact h_q_le
    exact mem_subSeg_of_paramOnSeg_in_range seg h_nondeg pt seg.p2 h_pt hp2_seg h_le
      q h_q h_ge_pt h_q_hi

/-- For an interior point `pt` of `seg`, `paramOnSeg seg pt ∈ (0, 1)`. -/
private theorem paramOnSeg_strict_interior
    (seg : LineSegment) (h_nondeg : seg.p1 ≠ seg.p2)
    (pt : Vector2D) (h_pt : pt ∈ seg.toSet)
    (h_ne1 : pt ≠ seg.p1) (h_ne2 : pt ≠ seg.p2) :
    0 < paramOnSeg seg pt ∧ paramOnSeg seg pt < 1 := by
  obtain ⟨_, _, h_nn, h_le⟩ := paramOnSeg_spec seg h_nondeg pt h_pt
  refine ⟨?_, ?_⟩
  · rcases lt_or_eq_of_le h_nn with hlt | heq
    · exact hlt
    · exfalso; apply h_ne1
      have hp1_seg : seg.p1 ∈ seg.toSet :=
        ⟨0, by norm_num, by norm_num, by ring, by ring⟩
      have hp1_param : paramOnSeg seg seg.p1 = 0 := paramOnSeg_p1 seg h_nondeg
      apply paramOnSeg_injective seg h_nondeg h_pt hp1_seg
      rw [hp1_param, ← heq]
  · rcases lt_or_eq_of_le h_le with hlt | heq
    · exact hlt
    · exfalso; apply h_ne2
      have hp2_seg : seg.p2 ∈ seg.toSet :=
        ⟨1, by norm_num, by norm_num, by ring, by ring⟩
      have hp2_param : paramOnSeg seg seg.p2 = 1 := paramOnSeg_p2 seg h_nondeg
      apply paramOnSeg_injective seg h_nondeg h_pt hp2_seg
      rw [hp2_param, heq]

open Classical in
/-- Order-independence of `iterativeSplit` for swapping two adjacent points,
    when both points are on `seg.toSet`. Result is an equality of toEM-mapped
    lists modulo permutation. -/
private theorem iterativeSplit_swap_pts_perm
    (seg : LineSegment) (h_nondeg : seg.p1 ≠ seg.p2)
    (a b : Vector2D) (h_a_seg : a ∈ seg.toSet) (h_b_seg : b ∈ seg.toSet)
    (l : List Vector2D) :
    List.Perm
      ((iterativeSplit seg (a :: b :: l)).map
        LineSegment.toEndpointsMultiset)
      ((iterativeSplit seg (b :: a :: l)).map
        LineSegment.toEndpointsMultiset) := by
  -- Case-split on whether a is interior to seg.
  by_cases h_a_int : a ∈ seg.toSet ∧ a ≠ seg.p1 ∧ a ≠ seg.p2
  · -- a strictly interior to seg.
    have h_a_ne_p1 : a ≠ seg.p1 := h_a_int.2.1
    have h_a_ne_p2 : a ≠ seg.p2 := h_a_int.2.2
    -- Case-split on whether b is interior to seg.
    by_cases h_b_int : b ∈ seg.toSet ∧ b ≠ seg.p1 ∧ b ≠ seg.p2
    · have h_b_ne_p1 : b ≠ seg.p1 := h_b_int.2.1
      have h_b_ne_p2 : b ≠ seg.p2 := h_b_int.2.2
      -- Both interior. Case on whether a = b.
      by_cases h_ab : a = b
      · subst h_ab; exact List.Perm.refl _
      · -- a ≠ b. WLOG paramOnSeg a < paramOnSeg b or paramOnSeg b < paramOnSeg a.
        have h_param_ne : paramOnSeg seg a ≠ paramOnSeg seg b := by
          intro h_param_eq
          exact h_ab (paramOnSeg_injective seg h_nondeg h_a_seg h_b_seg h_param_eq)
        rcases lt_or_gt_of_ne h_param_ne with h_lt | h_gt
        · -- paramOnSeg a < paramOnSeg b
          -- LHS: iterativeSplit seg (a :: b :: l)
          --    = iterativeSplit ⟨p1,a⟩ (b :: l) ++ iterativeSplit ⟨a,p2⟩ (b :: l) (since a interior)
          -- For ⟨p1,a⟩: b NOT in interior since paramOnSeg b > paramOnSeg a, so b ∉ ⟨p1,a⟩.toSet.
          --   ⇒ iterativeSplit ⟨p1,a⟩ (b :: l) = iterativeSplit ⟨p1,a⟩ l
          -- For ⟨a,p2⟩: b IS interior. b ∈ ⟨a,p2⟩.toSet, b ≠ a, b ≠ p2.
          --   ⇒ iterativeSplit ⟨a,p2⟩ (b :: l) = iterativeSplit ⟨a,b⟩ l ++ iterativeSplit ⟨b,p2⟩ l
          -- LHS = iterativeSplit ⟨p1,a⟩ l ++ (iterativeSplit ⟨a,b⟩ l ++ iterativeSplit ⟨b,p2⟩ l)
          -- RHS: iterativeSplit seg (b :: a :: l)
          --    = iterativeSplit ⟨p1,b⟩ (a :: l) ++ iterativeSplit ⟨b,p2⟩ (a :: l) (since b interior)
          -- For ⟨p1,b⟩: a IS interior. paramOnSeg a < paramOnSeg b ⇒ a ∈ ⟨p1,b⟩.toSet, a ≠ p1, a ≠ b.
          --   ⇒ iterativeSplit ⟨p1,b⟩ (a :: l) = iterativeSplit ⟨p1,a⟩ l ++ iterativeSplit ⟨a,b⟩ l
          -- For ⟨b,p2⟩: a NOT in interior (paramOnSeg a < paramOnSeg b ⇒ a ∉ ⟨b,p2⟩.toSet).
          --   ⇒ iterativeSplit ⟨b,p2⟩ (a :: l) = iterativeSplit ⟨b,p2⟩ l
          -- RHS = (iterativeSplit ⟨p1,a⟩ l ++ iterativeSplit ⟨a,b⟩ l) ++ iterativeSplit ⟨b,p2⟩ l
          -- These are equal by associativity!
          -- Prove the predicates.
          have h_b_notin_left : ¬ (b ∈ (LineSegment.mk seg.p1 a).toSet ∧
              b ≠ (LineSegment.mk seg.p1 a).p1 ∧ b ≠ (LineSegment.mk seg.p1 a).p2) := by
            rintro ⟨h_b_in, _, _⟩
            have := (mem_left_subSeg_iff seg h_nondeg a h_a_seg b h_b_seg).mp h_b_in
            linarith
          have h_b_in_right : b ∈ (LineSegment.mk a seg.p2).toSet ∧
              b ≠ (LineSegment.mk a seg.p2).p1 ∧ b ≠ (LineSegment.mk a seg.p2).p2 := by
            refine ⟨?_, ?_, ?_⟩
            · exact (mem_right_subSeg_iff seg h_nondeg a h_a_seg b h_b_seg).mpr (le_of_lt h_lt)
            · show b ≠ a; exact fun h => h_ab h.symm
            · show b ≠ seg.p2; exact h_b_ne_p2
          have h_a_in_left' : a ∈ (LineSegment.mk seg.p1 b).toSet ∧
              a ≠ (LineSegment.mk seg.p1 b).p1 ∧ a ≠ (LineSegment.mk seg.p1 b).p2 := by
            refine ⟨?_, ?_, ?_⟩
            · exact (mem_left_subSeg_iff seg h_nondeg b h_b_seg a h_a_seg).mpr (le_of_lt h_lt)
            · show a ≠ seg.p1; exact h_a_ne_p1
            · show a ≠ b; exact h_ab
          have h_a_notin_right' : ¬ (a ∈ (LineSegment.mk b seg.p2).toSet ∧
              a ≠ (LineSegment.mk b seg.p2).p1 ∧ a ≠ (LineSegment.mk b seg.p2).p2) := by
            rintro ⟨h_a_in, _, _⟩
            have := (mem_right_subSeg_iff seg h_nondeg b h_b_seg a h_a_seg).mp h_a_in
            linarith
          -- Now compute LHS.
          have hLHS : iterativeSplit seg (a :: b :: l) =
              iterativeSplit ⟨seg.p1, a⟩ l ++
                (iterativeSplit ⟨a, b⟩ l ++
                  iterativeSplit ⟨b, seg.p2⟩ l) := by
            show (if a ∈ seg.toSet ∧ a ≠ seg.p1 ∧ a ≠ seg.p2 then
                iterativeSplit ⟨seg.p1, a⟩ (b :: l) ++
                  iterativeSplit ⟨a, seg.p2⟩ (b :: l)
              else iterativeSplit seg (b :: l)) = _
            rw [if_pos h_a_int]
            -- Now break apart the (b :: l) cases.
            have h_left : iterativeSplit
                (LineSegment.mk seg.p1 a) (b :: l) =
                iterativeSplit (LineSegment.mk seg.p1 a) l := by
              show (if b ∈ (LineSegment.mk seg.p1 a).toSet ∧
                    b ≠ (LineSegment.mk seg.p1 a).p1 ∧ b ≠ (LineSegment.mk seg.p1 a).p2 then _
                  else _) = _
              rw [if_neg h_b_notin_left]
            have h_right : iterativeSplit
                (LineSegment.mk a seg.p2) (b :: l) =
                iterativeSplit ⟨a, b⟩ l ++
                  iterativeSplit ⟨b, seg.p2⟩ l := by
              show (if b ∈ (LineSegment.mk a seg.p2).toSet ∧
                    b ≠ (LineSegment.mk a seg.p2).p1 ∧ b ≠ (LineSegment.mk a seg.p2).p2 then _
                  else _) = _
              rw [if_pos h_b_in_right]
            rw [h_left, h_right]
          have hRHS : iterativeSplit seg (b :: a :: l) =
              (iterativeSplit ⟨seg.p1, a⟩ l ++
                iterativeSplit ⟨a, b⟩ l) ++
                iterativeSplit ⟨b, seg.p2⟩ l := by
            show (if b ∈ seg.toSet ∧ b ≠ seg.p1 ∧ b ≠ seg.p2 then
                iterativeSplit ⟨seg.p1, b⟩ (a :: l) ++
                  iterativeSplit ⟨b, seg.p2⟩ (a :: l)
              else iterativeSplit seg (a :: l)) = _
            rw [if_pos h_b_int]
            have h_left' : iterativeSplit
                (LineSegment.mk seg.p1 b) (a :: l) =
                iterativeSplit ⟨seg.p1, a⟩ l ++
                  iterativeSplit ⟨a, b⟩ l := by
              show (if a ∈ (LineSegment.mk seg.p1 b).toSet ∧
                    a ≠ (LineSegment.mk seg.p1 b).p1 ∧ a ≠ (LineSegment.mk seg.p1 b).p2 then _
                  else _) = _
              rw [if_pos h_a_in_left']
            have h_right' : iterativeSplit
                (LineSegment.mk b seg.p2) (a :: l) =
                iterativeSplit ⟨b, seg.p2⟩ l := by
              show (if a ∈ (LineSegment.mk b seg.p2).toSet ∧
                    a ≠ (LineSegment.mk b seg.p2).p1 ∧ a ≠ (LineSegment.mk b seg.p2).p2 then _
                  else _) = _
              rw [if_neg h_a_notin_right']
            rw [h_left', h_right']
          rw [hLHS, hRHS]
          -- Goal: (A ++ (B ++ C)).map toEM ~ ((A ++ B) ++ C).map toEM, equal!
          rw [List.append_assoc]
        · -- paramOnSeg b < paramOnSeg a; symmetric. Just swap roles by transitivity.
          -- Simpler: apply the previous case after swapping a, b.
          -- We have: iterativeSplit seg (b :: a :: l) ~ iterativeSplit seg (a :: b :: l).
          -- We want: iterativeSplit seg (a :: b :: l) ~ iterativeSplit seg (b :: a :: l).
          -- So just take the symmetric.
          -- We need the same proof with roles of a, b swapped.
          -- Rather than duplicating, just call iterativeSplit_swap_pts_perm with a, b swapped.
          -- But that's recursive... let me just inline.
          have h_b_int' : b ∈ seg.toSet ∧ b ≠ seg.p1 ∧ b ≠ seg.p2 := h_b_int
          -- Predicates for the symmetric case.
          have h_a_notin_left : ¬ (a ∈ (LineSegment.mk seg.p1 b).toSet ∧
              a ≠ (LineSegment.mk seg.p1 b).p1 ∧ a ≠ (LineSegment.mk seg.p1 b).p2) := by
            rintro ⟨h_a_in, _, _⟩
            have := (mem_left_subSeg_iff seg h_nondeg b h_b_seg a h_a_seg).mp h_a_in
            linarith
          have h_a_in_right : a ∈ (LineSegment.mk b seg.p2).toSet ∧
              a ≠ (LineSegment.mk b seg.p2).p1 ∧ a ≠ (LineSegment.mk b seg.p2).p2 := by
            refine ⟨?_, ?_, ?_⟩
            · exact (mem_right_subSeg_iff seg h_nondeg b h_b_seg a h_a_seg).mpr (le_of_lt h_gt)
            · show a ≠ b; exact h_ab
            · show a ≠ seg.p2; exact h_a_ne_p2
          have h_b_in_left' : b ∈ (LineSegment.mk seg.p1 a).toSet ∧
              b ≠ (LineSegment.mk seg.p1 a).p1 ∧ b ≠ (LineSegment.mk seg.p1 a).p2 := by
            refine ⟨?_, ?_, ?_⟩
            · exact (mem_left_subSeg_iff seg h_nondeg a h_a_seg b h_b_seg).mpr (le_of_lt h_gt)
            · show b ≠ seg.p1; exact h_b_ne_p1
            · show b ≠ a; exact fun h => h_ab h.symm
          have h_b_notin_right' : ¬ (b ∈ (LineSegment.mk a seg.p2).toSet ∧
              b ≠ (LineSegment.mk a seg.p2).p1 ∧ b ≠ (LineSegment.mk a seg.p2).p2) := by
            rintro ⟨h_b_in, _, _⟩
            have := (mem_right_subSeg_iff seg h_nondeg a h_a_seg b h_b_seg).mp h_b_in
            linarith
          -- Compute both sides.
          have hLHS : iterativeSplit seg (a :: b :: l) =
              (iterativeSplit ⟨seg.p1, b⟩ l ++
                iterativeSplit ⟨b, a⟩ l) ++
                iterativeSplit ⟨a, seg.p2⟩ l := by
            show (if a ∈ seg.toSet ∧ a ≠ seg.p1 ∧ a ≠ seg.p2 then
                iterativeSplit ⟨seg.p1, a⟩ (b :: l) ++
                  iterativeSplit ⟨a, seg.p2⟩ (b :: l)
              else iterativeSplit seg (b :: l)) = _
            rw [if_pos h_a_int]
            have h_left : iterativeSplit
                (LineSegment.mk seg.p1 a) (b :: l) =
                iterativeSplit ⟨seg.p1, b⟩ l ++
                  iterativeSplit ⟨b, a⟩ l := by
              show (if b ∈ (LineSegment.mk seg.p1 a).toSet ∧
                    b ≠ (LineSegment.mk seg.p1 a).p1 ∧ b ≠ (LineSegment.mk seg.p1 a).p2 then _
                  else _) = _
              rw [if_pos h_b_in_left']
            have h_right : iterativeSplit
                (LineSegment.mk a seg.p2) (b :: l) =
                iterativeSplit ⟨a, seg.p2⟩ l := by
              show (if b ∈ (LineSegment.mk a seg.p2).toSet ∧
                    b ≠ (LineSegment.mk a seg.p2).p1 ∧ b ≠ (LineSegment.mk a seg.p2).p2 then _
                  else _) = _
              rw [if_neg h_b_notin_right']
            rw [h_left, h_right]
          have hRHS : iterativeSplit seg (b :: a :: l) =
              iterativeSplit ⟨seg.p1, b⟩ l ++
                (iterativeSplit ⟨b, a⟩ l ++
                  iterativeSplit ⟨a, seg.p2⟩ l) := by
            show (if b ∈ seg.toSet ∧ b ≠ seg.p1 ∧ b ≠ seg.p2 then
                iterativeSplit ⟨seg.p1, b⟩ (a :: l) ++
                  iterativeSplit ⟨b, seg.p2⟩ (a :: l)
              else iterativeSplit seg (a :: l)) = _
            rw [if_pos h_b_int']
            have h_left' : iterativeSplit
                (LineSegment.mk seg.p1 b) (a :: l) =
                iterativeSplit ⟨seg.p1, b⟩ l := by
              show (if a ∈ (LineSegment.mk seg.p1 b).toSet ∧
                    a ≠ (LineSegment.mk seg.p1 b).p1 ∧ a ≠ (LineSegment.mk seg.p1 b).p2 then _
                  else _) = _
              rw [if_neg h_a_notin_left]
            have h_right' : iterativeSplit
                (LineSegment.mk b seg.p2) (a :: l) =
                iterativeSplit ⟨b, a⟩ l ++
                  iterativeSplit ⟨a, seg.p2⟩ l := by
              show (if a ∈ (LineSegment.mk b seg.p2).toSet ∧
                    a ≠ (LineSegment.mk b seg.p2).p1 ∧ a ≠ (LineSegment.mk b seg.p2).p2 then _
                  else _) = _
              rw [if_pos h_a_in_right]
            rw [h_left', h_right']
          rw [hLHS, hRHS, List.append_assoc]
    · -- a interior, b NOT interior (in seg).
      -- Then for LHS: iterativeSplit seg (a :: b :: l)
      --             = iterativeSplit ⟨p1,a⟩ (b :: l) ++ iterativeSplit ⟨a,p2⟩ (b :: l).
      -- b ∉ ⟨p1,a⟩.toSet (probably, but not necessarily — b may equal p1 or a).
      -- Hmm, let me just reason: if b is not strictly interior to seg, then b = p1, b = p2, or b ∉ seg.toSet.
      -- But h_b_seg : b ∈ seg.toSet, so b = p1 or b = p2.
      -- Hmm wait the hypothesis is `pt ∈ s.toSet ∧ pt ≠ s.p1 ∧ pt ≠ s.p2`. So `¬ h_b_int` means
      -- b ∉ seg.toSet OR b = seg.p1 OR b = seg.p2. Since b ∈ seg.toSet (h_b_seg), b = p1 or b = p2.
      have h_b_p1_or_p2 : b = seg.p1 ∨ b = seg.p2 := by
        rcases (Classical.em (b = seg.p1)) with hp1 | hnp1
        · exact Or.inl hp1
        · rcases (Classical.em (b = seg.p2)) with hp2 | hnp2
          · exact Or.inr hp2
          · exfalso; exact h_b_int ⟨h_b_seg, hnp1, hnp2⟩
      -- For RHS: iterativeSplit seg (b :: a :: l). b's predicate is false (since not interior).
      -- So iterativeSplit seg (b :: a :: l) = iterativeSplit seg (a :: l)
      --                                    = iterativeSplit ⟨p1,a⟩ l ++ iterativeSplit ⟨a,p2⟩ l.
      have hRHS : iterativeSplit seg (b :: a :: l) =
          iterativeSplit ⟨seg.p1, a⟩ l ++
            iterativeSplit ⟨a, seg.p2⟩ l := by
        show (if b ∈ seg.toSet ∧ b ≠ seg.p1 ∧ b ≠ seg.p2 then _
              else iterativeSplit seg (a :: l)) = _
        rw [if_neg h_b_int]
        show (if a ∈ seg.toSet ∧ a ≠ seg.p1 ∧ a ≠ seg.p2 then
            iterativeSplit ⟨seg.p1, a⟩ l ++
              iterativeSplit ⟨a, seg.p2⟩ l
          else iterativeSplit seg l) = _
        rw [if_pos h_a_int]
      -- For LHS: iterativeSplit seg (a :: b :: l) = iterativeSplit ⟨p1,a⟩ (b :: l) ++ iterativeSplit ⟨a,p2⟩ (b :: l).
      -- We need the predicate evaluation on b for each half.
      -- If b = seg.p1: in ⟨p1,a⟩, predicate b ∈ toSet ∧ b ≠ p1 ∧ b ≠ a is FALSE since b = p1.
      --                in ⟨a,p2⟩, predicate b ∈ toSet ∧ b ≠ a ∧ b ≠ p2; b = p1 ≠ p2; b = p1 ≠ a (since a ≠ p1); b ∈ ⟨a,p2⟩.toSet?
      --                  paramOnSeg b = paramOnSeg p1 = 0. paramOnSeg a > 0. So paramOnSeg b < paramOnSeg a, so b ∉ ⟨a,p2⟩.toSet (would need ≥). So predicate FALSE.
      --                Hence iterativeSplit ⟨a,p2⟩ (b :: l) = iterativeSplit ⟨a,p2⟩ l.
      -- Similarly if b = seg.p2.
      -- In all cases, LHS = iterativeSplit ⟨p1,a⟩ l ++ iterativeSplit ⟨a,p2⟩ l = RHS (equal!).
      have hLHS : iterativeSplit seg (a :: b :: l) =
          iterativeSplit ⟨seg.p1, a⟩ l ++
            iterativeSplit ⟨a, seg.p2⟩ l := by
        show (if a ∈ seg.toSet ∧ a ≠ seg.p1 ∧ a ≠ seg.p2 then
            iterativeSplit ⟨seg.p1, a⟩ (b :: l) ++
              iterativeSplit ⟨a, seg.p2⟩ (b :: l)
          else iterativeSplit seg (b :: l)) = _
        rw [if_pos h_a_int]
        -- Need b's predicate false on each half.
        have h_aint := paramOnSeg_strict_interior seg h_nondeg a h_a_seg h_a_ne_p1 h_a_ne_p2
        rcases h_b_p1_or_p2 with h_b_p1 | h_b_p2
        · -- b = seg.p1.
          -- ⟨p1, a⟩: b = p1 = ⟨p1,a⟩.p1, predicate fails on b ≠ p1.
          have h_b_pred_left : ¬ (b ∈ (LineSegment.mk seg.p1 a).toSet ∧
              b ≠ (LineSegment.mk seg.p1 a).p1 ∧ b ≠ (LineSegment.mk seg.p1 a).p2) := by
            rintro ⟨_, h_ne_p1, _⟩
            apply h_ne_p1; show b = seg.p1; exact h_b_p1
          -- ⟨a, p2⟩: b = p1, paramOnSeg b = 0, paramOnSeg a > 0, so b not in ⟨a,p2⟩.toSet.
          have h_b_pred_right : ¬ (b ∈ (LineSegment.mk a seg.p2).toSet ∧
              b ≠ (LineSegment.mk a seg.p2).p1 ∧ b ≠ (LineSegment.mk a seg.p2).p2) := by
            rintro ⟨h_b_in, _, _⟩
            have h_param_le := (mem_right_subSeg_iff seg h_nondeg a h_a_seg b h_b_seg).mp h_b_in
            rw [h_b_p1, paramOnSeg_p1 seg h_nondeg] at h_param_le
            linarith [h_aint.1]
          have h_left : iterativeSplit
              (LineSegment.mk seg.p1 a) (b :: l) =
              iterativeSplit (LineSegment.mk seg.p1 a) l := by
            show (if _ then _ else _) = _; rw [if_neg h_b_pred_left]
          have h_right : iterativeSplit
              (LineSegment.mk a seg.p2) (b :: l) =
              iterativeSplit (LineSegment.mk a seg.p2) l := by
            show (if _ then _ else _) = _; rw [if_neg h_b_pred_right]
          rw [h_left, h_right]
        · -- b = seg.p2. Symmetric.
          have h_b_pred_left : ¬ (b ∈ (LineSegment.mk seg.p1 a).toSet ∧
              b ≠ (LineSegment.mk seg.p1 a).p1 ∧ b ≠ (LineSegment.mk seg.p1 a).p2) := by
            rintro ⟨h_b_in, _, _⟩
            have h_param_le := (mem_left_subSeg_iff seg h_nondeg a h_a_seg b h_b_seg).mp h_b_in
            rw [h_b_p2, paramOnSeg_p2 seg h_nondeg] at h_param_le
            linarith [h_aint.2]
          have h_b_pred_right : ¬ (b ∈ (LineSegment.mk a seg.p2).toSet ∧
              b ≠ (LineSegment.mk a seg.p2).p1 ∧ b ≠ (LineSegment.mk a seg.p2).p2) := by
            rintro ⟨_, _, h_ne_p2⟩
            apply h_ne_p2; show b = seg.p2; exact h_b_p2
          have h_left : iterativeSplit
              (LineSegment.mk seg.p1 a) (b :: l) =
              iterativeSplit (LineSegment.mk seg.p1 a) l := by
            show (if _ then _ else _) = _; rw [if_neg h_b_pred_left]
          have h_right : iterativeSplit
              (LineSegment.mk a seg.p2) (b :: l) =
              iterativeSplit (LineSegment.mk a seg.p2) l := by
            show (if _ then _ else _) = _; rw [if_neg h_b_pred_right]
          rw [h_left, h_right]
      rw [hLHS, hRHS]
  · -- a NOT interior. Symmetric to "a interior, b not interior" case essentially.
    -- LHS = iterativeSplit seg (a :: b :: l) = iterativeSplit seg (b :: l) (since a fails predicate).
    have hLHS : iterativeSplit seg (a :: b :: l) =
        iterativeSplit seg (b :: l) := by
      show (if a ∈ seg.toSet ∧ a ≠ seg.p1 ∧ a ≠ seg.p2 then _
            else iterativeSplit seg (b :: l)) = _
      rw [if_neg h_a_int]
    -- RHS: case on b interior.
    by_cases h_b_int : b ∈ seg.toSet ∧ b ≠ seg.p1 ∧ b ≠ seg.p2
    · -- b interior. Same situation as above with roles swapped.
      -- RHS = iterativeSplit seg (b :: a :: l) = iterativeSplit ⟨p1,b⟩ (a :: l) ++ iterativeSplit ⟨b,p2⟩ (a :: l).
      -- LHS = iterativeSplit seg (b :: l) = iterativeSplit ⟨p1,b⟩ l ++ iterativeSplit ⟨b,p2⟩ l.
      -- Since a is in seg.toSet but is p1 or p2 (similar case).
      have h_b_ne_p1 : b ≠ seg.p1 := h_b_int.2.1
      have h_b_ne_p2 : b ≠ seg.p2 := h_b_int.2.2
      have h_a_p1_or_p2 : a = seg.p1 ∨ a = seg.p2 := by
        rcases (Classical.em (a = seg.p1)) with hp1 | hnp1
        · exact Or.inl hp1
        · rcases (Classical.em (a = seg.p2)) with hp2 | hnp2
          · exact Or.inr hp2
          · exfalso; exact h_a_int ⟨h_a_seg, hnp1, hnp2⟩
      have hLHS' : iterativeSplit seg (b :: l) =
          iterativeSplit ⟨seg.p1, b⟩ l ++
            iterativeSplit ⟨b, seg.p2⟩ l := by
        show (if b ∈ seg.toSet ∧ b ≠ seg.p1 ∧ b ≠ seg.p2 then _ else _) = _
        rw [if_pos h_b_int]
      have h_bint := paramOnSeg_strict_interior seg h_nondeg b h_b_seg h_b_ne_p1 h_b_ne_p2
      have hRHS : iterativeSplit seg (b :: a :: l) =
          iterativeSplit ⟨seg.p1, b⟩ l ++
            iterativeSplit ⟨b, seg.p2⟩ l := by
        show (if b ∈ seg.toSet ∧ b ≠ seg.p1 ∧ b ≠ seg.p2 then
            iterativeSplit ⟨seg.p1, b⟩ (a :: l) ++
              iterativeSplit ⟨b, seg.p2⟩ (a :: l)
          else iterativeSplit seg (a :: l)) = _
        rw [if_pos h_b_int]
        rcases h_a_p1_or_p2 with h_a_p1 | h_a_p2
        · -- a = seg.p1. ⟨p1,b⟩: a = p1, predicate fails. ⟨b,p2⟩: a = p1, paramOnSeg a = 0 < paramOnSeg b ⇒ a ∉ ⟨b,p2⟩.
          have h_a_pred_left : ¬ (a ∈ (LineSegment.mk seg.p1 b).toSet ∧
              a ≠ (LineSegment.mk seg.p1 b).p1 ∧ a ≠ (LineSegment.mk seg.p1 b).p2) := by
            rintro ⟨_, h_ne, _⟩; apply h_ne; show a = seg.p1; exact h_a_p1
          have h_a_pred_right : ¬ (a ∈ (LineSegment.mk b seg.p2).toSet ∧
              a ≠ (LineSegment.mk b seg.p2).p1 ∧ a ≠ (LineSegment.mk b seg.p2).p2) := by
            rintro ⟨h_a_in, _, _⟩
            have h_param_le := (mem_right_subSeg_iff seg h_nondeg b h_b_seg a h_a_seg).mp h_a_in
            rw [h_a_p1, paramOnSeg_p1 seg h_nondeg] at h_param_le
            linarith [h_bint.1]
          have h_left : iterativeSplit
              (LineSegment.mk seg.p1 b) (a :: l) =
              iterativeSplit (LineSegment.mk seg.p1 b) l := by
            show (if _ then _ else _) = _; rw [if_neg h_a_pred_left]
          have h_right : iterativeSplit
              (LineSegment.mk b seg.p2) (a :: l) =
              iterativeSplit (LineSegment.mk b seg.p2) l := by
            show (if _ then _ else _) = _; rw [if_neg h_a_pred_right]
          rw [h_left, h_right]
        · -- a = seg.p2. Symmetric.
          have h_a_pred_left : ¬ (a ∈ (LineSegment.mk seg.p1 b).toSet ∧
              a ≠ (LineSegment.mk seg.p1 b).p1 ∧ a ≠ (LineSegment.mk seg.p1 b).p2) := by
            rintro ⟨h_a_in, _, _⟩
            have h_param_le := (mem_left_subSeg_iff seg h_nondeg b h_b_seg a h_a_seg).mp h_a_in
            rw [h_a_p2, paramOnSeg_p2 seg h_nondeg] at h_param_le
            linarith [h_bint.2]
          have h_a_pred_right : ¬ (a ∈ (LineSegment.mk b seg.p2).toSet ∧
              a ≠ (LineSegment.mk b seg.p2).p1 ∧ a ≠ (LineSegment.mk b seg.p2).p2) := by
            rintro ⟨_, _, h_ne⟩; apply h_ne; show a = seg.p2; exact h_a_p2
          have h_left : iterativeSplit
              (LineSegment.mk seg.p1 b) (a :: l) =
              iterativeSplit (LineSegment.mk seg.p1 b) l := by
            show (if _ then _ else _) = _; rw [if_neg h_a_pred_left]
          have h_right : iterativeSplit
              (LineSegment.mk b seg.p2) (a :: l) =
              iterativeSplit (LineSegment.mk b seg.p2) l := by
            show (if _ then _ else _) = _; rw [if_neg h_a_pred_right]
          rw [h_left, h_right]
      rw [hLHS, hLHS', hRHS]
    · -- Both NOT interior.
      -- LHS = iterativeSplit seg (b :: l) = iterativeSplit seg l (since b fails).
      -- RHS = iterativeSplit seg (b :: a :: l) = iterativeSplit seg (a :: l) (since b fails)
      --     = iterativeSplit seg l (since a fails).
      have hLHS' : iterativeSplit seg (b :: l) =
          iterativeSplit seg l := by
        show (if _ then _ else _) = _; rw [if_neg h_b_int]
      have hRHS : iterativeSplit seg (b :: a :: l) =
          iterativeSplit seg l := by
        show (if b ∈ seg.toSet ∧ b ≠ seg.p1 ∧ b ≠ seg.p2 then _
              else iterativeSplit seg (a :: l)) = _
        rw [if_neg h_b_int]
        show (if _ then _ else _) = _
        rw [if_neg h_a_int]
      rw [hLHS, hLHS', hRHS]

open Classical in
/-- If `b` is NOT strictly interior to `seg` and `a` is strictly interior to `seg`,
    then `b` is NOT strictly interior to the left sub-segment `⟨seg.p1, a⟩`. -/
private lemma not_interior_left_subseg
    (seg : LineSegment) (h_nondeg : seg.p1 ≠ seg.p2)
    (a b : Vector2D)
    (h_a_int : a ∈ seg.toSet ∧ a ≠ seg.p1 ∧ a ≠ seg.p2)
    (h_b_not_int : ¬ (b ∈ seg.toSet ∧ b ≠ seg.p1 ∧ b ≠ seg.p2)) :
    ¬ (b ∈ (LineSegment.mk seg.p1 a).toSet ∧
        b ≠ (LineSegment.mk seg.p1 a).p1 ∧
        b ≠ (LineSegment.mk seg.p1 a).p2) := by
  rintro ⟨h_b_in, h_b_ne_p1, h_b_ne_a⟩
  -- ⟨p1, a⟩.p1 = seg.p1, ⟨p1, a⟩.p2 = a.
  have h_b_ne_segp1 : b ≠ seg.p1 := h_b_ne_p1
  -- b ∈ ⟨seg.p1, a⟩.toSet ⊆ seg.toSet.
  have h_b_in_seg : b ∈ seg.toSet := by
    -- Use convex combination: b ∈ ⟨seg.p1, a⟩.toSet means b = (1-t)·seg.p1 + t·a for t ∈ [0,1].
    -- a ∈ seg.toSet means a = (1-s)·seg.p1 + s·seg.p2 for s ∈ [0,1].
    -- So b = (1-t)·seg.p1 + t·((1-s)·seg.p1 + s·seg.p2) = (1 - ts)·seg.p1 + ts·seg.p2.
    obtain ⟨t, ht_nn, ht_le, hbx, hby⟩ := h_b_in
    obtain ⟨s, hs_nn, hs_le, hax, hay⟩ := h_a_int.1
    refine ⟨t * s, ?_, ?_, ?_, ?_⟩
    · exact mul_nonneg ht_nn hs_nn
    · calc t * s ≤ 1 * 1 := by
            apply mul_le_mul ht_le hs_le hs_nn (by linarith)
        _ = 1 := by ring
    · simp only at hbx hax
      rw [hbx, hax]; ring
    · simp only at hby hay
      rw [hby, hay]; ring
  -- b ≠ seg.p2: if b = seg.p2, then paramOnSeg seg.p2 = 1 ≤ paramOnSeg a < 1, contradiction.
  have h_b_ne_segp2 : b ≠ seg.p2 := by
    intro h_b_eq_p2
    have h_param_le := (mem_left_subSeg_iff seg h_nondeg a h_a_int.1 b h_b_in_seg).mp h_b_in
    rw [h_b_eq_p2, paramOnSeg_p2 seg h_nondeg] at h_param_le
    have h_a_lt := paramOnSeg_strict_interior seg h_nondeg a h_a_int.1 h_a_int.2.1 h_a_int.2.2
    linarith
  exact h_b_not_int ⟨h_b_in_seg, h_b_ne_segp1, h_b_ne_segp2⟩

open Classical in
/-- If `b` is NOT strictly interior to `seg` and `a` is strictly interior to `seg`,
    then `b` is NOT strictly interior to the right sub-segment `⟨a, seg.p2⟩`. -/
private lemma not_interior_right_subseg
    (seg : LineSegment) (h_nondeg : seg.p1 ≠ seg.p2)
    (a b : Vector2D)
    (h_a_int : a ∈ seg.toSet ∧ a ≠ seg.p1 ∧ a ≠ seg.p2)
    (h_b_not_int : ¬ (b ∈ seg.toSet ∧ b ≠ seg.p1 ∧ b ≠ seg.p2)) :
    ¬ (b ∈ (LineSegment.mk a seg.p2).toSet ∧
        b ≠ (LineSegment.mk a seg.p2).p1 ∧
        b ≠ (LineSegment.mk a seg.p2).p2) := by
  rintro ⟨h_b_in, h_b_ne_a, h_b_ne_p2⟩
  have h_b_ne_segp2 : b ≠ seg.p2 := h_b_ne_p2
  have h_b_in_seg : b ∈ seg.toSet := by
    obtain ⟨t, ht_nn, ht_le, hbx, hby⟩ := h_b_in
    obtain ⟨s, hs_nn, hs_le, hax, hay⟩ := h_a_int.1
    -- b = (1-t)·a + t·seg.p2 = (1-t)·((1-s)·p1 + s·p2) + t·p2 = (1-t)(1-s)·p1 + ((1-t)s + t)·p2
    refine ⟨(1 - t) * s + t, ?_, ?_, ?_, ?_⟩
    · have h1 : 0 ≤ (1 - t) * s := mul_nonneg (by linarith) hs_nn
      linarith
    · have h1 : (1 - t) * s ≤ (1 - t) * 1 :=
        mul_le_mul_of_nonneg_left hs_le (by linarith)
      linarith
    · simp only at hbx hax
      rw [hbx, hax]; ring
    · simp only at hby hay
      rw [hby, hay]; ring
  have h_b_ne_segp1 : b ≠ seg.p1 := by
    intro h_b_eq_p1
    have h_param_le := (mem_right_subSeg_iff seg h_nondeg a h_a_int.1 b h_b_in_seg).mp h_b_in
    rw [h_b_eq_p1, paramOnSeg_p1 seg h_nondeg] at h_param_le
    have h_a_lt := paramOnSeg_strict_interior seg h_nondeg a h_a_int.1 h_a_int.2.1 h_a_int.2.2
    linarith
  exact h_b_not_int ⟨h_b_in_seg, h_b_ne_segp1, h_b_ne_segp2⟩

open Classical in
/-- General version of `iterativeSplit_swap_pts_perm` without the on-seg
    hypotheses on `a, b`. -/
private theorem iterativeSplit_swap_general
    (seg : LineSegment) (h_nondeg : seg.p1 ≠ seg.p2)
    (a b : Vector2D) (l : List Vector2D) :
    List.Perm
      ((iterativeSplit seg (a :: b :: l)).map LineSegment.toEndpointsMultiset)
      ((iterativeSplit seg (b :: a :: l)).map LineSegment.toEndpointsMultiset) := by
  by_cases h_a_int : a ∈ seg.toSet ∧ a ≠ seg.p1 ∧ a ≠ seg.p2
  · by_cases h_b_int : b ∈ seg.toSet ∧ b ≠ seg.p1 ∧ b ≠ seg.p2
    · -- Both strictly interior to seg; on-seg holds, use existing lemma.
      exact iterativeSplit_swap_pts_perm seg h_nondeg a b h_a_int.1 h_b_int.1 l
    · -- a interior, b NOT.
      -- LHS: split at a, recurse with (b :: l).
      -- RHS: skip b, then split at a, recurse with l.
      -- Need: iterSplit ⟨p1,a⟩ (b :: l) = iterSplit ⟨p1,a⟩ l (b not interior to ⟨p1,a⟩).
      -- Same for ⟨a,p2⟩.
      have h_b_not_left := not_interior_left_subseg seg h_nondeg a b h_a_int h_b_int
      have h_b_not_right := not_interior_right_subseg seg h_nondeg a b h_a_int h_b_int
      have hLHS : iterativeSplit seg (a :: b :: l) =
          iterativeSplit ⟨seg.p1, a⟩ (b :: l) ++ iterativeSplit ⟨a, seg.p2⟩ (b :: l) := by
        show (if _ then _ else _) = _; rw [if_pos h_a_int]
      have h_left_b : iterativeSplit ⟨seg.p1, a⟩ (b :: l) = iterativeSplit ⟨seg.p1, a⟩ l := by
        show (if _ then _ else _) = _; rw [if_neg h_b_not_left]
      have h_right_b : iterativeSplit ⟨a, seg.p2⟩ (b :: l) = iterativeSplit ⟨a, seg.p2⟩ l := by
        show (if _ then _ else _) = _; rw [if_neg h_b_not_right]
      have hRHS : iterativeSplit seg (b :: a :: l) =
          iterativeSplit ⟨seg.p1, a⟩ l ++ iterativeSplit ⟨a, seg.p2⟩ l := by
        show (if _ then _ else _) = _; rw [if_neg h_b_int]
        show (if _ then _ else _) = _; rw [if_pos h_a_int]
      rw [hLHS, h_left_b, h_right_b, hRHS]
  · by_cases h_b_int : b ∈ seg.toSet ∧ b ≠ seg.p1 ∧ b ≠ seg.p2
    · -- b interior, a NOT. Symmetric.
      have h_a_not_left := not_interior_left_subseg seg h_nondeg b a h_b_int h_a_int
      have h_a_not_right := not_interior_right_subseg seg h_nondeg b a h_b_int h_a_int
      have hLHS : iterativeSplit seg (a :: b :: l) =
          iterativeSplit ⟨seg.p1, b⟩ l ++ iterativeSplit ⟨b, seg.p2⟩ l := by
        show (if _ then _ else _) = _; rw [if_neg h_a_int]
        show (if _ then _ else _) = _; rw [if_pos h_b_int]
      have h_left_a : iterativeSplit ⟨seg.p1, b⟩ (a :: l) = iterativeSplit ⟨seg.p1, b⟩ l := by
        show (if _ then _ else _) = _; rw [if_neg h_a_not_left]
      have h_right_a : iterativeSplit ⟨b, seg.p2⟩ (a :: l) = iterativeSplit ⟨b, seg.p2⟩ l := by
        show (if _ then _ else _) = _; rw [if_neg h_a_not_right]
      have hRHS : iterativeSplit seg (b :: a :: l) =
          iterativeSplit ⟨seg.p1, b⟩ (a :: l) ++ iterativeSplit ⟨b, seg.p2⟩ (a :: l) := by
        show (if _ then _ else _) = _; rw [if_pos h_b_int]
      rw [hLHS, hRHS, h_left_a, h_right_a]
    · -- Neither interior: both reduce to iterSplit seg l.
      have hLHS : iterativeSplit seg (a :: b :: l) = iterativeSplit seg l := by
        show (if _ then _ else _) = _; rw [if_neg h_a_int]
        show (if _ then _ else _) = _; rw [if_neg h_b_int]
      have hRHS : iterativeSplit seg (b :: a :: l) = iterativeSplit seg l := by
        show (if _ then _ else _) = _; rw [if_neg h_b_int]
        show (if _ then _ else _) = _; rw [if_neg h_a_int]
      rw [hLHS, hRHS]

open Classical in
/-- Order independence of `iterativeSplit` under permutation of the points list.
    No on-seg hypothesis required. -/
private theorem iterativeSplit_perm_pts
    (seg : LineSegment) (h_nondeg : seg.p1 ≠ seg.p2)
    (pts1 pts2 : List Vector2D) (h_perm : pts1.Perm pts2) :
    List.Perm
      ((iterativeSplit seg pts1).map LineSegment.toEndpointsMultiset)
      ((iterativeSplit seg pts2).map LineSegment.toEndpointsMultiset) := by
  induction h_perm generalizing seg with
  | nil => exact List.Perm.refl _
  | cons a h ih =>
    -- pts1 = a :: l1, pts2 = a :: l2.
    by_cases h_a_int : a ∈ seg.toSet ∧ a ≠ seg.p1 ∧ a ≠ seg.p2
    · -- Split at a, recurse on each half with l1, l2.
      have hL : ∀ l, iterativeSplit seg (a :: l) =
          iterativeSplit ⟨seg.p1, a⟩ l ++ iterativeSplit ⟨a, seg.p2⟩ l := fun l => by
        show (if _ then _ else _) = _; rw [if_pos h_a_int]
      have h_left_nondeg : (LineSegment.mk seg.p1 a).p1 ≠ (LineSegment.mk seg.p1 a).p2 := by
        show seg.p1 ≠ a; intro h; exact h_a_int.2.1 h.symm
      have h_right_nondeg : (LineSegment.mk a seg.p2).p1 ≠ (LineSegment.mk a seg.p2).p2 := by
        show a ≠ seg.p2; exact h_a_int.2.2
      have h_ih_left := ih ⟨seg.p1, a⟩ h_left_nondeg
      have h_ih_right := ih ⟨a, seg.p2⟩ h_right_nondeg
      rw [hL, hL]
      simp only [List.map_append]
      exact h_ih_left.append h_ih_right
    · -- Skip a, recurse on l1, l2.
      have hL : ∀ l, iterativeSplit seg (a :: l) = iterativeSplit seg l := fun l => by
        show (if _ then _ else _) = _; rw [if_neg h_a_int]
      rw [hL, hL]
      exact ih seg h_nondeg
  | swap a b l =>
    exact (iterativeSplit_swap_general seg h_nondeg b a l)
  | trans h12 h23 ih12 ih23 =>
    exact (ih12 seg h_nondeg).trans (ih23 seg h_nondeg)

open Classical in
/-- If no point of `pts` is strictly interior to `seg`, then
    `iterativeSplit seg pts = [seg]`. -/
private theorem iterativeSplit_eq_singleton_of_no_interior
    (seg : LineSegment) (pts : List Vector2D)
    (h : ∀ p ∈ pts, ¬ (p ∈ seg.toSet ∧ p ≠ seg.p1 ∧ p ≠ seg.p2)) :
    iterativeSplit seg pts = [seg] := by
  induction pts with
  | nil => rfl
  | cons p rest ih =>
    have h_p : ¬ (p ∈ seg.toSet ∧ p ≠ seg.p1 ∧ p ≠ seg.p2) :=
      h p ((List.mem_cons_self _ _))
    have h_rest : ∀ q ∈ rest, ¬ (q ∈ seg.toSet ∧ q ≠ seg.p1 ∧ q ≠ seg.p2) :=
      fun q hq => h q (List.mem_cons_of_mem _ hq)
    have hStep : iterativeSplit seg (p :: rest) =
        iterativeSplit seg rest := by
      show (if _ then _ else _) = _
      rw [if_neg h_p]
    rw [hStep]
    exact ih h_rest

open Classical in
/-- Filtering out points that are not in `seg.toSet` does not affect
    `iterativeSplit seg pts`. -/
private theorem iterativeSplit_filter_on_seg
    (seg : LineSegment) (pts : List Vector2D) :
    iterativeSplit seg pts =
    iterativeSplit seg
      (pts.filter (fun q => decide (q ∈ seg.toSet))) := by
  -- v4.15 does not accept `induction h : e using f generalizing vars`.
  -- We first `generalize` to introduce the hypothesis explicitly.
  generalize hN : pts.length = N
  induction N using Nat.strong_induction_on generalizing seg pts with
  | _ N ih =>
  match pts, hN with
  | [], _ => rfl
  | p :: rest, hN =>
    by_cases hp_seg : p ∈ seg.toSet
    · -- p is on seg.toSet. Filter keeps p.
      have h_filter : (p :: rest).filter (fun q => decide (q ∈ seg.toSet)) =
          p :: rest.filter (fun q => decide (q ∈ seg.toSet)) := by
        simp [hp_seg]
      rw [h_filter]
      by_cases hp_int : p ∈ seg.toSet ∧ p ≠ seg.p1 ∧ p ≠ seg.p2
      · -- p strictly interior: split.
        have hLHS : iterativeSplit seg (p :: rest) =
            iterativeSplit ⟨seg.p1, p⟩ rest ++
              iterativeSplit ⟨p, seg.p2⟩ rest := by
          show (if _ then _ else _) = _; rw [if_pos hp_int]
        have hRHS : iterativeSplit seg
              (p :: rest.filter (fun q => decide (q ∈ seg.toSet))) =
            iterativeSplit ⟨seg.p1, p⟩
              (rest.filter (fun q => decide (q ∈ seg.toSet))) ++
              iterativeSplit ⟨p, seg.p2⟩
                (rest.filter (fun q => decide (q ∈ seg.toSet))) := by
          show (if _ then _ else _) = _; rw [if_pos hp_int]
        rw [hLHS, hRHS]
        have h_left_subset : (LineSegment.mk seg.p1 p).toSet ⊆ seg.toSet := by
          intro q hq
          obtain ⟨t, ht_nn, ht_le, hqx, hqy⟩ := hq
          obtain ⟨s, hs_nn, hs_le, hpx, hpy⟩ := hp_seg
          refine ⟨t * s, mul_nonneg ht_nn hs_nn, ?_, ?_, ?_⟩
          · calc t * s ≤ 1 * 1 := mul_le_mul ht_le hs_le hs_nn (by linarith)
              _ = 1 := by ring
          · simp only at hqx hpx; rw [hqx, hpx]; ring
          · simp only at hqy hpy; rw [hqy, hpy]; ring
        have h_right_subset : (LineSegment.mk p seg.p2).toSet ⊆ seg.toSet := by
          intro q hq
          obtain ⟨t, ht_nn, ht_le, hqx, hqy⟩ := hq
          obtain ⟨s, hs_nn, hs_le, hpx, hpy⟩ := hp_seg
          refine ⟨(1 - t) * s + t, ?_, ?_, ?_, ?_⟩
          · have h1 : 0 ≤ (1 - t) * s := mul_nonneg (by linarith) hs_nn
            linarith
          · have h1 : (1 - t) * s ≤ (1 - t) * 1 :=
              mul_le_mul_of_nonneg_left hs_le (by linarith)
            linarith
          · simp only at hqx hpx; rw [hqx, hpx]; ring
          · simp only at hqy hpy; rw [hqy, hpy]; ring
        have h_rest_len : rest.length < N := by
          rw [← hN]; simp
        have ih_left : iterativeSplit (LineSegment.mk seg.p1 p) rest =
            iterativeSplit (LineSegment.mk seg.p1 p)
              (rest.filter (fun q => decide (q ∈ (LineSegment.mk seg.p1 p).toSet))) :=
          ih rest.length h_rest_len (LineSegment.mk seg.p1 p) rest rfl
        have ih_right : iterativeSplit (LineSegment.mk p seg.p2) rest =
            iterativeSplit (LineSegment.mk p seg.p2)
              (rest.filter (fun q => decide (q ∈ (LineSegment.mk p seg.p2).toSet))) :=
          ih rest.length h_rest_len (LineSegment.mk p seg.p2) rest rfl
        have h_filter_left :
            rest.filter (fun q => decide (q ∈ (LineSegment.mk seg.p1 p).toSet)) =
            (rest.filter (fun q => decide (q ∈ seg.toSet))).filter
              (fun q => decide (q ∈ (LineSegment.mk seg.p1 p).toSet)) := by
          rw [List.filter_filter]
          apply List.filter_congr
          intro q _
          by_cases hqL : q ∈ (LineSegment.mk seg.p1 p).toSet
          · have hqS : q ∈ seg.toSet := h_left_subset hqL
            simp [hqL, hqS]
          · simp [hqL]
        have h_filter_right :
            rest.filter (fun q => decide (q ∈ (LineSegment.mk p seg.p2).toSet)) =
            (rest.filter (fun q => decide (q ∈ seg.toSet))).filter
              (fun q => decide (q ∈ (LineSegment.mk p seg.p2).toSet)) := by
          rw [List.filter_filter]
          apply List.filter_congr
          intro q _
          by_cases hqR : q ∈ (LineSegment.mk p seg.p2).toSet
          · have hqS : q ∈ seg.toSet := h_right_subset hqR
            simp [hqR, hqS]
          · simp [hqR]
        have h_filtered_len : (rest.filter (fun q => decide (q ∈ seg.toSet))).length < N := by
          have := List.length_filter_le (fun q => decide (q ∈ seg.toSet)) rest
          omega
        have ih_left' : iterativeSplit (LineSegment.mk seg.p1 p)
            (rest.filter (fun q => decide (q ∈ seg.toSet))) =
            iterativeSplit (LineSegment.mk seg.p1 p)
              ((rest.filter (fun q => decide (q ∈ seg.toSet))).filter
                (fun q => decide (q ∈ (LineSegment.mk seg.p1 p).toSet))) :=
          ih (rest.filter (fun q => decide (q ∈ seg.toSet))).length h_filtered_len
            (LineSegment.mk seg.p1 p) (rest.filter (fun q => decide (q ∈ seg.toSet))) rfl
        have ih_right' : iterativeSplit (LineSegment.mk p seg.p2)
            (rest.filter (fun q => decide (q ∈ seg.toSet))) =
            iterativeSplit (LineSegment.mk p seg.p2)
              ((rest.filter (fun q => decide (q ∈ seg.toSet))).filter
                (fun q => decide (q ∈ (LineSegment.mk p seg.p2).toSet))) :=
          ih (rest.filter (fun q => decide (q ∈ seg.toSet))).length h_filtered_len
            (LineSegment.mk p seg.p2) (rest.filter (fun q => decide (q ∈ seg.toSet))) rfl
        rw [ih_left, ih_left', ih_right, ih_right']
        rw [← h_filter_left, ← h_filter_right]
      · -- p NOT strictly interior, p ∈ seg.toSet.
        have h_rest_len : rest.length < N := by rw [← hN]; simp
        have hLHS : iterativeSplit seg (p :: rest) =
            iterativeSplit seg rest := by
          show (if _ then _ else _) = _; rw [if_neg hp_int]
        have hRHS : iterativeSplit seg
              (p :: rest.filter (fun q => decide (q ∈ seg.toSet))) =
            iterativeSplit seg
              (rest.filter (fun q => decide (q ∈ seg.toSet))) := by
          show (if _ then _ else _) = _; rw [if_neg hp_int]
        rw [hLHS, hRHS]
        exact ih rest.length h_rest_len seg rest rfl
    · -- p ∉ seg.toSet. Filter drops p.
      have h_rest_len : rest.length < N := by rw [← hN]; simp
      have h_filter : (p :: rest).filter (fun q => decide (q ∈ seg.toSet)) =
          rest.filter (fun q => decide (q ∈ seg.toSet)) := by
        simp [hp_seg]
      rw [h_filter]
      have hp_int : ¬ (p ∈ seg.toSet ∧ p ≠ seg.p1 ∧ p ≠ seg.p2) := by
        intro ⟨h, _, _⟩; exact hp_seg h
      have hLHS : iterativeSplit seg (p :: rest) =
          iterativeSplit seg rest := by
        show (if _ then _ else _) = _; rw [if_neg hp_int]
      rw [hLHS]
      exact ih rest.length h_rest_len seg rest rfl

/-- Two lists strictly pairwise increasing by `paramOnSeg seg` (with all elements on `seg.toSet`)
    with the same membership are equal. -/
private theorem list_eq_of_paramOnSeg_strict_pairwise_same_mem
    (seg : LineSegment) (h_nondeg : seg.p1 ≠ seg.p2)
    (l1 l2 : List Vector2D)
    (hl1 : ∀ p ∈ l1, p ∈ seg.toSet) (hl2 : ∀ p ∈ l2, p ∈ seg.toSet)
    (h1 : l1.Pairwise (fun a b => paramOnSeg seg a < paramOnSeg seg b))
    (h2 : l2.Pairwise (fun a b => paramOnSeg seg a < paramOnSeg seg b))
    (h_mem : ∀ x, x ∈ l1 ↔ x ∈ l2) :
    l1 = l2 := by
  -- Both are nodup (from strict pairwise + irrefl <).
  have h_nodup_1 : l1.Nodup :=
    h1.imp (fun {_ _} h => fun heq => by rw [heq] at h; exact lt_irrefl _ h)
  have h_nodup_2 : l2.Nodup :=
    h2.imp (fun {_ _} h => fun heq => by rw [heq] at h; exact lt_irrefl _ h)
  have h_perm : List.Perm l1 l2 :=
    perm_of_nodup_same_mem _ _ h_nodup_1 h_nodup_2 h_mem
  -- Use Perm.eq_of_pairwise with paramOnSeg-based ≤ and antisymm.
  apply perm_eq_of_pairwise_local (r := fun a b => paramOnSeg seg a ≤ paramOnSeg seg b)
    ?_ ?_ ?_ h_perm
  · -- antisymm via paramOnSeg_injective.
    intro a b ha hb hab hba
    have ha_seg : a ∈ seg.toSet := hl1 a ha
    have hb_seg : b ∈ seg.toSet := hl2 b hb
    have : paramOnSeg seg a = paramOnSeg seg b := le_antisymm hab hba
    exact paramOnSeg_injective seg h_nondeg ha_seg hb_seg this
  · exact h1.imp (fun h => le_of_lt h)
  · exact h2.imp (fun h => le_of_lt h)

/-- For a non-degenerate `seg` and points `pts` all on `seg.toSet` with no
    strictly-interior point, `splitSegmentAtPoints seg pts = [⟨seg.p1, seg.p2⟩]`. -/
private theorem splitSegmentAtPoints_eq_singleton_of_no_interior
    (seg : LineSegment) (h_nondeg : seg.p1 ≠ seg.p2)
    (pts : List Vector2D)
    (h_pts_on_seg : ∀ p ∈ pts, p ∈ seg.toSet)
    (h_no_int : ∀ p ∈ pts, ¬ (p ∈ seg.toSet ∧ p ≠ seg.p1 ∧ p ≠ seg.p2)) :
    splitSegmentAtPoints seg pts = [⟨seg.p1, seg.p2⟩] := by
  -- Compute the canonical sorted-distinct list.
  show ((dedupConsec (sortAlongSeg seg.p1 seg.p2 (seg.p1 :: seg.p2 :: pts))).zip
        (dedupConsec (sortAlongSeg seg.p1 seg.p2 (seg.p1 :: seg.p2 :: pts))).tail).map
        (fun ab : Vector2D × Vector2D => (⟨ab.1, ab.2⟩ : LineSegment)) = _
  have h_p1_seg : seg.p1 ∈ seg.toSet := ⟨0, by norm_num, by norm_num, by ring, by ring⟩
  have h_p2_seg : seg.p2 ∈ seg.toSet := ⟨1, by norm_num, by norm_num, by ring, by ring⟩
  have h_all_on : ∀ p ∈ (seg.p1 :: seg.p2 :: pts), p ∈ seg.toSet := by
    intro p hp
    rcases List.mem_cons.mp hp with h | h
    · rw [h]; exact h_p1_seg
    · rcases List.mem_cons.mp h with h | h
      · rw [h]; exact h_p2_seg
      · exact h_pts_on_seg p h
  -- mem set of all-on list is exactly {seg.p1, seg.p2}.
  have h_pts_p12 : ∀ p ∈ pts, p = seg.p1 ∨ p = seg.p2 := by
    intro p hp
    have hp_seg : p ∈ seg.toSet := h_pts_on_seg p hp
    have hp_int := h_no_int p hp
    by_contra hne
    push_neg at hne
    exact hp_int ⟨hp_seg, hne.1, hne.2⟩
  set L := dedupConsec (sortAlongSeg seg.p1 seg.p2 (seg.p1 :: seg.p2 :: pts)) with hL_def
  -- L has mem = {seg.p1, seg.p2}.
  have h_mem_L : ∀ x, x ∈ L ↔ x = seg.p1 ∨ x = seg.p2 := by
    intro x
    rw [hL_def, dedupConsec_mem_iff, sortAlongSeg_mem_iff]
    simp only [List.mem_cons]
    constructor
    · rintro (h | h | h)
      · exact Or.inl h
      · exact Or.inr h
      · exact h_pts_p12 x h
    · rintro (h | h)
      · exact Or.inl h
      · exact Or.inr (Or.inl h)
  -- L is pairwise strictly increasing by paramOnSeg.
  have h_pw_strict :
      L.Pairwise (fun a b => paramOnSeg seg a < paramOnSeg seg b) :=
    dedupConsec_sortAlongSeg_pairwise_strict seg h_nondeg
      (seg.p1 :: seg.p2 :: pts) h_all_on
  -- [seg.p1, seg.p2] is also pairwise strictly increasing.
  have h_pw_strict_target :
      ([seg.p1, seg.p2] : List Vector2D).Pairwise
        (fun a b => paramOnSeg seg a < paramOnSeg seg b) := by
    rw [List.pairwise_pair]
    rw [paramOnSeg_p1 seg h_nondeg, paramOnSeg_p2 seg h_nondeg]
    norm_num
  -- mem of [seg.p1, seg.p2]: x = seg.p1 ∨ x = seg.p2.
  have h_mem_target : ∀ x, x ∈ ([seg.p1, seg.p2] : List Vector2D) ↔ x = seg.p1 ∨ x = seg.p2 := by
    intro x; simp [List.mem_cons]
  -- Use uniqueness of sorted lists with same membership.
  have h_L_on_seg : ∀ p ∈ L, p ∈ seg.toSet := by
    intro p hp
    rw [hL_def, dedupConsec_mem_iff, sortAlongSeg_mem_iff] at hp
    exact h_all_on p hp
  have h_target_on_seg : ∀ p ∈ ([seg.p1, seg.p2] : List Vector2D), p ∈ seg.toSet := by
    intro p hp
    simp only [List.mem_cons, (List.not_mem_nil _), or_false] at hp
    rcases hp with h | h
    · rw [h]; exact h_p1_seg
    · rw [h]; exact h_p2_seg
  have h_L_eq : L = [seg.p1, seg.p2] :=
    list_eq_of_paramOnSeg_strict_pairwise_same_mem seg h_nondeg L
      [seg.p1, seg.p2] h_L_on_seg h_target_on_seg h_pw_strict h_pw_strict_target
      (fun x => by rw [h_mem_L, h_mem_target])
  -- Now compute the pairs.
  rw [h_L_eq]
  -- L.zip L.tail = [(seg.p1, seg.p2)]; map to [⟨seg.p1, seg.p2⟩].
  rfl

/-- Helper lemma: paramOnSeg endpoint or interior. -/
private theorem paramOnSeg_strict_interior_or_endpoint
    (seg : LineSegment) (h_nondeg : seg.p1 ≠ seg.p2) (p : Vector2D) (h_p : p ∈ seg.toSet) :
    0 ≤ paramOnSeg seg p ∧ paramOnSeg seg p ≤ 1 := by
  obtain ⟨_, _, h1, h2⟩ := paramOnSeg_spec seg h_nondeg p h_p
  exact ⟨h1, h2⟩

/-- Helper: `paramOnSeg seg` and `paramOnSeg ⟨m₀, seg.p2⟩` agree as orderings
    on points of `⟨m₀, seg.p2⟩.toSet`. Specifically, for `q1, q2` in
    `⟨m₀, seg.p2⟩.toSet`,
    `paramOnSeg seg q1 ≤ paramOnSeg seg q2 ↔ paramOnSeg ⟨m₀, seg.p2⟩ q1 ≤ paramOnSeg ⟨m₀, seg.p2⟩ q2`. -/
private theorem paramOnSeg_subseg_right_le_iff
    (seg : LineSegment) (h_nondeg : seg.p1 ≠ seg.p2)
    (m₀ : Vector2D) (hm₀_seg : m₀ ∈ seg.toSet) (hm₀_ne_p2 : m₀ ≠ seg.p2)
    (q1 q2 : Vector2D)
    (hq1 : q1 ∈ (LineSegment.mk m₀ seg.p2).toSet)
    (hq2 : q2 ∈ (LineSegment.mk m₀ seg.p2).toSet) :
    paramOnSeg seg q1 ≤ paramOnSeg seg q2 ↔
      paramOnSeg ⟨m₀, seg.p2⟩ q1 ≤ paramOnSeg ⟨m₀, seg.p2⟩ q2 := by
  have h_sub_nondeg : (LineSegment.mk m₀ seg.p2).p1 ≠ (LineSegment.mk m₀ seg.p2).p2 := by
    show m₀ ≠ seg.p2; exact hm₀_ne_p2
  have hm₀_param := paramOnSeg_strict_interior_or_endpoint seg h_nondeg m₀ hm₀_seg
  -- Express qi in seg's parameterization. q ∈ ⟨m₀, p2⟩.toSet means
  -- q = (1 - s) m₀ + s p2 for some s ∈ [0, 1].
  -- m₀ = (1 - tm) p1 + tm p2 (for tm := paramOnSeg seg m₀).
  -- Hence q = (1 - (tm + s(1-tm))) p1 + (tm + s(1-tm)) p2.
  -- So paramOnSeg seg q = tm + s * (1 - tm).
  -- And paramOnSeg ⟨m₀, p2⟩ q = s.
  -- 1 - tm > 0 since m₀ ≠ p2 ⇒ tm < 1.
  have h_tm_lt : paramOnSeg seg m₀ < 1 := by
    rcases lt_or_eq_of_le hm₀_param.2 with hlt | heq
    · exact hlt
    · exfalso; apply hm₀_ne_p2
      apply paramOnSeg_injective seg h_nondeg hm₀_seg
        ⟨1, by norm_num, by norm_num, by ring, by ring⟩
      rw [heq, paramOnSeg_p2 seg h_nondeg]
  set tm := paramOnSeg seg m₀ with htm_def
  set s1 := paramOnSeg ⟨m₀, seg.p2⟩ q1 with hs1_def
  set s2 := paramOnSeg ⟨m₀, seg.p2⟩ q2 with hs2_def
  -- Compute paramOnSeg seg q1 in terms of tm and s1.
  -- q1 ∈ ⟨m₀, p2⟩.toSet: q1 = (1 - s1) m₀ + s1 p2 (using paramOnSeg_spec).
  -- Combined with m₀ = (1 - tm) p1 + tm p2:
  -- q1 = (1 - s1)(1 - tm) p1 + ((1 - s1) tm + s1) p2.
  -- So paramOnSeg seg q1 has coefficient at p2 = (1 - s1) tm + s1 = tm + s1 (1 - tm).
  obtain ⟨hq1x, hq1y, hs1_nn, hs1_le⟩ :=
    paramOnSeg_spec ⟨m₀, seg.p2⟩ h_sub_nondeg q1 hq1
  obtain ⟨hq2x, hq2y, hs2_nn, hs2_le⟩ :=
    paramOnSeg_spec ⟨m₀, seg.p2⟩ h_sub_nondeg q2 hq2
  obtain ⟨hmx, hmy, _, _⟩ := paramOnSeg_spec seg h_nondeg m₀ hm₀_seg
  -- q1 ∈ seg.toSet — need to show this.
  have hq1_seg : q1 ∈ seg.toSet := by
    obtain ⟨t1, ht1_nn, ht1_le, hqx1, hqy1⟩ := hq1
    obtain ⟨tm', htm_nn, htm_le, hmx', hmy'⟩ := hm₀_seg
    refine ⟨(1 - t1) * tm' + t1, ?_, ?_, ?_, ?_⟩
    · have : 0 ≤ (1 - t1) * tm' := mul_nonneg (by linarith) htm_nn
      linarith
    · have : (1 - t1) * tm' ≤ (1 - t1) * 1 := by
        apply mul_le_mul_of_nonneg_left htm_le (by linarith)
      linarith
    · simp only at hqx1 hmx'; rw [hqx1, hmx']; ring
    · simp only at hqy1 hmy'; rw [hqy1, hmy']; ring
  have hq2_seg : q2 ∈ seg.toSet := by
    obtain ⟨t2, ht2_nn, ht2_le, hqx2, hqy2⟩ := hq2
    obtain ⟨tm', htm_nn, htm_le, hmx', hmy'⟩ := hm₀_seg
    refine ⟨(1 - t2) * tm' + t2, ?_, ?_, ?_, ?_⟩
    · have : 0 ≤ (1 - t2) * tm' := mul_nonneg (by linarith) htm_nn
      linarith
    · have : (1 - t2) * tm' ≤ (1 - t2) * 1 := by
        apply mul_le_mul_of_nonneg_left htm_le (by linarith)
      linarith
    · simp only at hqx2 hmx'; rw [hqx2, hmx']; ring
    · simp only at hqy2 hmy'; rw [hqy2, hmy']; ring
  obtain ⟨hq1xs, hq1ys, _, _⟩ := paramOnSeg_spec seg h_nondeg q1 hq1_seg
  obtain ⟨hq2xs, hq2ys, _, _⟩ := paramOnSeg_spec seg h_nondeg q2 hq2_seg
  set t1 := paramOnSeg seg q1 with ht1_def
  set t2 := paramOnSeg seg q2 with ht2_def
  -- Show t1 = tm + s1 * (1 - tm). Use injectivity:
  -- both are coefficients of p2 in expressing q1 in terms of p1, p2.
  -- We have q1.x = (1 - t1) p1.x + t1 p2.x (from hq1xs).
  -- We also have q1.x = (1 - s1) m₀.x + s1 p2.x = (1 - s1)((1-tm) p1.x + tm p2.x) + s1 p2.x
  --                  = (1 - s1)(1 - tm) p1.x + ((1 - s1) tm + s1) p2.x
  -- Equating coefficients (using paramOnSeg uniqueness on segment):
  have h_t1_eq : t1 = tm + s1 * (1 - tm) := by
    -- Use paramOnSeg_injective: t1 corresponds to q1 in seg's param.
    -- We construct another expression of q1 as a convex combination of p1, p2,
    -- and show it equals t1 via uniqueness.
    have hq1_alt : q1 = ⟨(1 - (tm + s1 * (1 - tm))) * seg.p1.x + (tm + s1 * (1 - tm)) * seg.p2.x,
                       (1 - (tm + s1 * (1 - tm))) * seg.p1.y + (tm + s1 * (1 - tm)) * seg.p2.y⟩ := by
      apply Vector2D.ext
      · simp only at hq1x hmx
        rw [hq1x, hmx]; ring
      · simp only at hq1y hmy
        rw [hq1y, hmy]; ring
    -- t1 := paramOnSeg seg q1.
    -- So q1.x = (1 - t1) p1.x + t1 p2.x.
    -- Compare with hq1_alt.x: coefficient of p2.x is (tm + s1*(1-tm)).
    -- By paramOnSeg_injective (or direct ext on linear independence), t1 = tm + s1*(1-tm).
    -- Construct v := the alternative parameterized point and use injectivity.
    set t' := tm + s1 * (1 - tm) with ht'_def
    have ht'_nn : 0 ≤ t' := by
      rw [ht'_def]
      have : 0 ≤ s1 * (1 - tm) := mul_nonneg hs1_nn (by linarith)
      have htm_nn : 0 ≤ tm := hm₀_param.1
      linarith
    have ht'_le : t' ≤ 1 := by
      rw [ht'_def]
      have : s1 * (1 - tm) ≤ 1 * (1 - tm) :=
        mul_le_mul_of_nonneg_right hs1_le (by linarith)
      linarith
    have hq1_eq_alt : q1 = ⟨(1 - (tm + s1 * (1 - tm))) * seg.p1.x +
                       (tm + s1 * (1 - tm)) * seg.p2.x,
                       (1 - (tm + s1 * (1 - tm))) * seg.p1.y +
                       (tm + s1 * (1 - tm)) * seg.p2.y⟩ := by
      apply Vector2D.ext
      · simp only at hq1x hmx
        rw [hq1x, hmx]; ring
      · simp only at hq1y hmy
        rw [hq1y, hmy]; ring
    -- paramOnSeg seg of an explicitly paramaterized point with param t (in [0,1]) equals t.
    -- We use injectivity: paramOnSeg seg P = paramOnSeg seg Q ↔ P = Q for P, Q ∈ seg.toSet.
    -- paramOnSeg seg of the parameterized point with t' = tm + s1*(1-tm) is t'.
    have h_param_param :
        paramOnSeg seg ⟨(1 - (tm + s1 * (1 - tm))) * seg.p1.x +
                       (tm + s1 * (1 - tm)) * seg.p2.x,
                       (1 - (tm + s1 * (1 - tm))) * seg.p1.y +
                       (tm + s1 * (1 - tm)) * seg.p2.y⟩ = tm + s1 * (1 - tm) := by
      -- Compute explicitly via paramOnSeg's def.
      show (if _ then _ else _ : ℚ) = _
      by_cases hxd : seg.p2.x ≠ seg.p1.x
      · rw [if_pos hxd]
        have hxd' : seg.p2.x - seg.p1.x ≠ 0 := sub_ne_zero.mpr hxd
        field_simp
        ring
      · push_neg at hxd
        rw [if_neg (by push_neg; exact hxd)]
        have hyd : seg.p2.y ≠ seg.p1.y := by
          intro hye; apply h_nondeg; ext; exact hxd.symm; exact hye.symm
        have hyd' : seg.p2.y - seg.p1.y ≠ 0 := sub_ne_zero.mpr hyd
        field_simp
        ring
    rw [ht1_def, hq1_eq_alt, h_param_param]
  have h_t2_eq : t2 = tm + s2 * (1 - tm) := by
    have hq2_eq_alt : q2 = ⟨(1 - (tm + s2 * (1 - tm))) * seg.p1.x +
                       (tm + s2 * (1 - tm)) * seg.p2.x,
                       (1 - (tm + s2 * (1 - tm))) * seg.p1.y +
                       (tm + s2 * (1 - tm)) * seg.p2.y⟩ := by
      apply Vector2D.ext
      · simp only at hq2x hmx
        rw [hq2x, hmx]; ring
      · simp only at hq2y hmy
        rw [hq2y, hmy]; ring
    have h_param_param :
        paramOnSeg seg ⟨(1 - (tm + s2 * (1 - tm))) * seg.p1.x +
                       (tm + s2 * (1 - tm)) * seg.p2.x,
                       (1 - (tm + s2 * (1 - tm))) * seg.p1.y +
                       (tm + s2 * (1 - tm)) * seg.p2.y⟩ = tm + s2 * (1 - tm) := by
      show (if _ then _ else _ : ℚ) = _
      by_cases hxd : seg.p2.x ≠ seg.p1.x
      · rw [if_pos hxd]
        have hxd' : seg.p2.x - seg.p1.x ≠ 0 := sub_ne_zero.mpr hxd
        field_simp
        ring
      · push_neg at hxd
        rw [if_neg (by push_neg; exact hxd)]
        have hyd : seg.p2.y ≠ seg.p1.y := by
          intro hye; apply h_nondeg; ext; exact hxd.symm; exact hye.symm
        have hyd' : seg.p2.y - seg.p1.y ≠ 0 := sub_ne_zero.mpr hyd
        field_simp
        ring
    rw [ht2_def, hq2_eq_alt, h_param_param]
  -- Goal: t1 ≤ t2 ↔ s1 ≤ s2.
  rw [h_t1_eq, h_t2_eq]
  constructor
  · intro h
    have h_diff : s1 * (1 - tm) ≤ s2 * (1 - tm) := by linarith
    have h_pos : (0 : ℚ) < 1 - tm := by linarith
    by_contra h_not
    push_neg at h_not
    have : s2 * (1 - tm) < s1 * (1 - tm) :=
      mul_lt_mul_of_pos_right h_not h_pos
    linarith
  · intro h
    have h_diff : s1 * (1 - tm) ≤ s2 * (1 - tm) :=
      mul_le_mul_of_nonneg_right h (by linarith)
    linarith

open Classical in
/-- Splice lemma: when m₀ is a strictly-interior point of seg with no point in
    rest strictly interior to ⟨seg.p1, m₀⟩, splitting at m₀ gives the same toEM
    multiset as taking ⟨seg.p1, m₀⟩ alone plus splitSegmentAtPoints on the right
    half with rest filtered to ⟨m₀, seg.p2⟩.toSet. -/
private theorem splitSegmentAtPoints_split_at_min_perm
    (seg : LineSegment) (h_nondeg : seg.p1 ≠ seg.p2)
    (m₀ : Vector2D) (hm₀_int : m₀ ∈ seg.toSet ∧ m₀ ≠ seg.p1 ∧ m₀ ≠ seg.p2)
    (rest : List Vector2D) (h_rest_on_seg : ∀ q ∈ rest, q ∈ seg.toSet)
    (h_rest_no_left : ∀ q ∈ rest, ¬ (q ∈ (LineSegment.mk seg.p1 m₀).toSet ∧
        q ≠ (LineSegment.mk seg.p1 m₀).p1 ∧ q ≠ (LineSegment.mk seg.p1 m₀).p2)) :
    List.Perm
      ((splitSegmentAtPoints seg (m₀ :: rest)).map LineSegment.toEndpointsMultiset)
      ((([LineSegment.mk seg.p1 m₀] : List LineSegment) ++
        splitSegmentAtPoints (LineSegment.mk m₀ seg.p2)
        (rest.filter (fun q => decide (q ∈ (LineSegment.mk m₀ seg.p2).toSet)))).map
        LineSegment.toEndpointsMultiset) := by
  set rest' := rest.filter (fun q => decide (q ∈ (LineSegment.mk m₀ seg.p2).toSet))
    with hrest'_def
  have h_left_nondeg : (LineSegment.mk seg.p1 m₀).p1 ≠ (LineSegment.mk seg.p1 m₀).p2 := by
    show seg.p1 ≠ m₀; intro h; exact hm₀_int.2.1 h.symm
  have h_right_nondeg : (LineSegment.mk m₀ seg.p2).p1 ≠ (LineSegment.mk m₀ seg.p2).p2 := by
    show m₀ ≠ seg.p2; exact hm₀_int.2.2
  have h_m₀_param : 0 < paramOnSeg seg m₀ ∧ paramOnSeg seg m₀ < 1 :=
    paramOnSeg_strict_interior seg h_nondeg m₀ hm₀_int.1 hm₀_int.2.1 hm₀_int.2.2
  have h_p1_seg : seg.p1 ∈ seg.toSet := ⟨0, by norm_num, by norm_num, by ring, by ring⟩
  have h_p2_seg : seg.p2 ∈ seg.toSet := ⟨1, by norm_num, by norm_num, by ring, by ring⟩
  -- Define the canonical sorted-distinct list for LHS.
  set Lall := dedupConsec (sortAlongSeg seg.p1 seg.p2 (seg.p1 :: seg.p2 :: m₀ :: rest))
    with hLall_def
  -- Define the canonical sorted-distinct list for the right half.
  set Lright := dedupConsec (sortAlongSeg m₀ seg.p2 (m₀ :: seg.p2 :: rest'))
    with hLright_def
  -- The splice claim: Lall = seg.p1 :: Lright.
  -- Proof: both lists are nodup, sorted strict by paramOnSeg seg, and have same mem set.
  -- We prove Lall = seg.p1 :: Lright as a list equality.
  -- Step 1: rest' is on ⟨m₀, p2⟩.toSet.
  have h_rest'_on_right : ∀ q ∈ rest', q ∈ (LineSegment.mk m₀ seg.p2).toSet := by
    intro q hq
    rw [hrest'_def, List.mem_filter, decide_eq_true_eq] at hq
    exact hq.2
  -- Step 2: rest' on seg.toSet (since ⟨m₀, p2⟩.toSet ⊆ seg.toSet).
  have h_right_subset : (LineSegment.mk m₀ seg.p2).toSet ⊆ seg.toSet := by
    intro q hq
    obtain ⟨t, ht_nn, ht_le, hqx, hqy⟩ := hq
    obtain ⟨s, hs_nn, hs_le, hpx, hpy⟩ := hm₀_int.1
    refine ⟨(1 - t) * s + t, ?_, ?_, ?_, ?_⟩
    · have h1 : 0 ≤ (1 - t) * s := mul_nonneg (by linarith) hs_nn
      linarith
    · have h1 : (1 - t) * s ≤ (1 - t) * 1 :=
        mul_le_mul_of_nonneg_left hs_le (by linarith)
      linarith
    · simp only at hqx hpx; rw [hqx, hpx]; ring
    · simp only at hqy hpy; rw [hqy, hpy]; ring
  have h_rest'_on_seg : ∀ q ∈ rest', q ∈ seg.toSet :=
    fun q hq => h_right_subset (h_rest'_on_right q hq)
  -- Step 3: Mem set equality.
  -- Mem Lall = {seg.p1, seg.p2, m₀} ∪ set(rest).
  -- Mem (seg.p1 :: Lright) = {seg.p1} ∪ ({m₀, seg.p2} ∪ set(rest')) = {seg.p1, m₀, seg.p2} ∪ set(rest').
  -- These are equal: any q in rest \ rest' has q ∉ ⟨m₀, p2⟩.toSet, so by h_rest_no_left
  -- and analysis, q = seg.p1 (which is already in {seg.p1}).
  have h_rest_classify : ∀ q ∈ rest, q = seg.p1 ∨ q ∈ (LineSegment.mk m₀ seg.p2).toSet := by
    intro q hq
    have hq_seg : q ∈ seg.toSet := h_rest_on_seg q hq
    by_cases h_q_int_seg : q ∈ seg.toSet ∧ q ≠ seg.p1 ∧ q ≠ seg.p2
    · -- q is interior to seg. By h_rest_no_left, q ∉ ⟨seg.p1, m₀⟩.toSet OR q = seg.p1 OR q = m₀.
      have h_no_left := h_rest_no_left q hq
      -- q is interior to seg ⇒ q ≠ seg.p1, q ≠ m₀ (if q ≠ m₀).
      by_cases h_q_eq_m₀ : q = m₀
      · right; rw [h_q_eq_m₀]
        -- m₀ ∈ ⟨m₀, p2⟩.toSet.
        exact ⟨0, by norm_num, by norm_num, by ring, by ring⟩
      · -- q ≠ m₀, q ≠ seg.p1, q interior. So h_no_left gives ¬ (q ∈ ⟨seg.p1, m₀⟩.toSet ∧ q ≠ seg.p1 ∧ q ≠ m₀).
        push_neg at h_no_left
        have h_q_ne_p1 : q ≠ seg.p1 := h_q_int_seg.2.1
        -- The implications: from h_no_left: q ∈ ⟨seg.p1, m₀⟩.toSet → q = seg.p1 ∨ q = m₀.
        -- But q ≠ seg.p1 and q ≠ m₀, so q ∉ ⟨seg.p1, m₀⟩.toSet.
        have hq_not_left : q ∉ (LineSegment.mk seg.p1 m₀).toSet := by
          intro h_in_left
          exact h_q_eq_m₀ (h_no_left h_in_left h_q_ne_p1)
        -- q ∈ seg.toSet. So q ∈ ⟨seg.p1, m₀⟩.toSet ∪ ⟨m₀, p2⟩.toSet (covers seg).
        -- Use mem_left_subSeg_iff to characterize.
        have h_param_q_seg : 0 ≤ paramOnSeg seg q ∧ paramOnSeg seg q ≤ 1 :=
          paramOnSeg_strict_interior_or_endpoint seg h_nondeg q hq_seg
        have h_param_m₀ : paramOnSeg seg m₀ < 1 := h_m₀_param.2
        -- q ∉ ⟨seg.p1, m₀⟩ means paramOnSeg q > paramOnSeg m₀ (since q ∈ seg.toSet).
        -- More precisely: by mem_left_subSeg_iff, q ∈ ⟨p1, m₀⟩.toSet ↔ paramOnSeg q ≤ paramOnSeg m₀.
        -- So q ∉ ⟨p1, m₀⟩ ↔ paramOnSeg q > paramOnSeg m₀.
        have h_q_param_gt : paramOnSeg seg q > paramOnSeg seg m₀ := by
          by_contra h_le
          push_neg at h_le
          exact hq_not_left
            ((mem_left_subSeg_iff seg h_nondeg m₀ hm₀_int.1 q hq_seg).mpr h_le)
        right
        exact (mem_right_subSeg_iff seg h_nondeg m₀ hm₀_int.1 q hq_seg).mpr (le_of_lt h_q_param_gt)
    · -- q NOT interior. q ∈ seg.toSet, so q = seg.p1 or q = seg.p2.
      push_neg at h_q_int_seg
      by_cases h_q_eq_p1 : q = seg.p1
      · exact Or.inl h_q_eq_p1
      · by_cases h_q_eq_p2 : q = seg.p2
        · -- q = seg.p2 ∈ ⟨m₀, p2⟩.toSet.
          right; rw [h_q_eq_p2]
          exact ⟨1, by norm_num, by norm_num, by ring, by ring⟩
        · -- q ∈ seg.toSet, q ≠ p1, q ≠ p2: contradiction with NOT interior.
          exact absurd (h_q_int_seg hq_seg h_q_eq_p1) h_q_eq_p2
  have h_mem_Lall : ∀ x, x ∈ Lall ↔
      x = seg.p1 ∨ x = seg.p2 ∨ x = m₀ ∨ x ∈ rest := by
    intro x
    rw [hLall_def, dedupConsec_mem_iff, sortAlongSeg_mem_iff]
    simp only [List.mem_cons]
  have h_mem_Lright : ∀ x, x ∈ Lright ↔
      x = m₀ ∨ x = seg.p2 ∨ x ∈ rest' := by
    intro x
    rw [hLright_def, dedupConsec_mem_iff, sortAlongSeg_mem_iff]
    simp only [List.mem_cons]
  have h_mem_eq : ∀ x, x ∈ Lall ↔ x ∈ (seg.p1 :: Lright) := by
    intro x
    rw [List.mem_cons, h_mem_Lright, h_mem_Lall]
    constructor
    · rintro (h | h | h | h)
      · exact Or.inl h
      · exact Or.inr (Or.inr (Or.inl h))
      · exact Or.inr (Or.inl h)
      · -- x ∈ rest. By classify: x = seg.p1 OR x ∈ ⟨m₀, p2⟩.toSet.
        rcases h_rest_classify x h with hp1 | hright
        · exact Or.inl hp1
        · -- x ∈ ⟨m₀, p2⟩.toSet ⇒ x ∈ rest' (since rest' = rest.filter ∈ that toSet).
          right; right; right
          rw [hrest'_def]
          simp only [List.mem_filter, decide_eq_true_eq]
          exact ⟨h, hright⟩
    · rintro (h | h | h | h)
      · exact Or.inl h
      · exact Or.inr (Or.inr (Or.inl h))
      · exact Or.inr (Or.inl h)
      · -- x ∈ rest' ⊆ rest.
        right; right; right
        rw [hrest'_def, List.mem_filter] at h
        exact h.1
  -- Step 4: Pairwise strict by paramOnSeg seg on Lall.
  have h_all_on : ∀ p ∈ (seg.p1 :: seg.p2 :: m₀ :: rest), p ∈ seg.toSet := by
    intro p hp
    rcases List.mem_cons.mp hp with h | h
    · rw [h]; exact h_p1_seg
    · rcases List.mem_cons.mp h with h | h
      · rw [h]; exact h_p2_seg
      · rcases List.mem_cons.mp h with h | h
        · rw [h]; exact hm₀_int.1
        · exact h_rest_on_seg p h
  have h_pw_Lall : Lall.Pairwise (fun a b => paramOnSeg seg a < paramOnSeg seg b) :=
    dedupConsec_sortAlongSeg_pairwise_strict seg h_nondeg
      (seg.p1 :: seg.p2 :: m₀ :: rest) h_all_on
  -- Step 5: Pairwise strict by paramOnSeg seg on (seg.p1 :: Lright).
  -- For Lright: pairwise by paramOnSeg ⟨m₀, p2⟩, but on points in ⟨m₀, p2⟩.toSet, this matches paramOnSeg seg.
  have h_right_all_on : ∀ p ∈ (m₀ :: seg.p2 :: rest'), p ∈ (LineSegment.mk m₀ seg.p2).toSet := by
    intro p hp
    rcases List.mem_cons.mp hp with h | h
    · rw [h]; exact ⟨0, by norm_num, by norm_num, by ring, by ring⟩
    · rcases List.mem_cons.mp h with h | h
      · rw [h]; exact ⟨1, by norm_num, by norm_num, by ring, by ring⟩
      · exact h_rest'_on_right p h
  have h_pw_Lright_sub : Lright.Pairwise
      (fun a b => paramOnSeg ⟨m₀, seg.p2⟩ a < paramOnSeg ⟨m₀, seg.p2⟩ b) :=
    dedupConsec_sortAlongSeg_pairwise_strict ⟨m₀, seg.p2⟩ h_right_nondeg
      (m₀ :: seg.p2 :: rest') h_right_all_on
  have h_Lright_on_right : ∀ x ∈ Lright, x ∈ (LineSegment.mk m₀ seg.p2).toSet := by
    intro x hx
    rcases (h_mem_Lright x).mp hx with h | h | h
    · rw [h]; exact ⟨0, by norm_num, by norm_num, by ring, by ring⟩
    · rw [h]; exact ⟨1, by norm_num, by norm_num, by ring, by ring⟩
    · exact h_rest'_on_right x h
  have h_pw_Lright_on_seg : Lright.Pairwise
      (fun a b => paramOnSeg seg a < paramOnSeg seg b) := by
    -- Convert via paramOnSeg_subseg_right_le_iff.
    apply h_pw_Lright_sub.imp_of_mem
    intro a b ha hb hab
    have ha_right := h_Lright_on_right a ha
    have hb_right := h_Lright_on_right b hb
    rw [show (paramOnSeg seg a < paramOnSeg seg b) ↔ ¬ (paramOnSeg seg b ≤ paramOnSeg seg a) from
      ⟨not_le_of_gt, lt_of_not_ge⟩]
    intro h_le
    have := (paramOnSeg_subseg_right_le_iff seg h_nondeg m₀ hm₀_int.1 hm₀_int.2.2
      b a hb_right ha_right).mp h_le
    linarith
  -- Step 6: seg.p1 :: Lright pairwise strict by paramOnSeg seg.
  -- We need: paramOnSeg seg seg.p1 < paramOnSeg seg x for all x in Lright.
  have h_p1_lt_all : ∀ x ∈ Lright, paramOnSeg seg seg.p1 < paramOnSeg seg x := by
    intro x hx
    rw [paramOnSeg_p1 seg h_nondeg]
    have hx_right := h_Lright_on_right x hx
    -- x ∈ ⟨m₀, p2⟩.toSet ⇒ x.toSet has param ≥ paramOnSeg seg m₀ > 0.
    have h_x_seg : x ∈ seg.toSet := h_right_subset hx_right
    have h_x_param_ge : paramOnSeg seg m₀ ≤ paramOnSeg seg x :=
      (mem_right_subSeg_iff seg h_nondeg m₀ hm₀_int.1 x h_x_seg).mp hx_right
    linarith [h_m₀_param.1]
  have h_pw_p1_Lright : (seg.p1 :: Lright).Pairwise
      (fun a b => paramOnSeg seg a < paramOnSeg seg b) := by
    apply List.pairwise_cons.mpr
    exact ⟨h_p1_lt_all, h_pw_Lright_on_seg⟩
  -- Step 7: By uniqueness of pairwise+nodup with same membership.
  have h_Lall_on_seg : ∀ p ∈ Lall, p ∈ seg.toSet := by
    intro p hp
    rw [hLall_def, dedupConsec_mem_iff, sortAlongSeg_mem_iff] at hp
    exact h_all_on p hp
  have h_p1_Lright_on_seg : ∀ p ∈ (seg.p1 :: Lright), p ∈ seg.toSet := by
    intro p hp
    rcases List.mem_cons.mp hp with h | h
    · rw [h]; exact h_p1_seg
    · exact h_right_subset (h_Lright_on_right p h)
  have h_Lall_eq : Lall = seg.p1 :: Lright :=
    list_eq_of_paramOnSeg_strict_pairwise_same_mem seg h_nondeg Lall (seg.p1 :: Lright)
      h_Lall_on_seg h_p1_Lright_on_seg h_pw_Lall h_pw_p1_Lright h_mem_eq
  -- Now compute splitSegmentAtPoints seg (m₀ :: rest) and splitSegmentAtPoints ⟨m₀, p2⟩ rest'
  -- in terms of Lall and Lright.
  have h_split_seg_eq :
      splitSegmentAtPoints seg (m₀ :: rest) =
      (Lall.zip Lall.tail).map (fun ab : Vector2D × Vector2D => (⟨ab.1, ab.2⟩ : LineSegment)) := by
    show ((dedupConsec (sortAlongSeg seg.p1 seg.p2 (seg.p1 :: seg.p2 :: m₀ :: rest))).zip
          (dedupConsec (sortAlongSeg seg.p1 seg.p2 (seg.p1 :: seg.p2 :: m₀ :: rest))).tail).map _ = _
    rfl
  rw [h_split_seg_eq, h_Lall_eq]
  -- (seg.p1 :: Lright).tail = Lright.
  -- (seg.p1 :: Lright).zip Lright = (seg.p1, Lright.head?) :: Lright.zip Lright.tail.
  -- Cases on Lright.
  cases hLR : Lright with
  | nil =>
    -- Lright is empty. Then mem (seg.p1 :: Lright) = {seg.p1} only. But seg.p2 ∈ Lright (it's in mem).
    -- Contradiction.
    exfalso
    have : seg.p2 ∈ Lright := by
      rw [h_mem_Lright]; right; left; rfl
    rw [hLR] at this
    exact (List.not_mem_nil _) this
  | cons h_head h_tail =>
    -- Lright = h_head :: h_tail.
    simp only [List.zip_cons_cons, List.tail_cons, List.map_cons]
    -- Goal: ⟨seg.p1, h_head⟩.toEM :: ((h_head :: h_tail).zip h_tail).map.map ~
    --       [⟨seg.p1, m₀⟩].map.toEM ++ (splitSegmentAtPoints ⟨m₀, p2⟩ rest').map.toEM
    -- Note: h_head must be m₀ (since seg.p1 :: Lright is sorted strict by paramOnSeg seg
    -- and seg.p1 has minimum param, m₀ is next smallest in the mem set).
    -- Actually m₀ is in Lright, and Lright is sorted, so m₀ might not be h_head if there's a smaller element.
    -- Wait — Lright is sorted by paramOnSeg ⟨m₀, p2⟩, and m₀ has the minimum param (= 0)
    -- in ⟨m₀, p2⟩'s param. So m₀ IS the first element of Lright.
    have h_head_eq_m₀ : h_head = m₀ := by
      -- m₀ ∈ Lright (from h_mem_Lright, m₀ = m₀).
      have hm₀_in_Lright : m₀ ∈ Lright := (h_mem_Lright m₀).mpr (Or.inl rfl)
      rw [hLR] at hm₀_in_Lright
      simp only [List.mem_cons] at hm₀_in_Lright
      rcases hm₀_in_Lright with h | h
      · exact h.symm
      · -- m₀ ∈ h_tail, but h_pw_Lright_sub gives all elements of h_tail have param > h_head.
        -- Also m₀ has param 0 in ⟨m₀, p2⟩, which is the minimum. h_head is in Lright,
        -- so paramOnSeg ⟨m₀, p2⟩ h_head ≥ 0. The strict pairwise gives paramOnSeg h_head < paramOnSeg m₀ = 0.
        -- Contradiction.
        exfalso
        have h_head_in : h_head ∈ Lright := by rw [hLR]; exact (List.mem_cons_self _ _)
        have h_head_right := h_Lright_on_right h_head h_head_in
        have h_head_param_nn : 0 ≤ paramOnSeg ⟨m₀, seg.p2⟩ h_head := by
          have := paramOnSeg_spec ⟨m₀, seg.p2⟩ h_right_nondeg h_head h_head_right
          exact this.2.2.1
        rw [hLR] at h_pw_Lright_sub
        have := List.pairwise_cons.mp h_pw_Lright_sub
        have h_lt := this.1 m₀ h
        rw [paramOnSeg_p1 ⟨m₀, seg.p2⟩ h_right_nondeg] at h_lt
        linarith
    -- splitSegmentAtPoints ⟨m₀, p2⟩ rest' equals (Lright.zip Lright.tail).map.
    have h_split_right :
        splitSegmentAtPoints (LineSegment.mk m₀ seg.p2) rest' =
        (Lright.zip Lright.tail).map
          (fun ab : Vector2D × Vector2D => (⟨ab.1, ab.2⟩ : LineSegment)) := rfl
    rw [h_split_right, hLR, h_head_eq_m₀]
    simp only [List.tail_cons, List.map_cons,
               List.singleton_append]
    exact List.Perm.refl _

open Classical in
/-- For a non-degenerate segment `seg` and a list of points all on `seg.toSet`,
    `iterativeSplit seg pts` and `splitSegmentAtPoints seg pts` produce the
    same multiset of endpoint pairs. -/
private theorem iterativeSplit_perm_splitSegmentAtPoints
    (seg : LineSegment) (h_nondeg : seg.p1 ≠ seg.p2)
    (pts : List Vector2D) (h_pts_on_seg : ∀ p ∈ pts, p ∈ seg.toSet) :
    List.Perm
      ((iterativeSplit seg pts).map LineSegment.toEndpointsMultiset)
      ((splitSegmentAtPoints seg pts).map LineSegment.toEndpointsMultiset) := by
  -- Strong induction on pts.length, generalizing seg.
  generalize hN : pts.length = N
  induction N using Nat.strong_induction_on generalizing seg pts with
  | _ N ih =>
  -- Strategy: case split on existence of a strictly-interior point.
  by_cases h_exists_int : ∃ p ∈ pts, p ∈ seg.toSet ∧ p ≠ seg.p1 ∧ p ≠ seg.p2
  · -- Pick the strictly-interior point with smallest paramOnSeg.
    obtain ⟨m, hm_mem, hm_seg, hm_ne1, hm_ne2⟩ := h_exists_int
    set ints := pts.filter (fun p => decide (p ∈ seg.toSet ∧ p ≠ seg.p1 ∧ p ≠ seg.p2))
      with hints_def
    have hm_in_ints : m ∈ ints := by
      rw [hints_def]
      simp only [List.mem_filter, decide_eq_true_eq]
      exact ⟨hm_mem, hm_seg, hm_ne1, hm_ne2⟩
    -- Find element of ints with minimum paramOnSeg.
    have h_min_exists : ∃ m₀ ∈ ints, ∀ q ∈ ints, paramOnSeg seg m₀ ≤ paramOnSeg seg q := by
      have h_aux : ∀ (l : List Vector2D), l ≠ [] →
          ∃ m₀ ∈ l, ∀ q ∈ l, paramOnSeg seg m₀ ≤ paramOnSeg seg q := by
        intro l hne
        induction l with
        | nil => exact absurd rfl hne
        | cons a rest ihR =>
          by_cases hR : rest = []
          · subst hR
            exact ⟨a, (List.mem_cons_self _ _), fun q hq => by
              rcases List.mem_cons.mp hq with h | h
              · rw [h]
              · exact absurd h ((List.not_mem_nil _))⟩
          · obtain ⟨m', hm'_mem, hm'_min⟩ := ihR hR
            by_cases h_le : paramOnSeg seg a ≤ paramOnSeg seg m'
            · refine ⟨a, (List.mem_cons_self _ _), fun q hq => ?_⟩
              rcases List.mem_cons.mp hq with h | h
              · rw [h]
              · exact le_trans h_le (hm'_min q h)
            · push_neg at h_le
              refine ⟨m', List.mem_cons_of_mem _ hm'_mem, fun q hq => ?_⟩
              rcases List.mem_cons.mp hq with h | h
              · rw [h]; linarith
              · exact hm'_min q h
      exact h_aux ints (fun h => by rw [h] at hm_in_ints; exact (List.not_mem_nil _) hm_in_ints)
    obtain ⟨m₀, hm₀_in_ints, hm₀_min⟩ := h_min_exists
    have hm₀_in_pts : m₀ ∈ pts := by
      rw [hints_def, List.mem_filter] at hm₀_in_ints; exact hm₀_in_ints.1
    have hm₀_int : m₀ ∈ seg.toSet ∧ m₀ ≠ seg.p1 ∧ m₀ ≠ seg.p2 := by
      rw [hints_def, List.mem_filter, decide_eq_true_eq] at hm₀_in_ints
      exact hm₀_in_ints.2
    -- Permute pts to (m₀ :: pts.erase m₀).
    have h_perm_pts : pts.Perm (m₀ :: pts.erase m₀) := List.perm_cons_erase hm₀_in_pts
    have h_iterPerm := iterativeSplit_perm_pts seg h_nondeg pts (m₀ :: pts.erase m₀) h_perm_pts
    have h_pts_on_seg' : ∀ p ∈ (m₀ :: pts.erase m₀), p ∈ seg.toSet := by
      intro p hp
      rcases List.mem_cons.mp hp with hp_eq | hp_rest
      · rw [hp_eq]; exact hm₀_int.1
      · exact h_pts_on_seg p (List.mem_of_mem_erase hp_rest)
    have h_set_eq : ∀ p, p ∈ pts ↔ p ∈ (m₀ :: pts.erase m₀) := by
      intro p
      constructor
      · intro hp
        by_cases hpm : p = m₀
        · exact hpm ▸ (List.mem_cons_self _ _)
        · refine List.mem_cons_of_mem _ ?_
          exact (List.mem_erase_of_ne hpm).mpr hp
      · intro hp
        rcases List.mem_cons.mp hp with hp_eq | hp_rest
        · rw [hp_eq]; exact hm₀_in_pts
        · exact List.mem_of_mem_erase hp_rest
    have h_splitPerm := splitSegmentAtPoints_perm_iff_collinear seg pts
      (m₀ :: pts.erase m₀) h_nondeg h_pts_on_seg h_pts_on_seg' h_set_eq
    refine h_iterPerm.trans ?_
    refine List.Perm.trans ?_ h_splitPerm.symm
    set rest := pts.erase m₀ with hrest_def
    -- iterativeSplit seg (m₀ :: rest).
    have h_iterEq : iterativeSplit seg (m₀ :: rest) =
        iterativeSplit ⟨seg.p1, m₀⟩ rest ++
          iterativeSplit ⟨m₀, seg.p2⟩ rest := by
      show (if _ then _ else _) = _
      rw [if_pos hm₀_int]
    rw [h_iterEq, List.map_append]
    have h_m₀_param : 0 < paramOnSeg seg m₀ ∧ paramOnSeg seg m₀ < 1 :=
      paramOnSeg_strict_interior seg h_nondeg m₀ hm₀_int.1 hm₀_int.2.1 hm₀_int.2.2
    have h_left_nondeg : (LineSegment.mk seg.p1 m₀).p1 ≠ (LineSegment.mk seg.p1 m₀).p2 := by
      show seg.p1 ≠ m₀; intro h; exact hm₀_int.2.1 h.symm
    have h_right_nondeg : (LineSegment.mk m₀ seg.p2).p1 ≠ (LineSegment.mk m₀ seg.p2).p2 := by
      show m₀ ≠ seg.p2; exact hm₀_int.2.2
    have h_rest_on_seg : ∀ q ∈ rest, q ∈ seg.toSet := by
      intro q hq; exact h_pts_on_seg q (List.mem_of_mem_erase hq)
    -- Show no q in rest is strictly interior to ⟨seg.p1, m₀⟩.
    have h_rest_no_interior_left : ∀ q ∈ rest,
        ¬ (q ∈ (LineSegment.mk seg.p1 m₀).toSet ∧
            q ≠ (LineSegment.mk seg.p1 m₀).p1 ∧
            q ≠ (LineSegment.mk seg.p1 m₀).p2) := by
      intro q hq ⟨hq_left, hq_ne1, hq_ne2⟩
      have hq_seg : q ∈ seg.toSet := h_rest_on_seg q hq
      have h_qm₀_le : paramOnSeg seg q ≤ paramOnSeg seg m₀ :=
        (mem_left_subSeg_iff seg h_nondeg m₀ hm₀_int.1 q hq_seg).mp hq_left
      have h_q_ne_segp1 : q ≠ seg.p1 := hq_ne1
      have h_q_ne_m₀ : q ≠ m₀ := hq_ne2
      by_cases h_q_int : q ∈ seg.toSet ∧ q ≠ seg.p1 ∧ q ≠ seg.p2
      · have h_q_in_pts : q ∈ pts := List.mem_of_mem_erase hq
        have h_q_in_ints : q ∈ ints := by
          rw [hints_def]; simp only [List.mem_filter, decide_eq_true_eq]
          exact ⟨h_q_in_pts, h_q_int⟩
        have h_min : paramOnSeg seg m₀ ≤ paramOnSeg seg q := hm₀_min q h_q_in_ints
        have h_eq : paramOnSeg seg m₀ = paramOnSeg seg q := le_antisymm h_min h_qm₀_le
        have h_q_eq_m₀ : m₀ = q :=
          paramOnSeg_injective seg h_nondeg hm₀_int.1 hq_seg h_eq
        exact h_q_ne_m₀ h_q_eq_m₀.symm
      · push_neg at h_q_int
        have hcase : q = seg.p1 ∨ q = seg.p2 := by
          by_contra hne
          push_neg at hne
          exact hne.2 (h_q_int hq_seg hne.1)
        rcases hcase with h_eq | h_eq
        · exact h_q_ne_segp1 h_eq
        · rw [h_eq, paramOnSeg_p2 seg h_nondeg] at h_qm₀_le
          linarith [h_m₀_param.2]
    have h_left_eq_singleton :
        iterativeSplit (LineSegment.mk seg.p1 m₀) rest =
          [LineSegment.mk seg.p1 m₀] :=
      iterativeSplit_eq_singleton_of_no_interior _ rest h_rest_no_interior_left
    rw [h_left_eq_singleton]
    -- Now LHS = [⟨seg.p1, m₀⟩.toEM] ++ (iterativeSplit ⟨m₀, seg.p2⟩ rest).map toEM.
    -- Apply IH to right half via filter.
    set rest' := rest.filter (fun q => decide (q ∈ (LineSegment.mk m₀ seg.p2).toSet))
      with hrest'_def
    have h_right_filter :
        iterativeSplit (LineSegment.mk m₀ seg.p2) rest =
        iterativeSplit (LineSegment.mk m₀ seg.p2) rest' :=
      iterativeSplit_filter_on_seg (LineSegment.mk m₀ seg.p2) rest
    rw [h_right_filter]
    have h_rest'_len : rest'.length < pts.length := by
      have h1 : rest'.length ≤ rest.length := List.length_filter_le _ _
      have h2 : rest.length < pts.length := by
        rw [hrest_def]
        have h_perm : List.Perm pts (m₀ :: pts.erase m₀) := List.perm_cons_erase hm₀_in_pts
        have h_len : pts.length = (m₀ :: pts.erase m₀).length := h_perm.length_eq
        rw [h_len]
        simp
      exact lt_of_le_of_lt h1 h2
    have h_rest'_on : ∀ q ∈ rest', q ∈ (LineSegment.mk m₀ seg.p2).toSet := by
      intro q hq
      rw [hrest'_def, List.mem_filter, decide_eq_true_eq] at hq
      exact hq.2
    have ih_right := ih rest'.length (hN ▸ h_rest'_len) (LineSegment.mk m₀ seg.p2)
      h_right_nondeg rest' h_rest'_on rfl
    -- ih_right: (iterativeSplit ⟨m₀,p2⟩ rest').map toEM ~ (splitSegmentAtPoints ⟨m₀,p2⟩ rest').map toEM.
    -- Goal: [{p1, m₀}] ++ (iterativeSplit ⟨m₀,p2⟩ rest').map toEM ~
    --       (splitSegmentAtPoints seg (m₀ :: rest)).map toEM
    -- We need a splice lemma. Prove it inline.
    -- Strategy: both lists, after toEM-map, are perm-equal to consecutive pairs of canonical sorted-distinct list.
    -- canonical for LHS = [seg.p1, ...] -- starting with p1, then m₀ (smallest interior),
    -- then sorted distinct rest restricted to interior of ⟨m₀, p2⟩.
    -- canonical for RHS (splitSegmentAtPoints seg (m₀::rest)) = same.
    -- Specifically, prove: splitSegmentAtPoints seg (m₀ :: rest) corresponds to
    -- [⟨seg.p1, m₀⟩] ++ splitSegmentAtPoints ⟨m₀, seg.p2⟩ rest' (modulo toEM perm).
    -- This is by showing both produce the same canonical list.
    --
    -- We do this by explicit canonical-list manipulation.
    have h_splice :
        List.Perm
          ((splitSegmentAtPoints seg (m₀ :: rest)).map LineSegment.toEndpointsMultiset)
          (([LineSegment.mk seg.p1 m₀] ++
            splitSegmentAtPoints (LineSegment.mk m₀ seg.p2) rest').map
            LineSegment.toEndpointsMultiset) := by
      -- Prove via: dedupConsec (sortAlongSeg ...) computation.
      -- Both sides use sort-by-paramOnSeg, which on seg and on ⟨m₀, seg.p2⟩ are
      -- consistent (preserve order).
      apply splitSegmentAtPoints_split_at_min_perm seg h_nondeg m₀ hm₀_int rest h_rest_on_seg
        h_rest_no_interior_left
    -- Combine.
    refine List.Perm.trans ?_ h_splice.symm
    simp only [List.singleton_append]
    refine List.Perm.cons _ ih_right
  · -- No strictly interior point in pts.
    have h_no_int : ∀ p ∈ pts, ¬ (p ∈ seg.toSet ∧ p ≠ seg.p1 ∧ p ≠ seg.p2) := by
      intro p hp ⟨h1, h2, h3⟩
      exact h_exists_int ⟨p, hp, h1, h2, h3⟩
    have h_iterEq : iterativeSplit seg pts = [seg] :=
      iterativeSplit_eq_singleton_of_no_interior seg pts h_no_int
    have h_splitEq : splitSegmentAtPoints seg pts = [⟨seg.p1, seg.p2⟩] :=
      splitSegmentAtPoints_eq_singleton_of_no_interior seg h_nondeg pts h_pts_on_seg h_no_int
    rw [h_iterEq, h_splitEq]

/-- **Restricted capture hypothesis** (used as a hypothesis): every boundary
    intersection point of `seg ∈ m1.segments` with `m2.toBoundarySet`
    that arises from a *parallel/collinear* (i.e. `segSegIntersect = none`)
    m2 segment is in the refinement-points list. The transverse
    (`segSegIntersect = some _`) case is handled inline by the lemma proof. -/
private def boundaryCaptureProperty (m1 m2 : Multipolygon) : Prop :=
  ∀ seg ∈ m1.segments,
    ∀ q ∈ seg.toSet, ∀ seg2 ∈ m2.segments, q ∈ seg2.toSet →
      segSegIntersect seg seg2 = none →
      q ∈ (seg.p1 :: seg.p2 :: refinementPointsForSegment seg m1 m2)

/-- Helper: the point `(1 - t) * seg.p1 + t * seg.p2` for `t ∈ [0, 1]` is in
    `seg.toSet`. -/
private theorem pointAt_mem_seg (seg : LineSegment) (t : ℚ)
    (ht_nn : 0 ≤ t) (ht_le : t ≤ 1) :
    (⟨(1 - t) * seg.p1.x + t * seg.p2.x,
      (1 - t) * seg.p1.y + t * seg.p2.y⟩ : Vector2D) ∈ seg.toSet :=
  ⟨t, ht_nn, ht_le, rfl, rfl⟩

/-- Helper: for `D = 0` and `q ∈ seg.toSet ∩ seg2.toSet`, with both segments
    non-degenerate, the seg2 endpoints are expressible as
    `seg2.pi = (1 - r_i) * seg.p1 + r_i * seg.p2` for some `r_i`, and
    `r1 ≠ r2`. -/
private theorem collinear_seg2_in_seg_param
    (seg seg2 : LineSegment)
    (h_seg_nondeg : seg.p1 ≠ seg.p2)
    (h_seg2_nondeg : seg2.p1 ≠ seg2.p2)
    (h_D_zero : (seg.p2.x - seg.p1.x) * (seg2.p2.y - seg2.p1.y) -
                (seg.p2.y - seg.p1.y) * (seg2.p2.x - seg2.p1.x) = 0)
    (q : Vector2D) (hq1 : q ∈ seg.toSet) (hq2 : q ∈ seg2.toSet) :
    ∃ r1 r2 : ℚ, r1 ≠ r2 ∧
      seg2.p1.x = (1 - r1) * seg.p1.x + r1 * seg.p2.x ∧
      seg2.p1.y = (1 - r1) * seg.p1.y + r1 * seg.p2.y ∧
      seg2.p2.x = (1 - r2) * seg.p1.x + r2 * seg.p2.x ∧
      seg2.p2.y = (1 - r2) * seg.p1.y + r2 * seg.p2.y := by
  obtain ⟨t1, _ht1_nn, _ht1_le, hqx1, hqy1⟩ := hq1
  obtain ⟨t2, _ht2_nn, _ht2_le, hqx2, hqy2⟩ := hq2
  -- Case split on which axis seg is non-degenerate.
  by_cases hxne : seg.p2.x ≠ seg.p1.x
  · -- x-axis non-degenerate: dx := seg.p2.x - seg.p1.x ≠ 0.
    have hdx_ne : seg.p2.x - seg.p1.x ≠ 0 := sub_ne_zero.mpr hxne
    -- Define r1, r2 via x-coordinate.
    set r1 := (seg2.p1.x - seg.p1.x) / (seg.p2.x - seg.p1.x) with hr1_def
    set r2 := (seg2.p2.x - seg.p1.x) / (seg.p2.x - seg.p1.x) with hr2_def
    -- Compute x-equations.
    have hxEq1 : seg2.p1.x = (1 - r1) * seg.p1.x + r1 * seg.p2.x := by
      rw [hr1_def]; field_simp; ring
    have hxEq2 : seg2.p2.x = (1 - r2) * seg.p1.x + r2 * seg.p2.x := by
      rw [hr2_def]; field_simp; ring
    -- For y-equations, use D = 0: dx * (s2.p2.y - s2.p1.y) = dy * (s2.p2.x - s2.p1.x).
    -- Hence (s2.p2.y - s2.p1.y) = (dy/dx) * (s2.p2.x - s2.p1.x) = (dy/dx) * (r2 - r1) * dx
    -- = dy * (r2 - r1).
    have h_dy_diff : seg2.p2.y - seg2.p1.y = (seg.p2.y - seg.p1.y) * (r2 - r1) := by
      have : (seg.p2.x - seg.p1.x) * (seg2.p2.y - seg2.p1.y) =
             (seg.p2.y - seg.p1.y) * (seg2.p2.x - seg2.p1.x) := by linarith [h_D_zero]
      have hdiff : seg2.p2.x - seg2.p1.x = (r2 - r1) * (seg.p2.x - seg.p1.x) := by
        rw [hr1_def, hr2_def]; field_simp; try ring
      have h1 : (seg.p2.x - seg.p1.x) * (seg2.p2.y - seg2.p1.y) =
                (seg.p2.y - seg.p1.y) * ((r2 - r1) * (seg.p2.x - seg.p1.x)) := by
        rw [this, hdiff]
      have h2 : (seg.p2.x - seg.p1.x) * (seg2.p2.y - seg2.p1.y) =
                (seg.p2.x - seg.p1.x) * ((seg.p2.y - seg.p1.y) * (r2 - r1)) := by
        rw [h1]; ring
      have := mul_left_cancel₀ hdx_ne h2
      exact this
    -- Use parameterization of q to determine the y offsets.
    -- From hqx1, hqx2 we get t1 and t2 in terms of r1 and ... well, let's instead
    -- compute seg2.p1.y and seg2.p2.y directly.
    -- Use y-equation of q on each segment to get constraints; combined with h_dy_diff
    -- and consistency of q on the line, we get the y formulas for seg2.p1 and seg2.p2.
    -- Actually the simplest: define hq's seg-y-affine relation.
    -- From hq1: q.y = (1-t1)*s.p1.y + t1*s.p2.y.
    -- From hqx1: q.x = (1-t1)*s.p1.x + t1*s.p2.x, so t1 = (q.x - s.p1.x)/(s.p2.x - s.p1.x).
    -- Similarly compute t2 in seg2: q.x = (1-t2)*s2.p1.x + t2*s2.p2.x.
    -- We want seg2.p1.y formula. Use that q.y is affine in t1 along seg, and
    -- q.y - seg2.p1.y = t2 * (seg2.p2.y - seg2.p1.y).
    -- We'll compute seg2.p1.y from these.
    -- First derive t1.
    have ht1_eq : t1 = (q.x - seg.p1.x) / (seg.p2.x - seg.p1.x) := by
      have : q.x - seg.p1.x = t1 * (seg.p2.x - seg.p1.x) := by rw [hqx1]; ring
      field_simp; linarith
    -- Similarly seg2.p1's "t" via seg's parameterization.
    -- Note: seg2.p1 ∈ seg2.toSet trivially; we want it in seg's line parameterization.
    -- Compute q.y from t1.
    have hqy1' : q.y = seg.p1.y + t1 * (seg.p2.y - seg.p1.y) := by rw [hqy1]; ring
    -- Express seg2.p1.y. From hq2: q.y = (1-t2)*seg2.p1.y + t2*seg2.p2.y.
    -- And seg2.p2.y = seg2.p1.y + (s.p2.y - s.p1.y) * (r2 - r1).
    -- So q.y = seg2.p1.y + t2 * (s.p2.y - s.p1.y) * (r2 - r1).
    -- Also, by the x-relation: q.x - seg2.p1.x = t2 * (seg2.p2.x - seg2.p1.x)
    --                                          = t2 * (r2 - r1) * (s.p2.x - s.p1.x).
    -- And q.x - seg.p1.x = t1 * (s.p2.x - s.p1.x). Also seg2.p1.x - seg.p1.x = r1 * (s.p2.x - s.p1.x).
    -- So q.x - seg2.p1.x = (t1 - r1) * (s.p2.x - s.p1.x), giving t2 * (r2 - r1) = t1 - r1.
    have ht2_lin : t2 * (r2 - r1) = t1 - r1 := by
      have h_q_diff_x : q.x - seg2.p1.x = t2 * (seg2.p2.x - seg2.p1.x) := by
        rw [hqx2]; ring
      have h_seg2p1_diff_x : seg2.p1.x - seg.p1.x = r1 * (seg.p2.x - seg.p1.x) := by
        rw [hxEq1]; ring
      have h_q_diff_seg : q.x - seg.p1.x = t1 * (seg.p2.x - seg.p1.x) := by
        rw [hqx1]; ring
      have h_seg2_diff_x : seg2.p2.x - seg2.p1.x = (r2 - r1) * (seg.p2.x - seg.p1.x) := by
        rw [hxEq1, hxEq2]; ring
      have h1 : q.x - seg2.p1.x = (t1 - r1) * (seg.p2.x - seg.p1.x) := by
        have : q.x - seg2.p1.x = (q.x - seg.p1.x) - (seg2.p1.x - seg.p1.x) := by ring
        rw [this, h_q_diff_seg, h_seg2p1_diff_x]; ring
      have h2 : q.x - seg2.p1.x = t2 * ((r2 - r1) * (seg.p2.x - seg.p1.x)) := by
        rw [h_q_diff_x, h_seg2_diff_x]
      have h3 : (t1 - r1) * (seg.p2.x - seg.p1.x) =
                (t2 * (r2 - r1)) * (seg.p2.x - seg.p1.x) := by
        rw [← h1, h2]; ring
      have h4 : (seg.p2.x - seg.p1.x) * (t1 - r1) =
                (seg.p2.x - seg.p1.x) * (t2 * (r2 - r1)) := by linarith [h3]
      exact (mul_left_cancel₀ hdx_ne h4).symm
    -- Now compute seg2.p1.y. Using hq2 y-eqn: q.y = (1-t2)*s2.p1.y + t2*s2.p2.y
    -- and h_dy_diff: s2.p2.y = s2.p1.y + (s.p2.y - s.p1.y)*(r2 - r1).
    -- So q.y = s2.p1.y + t2*(s.p2.y - s.p1.y)*(r2 - r1).
    -- By ht2_lin: t2*(r2 - r1) = t1 - r1. So q.y = s2.p1.y + (t1 - r1)*(s.p2.y - s.p1.y).
    -- And q.y = s.p1.y + t1*(s.p2.y - s.p1.y).
    -- Hence s2.p1.y = s.p1.y + r1*(s.p2.y - s.p1.y) = (1 - r1)*s.p1.y + r1*s.p2.y.
    have hyEq1 : seg2.p1.y = (1 - r1) * seg.p1.y + r1 * seg.p2.y := by
      have hqy2' : q.y = seg2.p1.y + t2 * (r2 - r1) * (seg.p2.y - seg.p1.y) := by
        have h_y_eq : q.y = (1 - t2) * seg2.p1.y + t2 * seg2.p2.y := hqy2
        rw [h_y_eq]
        have hs2p2y : seg2.p2.y = seg2.p1.y + (seg.p2.y - seg.p1.y) * (r2 - r1) := by
          linarith [h_dy_diff]
        rw [hs2p2y]; ring
      have hqy_lin : q.y = seg2.p1.y + (t1 - r1) * (seg.p2.y - seg.p1.y) := by
        rw [hqy2']; rw [show t2 * (r2 - r1) * (seg.p2.y - seg.p1.y) =
                          (t2 * (r2 - r1)) * (seg.p2.y - seg.p1.y) from by ring,
                       ht2_lin]
      -- hqy1' : q.y = seg.p1.y + t1 * (seg.p2.y - seg.p1.y)
      linarith [hqy1', hqy_lin]
    have hyEq2 : seg2.p2.y = (1 - r2) * seg.p1.y + r2 * seg.p2.y := by
      have : seg2.p2.y = seg2.p1.y + (seg.p2.y - seg.p1.y) * (r2 - r1) := by
        linarith [h_dy_diff]
      rw [this, hyEq1]; ring
    -- Show r1 ≠ r2 by non-degeneracy of seg2.
    have hr_ne : r1 ≠ r2 := by
      intro h_eq
      apply h_seg2_nondeg
      apply Vector2D.ext
      · rw [hxEq1, hxEq2, h_eq]
      · rw [hyEq1, hyEq2, h_eq]
    exact ⟨r1, r2, hr_ne, hxEq1, hyEq1, hxEq2, hyEq2⟩
  · -- y-axis non-degenerate.
    push_neg at hxne
    have hyne : seg.p2.y ≠ seg.p1.y := by
      intro hye
      apply h_seg_nondeg
      ext
      · exact hxne.symm
      · exact hye.symm
    have hdy_ne : seg.p2.y - seg.p1.y ≠ 0 := sub_ne_zero.mpr hyne
    -- Define r1, r2 via y-coordinate.
    set r1 := (seg2.p1.y - seg.p1.y) / (seg.p2.y - seg.p1.y) with hr1_def
    set r2 := (seg2.p2.y - seg.p1.y) / (seg.p2.y - seg.p1.y) with hr2_def
    have hyEq1 : seg2.p1.y = (1 - r1) * seg.p1.y + r1 * seg.p2.y := by
      rw [hr1_def]; field_simp; ring
    have hyEq2 : seg2.p2.y = (1 - r2) * seg.p1.y + r2 * seg.p2.y := by
      rw [hr2_def]; field_simp; ring
    -- D = 0: (s.p2.x - s.p1.x) * (s2.p2.y - s2.p1.y) = (s.p2.y - s.p1.y) * (s2.p2.x - s2.p1.x).
    -- s.p2.x - s.p1.x = 0, so (s.p2.y - s.p1.y) * (s2.p2.x - s2.p1.x) = 0.
    -- Hence s2.p2.x = s2.p1.x.
    have h_s2x_eq : seg2.p2.x = seg2.p1.x := by
      have : (seg.p2.x - seg.p1.x) * (seg2.p2.y - seg2.p1.y) =
             (seg.p2.y - seg.p1.y) * (seg2.p2.x - seg2.p1.x) := by linarith [h_D_zero]
      have h_lhs_zero : (seg.p2.x - seg.p1.x) * (seg2.p2.y - seg2.p1.y) = 0 := by
        rw [show seg.p2.x - seg.p1.x = 0 from by linarith [hxne]]; ring
      have h_rhs_zero : (seg.p2.y - seg.p1.y) * (seg2.p2.x - seg2.p1.x) = 0 := by
        rw [← this]; exact h_lhs_zero
      have := mul_left_cancel₀ hdy_ne (by rw [h_rhs_zero]; ring :
        (seg.p2.y - seg.p1.y) * (seg2.p2.x - seg2.p1.x) = (seg.p2.y - seg.p1.y) * 0)
      linarith
    -- And seg.p1.x = seg.p2.x = seg2.p1.x = seg2.p2.x by hxne and the chain.
    -- Actually need to derive seg2.p1.x = seg.p1.x from q on both lines.
    -- From hq1: q.x = (1-t1)*s.p1.x + t1*s.p2.x = s.p1.x (since p1.x = p2.x).
    have h_qx_p1 : q.x = seg.p1.x := by rw [hqx1, hxne]; ring
    -- From hq2: q.x = (1-t2)*s2.p1.x + t2*s2.p2.x = s2.p1.x (since s2.p1.x = s2.p2.x).
    have h_qx_s2p1 : q.x = seg2.p1.x := by rw [hqx2, h_s2x_eq]; ring
    have h_s2p1x_eq : seg2.p1.x = seg.p1.x := by rw [← h_qx_p1, h_qx_s2p1]
    have h_s2p2x_eq : seg2.p2.x = seg.p1.x := by rw [h_s2x_eq, h_s2p1x_eq]
    -- Now show the x equations.
    have hxEq1 : seg2.p1.x = (1 - r1) * seg.p1.x + r1 * seg.p2.x := by
      rw [h_s2p1x_eq, hxne]; ring
    have hxEq2 : seg2.p2.x = (1 - r2) * seg.p1.x + r2 * seg.p2.x := by
      rw [h_s2p2x_eq, hxne]; ring
    have hr_ne : r1 ≠ r2 := by
      intro h_eq
      apply h_seg2_nondeg
      apply Vector2D.ext
      · rw [hxEq1, hxEq2, h_eq]
      · rw [hyEq1, hyEq2, h_eq]
    exact ⟨r1, r2, hr_ne, hxEq1, hyEq1, hxEq2, hyEq2⟩

set_option maxHeartbeats 400000 in
/-- Discharge of `boundaryCaptureProperty`: under non-degeneracy of both polygon's
    segments and finiteness of boundary intersection, the property holds. -/
private theorem boundaryCaptureProperty_holds (m1 m2 : Multipolygon)
    (h1_nondeg : ∀ s ∈ m1.segments, s.p1 ≠ s.p2)
    (h2_nondeg : ∀ s ∈ m2.segments, s.p1 ≠ s.p2)
    (h_fin : Set.Finite (m1.toBoundarySet ∩ m2.toBoundarySet)) :
    boundaryCaptureProperty m1 m2 := by
  intro seg h_seg q h_q_seg seg2 h_seg2 h_q_seg2 h_none
  -- Case split: q = seg.p1, q = seg.p2, or q is interior.
  by_cases h_q_p1 : q = seg.p1
  · simp [h_q_p1]
  by_cases h_q_p2 : q = seg.p2
  · rw [h_q_p2]; simp
  -- Interior case: derive contradiction with h_fin.
  exfalso
  have h_seg_nondeg : seg.p1 ≠ seg.p2 := h1_nondeg seg h_seg
  have h_seg2_nondeg : seg2.p1 ≠ seg2.p2 := h2_nondeg seg2 h_seg2
  have h_D_zero : (seg.p2.x - seg.p1.x) * (seg2.p2.y - seg2.p1.y) -
                  (seg.p2.y - seg.p1.y) * (seg2.p2.x - seg2.p1.x) = 0 :=
    segSegIntersect_none_implies_D_zero seg seg2 q h_q_seg h_q_seg2 h_none
  -- Get the seg2 endpoints in seg's parametrization.
  obtain ⟨r1, r2, hr_ne, hs2p1_x, hs2p1_y, hs2p2_x, hs2p2_y⟩ :=
    collinear_seg2_in_seg_param seg seg2 h_seg_nondeg h_seg2_nondeg h_D_zero
      q h_q_seg h_q_seg2
  -- Get q's parameter on seg.
  obtain ⟨hqx, hqy, h_tq_nn, h_tq_le⟩ := paramOnSeg_spec seg h_seg_nondeg q h_q_seg
  set t_q := paramOnSeg seg q with ht_q_def
  -- t_q ∈ (0, 1) since q ≠ seg.p1, q ≠ seg.p2.
  have h_tq_pos : 0 < t_q := by
    rcases lt_or_eq_of_le h_tq_nn with h | h
    · exact h
    · exfalso; apply h_q_p1
      have h_p1_param : paramOnSeg seg seg.p1 = 0 := paramOnSeg_p1 seg h_seg_nondeg
      have h_p1_seg : seg.p1 ∈ seg.toSet :=
        ⟨0, by norm_num, by norm_num, by ring, by ring⟩
      apply paramOnSeg_injective seg h_seg_nondeg h_q_seg h_p1_seg
      rw [← ht_q_def, ← h, h_p1_param]
  have h_tq_lt : t_q < 1 := by
    rcases lt_or_eq_of_le h_tq_le with h | h
    · exact h
    · exfalso; apply h_q_p2
      have h_p2_param : paramOnSeg seg seg.p2 = 1 := paramOnSeg_p2 seg h_seg_nondeg
      have h_p2_seg : seg.p2 ∈ seg.toSet :=
        ⟨1, by norm_num, by norm_num, by ring, by ring⟩
      apply paramOnSeg_injective seg h_seg_nondeg h_q_seg h_p2_seg
      rw [← ht_q_def, h, h_p2_param]
  -- We have hqx : q.x = (1 - t_q) * seg.p1.x + t_q * seg.p2.x
  --       hqy : q.y = (1 - t_q) * seg.p1.y + t_q * seg.p2.y
  -- Also q ∈ seg2.toSet means q = (1 - s) * seg2.p1 + s * seg2.p2 for some s ∈ [0, 1].
  -- Substituting seg2.p1 and seg2.p2 expressions, we get the equation in t_q, r1, r2:
  -- t_q = (1-s) * r1 + s * r2 (after some algebra).
  -- So r_min ≤ t_q ≤ r_max.
  -- Define r_min := min r1 r2, r_max := max r1 r2.
  set r_min := min r1 r2 with hr_min_def
  set r_max := max r1 r2 with hr_max_def
  have hr_min_lt_max : r_min < r_max := by
    rw [hr_min_def, hr_max_def]
    rcases lt_or_gt_of_ne hr_ne with h | h
    · simp [min_eq_left (le_of_lt h), max_eq_right (le_of_lt h), h]
    · simp [min_eq_right (le_of_lt h), max_eq_left (le_of_lt h), h]
  -- Compute t_q in terms of seg2's parameter s.
  obtain ⟨s, hs_nn, hs_le, hqx2, hqy2⟩ := h_q_seg2
  -- t_q = (1-s)*r1 + s*r2. Let's prove this.
  have h_tq_eq : t_q = (1 - s) * r1 + s * r2 := by
    -- Use either x or y axis. Since the segment is non-degenerate, use the appropriate one.
    by_cases hxne : seg.p2.x ≠ seg.p1.x
    · have hdx_ne : seg.p2.x - seg.p1.x ≠ 0 := sub_ne_zero.mpr hxne
      -- Compute q.x two ways.
      have h1 : (1 - t_q) * seg.p1.x + t_q * seg.p2.x =
                (1 - ((1-s)*r1 + s*r2)) * seg.p1.x + ((1-s)*r1 + s*r2) * seg.p2.x := by
        rw [← hqx]
        rw [hqx2, hs2p1_x, hs2p2_x]
        ring
      -- Solve for t_q.
      have h2 : (t_q - ((1-s)*r1 + s*r2)) * (seg.p2.x - seg.p1.x) = 0 := by linarith [h1]
      rcases mul_eq_zero.mp h2 with h | h
      · linarith
      · exact absurd h hdx_ne
    · push_neg at hxne
      have hyne : seg.p2.y ≠ seg.p1.y := by
        intro hye; apply h_seg_nondeg; ext
        · exact hxne.symm
        · exact hye.symm
      have hdy_ne : seg.p2.y - seg.p1.y ≠ 0 := sub_ne_zero.mpr hyne
      have h1 : (1 - t_q) * seg.p1.y + t_q * seg.p2.y =
                (1 - ((1-s)*r1 + s*r2)) * seg.p1.y + ((1-s)*r1 + s*r2) * seg.p2.y := by
        rw [← hqy]
        rw [hqy2, hs2p1_y, hs2p2_y]
        ring
      have h2 : (t_q - ((1-s)*r1 + s*r2)) * (seg.p2.y - seg.p1.y) = 0 := by linarith [h1]
      rcases mul_eq_zero.mp h2 with h | h
      · linarith
      · exact absurd h hdy_ne
  -- t_q ∈ [r_min, r_max]: since t_q is a convex combination of r1, r2.
  have h_tq_ge_rmin : r_min ≤ t_q := by
    rw [h_tq_eq, hr_min_def]
    rcases le_or_gt r1 r2 with h | h
    · rw [min_eq_left h]
      have hrw : (1 - s) * r1 + s * r2 = r1 + s * (r2 - r1) := by ring
      rw [hrw]
      have : 0 ≤ s * (r2 - r1) := mul_nonneg hs_nn (by linarith)
      linarith
    · rw [min_eq_right (le_of_lt h)]
      have hrw : (1 - s) * r1 + s * r2 = r2 + (1 - s) * (r1 - r2) := by ring
      rw [hrw]
      have : 0 ≤ (1 - s) * (r1 - r2) := mul_nonneg (by linarith) (by linarith)
      linarith
  have h_tq_le_rmax : t_q ≤ r_max := by
    rw [h_tq_eq, hr_max_def]
    rcases le_or_gt r1 r2 with h | h
    · rw [max_eq_right h]
      have hrw : (1 - s) * r1 + s * r2 = r2 - (1 - s) * (r2 - r1) := by ring
      rw [hrw]
      have : 0 ≤ (1 - s) * (r2 - r1) := mul_nonneg (by linarith) (by linarith)
      linarith
    · rw [max_eq_left (le_of_lt h)]
      have hrw : (1 - s) * r1 + s * r2 = r1 - s * (r1 - r2) := by ring
      rw [hrw]
      have : 0 ≤ s * (r1 - r2) := mul_nonneg hs_nn (by linarith)
      linarith
  -- Define the valid t-range.
  set t_lo := max 0 r_min with ht_lo_def
  set t_hi := min 1 r_max with ht_hi_def
  have h_tlo_le_tq : t_lo ≤ t_q := by
    rw [ht_lo_def]; exact max_le (le_of_lt h_tq_pos) h_tq_ge_rmin
  have h_tq_le_thi : t_q ≤ t_hi := by
    rw [ht_hi_def]; exact le_min (le_of_lt h_tq_lt) h_tq_le_rmax
  -- t_lo < t_hi.
  have h_tlo_lt_thi : t_lo < t_hi := by
    rw [ht_lo_def, ht_hi_def]
    -- Need max 0 r_min < min 1 r_max.
    -- Since r_min < r_max, 0 < t_q ≤ r_max so 0 < r_max, and r_min ≤ t_q < 1 so r_min < 1.
    have h_rmax_pos : 0 < r_max := lt_of_lt_of_le h_tq_pos h_tq_le_rmax
    have h_rmin_lt_one : r_min < 1 := lt_of_le_of_lt h_tq_ge_rmin h_tq_lt
    apply max_lt
    · exact lt_min (by norm_num : (0 : ℚ) < 1) h_rmax_pos
    · exact lt_min h_rmin_lt_one hr_min_lt_max
  -- Choose direction: forward if t_q < t_hi, else backward.
  -- δ_max := if t_q < t_hi then t_hi - t_q else t_q - t_lo. δ_max > 0.
  -- direction := if t_q < t_hi then 1 else -1.
  -- In either case, t_q + direction * δ_max / (n+2) ∈ [t_lo, t_hi] and is distinct for distinct n.
  -- We need to define an injection ℕ → m1.toBoundarySet ∩ m2.toBoundarySet.
  -- f n := pointAt (t_q + direction * δ_max / (n+2)).
  rcases lt_or_eq_of_le h_tq_le_thi with h_tq_lt_thi | h_tq_eq_thi
  · -- forward direction
    let δ : ℚ := t_hi - t_q
    have hδ_pos : 0 < δ := by simp [δ]; linarith
    -- Define f n.
    let f : ℕ → Vector2D := fun n =>
      ⟨(1 - (t_q + δ / (n + 2))) * seg.p1.x + (t_q + δ / (n + 2)) * seg.p2.x,
       (1 - (t_q + δ / (n + 2))) * seg.p1.y + (t_q + δ / (n + 2)) * seg.p2.y⟩
    -- Show: for each n, f n ∈ m1.toBoundarySet ∩ m2.toBoundarySet.
    have h_f_in : ∀ n : ℕ, f n ∈ m1.toBoundarySet ∩ m2.toBoundarySet := by
      intro n
      have h_n2_pos : (0 : ℚ) < (n : ℚ) + 2 := by positivity
      have h_n2_ne : ((n : ℚ) + 2) ≠ 0 := ne_of_gt h_n2_pos
      have h_t_n : t_q + δ / (n + 2) ∈ Set.Icc t_q t_hi := by
        constructor
        · have : 0 ≤ δ / (n + 2) := div_nonneg (le_of_lt hδ_pos) (le_of_lt h_n2_pos)
          linarith
        · -- t_q + δ/(n+2) ≤ t_q + δ = t_hi when n+2 ≥ 1, i.e., always since n ≥ 0.
          have h1 : δ / (n + 2) ≤ δ := by
            rw [div_le_iff₀ h_n2_pos]
            have : δ ≤ δ * (n + 2) := by
              have h_one_le : (1 : ℚ) ≤ (n : ℚ) + 2 := by
                have : (0 : ℚ) ≤ n := by exact_mod_cast Nat.zero_le n
                linarith
              calc δ = δ * 1 := by ring
                _ ≤ δ * (n + 2) := by
                    exact mul_le_mul_of_nonneg_left h_one_le (le_of_lt hδ_pos)
            exact this
          show t_q + δ / (n + 2) ≤ t_hi
          have : δ / (n + 2) ≤ t_hi - t_q := by show δ / (n + 2) ≤ δ; exact h1
          linarith
      obtain ⟨h_lb, h_ub⟩ := h_t_n
      -- Show f n ∈ seg.toSet.
      have h_param_in : 0 ≤ t_q + δ / (n + 2) ∧ t_q + δ / (n + 2) ≤ 1 := by
        refine ⟨?_, ?_⟩
        · linarith
        · have ht_hi_le_one : t_hi ≤ 1 := by rw [ht_hi_def]; exact min_le_left _ _
          linarith
      have h_f_seg : f n ∈ seg.toSet :=
        ⟨t_q + δ / (n + 2), h_param_in.1, h_param_in.2,
         show (f n).x = _ from rfl, show (f n).y = _ from rfl⟩
      -- Show f n ∈ seg2.toSet. Need to find s' ∈ [0,1] with f n = (1-s')*seg2.p1 + s'*seg2.p2.
      have h_param_in_seg2 : r_min ≤ t_q + δ / (n + 2) ∧ t_q + δ / (n + 2) ≤ r_max := by
        refine ⟨?_, ?_⟩
        · have ht_lo_ge_rmin : r_min ≤ t_lo := by rw [ht_lo_def]; exact le_max_right _ _
          linarith
        · have ht_hi_le_rmax : t_hi ≤ r_max := by rw [ht_hi_def]; exact min_le_right _ _
          linarith
      -- t_q + δ/(n+2) is in [r_min, r_max], so it's a convex combination of r1, r2.
      -- Define s' such that t_q + δ/(n+2) = (1-s')*r1 + s'*r2.
      -- s' = (t_q + δ/(n+2) - r1) / (r2 - r1). Need to check s' ∈ [0,1].
      have h_f_seg2 : f n ∈ seg2.toSet := by
        set t_n := t_q + δ / (n + 2) with ht_n_def
        have ht_n_min : r_min ≤ t_n := h_param_in_seg2.1
        have ht_n_max : t_n ≤ r_max := h_param_in_seg2.2
        rcases lt_or_gt_of_ne hr_ne with h_r1_lt_r2 | h_r2_lt_r1
        · -- r1 < r2: r_min = r1, r_max = r2. s' = (t_n - r1) / (r2 - r1).
          have hr_min_eq : r_min = r1 := by rw [hr_min_def, min_eq_left (le_of_lt h_r1_lt_r2)]
          have hr_max_eq : r_max = r2 := by rw [hr_max_def, max_eq_right (le_of_lt h_r1_lt_r2)]
          rw [hr_min_eq] at ht_n_min
          rw [hr_max_eq] at ht_n_max
          set s' := (t_n - r1) / (r2 - r1) with hs'_def
          have hr_diff_pos : 0 < r2 - r1 := by linarith
          have hs'_nn : 0 ≤ s' := by
            rw [hs'_def]; exact div_nonneg (by linarith) (le_of_lt hr_diff_pos)
          have hs'_le : s' ≤ 1 := by
            rw [hs'_def, div_le_one hr_diff_pos]; linarith
          -- Verify (1-s')*r1 + s'*r2 = t_n.
          have h_tn_decomp : t_n = (1 - s') * r1 + s' * r2 := by
            rw [hs'_def]; field_simp; ring
          refine ⟨s', hs'_nn, hs'_le, ?_, ?_⟩
          · -- (f n).x = (1-s')*seg2.p1.x + s'*seg2.p2.x.
            show (1 - t_n) * seg.p1.x + t_n * seg.p2.x =
              (1 - s') * seg2.p1.x + s' * seg2.p2.x
            rw [hs2p1_x, hs2p2_x]
            -- Need: (1 - t_n) * s.p1.x + t_n * s.p2.x =
            --       (1-s')*((1-r1)*s.p1.x + r1*s.p2.x) + s'*((1-r2)*s.p1.x + r2*s.p2.x).
            rw [h_tn_decomp]; ring
          · show (1 - t_n) * seg.p1.y + t_n * seg.p2.y =
              (1 - s') * seg2.p1.y + s' * seg2.p2.y
            rw [hs2p1_y, hs2p2_y, h_tn_decomp]; ring
        · -- r2 < r1: r_min = r2, r_max = r1. s' = (r1 - t_n) / (r1 - r2).
          have hr_min_eq : r_min = r2 := by rw [hr_min_def, min_eq_right (le_of_lt h_r2_lt_r1)]
          have hr_max_eq : r_max = r1 := by rw [hr_max_def, max_eq_left (le_of_lt h_r2_lt_r1)]
          rw [hr_min_eq] at ht_n_min
          rw [hr_max_eq] at ht_n_max
          set s' := (r1 - t_n) / (r1 - r2) with hs'_def
          have hr_diff_pos : 0 < r1 - r2 := by linarith
          have hs'_nn : 0 ≤ s' := by
            rw [hs'_def]; exact div_nonneg (by linarith) (le_of_lt hr_diff_pos)
          have hs'_le : s' ≤ 1 := by
            rw [hs'_def, div_le_one hr_diff_pos]; linarith
          have h_tn_decomp : t_n = (1 - s') * r1 + s' * r2 := by
            rw [hs'_def]; field_simp; ring
          refine ⟨s', hs'_nn, hs'_le, ?_, ?_⟩
          · show (1 - t_n) * seg.p1.x + t_n * seg.p2.x =
              (1 - s') * seg2.p1.x + s' * seg2.p2.x
            rw [hs2p1_x, hs2p2_x, h_tn_decomp]; ring
          · show (1 - t_n) * seg.p1.y + t_n * seg.p2.y =
              (1 - s') * seg2.p1.y + s' * seg2.p2.y
            rw [hs2p1_y, hs2p2_y, h_tn_decomp]; ring
      refine ⟨?_, ?_⟩
      · exact ⟨seg, h_seg, h_f_seg⟩
      · exact ⟨seg2, h_seg2, h_f_seg2⟩
    -- Show f is injective.
    have h_f_inj : Function.Injective f := by
      intro a b hab
      have hax : (f a).x = (f b).x := by rw [hab]
      -- (f n).x = (1 - (t_q + δ/(n+2))) * seg.p1.x + (t_q + δ/(n+2)) * seg.p2.x
      --        = seg.p1.x + (t_q + δ/(n+2)) * (seg.p2.x - seg.p1.x)
      -- So (f a).x = (f b).x means (t_q + δ/(a+2) - t_q - δ/(b+2)) * (s.p2.x - s.p1.x) = 0
      -- i.e., δ * (1/(a+2) - 1/(b+2)) * (s.p2.x - s.p1.x) = 0.
      -- Same with y.
      -- Since at least one of (s.p2.x - s.p1.x), (s.p2.y - s.p1.y) is non-zero,
      -- δ * (1/(a+2) - 1/(b+2)) = 0. Since δ ≠ 0, 1/(a+2) = 1/(b+2), so a = b.
      have hay : (f a).y = (f b).y := by rw [hab]
      have h_a2_pos : (0 : ℚ) < (a : ℚ) + 2 := by positivity
      have h_b2_pos : (0 : ℚ) < (b : ℚ) + 2 := by positivity
      have h_a2_ne : ((a : ℚ) + 2) ≠ 0 := ne_of_gt h_a2_pos
      have h_b2_ne : ((b : ℚ) + 2) ≠ 0 := ne_of_gt h_b2_pos
      -- f a, f b unfold:
      have hax' : (1 - (t_q + δ / (a + 2))) * seg.p1.x + (t_q + δ / (a + 2)) * seg.p2.x =
                  (1 - (t_q + δ / (b + 2))) * seg.p1.x + (t_q + δ / (b + 2)) * seg.p2.x := hax
      have hay' : (1 - (t_q + δ / (a + 2))) * seg.p1.y + (t_q + δ / (a + 2)) * seg.p2.y =
                  (1 - (t_q + δ / (b + 2))) * seg.p1.y + (t_q + δ / (b + 2)) * seg.p2.y := hay
      have hax_diff : (δ / (a + 2) - δ / (b + 2)) * (seg.p2.x - seg.p1.x) = 0 := by linarith [hax']
      have hay_diff : (δ / (a + 2) - δ / (b + 2)) * (seg.p2.y - seg.p1.y) = 0 := by linarith [hay']
      -- Now use that seg is non-degenerate.
      have h_diff_eq_zero : δ / (a + 2) - δ / (b + 2) = 0 := by
        by_cases hxne : seg.p2.x ≠ seg.p1.x
        · have : seg.p2.x - seg.p1.x ≠ 0 := sub_ne_zero.mpr hxne
          rcases mul_eq_zero.mp hax_diff with h | h
          · exact h
          · exact absurd h this
        · push_neg at hxne
          have hyne : seg.p2.y ≠ seg.p1.y := by
            intro hye; apply h_seg_nondeg; ext
            · exact hxne.symm
            · exact hye.symm
          have : seg.p2.y - seg.p1.y ≠ 0 := sub_ne_zero.mpr hyne
          rcases mul_eq_zero.mp hay_diff with h | h
          · exact h
          · exact absurd h this
      -- δ / (a+2) = δ / (b+2). Since δ ≠ 0, this gives a+2 = b+2, hence a = b.
      have h_div_eq : δ / (a + 2) = δ / (b + 2) := by linarith
      rw [div_eq_div_iff h_a2_ne h_b2_ne] at h_div_eq
      have hδ_ne : δ ≠ 0 := ne_of_gt hδ_pos
      -- h_div_eq : δ * (b + 2) = δ * (a + 2)
      have h_ab : ((b : ℚ) + 2) = ((a : ℚ) + 2) := mul_left_cancel₀ hδ_ne h_div_eq
      have h_ab' : (a : ℚ) = (b : ℚ) := by linarith
      exact_mod_cast h_ab'
    -- Conclude: m1.toBoundarySet ∩ m2.toBoundarySet is infinite.
    apply h_fin.not_infinite
    apply Set.infinite_of_injective_forall_mem (f := f) h_f_inj
    exact h_f_in
  · -- backward direction (t_q = t_hi).
    -- Then we must have t_lo < t_q. Show this.
    have h_tlo_lt_tq : t_lo < t_q := by
      rcases lt_or_eq_of_le h_tlo_le_tq with h | h
      · exact h
      · exfalso; rw [← h] at h_tq_eq_thi; rw [h_tq_eq_thi] at h_tlo_lt_thi; exact lt_irrefl _ h_tlo_lt_thi
    let δ : ℚ := t_q - t_lo
    have hδ_pos : 0 < δ := by simp [δ]; linarith
    let f : ℕ → Vector2D := fun n =>
      ⟨(1 - (t_q - δ / (n + 2))) * seg.p1.x + (t_q - δ / (n + 2)) * seg.p2.x,
       (1 - (t_q - δ / (n + 2))) * seg.p1.y + (t_q - δ / (n + 2)) * seg.p2.y⟩
    have h_f_in : ∀ n : ℕ, f n ∈ m1.toBoundarySet ∩ m2.toBoundarySet := by
      intro n
      have h_n2_pos : (0 : ℚ) < (n : ℚ) + 2 := by positivity
      have h_n2_ne : ((n : ℚ) + 2) ≠ 0 := ne_of_gt h_n2_pos
      have h_t_n : t_q - δ / (n + 2) ∈ Set.Icc t_lo t_q := by
        constructor
        · have h1 : δ / (n + 2) ≤ δ := by
            rw [div_le_iff₀ h_n2_pos]
            have h_one_le : (1 : ℚ) ≤ (n : ℚ) + 2 := by
              have : (0 : ℚ) ≤ n := by exact_mod_cast Nat.zero_le n
              linarith
            calc δ = δ * 1 := by ring
              _ ≤ δ * (n + 2) := by
                  exact mul_le_mul_of_nonneg_left h_one_le (le_of_lt hδ_pos)
          show t_lo ≤ t_q - δ / (n + 2)
          have : δ / (n + 2) ≤ t_q - t_lo := by show δ / (n + 2) ≤ δ; exact h1
          linarith
        · have : 0 ≤ δ / (n + 2) := div_nonneg (le_of_lt hδ_pos) (le_of_lt h_n2_pos)
          linarith
      obtain ⟨h_lb, h_ub⟩ := h_t_n
      have h_param_in : 0 ≤ t_q - δ / (n + 2) ∧ t_q - δ / (n + 2) ≤ 1 := by
        refine ⟨?_, ?_⟩
        · have ht_lo_ge_zero : 0 ≤ t_lo := by rw [ht_lo_def]; exact le_max_left _ _
          linarith
        · linarith
      have h_f_seg : f n ∈ seg.toSet :=
        ⟨t_q - δ / (n + 2), h_param_in.1, h_param_in.2, rfl, rfl⟩
      have h_param_in_seg2 : r_min ≤ t_q - δ / (n + 2) ∧ t_q - δ / (n + 2) ≤ r_max := by
        refine ⟨?_, ?_⟩
        · have ht_lo_ge_rmin : r_min ≤ t_lo := by rw [ht_lo_def]; exact le_max_right _ _
          linarith
        · linarith
      have h_f_seg2 : f n ∈ seg2.toSet := by
        set t_n := t_q - δ / (n + 2) with ht_n_def
        have ht_n_min : r_min ≤ t_n := h_param_in_seg2.1
        have ht_n_max : t_n ≤ r_max := h_param_in_seg2.2
        rcases lt_or_gt_of_ne hr_ne with h_r1_lt_r2 | h_r2_lt_r1
        · have hr_min_eq : r_min = r1 := by rw [hr_min_def, min_eq_left (le_of_lt h_r1_lt_r2)]
          have hr_max_eq : r_max = r2 := by rw [hr_max_def, max_eq_right (le_of_lt h_r1_lt_r2)]
          rw [hr_min_eq] at ht_n_min
          rw [hr_max_eq] at ht_n_max
          set s' := (t_n - r1) / (r2 - r1) with hs'_def
          have hr_diff_pos : 0 < r2 - r1 := by linarith
          have hs'_nn : 0 ≤ s' := by
            rw [hs'_def]; exact div_nonneg (by linarith) (le_of_lt hr_diff_pos)
          have hs'_le : s' ≤ 1 := by
            rw [hs'_def, div_le_one hr_diff_pos]; linarith
          have h_tn_decomp : t_n = (1 - s') * r1 + s' * r2 := by
            rw [hs'_def]; field_simp; ring
          refine ⟨s', hs'_nn, hs'_le, ?_, ?_⟩
          · show (1 - t_n) * seg.p1.x + t_n * seg.p2.x =
              (1 - s') * seg2.p1.x + s' * seg2.p2.x
            rw [hs2p1_x, hs2p2_x, h_tn_decomp]; ring
          · show (1 - t_n) * seg.p1.y + t_n * seg.p2.y =
              (1 - s') * seg2.p1.y + s' * seg2.p2.y
            rw [hs2p1_y, hs2p2_y, h_tn_decomp]; ring
        · have hr_min_eq : r_min = r2 := by rw [hr_min_def, min_eq_right (le_of_lt h_r2_lt_r1)]
          have hr_max_eq : r_max = r1 := by rw [hr_max_def, max_eq_left (le_of_lt h_r2_lt_r1)]
          rw [hr_min_eq] at ht_n_min
          rw [hr_max_eq] at ht_n_max
          set s' := (r1 - t_n) / (r1 - r2) with hs'_def
          have hr_diff_pos : 0 < r1 - r2 := by linarith
          have hs'_nn : 0 ≤ s' := by
            rw [hs'_def]; exact div_nonneg (by linarith) (le_of_lt hr_diff_pos)
          have hs'_le : s' ≤ 1 := by
            rw [hs'_def, div_le_one hr_diff_pos]; linarith
          have h_tn_decomp : t_n = (1 - s') * r1 + s' * r2 := by
            rw [hs'_def]; field_simp; ring
          refine ⟨s', hs'_nn, hs'_le, ?_, ?_⟩
          · show (1 - t_n) * seg.p1.x + t_n * seg.p2.x =
              (1 - s') * seg2.p1.x + s' * seg2.p2.x
            rw [hs2p1_x, hs2p2_x, h_tn_decomp]; ring
          · show (1 - t_n) * seg.p1.y + t_n * seg.p2.y =
              (1 - s') * seg2.p1.y + s' * seg2.p2.y
            rw [hs2p1_y, hs2p2_y, h_tn_decomp]; ring
      refine ⟨?_, ?_⟩
      · exact ⟨seg, h_seg, h_f_seg⟩
      · exact ⟨seg2, h_seg2, h_f_seg2⟩
    have h_f_inj : Function.Injective f := by
      intro a b hab
      have hax : (f a).x = (f b).x := by rw [hab]
      have hay : (f a).y = (f b).y := by rw [hab]
      have h_a2_pos : (0 : ℚ) < (a : ℚ) + 2 := by positivity
      have h_b2_pos : (0 : ℚ) < (b : ℚ) + 2 := by positivity
      have h_a2_ne : ((a : ℚ) + 2) ≠ 0 := ne_of_gt h_a2_pos
      have h_b2_ne : ((b : ℚ) + 2) ≠ 0 := ne_of_gt h_b2_pos
      have hax' : (1 - (t_q - δ / (a + 2))) * seg.p1.x + (t_q - δ / (a + 2)) * seg.p2.x =
                  (1 - (t_q - δ / (b + 2))) * seg.p1.x + (t_q - δ / (b + 2)) * seg.p2.x := hax
      have hay' : (1 - (t_q - δ / (a + 2))) * seg.p1.y + (t_q - δ / (a + 2)) * seg.p2.y =
                  (1 - (t_q - δ / (b + 2))) * seg.p1.y + (t_q - δ / (b + 2)) * seg.p2.y := hay
      have hax_diff : (δ / (a + 2) - δ / (b + 2)) * (seg.p2.x - seg.p1.x) = 0 := by linarith [hax']
      have hay_diff : (δ / (a + 2) - δ / (b + 2)) * (seg.p2.y - seg.p1.y) = 0 := by linarith [hay']
      have h_diff_eq_zero : δ / (a + 2) - δ / (b + 2) = 0 := by
        by_cases hxne : seg.p2.x ≠ seg.p1.x
        · have : seg.p2.x - seg.p1.x ≠ 0 := sub_ne_zero.mpr hxne
          rcases mul_eq_zero.mp hax_diff with h | h
          · exact h
          · exact absurd h this
        · push_neg at hxne
          have hyne : seg.p2.y ≠ seg.p1.y := by
            intro hye; apply h_seg_nondeg; ext
            · exact hxne.symm
            · exact hye.symm
          have : seg.p2.y - seg.p1.y ≠ 0 := sub_ne_zero.mpr hyne
          rcases mul_eq_zero.mp hay_diff with h | h
          · exact h
          · exact absurd h this
      have h_div_eq : δ / (a + 2) = δ / (b + 2) := by linarith
      rw [div_eq_div_iff h_a2_ne h_b2_ne] at h_div_eq
      have hδ_ne : δ ≠ 0 := ne_of_gt hδ_pos
      have h_ab : ((b : ℚ) + 2) = ((a : ℚ) + 2) := mul_left_cancel₀ hδ_ne h_div_eq
      have h_ab' : (a : ℚ) = (b : ℚ) := by linarith
      exact_mod_cast h_ab'
    apply h_fin.not_infinite
    apply Set.infinite_of_injective_forall_mem (f := f) h_f_inj
    exact h_f_in

set_option maxHeartbeats 800000 in
/-- Set-theoretic characterization of the refinement points of a segment, with
    endpoints excluded from both sides.

    **Note**: We exclude `seg.p1` and `seg.p2` from both sides because the
    `crossings` list inside `refinementPointsForSegment` may include the
    segment's endpoints (when a `m2` segment passes exactly through one of
    them), but the right-hand-side characterization requires open-interior
    points.

    **Note (capture hypothesis)**: We use `boundaryCaptureProperty m1 m2`
    as a hypothesis to handle the parallel/collinear case in the backward
    direction (where `segSegIntersect = none`). This mirrors the pattern used
    by `refinedSegments_inter_boundary_subset` in this file. -/
private theorem refinementPointsForSegment_set_eq
    (m1 m2 : Multipolygon) (seg : LineSegment)
    (h_seg : seg ∈ m1.segments)
    (h1_nondeg : ∀ s ∈ m1.segments, s.p1 ≠ s.p2)
    (_h2_nondeg : ∀ s ∈ m2.segments, s.p1 ≠ s.p2)
    (_h_fin : Set.Finite (m1.toBoundarySet ∩ m2.toBoundarySet))
    (h_capture : boundaryCaptureProperty m1 m2) :
    { p : Vector2D | p ∈ refinementPointsForSegment seg m1 m2 ∧
        p ≠ seg.p1 ∧ p ≠ seg.p2 } =
    { p : Vector2D | p ∈ seg.toSet ∧ p ≠ seg.p1 ∧ p ≠ seg.p2 ∧
        (p ∈ m1.toVertices ∨ p ∈ m2.toBoundarySet) } := by
  have h_seg_ne : seg.p1 ≠ seg.p2 := h1_nondeg seg h_seg
  ext p
  simp only [Set.mem_setOf_eq]
  constructor
  · -- Forward direction: list-membership ⇒ set characterization.
    rintro ⟨hp_list, hp_ne1, hp_ne2⟩
    -- p ∈ seg.toSet from refinementPointsForSegment_mem_toSet.
    have hp_seg : p ∈ seg.toSet :=
      refinementPointsForSegment_mem_toSet seg m1 m2 h_seg_ne p hp_list
    refine ⟨hp_seg, hp_ne1, hp_ne2, ?_⟩
    -- Split based on which sublist contains p.
    unfold refinementPointsForSegment at hp_list
    simp only [List.mem_append] at hp_list
    rcases hp_list with hpc | hpv
    · -- p ∈ crossings: there is a m2 segment seg2 with segSegIntersect seg seg2 = some p.
      right
      simp only [List.mem_filterMap] at hpc
      obtain ⟨seg2, h_seg2_mem, h_int⟩ := hpc
      -- By segSegIntersect_correct, the returned point is in seg2.toSet.
      rcases segSegIntersect_correct seg seg2 with ⟨pt, hpt_eq, _, hpt_seg2⟩ | hnone
      · rw [hpt_eq] at h_int
        rw [Option.some_inj] at h_int
        -- h_int : pt = p, so p ∈ seg2.toSet.
        have hp_seg2 : p ∈ seg2.toSet := h_int ▸ hpt_seg2
        exact ⟨seg2, h_seg2_mem, hp_seg2⟩
      · rw [h_int] at hnone; exact absurd hnone (by simp)
    · -- p ∈ selfVerts: p is a m1 vertex satisfying the filter.
      left
      simp only [List.mem_filter, Bool.and_eq_true, decide_eq_true_eq] at hpv
      obtain ⟨hp_vert, _⟩ := hpv
      exact hp_vert
  · -- Backward direction: set characterization ⇒ list-membership.
    rintro ⟨hp_seg, hp_ne1, hp_ne2, hp_or⟩
    refine ⟨?_, hp_ne1, hp_ne2⟩
    rcases hp_or with hp_v1 | hp_b2
    · -- Case: p is a m1 vertex on seg's interior.
      -- Show p ∈ selfVerts.
      unfold refinementPointsForSegment
      simp only [List.mem_append]
      right
      simp only [List.mem_filter, Bool.and_eq_true, decide_eq_true_eq]
      refine ⟨hp_v1, ⟨⟨?_, hp_ne1⟩, hp_ne2⟩⟩
      exact pointOnSegmentBool_of_mem_toSet seg p h_seg_ne hp_seg
    · -- Case: p is on m2's boundary.
      obtain ⟨seg2, h_seg2_mem, hp_seg2⟩ := hp_b2
      -- Split on whether segSegIntersect seg seg2 returns some or none.
      rcases h_int : segSegIntersect seg seg2 with _ | pt
      · -- Parallel/collinear case: appeal to h_capture, then exclude endpoints.
        have h_in_split : p ∈ (seg.p1 :: seg.p2 :: refinementPointsForSegment seg m1 m2) :=
          h_capture seg h_seg p hp_seg seg2 h_seg2_mem hp_seg2 h_int
        simp only [List.mem_cons] at h_in_split
        rcases h_in_split with h | h | h
        · exact absurd h hp_ne1
        · exact absurd h hp_ne2
        · exact h
      · -- Transverse case: p must equal pt, and pt is in crossings.
        -- First extract the transverse-intersection formula from h_int.
        have h_pt_correct := segSegIntersect_correct seg seg2
        rcases h_pt_correct with ⟨pt', hpt'_eq, hpt'_seg, _⟩ | hnone
        · rw [h_int] at hpt'_eq
          rw [Option.some_inj] at hpt'_eq
          have hpt_seg : pt ∈ seg.toSet := hpt'_eq ▸ hpt'_seg
          -- Show p = pt by uniqueness of transverse intersection (D ≠ 0).
          have h_p_eq_pt : p = pt := by
            rw [segSegIntersect_some_iff] at h_int
            obtain ⟨_hD_ne, _, _, _, _, hpt_eq⟩ := h_int
            obtain ⟨t1, _, _, hqx1, hqy1⟩ := hp_seg
            obtain ⟨t2, _, _, hqx2, hqy2⟩ := hp_seg2
            set dx1 := seg.p2.x - seg.p1.x
            set dy1 := seg.p2.y - seg.p1.y
            set dx2 := seg2.p2.x - seg2.p1.x
            set dy2 := seg2.p2.y - seg2.p1.y
            set D := dx1 * dy2 - dy1 * dx2 with hD_def
            set bx := seg2.p1.x - seg.p1.x
            set by_ := seg2.p1.y - seg.p1.y
            set t1Num := bx * dy2 - by_ * dx2
            have hqx1' : p.x - seg.p1.x = t1 * dx1 := by rw [hqx1]; ring
            have hqy1' : p.y - seg.p1.y = t1 * dy1 := by rw [hqy1]; ring
            have hqx2'' : p.x - seg2.p1.x = t2 * dx2 := by rw [hqx2]; ring
            have hqy2'' : p.y - seg2.p1.y = t2 * dy2 := by rw [hqy2]; ring
            have heq_x : t1 * dx1 = bx + t2 * dx2 := by
              have hcomb : p.x - seg.p1.x = (p.x - seg2.p1.x) + (seg2.p1.x - seg.p1.x) := by ring
              rw [hqx1', hqx2''] at hcomb
              show t1 * dx1 = (seg2.p1.x - seg.p1.x) + t2 * dx2
              linarith
            have heq_y : t1 * dy1 = by_ + t2 * dy2 := by
              have hcomb : p.y - seg.p1.y = (p.y - seg2.p1.y) + (seg2.p1.y - seg.p1.y) := by ring
              rw [hqy1', hqy2''] at hcomb
              show t1 * dy1 = (seg2.p1.y - seg.p1.y) + t2 * dy2
              linarith
            have hkey : t1 * D = t1Num := by
              have e1 : (t1 * dx1) * dy2 = (bx + t2 * dx2) * dy2 := by rw [heq_x]
              have e2 : (t1 * dy1) * dx2 = (by_ + t2 * dy2) * dx2 := by rw [heq_y]
              show t1 * (dx1 * dy2 - dy1 * dx2) = bx * dy2 - by_ * dx2
              nlinarith [e1, e2]
            have ht1_val : t1 = t1Num / D := by
              rw [eq_div_iff _hD_ne]
              linarith [hkey]
            rw [hpt_eq]
            ext
            · show p.x = seg.p1.x + t1Num / D * dx1
              rw [← ht1_val]; linarith [hqx1']
            · show p.y = seg.p1.y + t1Num / D * dy1
              rw [← ht1_val]; linarith [hqy1']
          -- Now p = pt ∈ crossings.
          unfold refinementPointsForSegment
          simp only [List.mem_append]
          left
          rw [h_p_eq_pt]
          exact mem_crossings_of_segSegIntersect seg m2 seg2 pt h_seg2_mem h_int
        · rw [h_int] at hnone; exact absurd hnone (by simp)

set_option maxHeartbeats 800000 in
/-- KEY LEMMA: In any refined sub-segment, the only intersection points with
    `m2`'s boundary are the endpoints of the sub-segment.

    **Note (weaker form)**: This is proved with two additional hypotheses:
    * `h_struct`: the geometric "consecutivity" property of
      `splitSegmentAtPoints` (depends on sortedness of `mergeSort` w.r.t.
      `vecCmpAlongSeg`).
    * `h_capture`: every m2-boundary intersection arising from a
      *parallel/collinear* m2 segment is captured in the refinement list
      (derivable from `h_fin` via a finite-overlap argument).
    The transverse case is proved inline. -/
private theorem refinedSegments_inter_boundary_subset
    (m1 m2 : Multipolygon)
    (_h_fin : Set.Finite (m1.toBoundarySet ∩ m2.toBoundarySet))
    (h_nondeg1 : ∀ seg ∈ m1.segments, seg.p1 ≠ seg.p2)
    (h_struct : splitStructuralProperty m1 m2)
    (h_capture : boundaryCaptureProperty m1 m2) :
    ∀ rs ∈ refinedSegments m1 m2,
      rs.toSet ∩ m2.toBoundarySet ⊆ ({rs.p1, rs.p2} : Set Vector2D) := by
  intro rs h_rs q ⟨hq_rs, hq_b⟩
  unfold refinedSegments at h_rs
  rw [List.mem_flatMap] at h_rs
  obtain ⟨seg, h_seg_mem, h_rs_split⟩ := h_rs
  have h_seg_ne : seg.p1 ≠ seg.p2 := h_nondeg1 seg h_seg_mem
  have h_pts_on_seg : ∀ p ∈ refinementPointsForSegment seg m1 m2, p ∈ seg.toSet :=
    refinementPointsForSegment_mem_toSet seg m1 m2 h_seg_ne
  have h_rs_subset : rs.toSet ⊆ seg.toSet :=
    splitSegmentAtPoints_toSet_subset seg _ h_pts_on_seg rs h_rs_split
  have hq_seg : q ∈ seg.toSet := h_rs_subset hq_rs
  -- q ∈ m2.toBoundarySet, so q ∈ seg2.toSet for some seg2 ∈ m2.segments.
  obtain ⟨seg2, h_seg2_mem, h_q_seg2⟩ := hq_b
  -- Show q ∈ split-points list.
  have h_q_in_split : q ∈ (seg.p1 :: seg.p2 :: refinementPointsForSegment seg m1 m2) := by
    rcases hint_disj : segSegIntersect seg seg2 with _ | pt
    · -- Parallel/collinear case: appeal to h_capture.
      exact h_capture seg h_seg_mem q hq_seg seg2 h_seg2_mem h_q_seg2 hint_disj
    · -- Transverse case: prove q = pt and pt is in crossings.
      have h_pt_correct := segSegIntersect_correct seg seg2
      rcases h_pt_correct with ⟨pt', hpt'_eq, hpt'_seg, hpt'_seg2⟩ | hnone
      · rw [hint_disj] at hpt'_eq
        rw [Option.some_inj] at hpt'_eq
        have hpt_seg : pt ∈ seg.toSet := hpt'_eq ▸ hpt'_seg
        have hpt_seg2 : pt ∈ seg2.toSet := hpt'_eq ▸ hpt'_seg2
        have h_pt_in : pt ∈ refinementPointsForSegment seg m1 m2 := by
          unfold refinementPointsForSegment
          simp only [List.mem_append]
          left
          exact mem_crossings_of_segSegIntersect seg m2 seg2 pt h_seg2_mem hint_disj
        -- Show q = pt.
        have h_q_eq_pt : q = pt := by
          rw [segSegIntersect_some_iff] at hint_disj
          obtain ⟨_hD_ne, _, _, _, _, hpt_eq⟩ := hint_disj
          obtain ⟨t1, _, _, hqx1, hqy1⟩ := hq_seg
          obtain ⟨t2, _, _, hqx2, hqy2⟩ := h_q_seg2
          set dx1 := seg.p2.x - seg.p1.x
          set dy1 := seg.p2.y - seg.p1.y
          set dx2 := seg2.p2.x - seg2.p1.x
          set dy2 := seg2.p2.y - seg2.p1.y
          set D := dx1 * dy2 - dy1 * dx2 with hD_def
          set bx := seg2.p1.x - seg.p1.x
          set by_ := seg2.p1.y - seg.p1.y
          set t1Num := bx * dy2 - by_ * dx2
          have hqx1' : q.x - seg.p1.x = t1 * dx1 := by rw [hqx1]; ring
          have hqy1' : q.y - seg.p1.y = t1 * dy1 := by rw [hqy1]; ring
          have hqx2'' : q.x - seg2.p1.x = t2 * dx2 := by rw [hqx2]; ring
          have hqy2'' : q.y - seg2.p1.y = t2 * dy2 := by rw [hqy2]; ring
          have heq_x : t1 * dx1 = bx + t2 * dx2 := by
            have : q.x - seg.p1.x = (q.x - seg2.p1.x) + (seg2.p1.x - seg.p1.x) := by ring
            rw [hqx1', hqx2''] at this
            show t1 * dx1 = (seg2.p1.x - seg.p1.x) + t2 * dx2
            linarith
          have heq_y : t1 * dy1 = by_ + t2 * dy2 := by
            have : q.y - seg.p1.y = (q.y - seg2.p1.y) + (seg2.p1.y - seg.p1.y) := by ring
            rw [hqy1', hqy2''] at this
            show t1 * dy1 = (seg2.p1.y - seg.p1.y) + t2 * dy2
            linarith
          have hkey : t1 * D = t1Num := by
            have e1 : (t1 * dx1) * dy2 = (bx + t2 * dx2) * dy2 := by rw [heq_x]
            have e2 : (t1 * dy1) * dx2 = (by_ + t2 * dy2) * dx2 := by rw [heq_y]
            show t1 * (dx1 * dy2 - dy1 * dx2) = bx * dy2 - by_ * dx2
            nlinarith [e1, e2]
          have ht1_val : t1 = t1Num / D := by
            rw [eq_div_iff _hD_ne]
            linarith [hkey]
          rw [hpt_eq]
          ext
          · show q.x = seg.p1.x + t1Num / D * dx1
            rw [← ht1_val]; linarith [hqx1']
          · show q.y = seg.p1.y + t1Num / D * dy1
            rw [← ht1_val]; linarith [hqy1']
        rw [h_q_eq_pt]
        simp only [List.mem_cons]
        right; right; exact h_pt_in
      · rw [hint_disj] at hnone; exact absurd hnone (by simp)
  have := h_struct seg h_seg_mem rs h_rs_split q h_q_in_split hq_rs
  rcases this with h | h
  · left; exact h
  · right; exact h

/-- Stronger form of `refinedSegments_inter_boundary_subset`: discharges the
    `splitStructuralProperty` and `boundaryCaptureProperty` hypotheses using
    `splitStructuralProperty_holds` and `boundaryCaptureProperty_holds`. -/
private theorem refinedSegments_inter_boundary_subset_strong
    (m1 m2 : Multipolygon)
    (h_fin : Set.Finite (m1.toBoundarySet ∩ m2.toBoundarySet))
    (h1_nondeg : ∀ seg ∈ m1.segments, seg.p1 ≠ seg.p2)
    (h2_nondeg : ∀ seg ∈ m2.segments, seg.p1 ≠ seg.p2) :
    ∀ rs ∈ refinedSegments m1 m2,
      rs.toSet ∩ m2.toBoundarySet ⊆ ({rs.p1, rs.p2} : Set Vector2D) :=
  refinedSegments_inter_boundary_subset m1 m2 h_fin h1_nondeg
    (splitStructuralProperty_holds m1 m2 h1_nondeg)
    (boundaryCaptureProperty_holds m1 m2 h1_nondeg h2_nondeg h_fin)

/-! ### Canonical refinement points (for the construction Equiv proof)

Helper definition and structural lemmas relating
`splitSegmentAtPoints seg (canonicalRefinementPoints seg m1 m2)` to the
segments produced by the noncomputable `graphRefinementSelfAndWrt`.

The full theorem `graphRefinementSelfAndWrt_segments_canonical_form`
characterizing the multiset of segments produced by the noncomputable
refinement is the central technical lemma needed to relate
`intersectionGraphSegments` to `evenGraphIntersection`. The helper
lemmas below capture the structural facts used by it. -/

/-- The canonical insertion points for splitting `seg` (a segment of `m1`)
    when refining `m1` with respect to `m2`. These are exactly the
    points `graphRefinementSelfAndWrt` inserts on `seg`: by definition,
    `refinementPointsForSegment` returns the rational intersections of
    `seg` with each `m2.segment`, plus all `m1.allVertices` that lie
    strictly in `seg`'s interior. -/
private def canonicalRefinementPoints (seg : LineSegment) (m1 m2 : Multipolygon) :
    List Vector2D := refinementPointsForSegment seg m1 m2

/-- Unfolding: `canonicalRefinementPoints` is `refinementPointsForSegment`. -/
private theorem canonicalRefinementPoints_eq (seg : LineSegment) (m1 m2 : Multipolygon) :
    canonicalRefinementPoints seg m1 m2 = refinementPointsForSegment seg m1 m2 :=
  rfl

/-- The canonical refinement points for a non-degenerate segment all lie
    on that segment. Direct consequence of
    `refinementPointsForSegment_mem_toSet`. -/
private theorem canonicalRefinementPoints_mem_toSet
    (seg : LineSegment) (m1 m2 : Multipolygon) (h_ne : seg.p1 ≠ seg.p2) :
    ∀ p ∈ canonicalRefinementPoints seg m1 m2, p ∈ seg.toSet := by
  intro p hp
  rw [canonicalRefinementPoints_eq] at hp
  exact refinementPointsForSegment_mem_toSet seg m1 m2 h_ne p hp

/-- The endpoints of a sub-segment from
    `splitSegmentAtPoints seg (canonicalRefinementPoints seg m1 m2)`
    belong to `seg.p1 :: seg.p2 :: canonicalRefinementPoints seg m1 m2`. -/
private theorem splitSegmentAtPoints_canonical_endpoints_mem
    (seg : LineSegment) (m1 m2 : Multipolygon)
    (rs : LineSegment)
    (h_rs : rs ∈ splitSegmentAtPoints seg (canonicalRefinementPoints seg m1 m2)) :
    rs.p1 ∈ seg.p1 :: seg.p2 :: canonicalRefinementPoints seg m1 m2 ∧
    rs.p2 ∈ seg.p1 :: seg.p2 :: canonicalRefinementPoints seg m1 m2 :=
  splitSegmentAtPoints_endpoints_mem seg _ rs h_rs

/-- A sub-segment from
    `splitSegmentAtPoints seg (canonicalRefinementPoints seg m1 m2)`
    with `seg` non-degenerate is itself contained in `seg.toSet`. -/
private theorem splitSegmentAtPoints_canonical_toSet_subset
    (seg : LineSegment) (m1 m2 : Multipolygon) (h_ne : seg.p1 ≠ seg.p2)
    (rs : LineSegment)
    (h_rs : rs ∈ splitSegmentAtPoints seg (canonicalRefinementPoints seg m1 m2)) :
    rs.toSet ⊆ seg.toSet :=
  splitSegmentAtPoints_toSet_subset seg _
    (canonicalRefinementPoints_mem_toSet seg m1 m2 h_ne) rs h_rs

/-! ## Section 3 — Computable point-in-polygon test

For each `k ∈ [1, K]`, try the ray with origin `p` and direction `(1, k)`.
If the ray avoids polygon vertices, count crossings; else try `k+1`. -/

/- Bool test: does the ray with origin `p`, direction `(1, k)`, avoid all
    vertices of `m`? A vertex `v` is on the ray iff
    `v - p = t · (1, k)` for some `t ≥ 0`, i.e. `v.y - p.y = k · (v.x - p.x)`
    and `v.x ≥ p.x`. -/
-- moved: `rayAvoidsVerticesBool` lives in `Polygons.MultipolygonIntersectionAlgorithmImpl`
/- Count crossings of the ray with origin `p`, direction `(1, k)` against
    polygon segments. -/
-- moved: `rayCountWithSlopeMultipolygon` lives in `Polygons.MultipolygonIntersectionAlgorithmImpl`
/- Find a slope `k ∈ [1, fuel]` that avoids the polygon's vertices, then
    count crossings. Returns `0` if no slope in the range works (which won't
    happen for `fuel ≥ m.allVertices.length + 1`). -/
-- moved: `rayCountSearchMultipolygon` lives in `Polygons.MultipolygonIntersectionAlgorithmImpl`
/- Point-in-polygon test: avoid segments and have an odd ray-crossing count
    with some valid slope. -/
-- moved: `pointInsideMultipolygonBool` lives in `Polygons.MultipolygonIntersectionAlgorithmImpl`
/- The ray with origin `p` and direction `(1, k)`. -/
-- moved: `slopeRay` lives in `Polygons.MultipolygonIntersectionAlgorithmImpl`
/-- A vertex `v` lies on `slopeRay p k` iff `v.x ≥ p.x` and the slope condition. -/
private lemma mem_slopeRay_iff (p : Vector2D) (k : ℚ) (v : Vector2D) :
    v ∈ (slopeRay p k).toSet ↔ v.x ≥ p.x ∧ v.y - p.y = k * (v.x - p.x) := by
  unfold slopeRay
  show (∃ t : ℚ, 0 ≤ t ∧ v.x = p.x + t * 1 ∧ v.y = p.y + t * k) ↔ _
  constructor
  · rintro ⟨t, ht_nn, hvx, hvy⟩
    have h_t_eq : t = v.x - p.x := by linarith [hvx]
    refine ⟨?_, ?_⟩
    · linarith [hvx]
    · rw [hvy]; rw [h_t_eq]; ring
  · rintro ⟨h_ge, h_eq⟩
    refine ⟨v.x - p.x, by linarith, ?_, ?_⟩
    · ring
    · linarith [h_eq]

/-- The boolean test `rayAvoidsVerticesBool` matches the proposition
    `rayAvoidsMultipolygonVertices` for the ray with slope `(1, k)`. -/
private lemma rayAvoidsVerticesBool_iff (p : Vector2D) (k : ℚ) (m : Multipolygon) :
    rayAvoidsVerticesBool p k m = true ↔ rayAvoidsMultipolygonVertices (slopeRay p k) m := by
  unfold rayAvoidsVerticesBool rayAvoidsMultipolygonVertices
  rw [List.all_eq_true]
  rw [Set.eq_empty_iff_forall_not_mem]
  constructor
  · intro h q hq
    obtain ⟨hq_ray, hq_vert⟩ := hq
    have hq_in_verts : q ∈ m.allVertices := hq_vert
    have hq_cond := (mem_slopeRay_iff p k q).mp hq_ray
    have hh := h q hq_in_verts
    -- hh : !(decide (q.x ≥ p.x) && decide (q.y - p.y = k * (q.x - p.x))) = true
    -- Hence decide (q.x ≥ p.x) && decide (q.y - p.y = ...) = false.
    rw [Bool.not_eq_true'] at hh
    rcases (Bool.and_eq_false_iff).mp hh with hh' | hh'
    · exact (decide_eq_false_iff_not.mp hh') hq_cond.1
    · exact (decide_eq_false_iff_not.mp hh') hq_cond.2
  · intro h v hv
    -- Goal: !(decide (v.x ≥ p.x) && decide (v.y - p.y = k * (v.x - p.x))) = true
    -- We show this is equivalent to ¬ (v.x ≥ p.x ∧ v.y - p.y = ...).
    by_contra h_neq
    -- h_neq : !(...) ≠ true.
    have h_eq_true : (decide (v.x ≥ p.x) && decide (v.y - p.y = k * (v.x - p.x))) = true := by
      cases hb : decide (v.x ≥ p.x) && decide (v.y - p.y = k * (v.x - p.x))
      · exfalso; apply h_neq; simp [hb]
      · rfl
    rw [Bool.and_eq_true] at h_eq_true
    obtain ⟨h1, h2⟩ := h_eq_true
    have h_vx_ge : v.x ≥ p.x := decide_eq_true_eq.mp h1
    have h_vy_eq : v.y - p.y = k * (v.x - p.x) := decide_eq_true_eq.mp h2
    have h_v_in_ray : v ∈ (slopeRay p k).toSet :=
      (mem_slopeRay_iff p k v).mpr ⟨h_vx_ge, h_vy_eq⟩
    exact h v ⟨h_v_in_ray, hv⟩

/-- The slope-based crossing count equals the noncomputable count for the
    corresponding ray. -/
private lemma rayCountWithSlopeMultipolygon_eq_intersectionRayMultipolygonSegmentsNumber
    (p : Vector2D) (k : ℚ) (m : Multipolygon) :
    rayCountWithSlopeMultipolygon p k m =
    intersectionRayMultipolygonSegmentsNumber (slopeRay p k) m := by
  show m.segments.countP _ = m.segments.countP _
  apply List.countP_congr
  intro seg _
  simp only [decide_eq_true_iff]
  -- Goal: rayIntersectsSegmentBool (slopeRay p k) seg = true ↔ rayIntersectsSegment (slopeRay p k) seg
  exact RayIntersectionAlgorithmProofs.rayIntersectsSegmentBool_iff _ seg

/-- Disjunction: `rayCountSearchMultipolygon` either returns 0 (when all candidate slopes
    in its range are bad), or it returns `rayCountWithSlopeMultipolygon` for some slope `k`
    that avoids the vertices. -/
private lemma rayCountSearchMultipolygon_disjunction
    (p : Vector2D) (m : Multipolygon) (fuel : ℕ) :
    (rayCountSearchMultipolygon p m fuel = 0 ∧
      ∀ n < fuel, rayAvoidsVerticesBool p
        ((m.allVertices.length + 1 - n : ℕ) : ℚ) m = false) ∨
    (∃ k : ℚ, rayAvoidsVerticesBool p k m = true ∧
      rayCountSearchMultipolygon p m fuel = rayCountWithSlopeMultipolygon p k m) := by
  induction fuel with
  | zero =>
    left
    refine ⟨rfl, ?_⟩
    intro n hn
    exact absurd hn (Nat.not_lt_zero _)
  | succ n ih =>
    -- At fuel = n+1, k = (vertices.length + 1 - n : ℕ) : ℚ
    set k : ℚ := ((m.allVertices.length + 1 - n : ℕ) : ℚ) with hk_def
    -- Compute rayCountSearchMultipolygon p m (n+1).
    have h_unfold : rayCountSearchMultipolygon p m (n + 1) =
        if rayAvoidsVerticesBool p k m then rayCountWithSlopeMultipolygon p k m
        else rayCountSearchMultipolygon p m n := rfl
    by_cases hk : rayAvoidsVerticesBool p k m = true
    · right
      refine ⟨k, hk, ?_⟩
      rw [h_unfold, if_pos hk]
    · have hk_false : rayAvoidsVerticesBool p k m = false := by
        cases hb : rayAvoidsVerticesBool p k m
        · rfl
        · exact absurd hb hk
      rcases ih with ⟨h_zero, h_all_bad⟩ | ⟨k', hk', h_eq⟩
      · left
        constructor
        · rw [h_unfold, if_neg (by rw [hk_false]; decide)]
          exact h_zero
        · intro idx hidx
          rcases Nat.lt_succ_iff_lt_or_eq.mp hidx with hm_lt | hm_eq
          · exact h_all_bad idx hm_lt
          · subst hm_eq
            exact hk_false
      · right
        refine ⟨k', hk', ?_⟩
        rw [h_unfold, if_neg (by rw [hk_false]; decide)]
        exact h_eq

/-- Vertex hit by slope ray (when the boolean check fails). -/
private lemma exists_vertex_hit_of_bool_false
    (p : Vector2D) (k : ℚ) (m : Multipolygon)
    (hk : rayAvoidsVerticesBool p k m = false) :
    ∃ v ∈ m.allVertices, v.x ≥ p.x ∧ v.y - p.y = k * (v.x - p.x) := by
  unfold rayAvoidsVerticesBool at hk
  -- hk : m.allVertices.all (fun v => !(decide ... && decide ...)) = false
  -- Use that ¬ (all ... = true). Then existence.
  have hk_neg : ¬ (m.allVertices.all
      (fun v => !(decide (v.x ≥ p.x) && decide (v.y - p.y = k * (v.x - p.x)))) = true) := by
    rw [hk]; decide
  rw [List.all_eq_true] at hk_neg
  push_neg at hk_neg
  obtain ⟨v, hv_mem, hv_cond⟩ := hk_neg
  -- hv_cond : !(decide (v.x ≥ p.x) && decide (...)) ≠ true
  -- This means decide (v.x ≥ p.x) && decide (...) = true.
  have h_and : (decide (v.x ≥ p.x) && decide (v.y - p.y = k * (v.x - p.x))) = true := by
    cases hb : decide (v.x ≥ p.x) && decide (v.y - p.y = k * (v.x - p.x))
    · simp [hb] at hv_cond
    · rfl
  rw [Bool.and_eq_true] at h_and
  obtain ⟨h1, h2⟩ := h_and
  exact ⟨v, hv_mem, decide_eq_true_eq.mp h1, decide_eq_true_eq.mp h2⟩

/-- Pigeonhole: when `p` is not a polygon vertex, distinct slopes can't share
    a hit witness. -/
private lemma slope_witness_unique
    (p v : Vector2D) (k₁ k₂ : ℚ)
    (hv_x_ge_1 : v.x ≥ p.x)
    (hv_eq_1 : v.y - p.y = k₁ * (v.x - p.x))
    (hv_x_ge_2 : v.x ≥ p.x)
    (hv_eq_2 : v.y - p.y = k₂ * (v.x - p.x))
    (h_p_ne_v : p ≠ v) :
    k₁ = k₂ := by
  -- Either v.x > p.x (so divide), or v.x = p.x and then v.y = p.y → v = p (contradiction).
  rcases lt_or_eq_of_le hv_x_ge_1 with hgt | heq
  · -- v.x > p.x ↔ p.x < v.x; we have v.x ≥ p.x and v.x > p.x.
    have h_diff : v.x - p.x ≠ 0 := by linarith
    have h_eq : k₁ * (v.x - p.x) = k₂ * (v.x - p.x) := by
      rw [← hv_eq_1, ← hv_eq_2]
    exact mul_right_cancel₀ h_diff h_eq
  · -- v.x = p.x. Then v.y - p.y = k * 0 = 0 → v.y = p.y → v = p.
    -- heq : p.x = v.x
    have h_vy_eq : v.y - p.y = 0 := by
      rw [hv_eq_1]
      have : v.x - p.x = 0 := by linarith
      rw [this]; ring
    have h_vy : v.y = p.y := by linarith
    have h_vx : v.x = p.x := heq.symm
    exfalso
    apply h_p_ne_v
    cases p; cases v; simp_all

/-- Pigeonhole: when p avoids all polygon segments and the polygon has at
    least one segment, there must exist a slope `k ∈ {1, ..., vertices.length+1}`
    that avoids all polygon vertices. -/
private lemma exists_good_slope_in_search_range (p : Vector2D) (m : Multipolygon)
    (h_len : ∀ poly ∈ m.polygons, poly.vertices.length ≥ 2)
    (h_distinct : ∀ seg ∈ m.segments, seg.p1 ≠ seg.p2)
    (h_avoids : ∀ seg ∈ m.segments, pointAvoidsSegment p seg) :
    ∃ n < m.allVertices.length + 1,
      rayAvoidsVerticesBool p ((m.allVertices.length + 1 - n : ℕ) : ℚ) m = true := by
  by_contra h
  push_neg at h
  -- h : ∀ n < vertices.length + 1, rayAvoidsVerticesBool p (...) m ≠ true
  -- For each n ∈ Fin (vertices.length + 1), pick a witness vertex.
  -- The witness function is injective (distinct n → distinct k → distinct vertex).
  -- But all witnesses are in m.allVertices (length vertices.length).
  -- vertices.length + 1 > vertices.length → contradiction.
  -- For the pigeon-hole, p must not be a vertex (use h_avoids).
  -- Every vertex v is on some segment (toSet). Hence p = v contradicts h_avoids.
  have h_p_not_vertex : ∀ v ∈ m.allVertices, p ≠ v := by
    intro v hv h_eq
    obtain ⟨seg, hseg, h_v_in_seg⟩ :=
      Multipolygon.vertex_on_some_segment m h_len h_distinct v hv
    have hp_not_in : p ∉ seg.toSet := h_avoids seg hseg
    rw [h_eq] at hp_not_in
    exact hp_not_in h_v_in_seg
  -- Now define f : Fin (vertices.length + 1) → Vector2D, picking a witness vertex.
  -- For each n with k_n bad, pick a witness via exists_vertex_hit_of_bool_false.
  classical
  let f : Fin (m.allVertices.length + 1) → Vector2D := fun n =>
    let k_n : ℚ := ((m.allVertices.length + 1 - n.val : ℕ) : ℚ)
    have h_bad : rayAvoidsVerticesBool p k_n m = false := by
      have := h n.val n.isLt
      cases hb : rayAvoidsVerticesBool p k_n m
      · rfl
      · exact absurd hb this
    Classical.choose (exists_vertex_hit_of_bool_false p k_n m h_bad)
  -- Properties of f.
  have f_spec : ∀ n : Fin (m.allVertices.length + 1),
      f n ∈ m.allVertices ∧ (f n).x ≥ p.x ∧
      (f n).y - p.y = ((m.allVertices.length + 1 - n.val : ℕ) : ℚ) * ((f n).x - p.x) := by
    intro n
    let k_n : ℚ := ((m.allVertices.length + 1 - n.val : ℕ) : ℚ)
    have h_bad : rayAvoidsVerticesBool p k_n m = false := by
      have := h n.val n.isLt
      cases hb : rayAvoidsVerticesBool p k_n m
      · rfl
      · exact absurd hb this
    have h_choose := Classical.choose_spec (exists_vertex_hit_of_bool_false p k_n m h_bad)
    show f n ∈ m.allVertices ∧ (f n).x ≥ p.x ∧ (f n).y - p.y = k_n * ((f n).x - p.x)
    exact ⟨h_choose.1, h_choose.2.1, h_choose.2.2⟩
  -- f is injective: distinct n's give distinct k's (since 1, ..., vertices.length+1 are distinct).
  have f_inj : Function.Injective f := by
    intro n1 n2 h_fn_eq
    by_contra h_ne
    have hfn := f_spec n1
    have hfm := f_spec n2
    rw [h_fn_eq] at hfn
    have h_p_ne_fn : p ≠ f n2 := h_p_not_vertex (f n2) hfm.1
    have k_eq := slope_witness_unique p (f n2)
      ((m.allVertices.length + 1 - n1.val : ℕ) : ℚ)
      ((m.allVertices.length + 1 - n2.val : ℕ) : ℚ)
      hfn.2.1 hfn.2.2 hfm.2.1 hfm.2.2 h_p_ne_fn
    have h_n_le : n1.val < m.allVertices.length + 1 := n1.isLt
    have h_m_le : n2.val < m.allVertices.length + 1 := n2.isLt
    have h_n_le' : n1.val ≤ m.allVertices.length := Nat.lt_succ_iff.mp h_n_le
    have h_m_le' : n2.val ≤ m.allVertices.length := Nat.lt_succ_iff.mp h_m_le
    have h_nat_eq :
        (m.allVertices.length + 1 - n1.val : ℕ) =
        (m.allVertices.length + 1 - n2.val : ℕ) := by
      exact_mod_cast k_eq
    have h_nv_eq : n1.val = n2.val := by omega
    apply h_ne
    apply Fin.ext
    exact h_nv_eq
  -- Now: f is injective from Fin (length + 1) into a finite set of size ≤ length.
  -- Use Finset.card_le_card: image of Fin (length+1) under f ⊆ m.allVertices.toFinset.
  have h_image_card_eq : ((Finset.univ : Finset (Fin (m.allVertices.length + 1))).image f).card =
      m.allVertices.length + 1 := by
    rw [Finset.card_image_of_injective _ f_inj]
    exact Finset.card_univ.trans (Fintype.card_fin _)
  have h_image_subset : (Finset.univ : Finset (Fin (m.allVertices.length + 1))).image f ⊆
      m.allVertices.toFinset := by
    intro v hv
    simp only [Finset.mem_image, Finset.mem_univ, true_and] at hv
    obtain ⟨n, hn⟩ := hv
    rw [List.mem_toFinset]
    rw [← hn]
    exact (f_spec n).1
  have h_image_card_le : ((Finset.univ : Finset (Fin (m.allVertices.length + 1))).image f).card ≤
      m.allVertices.toFinset.card :=
    Finset.card_le_card h_image_subset
  have h_to_finset_card : m.allVertices.toFinset.card ≤ m.allVertices.length :=
    List.toFinset_card_le _
  omega

/-- Multipolygon analog of `intersectionParity_eq_of_sameOrigin_avoidsVertices`.
    Transfers the EvenGraph-level result to a multipolygon via
    `m.toEvenGraph`. -/
private lemma intersectionParity_eq_of_sameOrigin_avoidsMultipolygonVertices
    (r1 r2 : Ray) (m : Multipolygon)
    (h_len : ∀ poly ∈ m.polygons, poly.vertices.length ≥ 2)
    (h_distinct : ∀ seg ∈ m.segments, seg.p1 ≠ seg.p2)
    (h_origin : sameOrigin r1 r2)
    (h_r1_avoids : rayAvoidsMultipolygonVertices r1 m)
    (h_r2_avoids : rayAvoidsMultipolygonVertices r2 m)
    (h_origin_avoids_segments : ∀ seg ∈ m.segments,
      pointAvoidsSegment r1.origin seg) :
    intersectionRayMultipolygonSegmentsNumber r1 m % 2 =
    intersectionRayMultipolygonSegmentsNumber r2 m % 2 := by
  set G := m.toEvenGraph h_len h_distinct with hG_def
  have h_seg : G.segments = m.segments :=
    Multipolygon.toEvenGraph_segments_eq m h_len h_distinct
  have h_vset : G.toVertexSet = m.toVertices :=
    Multipolygon.toEvenGraph_toVertexSet_eq m h_len h_distinct
  have h_r1_avoids_g : rayAvoidsGraphVertices r1 G := by
    rw [rayAvoidsGraphVertices, h_vset]
    rwa [rayAvoidsMultipolygonVertices] at h_r1_avoids
  have h_r2_avoids_g : rayAvoidsGraphVertices r2 G := by
    rw [rayAvoidsGraphVertices, h_vset]
    rwa [rayAvoidsMultipolygonVertices] at h_r2_avoids
  have h_origin_avoids_segs_g :
      ∀ seg ∈ G.segments, pointAvoidsSegment r1.origin seg := by
    intro seg hseg
    apply h_origin_avoids_segments
    rwa [← h_seg]
  have h := intersectionParity_eq_of_sameOrigin_avoidsGraphVertices r1 r2 G
    h_origin h_r1_avoids_g h_r2_avoids_g h_origin_avoids_segs_g
  show m.segments.countP _ % 2 = m.segments.countP _ % 2
  rw [← h_seg]
  exact h

/-- Multipolygon analog of `intersectionParity_eq_of_originSegmentAvoidsSegments`. -/
private lemma intersectionParity_eq_of_originSegmentAvoidsMultipolygonSegments
    (r1 r2 : Ray) (m : Multipolygon)
    (h_len : ∀ poly ∈ m.polygons, poly.vertices.length ≥ 2)
    (h_distinct : ∀ seg ∈ m.segments, seg.p1 ≠ seg.p2)
    (h_r1_avoids : rayAvoidsMultipolygonVertices r1 m)
    (h_r2_avoids : rayAvoidsMultipolygonVertices r2 m)
    (h_origin_segment_avoids : ∀ seg ∈ m.segments,
      segmentDoesNotIntersectSegment ⟨r1.origin, r2.origin⟩ seg)
    (h_verts_avoid_origin_seg : ∀ v ∈ m.toVertices,
      v ∉ (LineSegment.mk r1.origin r2.origin).toSet) :
    intersectionRayMultipolygonSegmentsNumber r1 m % 2 =
    intersectionRayMultipolygonSegmentsNumber r2 m % 2 := by
  set G := m.toEvenGraph h_len h_distinct with hG_def
  have h_seg : G.segments = m.segments :=
    Multipolygon.toEvenGraph_segments_eq m h_len h_distinct
  have h_vset : G.toVertexSet = m.toVertices :=
    Multipolygon.toEvenGraph_toVertexSet_eq m h_len h_distinct
  have h_r1_avoids_g : rayAvoidsGraphVertices r1 G := by
    rw [rayAvoidsGraphVertices, h_vset]
    rwa [rayAvoidsMultipolygonVertices] at h_r1_avoids
  have h_r2_avoids_g : rayAvoidsGraphVertices r2 G := by
    rw [rayAvoidsGraphVertices, h_vset]
    rwa [rayAvoidsMultipolygonVertices] at h_r2_avoids
  have h_origin_segment_avoids_g : ∀ seg ∈ G.segments,
      segmentDoesNotIntersectSegment ⟨r1.origin, r2.origin⟩ seg := by
    intro seg hseg
    apply h_origin_segment_avoids
    rwa [← h_seg]
  have h_verts_avoid_origin_seg_g : ∀ v ∈ G.toVertices,
      v ∉ (LineSegment.mk r1.origin r2.origin).toSet := by
    intro v hv
    apply h_verts_avoid_origin_seg
    show v ∈ m.toVertices
    rw [← h_vset]
    exact hv
  have h := intersectionParity_eq_of_originSegmentAvoidsGraphSegments r1 r2 G
    h_r1_avoids_g h_r2_avoids_g h_origin_segment_avoids_g
    h_verts_avoid_origin_seg_g
  show m.segments.countP _ % 2 = m.segments.countP _ % 2
  rw [← h_seg]
  exact h

/-- Main lemma — equivalence of the boolean test and `interior`. -/
private theorem pointInsideMultipolygonBool_iff (p : Vector2D) (m : Multipolygon)
    (h_len : ∀ poly ∈ m.polygons, poly.vertices.length ≥ 2)
    (h_nondeg : ∀ seg ∈ m.segments, seg.p1 ≠ seg.p2) :
    pointInsideMultipolygonBool p m = true ↔ p ∈ m.interior := by
  -- Set up the boundary check equivalence.
  have h_boundary_iff : m.segments.any
      (fun seg => pointOnSegmentBool p seg.p1 seg.p2) = true ↔
      ¬ (∀ seg ∈ m.segments, pointAvoidsSegment p seg) := by
    rw [List.any_eq_true]
    simp only [pointAvoidsSegment]
    push_neg
    constructor
    · rintro ⟨seg, hseg, h⟩
      refine ⟨seg, hseg, ?_⟩
      exact (pointOnSegmentBool_iff p seg.p1 seg.p2 (h_nondeg seg hseg)).mp h
    · rintro ⟨seg, hseg, h⟩
      refine ⟨seg, hseg, ?_⟩
      exact (pointOnSegmentBool_iff p seg.p1 seg.p2 (h_nondeg seg hseg)).mpr h
  -- Use existential characterization of interior.
  rw [show m.interior = _ from Multipolygon.interior_eq_exists m h_len h_nondeg]
  unfold pointInsideMultipolygonBool
  set onBoundary := m.segments.any (fun seg => pointOnSegmentBool p seg.p1 seg.p2)
  by_cases hb : onBoundary = true
  · -- Boundary case: returns false.
    simp only [hb, ↓reduceIte]
    constructor
    · intro h; exact absurd h (by simp)
    · rintro ⟨h_avoid, _⟩
      exact absurd h_avoid (h_boundary_iff.mp hb)
  · -- Not on boundary.
    have hb_false : onBoundary = false := by
      cases hbb : onBoundary
      · rfl
      · exact absurd hbb hb
    simp only [hb_false, Bool.false_eq_true, ↓reduceIte]
    have h_avoids_segments : ∀ seg ∈ m.segments, pointAvoidsSegment p seg := by
      by_contra h
      have hh := h_boundary_iff.mpr h
      rw [hb_false] at hh
      exact absurd hh (by decide)
    -- Use the pigeonhole to derive that the disjunction's right branch holds.
    have h_search_finds : ∃ k : ℚ, rayAvoidsVerticesBool p k m = true ∧
        rayCountSearchMultipolygon p m (m.allVertices.length + 1) = rayCountWithSlopeMultipolygon p k m := by
      rcases rayCountSearchMultipolygon_disjunction p m (m.allVertices.length + 1) with
        ⟨_, h_all_bad⟩ | ⟨k, hk, h_eq⟩
      · obtain ⟨n, hn_lt, hn_good⟩ :=
          exists_good_slope_in_search_range p m h_len h_nondeg h_avoids_segments
        exfalso
        have := h_all_bad n hn_lt
        rw [hn_good] at this
        exact absurd this (by decide)
      · exact ⟨k, hk, h_eq⟩
    obtain ⟨k, hk, h_eq⟩ := h_search_finds
    -- Now both directions reduce to using k and the parity equivalence.
    constructor
    · intro h_count_odd
      have h_count_odd' : rayCountSearchMultipolygon p m (m.allVertices.length + 1) % 2 = 1 := by
        rw [decide_eq_true_eq] at h_count_odd
        exact h_count_odd
      refine ⟨h_avoids_segments, ?_⟩
      refine ⟨slopeRay p k, rfl, (rayAvoidsVerticesBool_iff p k m).mp hk, ?_⟩
      rw [← rayCountWithSlopeMultipolygon_eq_intersectionRayMultipolygonSegmentsNumber]
      rw [← h_eq]
      exact h_count_odd'
    · rintro ⟨_, r, hr_origin, hr_avoid, hr_odd⟩
      rw [decide_eq_true_eq]
      rw [h_eq, rayCountWithSlopeMultipolygon_eq_intersectionRayMultipolygonSegmentsNumber]
      have h_parity := intersectionParity_eq_of_sameOrigin_avoidsMultipolygonVertices
        (slopeRay p k) r m h_len h_nondeg
        (show (slopeRay p k).origin = r.origin from hr_origin.symm)
        ((rayAvoidsVerticesBool_iff p k m).mp hk)
        hr_avoid
        (by intro seg hseg
            exact h_avoids_segments seg hseg)
      rw [h_parity, hr_odd]

/-! ## Section 4 — Computable intersection graph -/

/- Midpoint of a segment. -/
-- moved: `segmentMidpoint` lives in `Polygons.MultipolygonIntersectionAlgorithmImpl`
/-- Auxiliary: the midpoint of a non-degenerate segment is on the segment and
    distinct from both endpoints. -/
private lemma segmentMidpoint_mem_open_interior
    (seg : LineSegment) (h_nondeg : seg.p1 ≠ seg.p2) :
    segmentMidpoint seg ∈ seg.toSet ∧
    segmentMidpoint seg ≠ seg.p1 ∧ segmentMidpoint seg ≠ seg.p2 := by
  refine ⟨⟨1/2, by norm_num, by norm_num, ?_, ?_⟩, ?_, ?_⟩
  · show (seg.p1.x + seg.p2.x) / 2 = (1 - 1/2) * seg.p1.x + 1/2 * seg.p2.x
    ring
  · show (seg.p1.y + seg.p2.y) / 2 = (1 - 1/2) * seg.p1.y + 1/2 * seg.p2.y
    ring
  · -- midpoint ≠ p1
    intro h_eq
    apply h_nondeg
    have hx : (seg.p1.x + seg.p2.x) / 2 = seg.p1.x := congrArg Vector2D.x h_eq
    have hy : (seg.p1.y + seg.p2.y) / 2 = seg.p1.y := congrArg Vector2D.y h_eq
    have hxx : seg.p2.x = seg.p1.x := by linarith
    have hyy : seg.p2.y = seg.p1.y := by linarith
    ext
    · exact hxx.symm
    · exact hyy.symm
  · -- midpoint ≠ p2
    intro h_eq
    apply h_nondeg
    have hx : (seg.p1.x + seg.p2.x) / 2 = seg.p2.x := congrArg Vector2D.x h_eq
    have hy : (seg.p1.y + seg.p2.y) / 2 = seg.p2.y := congrArg Vector2D.y h_eq
    have hxx : seg.p1.x = seg.p2.x := by linarith
    have hyy : seg.p1.y = seg.p2.y := by linarith
    ext
    · exact hxx
    · exact hyy

/-- Auxiliary (analogue of `segment_in_open_interior` from
    `EvenGraphIntersectionProofs`): if two points lie in the open interior of a
    segment, then any point on the line segment between them is also in the
    open interior of the original segment. -/
private lemma sub_segment_in_open_interior
    (seg : LineSegment) (p q : Vector2D)
    (hp : p ∈ seg.toSet) (hp1 : p ≠ seg.p1) (hp2 : p ≠ seg.p2)
    (hq : q ∈ seg.toSet) (hq1 : q ≠ seg.p1) (hq2 : q ≠ seg.p2)
    (x : Vector2D) (hx : x ∈ (LineSegment.mk p q).toSet) :
    x ∈ seg.toSet ∧ x ≠ seg.p1 ∧ x ≠ seg.p2 := by
  obtain ⟨sp, hsp0, hsp1, hspx, hspy⟩ := hp
  obtain ⟨sq, hsq0, hsq1, hsqx, hsqy⟩ := hq
  obtain ⟨u, hu0, hu1, hux, huy⟩ := hx
  set s := (1 - u) * sp + u * sq with hs_def
  have hs0 : 0 ≤ s := by rw [hs_def]; nlinarith
  have hs1 : s ≤ 1 := by rw [hs_def]; nlinarith
  have hxx : x.x = (1 - s) * seg.p1.x + s * seg.p2.x := by
    rw [hux, hspx, hsqx, hs_def]; ring
  have hxy : x.y = (1 - s) * seg.p1.y + s * seg.p2.y := by
    rw [huy, hspy, hsqy, hs_def]; ring
  have hx_mem : x ∈ seg.toSet := ⟨s, hs0, hs1, hxx, hxy⟩
  by_cases h_deg : seg.p1 = seg.p2
  · exfalso
    have h_p1p2_x : seg.p2.x = seg.p1.x := by rw [h_deg]
    have h_p1p2_y : seg.p2.y = seg.p1.y := by rw [h_deg]
    apply hp1
    ext
    · rw [hspx, h_p1p2_x]; ring
    · rw [hspy, h_p1p2_y]; ring
  · refine ⟨hx_mem, ?_, ?_⟩
    · intro hx_eq
      have hsp_pos : 0 < sp := by
        rcases lt_or_eq_of_le hsp0 with h | h
        · exact h
        · exfalso; apply hp1; ext
          · show p.x = seg.p1.x; rw [hspx, ← h]; ring
          · show p.y = seg.p1.y; rw [hspy, ← h]; ring
      have hsq_pos : 0 < sq := by
        rcases lt_or_eq_of_le hsq0 with h | h
        · exact h
        · exfalso; apply hq1; ext
          · show q.x = seg.p1.x; rw [hsqx, ← h]; ring
          · show q.y = seg.p1.y; rw [hsqy, ← h]; ring
      have hs_pos : 0 < s := by
        rw [hs_def]
        by_cases hu_one : u = 1
        · rw [hu_one]; linarith
        · have h1u_pos : 0 < 1 - u := by
            rcases lt_or_eq_of_le hu1 with h | h
            · linarith
            · exfalso; exact hu_one h
          nlinarith
      have hxx_eq : seg.p1.x = (1 - s) * seg.p1.x + s * seg.p2.x := by
        rw [← hxx]; exact (congrArg Vector2D.x hx_eq).symm
      have hxy_eq : seg.p1.y = (1 - s) * seg.p1.y + s * seg.p2.y := by
        rw [← hxy]; exact (congrArg Vector2D.y hx_eq).symm
      have hdx : s * (seg.p2.x - seg.p1.x) = 0 := by linarith
      have hdy : s * (seg.p2.y - seg.p1.y) = 0 := by linarith
      have hs_ne : s ≠ 0 := ne_of_gt hs_pos
      have hpx_eq : seg.p2.x = seg.p1.x := by
        rcases mul_eq_zero.mp hdx with h | h
        · exact absurd h hs_ne
        · linarith
      have hpy_eq : seg.p2.y = seg.p1.y := by
        rcases mul_eq_zero.mp hdy with h | h
        · exact absurd h hs_ne
        · linarith
      apply h_deg
      ext
      · rw [hpx_eq]
      · rw [hpy_eq]
    · intro hx_eq
      have hsp_lt : sp < 1 := by
        rcases lt_or_eq_of_le hsp1 with h | h
        · exact h
        · exfalso; apply hp2; ext
          · show p.x = seg.p2.x; rw [hspx, h]; ring
          · show p.y = seg.p2.y; rw [hspy, h]; ring
      have hsq_lt : sq < 1 := by
        rcases lt_or_eq_of_le hsq1 with h | h
        · exact h
        · exfalso; apply hq2; ext
          · show q.x = seg.p2.x; rw [hsqx, h]; ring
          · show q.y = seg.p2.y; rw [hsqy, h]; ring
      have hs_lt : s < 1 := by
        rw [hs_def]
        by_cases hu_zero : u = 0
        · rw [hu_zero]; linarith
        · have hu_pos : 0 < u := lt_of_le_of_ne hu0 (Ne.symm hu_zero)
          nlinarith
      have hxx_eq : seg.p2.x = (1 - s) * seg.p1.x + s * seg.p2.x := by
        rw [← hxx]; exact (congrArg Vector2D.x hx_eq).symm
      have hxy_eq : seg.p2.y = (1 - s) * seg.p1.y + s * seg.p2.y := by
        rw [← hxy]; exact (congrArg Vector2D.y hx_eq).symm
      have hdx : (1 - s) * (seg.p2.x - seg.p1.x) = 0 := by linarith
      have hdy : (1 - s) * (seg.p2.y - seg.p1.y) = 0 := by linarith
      have h1s_ne : (1 - s) ≠ 0 := by intro heq; linarith
      have hpx_eq : seg.p2.x = seg.p1.x := by
        rcases mul_eq_zero.mp hdx with h | h
        · exact absurd h h1s_ne
        · linarith
      have hpy_eq : seg.p2.y = seg.p1.y := by
        rcases mul_eq_zero.mp hdy with h | h
        · exact absurd h h1s_ne
        · linarith
      apply h_deg
      ext
      · rw [hpx_eq]
      · rw [hpy_eq]

/-- Auxiliary: there is a ray from `p` whose toSet avoids a finite list of
    points (other than `p` itself). -/
private lemma exists_ray_avoiding_points (p : Vector2D) (verts : List Vector2D)
    (h_not_vert : ∀ v ∈ verts, v ≠ p) :
    ∃ r : Ray, r.origin = p ∧ r.toSet ∩ { q | q ∈ verts } = ∅ := by
  have : Infinite ℚ := Infinite.of_injective (fun n : ℕ => (n : ℚ)) Nat.cast_injective
  let badSlopes : Finset ℚ := (verts.filterMap fun v =>
    if v.x > p.x then some ((v.y - p.y) / (v.x - p.x)) else none).toFinset
  obtain ⟨q, hq⟩ := Finset.exists_not_mem badSlopes
  have h_nonzero : (⟨1, q⟩ : Vector2D) ≠ ⟨0, 0⟩ := by
    intro h; exact absurd (congrArg Vector2D.x h) (by norm_num)
  refine ⟨⟨p, ⟨1, q⟩, h_nonzero⟩, rfl, ?_⟩
  rw [Set.eq_empty_iff_forall_not_mem]
  intro v hv
  obtain ⟨hv_ray, hv_vert⟩ := hv
  simp only [Set.mem_setOf_eq] at hv_vert
  obtain ⟨t, ht_nonneg, hvx, hvy⟩ := hv_ray
  simp only [mul_one] at hvx
  have hne : v ≠ p := h_not_vert v hv_vert
  have ht_eq : t = v.x - p.x := by linarith
  by_cases h_gt : v.x > p.x
  · have h_slope_mem : (v.y - p.y) / (v.x - p.x) ∈ badSlopes := by
      simp only [badSlopes, List.mem_toFinset, List.mem_filterMap]
      exact ⟨v, hv_vert, by simp [if_pos h_gt]⟩
    have hvmy : v.y - p.y = t * q := by linarith
    rw [ht_eq] at hvmy
    have hvx_ne : v.x - p.x ≠ 0 := ne_of_gt (by linarith : v.x - p.x > 0)
    have hq_eq : q = (v.y - p.y) / (v.x - p.x) := by
      rw [eq_div_iff hvx_ne, mul_comm]; linarith
    exact hq (hq_eq ▸ h_slope_mem)
  · push_neg at h_gt
    by_cases h_eq : v.x = p.x
    · have ht_zero : t = 0 := by linarith
      have hvy_eq : v.y = p.y := by
        have := hvy; rw [ht_zero] at this; simp at this; exact this
      exact hne (by cases v; cases p; simp_all)
    · linarith [lt_of_le_of_ne h_gt h_eq]

/-- The midpoint test of `pointInsideMultipolygonBool` for the multipolygon
    `mp` is correct for testing whether the open interior of `seg` is contained
    in `mp.interior`, provided that `seg`'s interior is disjoint from
    `mp.toBoundarySet` (other than possibly meeting at the endpoints). -/
private theorem midpoint_inside_iff_openInteriorSubset
    (seg : LineSegment) (mp : Multipolygon)
    (h_len : ∀ poly ∈ mp.polygons, poly.vertices.length ≥ 2)
    (h_nondeg : ∀ s ∈ mp.segments, s.p1 ≠ s.p2)
    (h_seg_nondeg : seg.p1 ≠ seg.p2)
    (h_inter : seg.toSet ∩ mp.toBoundarySet ⊆ ({seg.p1, seg.p2} : Set Vector2D)) :
    pointInsideMultipolygonBool (segmentMidpoint seg) mp = true ↔
    segmentOpenInteriorSubset seg mp.interior := by
  -- Key facts about the midpoint
  obtain ⟨h_mid_on_seg, h_mid_ne_p1, h_mid_ne_p2⟩ :=
    segmentMidpoint_mem_open_interior seg h_seg_nondeg
  set mid := segmentMidpoint seg with hmid_def
  -- Lemma: for any q ∈ seg.toSet with q ≠ p1, q ≠ p2, q is not on the multipolygon boundary.
  have h_open_avoids_boundary :
      ∀ q ∈ seg.toSet, q ≠ seg.p1 → q ≠ seg.p2 → q ∉ mp.toBoundarySet := by
    intro q hq hq1 hq2 hq_b
    have : q ∈ ({seg.p1, seg.p2} : Set Vector2D) := h_inter ⟨hq, hq_b⟩
    rcases this with h | h
    · exact hq1 h
    · exact hq2 h
  have h_mid_avoids_boundary : mid ∉ mp.toBoundarySet :=
    h_open_avoids_boundary mid h_mid_on_seg h_mid_ne_p1 h_mid_ne_p2
  -- Convert "not on boundary" to "avoids all multipolygon segments".
  have h_mid_avoids_segs : ∀ s ∈ mp.segments, pointAvoidsSegment mid s := by
    intro s hs h_mem
    exact h_mid_avoids_boundary ⟨s, hs, h_mem⟩
  rw [pointInsideMultipolygonBool_iff mid mp h_len h_nondeg]
  constructor
  · -- Forward: mid ∈ mp.interior → ∀ q in open interior, q ∈ mp.interior.
    intro hmid_int q hq hq1 hq2
    have h_q_avoids_segs : ∀ s ∈ mp.segments, pointAvoidsSegment q s := by
      intro s hs h_mem
      exact h_open_avoids_boundary q hq hq1 hq2 ⟨s, hs, h_mem⟩
    refine ⟨h_q_avoids_segs, ?_⟩
    intro r_q hr_q_origin hr_q_avoids_verts
    -- Find a ray from mid avoiding multipolygon vertices.
    have h_mid_not_vert : ∀ v ∈ mp.allVertices, v ≠ mid := by
      intro v hv heq
      apply h_mid_avoids_boundary
      obtain ⟨s, hs, hvs⟩ :=
        Multipolygon.vertex_on_some_segment mp h_len h_nondeg v hv
      exact ⟨s, hs, heq ▸ hvs⟩
    obtain ⟨r_m, hr_m_origin, hr_m_avoids⟩ :=
      exists_ray_avoiding_points mid mp.allVertices h_mid_not_vert
    have hr_m_avoids_verts : rayAvoidsMultipolygonVertices r_m mp := by
      rw [rayAvoidsMultipolygonVertices]
      show r_m.toSet ∩ mp.toVertices = ∅
      show r_m.toSet ∩ {p | p ∈ mp.allVertices} = ∅
      exact hr_m_avoids
    have h_m_count_odd : intersectionRayMultipolygonSegmentsNumber r_m mp % 2 = 1 :=
      hmid_int.2 r_m hr_m_origin hr_m_avoids_verts
    -- Use parity invariance to transfer to r_q.
    have h_origin_segment : ∀ s ∈ mp.segments,
        segmentDoesNotIntersectSegment ⟨r_m.origin, r_q.origin⟩ s := by
      intro s hs
      rw [segmentDoesNotIntersectSegment, Set.eq_empty_iff_forall_not_mem]
      rintro x ⟨hx_mq, hx_s⟩
      have hx_data := sub_segment_in_open_interior seg mid q
        h_mid_on_seg h_mid_ne_p1 h_mid_ne_p2 hq hq1 hq2 x
      have hx_mq' : x ∈ (LineSegment.mk r_m.origin r_q.origin).toSet := hx_mq
      rw [hr_m_origin, hr_q_origin] at hx_mq'
      have ⟨hx_seg, hx_ne_p1, hx_ne_p2⟩ := hx_data hx_mq'
      have hx_b : x ∈ mp.toBoundarySet := ⟨s, hs, hx_s⟩
      exact h_open_avoids_boundary x hx_seg hx_ne_p1 hx_ne_p2 hx_b
    have h_verts_avoid_origin_seg :
        ∀ v ∈ mp.toVertices, v ∉ (LineSegment.mk r_m.origin r_q.origin).toSet := by
      intro v hv h_v_on
      have hv_list : v ∈ mp.allVertices := hv
      have h_v_in_seg_open := sub_segment_in_open_interior seg mid q
        h_mid_on_seg h_mid_ne_p1 h_mid_ne_p2 hq hq1 hq2 v
      have h_v_on' : v ∈ (LineSegment.mk r_m.origin r_q.origin).toSet := h_v_on
      rw [hr_m_origin, hr_q_origin] at h_v_on'
      have ⟨h_v_seg, h_v_ne_p1, h_v_ne_p2⟩ := h_v_in_seg_open h_v_on'
      -- v is on seg, but every vertex of mp is on some mp segment.
      obtain ⟨s, hs, hvs⟩ :=
        Multipolygon.vertex_on_some_segment mp h_len h_nondeg v hv_list
      -- So v ∈ mp.toBoundarySet, contradicting h_open_avoids_boundary.
      exact h_open_avoids_boundary v h_v_seg h_v_ne_p1 h_v_ne_p2 ⟨s, hs, hvs⟩
    have h_parity := intersectionParity_eq_of_originSegmentAvoidsMultipolygonSegments
      r_m r_q mp h_len h_nondeg hr_m_avoids_verts hr_q_avoids_verts h_origin_segment
      h_verts_avoid_origin_seg
    rw [← h_parity]
    exact h_m_count_odd
  · -- Backward: openInteriorSubset → mid ∈ mp.interior.
    intro h_subset
    exact h_subset mid h_mid_on_seg h_mid_ne_p1 h_mid_ne_p2

/- Filter refined segments of m1 to those whose midpoint is inside m2. -/
-- moved: `selectInsideOther` lives in `Polygons.MultipolygonIntersectionAlgorithmImpl`
/- The intersection graph: refined segments of m1 inside m2, plus
    refined segments of m2 inside m1. -/
-- moved: `intersectionGraphSegments` lives in `Polygons.MultipolygonIntersectionAlgorithmImpl`
/-! ## Section 5 — Computable greedy decomposition

We use `EvenGraphDecompositionImpl.decomposeList` already defined and proved
correct in `EvenGraphDecompositionImpl.lean`. -/

/- Public computable greedy decomposition. -/
-- moved: `decomposeSegments` lives in `Polygons.MultipolygonIntersectionAlgorithmImpl`
/-! ## Section 6 — Top-level computable algorithm

`multipolygonIntersectionAlgorithm` (the main computable entry point)
lives in `Polygons.MultipolygonIntersectionAlgorithmImpl`. -/
/-! ## Section 7 — Correctness proof -/

open Set Classical List

/-! ### Helpers for the construction equivalence proof -/

/-- A version of `splitSegmentAtPoints_perm_iff_collinear` that only requires
    the strict-interior-to-seg portions of the two lists to be set-equal, since
    the construction `splitSegmentAtPoints` always implicitly includes
    `seg.p1` and `seg.p2`. -/
private theorem splitSegmentAtPoints_perm_of_strict_interior_set_eq
    (seg : LineSegment) (h_seg_nondeg : seg.p1 ≠ seg.p2)
    (pts1 pts2 : List Vector2D)
    (h_on_seg1 : ∀ p ∈ pts1, p ∈ seg.toSet)
    (h_on_seg2 : ∀ p ∈ pts2, p ∈ seg.toSet)
    (h_strict_eq : ∀ p, (p ∈ pts1 ∧ p ≠ seg.p1 ∧ p ≠ seg.p2) ↔
                       (p ∈ pts2 ∧ p ≠ seg.p1 ∧ p ≠ seg.p2)) :
    List.Perm ((splitSegmentAtPoints seg pts1).map LineSegment.toEndpointsMultiset)
              ((splitSegmentAtPoints seg pts2).map LineSegment.toEndpointsMultiset) := by
  -- Both `splitSegmentAtPoints seg pts` definitionally use
  -- `dedupConsec (sortAlongSeg seg.p1 seg.p2 (seg.p1 :: seg.p2 :: pts))`.
  -- We replicate the proof of `splitSegmentAtPoints_perm_iff_collinear` but use a
  -- weakened set-equality on the augmented lists.
  suffices h : dedupConsec (sortAlongSeg seg.p1 seg.p2 (seg.p1 :: seg.p2 :: pts1))
             = dedupConsec (sortAlongSeg seg.p1 seg.p2 (seg.p1 :: seg.p2 :: pts2)) by
    have hsplit : splitSegmentAtPoints seg pts1 = splitSegmentAtPoints seg pts2 := by
      show ((dedupConsec (sortAlongSeg seg.p1 seg.p2 (seg.p1 :: seg.p2 :: pts1))).zip
            (dedupConsec (sortAlongSeg seg.p1 seg.p2 (seg.p1 :: seg.p2 :: pts1))).tail).map
            (fun (ab : Vector2D × Vector2D) => (⟨ab.1, ab.2⟩ : LineSegment)) =
            ((dedupConsec (sortAlongSeg seg.p1 seg.p2 (seg.p1 :: seg.p2 :: pts2))).zip
            (dedupConsec (sortAlongSeg seg.p1 seg.p2 (seg.p1 :: seg.p2 :: pts2))).tail).map
            (fun (ab : Vector2D × Vector2D) => (⟨ab.1, ab.2⟩ : LineSegment))
      rw [h]
    rw [hsplit]
  set L1 := sortAlongSeg seg.p1 seg.p2 (seg.p1 :: seg.p2 :: pts1) with hL1
  set L2 := sortAlongSeg seg.p1 seg.p2 (seg.p1 :: seg.p2 :: pts2) with hL2
  have hPw1 : L1.Pairwise (fun a b => (vecCmpAlongSeg seg.p1 seg.p2 a b).isLE = true) := by
    rw [hL1]; exact sortAlongSeg_pairwise_isLE _ _ _
  have hPw2 : L2.Pairwise (fun a b => (vecCmpAlongSeg seg.p1 seg.p2 a b).isLE = true) := by
    rw [hL2]; exact sortAlongSeg_pairwise_isLE _ _ _
  have hPwD1 : (dedupConsec L1).Pairwise
                  (fun a b => (vecCmpAlongSeg seg.p1 seg.p2 a b).isLE = true) :=
    dedupConsec_pairwise L1 hPw1
  have hPwD2 : (dedupConsec L2).Pairwise
                  (fun a b => (vecCmpAlongSeg seg.p1 seg.p2 a b).isLE = true) :=
    dedupConsec_pairwise L2 hPw2
  have hMemL1 : ∀ x, x ∈ L1 ↔ x ∈ seg.p1 :: seg.p2 :: pts1 := by
    intro x; rw [hL1]; exact sortAlongSeg_mem_iff _ _ _ _
  have hMemL2 : ∀ x, x ∈ L2 ↔ x ∈ seg.p1 :: seg.p2 :: pts2 := by
    intro x; rw [hL2]; exact sortAlongSeg_mem_iff _ _ _ _
  have hMemD1 : ∀ x, x ∈ dedupConsec L1 ↔ x ∈ seg.p1 :: seg.p2 :: pts1 := fun x =>
    Iff.trans (dedupConsec_mem_iff L1 x) (hMemL1 x)
  have hMemD2 : ∀ x, x ∈ dedupConsec L2 ↔ x ∈ seg.p1 :: seg.p2 :: pts2 := fun x =>
    Iff.trans (dedupConsec_mem_iff L2 x) (hMemL2 x)
  -- Key step: same membership of augmented lists, derived from h_strict_eq.
  have hMemAug : ∀ x, x ∈ seg.p1 :: seg.p2 :: pts1 ↔ x ∈ seg.p1 :: seg.p2 :: pts2 := by
    intro x
    simp only [List.mem_cons]
    constructor
    · rintro (h | h | h)
      · left; exact h
      · right; left; exact h
      · by_cases hx1 : x = seg.p1
        · left; exact hx1
        · by_cases hx2 : x = seg.p2
          · right; left; exact hx2
          · right; right
            have := (h_strict_eq x).mp ⟨h, hx1, hx2⟩
            exact this.1
    · rintro (h | h | h)
      · left; exact h
      · right; left; exact h
      · by_cases hx1 : x = seg.p1
        · left; exact hx1
        · by_cases hx2 : x = seg.p2
          · right; left; exact hx2
          · right; right
            have := (h_strict_eq x).mpr ⟨h, hx1, hx2⟩
            exact this.1
  have hMemSame : ∀ x, x ∈ dedupConsec L1 ↔ x ∈ dedupConsec L2 := by
    intro x; rw [hMemD1 x, hMemD2 x]; exact hMemAug x
  have hp1_seg : seg.p1 ∈ seg.toSet :=
    ⟨0, by norm_num, by norm_num, by ring, by ring⟩
  have hp2_seg : seg.p2 ∈ seg.toSet :=
    ⟨1, by norm_num, by norm_num, by ring, by ring⟩
  have hAntisymmL1 :
      ∀ a ∈ L1, ∀ b ∈ L1,
        (vecCmpAlongSeg seg.p1 seg.p2 a b).isLE = true →
        (vecCmpAlongSeg seg.p1 seg.p2 b a).isLE = true → a = b := by
    intro a ha b hb hab hba
    have ha_in : a ∈ seg.p1 :: seg.p2 :: pts1 := (hMemL1 a).mp ha
    have hb_in : b ∈ seg.p1 :: seg.p2 :: pts1 := (hMemL1 b).mp hb
    have ha_seg : a ∈ seg.toSet := by
      rcases List.mem_cons.mp ha_in with hp | hr
      · rw [hp]; exact hp1_seg
      · rcases List.mem_cons.mp hr with hp | hr2
        · rw [hp]; exact hp2_seg
        · exact h_on_seg1 a hr2
    have hb_seg : b ∈ seg.toSet := by
      rcases List.mem_cons.mp hb_in with hp | hr
      · rw [hp]; exact hp1_seg
      · rcases List.mem_cons.mp hr with hp | hr2
        · rw [hp]; exact hp2_seg
        · exact h_on_seg1 b hr2
    exact vecCmpAlongSeg_isLE_antisymm_on_seg seg a b h_seg_nondeg ha_seg hb_seg hab hba
  have hAntisymmL2 :
      ∀ a ∈ L2, ∀ b ∈ L2,
        (vecCmpAlongSeg seg.p1 seg.p2 a b).isLE = true →
        (vecCmpAlongSeg seg.p1 seg.p2 b a).isLE = true → a = b := by
    intro a ha b hb hab hba
    have ha_in : a ∈ seg.p1 :: seg.p2 :: pts2 := (hMemL2 a).mp ha
    have hb_in : b ∈ seg.p1 :: seg.p2 :: pts2 := (hMemL2 b).mp hb
    have ha_seg : a ∈ seg.toSet := by
      rcases List.mem_cons.mp ha_in with hp | hr
      · rw [hp]; exact hp1_seg
      · rcases List.mem_cons.mp hr with hp | hr2
        · rw [hp]; exact hp2_seg
        · exact h_on_seg2 a hr2
    have hb_seg : b ∈ seg.toSet := by
      rcases List.mem_cons.mp hb_in with hp | hr
      · rw [hp]; exact hp1_seg
      · rcases List.mem_cons.mp hr with hp | hr2
        · rw [hp]; exact hp2_seg
        · exact h_on_seg2 b hr2
    exact vecCmpAlongSeg_isLE_antisymm_on_seg seg a b h_seg_nondeg ha_seg hb_seg hab hba
  have hNodup1 : (dedupConsec L1).Nodup :=
    dedupConsec_nodup_of_sorted_antisymm _ L1 hPw1 hAntisymmL1
  have hNodup2 : (dedupConsec L2).Nodup :=
    dedupConsec_nodup_of_sorted_antisymm _ L2 hPw2 hAntisymmL2
  have hPerm : List.Perm (dedupConsec L1) (dedupConsec L2) :=
    perm_of_nodup_same_mem _ _ hNodup1 hNodup2 hMemSame
  have hAntisymmD :
      ∀ a b, a ∈ dedupConsec L1 → b ∈ dedupConsec L2 →
        (vecCmpAlongSeg seg.p1 seg.p2 a b).isLE = true →
        (vecCmpAlongSeg seg.p1 seg.p2 b a).isLE = true → a = b := by
    intro a b ha hb hab hba
    have ha_in : a ∈ seg.p1 :: seg.p2 :: pts1 := (hMemD1 a).mp ha
    have hb_in : b ∈ seg.p1 :: seg.p2 :: pts2 := (hMemD2 b).mp hb
    have ha_seg : a ∈ seg.toSet := by
      rcases List.mem_cons.mp ha_in with hp | hr
      · rw [hp]; exact hp1_seg
      · rcases List.mem_cons.mp hr with hp | hr2
        · rw [hp]; exact hp2_seg
        · exact h_on_seg1 a hr2
    have hb_seg : b ∈ seg.toSet := by
      rcases List.mem_cons.mp hb_in with hp | hr
      · rw [hp]; exact hp1_seg
      · rcases List.mem_cons.mp hr with hp | hr2
        · rw [hp]; exact hp2_seg
        · exact h_on_seg2 b hr2
    exact vecCmpAlongSeg_isLE_antisymm_on_seg seg a b h_seg_nondeg ha_seg hb_seg hab hba
  exact perm_eq_of_pairwise_local hAntisymmD hPwD1 hPwD2 hPerm

/-- Per-segment construction lemma: for `seg ∈ m1.segments`, the multiset
    of endpoint pairs from `splitSegmentAtPoints seg (refinementPointsForSegment seg m1 m2)`
    matches that of `iterativeSplit seg (selfPts ++ wrtPts)` where `selfPts` and `wrtPts`
    are the point lists used by `graphRefinementSelfAndWrt (m1.toEvenGraph) (m2.toEvenGraph)`. -/
private theorem refinedSeg_perm_iterativeSplit_selfWrt
    (m1 m2 : Multipolygon)
    (h1_len : ∀ poly ∈ m1.polygons, poly.vertices.length ≥ 2)
    (h2_len : ∀ poly ∈ m2.polygons, poly.vertices.length ≥ 2)
    (h1_nondeg : ∀ seg ∈ m1.segments, seg.p1 ≠ seg.p2)
    (h2_nondeg : ∀ seg ∈ m2.segments, seg.p1 ≠ seg.p2)
    (h_fin12 : Set.Finite ((m1.toEvenGraph h1_len h1_nondeg).toBoundarySet ∩
        (m2.toEvenGraph h2_len h2_nondeg).toBoundarySet))
    (seg : LineSegment) (h_seg : seg ∈ m1.segments) :
    let G1 := m1.toEvenGraph h1_len h1_nondeg
    let selfPts := (selfSegmentInteriorVertices_finite G1).toFinset.toList
    let wrtPts := h_fin12.toFinset.toList
    List.Perm
      ((splitSegmentAtPoints seg (refinementPointsForSegment seg m1 m2)).map
        LineSegment.toEndpointsMultiset)
      ((iterativeSplit seg (selfPts ++ wrtPts)).map LineSegment.toEndpointsMultiset) := by
  intro G1 selfPts wrtPts
  have h_seg_ne : seg.p1 ≠ seg.p2 := h1_nondeg seg h_seg
  -- Step 1: Connect splitSegmentAtPoints with iterativeSplit on refinementPointsForSegment.
  have h_refPts_on_seg : ∀ p ∈ refinementPointsForSegment seg m1 m2, p ∈ seg.toSet :=
    refinementPointsForSegment_mem_toSet seg m1 m2 h_seg_ne
  have h_split_perm_iter :
      List.Perm
        ((splitSegmentAtPoints seg (refinementPointsForSegment seg m1 m2)).map
          LineSegment.toEndpointsMultiset)
        ((iterativeSplit seg (refinementPointsForSegment seg m1 m2)).map
          LineSegment.toEndpointsMultiset) :=
    (iterativeSplit_perm_splitSegmentAtPoints seg h_seg_ne _ h_refPts_on_seg).symm
  refine h_split_perm_iter.trans ?_
  -- Step 2: iterativeSplit on refinementPointsForSegment ~toEM iterativeSplit on (selfPts ++ wrtPts).
  -- We use iterativeSplit_filter_on_seg to filter both sides to seg.toSet, then transform.
  -- Apply iterativeSplit_perm_splitSegmentAtPoints in REVERSE for the (selfPts++wrtPts) side?
  -- That requires (selfPts++wrtPts) ⊆ seg.toSet, which is FALSE in general.
  -- So we need a different approach: filter both lists to seg.toSet first.
  set L1 := refinementPointsForSegment seg m1 m2 with hL1_def
  set L2 := selfPts ++ wrtPts with hL2_def
  -- Filter both lists to seg.toSet.
  set L1' := L1.filter (fun q => decide (q ∈ seg.toSet)) with hL1'_def
  set L2' := L2.filter (fun q => decide (q ∈ seg.toSet)) with hL2'_def
  have h_iter_filter1 : iterativeSplit seg L1 = iterativeSplit seg L1' :=
    iterativeSplit_filter_on_seg seg L1
  have h_iter_filter2 : iterativeSplit seg L2 = iterativeSplit seg L2' :=
    iterativeSplit_filter_on_seg seg L2
  rw [h_iter_filter1, h_iter_filter2]
  have h_L1'_on_seg : ∀ p ∈ L1', p ∈ seg.toSet := by
    intro p hp
    rw [hL1'_def, List.mem_filter, decide_eq_true_eq] at hp
    exact hp.2
  have h_L2'_on_seg : ∀ p ∈ L2', p ∈ seg.toSet := by
    intro p hp
    rw [hL2'_def, List.mem_filter, decide_eq_true_eq] at hp
    exact hp.2
  -- Step 3: Transform iterativeSplit to splitSegmentAtPoints on both sides.
  have h_iter_split1 :=
    iterativeSplit_perm_splitSegmentAtPoints seg h_seg_ne L1' h_L1'_on_seg
  have h_iter_split2 :=
    iterativeSplit_perm_splitSegmentAtPoints seg h_seg_ne L2' h_L2'_on_seg
  refine h_iter_split1.trans ?_
  refine List.Perm.trans ?_ h_iter_split2.symm
  -- Step 4: Apply splitSegmentAtPoints_perm_of_strict_interior_set_eq.
  apply splitSegmentAtPoints_perm_of_strict_interior_set_eq seg h_seg_ne L1' L2'
    h_L1'_on_seg h_L2'_on_seg
  -- Need: ∀ p, (p ∈ L1' ∧ p ≠ seg.p1 ∧ p ≠ seg.p2) ↔ (p ∈ L2' ∧ p ≠ seg.p1 ∧ p ≠ seg.p2).
  intro p
  constructor
  · rintro ⟨hp_L1', hp_ne1, hp_ne2⟩
    rw [hL1'_def, List.mem_filter, decide_eq_true_eq] at hp_L1'
    obtain ⟨hp_L1, hp_seg⟩ := hp_L1'
    refine ⟨?_, hp_ne1, hp_ne2⟩
    rw [hL2'_def, List.mem_filter, decide_eq_true_eq]
    refine ⟨?_, hp_seg⟩
    -- p ∈ L1 = refinementPointsForSegment, p strictly interior to seg.
    -- Use refinementPointsForSegment_set_eq.
    have h_capture : boundaryCaptureProperty m1 m2 :=
      boundaryCaptureProperty_holds m1 m2 h1_nondeg h2_nondeg (by
        rw [Multipolygon.toEvenGraph_toBoundarySet_eq m1 h1_len h1_nondeg,
            Multipolygon.toEvenGraph_toBoundarySet_eq m2 h2_len h2_nondeg] at h_fin12
        exact h_fin12)
    have h_set_eq := refinementPointsForSegment_set_eq m1 m2 seg h_seg
      h1_nondeg h2_nondeg (by
        rw [Multipolygon.toEvenGraph_toBoundarySet_eq m1 h1_len h1_nondeg,
            Multipolygon.toEvenGraph_toBoundarySet_eq m2 h2_len h2_nondeg] at h_fin12
        exact h_fin12) h_capture
    -- h_set_eq : { p | p ∈ refPts ∧ p ≠ seg.p1 ∧ p ≠ seg.p2 } =
    --            { p | p ∈ seg.toSet ∧ p ≠ seg.p1 ∧ p ≠ seg.p2 ∧ (p ∈ m1.toVertices ∨ p ∈ m2.toBoundarySet) }
    have hp_in_set : p ∈ { q : Vector2D | q ∈ refinementPointsForSegment seg m1 m2 ∧
        q ≠ seg.p1 ∧ q ≠ seg.p2 } := ⟨hp_L1, hp_ne1, hp_ne2⟩
    rw [h_set_eq] at hp_in_set
    obtain ⟨hp_seg', hp_ne1', hp_ne2', h_or⟩ := hp_in_set
    -- h_or: p ∈ m1.toVertices ∨ p ∈ m2.toBoundarySet.
    -- Show p ∈ selfPts ∨ p ∈ wrtPts.
    rcases h_or with h_v1 | h_b2
    · -- p ∈ m1.toVertices, p strictly interior to seg ∈ m1.segments → p ∈ selfPts.
      have h_p_in_self : p ∈ selfSegmentInteriorVertices G1 := by
        refine ⟨?_, seg, ?_, hp_seg, hp_ne1', hp_ne2'⟩
        · -- p ∈ G1.toVertexSet = m1.toVertices.
          rw [show G1.toVertexSet = m1.toVertices from
            Multipolygon.toEvenGraph_toVertexSet_eq m1 h1_len h1_nondeg]
          exact h_v1
        · -- seg ∈ G1.segments = m1.segments.
          rw [show G1.segments = m1.segments from
            Multipolygon.toEvenGraph_segments_eq m1 h1_len h1_nondeg]
          exact h_seg
      show p ∈ selfPts ++ wrtPts
      rw [List.mem_append]
      left
      show p ∈ (selfSegmentInteriorVertices_finite G1).toFinset.toList
      rw [Finset.mem_toList]
      exact (selfSegmentInteriorVertices_finite G1).mem_toFinset.mpr h_p_in_self
    · -- p ∈ m2.toBoundarySet → p ∈ wrtPts.
      -- Note p ∈ seg.toSet, seg ∈ m1.segments, so p ∈ m1.toBoundarySet.
      have h_p_b1 : p ∈ m1.toBoundarySet := ⟨seg, h_seg, hp_seg⟩
      have h_p_inter : p ∈ G1.toBoundarySet ∩
          (m2.toEvenGraph h2_len h2_nondeg).toBoundarySet := by
        constructor
        · rw [Multipolygon.toEvenGraph_toBoundarySet_eq m1 h1_len h1_nondeg]
          exact h_p_b1
        · rw [Multipolygon.toEvenGraph_toBoundarySet_eq m2 h2_len h2_nondeg]
          exact h_b2
      show p ∈ selfPts ++ wrtPts
      rw [List.mem_append]
      right
      show p ∈ h_fin12.toFinset.toList
      rw [Finset.mem_toList]
      exact h_fin12.mem_toFinset.mpr h_p_inter
  · rintro ⟨hp_L2', hp_ne1, hp_ne2⟩
    rw [hL2'_def, List.mem_filter, decide_eq_true_eq] at hp_L2'
    obtain ⟨hp_L2, hp_seg⟩ := hp_L2'
    refine ⟨?_, hp_ne1, hp_ne2⟩
    rw [hL1'_def, List.mem_filter, decide_eq_true_eq]
    refine ⟨?_, hp_seg⟩
    -- p ∈ selfPts ++ wrtPts, p ∈ seg.toSet, p ≠ seg.p1, p ≠ seg.p2.
    -- Show p ∈ refinementPointsForSegment seg m1 m2.
    have h_capture : boundaryCaptureProperty m1 m2 :=
      boundaryCaptureProperty_holds m1 m2 h1_nondeg h2_nondeg (by
        rw [Multipolygon.toEvenGraph_toBoundarySet_eq m1 h1_len h1_nondeg,
            Multipolygon.toEvenGraph_toBoundarySet_eq m2 h2_len h2_nondeg] at h_fin12
        exact h_fin12)
    have h_set_eq := refinementPointsForSegment_set_eq m1 m2 seg h_seg
      h1_nondeg h2_nondeg (by
        rw [Multipolygon.toEvenGraph_toBoundarySet_eq m1 h1_len h1_nondeg,
            Multipolygon.toEvenGraph_toBoundarySet_eq m2 h2_len h2_nondeg] at h_fin12
        exact h_fin12) h_capture
    -- We need to show p ∈ {q | q ∈ refPts ∧ q ≠ seg.p1 ∧ q ≠ seg.p2}, then strip the conjuncts.
    have hp_in_set : p ∈ { q : Vector2D | q ∈ seg.toSet ∧ q ≠ seg.p1 ∧ q ≠ seg.p2 ∧
        (q ∈ m1.toVertices ∨ q ∈ m2.toBoundarySet) } := by
      rw [hL2_def] at hp_L2
      rw [List.mem_append] at hp_L2
      refine ⟨hp_seg, hp_ne1, hp_ne2, ?_⟩
      rcases hp_L2 with hp_self | hp_wrt
      · left
        -- p ∈ selfPts.
        show p ∈ m1.toVertices
        have hp_self_set : p ∈ selfSegmentInteriorVertices G1 := by
          have hp_in_finset : p ∈ (selfSegmentInteriorVertices_finite G1).toFinset :=
            Finset.mem_toList.mp hp_self
          exact (selfSegmentInteriorVertices_finite G1).mem_toFinset.mp hp_in_finset
        obtain ⟨hp_vset, _⟩ := hp_self_set
        rw [show G1.toVertexSet = m1.toVertices from
          Multipolygon.toEvenGraph_toVertexSet_eq m1 h1_len h1_nondeg] at hp_vset
        exact hp_vset
      · right
        -- p ∈ wrtPts.
        show p ∈ m2.toBoundarySet
        have hp_inter : p ∈ G1.toBoundarySet ∩
            (m2.toEvenGraph h2_len h2_nondeg).toBoundarySet := by
          have hp_in_finset : p ∈ h_fin12.toFinset := Finset.mem_toList.mp hp_wrt
          exact h_fin12.mem_toFinset.mp hp_in_finset
        rw [Multipolygon.toEvenGraph_toBoundarySet_eq m2 h2_len h2_nondeg] at hp_inter
        exact hp_inter.2
    rw [← h_set_eq] at hp_in_set
    exact hp_in_set.1

/-- If `L1.map toEM ~ L2.map toEM` and predicate `q` is invariant under endpoint swap,
    then filtering both lists by `q` and mapping to toEM also gives a perm. -/
private theorem map_toEM_filter_perm_of_swap_invariant
    (L1 L2 : List LineSegment) (q : LineSegment → Bool)
    (h_q_swap : ∀ a b : Vector2D,
      q (LineSegment.mk a b) = q (LineSegment.mk b a))
    (h_perm : List.Perm (L1.map LineSegment.toEndpointsMultiset)
      (L2.map LineSegment.toEndpointsMultiset)) :
    List.Perm
      ((L1.filter q).map LineSegment.toEndpointsMultiset)
      ((L2.filter q).map LineSegment.toEndpointsMultiset) := by
  -- Define a swap-invariant predicate on multisets.
  classical
  set f : Multiset Vector2D → Bool := fun m =>
    decide (∃ s : LineSegment, s.toEndpointsMultiset = m ∧ q s = true) with hf_def
  -- Show: for each s, q s = f s.toEM.
  have h_q_eq_f : ∀ s : LineSegment, q s = f s.toEndpointsMultiset := by
    intro s
    rw [hf_def]
    by_cases hs : q s = true
    · rw [hs]
      symm
      simp only [decide_eq_true_eq]
      exact ⟨s, rfl, hs⟩
    · push_neg at hs
      have hs_false : q s = false := by
        rcases h : q s with _ | _
        · rfl
        · exact absurd h hs
      rw [hs_false]
      symm
      simp only [decide_eq_false_iff_not, not_exists]
      intro s'
      rintro ⟨hs'_eq, hq_s'_true⟩
      -- s'.toEM = s.toEM ⇒ s = s' or s = swap s'
      -- Note hs'_eq : s'.toEM = s.toEM  (s'.toEM = m and m = s.toEM via decide ∃ frame)
      cases s with
      | mk a b =>
      cases s' with
      | mk c d =>
      simp only [LineSegment.toEndpointsMultiset] at hs'_eq
      -- hs'_eq : ({c, d} : Multiset Vector2D) = {a, b}
      have hac : a = c ∨ a = d := by
        have ha : a ∈ ({c, d} : Multiset Vector2D) := by
          rw [hs'_eq]; exact Multiset.mem_cons_self _ _
        rcases Multiset.mem_cons.mp ha with hc | hd
        · exact Or.inl hc
        · exact Or.inr (Multiset.mem_singleton.mp hd)
      rcases hac with rfl | rfl
      · -- a = c, then b = d
        have hbd : b = d := by
          have step : Multiset.erase ({a, d} : Multiset Vector2D) a =
              Multiset.erase ({a, b} : Multiset Vector2D) a := by rw [hs'_eq]
          have l1 : ({a, b} : Multiset Vector2D) = a ::ₘ ({b} : Multiset Vector2D) := rfl
          have l2 : ({a, d} : Multiset Vector2D) = a ::ₘ ({d} : Multiset Vector2D) := rfl
          rw [l1, l2, Multiset.erase_cons_head, Multiset.erase_cons_head] at step
          exact (Multiset.singleton_inj.mp step).symm
        subst hbd
        rw [hq_s'_true] at hs_false
        exact absurd hs_false (by simp)
      · -- a = d. Then s' = ⟨c, a⟩, hs'_eq : {c, a} = {a, b}, swap: {a, c} = {a, b}, so b = c.
        have h_swap : ({c, a} : Multiset Vector2D) = ({a, c} : Multiset Vector2D) :=
          Multiset.cons_swap _ _ _
        rw [h_swap] at hs'_eq
        have hbc : b = c := by
          have step : Multiset.erase ({a, c} : Multiset Vector2D) a =
              Multiset.erase ({a, b} : Multiset Vector2D) a := by rw [hs'_eq]
          have l1 : ({a, b} : Multiset Vector2D) = a ::ₘ ({b} : Multiset Vector2D) := rfl
          have l2 : ({a, c} : Multiset Vector2D) = a ::ₘ ({c} : Multiset Vector2D) := rfl
          rw [l1, l2, Multiset.erase_cons_head, Multiset.erase_cons_head] at step
          exact (Multiset.singleton_inj.mp step).symm
        subst hbc
        -- Now s = ⟨a, b⟩, s' = ⟨b, a⟩, q ⟨b, a⟩ = q ⟨a, b⟩ = false.
        rw [h_q_swap b a] at hq_s'_true
        rw [hq_s'_true] at hs_false
        exact absurd hs_false (by simp)
  -- (L.filter q).map toEM = (L.map toEM).filter f
  have h_eq : ∀ L : List LineSegment,
      (L.filter q).map LineSegment.toEndpointsMultiset =
      (L.map LineSegment.toEndpointsMultiset).filter f := by
    intro L
    induction L with
    | nil => rfl
    | cons s rest ih =>
      by_cases hq : q s = true
      · have hf_s : f s.toEndpointsMultiset = true := by
          rw [← h_q_eq_f]; exact hq
        simp only [List.filter_cons, List.map_cons, hq, hf_s, if_true]
        exact congrArg _ ih
      · push_neg at hq
        have hq_false : q s = false := by
          rcases h : q s with _ | _
          · rfl
          · exact absurd h hq
        have hf_s : f s.toEndpointsMultiset = false := by
          rw [← h_q_eq_f]; exact hq_false
        simp only [List.filter_cons, List.map_cons, hq_false, hf_s]
        exact ih
  rw [h_eq L1, h_eq L2]
  exact h_perm.filter f

/-- A general flatMap perm lemma: if for every segment in the list, two functions yield
    `toEndpointsMultiset`-perm-equal lists, then the flatMaps are also `toEndpointsMultiset`-perm-equal. -/
private theorem flatMap_perm_of_perm_pointwise
    (segs : List LineSegment) (f g : LineSegment → List LineSegment)
    (h : ∀ s ∈ segs, List.Perm ((f s).map LineSegment.toEndpointsMultiset)
      ((g s).map LineSegment.toEndpointsMultiset)) :
    List.Perm ((segs.flatMap f).map LineSegment.toEndpointsMultiset)
              ((segs.flatMap g).map LineSegment.toEndpointsMultiset) := by
  induction segs with
  | nil => exact List.Perm.refl _
  | cons s rest ih =>
    have h_s := h s (List.mem_cons_self _ _)
    have h_rest : ∀ s' ∈ rest, List.Perm ((f s').map LineSegment.toEndpointsMultiset)
        ((g s').map LineSegment.toEndpointsMultiset) :=
      fun s' h' => h s' (List.mem_cons_of_mem _ h')
    have h_ih := ih h_rest
    simp only [List.flatMap_cons, List.map_append]
    exact h_s.append h_ih

/-- Construction perm: lifting `refinedSeg_perm_iterativeSplit_selfWrt` through `flatMap`
    over `m1.segments`. -/
private theorem refinedSegments_perm_flatMap_iterativeSplit
    (m1 m2 : Multipolygon)
    (h1_len : ∀ poly ∈ m1.polygons, poly.vertices.length ≥ 2)
    (h2_len : ∀ poly ∈ m2.polygons, poly.vertices.length ≥ 2)
    (h1_nondeg : ∀ seg ∈ m1.segments, seg.p1 ≠ seg.p2)
    (h2_nondeg : ∀ seg ∈ m2.segments, seg.p1 ≠ seg.p2)
    (h_fin12 : Set.Finite ((m1.toEvenGraph h1_len h1_nondeg).toBoundarySet ∩
        (m2.toEvenGraph h2_len h2_nondeg).toBoundarySet)) :
    let G1 := m1.toEvenGraph h1_len h1_nondeg
    let selfPts := (selfSegmentInteriorVertices_finite G1).toFinset.toList
    let wrtPts := h_fin12.toFinset.toList
    List.Perm
      ((refinedSegments m1 m2).map LineSegment.toEndpointsMultiset)
      ((G1.segments.flatMap
        (fun s => iterativeSplit s (selfPts ++ wrtPts))).map
          LineSegment.toEndpointsMultiset) := by
  intro G1 selfPts wrtPts
  -- refinedSegments m1 m2 = m1.segments.flatMap (fun s => splitSegmentAtPoints s (refPts s))
  show (m1.segments.flatMap
        (fun s => splitSegmentAtPoints s (refinementPointsForSegment s m1 m2))).map
        LineSegment.toEndpointsMultiset ~ _
  -- G1.segments = m1.segments via the multipolygon-toEvenGraph lemma.
  rw [show G1.segments = m1.segments from
    Multipolygon.toEvenGraph_segments_eq m1 h1_len h1_nondeg]
  apply flatMap_perm_of_perm_pointwise
  intro s h_s
  exact refinedSeg_perm_iterativeSplit_selfWrt m1 m2 h1_len h2_len h1_nondeg h2_nondeg
    h_fin12 s h_s

/-- Helper: `splitSegmentAtPoints` produces non-degenerate sub-segments
    (consecutive elements of a deduped list are distinct). -/
private theorem splitSegmentAtPoints_nondeg
    (seg : LineSegment) (pts : List Vector2D) (h_seg_ne : seg.p1 ≠ seg.p2)
    (h_pts_on : ∀ p ∈ pts, p ∈ seg.toSet)
    (rs : LineSegment) (h_rs : rs ∈ splitSegmentAtPoints seg pts) :
    rs.p1 ≠ rs.p2 := by
  -- Use that consecutive elements of dedupConsec are distinct (when sorted antisymmetrically).
  unfold splitSegmentAtPoints at h_rs
  simp only [List.mem_map] at h_rs
  obtain ⟨⟨a, b⟩, hab_mem, hab_eq⟩ := h_rs
  show rs.p1 ≠ rs.p2
  rw [← hab_eq]
  show a ≠ b
  -- (a, b) ∈ deduped.zip deduped.tail. Use Pairwise on dedupConsec.
  set L := sortAlongSeg seg.p1 seg.p2 (seg.p1 :: seg.p2 :: pts) with hL_def
  set deduped := dedupConsec L with hded_def
  have hPw : L.Pairwise (fun a b => (vecCmpAlongSeg seg.p1 seg.p2 a b).isLE = true) := by
    rw [hL_def]; exact sortAlongSeg_pairwise_isLE _ _ _
  have hPwD : deduped.Pairwise
      (fun a b => (vecCmpAlongSeg seg.p1 seg.p2 a b).isLE = true) :=
    dedupConsec_pairwise L hPw
  -- Get antisymm on dedupConsec via on-seg property.
  have hp1_seg : seg.p1 ∈ seg.toSet :=
    ⟨0, by norm_num, by norm_num, by ring, by ring⟩
  have hp2_seg : seg.p2 ∈ seg.toSet :=
    ⟨1, by norm_num, by norm_num, by ring, by ring⟩
  have hMemL : ∀ x, x ∈ L ↔ x ∈ seg.p1 :: seg.p2 :: pts := by
    intro x; rw [hL_def]; exact sortAlongSeg_mem_iff _ _ _ _
  have hAntisymm : ∀ a ∈ L, ∀ b ∈ L,
      (vecCmpAlongSeg seg.p1 seg.p2 a b).isLE = true →
      (vecCmpAlongSeg seg.p1 seg.p2 b a).isLE = true → a = b := by
    intro a ha b hb hab hba
    have ha_in := (hMemL a).mp ha
    have hb_in := (hMemL b).mp hb
    have ha_seg : a ∈ seg.toSet := by
      rcases List.mem_cons.mp ha_in with hp | hr
      · rw [hp]; exact hp1_seg
      · rcases List.mem_cons.mp hr with hp | hr2
        · rw [hp]; exact hp2_seg
        · exact h_pts_on a hr2
    have hb_seg : b ∈ seg.toSet := by
      rcases List.mem_cons.mp hb_in with hp | hr
      · rw [hp]; exact hp1_seg
      · rcases List.mem_cons.mp hr with hp | hr2
        · rw [hp]; exact hp2_seg
        · exact h_pts_on b hr2
    exact vecCmpAlongSeg_isLE_antisymm_on_seg seg a b h_seg_ne ha_seg hb_seg hab hba
  have hNodup : deduped.Nodup :=
    dedupConsec_nodup_of_sorted_antisymm _ L hPw hAntisymm
  -- Now (a, b) ∈ deduped.zip deduped.tail. By Nodup of deduped, consecutive elements are distinct.
  intro h_eq
  -- a = b. Get an index where deduped[n] = a and deduped[n+1] = b = a, contradicting Nodup.
  rw [List.mem_iff_getElem] at hab_mem
  obtain ⟨n, hn_lt, h_get_eq⟩ := hab_mem
  rw [List.length_zip] at hn_lt
  have hn_lt_ded : n < deduped.length := lt_of_lt_of_le hn_lt (min_le_left _ _)
  have hn_lt_tail : n < deduped.tail.length := lt_of_lt_of_le hn_lt (min_le_right _ _)
  have hn1_lt_ded : n + 1 < deduped.length := by
    rw [List.length_tail] at hn_lt_tail
    omega
  -- (deduped.zip deduped.tail)[n] = (deduped[n], deduped.tail[n]) = (a, b)
  have h_zip_get : (deduped.zip deduped.tail)[n]'(by rw [List.length_zip]; exact hn_lt) =
      (deduped[n]'hn_lt_ded, deduped.tail[n]'hn_lt_tail) :=
    List.getElem_zip
  rw [h_zip_get] at h_get_eq
  have h_a_eq : a = deduped[n]'hn_lt_ded := by
    have := congrArg Prod.fst h_get_eq
    exact this.symm
  have h_b_eq : b = deduped.tail[n]'hn_lt_tail := by
    have := congrArg Prod.snd h_get_eq
    exact this.symm
  -- deduped.tail[n] = deduped[n+1]
  have h_tail_eq : deduped.tail[n]'hn_lt_tail = deduped[n + 1]'hn1_lt_ded := by
    rw [List.getElem_tail]
  have h_dup : deduped[n] = deduped[n + 1] := by
    rw [← h_a_eq, h_eq, h_b_eq, h_tail_eq]
  have h_ne_idx : n ≠ n + 1 := by omega
  have := (List.Nodup.getElem_inj_iff hNodup).mp h_dup
  exact h_ne_idx this

/-- Half-perm of the construction equivalence: for one of the two halves (the (m1, m2) half),
    show the endpoint-multiset perm. -/
private theorem intersectionGraphSegments_half_perm
    (m1 m2 : Multipolygon)
    (h1_len : ∀ poly ∈ m1.polygons, poly.vertices.length ≥ 2)
    (h2_len : ∀ poly ∈ m2.polygons, poly.vertices.length ≥ 2)
    (h1_nondeg : ∀ seg ∈ m1.segments, seg.p1 ≠ seg.p2)
    (h2_nondeg : ∀ seg ∈ m2.segments, seg.p1 ≠ seg.p2)
    (h_fin12 : Set.Finite ((m1.toEvenGraph h1_len h1_nondeg).toBoundarySet ∩
        (m2.toEvenGraph h2_len h2_nondeg).toBoundarySet)) :
    let G1 := m1.toEvenGraph h1_len h1_nondeg
    let G2 := m2.toEvenGraph h2_len h2_nondeg
    List.Perm
      ((selectInsideOther (refinedSegments m1 m2) m2).map
        LineSegment.toEndpointsMultiset)
      ((_root_.selectSegmentsInside
        (EvenGraphRefinementProofs.graphRefinementSelfAndWrt G1 G2 h_fin12).segments
        G2.interior).map LineSegment.toEndpointsMultiset) := by
  intro G1 G2
  -- Step 1: Construction perm at toEM-level.
  have h_constr := refinedSegments_perm_flatMap_iterativeSplit m1 m2 h1_len h2_len
    h1_nondeg h2_nondeg h_fin12
  set selfPts := (selfSegmentInteriorVertices_finite G1).toFinset.toList with hselfPts_def
  set wrtPts := h_fin12.toFinset.toList with hwrtPts_def
  -- h_constr : (refinedSegments m1 m2).map toEM ~ (G1.segments.flatMap (· iterativeSplit · (selfPts++wrtPts))).map toEM
  -- Compose with graphRefinementSelfAndWrt_segments_perm.
  have h_grs := graphRefinementSelfAndWrt_segments_perm G1 G2 h_fin12
  -- h_grs : (graphRefinementSelfAndWrt G1 G2 h_fin12).segments.map toEM ~ (G1.segments.flatMap (· iterativeSplit · (selfPts++wrtPts))).map toEM
  have h_top : List.Perm
      ((refinedSegments m1 m2).map LineSegment.toEndpointsMultiset)
      ((EvenGraphRefinementProofs.graphRefinementSelfAndWrt G1 G2 h_fin12).segments.map
        LineSegment.toEndpointsMultiset) := h_constr.trans h_grs.symm
  -- Step 2: Define the LHS predicate p_LHS and the RHS predicate p_RHS,
  -- and show they're swap-invariant.
  -- p_LHS s := pointInsideMultipolygonBool (segmentMidpoint s) m2
  -- p_RHS s := decide (segmentOpenInteriorSubset s G2.interior)
  set p_LHS : LineSegment → Bool :=
    fun s => pointInsideMultipolygonBool (segmentMidpoint s) m2 with hpLHS_def
  set p_RHS : LineSegment → Bool :=
    fun s => decide (segmentOpenInteriorSubset s G2.interior) with hpRHS_def
  -- Step 3: For each refined segment of LHS, p_LHS = p_RHS (using midpoint_inside_iff_openInteriorSubset).
  -- We use the fact that refinedSegments are nondegenerate and have boundary subset property.
  -- Step 4: Use map_toEM_filter_perm_of_swap_invariant.
  -- The "shared" predicate q := p_RHS (works for both lists since both have boundary-subset property).
  -- Selection on LHS: filter refinedSegments by p_LHS.
  -- This equals filter by p_RHS, by List.filter_congr using h_pred_eq_LHS.
  -- Then transfer through the perm h_top using the swap-invariance lemma.
  -- Then on RHS, the filter by p_RHS gives selectSegmentsInside.
  -- Step 4a: p_LHS = p_RHS pointwise on refinedSegments (using boundary subset property).
  have h_fin_poly : Set.Finite (m1.toBoundarySet ∩ m2.toBoundarySet) := by
    rw [Multipolygon.toEvenGraph_toBoundarySet_eq m1 h1_len h1_nondeg,
        Multipolygon.toEvenGraph_toBoundarySet_eq m2 h2_len h2_nondeg] at h_fin12
    exact h_fin12
  have h_pred_eq_LHS : ∀ s ∈ refinedSegments m1 m2, p_LHS s = p_RHS s := by
    intro s h_s_ref
    -- Need s.p1 ≠ s.p2
    have h_s_nondeg : s.p1 ≠ s.p2 := by
      -- s is in refinedSegments = m1.segments.flatMap (splitSegmentAtPoints _ _)
      -- splitSegmentAtPoints output is nondeg by splitSegmentAtPoints_nondeg... let's check.
      -- Actually we need a specific lemma. The refined segments come from splitSegmentAtPoints,
      -- which produces segments ⟨a, b⟩ where a and b are CONSECUTIVE in the deduped sorted list.
      -- Consecutive distinct points => a ≠ b.
      unfold refinedSegments at h_s_ref
      rw [List.mem_flatMap] at h_s_ref
      obtain ⟨seg, h_seg_mem, h_s_split⟩ := h_s_ref
      have h_seg_nondeg : seg.p1 ≠ seg.p2 := h1_nondeg seg h_seg_mem
      -- splitSegmentAtPoints seg [...] outputs sub-segments; we need s.p1 ≠ s.p2.
      have h_pts_on : ∀ p ∈ refinementPointsForSegment seg m1 m2, p ∈ seg.toSet :=
        refinementPointsForSegment_mem_toSet seg m1 m2 h_seg_nondeg
      exact splitSegmentAtPoints_nondeg seg _ h_seg_nondeg h_pts_on s h_s_split
    -- Boundary subset property.
    have h_inter : s.toSet ∩ m2.toBoundarySet ⊆ ({s.p1, s.p2} : Set Vector2D) :=
      refinedSegments_inter_boundary_subset_strong m1 m2 h_fin_poly h1_nondeg h2_nondeg
        s h_s_ref
    -- Apply midpoint_inside_iff_openInteriorSubset.
    have h_iff := midpoint_inside_iff_openInteriorSubset s m2 h2_len h2_nondeg
      h_s_nondeg h_inter
    -- p_LHS s = true ↔ p_RHS s = true.
    show pointInsideMultipolygonBool (segmentMidpoint s) m2 =
        decide (segmentOpenInteriorSubset s G2.interior)
    -- G2.interior = m2.interior.
    have h_int_eq : G2.interior = m2.interior :=
      Multipolygon.toEvenGraph_interior_eq m2 h2_len h2_nondeg
    rw [h_int_eq]
    -- Goal: pointInsideMultipolygonBool (midpoint s) m2 = decide (segmentOpenInteriorSubset s m2.interior)
    by_cases h : pointInsideMultipolygonBool (segmentMidpoint s) m2 = true
    · rw [h]; symm
      simp only [decide_eq_true_eq]
      exact h_iff.mp h
    · push_neg at h
      have h_false : pointInsideMultipolygonBool (segmentMidpoint s) m2 = false := by
        rcases h_b : pointInsideMultipolygonBool (segmentMidpoint s) m2 with _ | _
        · rfl
        · exact absurd h_b h
      rw [h_false]; symm
      simp only [decide_eq_false_iff_not]
      intro h_subset
      exact h (h_iff.mpr h_subset)
  -- Step 4b: p_RHS swap invariant.
  have h_RHS_swap : ∀ a b : Vector2D,
      p_RHS (LineSegment.mk a b) = p_RHS (LineSegment.mk b a) := by
    intro a b
    show decide (segmentOpenInteriorSubset _ _) = decide (segmentOpenInteriorSubset _ _)
    -- segmentOpenInteriorSubset depends only on .toSet which is symmetric.
    have h_toSet_eq : (LineSegment.mk a b).toSet = (LineSegment.mk b a).toSet :=
      EvenGraphProofs.lineSegment_toSet_swap a b
    have h_iff : segmentOpenInteriorSubset (LineSegment.mk a b) G2.interior ↔
        segmentOpenInteriorSubset (LineSegment.mk b a) G2.interior := by
      unfold segmentOpenInteriorSubset
      constructor
      · intro h p hp h1 h2
        -- (b, a).toSet = (a, b).toSet, so p ∈ (a, b).toSet
        have hp' : p ∈ (LineSegment.mk a b).toSet := h_toSet_eq ▸ hp
        -- p1 of swapped is b, p2 is a.
        -- show p ∈ G2.interior
        exact h p hp' h2 h1
      · intro h p hp h1 h2
        have hp' : p ∈ (LineSegment.mk b a).toSet := h_toSet_eq.symm ▸ hp
        exact h p hp' h2 h1
    by_cases h : segmentOpenInteriorSubset (LineSegment.mk a b) G2.interior
    · rw [decide_eq_true (h_iff.mp h), decide_eq_true h]
    · rw [decide_eq_false (fun h' => h (h_iff.mpr h'))]
      rw [decide_eq_false h]
  -- Step 5: Compose.
  -- selectInsideOther (refinedSegments) m2 = (refinedSegments).filter p_LHS
  -- selectSegmentsInside (graphRefinementSelfAndWrt G1 G2 h_fin12).segments G2.interior =
  --     (graphRefinementSelfAndWrt G1 G2 h_fin12).segments.filter p_RHS.
  show ((refinedSegments m1 m2).filter p_LHS).map LineSegment.toEndpointsMultiset ~
       ((EvenGraphRefinementProofs.graphRefinementSelfAndWrt G1 G2 h_fin12).segments.filter p_RHS).map
         LineSegment.toEndpointsMultiset
  -- Replace p_LHS with p_RHS via List.filter_congr.
  have h_filter_LHS_eq : (refinedSegments m1 m2).filter p_LHS =
      (refinedSegments m1 m2).filter p_RHS := by
    apply List.filter_congr
    intro s h_s
    exact h_pred_eq_LHS s h_s
  rw [h_filter_LHS_eq]
  -- Now apply the swap-invariance lemma.
  exact map_toEM_filter_perm_of_swap_invariant _ _ p_RHS h_RHS_swap h_top

/-- Construction equivalence: the multiset of segment endpoint multisets of
    `intersectionGraphSegments m1 m2` matches that of
    `evenGraphIntersection (m1.toEvenGraph) (m2.toEvenGraph) ...`. -/
theorem intersectionGraphSegments_perm_evenGraphIntersection
    (m1 m2 : Multipolygon)
    (h1_len : ∀ poly ∈ m1.polygons, poly.vertices.length ≥ 2)
    (h2_len : ∀ poly ∈ m2.polygons, poly.vertices.length ≥ 2)
    (h1_nondeg : ∀ seg ∈ m1.segments, seg.p1 ≠ seg.p2)
    (h2_nondeg : ∀ seg ∈ m2.segments, seg.p1 ≠ seg.p2)
    (h_fin12 : Set.Finite ((m1.toEvenGraph h1_len h1_nondeg).toBoundarySet ∩
        (m2.toEvenGraph h2_len h2_nondeg).toBoundarySet)) :
    (intersectionGraphSegments m1 m2).map LineSegment.toEndpointsMultiset ~
    (evenGraphIntersection (m1.toEvenGraph h1_len h1_nondeg)
        (m2.toEvenGraph h2_len h2_nondeg) h_fin12).segments.map
      LineSegment.toEndpointsMultiset := by
  have h_fin21 : Set.Finite ((m2.toEvenGraph h2_len h2_nondeg).toBoundarySet ∩
      (m1.toEvenGraph h1_len h1_nondeg).toBoundarySet) :=
    EvenGraphIntersectionProofs.flipFin h_fin12
  -- Decompose both sides into halves.
  show ((selectInsideOther (refinedSegments m1 m2) m2 ++
         selectInsideOther (refinedSegments m2 m1) m1).map
         LineSegment.toEndpointsMultiset) ~
       ((((EvenGraphRefinementProofs.graphRefinementSelfAndWrt
            (m1.toEvenGraph h1_len h1_nondeg) (m2.toEvenGraph h2_len h2_nondeg) h_fin12).toGraph.selectSegmentsInside
            (m2.toEvenGraph h2_len h2_nondeg).interior).append
          ((EvenGraphRefinementProofs.graphRefinementSelfAndWrt
            (m2.toEvenGraph h2_len h2_nondeg) (m1.toEvenGraph h1_len h1_nondeg) h_fin21).toGraph.selectSegmentsInside
            (m1.toEvenGraph h1_len h1_nondeg).interior)).segments).map
        LineSegment.toEndpointsMultiset
  rw [Graph.append_segments]
  rw [List.map_append, List.map_append]
  -- Apply Perm.append.
  refine List.Perm.append ?_ ?_
  · -- Half 1 (m1, m2).
    exact intersectionGraphSegments_half_perm m1 m2 h1_len h2_len h1_nondeg h2_nondeg h_fin12
  · -- Half 2 (m2, m1).
    exact intersectionGraphSegments_half_perm m2 m1 h2_len h1_len h2_nondeg h1_nondeg h_fin21

/-- Each polygon produced by the algorithm is valid (length ≥ 2, segs non-degenerate). -/
theorem multipolygonIntersectionAlgorithm_polys_valid
    (m1 m2 : Multipolygon)
    (h1_len : ∀ poly ∈ m1.polygons, poly.vertices.length ≥ 2)
    (h2_len : ∀ poly ∈ m2.polygons, poly.vertices.length ≥ 2)
    (h1_nondeg : ∀ seg ∈ m1.segments, seg.p1 ≠ seg.p2)
    (h2_nondeg : ∀ seg ∈ m2.segments, seg.p1 ≠ seg.p2)
    (h_fin12 : Set.Finite ((m1.toEvenGraph h1_len h1_nondeg).toBoundarySet ∩
        (m2.toEvenGraph h2_len h2_nondeg).toBoundarySet)) :
    ∀ poly ∈ (multipolygonIntersectionAlgorithm m1 m2).polygons,
      poly.vertices.length ≥ 2 ∧ ∀ seg ∈ poly.segments, seg.p1 ≠ seg.p2 := by
  -- Get the even graph intersection
  obtain ⟨h_even, _⟩ := evenGraphIntersection_isEven_and_interior_eq
    (m1.toEvenGraph h1_len h1_nondeg) (m2.toEvenGraph h2_len h2_nondeg) h_fin12
  set Gint : EvenGraph :=
    ⟨evenGraphIntersection (m1.toEvenGraph h1_len h1_nondeg)
      (m2.toEvenGraph h2_len h2_nondeg) h_fin12, h_even⟩
  -- Construction perm
  have h_construction : (intersectionGraphSegments m1 m2).map
        LineSegment.toEndpointsMultiset ~
      Gint.segments.map LineSegment.toEndpointsMultiset :=
    intersectionGraphSegments_perm_evenGraphIntersection m1 m2 h1_len h2_len
      h1_nondeg h2_nondeg h_fin12
  -- Derive non-degeneracy for intersectionGraphSegments via construction Equiv.
  have h_nondeg : ∀ s ∈ intersectionGraphSegments m1 m2, s.p1 ≠ s.p2 := by
    intro s hs h_deg
    have hs_in_image : s.toEndpointsMultiset ∈
        (intersectionGraphSegments m1 m2).map LineSegment.toEndpointsMultiset :=
      List.mem_map_of_mem _ hs
    have hs_in_gint : s.toEndpointsMultiset ∈
        Gint.segments.map LineSegment.toEndpointsMultiset :=
      h_construction.mem_iff.mp hs_in_image
    obtain ⟨s', hs'_mem, hs'_eq⟩ := List.mem_map.mp hs_in_gint
    have hs'_nondeg : s'.p1 ≠ s'.p2 := Gint.segments_nondegenerate s' hs'_mem
    have h_s'_nodup : s'.toEndpointsMultiset.Nodup :=
      EvenGraphDecompositionProofs.pair_nodup_iff.mpr hs'_nondeg
    have h_s_nodup : s.toEndpointsMultiset.Nodup := hs'_eq ▸ h_s'_nodup
    exact (EvenGraphDecompositionProofs.pair_nodup_iff.mp h_s_nodup) h_deg
  -- Derive even-degree for intersectionGraphSegments via construction Equiv.
  have h_inc_eq_general : ∀ (L : List LineSegment) (v : Vector2D),
      EvenGraphDecompositionImpl.incCount L v =
      (L.map LineSegment.toEndpointsMultiset).countP (fun m => decide (v ∈ m)) := by
    intro L v
    unfold EvenGraphDecompositionImpl.incCount
    rw [List.countP_map]
    congr 1
    funext s
    show decide (s.p1 = v ∨ s.p2 = v) = decide (v ∈ s.toEndpointsMultiset)
    show decide (s.p1 = v ∨ s.p2 = v) =
      decide (v ∈ ({s.p1, s.p2} : Multiset Vector2D))
    rw [show ({s.p1, s.p2} : Multiset Vector2D) = (s.p1 ::ₘ {s.p2}) from rfl]
    simp only [Multiset.mem_cons, Multiset.mem_singleton]
    have h_eq : (s.p1 = v ∨ s.p2 = v) ↔ (v = s.p1 ∨ v = s.p2) := by
      constructor
      · rintro (h | h)
        · left; exact h.symm
        · right; exact h.symm
      · rintro (h | h)
        · left; exact h.symm
        · right; exact h.symm
    rw [show (decide (s.p1 = v ∨ s.p2 = v)) = decide (v = s.p1 ∨ v = s.p2) from
      decide_eq_decide.mpr h_eq]
  have h_even_intersection : ∀ v, Even
      (EvenGraphDecompositionImpl.incCount (intersectionGraphSegments m1 m2) v) := by
    intro v
    rw [h_inc_eq_general]
    rw [h_construction.countP_eq]
    rw [← h_inc_eq_general]
    exact h_even v
  -- Apply decomposeListFuel_polys_valid.
  have h_eq_decomp : (multipolygonIntersectionAlgorithm m1 m2).polygons =
      EvenGraphDecompositionImpl.decomposeListFuel
        (intersectionGraphSegments m1 m2).length
        (intersectionGraphSegments m1 m2) := rfl
  rw [h_eq_decomp]
  exact EvenGraphDecompositionProofs.decomposeListFuel_polys_valid
    (intersectionGraphSegments m1 m2).length
    (intersectionGraphSegments m1 m2) (Nat.le_refl _) h_nondeg h_even_intersection

/-- Helper: the segments of `combine (polys.attach.map (fun ⟨p, hp⟩ =>
    p.toEvenGraph ...))` equal `polys.flatMap Polygon.segments`. -/
private lemma combine_attach_segments
    (polys : List Polygon)
    (h_polys_valid : ∀ poly ∈ polys,
        poly.vertices.length ≥ 2 ∧ ∀ seg ∈ poly.segments, seg.p1 ≠ seg.p2) :
    (EvenGraph.combine (polys.attach.map
      (fun ⟨p, hp⟩ => p.toEvenGraph (h_polys_valid p hp).1
        (h_polys_valid p hp).2))).segments = polys.flatMap Polygon.segments := by
  rw [EvenGraph.combine_segments]
  -- (polys.attach.map (fun ⟨p, hp⟩ => p.toEvenGraph ...)).flatMap (·.segments)
  --   = polys.attach.flatMap (fun ⟨p, hp⟩ => (p.toEvenGraph ...).segments)
  --   = polys.attach.flatMap (fun ⟨p, hp⟩ => p.segments)        [by EvenGraph segments unfolding]
  --   = polys.flatMap Polygon.segments                          [by attach lemma]
  show (polys.attach.map (fun ⟨p, hp⟩ => p.toEvenGraph (h_polys_valid p hp).1
        (h_polys_valid p hp).2)).flatMap (·.segments) =
       polys.flatMap Polygon.segments
  rw [List.flatMap_map]
  show (polys.attach.flatMap (fun (x : {p // p ∈ polys}) =>
        (x.val.toEvenGraph (h_polys_valid x.val x.property).1
          (h_polys_valid x.val x.property).2).segments)) =
       polys.flatMap Polygon.segments
  -- toEvenGraph segments = polygon segments (definitionally rfl)
  rw [show (fun (x : {p // p ∈ polys}) =>
        (x.val.toEvenGraph (h_polys_valid x.val x.property).1
          (h_polys_valid x.val x.property).2).segments) =
        (fun (x : {p // p ∈ polys}) => x.val.segments) from rfl]
  -- Now polys.attach.flatMap (fun x => x.val.segments) = polys.flatMap Polygon.segments
  show polys.attach.flatMap (fun (x : {p // p ∈ polys}) => x.val.segments) =
       polys.flatMap Polygon.segments
  clear h_polys_valid
  induction polys with
  | nil => rfl
  | cons p rest ih =>
    simp only [List.attach_cons, List.flatMap_cons, List.flatMap_map, ih]

/-- The combined even graph from the algorithm output is `Equiv` to
    `evenGraphIntersection`. -/
theorem multipolygonIntersectionAlgorithm_combine_equiv
    (m1 m2 : Multipolygon)
    (h1_len : ∀ poly ∈ m1.polygons, poly.vertices.length ≥ 2)
    (h2_len : ∀ poly ∈ m2.polygons, poly.vertices.length ≥ 2)
    (h1_nondeg : ∀ seg ∈ m1.segments, seg.p1 ≠ seg.p2)
    (h2_nondeg : ∀ seg ∈ m2.segments, seg.p1 ≠ seg.p2)
    (h_fin12 : Set.Finite ((m1.toEvenGraph h1_len h1_nondeg).toBoundarySet ∩
        (m2.toEvenGraph h2_len h2_nondeg).toBoundarySet))
    (h_even : (evenGraphIntersection (m1.toEvenGraph h1_len h1_nondeg)
        (m2.toEvenGraph h2_len h2_nondeg) h_fin12).IsEven)
    (h_polys_valid : ∀ poly ∈ (multipolygonIntersectionAlgorithm m1 m2).polygons,
        poly.vertices.length ≥ 2 ∧ ∀ seg ∈ poly.segments, seg.p1 ≠ seg.p2) :
    (EvenGraph.combine ((multipolygonIntersectionAlgorithm m1 m2).polygons.attach.map
      (fun ⟨p, hp⟩ => p.toEvenGraph (h_polys_valid p hp).1
        (h_polys_valid p hp).2))).Equiv
    ⟨evenGraphIntersection (m1.toEvenGraph h1_len h1_nondeg)
      (m2.toEvenGraph h2_len h2_nondeg) h_fin12, h_even⟩ := by
  show _ ~ _
  rw [combine_attach_segments _ h_polys_valid]
  -- Goal: (polys.flatMap Polygon.segments).map LineSegment.toEndpointsMultiset ~ ...
  -- polys = decomposeSegments (intersectionGraphSegments m1 m2)
  --       = decomposeList (intersectionGraphSegments m1 m2)
  show ((decomposeSegments (intersectionGraphSegments m1 m2)).flatMap
        Polygon.segments).map LineSegment.toEndpointsMultiset ~ _
  -- Construction Equiv at the multiset-of-endpoint-multisets level.
  set Gint : EvenGraph :=
    ⟨evenGraphIntersection (m1.toEvenGraph h1_len h1_nondeg)
      (m2.toEvenGraph h2_len h2_nondeg) h_fin12, h_even⟩
  have h_construction : (intersectionGraphSegments m1 m2).map
        LineSegment.toEndpointsMultiset ~
      Gint.segments.map LineSegment.toEndpointsMultiset :=
    intersectionGraphSegments_perm_evenGraphIntersection m1 m2 h1_len h2_len
      h1_nondeg h2_nondeg h_fin12
  -- Derive non-degeneracy for intersectionGraphSegments via construction Equiv.
  have h_nondeg : ∀ s ∈ intersectionGraphSegments m1 m2, s.p1 ≠ s.p2 := by
    intro s hs h_deg
    have hs_in_image : s.toEndpointsMultiset ∈
        (intersectionGraphSegments m1 m2).map LineSegment.toEndpointsMultiset :=
      List.mem_map_of_mem _ hs
    have hs_in_gint : s.toEndpointsMultiset ∈
        Gint.segments.map LineSegment.toEndpointsMultiset :=
      h_construction.mem_iff.mp hs_in_image
    obtain ⟨s', hs'_mem, hs'_eq⟩ := List.mem_map.mp hs_in_gint
    have hs'_nondeg : s'.p1 ≠ s'.p2 := Gint.segments_nondegenerate s' hs'_mem
    have h_s'_nodup : s'.toEndpointsMultiset.Nodup :=
      EvenGraphDecompositionProofs.pair_nodup_iff.mpr hs'_nondeg
    have h_s_nodup : s.toEndpointsMultiset.Nodup := hs'_eq ▸ h_s'_nodup
    exact (EvenGraphDecompositionProofs.pair_nodup_iff.mp h_s_nodup) h_deg
  -- Derive even-degree for intersectionGraphSegments via construction Equiv.
  -- Key observation: incCount L v = (L.map toEndpointsMultiset).countP (v ∈ ·).
  have h_inc_eq_general : ∀ (L : List LineSegment) (v : Vector2D),
      EvenGraphDecompositionImpl.incCount L v =
      (L.map LineSegment.toEndpointsMultiset).countP (fun m => decide (v ∈ m)) := by
    intro L v
    unfold EvenGraphDecompositionImpl.incCount
    rw [List.countP_map]
    congr 1
    funext s
    show decide (s.p1 = v ∨ s.p2 = v) = decide (v ∈ s.toEndpointsMultiset)
    show decide (s.p1 = v ∨ s.p2 = v) =
      decide (v ∈ ({s.p1, s.p2} : Multiset Vector2D))
    rw [show ({s.p1, s.p2} : Multiset Vector2D) = (s.p1 ::ₘ {s.p2}) from rfl]
    simp only [Multiset.mem_cons, Multiset.mem_singleton]
    have h_eq : (s.p1 = v ∨ s.p2 = v) ↔ (v = s.p1 ∨ v = s.p2) := by
      constructor
      · rintro (h | h)
        · left; exact h.symm
        · right; exact h.symm
      · rintro (h | h)
        · left; exact h.symm
        · right; exact h.symm
    rw [show (decide (s.p1 = v ∨ s.p2 = v)) = decide (v = s.p1 ∨ v = s.p2) from
      decide_eq_decide.mpr h_eq]
  have h_even_intersection : ∀ v, Even
      (EvenGraphDecompositionImpl.incCount (intersectionGraphSegments m1 m2) v) := by
    intro v
    rw [h_inc_eq_general]
    rw [h_construction.countP_eq]
    rw [← h_inc_eq_general]
    exact h_even v
  -- Apply decomposeListFuel_perm.
  have h_decomp_perm := EvenGraphDecompositionProofs.decomposeListFuel_perm
    (intersectionGraphSegments m1 m2).length
    (intersectionGraphSegments m1 m2) (Nat.le_refl _) h_nondeg h_even_intersection
  -- decomposeSegments = decomposeList = decomposeListFuel ...
  have h_eq_decomp : decomposeSegments (intersectionGraphSegments m1 m2) =
      EvenGraphDecompositionImpl.decomposeListFuel
        (intersectionGraphSegments m1 m2).length
        (intersectionGraphSegments m1 m2) := rfl
  rw [h_eq_decomp]
  exact (h_decomp_perm.symm).trans h_construction

/-- The main correctness theorem about the computable algorithm: the
    intersection of `m1` and `m2`'s interiors equals the interior of the
    multipolygon produced by the algorithm. -/
theorem multipolygonIntersectionAlgorithm_correct
    (m1 m2 : Multipolygon)
    (h1_len : ∀ poly ∈ m1.polygons, poly.vertices.length ≥ 2)
    (h2_len : ∀ poly ∈ m2.polygons, poly.vertices.length ≥ 2)
    (h1_nondeg : ∀ seg ∈ m1.segments, seg.p1 ≠ seg.p2)
    (h2_nondeg : ∀ seg ∈ m2.segments, seg.p1 ≠ seg.p2)
    (h_fin : Set.Finite (m1.toBoundarySet ∩ m2.toBoundarySet)) :
    m1.interior ∩ m2.interior =
      (multipolygonIntersectionAlgorithm m1 m2).interior := by
  set G1 : EvenGraph := m1.toEvenGraph h1_len h1_nondeg with hG1_def
  set G2 : EvenGraph := m2.toEvenGraph h2_len h2_nondeg with hG2_def
  have hb1 : G1.toBoundarySet = m1.toBoundarySet :=
    Multipolygon.toEvenGraph_toBoundarySet_eq m1 h1_len h1_nondeg
  have hb2 : G2.toBoundarySet = m2.toBoundarySet :=
    Multipolygon.toEvenGraph_toBoundarySet_eq m2 h2_len h2_nondeg
  have hi1 : G1.interior = m1.interior :=
    Multipolygon.toEvenGraph_interior_eq m1 h1_len h1_nondeg
  have hi2 : G2.interior = m2.interior :=
    Multipolygon.toEvenGraph_interior_eq m2 h2_len h2_nondeg
  have h_fin12 : Set.Finite (G1.toBoundarySet ∩ G2.toBoundarySet) := by
    rw [hb1, hb2]; exact h_fin
  obtain ⟨h_even, h_interior_eq⟩ :=
    evenGraphIntersection_isEven_and_interior_eq G1 G2 h_fin12
  set Gint : EvenGraph :=
    ⟨evenGraphIntersection G1 G2 h_fin12, h_even⟩ with hGint_def
  have hGint_int : Gint.interior = m1.interior ∩ m2.interior := by
    rw [h_interior_eq, hi1, hi2]
  -- Validity of algorithm output polygons.
  have h_polys_valid : ∀ poly ∈ (multipolygonIntersectionAlgorithm m1 m2).polygons,
      poly.vertices.length ≥ 2 ∧ ∀ seg ∈ poly.segments, seg.p1 ≠ seg.p2 :=
    multipolygonIntersectionAlgorithm_polys_valid m1 m2 h1_len h2_len
      h1_nondeg h2_nondeg h_fin12
  -- Convert h_polys_valid into per-polygon length + flat nondeg hypotheses.
  set mout : Multipolygon := multipolygonIntersectionAlgorithm m1 m2 with hmout_def
  have hmout_len : ∀ poly ∈ mout.polygons, poly.vertices.length ≥ 2 :=
    fun poly hp => (h_polys_valid poly hp).1
  have hmout_nondeg : ∀ seg ∈ mout.segments, seg.p1 ≠ seg.p2 := by
    intro seg hseg
    obtain ⟨poly, hpoly, hps⟩ := List.mem_flatMap.mp hseg
    exact (h_polys_valid poly hpoly).2 seg hps
  -- The combined even graph from algorithm output.
  set polys := mout.polygons with hpolys_def
  set polyGraphs := polys.attach.map (fun ⟨p, hp⟩ =>
    p.toEvenGraph (h_polys_valid p hp).1 (h_polys_valid p hp).2) with hpolyGraphs_def
  -- Combine of polyGraphs is Equiv to Gint.
  have h_total_equiv : (EvenGraph.combine polyGraphs).Equiv Gint :=
    multipolygonIntersectionAlgorithm_combine_equiv m1 m2 h1_len h2_len
      h1_nondeg h2_nondeg h_fin12 h_even h_polys_valid
  have h_combine_int : (EvenGraph.combine polyGraphs).interior =
      m1.interior ∩ m2.interior := by
    rw [h_total_equiv.interior_eq, hGint_int]
  -- Map of interiors: polyGraphs.map .interior = polys.map Polygon.interior.
  have h_map_int : polyGraphs.map EvenGraph.interior = polys.map Polygon.interior := by
    show (polys.attach.map (fun (x : {p // p ∈ polys}) =>
        x.val.toEvenGraph (h_polys_valid x.val x.property).1
          (h_polys_valid x.val x.property).2)).map EvenGraph.interior =
      polys.map Polygon.interior
    rw [List.map_map]
    have hpolys_eq : polys = polys.attach.map Subtype.val := by simp
    conv_rhs => rw [hpolys_eq, List.map_map]
    refine List.map_congr_left ?_
    rintro ⟨p, hp⟩ _
    show (p.toEvenGraph _ _).interior = p.interior
    exact (Polygon.toEvenGraph_interior_eq p (h_polys_valid p hp).1
      (h_polys_valid p hp).2)
  -- Boundary set equalities: combine boundary = mout boundary.
  have h_combine_bd_set : (EvenGraph.combine polyGraphs).toBoundarySet =
      mout.toBoundarySet := by
    rw [EvenGraph.combine_toBoundarySet]
    ext p
    -- LHS: ∃ G ∈ polyGraphs, p ∈ G.toBoundarySet.
    -- RHS: ∃ seg ∈ mout.segments, p ∈ seg.toSet = ∃ seg ∈ polys.flatMap Polygon.segments, ...
    show (p ∈ ⋃ G ∈ polyGraphs, G.toBoundarySet) ↔
         (∃ seg ∈ mout.segments, p ∈ seg.toSet)
    show _ ↔ (∃ seg ∈ polys.flatMap Polygon.segments, p ∈ seg.toSet)
    simp only [Set.mem_iUnion, exists_prop, List.mem_flatMap]
    constructor
    · rintro ⟨G', hG'_mem, hp_G'⟩
      simp only [hpolyGraphs_def, List.mem_map, List.mem_attach, true_and,
        Subtype.exists] at hG'_mem
      obtain ⟨q, hq, hq_eq⟩ := hG'_mem
      subst hq_eq
      rw [Polygon.toEvenGraph_boundary_eq] at hp_G'
      obtain ⟨seg, hseg_q, hp_seg⟩ := hp_G'
      exact ⟨seg, ⟨q, hq, hseg_q⟩, hp_seg⟩
    · rintro ⟨seg, ⟨q, hq, hseg_q⟩, hp_seg⟩
      refine ⟨q.toEvenGraph (h_polys_valid q hq).1 (h_polys_valid q hq).2, ?_, ?_⟩
      · simp only [hpolyGraphs_def, List.mem_map, List.mem_attach, true_and,
          Subtype.exists]
        exact ⟨q, hq, rfl⟩
      · rw [Polygon.toEvenGraph_boundary_eq q (h_polys_valid q hq).1
          (h_polys_valid q hq).2]
        exact ⟨seg, hseg_q, hp_seg⟩
  -- Final assemble: m1.interior ∩ m2.interior = Gint.interior = combine.interior =
  -- symmDiff form = mout.interior.
  rw [Multipolygon.interior_eq_symmDiffAll_sdiff_boundary mout hmout_len hmout_nondeg,
      ← h_combine_int, EvenGraph.combine_interior_eq_symmDiff_sdiff_boundary,
      h_combine_bd_set, h_map_int]

end MultipolygonIntersectionAlgorithmProofs
