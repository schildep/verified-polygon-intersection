/-- v4.15 compatibility shim. Mathlib v4.15's `List.eq_of_perm_of_sorted`
requires a global `[IsAntisymm α r]` typeclass instance, but several proofs
in this file only have *local* antisymmetry — `r` is only antisymmetric on
the actual elements of `l₁` and `l₂`. v4.29's `List.Perm.eq_of_pairwise`
took the antisymmetry as an explicit argument, which is what we need.
This helper restores that interface. -/
private theorem perm_eq_of_pairwise_local {α : Type*} {r : α → α → Prop}
    {l₁ l₂ : List α}
    (antisymm : ∀ a b, a ∈ l₁ → b ∈ l₂ → r a b → r b a → a = b)
    (hp₁ : l₁.Pairwise r) (hp₂ : l₂.Pairwise r) (hperm : l₁.Perm l₂) :
    l₁ = l₂ := by
  induction l₁ generalizing l₂ with
  | nil =>
    cases l₂ with
    | nil => rfl
    | cons _ _ => exact absurd hperm (by simp)
  | cons a l₁' ih =>
    cases l₂ with
    | nil => exact absurd hperm (by simp)
    | cons b l₂' =>
      have ha_in : a ∈ b :: l₂' := hperm.subset (List.mem_cons_self _ _)
      have hb_in : b ∈ a :: l₁' := hperm.symm.subset (List.mem_cons_self _ _)
      have ha_le : ∀ x ∈ l₁', r a x := (List.pairwise_cons.mp hp₁).1
      have hb_le : ∀ x ∈ l₂', r b x := (List.pairwise_cons.mp hp₂).1
      have hp₁' : l₁'.Pairwise r := (List.pairwise_cons.mp hp₁).2
      have hp₂' : l₂'.Pairwise r := (List.pairwise_cons.mp hp₂).2
      have hab : a = b := by
        rcases List.mem_cons.mp ha_in with h | h
        · exact h
        · rcases List.mem_cons.mp hb_in with hba | hba_in
          · exact hba.symm
          · exact antisymm a b (List.mem_cons_self _ _)
              (List.mem_cons_self _ _)
              (ha_le b hba_in) (hb_le a h)
      subst hab
      have hperm' : l₁'.Perm l₂' := (List.perm_cons _).mp hperm
      have antisymm' : ∀ x y, x ∈ l₁' → y ∈ l₂' → r x y → r y x → x = y := by
        intro x y hx hy
        exact antisymm x y (List.mem_cons_of_mem _ hx) (List.mem_cons_of_mem _ hy)
      have heq : l₁' = l₂' := ih antisymm' hp₁' hp₂' hperm'
      rw [heq]

/-!
# Polygon Intersection Algorithm – Implementation

A *computable* algorithm `multipolygonIntersectionAlgorithm : Polygon → Polygon →
List Polygon` that, for two polygons `m1` and `m2` whose vertex lists
have length ≥ 2 with non-degenerate segments and finite boundary
intersection, returns a list of polygons whose interior symmetric
difference (minus boundaries) equals `m1.interior ∩ m2.interior`.

## Algorithm

Following the construction of `evenGraphIntersection` and the polygon
decomposition theorem:

1. **Refine** each polygon segment by inserting all rational intersection
   points with the other polygon's segments and all of the polygon's own
   vertices that lie strictly in the segment's interior.
2. **Select** refined segments whose midpoint lies inside the other polygon
   (tested by ray casting with rational slopes `(1, k)` for `k = 1, 2, …`,
   choosing the smallest `k` that avoids the polygon's vertices).
3. **Combine** the selected segments from both polygons into a single graph.
4. **Decompose** the resulting even graph greedily into a list of polygons
   using the fuel-based walk from `EvenGraphDecompositionImpl`.

Each step is computable. Correctness is established via `EvenGraph.Equiv`
chains to the noncomputable infrastructure already proven in
`PolygonIntersectionProofs.lean`.
-/

namespace MultipolygonIntersectionAlgorithmProofs
open MultipolygonIntersectionAlgorithmImpl
open EvenGraphRefinementProofs

