/-! ### Parity invariance for graphs -/

/-- Helper: the graph crossing count equals the sum of polygon crossing counts
    when the polygon segments form a permutation of the graph segments. -/
private lemma countP_flatMap_eq_sum {α β : Type} (p : β → Bool) (f : α → List β) (l : List α) :
    (l.flatMap f).countP p = (l.map fun x => (f x).countP p).sum := by
  induction l with
  | nil => simp
  | cons a rest ih =>
    simp only [List.flatMap_cons, List.countP_append, List.map_cons, List.sum_cons, ih]

private lemma crossingCount_eq_sum_of_decomposition
    (r : Ray) (G : EvenGraph) (polys : List Polygon)
    (h_perm : G.segments.Perm (polys.flatMap Polygon.segments)) :
    intersectionRayGraphSegmentsNumber r G % 2 =
    (polys.map fun poly => intersectionRayPolygonSegmentsNumber r poly).sum % 2 := by
  have h_countP : G.segments.countP (fun seg => decide (rayIntersectsSegment r seg)) =
      (polys.flatMap Polygon.segments).countP (fun seg => decide (rayIntersectsSegment r seg)) :=
    h_perm.countP_eq _
  simp only [intersectionRayGraphSegmentsNumber, intersectionRayPolygonSegmentsNumber]
  rw [h_countP, List.countP_flatMap]
  rfl

/-! #### Geometric helpers for graph parity proofs -/
-- These mirror private lemmas in the Proofs namespace (ParityProofs.lean),
-- adapted to work with EvenGraph.segments rather than Polygon.segments.

private def egp_cross (v w : Vector2D) : ℚ := v.x * w.y - v.y * w.x

private lemma egp_rot90_nonzero (v : Vector2D) (hv : v ≠ ⟨0, 0⟩) :
    (⟨-v.y, v.x⟩ : Vector2D) ≠ ⟨0, 0⟩ := by
  intro h; apply hv
  have hx : (-v.y : ℚ) = 0 := congrArg Vector2D.x h
  have hy : v.x = 0 := congrArg Vector2D.y h
  simp at hx
  exact (Vector2D.mk.injEq _ _ _ _).mpr ⟨hy, hx⟩

private lemma egp_direction_trichotomy (d1 d2 : Vector2D)
    (hd1 : d1 ≠ ⟨0, 0⟩) (hd2 : d2 ≠ ⟨0, 0⟩) :
    (∃ c : ℚ, c > 0 ∧ d1.x = c * d2.x ∧ d1.y = c * d2.y) ∨
    (∃ c : ℚ, c < 0 ∧ d1.x = c * d2.x ∧ d1.y = c * d2.y) ∨
    egp_cross d1 d2 ≠ 0 := by
  by_cases hcross : egp_cross d1 d2 ≠ 0
  · exact Or.inr (Or.inr hcross)
  · push_neg at hcross
    unfold egp_cross at hcross
    have hcross : d1.x * d2.y = d1.y * d2.x := by linarith
    have hd2_or : d2.x ≠ 0 ∨ d2.y ≠ 0 := by
      by_contra h; push_neg at h
      exact hd2 ((Vector2D.mk.injEq _ _ _ _).mpr ⟨h.1, h.2⟩)
    suffices ∃ c : ℚ, d1.x = c * d2.x ∧ d1.y = c * d2.y by
      obtain ⟨c, hcx, hcy⟩ := this
      rcases lt_trichotomy c 0 with hlt | heq | hgt
      · exact Or.inr (Or.inl ⟨c, hlt, hcx, hcy⟩)
      · subst heq; simp at hcx hcy
        exact absurd ((Vector2D.mk.injEq _ _ _ _).mpr ⟨hcx, hcy⟩) hd1
      · exact Or.inl ⟨c, hgt, hcx, hcy⟩
    rcases hd2_or with hx | hy
    · refine ⟨d1.x / d2.x, ?_, ?_⟩
      · exact (div_mul_cancel₀ d1.x hx).symm
      · calc d1.y = d1.y * d2.x / d2.x := (mul_div_cancel_right₀ d1.y hx).symm
            _ = d1.x * d2.y / d2.x := by rw [hcross.symm]
            _ = d1.x / d2.x * d2.y := by ring
    · refine ⟨d1.y / d2.y, ?_, ?_⟩
      · calc d1.x = d1.x * d2.y / d2.y := (mul_div_cancel_right₀ d1.x hy).symm
            _ = d1.y * d2.x / d2.y := by rw [hcross]
            _ = d1.y / d2.y * d2.x := by ring
      · exact (div_mul_cancel₀ d1.y hy).symm

private lemma egp_subsingleton_card (S : Set Vector2D) (hfin : S.Finite) (hsub : S.Subsingleton) :
    hfin.toFinset.card ≤ 1 := by
  rw [Finset.card_le_one]
  intro a ha b hb
  exact hsub (hfin.mem_toFinset.mp ha) (hfin.mem_toFinset.mp hb)

private lemma egp_nonempty_card (S : Set Vector2D) (hfin : S.Finite) (hne : S.Nonempty) :
    1 ≤ hfin.toFinset.card := by
  rw [Finset.one_le_card]
  exact hfin.toFinset_nonempty.mpr hne

private lemma egp_countP_eq_map_sum {α : Type} (p : α → Bool) (l : List α) :
    l.countP p = (l.map fun x => if p x then 1 else 0).sum := by
  induction l with
  | nil => simp
  | cons a rest ih =>
    simp only [List.countP_cons, List.map_cons, List.sum_cons, ih]
    split <;> omega

private lemma egp_sum_map_add {α : Type} (f g : α → ℕ) (l : List α) :
    (l.map fun x => f x + g x).sum = (l.map f).sum + (l.map g).sum := by
  induction l with
  | nil => simp
  | cons a rest ih => simp only [List.map_cons, List.sum_cons, ih]; omega

/-- Same-direction rays give equal graph intersection counts. -/
private lemma egp_same_dir_eq_count_graph (r1 r2 : Ray) (G : EvenGraph)
    (h_origin : sameOrigin r1 r2)
    (h_same : ∃ c : ℚ, c > 0 ∧ r1.direction.x = c * r2.direction.x ∧
                                  r1.direction.y = c * r2.direction.y) :
    intersectionRayGraphSegmentsNumber r1 G =
    intersectionRayGraphSegmentsNumber r2 G := by
  obtain ⟨c, hc_pos, hcx, hcy⟩ := h_same
  unfold sameOrigin at h_origin
  have h_eq : r1.toSet = r2.toSet := by
    ext p; simp only [Ray.toSet, Set.mem_setOf_eq]
    constructor
    · rintro ⟨t, ht, hpx, hpy⟩
      exact ⟨t * c, mul_nonneg ht (le_of_lt hc_pos),
        by rw [hpx, h_origin]; ring_nf; rw [hcx]; ring,
        by rw [hpy, h_origin]; ring_nf; rw [hcy]; ring⟩
    · rintro ⟨t, ht, hpx, hpy⟩
      exact ⟨t / c, div_nonneg ht (le_of_lt hc_pos),
        by rw [hpx, ← h_origin, hcx, ← mul_assoc, div_mul_cancel₀ t (ne_of_gt hc_pos)],
        by rw [hpy, ← h_origin, hcy, ← mul_assoc, div_mul_cancel₀ t (ne_of_gt hc_pos)]⟩
  simp only [intersectionRayGraphSegmentsNumber, rayIntersectsSegment, h_eq]

/-- Single-HP HPI from a ray. -/
private def egp_opposite_rays_hpi (r : Ray) : HalfPlaneIntersection :=
  ⟨[⟨r.origin, ⟨-r.direction.y, r.direction.x⟩, egp_rot90_nonzero r.direction r.direction_nonzero⟩]⟩

/-- The boundary of this HPI = r1.toSet ∪ r2.toSet when rays are opposite. -/
private lemma egp_opposite_hpi_boundary_eq (r1 r2 : Ray) (h_origin : sameOrigin r1 r2)
    (h_opp : ∃ c : ℚ, c < 0 ∧ r1.direction.x = c * r2.direction.x ∧
                                 r1.direction.y = c * r2.direction.y) :
    (egp_opposite_rays_hpi r1).toBoundarySet = r1.toSet ∪ r2.toSet := by
  obtain ⟨c, hc_neg, hcx, hcy⟩ := h_opp
  unfold sameOrigin at h_origin
  ext q; simp only [Set.mem_union]; constructor
  · intro hq
    simp only [egp_opposite_rays_hpi, HalfPlaneIntersection.toBoundarySet, HalfPlane.toBoundarySet,
               HalfPlane.toExteriorSet, HalfPlane.dot, Set.mem_setOf_eq, List.mem_singleton] at hq
    obtain ⟨⟨_, rfl, hdot⟩, _⟩ := hq
    have heq : (q.x - r1.origin.x) * r1.direction.y =
               (q.y - r1.origin.y) * r1.direction.x := by ring_linarith
    have hd_or : r1.direction.x ≠ 0 ∨ r1.direction.y ≠ 0 := by
      by_contra h; push_neg at h
      exact r1.direction_nonzero ((Vector2D.mk.injEq _ _ _ _).mpr ⟨h.1, h.2⟩)
    suffices ∃ t : ℚ, q.x = r1.origin.x + t * r1.direction.x ∧
                       q.y = r1.origin.y + t * r1.direction.y by
      obtain ⟨t, htx, hty⟩ := this
      by_cases ht : 0 ≤ t
      · left; exact ⟨t, ht, htx, hty⟩
      · push_neg at ht; right
        refine ⟨t * c, le_of_lt (mul_pos_of_neg_of_neg ht hc_neg), ?_, ?_⟩
        · rw [htx, h_origin, hcx]; ring
        · rw [hty, h_origin, hcy]; ring
    rcases hd_or with hdx | hdy
    · refine ⟨(q.x - r1.origin.x) / r1.direction.x, ?_, ?_⟩
      · rw [div_mul_cancel₀ _ hdx]; ring
      · have h1 : (q.x - r1.origin.x) / r1.direction.x * r1.direction.y * r1.direction.x =
                   (q.y - r1.origin.y) * r1.direction.x := by
          calc _ = (q.x - r1.origin.x) / r1.direction.x * r1.direction.x * r1.direction.y := by ring
            _ = (q.x - r1.origin.x) * r1.direction.y := by rw [div_mul_cancel₀ _ hdx]
            _ = (q.y - r1.origin.y) * r1.direction.x := heq
        linarith [mul_right_cancel₀ hdx h1]
    · refine ⟨(q.y - r1.origin.y) / r1.direction.y, ?_, ?_⟩
      · have h1 : (q.y - r1.origin.y) / r1.direction.y * r1.direction.x * r1.direction.y =
                   (q.x - r1.origin.x) * r1.direction.y := by
          calc _ = (q.y - r1.origin.y) / r1.direction.y * r1.direction.y * r1.direction.x := by ring
            _ = (q.y - r1.origin.y) * r1.direction.x := by rw [div_mul_cancel₀ _ hdy]
            _ = (q.x - r1.origin.x) * r1.direction.y := heq.symm
        linarith [mul_right_cancel₀ hdy h1]
      · rw [div_mul_cancel₀ _ hdy]; ring
  · intro hq
    have hdot_eq : (q.x - r1.origin.x) * (-r1.direction.y) +
                   (q.y - r1.origin.y) * r1.direction.x = 0 := by
      rcases hq with ⟨t, _, hqx, hqy⟩ | ⟨t, _, hqx, hqy⟩
      · rw [hqx, hqy]; ring
      · rw [hqx, hqy, hcx, hcy, h_origin]; ring
    simp only [egp_opposite_rays_hpi, HalfPlaneIntersection.toBoundarySet, HalfPlane.toBoundarySet,
               HalfPlane.toExteriorSet, HalfPlane.dot, Set.mem_setOf_eq, List.mem_singleton]
    exact ⟨⟨_, rfl, hdot_eq⟩, fun _ ha => by subst ha; ring_linarith⟩

/-- The single-HP HPI has empty vertex set. -/
private lemma egp_opposite_hpi_segments_avoid_vertices (r : Ray) (segs : List LineSegment) :
    ∀ seg ∈ segs, ∀ q ∈ seg.toSet, q ∉ (egp_opposite_rays_hpi r).toVertexSet := by
  intro seg _ q _ hq
  simp only [egp_opposite_rays_hpi, HalfPlaneIntersection.toVertexSet, Set.mem_setOf_eq] at hq
  obtain ⟨hp1, hp1_mem, hp2, hp2_mem, hne, _, _⟩ := hq
  simp only [List.mem_singleton] at hp1_mem hp2_mem
  exact hne (hp1_mem.trans hp2_mem.symm)

/-- Total crossings of single-HP HPI = sum of r1 and r2 crossings.
    Works for any segment list with appropriate endpoint conditions. -/
private lemma egp_segs_opp_total_eq (r1 r2 : Ray) (segs : List LineSegment)
    (h_origin : sameOrigin r1 r2)
    (h_opp : ∃ c : ℚ, c < 0 ∧ r1.direction.x = c * r2.direction.x ∧
                                 r1.direction.y = c * r2.direction.y)
    (h_ep_not_bnd : ∀ seg ∈ segs,
        seg.p1 ∉ (egp_opposite_rays_hpi r1).toBoundarySet ∧
        seg.p2 ∉ (egp_opposite_rays_hpi r1).toBoundarySet)
    (h_origin_avoids : ∀ seg ∈ segs, pointAvoidsSegment r1.origin seg) :
    (segs.map fun seg => segCrossingCount seg (egp_opposite_rays_hpi r1)).sum =
    segs.countP (fun seg => decide (rayIntersectsSegment r1 seg)) +
    segs.countP (fun seg => decide (rayIntersectsSegment r2 seg)) := by
  obtain ⟨c, hc_neg, hcx, hcy⟩ := h_opp
  unfold sameOrigin at h_origin
  set hpi := egp_opposite_rays_hpi r1 with hpi_def
  set hp : HalfPlane := ⟨r1.origin, ⟨-r1.direction.y, r1.direction.x⟩,
    egp_rot90_nonzero r1.direction r1.direction_nonzero⟩ with hp_def
  have h_bnd := egp_opposite_hpi_boundary_eq r1 r2 h_origin ⟨c, hc_neg, hcx, hcy⟩
  have h_hpi_hp : hpi.toBoundarySet = hp.toBoundarySet := by
    simp only [hpi_def, egp_opposite_rays_hpi, hp_def,
               HalfPlaneIntersection.toBoundarySet, HalfPlane.toBoundarySet,
               HalfPlane.toExteriorSet, HalfPlane.dot, Set.mem_setOf_eq,
               List.mem_singleton]
    ext q; constructor
    · rintro ⟨⟨_, rfl, h⟩, _⟩; exact h
    · intro h; exact ⟨⟨_, rfl, h⟩, fun _ ha => by
        subst ha
        dsimp only [HalfPlane.toExteriorSet, HalfPlane.dot, Set.mem_setOf_eq]
        push_neg
        dsimp only [HalfPlane.toBoundarySet, HalfPlane.dot, Set.mem_setOf_eq] at h
        linarith⟩
  suffices h_per : ∀ seg ∈ segs,
      segCrossingCount seg hpi =
        (if decide (rayIntersectsSegment r1 seg) then 1 else 0) +
        (if decide (rayIntersectsSegment r2 seg) then 1 else 0) by
    have h_map : (segs.map fun seg => segCrossingCount seg hpi) =
        segs.map fun seg =>
          (if decide (rayIntersectsSegment r1 seg) then 1 else 0) +
          (if decide (rayIntersectsSegment r2 seg) then 1 else 0) :=
      List.map_congr_left h_per
    rw [h_map, egp_sum_map_add]
    rw [egp_countP_eq_map_sum, egp_countP_eq_map_sum]
  intro seg hseg
  have ⟨h_p1_not_bnd, h_p2_not_bnd⟩ := h_ep_not_bnd seg hseg
  have hp_dot_p1 : hp.dot seg.p1 ≠ 0 := by
    intro hdot
    apply h_p1_not_bnd
    rw [h_hpi_hp]; exact hdot
  have hp_dot_p2 : hp.dot seg.p2 ≠ 0 := by
    intro hdot
    apply h_p2_not_bnd
    rw [h_hpi_hp]; exact hdot
  have h_sub := hp.boundary_segment_subsingleton seg (Or.inl hp_dot_p1)
  have h_cross_eq : seg.boundaryCrossings hpi = seg.toSet ∩ hp.toBoundarySet := by
    unfold LineSegment.boundaryCrossings; rw [h_hpi_hp]
  have h_sub2 : (seg.boundaryCrossings hpi).Subsingleton := by
    rw [h_cross_eq]; exact h_sub
  have h_fin : (seg.boundaryCrossings hpi).Finite := h_sub2.finite
  have h_card_le := egp_subsingleton_card _ h_fin h_sub2
  have h_cc : segCrossingCount seg hpi = h_fin.toFinset.card := by
    simp [segCrossingCount, dif_pos h_fin]
  have h_O_avoids := h_origin_avoids seg hseg
  unfold pointAvoidsSegment at h_O_avoids
  have h_disjoint : ∀ q, q ∈ seg.toSet → q ∈ r1.toSet → q ∈ r2.toSet → False := by
    intro q hq_seg hq_r1 hq_r2
    obtain ⟨t1, ht1, ht1x, ht1y⟩ := hq_r1
    obtain ⟨t2, ht2, ht2x, ht2y⟩ := hq_r2
    have heqx : t1 * r1.direction.x = t2 * r2.direction.x := by
      have := ht1x; rw [ht2x, h_origin] at this; linarith
    have heqy : t1 * r1.direction.y = t2 * r2.direction.y := by
      have := ht1y; rw [ht2y, h_origin] at this; linarith
    have hd2_or : r2.direction.x ≠ 0 ∨ r2.direction.y ≠ 0 := by
      by_contra h; push_neg at h
      exact r2.direction_nonzero ((Vector2D.mk.injEq _ _ _ _).mpr ⟨h.1, h.2⟩)
    have h_tc : t1 * c = t2 := by
      rcases hd2_or with hdx | hdy
      · have : t1 * (c * r2.direction.x) = t2 * r2.direction.x := by rw [← hcx]; linarith [heqx]
        have : (t1 * c - t2) * r2.direction.x = 0 := by linarith
        have := (mul_eq_zero.mp this).resolve_right hdx; linarith
      · have : t1 * (c * r2.direction.y) = t2 * r2.direction.y := by rw [← hcy]; linarith [heqy]
        have : (t1 * c - t2) * r2.direction.y = 0 := by linarith
        have := (mul_eq_zero.mp this).resolve_right hdy; linarith
    have ht1_zero : t1 = 0 := by nlinarith
    have ht2_zero : t2 = 0 := by nlinarith [h_tc, ht1_zero]
    have hq_origin : q = r1.origin := (Vector2D.mk.injEq _ _ _ _).mpr
      ⟨by rw [ht1x]; simp [ht1_zero], by rw [ht1y]; simp [ht1_zero]⟩
    exact h_O_avoids (hq_origin ▸ hq_seg)
  have h_cross_union : seg.boundaryCrossings hpi = seg.toSet ∩ (r1.toSet ∪ r2.toSet) := by
    unfold LineSegment.boundaryCrossings; rw [h_bnd]
  have h_01 : h_fin.toFinset.card = 0 ∨ h_fin.toFinset.card = 1 := by omega
  rcases h_01 with hcard | hcard
  · rw [h_cc, hcard]
    have h_empty : seg.boundaryCrossings hpi = ∅ :=
      (Set.Finite.toFinset_eq_empty (h := h_fin)).mp (Finset.card_eq_zero.mp hcard)
    have h_r1_no : ¬rayIntersectsSegment r1 seg := by
      intro ⟨q, hq1, hq2⟩
      have : q ∈ seg.boundaryCrossings hpi := by rw [h_cross_union]; exact ⟨hq2, Or.inl hq1⟩
      rw [h_empty] at this; exact this
    have h_r2_no : ¬rayIntersectsSegment r2 seg := by
      intro ⟨q, hq1, hq2⟩
      have : q ∈ seg.boundaryCrossings hpi := by rw [h_cross_union]; exact ⟨hq2, Or.inr hq1⟩
      rw [h_empty] at this; exact this
    simp [h_r1_no, h_r2_no]
  · rw [h_cc, hcard]
    have h_ne : (seg.boundaryCrossings hpi).Nonempty :=
      h_fin.toFinset_nonempty.mp (Finset.card_pos.mp (by omega))
    rw [h_cross_union] at h_ne
    obtain ⟨q, hq_seg, hq_ray⟩ := h_ne
    rcases hq_ray with hq_r1 | hq_r2
    · have h_r1_yes : rayIntersectsSegment r1 seg := ⟨q, hq_r1, hq_seg⟩
      have h_r2_no : ¬rayIntersectsSegment r2 seg := by
        intro ⟨q', hq'_r2, hq'_seg⟩
        have hq'_cross : q' ∈ seg.boundaryCrossings hpi := by
          rw [h_cross_union]; exact ⟨hq'_seg, Or.inr hq'_r2⟩
        have hq_cross : q ∈ seg.boundaryCrossings hpi := by
          rw [h_cross_union]; exact ⟨hq_seg, Or.inl hq_r1⟩
        have := h_sub2 hq_cross hq'_cross
        exact h_disjoint q hq_seg hq_r1 (this ▸ hq'_r2)
      simp [h_r1_yes, h_r2_no]
    · have h_r2_yes : rayIntersectsSegment r2 seg := ⟨q, hq_r2, hq_seg⟩
      have h_r1_no : ¬rayIntersectsSegment r1 seg := by
        intro ⟨q', hq'_r1, hq'_seg⟩
        have hq'_cross : q' ∈ seg.boundaryCrossings hpi := by
          rw [h_cross_union]; exact ⟨hq'_seg, Or.inl hq'_r1⟩
        have hq_cross : q ∈ seg.boundaryCrossings hpi := by
          rw [h_cross_union]; exact ⟨hq_seg, Or.inr hq_r2⟩
        have := h_sub2 hq_cross hq'_cross
        exact h_disjoint q hq_seg (this ▸ hq'_r1) hq_r2
      simp [h_r1_no, h_r2_yes]

/-- Choose n1 perpendicular to d1, pointing toward d2's side. -/
private def egp_choose_n1 (d1 d2 : Vector2D) : Vector2D :=
  if egp_cross d1 d2 > 0 then ⟨-d1.y, d1.x⟩ else ⟨d1.y, -d1.x⟩

/-- Choose n2 perpendicular to d2, pointing toward d1's side. -/
private def egp_choose_n2 (d1 d2 : Vector2D) : Vector2D :=
  if egp_cross d1 d2 > 0 then ⟨d2.y, -d2.x⟩ else ⟨-d2.y, d2.x⟩

private lemma egp_choose_n1_nonzero (d1 d2 : Vector2D) (hd1 : d1 ≠ ⟨0, 0⟩) :
    egp_choose_n1 d1 d2 ≠ ⟨0, 0⟩ := by
  unfold egp_choose_n1; split <;> intro h
  · apply hd1; have hx : (-d1.y : ℚ) = 0 := congrArg Vector2D.x h
    have hy : d1.x = 0 := congrArg Vector2D.y h
    simp at hx; exact (Vector2D.mk.injEq _ _ _ _).mpr ⟨hy, hx⟩
  · apply hd1; have hx : d1.y = 0 := congrArg Vector2D.x h
    have hy : (-d1.x : ℚ) = 0 := congrArg Vector2D.y h
    simp at hy; exact (Vector2D.mk.injEq _ _ _ _).mpr ⟨hy, hx⟩

private lemma egp_choose_n2_nonzero (d1 d2 : Vector2D) (hd2 : d2 ≠ ⟨0, 0⟩) :
    egp_choose_n2 d1 d2 ≠ ⟨0, 0⟩ := by
  unfold egp_choose_n2; split <;> intro h
  · apply hd2; have hx : d2.y = 0 := congrArg Vector2D.x h
    have hy : (-d2.x : ℚ) = 0 := congrArg Vector2D.y h
    simp at hy; exact (Vector2D.mk.injEq _ _ _ _).mpr ⟨hy, hx⟩
  · apply hd2; have hx : (-d2.y : ℚ) = 0 := congrArg Vector2D.x h
    have hy : d2.x = 0 := congrArg Vector2D.y h
    simp at hx; exact (Vector2D.mk.injEq _ _ _ _).mpr ⟨hy, hx⟩

/-- Two-HP HPI for non-collinear rays. -/
private noncomputable def egp_nc_rays_hpi (r1 r2 : Ray) (_h_origin : sameOrigin r1 r2)
    (_h_nc : egp_cross r1.direction r2.direction ≠ 0) : HalfPlaneIntersection :=
  ⟨[⟨r1.origin, egp_choose_n1 r1.direction r2.direction,
     egp_choose_n1_nonzero r1.direction r2.direction r1.direction_nonzero⟩,
    ⟨r1.origin, egp_choose_n2 r1.direction r2.direction,
     egp_choose_n2_nonzero r1.direction r2.direction r2.direction_nonzero⟩]⟩

/-- Extract line parameter from dot-product condition. -/
private lemma egp_extract_line_param (d O q : Vector2D) (hd : d ≠ ⟨0, 0⟩)
    (h : (q.x - O.x) * d.y = (q.y - O.y) * d.x) :
    ∃ t : ℚ, q.x = O.x + t * d.x ∧ q.y = O.y + t * d.y := by
  have hd_or : d.x ≠ 0 ∨ d.y ≠ 0 := by
    by_contra hc; push_neg at hc
    exact hd ((Vector2D.mk.injEq _ _ _ _).mpr ⟨hc.1, hc.2⟩)
  rcases hd_or with hdx | hdy
  · refine ⟨(q.x - O.x) / d.x, ?_, ?_⟩
    · rw [div_mul_cancel₀ _ hdx]; ring
    · have h2 : (q.x - O.x) / d.x * d.y * d.x = (q.y - O.y) * d.x := by
        calc _ = (q.x - O.x) / d.x * d.x * d.y := by ring
          _ = (q.x - O.x) * d.y := by rw [div_mul_cancel₀ _ hdx]
          _ = (q.y - O.y) * d.x := h
      linarith [mul_right_cancel₀ hdx h2]
  · refine ⟨(q.y - O.y) / d.y, ?_, ?_⟩
    · have h2 : (q.y - O.y) / d.y * d.x * d.y = (q.x - O.x) * d.y := by
        calc _ = (q.y - O.y) / d.y * d.y * d.x := by ring
          _ = (q.y - O.y) * d.x := by rw [div_mul_cancel₀ _ hdy]
          _ = (q.x - O.x) * d.y := h.symm
      linarith [mul_right_cancel₀ hdy h2]
    · rw [div_mul_cancel₀ _ hdy]; ring

/-- The 2-HP HPI boundary equals r1.toSet ∪ r2.toSet. -/
private lemma egp_nc_hpi_boundary_eq (r1 r2 : Ray) (h_origin : sameOrigin r1 r2)
    (h_nc : egp_cross r1.direction r2.direction ≠ 0) :
    (egp_nc_rays_hpi r1 r2 h_origin h_nc).toBoundarySet = r1.toSet ∪ r2.toSet := by
  unfold sameOrigin at h_origin
  set d1 := r1.direction; set d2 := r2.direction; set O := r1.origin
  set n1 := egp_choose_n1 d1 d2; set n2 := egp_choose_n2 d1 d2
  have h_d1_n1 : ∀ t : ℚ, (t * d1.x) * n1.x + (t * d1.y) * n1.y = 0 := by
    intro t; simp only [n1, egp_choose_n1]; split <;> ring
  have h_d2_n2 : ∀ t : ℚ, (t * d2.x) * n2.x + (t * d2.y) * n2.y = 0 := by
    intro t; simp only [n2, egp_choose_n2]; split <;> ring
  set κ : ℚ := if egp_cross d1 d2 > 0 then egp_cross d1 d2 else -(egp_cross d1 d2)
  have hκ_pos : κ > 0 := by
    simp only [κ]; split
    · assumption
    · rename_i h; push_neg at h; linarith [lt_of_le_of_ne h h_nc]
  have h_d1_n2 : ∀ t : ℚ, (t * d1.x) * n2.x + (t * d1.y) * n2.y = t * κ := by
    intro t; simp only [n2, egp_choose_n2, κ, egp_cross]; split <;> ring
  have h_d2_n1 : ∀ t : ℚ, (t * d2.x) * n1.x + (t * d2.y) * n1.y = t * κ := by
    intro t; simp only [n1, egp_choose_n1, κ, egp_cross]; split <;> ring
  have h_perp1 : ∀ q : Vector2D, (q.x - O.x) * n1.x + (q.y - O.y) * n1.y = 0 →
      (q.x - O.x) * d1.y = (q.y - O.y) * d1.x := by
    intro q hq; simp only [n1, egp_choose_n1] at hq; split at hq <;> ring_linarith
  have h_perp2 : ∀ q : Vector2D, (q.x - O.x) * n2.x + (q.y - O.y) * n2.y = 0 →
      (q.x - O.x) * d2.y = (q.y - O.y) * d2.x := by
    intro q hq; simp only [n2, egp_choose_n2] at hq; split at hq <;> ring_linarith
  ext q; simp only [Set.mem_union]; constructor
  · intro hq
    simp only [egp_nc_rays_hpi, HalfPlaneIntersection.toBoundarySet, HalfPlane.toBoundarySet,
      HalfPlane.toExteriorSet, HalfPlane.dot, Set.mem_setOf_eq,
      List.mem_cons, (List.not_mem_nil _), or_false] at hq
    obtain ⟨⟨hp, hp_mem, hdot⟩, h_not_ext⟩ := hq
    rcases hp_mem with rfl | rfl
    · have h_line := h_perp1 q hdot
      obtain ⟨t, htx, hty⟩ := egp_extract_line_param d1 O q r1.direction_nonzero h_line
      have h_hp2 := h_not_ext _ (Or.inr rfl)
      push_neg at h_hp2
      have h_dot2 : (q.x - O.x) * n2.x + (q.y - O.y) * n2.y = t * κ := by
        rw [show (q.x - O.x) = t * d1.x from by linarith [htx],
            show (q.y - O.y) = t * d1.y from by linarith [hty]]
        exact h_d1_n2 t
      have ht_nn : 0 ≤ t := by nlinarith [h_hp2, h_dot2, hκ_pos]
      left; exact ⟨t, ht_nn, htx, hty⟩
    · have h_line := h_perp2 q hdot
      obtain ⟨t, htx, hty⟩ := egp_extract_line_param d2 O q r2.direction_nonzero h_line
      have h_hp1 := h_not_ext _ (Or.inl rfl)
      push_neg at h_hp1
      have h_dot1 : (q.x - O.x) * n1.x + (q.y - O.y) * n1.y = t * κ := by
        rw [show (q.x - O.x) = t * d2.x from by linarith [htx],
            show (q.y - O.y) = t * d2.y from by linarith [hty]]
        exact h_d2_n1 t
      have ht_nn : 0 ≤ t := by nlinarith [h_hp1, h_dot1, hκ_pos]
      right; exact ⟨t, ht_nn, by rw [htx, h_origin], by rw [hty, h_origin]⟩
  · intro hq
    simp only [egp_nc_rays_hpi, HalfPlaneIntersection.toBoundarySet, HalfPlane.toBoundarySet,
      HalfPlane.toExteriorSet, HalfPlane.dot, Set.mem_setOf_eq,
      List.mem_cons, (List.not_mem_nil _), or_false]
    rcases hq with ⟨t, ht, htx, hty⟩ | ⟨t, ht, htx, hty⟩
    · constructor
      · exact ⟨_, Or.inl rfl, by rw [htx, hty]; simp only; linarith [h_d1_n1 t]⟩
      · intro hp hp_mem
        rcases hp_mem with rfl | rfl
        · intro h_neg; rw [htx, hty] at h_neg; simp only at h_neg; linarith [h_d1_n1 t]
        · intro h_neg; rw [htx, hty] at h_neg; simp only at h_neg; nlinarith [h_d1_n2 t]
    · have h_oeq : r1.origin = r2.origin := h_origin
      constructor
      · exact ⟨_, Or.inr rfl, by rw [htx, hty]; simp only; rw [h_oeq]; linarith [h_d2_n2 t]⟩
      · intro hp hp_mem
        rcases hp_mem with rfl | rfl
        · intro h_neg; rw [htx, hty] at h_neg; simp only at h_neg; rw [h_oeq] at h_neg; nlinarith [h_d2_n1 t]
        · intro h_neg; rw [htx, hty] at h_neg; simp only at h_neg; rw [h_oeq] at h_neg; linarith [h_d2_n2 t]

/-- Graph segments avoid the 2-HP HPI vertices (= {origin}). -/
private lemma egp_nc_segs_avoid_vertices (r1 r2 : Ray) (segs : List LineSegment)
    (h_origin : sameOrigin r1 r2) (h_nc : egp_cross r1.direction r2.direction ≠ 0)
    (h_origin_avoids : ∀ seg ∈ segs, pointAvoidsSegment r1.origin seg) :
    ∀ seg ∈ segs, ∀ q ∈ seg.toSet,
      q ∉ (egp_nc_rays_hpi r1 r2 h_origin h_nc).toVertexSet := by
  intro seg hseg q hq_seg hq_vert
  simp only [egp_nc_rays_hpi, HalfPlaneIntersection.toVertexSet, HalfPlane.toBoundarySet,
    HalfPlane.dot, Set.mem_setOf_eq, List.mem_cons] at hq_vert
  obtain ⟨hp1, hp1_mem, hp2, hp2_mem, hne, hdot1, hdot2⟩ := hq_vert
  unfold sameOrigin at h_origin
  have h_det : (egp_choose_n1 r1.direction r2.direction).x *
               (egp_choose_n2 r1.direction r2.direction).y -
               (egp_choose_n1 r1.direction r2.direction).y *
               (egp_choose_n2 r1.direction r2.direction).x ≠ 0 := by
    unfold egp_choose_n1 egp_choose_n2
    split <;> (dsimp; intro h; apply h_nc; unfold egp_cross; linarith)
  have h_both :
      (q.x - r1.origin.x) * (egp_choose_n1 r1.direction r2.direction).x +
      (q.y - r1.origin.y) * (egp_choose_n1 r1.direction r2.direction).y = 0 ∧
      (q.x - r1.origin.x) * (egp_choose_n2 r1.direction r2.direction).x +
      (q.y - r1.origin.y) * (egp_choose_n2 r1.direction r2.direction).y = 0 := by
    rcases hp1_mem with rfl | rfl | h1
    · rcases hp2_mem with rfl | rfl | h2
      · exact absurd rfl hne
      · exact ⟨hdot1, hdot2⟩
      · simp at h2
    · rcases hp2_mem with rfl | rfl | h2
      · exact ⟨hdot2, hdot1⟩
      · exact absurd rfl hne
      · simp at h2
    · simp at h1
  obtain ⟨eq1, eq2⟩ := h_both
  set n1 := egp_choose_n1 r1.direction r2.direction
  set n2 := egp_choose_n2 r1.direction r2.direction
  have hdx : q.x - r1.origin.x = 0 := by
    have := calc (q.x - r1.origin.x) * (n1.x * n2.y - n1.y * n2.x)
        = n2.y * ((q.x - r1.origin.x) * n1.x + (q.y - r1.origin.y) * n1.y) -
          n1.y * ((q.x - r1.origin.x) * n2.x + (q.y - r1.origin.y) * n2.y) := by ring
      _ = n2.y * 0 - n1.y * 0 := by rw [eq1, eq2]
      _ = 0 := by ring
    exact (mul_eq_zero.mp this).resolve_right h_det
  have hdy : q.y - r1.origin.y = 0 := by
    have := calc (q.y - r1.origin.y) * (n1.x * n2.y - n1.y * n2.x)
        = n1.x * ((q.x - r1.origin.x) * n2.x + (q.y - r1.origin.y) * n2.y) -
          n2.x * ((q.x - r1.origin.x) * n1.x + (q.y - r1.origin.y) * n1.y) := by ring
      _ = n1.x * 0 - n2.x * 0 := by rw [eq1, eq2]
      _ = 0 := by ring
    exact (mul_eq_zero.mp this).resolve_right h_det
  have hq_eq : q = r1.origin :=
    (Vector2D.mk.injEq _ _ _ _).mpr ⟨by linarith, by linarith⟩
  exact h_origin_avoids seg hseg (hq_eq ▸ hq_seg)

-- Total crossings of 2-HP HPI = r1 count + r2 count for non-collinear rays.
-- Works for any segment list with appropriate endpoint conditions.
set_option maxHeartbeats 800000 in
private lemma egp_segs_nc_total_eq (r1 r2 : Ray) (segs : List LineSegment)
    (h_origin : sameOrigin r1 r2) (h_nc : egp_cross r1.direction r2.direction ≠ 0)
    (h_ep_not_bnd : ∀ seg ∈ segs,
        seg.p1 ∉ (egp_nc_rays_hpi r1 r2 h_origin h_nc).toBoundarySet ∧
        seg.p2 ∉ (egp_nc_rays_hpi r1 r2 h_origin h_nc).toBoundarySet)
    (h_seg_avoid_vert : ∀ seg ∈ segs, ∀ q ∈ seg.toSet,
        q ∉ (egp_nc_rays_hpi r1 r2 h_origin h_nc).toVertexSet)
    (h_origin_avoids : ∀ seg ∈ segs, pointAvoidsSegment r1.origin seg) :
    (segs.map fun seg => segCrossingCount seg (egp_nc_rays_hpi r1 r2 h_origin h_nc)).sum =
    segs.countP (fun seg => decide (rayIntersectsSegment r1 seg)) +
    segs.countP (fun seg => decide (rayIntersectsSegment r2 seg)) := by
  have h_oeq : r1.origin = r2.origin := h_origin
  set hpi := egp_nc_rays_hpi r1 r2 h_origin h_nc with hpi_def
  set d1 := r1.direction; set d2 := r2.direction; set O := r1.origin
  set n1 := egp_choose_n1 d1 d2; set n2 := egp_choose_n2 d1 d2
  have h_bnd := egp_nc_hpi_boundary_eq r1 r2 h_origin h_nc
  have h_d1_n1 : ∀ t : ℚ, (t * d1.x) * n1.x + (t * d1.y) * n1.y = 0 := by
    intro t; simp only [n1, egp_choose_n1]; split <;> ring
  have h_d2_n2 : ∀ t : ℚ, (t * d2.x) * n2.x + (t * d2.y) * n2.y = 0 := by
    intro t; simp only [n2, egp_choose_n2]; split <;> ring
  set κ : ℚ := if egp_cross d1 d2 > 0 then egp_cross d1 d2 else -(egp_cross d1 d2)
  have hκ_pos : κ > 0 := by
    simp only [κ]; split
    · assumption
    · rename_i h; push_neg at h; linarith [lt_of_le_of_ne h h_nc]
  have h_d1_n2 : ∀ t : ℚ, (t * d1.x) * n2.x + (t * d1.y) * n2.y = t * κ := by
    intro t; simp only [n2, egp_choose_n2, κ, egp_cross]; split <;> ring
  have h_d2_n1 : ∀ t : ℚ, (t * d2.x) * n1.x + (t * d2.y) * n1.y = t * κ := by
    intro t; simp only [n1, egp_choose_n1, κ, egp_cross]; split <;> ring
  suffices h_per : ∀ seg ∈ segs,
      segCrossingCount seg hpi =
        (if decide (rayIntersectsSegment r1 seg) then 1 else 0) +
        (if decide (rayIntersectsSegment r2 seg) then 1 else 0) by
    have h_map : (segs.map fun seg => segCrossingCount seg hpi) =
        segs.map fun seg =>
          (if decide (rayIntersectsSegment r1 seg) then 1 else 0) +
          (if decide (rayIntersectsSegment r2 seg) then 1 else 0) :=
      List.map_congr_left h_per
    rw [h_map, egp_sum_map_add, egp_countP_eq_map_sum, egp_countP_eq_map_sum]
  intro seg hseg
  have ⟨h_p1_not_bnd, h_p2_not_bnd⟩ := h_ep_not_bnd seg hseg
  have h_seg_avoids := h_seg_avoid_vert seg hseg
  have h_fin : (seg.boundaryCrossings hpi).Finite :=
    HalfPlaneIntersection.boundaryCrossings_finite hpi seg h_p1_not_bnd h_p2_not_bnd h_seg_avoids
  have h_cc : segCrossingCount seg hpi = h_fin.toFinset.card := by
    simp [segCrossingCount, dif_pos h_fin]
  have h_cross_union : seg.boundaryCrossings hpi = seg.toSet ∩ (r1.toSet ∪ r2.toSet) := by
    unfold LineSegment.boundaryCrossings; rw [h_bnd]
  have h_O_avoids := h_origin_avoids seg hseg
  unfold pointAvoidsSegment at h_O_avoids
  have h_disjoint : ∀ q, q ∈ seg.toSet → q ∈ r1.toSet → q ∈ r2.toSet → False := by
    intro q hq_seg hq_r1 hq_r2
    obtain ⟨t1, ht1, ht1x, ht1y⟩ := hq_r1
    obtain ⟨t2, ht2, ht2x, ht2y⟩ := hq_r2
    have h_ox : r1.origin.x = r2.origin.x := congrArg Vector2D.x h_oeq
    have h_oy : r1.origin.y = r2.origin.y := congrArg Vector2D.y h_oeq
    have heqx : t1 * d1.x = t2 * d2.x := by linarith
    have heqy : t1 * d1.y = t2 * d2.y := by linarith
    have h_tc : t1 * egp_cross d1 d2 = 0 := by
      have hm1 : (t1 * d1.x) * d2.y = (t2 * d2.x) * d2.y := congr_arg (· * d2.y) heqx
      have hm2 : (t1 * d1.y) * d2.x = (t2 * d2.y) * d2.x := congr_arg (· * d2.x) heqy
      simp only [egp_cross]; ring_nf at hm1 hm2 ⊢; linarith
    have ht1_zero : t1 = 0 := (mul_eq_zero.mp h_tc).resolve_right h_nc
    have ht2_zero : t2 = 0 := by
      have hd2_or : d2.x ≠ 0 ∨ d2.y ≠ 0 := by
        by_contra h; push_neg at h
        exact r2.direction_nonzero ((Vector2D.mk.injEq _ _ _ _).mpr ⟨h.1, h.2⟩)
      have h0x : t1 * d1.x = 0 := by rw [ht1_zero]; ring
      have h0y : t1 * d1.y = 0 := by rw [ht1_zero]; ring
      have h1 : t2 * d2.x = 0 := by linarith
      have h2 : t2 * d2.y = 0 := by linarith
      rcases hd2_or with hdx | hdy
      · exact (mul_eq_zero.mp h1).resolve_right hdx
      · exact (mul_eq_zero.mp h2).resolve_right hdy
    rw [ht1_zero] at ht1x ht1y
    simp only [zero_mul, add_zero] at ht1x ht1y
    rw [show q = O from (Vector2D.mk.injEq _ _ _ _).mpr ⟨ht1x, ht1y⟩] at hq_seg
    exact h_O_avoids hq_seg
  -- seg ∩ r1 is subsingleton
  have h_seg_r1_sub : (seg.toSet ∩ r1.toSet).Subsingleton := by
    let hp1' : HalfPlane := ⟨O, n1, egp_choose_n1_nonzero d1 d2 r1.direction_nonzero⟩
    have h_r1_bnd : r1.toSet ⊆ hp1'.toBoundarySet := by
      intro q ⟨t, _, htx, hty⟩
      show (q.x - O.x) * n1.x + (q.y - O.y) * n1.y = 0
      rw [show q.x - O.x = t * d1.x from by linarith,
          show q.y - O.y = t * d1.y from by linarith]
      exact h_d1_n1 t
    by_cases h_nd1 : hp1'.dot seg.p1 ≠ 0 ∨ hp1'.dot seg.p2 ≠ 0
    · intro a ha b hb
      exact hp1'.boundary_segment_subsingleton seg h_nd1
        ⟨ha.1, h_r1_bnd ha.2⟩ ⟨hb.1, h_r1_bnd hb.2⟩
    · push_neg at h_nd1
      intro q1 ⟨hq1_seg, hq1_r1⟩ q2 _; exfalso
      obtain ⟨t, ht, htx, hty⟩ := hq1_r1
      have h_tpos : 0 < t := by
        rcases eq_or_lt_of_le ht with rfl | h
        · exfalso; apply h_O_avoids
          simp only [zero_mul, add_zero] at htx hty
          rw [show q1 = O from (Vector2D.mk.injEq _ _ _ _).mpr ⟨htx, hty⟩] at hq1_seg
          exact hq1_seg
        · exact h
      have h_dot_pos : (q1.x - O.x) * n2.x + (q1.y - O.y) * n2.y > 0 := by
        rw [show q1.x - O.x = t * d1.x from by linarith,
            show q1.y - O.y = t * d1.y from by linarith]
        linarith [h_d1_n2 t, mul_pos h_tpos hκ_pos]
      have h_hp2_p1 : (seg.p1.x - O.x) * n2.x + (seg.p1.y - O.y) * n2.y < 0 := by
        by_contra hge; push_neg at hge
        have h_line : (seg.p1.x - O.x) * d1.y = (seg.p1.y - O.y) * d1.x := by
          have h0 : (seg.p1.x - O.x) * n1.x + (seg.p1.y - O.y) * n1.y = 0 := h_nd1.1
          simp only [n1, egp_choose_n1] at h0; split at h0 <;> ring_linarith
        obtain ⟨tp, htpx, htpy⟩ := egp_extract_line_param d1 O seg.p1 r1.direction_nonzero h_line
        have h_tpk : tp * κ ≥ 0 := by
          have : (seg.p1.x - O.x) * n2.x + (seg.p1.y - O.y) * n2.y = tp * κ := by
            rw [show seg.p1.x - O.x = tp * d1.x from by linarith,
                show seg.p1.y - O.y = tp * d1.y from by linarith]; exact h_d1_n2 tp
          linarith
        have h_tp_nn : tp ≥ 0 := by
          by_contra h_neg; push_neg at h_neg
          exact absurd h_tpk (not_le.mpr (mul_neg_of_neg_of_pos h_neg hκ_pos))
        exact absurd (show seg.p1 ∈ hpi.toBoundarySet by
          rw [h_bnd]; exact Set.mem_union_left _ ⟨tp, h_tp_nn, htpx, htpy⟩) h_p1_not_bnd
      have h_hp2_p2 : (seg.p2.x - O.x) * n2.x + (seg.p2.y - O.y) * n2.y < 0 := by
        by_contra hge; push_neg at hge
        have h_line : (seg.p2.x - O.x) * d1.y = (seg.p2.y - O.y) * d1.x := by
          have h0 : (seg.p2.x - O.x) * n1.x + (seg.p2.y - O.y) * n1.y = 0 := h_nd1.2
          simp only [n1, egp_choose_n1] at h0; split at h0 <;> ring_linarith
        obtain ⟨tp, htpx, htpy⟩ := egp_extract_line_param d1 O seg.p2 r1.direction_nonzero h_line
        have h_tpk : tp * κ ≥ 0 := by
          have : (seg.p2.x - O.x) * n2.x + (seg.p2.y - O.y) * n2.y = tp * κ := by
            rw [show seg.p2.x - O.x = tp * d1.x from by linarith,
                show seg.p2.y - O.y = tp * d1.y from by linarith]; exact h_d1_n2 tp
          linarith
        have h_tp_nn : tp ≥ 0 := by
          by_contra h_neg; push_neg at h_neg
          exact absurd h_tpk (not_le.mpr (mul_neg_of_neg_of_pos h_neg hκ_pos))
        exact absurd (show seg.p2 ∈ hpi.toBoundarySet by
          rw [h_bnd]; exact Set.mem_union_left _ ⟨tp, h_tp_nn, htpx, htpy⟩) h_p2_not_bnd
      obtain ⟨s, hs0, hs1, hsx, hsy⟩ := hq1_seg
      have h_dot_seg : (q1.x - O.x) * n2.x + (q1.y - O.y) * n2.y =
        (1 - s) * ((seg.p1.x - O.x) * n2.x + (seg.p1.y - O.y) * n2.y) +
        s * ((seg.p2.x - O.x) * n2.x + (seg.p2.y - O.y) * n2.y) := by
        rw [show q1.x - O.x = (1 - s) * (seg.p1.x - O.x) + s * (seg.p2.x - O.x) from by linarith,
            show q1.y - O.y = (1 - s) * (seg.p1.y - O.y) + s * (seg.p2.y - O.y) from by linarith]
        ring
      rcases eq_or_lt_of_le hs0 with rfl | hs_pos
      · simp at h_dot_seg; linarith
      · linarith [mul_neg_of_pos_of_neg hs_pos h_hp2_p2,
          mul_nonpos_of_nonneg_of_nonpos (show (1 : ℚ) - s ≥ 0 by linarith) (le_of_lt h_hp2_p1)]
  -- seg ∩ r2 is subsingleton
  have h_seg_r2_sub : (seg.toSet ∩ r2.toSet).Subsingleton := by
    let hp2' : HalfPlane := ⟨O, n2, egp_choose_n2_nonzero d1 d2 r2.direction_nonzero⟩
    have h_r2_bnd : r2.toSet ⊆ hp2'.toBoundarySet := by
      intro q ⟨t, _, htx, hty⟩
      show (q.x - O.x) * n2.x + (q.y - O.y) * n2.y = 0
      rw [show q.x - O.x = t * d2.x from by linarith [congrArg Vector2D.x h_oeq],
          show q.y - O.y = t * d2.y from by linarith [congrArg Vector2D.y h_oeq]]
      exact h_d2_n2 t
    by_cases h_nd2 : hp2'.dot seg.p1 ≠ 0 ∨ hp2'.dot seg.p2 ≠ 0
    · intro a ha b hb
      exact hp2'.boundary_segment_subsingleton seg h_nd2
        ⟨ha.1, h_r2_bnd ha.2⟩ ⟨hb.1, h_r2_bnd hb.2⟩
    · push_neg at h_nd2
      intro q1 ⟨hq1_seg, hq1_r2⟩ q2 _; exfalso
      obtain ⟨t, ht, htx, hty⟩ := hq1_r2
      have h_tpos : 0 < t := by
        rcases eq_or_lt_of_le ht with rfl | h
        · exfalso; apply h_O_avoids
          simp only [zero_mul, add_zero] at htx hty
          have hqx : q1.x = O.x := by linarith [congrArg Vector2D.x h_oeq]
          have hqy : q1.y = O.y := by linarith [congrArg Vector2D.y h_oeq]
          rw [show q1 = O from (Vector2D.mk.injEq _ _ _ _).mpr ⟨hqx, hqy⟩] at hq1_seg
          exact hq1_seg
        · exact h
      have h_dot_pos : (q1.x - O.x) * n1.x + (q1.y - O.y) * n1.y > 0 := by
        rw [show q1.x - O.x = t * d2.x from by linarith [congrArg Vector2D.x h_oeq],
            show q1.y - O.y = t * d2.y from by linarith [congrArg Vector2D.y h_oeq]]
        linarith [h_d2_n1 t, mul_pos h_tpos hκ_pos]
      have h_hp1_p1 : (seg.p1.x - O.x) * n1.x + (seg.p1.y - O.y) * n1.y < 0 := by
        by_contra hge; push_neg at hge
        have h_line : (seg.p1.x - O.x) * d2.y = (seg.p1.y - O.y) * d2.x := by
          have h0 : (seg.p1.x - O.x) * n2.x + (seg.p1.y - O.y) * n2.y = 0 := h_nd2.1
          simp only [n2, egp_choose_n2] at h0; split at h0 <;> ring_linarith
        obtain ⟨tp, htpx, htpy⟩ := egp_extract_line_param d2 O seg.p1 r2.direction_nonzero h_line
        have h_tpk : tp * κ ≥ 0 := by
          have : (seg.p1.x - O.x) * n1.x + (seg.p1.y - O.y) * n1.y = tp * κ := by
            rw [show seg.p1.x - O.x = tp * d2.x from by linarith,
                show seg.p1.y - O.y = tp * d2.y from by linarith]; exact h_d2_n1 tp
          linarith
        have h_tp_nn : tp ≥ 0 := by
          by_contra h_neg; push_neg at h_neg
          exact absurd h_tpk (not_le.mpr (mul_neg_of_neg_of_pos h_neg hκ_pos))
        exact absurd (show seg.p1 ∈ hpi.toBoundarySet by
          rw [h_bnd]; exact Set.mem_union_right _
            ⟨tp, h_tp_nn, by linarith [congrArg Vector2D.x h_oeq],
                           by linarith [congrArg Vector2D.y h_oeq]⟩) h_p1_not_bnd
      have h_hp1_p2 : (seg.p2.x - O.x) * n1.x + (seg.p2.y - O.y) * n1.y < 0 := by
        by_contra hge; push_neg at hge
        have h_line : (seg.p2.x - O.x) * d2.y = (seg.p2.y - O.y) * d2.x := by
          have h0 : (seg.p2.x - O.x) * n2.x + (seg.p2.y - O.y) * n2.y = 0 := h_nd2.2
          simp only [n2, egp_choose_n2] at h0; split at h0 <;> ring_linarith
        obtain ⟨tp, htpx, htpy⟩ := egp_extract_line_param d2 O seg.p2 r2.direction_nonzero h_line
        have h_tpk : tp * κ ≥ 0 := by
          have : (seg.p2.x - O.x) * n1.x + (seg.p2.y - O.y) * n1.y = tp * κ := by
            rw [show seg.p2.x - O.x = tp * d2.x from by linarith,
                show seg.p2.y - O.y = tp * d2.y from by linarith]; exact h_d2_n1 tp
          linarith
        have h_tp_nn : tp ≥ 0 := by
          by_contra h_neg; push_neg at h_neg
          exact absurd h_tpk (not_le.mpr (mul_neg_of_neg_of_pos h_neg hκ_pos))
        exact absurd (show seg.p2 ∈ hpi.toBoundarySet by
          rw [h_bnd]; exact Set.mem_union_right _
            ⟨tp, h_tp_nn, by linarith [congrArg Vector2D.x h_oeq],
                           by linarith [congrArg Vector2D.y h_oeq]⟩) h_p2_not_bnd
      obtain ⟨s, hs0, hs1, hsx, hsy⟩ := hq1_seg
      have h_dot_seg : (q1.x - O.x) * n1.x + (q1.y - O.y) * n1.y =
        (1 - s) * ((seg.p1.x - O.x) * n1.x + (seg.p1.y - O.y) * n1.y) +
        s * ((seg.p2.x - O.x) * n1.x + (seg.p2.y - O.y) * n1.y) := by
        rw [show q1.x - O.x = (1 - s) * (seg.p1.x - O.x) + s * (seg.p2.x - O.x) from by linarith,
            show q1.y - O.y = (1 - s) * (seg.p1.y - O.y) + s * (seg.p2.y - O.y) from by linarith]
        ring
      rcases eq_or_lt_of_le hs0 with rfl | hs_pos
      · simp at h_dot_seg; linarith
      · linarith [mul_neg_of_pos_of_neg hs_pos h_hp1_p2,
          mul_nonpos_of_nonneg_of_nonpos (show (1 : ℚ) - s ≥ 0 by linarith) (le_of_lt h_hp1_p1)]
  -- Split crossings
  have h_cross_split : seg.boundaryCrossings hpi =
      (seg.toSet ∩ r1.toSet) ∪ (seg.toSet ∩ r2.toSet) := by
    rw [h_cross_union, Set.inter_union_distrib_left]
  have h_fin_r1 : (seg.toSet ∩ r1.toSet).Finite := h_seg_r1_sub.finite
  have h_fin_r2 : (seg.toSet ∩ r2.toSet).Finite := h_seg_r2_sub.finite
  have h_disj : Disjoint h_fin_r1.toFinset h_fin_r2.toFinset := by
    rw [Finset.disjoint_left]; intro q hq1 hq2
    exact h_disjoint q (h_fin_r1.mem_toFinset.mp hq1).1
      (h_fin_r1.mem_toFinset.mp hq1).2 (h_fin_r2.mem_toFinset.mp hq2).2
  have h_tofinset : h_fin.toFinset = h_fin_r1.toFinset ∪ h_fin_r2.toFinset := by
    ext q; simp only [Set.Finite.mem_toFinset, Finset.mem_union, h_cross_split, Set.mem_union]
  rw [h_cc, h_tofinset, Finset.card_union_of_disjoint h_disj]
  congr 1
  · by_cases hr1 : rayIntersectsSegment r1 seg
    · rw [if_pos (decide_eq_true hr1)]
      have h_ne : (seg.toSet ∩ r1.toSet).Nonempty := by
        obtain ⟨q, hq1, hq2⟩ := hr1; exact ⟨q, hq2, hq1⟩
      have := egp_subsingleton_card _ h_fin_r1 h_seg_r1_sub
      have := egp_nonempty_card _ h_fin_r1 h_ne
      omega
    · have hd1 : ¬(decide (rayIntersectsSegment r1 seg) = true) :=
        fun h => hr1 (of_decide_eq_true h)
      rw [if_neg hd1, Finset.card_eq_zero, Finset.eq_empty_iff_forall_not_mem]
      intro q hq
      exact hr1 ⟨q, (h_fin_r1.mem_toFinset.mp hq).2, (h_fin_r1.mem_toFinset.mp hq).1⟩
  · by_cases hr2 : rayIntersectsSegment r2 seg
    · rw [if_pos (decide_eq_true hr2)]
      have h_ne : (seg.toSet ∩ r2.toSet).Nonempty := by
        obtain ⟨q, hq1, hq2⟩ := hr2; exact ⟨q, hq2, hq1⟩
      have := egp_subsingleton_card _ h_fin_r2 h_seg_r2_sub
      have := egp_nonempty_card _ h_fin_r2 h_ne
      omega
    · have hd2 : ¬(decide (rayIntersectsSegment r2 seg) = true) :=
        fun h => hr2 (of_decide_eq_true h)
      rw [if_neg hd2, Finset.card_eq_zero, Finset.eq_empty_iff_forall_not_mem]
      intro q hq
      exact hr2 ⟨q, (h_fin_r2.mem_toFinset.mp hq).2, (h_fin_r2.mem_toFinset.mp hq).1⟩

/-! #### HPI crossings even (needed for parity theorems) -/

private lemma countP_or_of_disjoint' (l : List LineSegment)
    (h_ne : ∀ seg ∈ l, seg.p1 ≠ seg.p2) (u : Vector2D) :
    l.countP (fun seg => decide (seg.p1 = u ∨ seg.p2 = u)) =
    l.countP (fun seg => decide (seg.p1 = u)) +
    l.countP (fun seg => decide (seg.p2 = u)) := by
  induction l with
  | nil => simp
  | cons seg tl ih =>
    have h_ne_tl : ∀ seg ∈ tl, seg.p1 ≠ seg.p2 :=
      fun s hs => h_ne s (List.mem_cons.mpr (Or.inr hs))
    simp only [List.countP_cons]
    rw [ih h_ne_tl]
    have h_seg_ne := h_ne seg (List.mem_cons_self _ _)
    by_cases h1 : seg.p1 = u
    · have h2 : seg.p2 ≠ u := fun h => h_seg_ne (h1 ▸ h.symm)
      simp [h1, h2]; omega
    · by_cases h2 : seg.p2 = u
      · simp [h1, h2]; omega
      · simp [h1, h2]

private lemma sum_zero_of_ne' (l : List Vector2D) (p : Vector2D)
    (h_ne : ∀ v ∈ l, p ≠ v) (E : Set Vector2D) :
    (l.map (fun v => (if p = v then (1 : ℕ) else 0) * (if v ∈ E then 1 else 0))).sum = 0 := by
  apply List.sum_eq_zero
  intro x hx
  obtain ⟨v, hv, rfl⟩ := List.mem_map.mp hx
  simp [h_ne v hv]

private lemma single_seg_sum_eq' (verts : List Vector2D) (p : Vector2D)
    (h_nodup : verts.Nodup) (h_mem : p ∈ verts) (E : Set Vector2D) :
    (verts.map (fun v => (if p = v then (1 : ℕ) else 0) * (if v ∈ E then 1 else 0))).sum =
    if p ∈ E then 1 else 0 := by
  induction verts with
  | nil => simp at h_mem
  | cons hd tl ih =>
    simp only [List.map_cons, List.sum_cons, List.nodup_cons, List.mem_cons] at *
    obtain ⟨h_nhead, h_nd⟩ := h_nodup
    rcases h_mem with rfl | h_mem_tail
    · simp only [ite_true]
      have := sum_zero_of_ne' tl p (fun v hv => fun h => h_nhead (h ▸ hv)) E
      omega
    · have h_ne : p ≠ hd := fun h => h_nhead (h ▸ h_mem_tail)
      simp only [if_neg h_ne, zero_mul, zero_add]
      exact ih h_nd h_mem_tail

private lemma sum_indicator_eq_verts_sum' (segs : List LineSegment) (verts : List Vector2D)
    (h_nodup : verts.Nodup) (h_cover : ∀ s ∈ segs, s.p1 ∈ verts) (E : Set Vector2D) :
    (segs.map (fun s : LineSegment => if s.p1 ∈ E then (1 : ℕ) else 0)).sum =
    (verts.map (fun v => segs.countP (fun s => decide (s.p1 = v)) * (if v ∈ E then 1 else 0))).sum := by
  induction segs with
  | nil => simp
  | cons seg rest ih =>
    have h_cover_rest : ∀ s ∈ rest, s.p1 ∈ verts := fun s hs => h_cover s (List.mem_cons_of_mem _ hs)
    have h_p1_mem := h_cover seg (List.mem_cons_self _ _)
    simp only [List.map_cons, List.sum_cons]
    rw [ih h_cover_rest]
    have h1 : (verts.map (fun v : Vector2D => (seg :: rest).countP (fun s => decide (s.p1 = v)) *
            (if v ∈ E then (1 : ℕ) else 0))).sum =
        (verts.map (fun v : Vector2D =>
            (if seg.p1 = v then (1 : ℕ) else 0) * (if v ∈ E then 1 else 0) +
            rest.countP (fun s => decide (s.p1 = v)) * (if v ∈ E then 1 else 0))).sum := by
      congr 1; apply List.map_congr_left; intro v _
      simp only [List.countP_cons]
      by_cases h : seg.p1 = v <;> by_cases he : v ∈ E <;> simp [h, he]; omega
    rw [h1, show (verts.map (fun v : Vector2D =>
            (if seg.p1 = v then (1 : ℕ) else 0) * (if v ∈ E then 1 else 0) +
            rest.countP (fun s => decide (s.p1 = v)) * (if v ∈ E then 1 else 0))).sum =
        (verts.map (fun v : Vector2D => (if seg.p1 = v then (1 : ℕ) else 0) * (if v ∈ E then 1 else 0))).sum +
        (verts.map (fun v : Vector2D => rest.countP (fun s => decide (s.p1 = v)) * (if v ∈ E then 1 else 0))).sum from by simp,
      single_seg_sum_eq' verts seg.p1 h_nodup h_p1_mem E]

private lemma sum_indicator_p2_eq_verts_sum' (segs : List LineSegment) (verts : List Vector2D)
    (h_nodup : verts.Nodup) (h_cover : ∀ s ∈ segs, s.p2 ∈ verts) (E : Set Vector2D) :
    (segs.map (fun s : LineSegment => if s.p2 ∈ E then (1 : ℕ) else 0)).sum =
    (verts.map (fun v => segs.countP (fun s => decide (s.p2 = v)) * (if v ∈ E then 1 else 0))).sum := by
  induction segs with
  | nil => simp
  | cons seg rest ih =>
    have h_cover_rest : ∀ s ∈ rest, s.p2 ∈ verts := fun s hs => h_cover s (List.mem_cons_of_mem _ hs)
    have h_p2_mem := h_cover seg (List.mem_cons_self _ _)
    simp only [List.map_cons, List.sum_cons]
    rw [ih h_cover_rest]
    have h1 : (verts.map (fun v : Vector2D => (seg :: rest).countP (fun s => decide (s.p2 = v)) *
            (if v ∈ E then (1 : ℕ) else 0))).sum =
        (verts.map (fun v : Vector2D =>
            (if seg.p2 = v then (1 : ℕ) else 0) * (if v ∈ E then 1 else 0) +
            rest.countP (fun s => decide (s.p2 = v)) * (if v ∈ E then 1 else 0))).sum := by
      congr 1; apply List.map_congr_left; intro v _
      simp only [List.countP_cons]
      by_cases h : seg.p2 = v <;> by_cases he : v ∈ E <;> simp [h, he]; omega
    rw [h1, show (verts.map (fun v : Vector2D =>
            (if seg.p2 = v then (1 : ℕ) else 0) * (if v ∈ E then 1 else 0) +
            rest.countP (fun s => decide (s.p2 = v)) * (if v ∈ E then 1 else 0))).sum =
        (verts.map (fun v : Vector2D => (if seg.p2 = v then (1 : ℕ) else 0) * (if v ∈ E then 1 else 0))).sum +
        (verts.map (fun v : Vector2D => rest.countP (fun s => decide (s.p2 = v)) * (if v ∈ E then 1 else 0))).sum from by simp,
      single_seg_sum_eq' verts seg.p2 h_nodup h_p2_mem E]

private lemma even_sum_of_even_terms' (verts : List Vector2D) (f : Vector2D → ℕ)
    (h : ∀ v ∈ verts, Even (f v)) : Even (verts.map f).sum := by
  induction verts with
  | nil => simp
  | cons hd tl ih =>
    simp only [List.map_cons, List.sum_cons]
    exact Even.add (h hd (List.mem_cons_self _ _)) (ih (fun x hx => h x (List.mem_cons.mpr (Or.inr hx))))

private lemma even_total_ext' (hpi : HalfPlaneIntersection) (G : EvenGraph)
    (_h_vertices_not_boundary : ∀ v ∈ G.toVertices, v ∉ hpi.toBoundarySet) :
    Even ((G.segments.map fun seg => hpi.segExtCount seg).sum) := by
  simp only [HalfPlaneIntersection.segExtCount]
  have h_split : (G.segments.map fun seg =>
      (if seg.p1 ∈ hpi.toExteriorSet then (1 : ℕ) else 0) +
      (if seg.p2 ∈ hpi.toExteriorSet then 1 else 0)).sum =
    (G.segments.map fun seg => if seg.p1 ∈ hpi.toExteriorSet then (1 : ℕ) else 0).sum +
    (G.segments.map fun seg => if seg.p2 ∈ hpi.toExteriorSet then (1 : ℕ) else 0).sum := by
    induction G.segments with
    | nil => simp
    | cons seg tl ih => simp [ih]; omega
  rw [h_split]
  let verts := G.toVertices.dedup
  have h_nodup : verts.Nodup := List.nodup_dedup _
  have h_p1_cover : ∀ s ∈ G.segments, s.p1 ∈ verts :=
    fun s hs => List.mem_dedup.mpr (G.segments_endpoints s hs).1
  have h_p2_cover : ∀ s ∈ G.segments, s.p2 ∈ verts :=
    fun s hs => List.mem_dedup.mpr (G.segments_endpoints s hs).2
  rw [sum_indicator_eq_verts_sum' G.segments verts h_nodup h_p1_cover hpi.toExteriorSet,
      sum_indicator_p2_eq_verts_sum' G.segments verts h_nodup h_p2_cover hpi.toExteriorSet]
  rw [show (verts.map (fun v => G.segments.countP (fun s => decide (s.p1 = v)) *
          (if v ∈ hpi.toExteriorSet then (1 : ℕ) else 0))).sum +
      (verts.map (fun v => G.segments.countP (fun s => decide (s.p2 = v)) *
          (if v ∈ hpi.toExteriorSet then (1 : ℕ) else 0))).sum =
      (verts.map (fun v => (G.segments.countP (fun s => decide (s.p1 = v)) +
          G.segments.countP (fun s => decide (s.p2 = v))) *
          (if v ∈ hpi.toExteriorSet then (1 : ℕ) else 0))).sum from by
    induction verts with
    | nil => simp
    | cons hd tl ih =>
      simp only [List.map_cons, List.sum_cons]
      have : (G.segments.countP (fun s => decide (s.p1 = hd)) +
              G.segments.countP (fun s => decide (s.p2 = hd))) *
              (if hd ∈ hpi.toExteriorSet then (1 : ℕ) else 0) =
          G.segments.countP (fun s => decide (s.p1 = hd)) * (if hd ∈ hpi.toExteriorSet then 1 else 0) +
          G.segments.countP (fun s => decide (s.p2 = hd)) * (if hd ∈ hpi.toExteriorSet then 1 else 0) := by ring
      omega]
  apply even_sum_of_even_terms'
  intro v _hv
  have h_deg_even := G.even_degree v
  rw [countP_or_of_disjoint' G.segments G.segments_nondegenerate v] at h_deg_even
  exact Even.mul_right h_deg_even _

private lemma even_cc_plus_ext' (hpi : HalfPlaneIntersection) (G : EvenGraph)
    (h_vertices_not_boundary : ∀ v ∈ G.toVertices, v ∉ hpi.toBoundarySet)
    (h_avoids_vertices : ∀ seg ∈ G.segments, ∀ q ∈ seg.toSet, q ∉ hpi.toVertexSet) :
    Even ((G.segments.map fun seg =>
      segCrossingCount seg hpi + hpi.segExtCount seg).sum) := by
  have h_each : ∀ seg ∈ G.segments,
      Even (segCrossingCount seg hpi + hpi.segExtCount seg) := by
    intro seg hseg
    exact (hpi.segment_parity seg
      (h_vertices_not_boundary seg.p1 (G.segments_endpoints seg hseg).1)
      (h_vertices_not_boundary seg.p2 (G.segments_endpoints seg hseg).2)
      (h_avoids_vertices seg hseg)).2
  have h_sum_even : ∀ (xs : List ℕ), (∀ x ∈ xs, Even x) → Even xs.sum := by
    intro xs
    induction xs with
    | nil => simp
    | cons x tl ih =>
      intro h
      simp only [List.sum_cons]
      exact Even.add (h x (List.mem_cons_self _ _))
        (ih (fun y hy => h y (List.mem_cons.mpr (Or.inr hy))))
  apply h_sum_even
  simp only [List.mem_map]
  rintro _ ⟨seg, hseg, rfl⟩
  exact h_each seg hseg

private lemma graph_crossings_even' (hpi : HalfPlaneIntersection) (G : EvenGraph)
    (h_vertices_not_boundary : ∀ v ∈ G.toVertices, v ∉ hpi.toBoundarySet)
    (h_avoids_vertices : ∀ seg ∈ G.segments, ∀ q ∈ seg.toSet, q ∉ hpi.toVertexSet) :
    (∀ seg ∈ G.segments, (seg.boundaryCrossings hpi).Finite) ∧
    Even ((G.segments.map fun seg => segCrossingCount seg hpi).sum) := by
  constructor
  · intro seg hseg
    have hp1_nb := h_vertices_not_boundary seg.p1 (G.segments_endpoints seg hseg).1
    have hp2_nb := h_vertices_not_boundary seg.p2 (G.segments_endpoints seg hseg).2
    exact (hpi.segment_parity seg hp1_nb hp2_nb (h_avoids_vertices seg hseg)).1
  · have h1 := even_cc_plus_ext' hpi G h_vertices_not_boundary h_avoids_vertices
    have h2 := even_total_ext' hpi G h_vertices_not_boundary
    have h_split : (G.segments.map fun seg =>
        segCrossingCount seg hpi + hpi.segExtCount seg).sum =
      (G.segments.map fun seg => segCrossingCount seg hpi).sum +
      (G.segments.map fun seg => hpi.segExtCount seg).sum := by
      induction G.segments with
      | nil => simp
      | cons seg tl ih => simp [ih]; omega
    rw [h_split] at h1
    obtain ⟨k1, hk1⟩ := h1
    obtain ⟨k2, hk2⟩ := h2
    exact ⟨k1 - k2, by omega⟩

theorem intersectionParity_eq_of_sameOrigin_avoidsGraphVertices
    (r1 r2 : Ray) (G : EvenGraph)
    (h_origin : sameOrigin r1 r2)
    (h_r1_avoids : rayAvoidsGraphVertices r1 G)
    (h_r2_avoids : rayAvoidsGraphVertices r2 G)
    (h_origin_avoids_segments : ∀ seg ∈ G.segments, pointAvoidsSegment r1.origin seg) :
    (intersectionRayGraphSegmentsNumber r1 G) % 2 =
    (intersectionRayGraphSegmentsNumber r2 G) % 2 := by
  rcases egp_direction_trichotomy r1.direction r2.direction
      r1.direction_nonzero r2.direction_nonzero with h_same | h_opp | h_nc
  · -- Same direction: equal counts
    rw [egp_same_dir_eq_count_graph r1 r2 G h_origin h_same]
  · -- Opposite direction: apply graph_crossings_even
    set hpi := egp_opposite_rays_hpi r1 with hpi_def
    have h_bnd := egp_opposite_hpi_boundary_eq r1 r2 h_origin h_opp
    -- Vertices avoid HPI boundary
    have h_verts_avoid : ∀ v ∈ G.toVertices, v ∉ hpi.toBoundarySet := by
      rw [h_bnd]
      intro v hv hmem
      simp only [Set.mem_union] at hmem
      rcases hmem with hr1 | hr2
      · have : v ∈ r1.toSet ∩ G.toVertexSet := ⟨hr1, hv⟩
        rw [rayAvoidsGraphVertices] at h_r1_avoids
        rw [h_r1_avoids] at this; exact this
      · have : v ∈ r2.toSet ∩ G.toVertexSet := ⟨hr2, hv⟩
        rw [rayAvoidsGraphVertices] at h_r2_avoids
        rw [h_r2_avoids] at this; exact this
    -- HPI crossings: even total
    have h_even_total := (graph_crossings_even' hpi G h_verts_avoid
      (egp_opposite_hpi_segments_avoid_vertices r1 G.segments)).2
    -- Total crossings = r1 + r2
    have h_ep_not_bnd : ∀ seg ∈ G.segments,
        seg.p1 ∉ hpi.toBoundarySet ∧ seg.p2 ∉ hpi.toBoundarySet := by
      intro seg hseg
      exact ⟨h_verts_avoid seg.p1 (G.segments_endpoints seg hseg).1,
             h_verts_avoid seg.p2 (G.segments_endpoints seg hseg).2⟩
    have h_total := egp_segs_opp_total_eq r1 r2 G.segments h_origin h_opp
      h_ep_not_bnd h_origin_avoids_segments
    -- h_total: (map segCC).sum = countP r1 + countP r2
    -- h_even_total: Even (map segCC).sum
    simp only [intersectionRayGraphSegmentsNumber, hpi_def] at *
    rw [h_total] at h_even_total
    rw [egp_countP_eq_map_sum, egp_countP_eq_map_sum] at h_even_total ⊢
    obtain ⟨k, hk⟩ := h_even_total
    omega
  · -- Non-collinear: apply graph_crossings_even
    set hpi := egp_nc_rays_hpi r1 r2 h_origin h_nc with hpi_def
    have h_bnd := egp_nc_hpi_boundary_eq r1 r2 h_origin h_nc
    have h_verts_avoid : ∀ v ∈ G.toVertices, v ∉ hpi.toBoundarySet := by
      rw [h_bnd]
      intro v hv hmem
      simp only [Set.mem_union] at hmem
      rcases hmem with hr1 | hr2
      · have : v ∈ r1.toSet ∩ G.toVertexSet := ⟨hr1, hv⟩
        rw [rayAvoidsGraphVertices] at h_r1_avoids
        rw [h_r1_avoids] at this; exact this
      · have : v ∈ r2.toSet ∩ G.toVertexSet := ⟨hr2, hv⟩
        rw [rayAvoidsGraphVertices] at h_r2_avoids
        rw [h_r2_avoids] at this; exact this
    have h_seg_avoid_vert := egp_nc_segs_avoid_vertices r1 r2 G.segments h_origin h_nc
      h_origin_avoids_segments
    have h_even_total := (graph_crossings_even' hpi G h_verts_avoid h_seg_avoid_vert).2
    have h_ep_not_bnd : ∀ seg ∈ G.segments,
        seg.p1 ∉ hpi.toBoundarySet ∧ seg.p2 ∉ hpi.toBoundarySet := by
      intro seg hseg
      exact ⟨h_verts_avoid seg.p1 (G.segments_endpoints seg hseg).1,
             h_verts_avoid seg.p2 (G.segments_endpoints seg hseg).2⟩
    have h_total := egp_segs_nc_total_eq r1 r2 G.segments h_origin h_nc
      h_ep_not_bnd h_seg_avoid_vert h_origin_avoids_segments
    simp only [intersectionRayGraphSegmentsNumber, hpi_def] at *
    rw [h_total] at h_even_total
    rw [egp_countP_eq_map_sum, egp_countP_eq_map_sum] at h_even_total ⊢
    obtain ⟨k, hk⟩ := h_even_total
    omega

/-! #### Additional helpers for theorem 4 -/

private lemma egp_sub_nonzero (O1 O2 : Vector2D) (h : O1 ≠ O2) :
    (⟨O2.x - O1.x, O2.y - O1.y⟩ : Vector2D) ≠ ⟨0, 0⟩ := by
  intro heq
  apply h
  have hx : O2.x - O1.x = 0 := congrArg Vector2D.x heq
  have hy : O2.y - O1.y = 0 := congrArg Vector2D.y heq
  exact (Vector2D.mk.injEq _ _ _ _).mpr ⟨by linarith, by linarith⟩

private def egp_par_n1 (d delta : Vector2D) : Vector2D :=
  if egp_cross d delta > 0 then ⟨-d.y, d.x⟩ else ⟨d.y, -d.x⟩

private def egp_par_n2 (d delta : Vector2D) : Vector2D :=
  if egp_cross d delta > 0 then ⟨d.y, -d.x⟩ else ⟨-d.y, d.x⟩

private def egp_par_n3 (d delta : Vector2D) : Vector2D :=
  if egp_cross d delta > 0 then ⟨delta.y, -delta.x⟩ else ⟨-delta.y, delta.x⟩

private lemma egp_par_n1_nonzero (d delta : Vector2D) (hd : d ≠ ⟨0, 0⟩) :
    egp_par_n1 d delta ≠ ⟨0, 0⟩ := by
  unfold egp_par_n1; split <;> intro h
  · apply hd; have hx : (-d.y : ℚ) = 0 := congrArg Vector2D.x h
    have hy : d.x = 0 := congrArg Vector2D.y h
    simp at hx; exact (Vector2D.mk.injEq _ _ _ _).mpr ⟨hy, hx⟩
  · apply hd; have hx : d.y = 0 := congrArg Vector2D.x h
    have hy : (-d.x : ℚ) = 0 := congrArg Vector2D.y h
    simp at hy; exact (Vector2D.mk.injEq _ _ _ _).mpr ⟨hy, hx⟩

private lemma egp_par_n2_nonzero (d delta : Vector2D) (hd : d ≠ ⟨0, 0⟩) :
    egp_par_n2 d delta ≠ ⟨0, 0⟩ := by
  unfold egp_par_n2; split <;> intro h
  · apply hd; have hx : d.y = 0 := congrArg Vector2D.x h
    have hy : (-d.x : ℚ) = 0 := congrArg Vector2D.y h
    simp at hy; exact (Vector2D.mk.injEq _ _ _ _).mpr ⟨hy, hx⟩
  · apply hd; have hx : (-d.y : ℚ) = 0 := congrArg Vector2D.x h
    have hy : d.x = 0 := congrArg Vector2D.y h
    simp at hx; exact (Vector2D.mk.injEq _ _ _ _).mpr ⟨hy, hx⟩

private lemma egp_par_n3_nonzero (d delta : Vector2D) (hdelta : delta ≠ ⟨0, 0⟩) :
    egp_par_n3 d delta ≠ ⟨0, 0⟩ := by
  unfold egp_par_n3; split <;> intro h
  · apply hdelta; have hx : delta.y = 0 := congrArg Vector2D.x h
    have hy : (-delta.x : ℚ) = 0 := congrArg Vector2D.y h
    simp at hy; exact (Vector2D.mk.injEq _ _ _ _).mpr ⟨hy, hx⟩
  · apply hdelta; have hx : (-delta.y : ℚ) = 0 := congrArg Vector2D.x h
    have hy : delta.x = 0 := congrArg Vector2D.y h
    simp at hx; exact (Vector2D.mk.injEq _ _ _ _).mpr ⟨hy, hx⟩

private noncomputable def egp_par_rays_hpi (O1 O2 : Vector2D) (d : Vector2D)
    (hd : d ≠ ⟨0, 0⟩) (h_neq : O1 ≠ O2)
    (_h_nc : egp_cross d ⟨O2.x - O1.x, O2.y - O1.y⟩ ≠ 0) : HalfPlaneIntersection :=
  let delta : Vector2D := ⟨O2.x - O1.x, O2.y - O1.y⟩
  ⟨[⟨O1, egp_par_n1 d delta, egp_par_n1_nonzero d delta hd⟩,
    ⟨O2, egp_par_n2 d delta, egp_par_n2_nonzero d delta hd⟩,
    ⟨O1, egp_par_n3 d delta, egp_par_n3_nonzero d delta (egp_sub_nonzero O1 O2 h_neq)⟩]⟩

private lemma egp_exists_noncollinear_direction (dirs : List Vector2D)
    (h_nz : ∀ w ∈ dirs, w ≠ ⟨0, 0⟩) :
    ∃ d : Vector2D, d ≠ ⟨0, 0⟩ ∧ ∀ w ∈ dirs, egp_cross d w ≠ 0 := by
  have : Infinite ℚ := Infinite.of_injective (fun n : ℕ => (n : ℚ)) Nat.cast_injective
  -- The bad slopes for d = ⟨1, q⟩: egp_cross ⟨1,q⟩ w = 1*w.y - q*w.x = 0
  -- So q = w.y / w.x when w.x ≠ 0; when w.x = 0, there is no bad q (since w.y ≠ 0)
  let badSlopes : Finset ℚ := (dirs.filterMap fun w =>
    if w.x ≠ 0 then some (w.y / w.x) else none).toFinset
  obtain ⟨q, hq⟩ := Finset.exists_not_mem badSlopes
  refine ⟨⟨1, q⟩, by intro h; exact absurd (congrArg Vector2D.x h) one_ne_zero, ?_⟩
  intro w hw hwc
  simp only [egp_cross] at hwc
  -- hwc : 1 * w.y - q * w.x = 0, i.e., w.y = q * w.x
  have hw_nz := h_nz w hw
  by_cases hwxx : w.x ≠ 0
  · -- w.x ≠ 0: bad q is w.y / w.x, which must equal q
    apply hq
    simp only [badSlopes, List.mem_toFinset, List.mem_filterMap]
    refine ⟨w, hw, ?_⟩
    rw [if_pos hwxx]
    congr 1
    have hqx : q * w.x = w.y := by linarith
    rw [div_eq_iff hwxx]
    linarith
  · -- w.x = 0: then w.y = q * 0 = 0, contradicting w ≠ ⟨0,0⟩
    push_neg at hwxx
    have hwy : w.y = 0 := by linarith [hwxx ▸ (mul_zero q)]
    exact absurd ((Vector2D.mk.injEq _ _ _ _).mpr ⟨hwxx, hwy⟩) hw_nz

private lemma egp_cross_ne_zero_not_on_ray (O : Vector2D) (d : Vector2D) (hd : d ≠ ⟨0, 0⟩)
    (v : Vector2D) (hcross : egp_cross d ⟨v.x - O.x, v.y - O.y⟩ ≠ 0) :
    v ∉ (Ray.mk O d hd).toSet := by
  intro ⟨t, _, htx, hty⟩
  apply hcross
  unfold egp_cross
  rw [show v.x - O.x = t * d.x from by linarith,
      show v.y - O.y = t * d.y from by linarith]
  ring

private lemma egp_exists_good_direction (O1 O2 : Vector2D) (h_neq : O1 ≠ O2)
    (vertices : List Vector2D)
    (h_v_ne_O1 : ∀ v ∈ vertices, v ≠ O1)
    (h_v_ne_O2 : ∀ v ∈ vertices, v ≠ O2) :
    ∃ d : Vector2D, d ≠ ⟨0, 0⟩ ∧
      egp_cross d ⟨O2.x - O1.x, O2.y - O1.y⟩ ≠ 0 ∧
      (∀ v ∈ vertices, egp_cross d ⟨v.x - O1.x, v.y - O1.y⟩ ≠ 0) ∧
      (∀ v ∈ vertices, egp_cross d ⟨v.x - O2.x, v.y - O2.y⟩ ≠ 0) := by
  have h_delta_nz : (⟨O2.x - O1.x, O2.y - O1.y⟩ : Vector2D) ≠ ⟨0, 0⟩ :=
    egp_sub_nonzero O1 O2 h_neq
  have h_dirs1_nz : ∀ v ∈ vertices, (⟨v.x - O1.x, v.y - O1.y⟩ : Vector2D) ≠ ⟨0, 0⟩ := by
    intro v hv heq
    have hx : v.x - O1.x = 0 := congrArg Vector2D.x heq
    have hy : v.y - O1.y = 0 := congrArg Vector2D.y heq
    exact h_v_ne_O1 v hv ((Vector2D.mk.injEq _ _ _ _).mpr ⟨by linarith, by linarith⟩)
  have h_dirs2_nz : ∀ v ∈ vertices, (⟨v.x - O2.x, v.y - O2.y⟩ : Vector2D) ≠ ⟨0, 0⟩ := by
    intro v hv heq
    have hx : v.x - O2.x = 0 := congrArg Vector2D.x heq
    have hy : v.y - O2.y = 0 := congrArg Vector2D.y heq
    exact h_v_ne_O2 v hv ((Vector2D.mk.injEq _ _ _ _).mpr ⟨by linarith, by linarith⟩)
  set dirs := ⟨O2.x - O1.x, O2.y - O1.y⟩ ::
    ((vertices.map fun v => (⟨v.x - O1.x, v.y - O1.y⟩ : Vector2D)) ++
     (vertices.map fun v => (⟨v.x - O2.x, v.y - O2.y⟩ : Vector2D)))
  have h_all_nz : ∀ w ∈ dirs, w ≠ ⟨0, 0⟩ := by
    intro w hw
    simp only [dirs, List.mem_cons, List.mem_append, List.mem_map] at hw
    rcases hw with rfl | (⟨v, hv, rfl⟩ | ⟨v, hv, rfl⟩)
    · exact h_delta_nz
    · exact h_dirs1_nz v hv
    · exact h_dirs2_nz v hv
  obtain ⟨d, hd_nz, hd_cross⟩ := egp_exists_noncollinear_direction dirs h_all_nz
  refine ⟨d, hd_nz, ?_, ?_, ?_⟩
  · exact hd_cross _ (List.mem_cons_self _ _)
  · intro v hv
    have hmem : (⟨v.x - O1.x, v.y - O1.y⟩ : Vector2D) ∈
        vertices.map (fun (w : Vector2D) => (⟨w.x - O1.x, w.y - O1.y⟩ : Vector2D)) :=
      List.mem_map_of_mem _ hv
    exact hd_cross _ (List.mem_cons_of_mem _ (List.mem_append_left _ hmem))
  · intro v hv
    have hmem : (⟨v.x - O2.x, v.y - O2.y⟩ : Vector2D) ∈
        vertices.map (fun (w : Vector2D) => (⟨w.x - O2.x, w.y - O2.y⟩ : Vector2D)) :=
      List.mem_map_of_mem _ hv
    exact hd_cross _ (List.mem_cons_of_mem _ (List.mem_append_right _ hmem))

/-- If a vertex has positive degree, it lies on some segment of the graph.
    (Defined early to be available for parallel rays proof.) -/
private lemma vertex_on_some_graph_segment' (G : EvenGraph) (v : Vector2D)
    (h_degree_pos : (G.segments.countP fun seg => seg.p1 = v ∨ seg.p2 = v) > 0) :
    ∃ seg ∈ G.segments, v ∈ seg.toSet := by
  have ⟨seg, h_mem, h_pred⟩ := List.countP_pos_iff.mp h_degree_pos
  simp only [decide_eq_true_eq] at h_pred
  refine ⟨seg, h_mem, ?_⟩
  rcases h_pred with rfl | rfl
  · exact ⟨0, le_refl 0, zero_le_one, by ring, by ring⟩
  · exact ⟨1, zero_le_one, le_refl 1, by ring, by ring⟩

set_option maxHeartbeats 4000000 in
theorem intersectionParity_eq_of_originSegmentAvoidsGraphSegments
    (r1 r2 : Ray) (G : EvenGraph)
    (h_r1_avoids : rayAvoidsGraphVertices r1 G)
    (h_r2_avoids : rayAvoidsGraphVertices r2 G)
    (h_origin_segment_avoids : ∀ seg ∈ G.segments,
      segmentDoesNotIntersectSegment ⟨r1.origin, r2.origin⟩ seg)
    (h_verts_avoid_origin_seg : ∀ v ∈ G.toVertices,
      v ∉ (LineSegment.mk r1.origin r2.origin).toSet) :
    (intersectionRayGraphSegmentsNumber r1 G) % 2 =
    (intersectionRayGraphSegmentsNumber r2 G) % 2 := by
  set O1 := r1.origin; set O2 := r2.origin
  have h_O1_avoids : ∀ seg ∈ G.segments, pointAvoidsSegment O1 seg := by
    intro seg hseg
    have h := h_origin_segment_avoids seg hseg
    unfold segmentDoesNotIntersectSegment at h
    intro hO1
    have h1 : O1 ∈ (LineSegment.mk O1 O2).toSet :=
      ⟨0, le_refl _, le_of_lt one_pos, by simp, by simp⟩
    have hmem : O1 ∈ (LineSegment.mk O1 O2).toSet ∩ seg.toSet := ⟨h1, hO1⟩
    rw [h] at hmem; exact hmem.elim
  have h_O2_avoids : ∀ seg ∈ G.segments, pointAvoidsSegment O2 seg := by
    intro seg hseg
    have h := h_origin_segment_avoids seg hseg
    unfold segmentDoesNotIntersectSegment at h
    intro hO2
    have h2 : O2 ∈ (LineSegment.mk O1 O2).toSet :=
      ⟨1, le_of_lt one_pos, le_refl _, by simp, by simp⟩
    have hmem : O2 ∈ (LineSegment.mk O1 O2).toSet ∩ seg.toSet := ⟨h2, hO2⟩
    rw [h] at hmem; exact hmem.elim
  by_cases h_eq : O1 = O2
  · -- Same origin
    exact intersectionParity_eq_of_sameOrigin_avoidsGraphVertices r1 r2 G h_eq
      h_r1_avoids h_r2_avoids (fun seg hseg => by rw [show r1.origin = O1 from rfl]; exact h_O1_avoids seg hseg)
  · -- Different origins
    by_cases h_segs : G.segments = []
    · simp [intersectionRayGraphSegmentsNumber, h_segs]
    · -- Find good auxiliary direction
      -- O1 ∉ G.toVertices: r1.origin = O1 is in r1.toSet (at t=0),
      -- but h_r1_avoids says r1.toSet ∩ G.toVertexSet = ∅.
      have h_O1_not_vert : O1 ∉ G.toVertexSet := by
        intro hO1
        have hO1_ray : O1 ∈ r1.toSet := by
          simp only [Ray.toSet, Set.mem_setOf_eq]
          exact ⟨0, le_refl _, by simp [O1], by simp [O1]⟩
        rw [rayAvoidsGraphVertices] at h_r1_avoids
        have hmem1 : O1 ∈ r1.toSet ∩ G.toVertexSet := ⟨hO1_ray, hO1⟩
        rw [h_r1_avoids] at hmem1; exact hmem1.elim
      have h_O2_not_vert : O2 ∉ G.toVertexSet := by
        intro hO2
        have hO2_ray : O2 ∈ r2.toSet := by
          simp only [Ray.toSet, Set.mem_setOf_eq]
          exact ⟨0, le_refl _, by simp [O2], by simp [O2]⟩
        rw [rayAvoidsGraphVertices] at h_r2_avoids
        have hmem2 : O2 ∈ r2.toSet ∩ G.toVertexSet := ⟨hO2_ray, hO2⟩
        rw [h_r2_avoids] at hmem2; exact hmem2.elim
      have h_v_ne_O1 : ∀ v ∈ G.toVertices, v ≠ O1 := by
        intro v hv hveq; exact h_O1_not_vert (hveq ▸ hv)
      have h_v_ne_O2 : ∀ v ∈ G.toVertices, v ≠ O2 := by
        intro v hv hveq; exact h_O2_not_vert (hveq ▸ hv)
      obtain ⟨d, hd_nz, h_nc, h_d_O1, h_d_O2⟩ :=
        egp_exists_good_direction O1 O2 h_eq G.toVertices h_v_ne_O1 h_v_ne_O2
      set r1' : Ray := ⟨O1, d, hd_nz⟩
      set r2' : Ray := ⟨O2, d, hd_nz⟩
      have h_r1'_avoids : rayAvoidsGraphVertices r1' G := by
        rw [rayAvoidsGraphVertices]
        ext q; simp only [Set.mem_inter_iff, Set.mem_empty_iff_false, iff_false, not_and]
        intro hq_ray hq_vert
        exact egp_cross_ne_zero_not_on_ray O1 d hd_nz q (h_d_O1 q hq_vert) hq_ray
      have h_r2'_avoids : rayAvoidsGraphVertices r2' G := by
        rw [rayAvoidsGraphVertices]
        ext q; simp only [Set.mem_inter_iff, Set.mem_empty_iff_false, iff_false, not_and]
        intro hq_ray hq_vert
        exact egp_cross_ne_zero_not_on_ray O2 d hd_nz q (h_d_O2 q hq_vert) hq_ray
      have h_step1 : (intersectionRayGraphSegmentsNumber r1 G) % 2 =
          (intersectionRayGraphSegmentsNumber r1' G) % 2 :=
        intersectionParity_eq_of_sameOrigin_avoidsGraphVertices r1 r1' G
          (show sameOrigin r1 r1' from rfl)
          h_r1_avoids h_r1'_avoids h_O1_avoids
      have h_step2 : (intersectionRayGraphSegmentsNumber r2 G) % 2 =
          (intersectionRayGraphSegmentsNumber r2' G) % 2 :=
        intersectionParity_eq_of_sameOrigin_avoidsGraphVertices r2 r2' G
          (show sameOrigin r2 r2' from rfl)
          h_r2_avoids h_r2'_avoids h_O2_avoids
      -- r1' ≡ r2' (mod 2): parallel rays from different origins
      -- Apply graph_crossings_even to the 3-HP HPI
      have h_step3 : (intersectionRayGraphSegmentsNumber r1' G) % 2 =
          (intersectionRayGraphSegmentsNumber r2' G) % 2 := by
        -- Use a 3-HP HPI for parallel rays
        set hpi := egp_par_rays_hpi O1 O2 d hd_nz h_eq h_nc with hpi_def
        set delta : Vector2D := ⟨O2.x - O1.x, O2.y - O1.y⟩
        set n1 := egp_par_n1 d delta
        set n2 := egp_par_n2 d delta
        set n3 := egp_par_n3 d delta
        -- The HPI boundary = r1' ∪ seg(O1,O2) ∪ r2'
        -- Key algebraic identities
        set κ : ℚ := if egp_cross d delta > 0 then egp_cross d delta else -(egp_cross d delta)
        have hκ_pos : κ > 0 := by
          simp only [κ]; split
          · assumption
          · rename_i h; push_neg at h; linarith [lt_of_le_of_ne h h_nc]
        have h_d_n1 : ∀ t : ℚ, (t * d.x) * n1.x + (t * d.y) * n1.y = 0 := by
          intro t; simp only [n1, egp_par_n1]; split <;> ring
        have h_d_n2 : ∀ t : ℚ, (t * d.x) * n2.x + (t * d.y) * n2.y = 0 := by
          intro t; simp only [n2, egp_par_n2]; split <;> ring
        have h_delta_n1 : delta.x * n1.x + delta.y * n1.y = κ := by
          simp only [n1, egp_par_n1, κ, egp_cross]; split <;> ring
        have h_delta_n2 : delta.x * n2.x + delta.y * n2.y = -κ := by
          simp only [n2, egp_par_n2, κ, egp_cross]; split <;> ring
        have h_d_n3 : d.x * n3.x + d.y * n3.y = κ := by
          simp only [n3, egp_par_n3, κ, egp_cross]; split <;> ring
        have h_delta_n3 : ∀ t : ℚ, (t * delta.x) * n3.x + (t * delta.y) * n3.y = 0 := by
          intro t; simp only [n3, egp_par_n3]; split <;> ring
        have h_vert_avoids_seg : ∀ v ∈ G.toVertices, v ∉ (LineSegment.mk O1 O2).toSet := by
          intro v hv hv_seg
          -- If v is on some graph segment seg, then seg(O1,O2) ∩ seg ≠ ∅, contradiction
          by_cases h_deg_pos : (G.segments.countP fun seg => decide (seg.p1 = v ∨ seg.p2 = v)) > 0
          · obtain ⟨seg, hseg, hv_on_seg⟩ := vertex_on_some_graph_segment' G v h_deg_pos
            have h_disj := h_origin_segment_avoids seg hseg
            unfold segmentDoesNotIntersectSegment at h_disj
            have hmemd : v ∈ (LineSegment.mk O1 O2).toSet ∩ seg.toSet := ⟨hv_seg, hv_on_seg⟩
            rw [h_disj] at hmemd; exact hmemd.elim
          · -- Isolated vertex case: use h_verts_avoid_origin_seg directly
            push_neg at h_deg_pos
            exact absurd hv_seg (h_verts_avoid_origin_seg v hv)
        -- Check all 3 HPI components
        -- This requires proving hpi boundary = r1' ∪ seg ∪ r2' and vertices avoid each
        -- For now, we use the even crossing argument
        -- The HPI has segments for n1 (through O1, ⊥d), n2 (through O2, ⊥d), n3 (through O1, ⊥delta)
        -- r1' = {O1 + t*d | t≥0} ⊆ boundary of hp1
        -- r2' = {O2 + t*d | t≥0} ⊆ boundary of hp2
        -- seg(O1,O2) ⊆ boundary of hp3
        -- Vertices avoid r1' (from h_r1'_avoids)
        -- Vertices avoid r2' (from h_r2'_avoids)
        -- Vertices avoid seg(O1,O2) (proven above)
        -- The hpi boundary is r1' ∪ seg(O1,O2) ∪ r2':
        -- If v is on hpi boundary and v ∈ G.toVertices, derive contradiction.
        -- We prove: hpi.toBoundarySet ⊆ r1'.toSet ∪ (LineSegment.mk O1 O2).toSet ∪ r2'.toSet
        -- Then vertices avoid r1' (h_r1'_avoids), r2' (h_r2'_avoids), seg (h_vert_avoids_seg)
        have h_perp1 : ∀ q : Vector2D, (q.x - O1.x) * n1.x + (q.y - O1.y) * n1.y = 0 →
            (q.x - O1.x) * d.y = (q.y - O1.y) * d.x := by
          intro q hq; simp only [n1, egp_par_n1] at hq; split at hq <;> ring_linarith
        have h_perp2 : ∀ q : Vector2D, (q.x - O2.x) * n2.x + (q.y - O2.y) * n2.y = 0 →
            (q.x - O2.x) * d.y = (q.y - O2.y) * d.x := by
          intro q hq; simp only [n2, egp_par_n2] at hq; split at hq <;> ring_linarith
        have h_perp3 : ∀ q : Vector2D, (q.x - O1.x) * n3.x + (q.y - O1.y) * n3.y = 0 →
            (q.x - O1.x) * delta.y = (q.y - O1.y) * delta.x := by
          intro q hq; simp only [n3, egp_par_n3] at hq; split at hq <;> ring_linarith
        have h_delta_n2 : delta.x * n2.x + delta.y * n2.y = -κ := by
          simp only [n2, egp_par_n2, κ, egp_cross]; split <;> ring
        have h_neg_delta_n2 : (-delta.x) * n2.x + (-delta.y) * n2.y = κ := by linarith
        have h_dn3_zero : delta.x * n3.x + delta.y * n3.y = 0 := by
          have := h_delta_n3 1; simp at this; exact this
        have h_bnd : hpi.toBoundarySet =
            r1'.toSet ∪ (LineSegment.mk O1 O2).toSet ∪ r2'.toSet := by
          ext q; simp only [Set.mem_union]; constructor
          · intro hq
            simp only [hpi_def, egp_par_rays_hpi, HalfPlaneIntersection.toBoundarySet,
              HalfPlane.toBoundarySet, HalfPlane.toExteriorSet, HalfPlane.dot,
              Set.mem_setOf_eq, List.mem_cons, (List.not_mem_nil _), or_false] at hq
            obtain ⟨⟨hp, hp_mem, hdot⟩, h_not_ext⟩ := hq
            rcases hp_mem with rfl | rfl | rfl
            · -- q on HP1 boundary
              have h_line := h_perp1 q hdot
              obtain ⟨t, htx, hty⟩ := egp_extract_line_param d O1 q hd_nz h_line
              have h_hp2_nn : (q.x - O2.x) * n2.x + (q.y - O2.y) * n2.y ≥ 0 := by
                have := h_not_ext _ (Or.inr (Or.inl rfl))
                push_neg at this; exact this
              have h_dot2 : (q.x - O2.x) * n2.x + (q.y - O2.y) * n2.y =
                  (t * d.x + (-delta.x)) * n2.x + (t * d.y + (-delta.y)) * n2.y := by
                have hqx2 : q.x - O2.x = t * d.x + (-delta.x) := by simp only [delta]; linarith [htx]
                have hqy2 : q.y - O2.y = t * d.y + (-delta.y) := by simp only [delta]; linarith [hty]
                rw [hqx2, hqy2]
              rw [h_dot2] at h_hp2_nn
              have : (t * d.x + (-delta.x)) * n2.x + (t * d.y + (-delta.y)) * n2.y =
                  (t * d.x) * n2.x + (t * d.y) * n2.y + (-delta.x * n2.x + -delta.y * n2.y) := by ring
              rw [this, h_d_n2 t, h_neg_delta_n2] at h_hp2_nn
              simp at h_hp2_nn
              have h_hp3_nn : (q.x - O1.x) * n3.x + (q.y - O1.y) * n3.y ≥ 0 := by
                have := h_not_ext _ (Or.inr (Or.inr rfl))
                push_neg at this; exact this
              have h_dot3 : (q.x - O1.x) * n3.x + (q.y - O1.y) * n3.y = t * (d.x * n3.x + d.y * n3.y) := by
                rw [show q.x - O1.x = t * d.x from by linarith [htx],
                    show q.y - O1.y = t * d.y from by linarith [hty]]
                ring
              rw [h_dot3, h_d_n3] at h_hp3_nn
              have ht_nn : 0 ≤ t := by nlinarith [hκ_pos]
              left; left; exact ⟨t, ht_nn, htx, hty⟩
            · -- q on HP2 boundary
              have h_line := h_perp2 q hdot
              obtain ⟨t, htx, hty⟩ := egp_extract_line_param d O2 q hd_nz h_line
              have h_hp1_nn : (q.x - O1.x) * n1.x + (q.y - O1.y) * n1.y ≥ 0 := by
                have := h_not_ext _ (Or.inl rfl)
                push_neg at this; exact this
              have h_dot1 : (q.x - O1.x) * n1.x + (q.y - O1.y) * n1.y =
                  (t * d.x) * n1.x + (t * d.y) * n1.y + (delta.x * n1.x + delta.y * n1.y) := by
                have hqx : q.x - O1.x = t * d.x + delta.x := by simp only [delta]; linarith [htx]
                have hqy : q.y - O1.y = t * d.y + delta.y := by simp only [delta]; linarith [hty]
                rw [hqx, hqy]; ring
              rw [h_dot1, h_d_n1 t, h_delta_n1] at h_hp1_nn
              simp at h_hp1_nn
              have h_hp3_nn : (q.x - O1.x) * n3.x + (q.y - O1.y) * n3.y ≥ 0 := by
                have := h_not_ext _ (Or.inr (Or.inr rfl))
                push_neg at this; exact this
              have h_dot3 : (q.x - O1.x) * n3.x + (q.y - O1.y) * n3.y =
                  t * (d.x * n3.x + d.y * n3.y) + (delta.x * n3.x + delta.y * n3.y) := by
                have hqx : q.x - O1.x = t * d.x + delta.x := by simp only [delta]; linarith [htx]
                have hqy : q.y - O1.y = t * d.y + delta.y := by simp only [delta]; linarith [hty]
                rw [hqx, hqy]; ring
              rw [h_dot3, h_d_n3, h_dn3_zero] at h_hp3_nn
              simp at h_hp3_nn
              have ht_nn : 0 ≤ t := by nlinarith [hκ_pos]
              right; exact ⟨t, ht_nn, htx, hty⟩
            · -- q on HP3 boundary
              have h_line := h_perp3 q hdot
              obtain ⟨t, htx, hty⟩ := egp_extract_line_param delta O1 q
                (egp_sub_nonzero O1 O2 h_eq) h_line
              have h_hp1_nn : (q.x - O1.x) * n1.x + (q.y - O1.y) * n1.y ≥ 0 := by
                have := h_not_ext _ (Or.inl rfl)
                push_neg at this; exact this
              have h_dot1 : (q.x - O1.x) * n1.x + (q.y - O1.y) * n1.y =
                  t * (delta.x * n1.x + delta.y * n1.y) := by
                rw [show q.x - O1.x = t * delta.x from by linarith [htx],
                    show q.y - O1.y = t * delta.y from by linarith [hty]]
                ring
              rw [h_dot1, h_delta_n1] at h_hp1_nn
              have ht_nn : 0 ≤ t := by nlinarith [hκ_pos]
              have h_hp2_nn : (q.x - O2.x) * n2.x + (q.y - O2.y) * n2.y ≥ 0 := by
                have := h_not_ext _ (Or.inr (Or.inl rfl))
                push_neg at this; exact this
              have h_dot2 : (q.x - O2.x) * n2.x + (q.y - O2.y) * n2.y =
                  (t - 1) * (delta.x * n2.x + delta.y * n2.y) := by
                have hqx : q.x - O2.x = (t - 1) * delta.x := by simp only [delta]; (ring_nf at *; linarith [htx])
                have hqy : q.y - O2.y = (t - 1) * delta.y := by simp only [delta]; (ring_nf at *; linarith [hty])
                rw [hqx, hqy]; ring
              rw [h_dot2, h_delta_n2] at h_hp2_nn
              have ht_le : t ≤ 1 := by nlinarith [hκ_pos]
              left; right
              exact ⟨t, ht_nn, ht_le,
                by rw [htx]; ring,
                by rw [hty]; ring⟩
          · intro hq
            simp only [hpi_def, egp_par_rays_hpi, HalfPlaneIntersection.toBoundarySet,
              HalfPlane.toBoundarySet, HalfPlane.toExteriorSet, HalfPlane.dot,
              Set.mem_setOf_eq, List.mem_cons, (List.not_mem_nil _), or_false]
            rcases hq with (⟨t, ht, htx, hty⟩ | ⟨t, ht0, ht1, htx, hty⟩) | ⟨t, ht, htx, hty⟩
            · constructor
              · exact ⟨_, Or.inl rfl, by rw [htx, hty]; simp only; linarith [h_d_n1 t]⟩
              · intro hp hp_mem
                rcases hp_mem with rfl | rfl | rfl
                · intro h_neg; rw [htx, hty] at h_neg; simp only at h_neg; linarith [h_d_n1 t]
                · intro h_neg
                  have : (q.x - O2.x) * n2.x + (q.y - O2.y) * n2.y =
                      (t * d.x) * n2.x + (t * d.y) * n2.y + ((-delta.x) * n2.x + (-delta.y) * n2.y) := by
                    rw [show q.x - O2.x = t * d.x + (-delta.x) from by simp only [delta]; linarith [htx],
                        show q.y - O2.y = t * d.y + (-delta.y) from by simp only [delta]; linarith [hty]]; ring
                  rw [this, h_d_n2 t, h_neg_delta_n2] at h_neg; simp at h_neg; linarith [hκ_pos]
                · intro h_neg
                  have : (q.x - O1.x) * n3.x + (q.y - O1.y) * n3.y = t * (d.x * n3.x + d.y * n3.y) := by
                    rw [show q.x - O1.x = t * d.x from by linarith [htx],
                        show q.y - O1.y = t * d.y from by linarith [hty]]; ring
                  rw [this, h_d_n3] at h_neg; nlinarith [hκ_pos]
            · have hqx : q.x - O1.x = t * delta.x := by simp only [delta]; linarith [htx]
              have hqy : q.y - O1.y = t * delta.y := by simp only [delta]; linarith [hty]
              constructor
              · exact ⟨_, Or.inr (Or.inr rfl), by rw [hqx, hqy]; linarith [h_delta_n3 t]⟩
              · intro hp hp_mem
                rcases hp_mem with rfl | rfl | rfl
                · intro h_neg
                  have h_expand : (q.x - O1.x) * n1.x + (q.y - O1.y) * n1.y =
                      t * (delta.x * n1.x + delta.y * n1.y) := by rw [hqx, hqy]; ring
                  rw [h_expand, h_delta_n1] at h_neg; nlinarith [hκ_pos]
                · intro h_neg
                  have h_expand : (q.x - O2.x) * n2.x + (q.y - O2.y) * n2.y =
                      (t - 1) * (delta.x * n2.x + delta.y * n2.y) := by
                    have hqx2 : q.x - O2.x = (t - 1) * delta.x := by simp only [delta]; linarith [htx]
                    have hqy2 : q.y - O2.y = (t - 1) * delta.y := by simp only [delta]; linarith [hty]
                    rw [hqx2, hqy2]; ring
                  rw [h_expand, h_delta_n2] at h_neg; nlinarith [hκ_pos]
                · intro h_neg; rw [hqx, hqy] at h_neg; simp only at h_neg; (ring_nf at *; linarith [h_delta_n3 t])
            · have hqx1 : q.x - O1.x = t * d.x + delta.x := by simp only [delta]; linarith [htx]
              have hqy1 : q.y - O1.y = t * d.y + delta.y := by simp only [delta]; linarith [hty]
              constructor
              · exact ⟨_, Or.inr (Or.inl rfl), by rw [htx, hty]; simp only; linarith [h_d_n2 t]⟩
              · intro hp hp_mem
                rcases hp_mem with rfl | rfl | rfl
                · intro h_neg
                  have : (t * d.x + delta.x) * n1.x + (t * d.y + delta.y) * n1.y =
                      (t * d.x) * n1.x + (t * d.y) * n1.y + (delta.x * n1.x + delta.y * n1.y) := by ring
                  rw [hqx1, hqy1] at h_neg; simp only at h_neg; rw [this, h_d_n1 t, h_delta_n1] at h_neg
                  simp at h_neg; linarith [hκ_pos]
                · intro h_neg; rw [htx, hty] at h_neg; simp only at h_neg; linarith [h_d_n2 t]
                · intro h_neg
                  have h_expand : (q.x - O1.x) * n3.x + (q.y - O1.y) * n3.y =
                      t * κ + 0 := by
                    calc (q.x - O1.x) * n3.x + (q.y - O1.y) * n3.y
                        = (t * d.x + delta.x) * n3.x + (t * d.y + delta.y) * n3.y := by rw [hqx1, hqy1]
                      _ = t * (d.x * n3.x + d.y * n3.y) + (delta.x * n3.x + delta.y * n3.y) := by ring
                      _ = t * κ + 0 := by rw [h_d_n3, h_dn3_zero]
                  rw [h_expand] at h_neg; nlinarith [hκ_pos]
        have h_verts_avoid_hpi : ∀ v ∈ G.toVertices, v ∉ hpi.toBoundarySet := by
          rw [h_bnd]
          intro v hv hmem
          simp only [Set.mem_union] at hmem
          rcases hmem with (hr1' | hseg) | hr2'
          · -- v on r1': contradicts h_r1'_avoids
            rw [rayAvoidsGraphVertices] at h_r1'_avoids
            have hmem_r1' : v ∈ r1'.toSet ∩ G.toVertexSet := ⟨hr1', hv⟩
            rw [h_r1'_avoids] at hmem_r1'; exact hmem_r1'.elim
          · -- v on seg(O1,O2): use h_vert_avoids_seg
            exact h_vert_avoids_seg v hv hseg
          · -- v on r2': contradicts h_r2'_avoids
            rw [rayAvoidsGraphVertices] at h_r2'_avoids
            have hmem_r2' : v ∈ r2'.toSet ∩ G.toVertexSet := ⟨hr2', hv⟩
            rw [h_r2'_avoids] at hmem_r2'; exact hmem_r2'.elim
        -- Segments avoid HPI vertices (vertex set for 3-HP HPI = {O1, O2})
        have h_seg_av : ∀ seg ∈ G.segments, ∀ q ∈ seg.toSet,
            q ∉ hpi.toVertexSet := by
          intro seg hseg q hq_seg hq_vert
          simp only [hpi_def, egp_par_rays_hpi, HalfPlaneIntersection.toVertexSet, HalfPlane.toBoundarySet,
            HalfPlane.dot, Set.mem_setOf_eq, List.mem_cons, (List.not_mem_nil _), or_false] at hq_vert
          obtain ⟨hp_a, hp_a_mem, hp_b, hp_b_mem, hne, hdot_a, hdot_b⟩ := hq_vert
          -- The HPI vertex must be O1 or O2 (Cramer's rule argument)
          have h_det13 : n1.x * n3.y - n1.y * n3.x ≠ 0 := by
            simp only [n1, egp_par_n1, n3, egp_par_n3]
            split <;> (dsimp; intro h; apply h_nc; unfold egp_cross; ring_linarith)
          have h_det23 : n2.x * n3.y - n2.y * n3.x ≠ 0 := by
            simp only [n2, egp_par_n2, n3, egp_par_n3]
            split <;> (dsimp; intro h; apply h_nc; unfold egp_cross; ring_linarith)
          suffices hq_origin : q = O1 ∨ q = O2 by
            rcases hq_origin with rfl | rfl
            · exact h_O1_avoids seg hseg hq_seg
            · exact h_O2_avoids seg hseg hq_seg
          -- The 3 HPs: [HP1(O1,n1), HP2(O2,n2), HP3(O1,n3)]
          -- hp_a, hp_b are distinct elements from this list
          rcases hp_a_mem with rfl | rfl | rfl <;> rcases hp_b_mem with rfl | rfl | rfl
          · exact absurd rfl hne
          · -- HP1 + HP2: both on HP1 boundary → κ = 0, contradiction
            exfalso
            have h12 : (q.x - O1.x) * n1.x + (q.y - O1.y) * n1.y = 0 := hdot_a
            have h22 : (q.x - O2.x) * n2.x + (q.y - O2.y) * n2.y = 0 := hdot_b
            have hn_rel : n2.x = -n1.x ∧ n2.y = -n1.y := by
              simp only [n1, egp_par_n1, n2, egp_par_n2]; split <;> exact ⟨by ring, by ring⟩
            have h22' : (q.x - O2.x) * n1.x + (q.y - O2.y) * n1.y = 0 := by
              have : (q.x - O2.x) * (-n1.x) + (q.y - O2.y) * (-n1.y) = 0 := by
