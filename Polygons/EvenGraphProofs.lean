                  = n3.y * ((q.x - O2.x) * n2.x + (q.y - O2.y) * n2.y) -
                    n2.y * ((q.x - O2.x) * n3.x + (q.y - O2.y) * n3.y) := by ring
                _ = 0 := by rw [h22, h32']; ring)).resolve_right h_det23
            have hdy : q.y - O2.y = 0 :=
