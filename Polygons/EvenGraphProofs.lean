/-!
# Even Graph Proofs

Proofs for the interior and parity theorems of even graphs.

## Proof strategy

**Parity invariance** (same-origin rays):
An even graph can be decomposed into edge-disjoint cycles (since every
vertex has even degree). Each cycle is a polygon. The crossing count for the
graph is the sum of crossing counts over the individual polygons. Since the
polygon parity theorem (`intersectionParity_eq_of_sameOrigin_avoidsVertices`)
shows each polygon's parity is invariant, the total parity is invariant.

**Parity invariance** (connected origins):
Similarly decomposes into polygon parity via
`intersectionParity_eq_of_originSegmentAvoidsSegments`.

**Interior forall ↔ exists**: Once parity invariance is established,
the proof follows the same structure as `PolygonProofs.interior_forall_eq_exists`.

**Polygon-to-graph equivalence**: A polygon with ≥ 2 distinct consecutive
vertices forms an even graph with degree 2 at every vertex. The boundary
and interior coincide by construction.

**HPI crossings even**: Follows from the polygon version by cycle decomposition.
-/

open Classical Set List

noncomputable section

/-! ### Basic facts about `Graph.toVertices` -/

/-- If `seg ∈ G.segments`, then `seg.p1 ∈ G.toVertices`. -/
theorem EvenGraph.p1_mem_toVertices (G : EvenGraph) {seg : LineSegment}
    (hseg : seg ∈ G.segments) : seg.p1 ∈ G.toVertices := by
  simp only [Graph.toVertices, List.mem_dedup, List.mem_flatMap, List.mem_cons,
             (List.not_mem_nil _), or_false]
  exact ⟨seg, hseg, Or.inl rfl⟩

/-- If `seg ∈ G.segments`, then `seg.p2 ∈ G.toVertices`. -/
theorem EvenGraph.p2_mem_toVertices (G : EvenGraph) {seg : LineSegment}
    (hseg : seg ∈ G.segments) : seg.p2 ∈ G.toVertices := by
  simp only [Graph.toVertices, List.mem_dedup, List.mem_flatMap, List.mem_cons,
             (List.not_mem_nil _), or_false]
  exact ⟨seg, hseg, Or.inr rfl⟩

/-- Membership in `toVertices` unfolded to the existence of an incident segment. -/
theorem EvenGraph.mem_toVertices_iff (G : EvenGraph) (v : Vector2D) :
    v ∈ G.toVertices ↔ ∃ seg ∈ G.segments, seg.p1 = v ∨ seg.p2 = v := by
  simp only [Graph.toVertices, List.mem_dedup, List.mem_flatMap, List.mem_cons,
             (List.not_mem_nil _), or_false]
  constructor
  · rintro ⟨seg, hseg, rfl | rfl⟩
    · exact ⟨seg, hseg, Or.inl rfl⟩
    · exact ⟨seg, hseg, Or.inr rfl⟩
  · rintro ⟨seg, hseg, rfl | rfl⟩
    · exact ⟨seg, hseg, Or.inl rfl⟩
    · exact ⟨seg, hseg, Or.inr rfl⟩

/-- `toVertices` has no duplicates. -/
theorem EvenGraph.toVertices_nodup (G : EvenGraph) : G.toVertices.Nodup :=
  List.nodup_dedup _

/-- For any segment of an even graph, both endpoints lie in `toVertices`. -/
theorem EvenGraph.segments_endpoints (G : EvenGraph) (seg : LineSegment)
    (hseg : seg ∈ G.segments) : seg.p1 ∈ G.toVertices ∧ seg.p2 ∈ G.toVertices :=
  ⟨G.p1_mem_toVertices hseg, G.p2_mem_toVertices hseg⟩

/-- Every vertex of an even graph has at least one incident segment.
    This is immediate from the definition of `toVertices`: membership means
    the vertex appears as an endpoint of some segment. -/
theorem EvenGraph.incident_count_pos (G : EvenGraph) (v : Vector2D)
    (hv : v ∈ G.toVertices) :
    (G.segments.countP fun seg => seg.p1 = v ∨ seg.p2 = v) > 0 := by
  rw [G.mem_toVertices_iff] at hv
  obtain ⟨seg, h_mem, h_pred⟩ := hv
  exact List.countP_pos_iff.mpr ⟨seg, h_mem, by simp [h_pred]⟩

