              have h_line_p1 : (seg.p1.x - O1.x) * d.y = (seg.p1.y - O1.y) * d.x := by
                have h0 : (seg.p1.x - O1.x) * n1.x + (seg.p1.y - O1.y) * n1.y = 0 := h_nd1.1
                simp only [n1, egp_par_n1] at h0; split at h0 <;> ring_linarith
              obtain ⟨tp1, htp1x, htp1y⟩ := egp_extract_line_param d O1 seg.p1 hd_nz h_line_p1
              -- (seg.p1 - O1) · n3 = tp1 * κ < 0 (since seg.p1 not on r1' boundary)
              have h_tp1_n3 : (seg.p1.x - O1.x) * n3.x + (seg.p1.y - O1.y) * n3.y = tp1 * κ := by
                calc (seg.p1.x - O1.x) * n3.x + (seg.p1.y - O1.y) * n3.y
                    = (tp1 * d.x) * n3.x + (tp1 * d.y) * n3.y := by
                        rw [show seg.p1.x - O1.x = tp1 * d.x from by linarith,
                            show seg.p1.y - O1.y = tp1 * d.y from by linarith]
                  _ = tp1 * (d.x * n3.x + d.y * n3.y) := by ring
                  _ = tp1 * κ := by rw [h_d_n3]
              have h_tp1_neg : tp1 < 0 := by
                by_contra h_nn; push_neg at h_nn
                exact absurd (show seg.p1 ∈ hpi.toBoundarySet from by
                  rw [h_bnd]; exact Set.mem_union_left _ (Set.mem_union_left _ ⟨tp1, h_nn, htp1x, htp1y⟩)) h_p1_not_bnd
              have h_line_p2 : (seg.p2.x - O1.x) * d.y = (seg.p2.y - O1.y) * d.x := by
                have h0 : (seg.p2.x - O1.x) * n1.x + (seg.p2.y - O1.y) * n1.y = 0 := h_nd1.2
                simp only [n1, egp_par_n1] at h0; split at h0 <;> ring_linarith
              obtain ⟨tp2, htp2x, htp2y⟩ := egp_extract_line_param d O1 seg.p2 hd_nz h_line_p2
              have h_tp2_n3 : (seg.p2.x - O1.x) * n3.x + (seg.p2.y - O1.y) * n3.y = tp2 * κ := by
                calc (seg.p2.x - O1.x) * n3.x + (seg.p2.y - O1.y) * n3.y
                    = (tp2 * d.x) * n3.x + (tp2 * d.y) * n3.y := by
                        rw [show seg.p2.x - O1.x = tp2 * d.x from by linarith,
                            show seg.p2.y - O1.y = tp2 * d.y from by linarith]
                  _ = tp2 * (d.x * n3.x + d.y * n3.y) := by ring
                  _ = tp2 * κ := by rw [h_d_n3]
              have h_tp2_neg : tp2 < 0 := by
                by_contra h_nn; push_neg at h_nn
                exact absurd (show seg.p2 ∈ hpi.toBoundarySet from by
                  rw [h_bnd]; exact Set.mem_union_left _ (Set.mem_union_left _ ⟨tp2, h_nn, htp2x, htp2y⟩)) h_p2_not_bnd
              obtain ⟨s, hs0, hs1, hsx, hsy⟩ := hq1_seg
              have h_q1_n3' : (q1.x - O1.x) * n3.x + (q1.y - O1.y) * n3.y =
                  (1 - s) * (tp1 * κ) + s * (tp2 * κ) := by
                calc (q1.x - O1.x) * n3.x + (q1.y - O1.y) * n3.y
                    = (1 - s) * ((seg.p1.x - O1.x) * n3.x + (seg.p1.y - O1.y) * n3.y) +
                      s * ((seg.p2.x - O1.x) * n3.x + (seg.p2.y - O1.y) * n3.y) := by
                        rw [show q1.x - O1.x = (1 - s) * (seg.p1.x - O1.x) + s * (seg.p2.x - O1.x) from by linarith,
                            show q1.y - O1.y = (1 - s) * (seg.p1.y - O1.y) + s * (seg.p2.y - O1.y) from by linarith]
                        ring
                  _ = (1 - s) * (tp1 * κ) + s * (tp2 * κ) := by rw [h_tp1_n3, h_tp2_n3]
              have h_lhs_pos : t * κ > 0 := mul_pos h_tpos hκ_pos
              nlinarith [mul_neg_of_neg_of_pos h_tp1_neg hκ_pos, mul_neg_of_neg_of_pos h_tp2_neg hκ_pos,
                mul_nonneg (show (1 : ℚ) - s ≥ 0 from by linarith) (le_refl (0 : ℚ))]
          -- seg ∩ r2' is subsingleton
          have h_seg_r2_sub : (seg.toSet ∩ r2'.toSet).Subsingleton := by
            let hp2' : HalfPlane := ⟨O2, n2, egp_par_n2_nonzero d delta hd_nz⟩
            have h_r2_bnd : r2'.toSet ⊆ hp2'.toBoundarySet := by
              intro q ⟨t, _, htx, hty⟩
              show (q.x - O2.x) * n2.x + (q.y - O2.y) * n2.y = 0
