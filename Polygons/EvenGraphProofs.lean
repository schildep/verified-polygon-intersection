                linarith [mul_pos h_tpos hκ_pos]
              have h_line_p1 : (seg.p1.x - O2.x) * d.y = (seg.p1.y - O2.y) * d.x := by
                have h0 : (seg.p1.x - O2.x) * n2.x + (seg.p1.y - O2.y) * n2.y = 0 := h_nd2.1
                simp only [n2, egp_par_n2] at h0; split at h0 <;> ring_linarith
              obtain ⟨tp1, htp1x, htp1y⟩ := egp_extract_line_param d O2 seg.p1 hd_nz h_line_p1
              -- (seg.p1 - O1) · n3 = (tp1 * d + delta) · n3 = tp1 * κ
              have h_tp1_n3 : (seg.p1.x - O1.x) * n3.x + (seg.p1.y - O1.y) * n3.y = tp1 * κ := by
                have hqx : seg.p1.x - O1.x = tp1 * d.x + delta.x := by simp only [delta]; linarith [htp1x]
                have hqy : seg.p1.y - O1.y = tp1 * d.y + delta.y := by simp only [delta]; linarith [htp1y]
                calc (seg.p1.x - O1.x) * n3.x + (seg.p1.y - O1.y) * n3.y
                    = (tp1 * d.x + delta.x) * n3.x + (tp1 * d.y + delta.y) * n3.y := by rw [hqx, hqy]
                  _ = tp1 * (d.x * n3.x + d.y * n3.y) + (delta.x * n3.x + delta.y * n3.y) := by ring
                  _ = tp1 * κ + 0 := by rw [h_d_n3, h_dn3_zero]
                  _ = tp1 * κ := by ring
              have h_tp1_neg : tp1 < 0 := by
                by_contra h_nn; push_neg at h_nn
                exact absurd (show seg.p1 ∈ hpi.toBoundarySet from by
                  rw [h_bnd]; exact Set.mem_union_right _ ⟨tp1, h_nn, htp1x, htp1y⟩) h_p1_not_bnd
              have h_line_p2 : (seg.p2.x - O2.x) * d.y = (seg.p2.y - O2.y) * d.x := by
                have h0 : (seg.p2.x - O2.x) * n2.x + (seg.p2.y - O2.y) * n2.y = 0 := h_nd2.2
                simp only [n2, egp_par_n2] at h0; split at h0 <;> ring_linarith
              obtain ⟨tp2, htp2x, htp2y⟩ := egp_extract_line_param d O2 seg.p2 hd_nz h_line_p2
              have h_tp2_n3 : (seg.p2.x - O1.x) * n3.x + (seg.p2.y - O1.y) * n3.y = tp2 * κ := by
                have hqx : seg.p2.x - O1.x = tp2 * d.x + delta.x := by simp only [delta]; linarith [htp2x]
                have hqy : seg.p2.y - O1.y = tp2 * d.y + delta.y := by simp only [delta]; linarith [htp2y]
                calc (seg.p2.x - O1.x) * n3.x + (seg.p2.y - O1.y) * n3.y
                    = (tp2 * d.x + delta.x) * n3.x + (tp2 * d.y + delta.y) * n3.y := by rw [hqx, hqy]
                  _ = tp2 * (d.x * n3.x + d.y * n3.y) + (delta.x * n3.x + delta.y * n3.y) := by ring
                  _ = tp2 * κ + 0 := by rw [h_d_n3, h_dn3_zero]
                  _ = tp2 * κ := by ring
              have h_tp2_neg : tp2 < 0 := by
                by_contra h_nn; push_neg at h_nn
                exact absurd (show seg.p2 ∈ hpi.toBoundarySet from by
                  rw [h_bnd]; exact Set.mem_union_right _ ⟨tp2, h_nn, htp2x, htp2y⟩) h_p2_not_bnd
              obtain ⟨s, hs0, hs1, hsx, hsy⟩ := hq1_seg
              have h_q1_n3' : (q1.x - O1.x) * n3.x + (q1.y - O1.y) * n3.y =
                  (1 - s) * (tp1 * κ) + s * (tp2 * κ) := by
                calc (q1.x - O1.x) * n3.x + (q1.y - O1.y) * n3.y
                    = (1 - s) * ((seg.p1.x - O1.x) * n3.x + (seg.p1.y - O1.y) * n3.y) +
                      s * ((seg.p2.x - O1.x) * n3.x + (seg.p2.y - O1.y) * n3.y) := by
                        rw [show q1.x - O1.x = (1 - s) * (seg.p1.x - O1.x) + s * (seg.p2.x - O1.x) from by linarith,
                            show q1.y - O1.y = (1 - s) * (seg.p1.y - O1.y) + s * (seg.p2.y - O1.y) from by linarith]
                        ring
                  _ = (1 - s) * (tp1 * κ) + s * (tp2 * κ) := by rw [h_tp1_n3, h_tp2_n3]
              nlinarith [h_q1_n3_pos, h_q1_n3',
                mul_neg_of_neg_of_pos h_tp1_neg hκ_pos,
                mul_neg_of_neg_of_pos h_tp2_neg hκ_pos,
                mul_nonneg (show (1:ℚ) - s ≥ 0 from by linarith) (le_refl (0:ℚ))]
          -- Combine: seg crossings = count(r1') + count(r2')
          have h_cross_split : seg.boundaryCrossings hpi =
              (seg.toSet ∩ r1'.toSet) ∪ (seg.toSet ∩ r2'.toSet) := h_cross_union
          have h_fin_r1 : (seg.toSet ∩ r1'.toSet).Finite := h_seg_r1_sub.finite
          have h_fin_r2 : (seg.toSet ∩ r2'.toSet).Finite := h_seg_r2_sub.finite
          have h_disj : Disjoint h_fin_r1.toFinset h_fin_r2.toFinset := by
            rw [Finset.disjoint_left]; intro q hq1 hq2
            exact h_r1r2_disj_on_seg q (h_fin_r1.mem_toFinset.mp hq1).1
              (h_fin_r1.mem_toFinset.mp hq1).2 (h_fin_r2.mem_toFinset.mp hq2).2
          have h_tofinset : h_fin.toFinset = h_fin_r1.toFinset ∪ h_fin_r2.toFinset := by
            ext q; simp only [Set.Finite.mem_toFinset, Finset.mem_union, h_cross_split, Set.mem_union]
          rw [h_cc, h_tofinset, Finset.card_union_of_disjoint h_disj]
          congr 1
          · by_cases hr1 : rayIntersectsSegment r1' seg
            · rw [if_pos (decide_eq_true hr1)]
              have h_ne : (seg.toSet ∩ r1'.toSet).Nonempty := by
                obtain ⟨q, hq1, hq2⟩ := hr1; exact ⟨q, hq2, hq1⟩
              linarith [egp_subsingleton_card _ h_fin_r1 h_seg_r1_sub,
                        egp_nonempty_card _ h_fin_r1 h_ne]
            · have hd1 : ¬(decide (rayIntersectsSegment r1' seg) = true) :=
                fun h => hr1 (of_decide_eq_true h)
              rw [if_neg hd1, Finset.card_eq_zero, Finset.eq_empty_iff_forall_not_mem]
              intro q hq
              exact hr1 ⟨q, (h_fin_r1.mem_toFinset.mp hq).2, (h_fin_r1.mem_toFinset.mp hq).1⟩
          · by_cases hr2 : rayIntersectsSegment r2' seg
            · rw [if_pos (decide_eq_true hr2)]
              have h_ne : (seg.toSet ∩ r2'.toSet).Nonempty := by
                obtain ⟨q, hq1, hq2⟩ := hr2; exact ⟨q, hq2, hq1⟩
              linarith [egp_subsingleton_card _ h_fin_r2 h_seg_r2_sub,
                        egp_nonempty_card _ h_fin_r2 h_ne]
            · have hd2 : ¬(decide (rayIntersectsSegment r2' seg) = true) :=
                fun h => hr2 (of_decide_eq_true h)
              rw [if_neg hd2, Finset.card_eq_zero, Finset.eq_empty_iff_forall_not_mem]
              intro q hq
              exact hr2 ⟨q, (h_fin_r2.mem_toFinset.mp hq).2, (h_fin_r2.mem_toFinset.mp hq).1⟩
        -- Use h_even_total and h_total_eq to derive parity equality
        rw [h_total_eq] at h_even_total
        obtain ⟨k, hk⟩ := h_even_total
        omega
      rw [h_step1, h_step2, h_step3]

/-! ### Interior: forall ↔ exists -/

/-- Any point not on a graph vertex admits a ray that avoids all vertices. -/
private lemma exists_ray_avoiding_graph_vertices (p : Vector2D) (G : EvenGraph)
    (h_not_vertex : ∀ v ∈ G.toVertices, v ≠ p) :
    ∃ r : Ray, r.origin = p ∧ rayAvoidsGraphVertices r G := by
  -- Same construction as PolygonProofs.exists_ray_avoiding_vertices:
  -- choose direction (1, q) with q avoiding finitely many bad slopes.
  have : Infinite ℚ := Infinite.of_injective (fun n : ℕ => (n : ℚ)) Nat.cast_injective
  let badSlopes : Finset ℚ := (G.toVertices.filterMap fun v =>
    if v.x > p.x then some ((v.y - p.y) / (v.x - p.x)) else none).toFinset
  obtain ⟨q, hq⟩ := Finset.exists_not_mem badSlopes
  have h_nonzero : (⟨1, q⟩ : Vector2D) ≠ ⟨0, 0⟩ := by
    intro h; exact absurd (congrArg Vector2D.x h) (by norm_num)
  refine ⟨⟨p, ⟨1, q⟩, h_nonzero⟩, rfl, ?_⟩
  rw [rayAvoidsGraphVertices, Set.eq_empty_iff_forall_not_mem]
  intro v hv
  simp only [Set.mem_inter_iff] at hv
  obtain ⟨hv_ray, hv_vert⟩ := hv
  simp only [Ray.toSet, Set.mem_setOf_eq] at hv_ray
  simp only [Graph.toVertexSet, Set.mem_setOf_eq] at hv_vert
  obtain ⟨t, ht_nonneg, hvx, hvy⟩ := hv_ray
  simp only [mul_one] at hvx
  have hne : v ≠ p := h_not_vertex v hv_vert
  have ht_eq : t = v.x - p.x := by linarith
  by_cases h_gt : v.x > p.x
  · have h_slope_mem : (v.y - p.y) / (v.x - p.x) ∈ badSlopes := by
      simp only [badSlopes, List.mem_toFinset, List.mem_filterMap]
      exact ⟨v, hv_vert, by simp [if_pos h_gt]⟩
    have hvmy : v.y - p.y = t * q := by linarith
    rw [ht_eq] at hvmy
    have hvx_ne : v.x - p.x ≠ 0 := ne_of_gt (by linarith : v.x - p.x > 0)
    have hq_eq : q = (v.y - p.y) / (v.x - p.x) := by
      rw [eq_div_iff hvx_ne, mul_comm]; linarith
    exact hq (hq_eq ▸ h_slope_mem)
  · push_neg at h_gt
    by_cases h_eq : v.x = p.x
    · have ht_zero : t = 0 := by linarith
      have hvy_eq : v.y = p.y := by
        have := hvy; rw [ht_zero] at this; simp at this; exact this
      exact hne (by cases v; cases p; simp_all)
    · linarith [lt_of_le_of_ne h_gt h_eq]

/-- If a vertex has positive degree, it lies on some segment of the graph. -/
private lemma vertex_on_some_graph_segment (G : EvenGraph) (v : Vector2D)
    (h_degree_pos : (G.segments.countP fun seg => seg.p1 = v ∨ seg.p2 = v) > 0) :
    ∃ seg ∈ G.segments, v ∈ seg.toSet := by
  -- countP > 0 means there exists a segment with v as endpoint
  have ⟨seg, h_mem, h_pred⟩ := List.countP_pos_iff.mp h_degree_pos
  simp only [decide_eq_true_eq] at h_pred
  refine ⟨seg, h_mem, ?_⟩
  rcases h_pred with rfl | rfl
  · exact ⟨0, le_refl 0, zero_le_one, by ring, by ring⟩
  · exact ⟨1, zero_le_one, le_refl 1, by ring, by ring⟩

theorem interior_forall_eq_exists (G : EvenGraph) :
    { p : Vector2D |
        (∀ seg ∈ G.segments, pointAvoidsSegment p seg) ∧
        ∀ r : Ray, r.origin = p → rayAvoidsGraphVertices r G →
          intersectionRayGraphSegmentsNumber r G % 2 = 1 } =
    { p : Vector2D |
        (∀ seg ∈ G.segments, pointAvoidsSegment p seg) ∧
        ∃ r : Ray, r.origin = p ∧ rayAvoidsGraphVertices r G ∧
          intersectionRayGraphSegmentsNumber r G % 2 = 1 } := by
  ext p
  simp only [mem_setOf_eq]
  constructor
  · -- forall → exists: construct a witness ray
    intro ⟨h_avoids_segs, h_forall⟩
    have h_not_vertex : ∀ v ∈ G.toVertices, v ≠ p := by
      intro v hv h_eq; subst h_eq
      obtain ⟨seg, h_seg, h_on⟩ :=
        vertex_on_some_graph_segment G v (G.incident_count_pos v hv)
      exact h_avoids_segs seg h_seg h_on
    obtain ⟨r, h_origin, h_avoids_verts⟩ := exists_ray_avoiding_graph_vertices p G h_not_vertex
    exact ⟨h_avoids_segs, r, h_origin, h_avoids_verts, h_forall r h_origin h_avoids_verts⟩
  · -- exists → forall: use parity invariance
    intro ⟨h_avoids_segs, r₀, h_origin₀, h_avoids₀, h_parity₀⟩
    refine ⟨h_avoids_segs, fun r h_origin h_avoids => ?_⟩
    have h_same : sameOrigin r₀ r := by
      simp [sameOrigin, h_origin₀, h_origin]
    have h_seg_avoids : ∀ seg ∈ G.segments, pointAvoidsSegment r₀.origin seg := by
      rwa [h_origin₀]
    have h_eq := intersectionParity_eq_of_sameOrigin_avoidsGraphVertices r₀ r G
      h_same h_avoids₀ h_avoids h_seg_avoids
    omega

/-- Generalization of `exists_ray_avoiding_graph_vertices` to two graphs: there
    is a ray from `p` avoiding the vertices of both `G` and `G'`. -/
private lemma exists_ray_avoiding_two_graph_vertices (p : Vector2D) (G G' : EvenGraph)
    (h_not_vertex : ∀ v ∈ (G.toVertices ++ G'.toVertices), v ≠ p) :
    ∃ r : Ray, r.origin = p ∧ rayAvoidsGraphVertices r G ∧ rayAvoidsGraphVertices r G' := by
  -- Same construction as `exists_ray_avoiding_graph_vertices`, but the bad slopes
  -- are collected from the union of the two vertex lists.
  have : Infinite ℚ := Infinite.of_injective (fun n : ℕ => (n : ℚ)) Nat.cast_injective
  let badSlopes : Finset ℚ := ((G.toVertices ++ G'.toVertices).filterMap fun v =>
    if v.x > p.x then some ((v.y - p.y) / (v.x - p.x)) else none).toFinset
  obtain ⟨q, hq⟩ := Finset.exists_not_mem badSlopes
  have h_nonzero : (⟨1, q⟩ : Vector2D) ≠ ⟨0, 0⟩ := by
    intro h; exact absurd (congrArg Vector2D.x h) (by norm_num)
  refine ⟨⟨p, ⟨1, q⟩, h_nonzero⟩, rfl, ?_, ?_⟩ <;>
    (rw [rayAvoidsGraphVertices, Set.eq_empty_iff_forall_not_mem]
     intro v hv
     simp only [Set.mem_inter_iff] at hv
     obtain ⟨hv_ray, hv_vert⟩ := hv
     simp only [Ray.toSet, Set.mem_setOf_eq] at hv_ray
     simp only [Graph.toVertexSet, Set.mem_setOf_eq] at hv_vert
     obtain ⟨t, ht_nonneg, hvx, hvy⟩ := hv_ray
     simp only [mul_one] at hvx
     have hv_mem : v ∈ (G.toVertices ++ G'.toVertices) := by
       simp only [List.mem_append]
       first | exact Or.inl hv_vert | exact Or.inr hv_vert
     have hne : v ≠ p := h_not_vertex v hv_mem
     have ht_eq : t = v.x - p.x := by linarith
     by_cases h_gt : v.x > p.x
     · have h_slope_mem : (v.y - p.y) / (v.x - p.x) ∈ badSlopes := by
         simp only [badSlopes, List.mem_toFinset, List.mem_filterMap]
         exact ⟨v, hv_mem, by simp [if_pos h_gt]⟩
       have hvmy : v.y - p.y = t * q := by linarith
       rw [ht_eq] at hvmy
       have hvx_ne : v.x - p.x ≠ 0 := ne_of_gt (by linarith : v.x - p.x > 0)
       have hq_eq : q = (v.y - p.y) / (v.x - p.x) := by
         rw [eq_div_iff hvx_ne, mul_comm]; linarith
       exact hq (hq_eq ▸ h_slope_mem)
     · push_neg at h_gt
       by_cases h_eq : v.x = p.x
       · have ht_zero : t = 0 := by linarith
         have hvy_eq : v.y = p.y := by
           have := hvy; rw [ht_zero] at this; simp at this; exact this
         exact hne (by cases v; cases p; simp_all)
       · linarith [lt_of_le_of_ne h_gt h_eq])

/-- If two even graphs have the same boundary and the same parity (for all rays
    that avoid both graphs' vertices and start off the common boundary), then
    they have the same interior. -/
theorem interior_eq_of_boundary_and_parity (G G' : EvenGraph)
    (h_bd : G.toBoundarySet = G'.toBoundarySet)
    (h_par : ∀ r : Ray,
        rayAvoidsGraphVertices r G → rayAvoidsGraphVertices r G' →
        (∀ seg ∈ G.segments, pointAvoidsSegment r.origin seg) →
        intersectionRayGraphSegmentsNumber r G % 2 =
          intersectionRayGraphSegmentsNumber r G' % 2) :
    G.interior = G'.interior := by
  -- A point avoids all segments of a graph iff it is off the graph's boundary.
  have avoids_iff : ∀ (H : EvenGraph) (p : Vector2D),
      (∀ seg ∈ H.segments, pointAvoidsSegment p seg) ↔ p ∉ H.toBoundarySet := by
    intro H p
    simp only [pointAvoidsSegment, Graph.toBoundarySet, Set.mem_setOf_eq]
    constructor
    · intro h
      rintro ⟨seg, hseg, hp⟩
      exact h seg hseg hp
    · intro h seg hseg hp
      exact h ⟨seg, hseg, hp⟩
  -- A point off the boundary is not equal to any vertex (vertices lie on segments).
  have not_vertex_of_avoids : ∀ (H : EvenGraph) (p : Vector2D),
      p ∉ H.toBoundarySet → ∀ v ∈ H.toVertices, v ≠ p := by
    intro H p hp v hv h_eq
    subst h_eq
    obtain ⟨seg, h_seg, h_on⟩ :=
      vertex_on_some_graph_segment H v (H.incident_count_pos v hv)
    exact hp ⟨seg, h_seg, h_on⟩
  -- The interior is the FORALL-set by definition.
  have interior_def : ∀ (H : EvenGraph), H.interior =
      { p : Vector2D |
          (∀ seg ∈ H.segments, pointAvoidsSegment p seg) ∧
          ∀ r : Ray, r.origin = p → rayAvoidsGraphVertices r H →
            intersectionRayGraphSegmentsNumber r H % 2 = 1 } := fun H => rfl
  -- Symmetric helper proving one inclusion. `h_par'` is `h_par` possibly swapped.
  have one_dir : ∀ (A B : EvenGraph),
      A.toBoundarySet = B.toBoundarySet →
      (∀ r : Ray, rayAvoidsGraphVertices r A → rayAvoidsGraphVertices r B →
        (∀ seg ∈ A.segments, pointAvoidsSegment r.origin seg) →
        intersectionRayGraphSegmentsNumber r A % 2 =
          intersectionRayGraphSegmentsNumber r B % 2) →
      A.interior ⊆ B.interior := by
    intro A B hAB hpar p hp
    rw [interior_def A, Set.mem_setOf_eq] at hp
    obtain ⟨h_avoidA, h_forallA⟩ := hp
    -- p is off A's boundary, hence off B's boundary.
    have hp_notA : p ∉ A.toBoundarySet := (avoids_iff A p).mp h_avoidA
    have hp_notB : p ∉ B.toBoundarySet := by rw [← hAB]; exact hp_notA
    have h_avoidB : ∀ seg ∈ B.segments, pointAvoidsSegment p seg :=
      (avoids_iff B p).mpr hp_notB
    -- p is not a vertex of A or B.
    have h_not_vertex : ∀ v ∈ (A.toVertices ++ B.toVertices), v ≠ p := by
      intro v hv
      rcases List.mem_append.mp hv with hvA | hvB
      · exact not_vertex_of_avoids A p hp_notA v hvA
      · exact not_vertex_of_avoids B p hp_notB v hvB
    -- A ray from p avoiding both graphs' vertices.
    obtain ⟨r, h_origin, h_avoids_r_A, h_avoids_r_B⟩ :=
      exists_ray_avoiding_two_graph_vertices p A B h_not_vertex
    -- That ray has odd parity for A (from membership of p), transferred to B.
    have h_oddA : intersectionRayGraphSegmentsNumber r A % 2 = 1 :=
      h_forallA r h_origin h_avoids_r_A
    have h_seg_avoids_r : ∀ seg ∈ A.segments, pointAvoidsSegment r.origin seg := by
      rw [h_origin]; exact h_avoidA
    have h_parB : intersectionRayGraphSegmentsNumber r B % 2 = 1 := by
      have := hpar r h_avoids_r_A h_avoids_r_B h_seg_avoids_r
      omega
    -- Conclude membership in B's interior via the EXISTS characterization.
    rw [interior_def B, interior_forall_eq_exists B, Set.mem_setOf_eq]
    exact ⟨h_avoidB, r, h_origin, h_avoids_r_B, h_parB⟩
  apply Set.Subset.antisymm
  · exact one_dir G G' h_bd h_par
  · refine one_dir G' G h_bd.symm ?_
    intro r h_avoidsG' h_avoidsG h_seg
    -- Need parity equality with A = G', B = G; `h_par` needs the avoid-G hypothesis.
    -- `h_seg` avoids G' segments; transfer to G segments via equal boundaries.
    have h_seg_G : ∀ seg ∈ G.segments, pointAvoidsSegment r.origin seg := by
      have hnotG' : r.origin ∉ G'.toBoundarySet := (avoids_iff G' r.origin).mp h_seg
      have hnotG : r.origin ∉ G.toBoundarySet := by rw [h_bd]; exact hnotG'
      exact (avoids_iff G r.origin).mpr hnotG
    have := h_par r h_avoidsG h_avoidsG' h_seg_G
    omega

/-! ### Polygon to even graph -/

/-- Helper: elements of the zip-pairs from polygon segment construction
    have their first component in the vertex list. -/
private lemma zip_fst_mem (v : Vector2D) (vs : List Vector2D)
    (seg : LineSegment) (h : seg ∈ (List.zip (v :: vs) (vs ++ [v])).map fun (a, b) => LineSegment.mk a b) :
    seg.p1 ∈ (v :: vs) := by
  simp only [List.mem_map, Prod.exists] at h
  obtain ⟨a, b, hab, rfl⟩ := h
  have : a ∈ (List.zip (v :: vs) (vs ++ [v])).map Prod.fst :=
    List.mem_map.mpr ⟨(a, b), hab, rfl⟩
  rwa [List.map_fst_zip (v :: vs) (vs ++ [v]) (by simp [List.length_append])] at this

/-- Helper: elements of the zip-pairs from polygon segment construction
    have their second component in the vertex list. -/
private lemma zip_snd_mem (v : Vector2D) (vs : List Vector2D)
    (seg : LineSegment) (h : seg ∈ (List.zip (v :: vs) (vs ++ [v])).map fun (a, b) => LineSegment.mk a b) :
    seg.p2 ∈ (v :: vs) := by
  simp only [List.mem_map, Prod.exists] at h
  obtain ⟨a, b, hab, rfl⟩ := h
  have : b ∈ (List.zip (v :: vs) (vs ++ [v])).map Prod.snd :=
    List.mem_map.mpr ⟨(a, b), hab, rfl⟩
  rw [List.map_snd_zip (v :: vs) (vs ++ [v]) (by simp)] at this
  simp only [List.mem_append, List.mem_singleton] at this
  rcases this with hb | rfl
  · exact List.mem_cons_of_mem _ hb
  · exact (List.mem_cons_self _ _)

private lemma countP_or_of_disjoint (l : List LineSegment)
    (h_ne : ∀ seg ∈ l, seg.p1 ≠ seg.p2)
    (u : Vector2D) :
    l.countP (fun seg => decide (seg.p1 = u ∨ seg.p2 = u)) =
    l.countP (fun seg => decide (seg.p1 = u)) +
    l.countP (fun seg => decide (seg.p2 = u)) := by
  induction l with
  | nil => simp
  | cons seg tl ih =>
    have h_ne_tl : ∀ seg ∈ tl, seg.p1 ≠ seg.p2 :=
      fun s hs => h_ne s (List.mem_cons.mpr (Or.inr hs))
    simp only [List.countP_cons]
    rw [ih h_ne_tl]
    have h_seg_ne := h_ne seg (List.mem_cons_self _ _)
    -- The decide values for the three predicates on seg
    -- Case analysis on the decide results
    by_cases h1 : seg.p1 = u
    · have h2 : seg.p2 ≠ u := fun h => h_seg_ne (h1 ▸ h.symm)
      simp [h1, h2]; omega
    · by_cases h2 : seg.p2 = u
      · simp [h1, h2]; omega
      · simp [h1, h2]

private lemma countP_zip_fst_eq {l1 l2 : List Vector2D} (u : Vector2D)
    (h_len : l1.length = l2.length) :
    ((l1.zip l2).map fun (a, b) => (⟨a, b⟩ : LineSegment)).countP
      (fun seg => decide (seg.p1 = u)) =
    l1.countP (fun x => decide (x = u)) := by
  induction l1 generalizing l2 with
  | nil => simp
  | cons a1 t1 ih =>
    cases l2 with
    | nil => simp at h_len
    | cons a2 t2 =>
      simp only [List.zip_cons_cons, List.map_cons, List.countP_cons]
      rw [ih (by simpa using h_len)]

private lemma countP_zip_snd_eq {l1 l2 : List Vector2D} (u : Vector2D)
    (h_len : l1.length = l2.length) :
    ((l1.zip l2).map fun (a, b) => (⟨a, b⟩ : LineSegment)).countP
      (fun seg => decide (seg.p2 = u)) =
    l2.countP (fun x => decide (x = u)) := by
  induction l1 generalizing l2 with
  | nil =>
    have h0 : l2.length = 0 := by simp at h_len; exact h_len.symm
    have : l2 = [] := List.eq_nil_of_length_eq_zero h0
    subst this; simp
  | cons a1 t1 ih =>
    cases l2 with
    | nil => simp at h_len
    | cons a2 t2 =>
      simp only [List.zip_cons_cons, List.map_cons, List.countP_cons]
      rw [ih (by simpa using h_len)]

private lemma polygon_even_degree (v w : Vector2D) (rest : List Vector2D)
    (h_distinct : ∀ seg ∈ (Polygon.mk (v :: w :: rest)).segments, seg.p1 ≠ seg.p2)
    (u : Vector2D) :
    Even ((Polygon.mk (v :: w :: rest)).segments.countP
      fun seg => seg.p1 = u ∨ seg.p2 = u) := by
  -- Unfold polygon segments
  change Even (((List.zip (v :: w :: rest) ((w :: rest) ++ [v])).map
    fun (a, b) => (⟨a, b⟩ : LineSegment)).countP _)
  set l1 := (v :: w :: rest)
  set l2 := ((w :: rest) ++ [v])
  set segs := (l1.zip l2).map fun (a, b) => (⟨a, b⟩ : LineSegment)
  have h_len : l1.length = l2.length := by simp [l1, l2]
  -- Split the disjunction into two countP's
  rw [countP_or_of_disjoint segs h_distinct u]
  -- Relate to countP on the component lists
  rw [countP_zip_fst_eq u h_len, countP_zip_snd_eq u h_len]
  -- l2 = (w :: rest) ++ [v] is a rotation of l1 = v :: w :: rest
  -- So they have the same count of u
  have h_eq : l2.countP (fun x => decide (x = u)) = l1.countP (fun x => decide (x = u)) := by
    simp only [l1, l2, List.countP_append, List.countP_cons, List.countP_nil]
    omega
  rw [h_eq]
  exact ⟨l1.countP (fun x => decide (x = u)), by ring⟩

/-- Convert a polygon with ≥ 2 vertices and distinct consecutive vertices
    to an even graph. Each vertex has degree 2. -/
def polygonToEvenGraph (poly : Polygon) (h_len : poly.vertices.length ≥ 2)
    (h_distinct : ∀ seg ∈ poly.segments, seg.p1 ≠ seg.p2) : EvenGraph where
  segments := poly.segments
  segments_nondegenerate := h_distinct
  even_degree := by
    show ∀ u, Even (poly.segments.countP _)
    intro u
    cases h_eq : poly.vertices with
    | nil => simp [h_eq] at h_len
    | cons v tl =>
      cases tl with
      | nil => simp [h_eq] at h_len
      | cons w rest =>
        have h_poly : poly = ⟨v :: w :: rest⟩ := by cases poly; simp_all
        rw [h_poly] at h_distinct ⊢
        exact polygon_even_degree v w rest h_distinct u

theorem polygonToEvenGraph_segments_eq (poly : Polygon) (h_len : poly.vertices.length ≥ 2)
    (h_distinct : ∀ seg ∈ poly.segments, seg.p1 ≠ seg.p2) :
    (polygonToEvenGraph poly h_len h_distinct).segments = poly.segments :=
  rfl

/-- Every vertex of `v :: vs` appears as the first component of some segment
    in the polygon zip construction. -/
private lemma zip_p1_covers_vertex (v : Vector2D) (vs : List Vector2D) (p : Vector2D)
    (hp : p ∈ (v :: vs)) :
    ∃ seg ∈ (List.zip (v :: vs) (vs ++ [v])).map fun (a, b) => (⟨a, b⟩ : LineSegment),
      seg.p1 = p := by
  have h_map_fst : (List.zip (v :: vs) (vs ++ [v])).map Prod.fst = (v :: vs) :=
    List.map_fst_zip (v :: vs) (vs ++ [v]) (by simp)
  have hp_in_map : p ∈ (List.zip (v :: vs) (vs ++ [v])).map Prod.fst := by
    rw [h_map_fst]; exact hp
  obtain ⟨⟨a, b⟩, hab_in, hab_fst⟩ := List.mem_map.mp hp_in_map
  simp only at hab_fst; subst hab_fst
  exact ⟨⟨a, b⟩, List.mem_map.mpr ⟨(a, b), hab_in, rfl⟩, rfl⟩

/-- The vertex set of the even graph built from a polygon (with ≥ 2 vertices)
    equals the polygon's vertex set. -/
theorem polygonToEvenGraph_toVertexSet_eq (poly : Polygon)
    (h_len : poly.vertices.length ≥ 2)
    (h_distinct : ∀ seg ∈ poly.segments, seg.p1 ≠ seg.p2) :
    (polygonToEvenGraph poly h_len h_distinct).toVertexSet = Polygon.toVertices poly := by
  cases h_eq : poly.vertices with
  | nil => simp [h_eq] at h_len
  | cons v tl =>
    cases tl with
    | nil => simp [h_eq] at h_len
    | cons w rest =>
      have h_poly : poly = ⟨v :: w :: rest⟩ := by cases poly; simp_all
      subst h_poly
      ext p
      simp only [Graph.toVertexSet, Graph.toVertices, polygonToEvenGraph,
                 Polygon.toVertices, Polygon.segments, List.mem_dedup, List.mem_flatMap,
                 List.mem_cons, (List.not_mem_nil _), or_false, Set.mem_setOf_eq]
      constructor
      · rintro ⟨seg, hseg, rfl | rfl⟩
        · exact List.mem_cons.mp (zip_fst_mem v (w :: rest) seg hseg) |>.elim
            Or.inl (fun h => Or.inr (List.mem_cons.mp h))
        · exact List.mem_cons.mp (zip_snd_mem v (w :: rest) seg hseg) |>.elim
            Or.inl (fun h => Or.inr (List.mem_cons.mp h))
      · intro hp
        have hp_list : p ∈ (v :: w :: rest) := by
          rcases hp with rfl | rfl | hp
          · exact (List.mem_cons_self _ _)
          · exact List.mem_cons_of_mem _ (List.mem_cons_self _ _)
          · exact List.mem_cons_of_mem _ (List.mem_cons_of_mem _ hp)
        obtain ⟨seg, hseg, hp1⟩ := zip_p1_covers_vertex v (w :: rest) p hp_list
        exact ⟨seg, hseg, Or.inl hp1.symm⟩

theorem polygonToEvenGraph_boundary_eq (poly : Polygon) (h_len : poly.vertices.length ≥ 2)
    (h_distinct : ∀ seg ∈ poly.segments, seg.p1 ≠ seg.p2) :
    (polygonToEvenGraph poly h_len h_distinct).toBoundarySet = poly.toBoundarySet := by
  ext p
  simp only [Graph.toBoundarySet, Polygon.toBoundarySet, Set.mem_setOf_eq,
             polygonToEvenGraph]

theorem polygonToEvenGraph_interior_eq (poly : Polygon) (h_len : poly.vertices.length ≥ 2)
    (h_distinct : ∀ seg ∈ poly.segments, seg.p1 ≠ seg.p2) :
    { p : Vector2D |
        (∀ seg ∈ (polygonToEvenGraph poly h_len h_distinct).segments,
          pointAvoidsSegment p seg) ∧
        ∀ r : Ray, r.origin = p →
          rayAvoidsGraphVertices r (polygonToEvenGraph poly h_len h_distinct) →
          intersectionRayGraphSegmentsNumber r (polygonToEvenGraph poly h_len h_distinct)
            % 2 = 1 } =
    { p : Vector2D |
        (∀ seg ∈ poly.segments, pointAvoidsSegment p seg) ∧
        ∀ r : Ray, r.origin = p → rayAvoidsVertices r poly →
          intersectionRayPolygonSegmentsNumber r poly % 2 = 1 } := by
  ext p; simp only [Set.mem_setOf_eq]
  -- The graph's segments = poly.segments by rfl. The vertex sets coincide (set equality)
  -- via `polygonToEvenGraph_toVertexSet_eq`.
  have h_segs : (polygonToEvenGraph poly h_len h_distinct).segments = poly.segments := rfl
  have h_vset : (polygonToEvenGraph poly h_len h_distinct).toVertexSet =
      Polygon.toVertices poly :=
    polygonToEvenGraph_toVertexSet_eq poly h_len h_distinct
  constructor <;> intro ⟨h1, h2⟩
  · refine ⟨fun seg hs => h1 seg hs, fun r hr hav => ?_⟩
    apply h2 r hr
    rw [rayAvoidsGraphVertices, h_vset]
    rwa [rayAvoidsVertices] at hav
  · refine ⟨fun seg hs => h1 seg hs, fun r hr hav => ?_⟩
    have hav' : rayAvoidsVertices r poly := by
      rw [rayAvoidsVertices]
      rw [rayAvoidsGraphVertices, h_vset] at hav
      exact hav
    have := h2 r hr hav'
    show intersectionRayGraphSegmentsNumber r (polygonToEvenGraph poly h_len h_distinct) % 2 = 1
    change (polygonToEvenGraph poly h_len h_distinct).segments.countP _ % 2 = 1
    rw [h_segs]
    exact this

/-! ### HPI crossings even -/

/-- The total segExtCount over a graph's segments equals the sum over vertices
    of degree(v) * (if v is exterior then 1 else 0).
    Equivalently, it's sum_seg (ext(seg.p1) + ext(seg.p2))
      = sum_seg ext(seg.p1) + sum_seg ext(seg.p2). -/
private lemma total_ext_count_eq (hpi : HalfPlaneIntersection) (G : EvenGraph) :
    (G.segments.map fun seg => hpi.segExtCount seg).sum =
    (G.segments.map fun seg =>
      (if seg.p1 ∈ hpi.toExteriorSet then 1 else 0) +
      (if seg.p2 ∈ hpi.toExteriorSet then 1 else 0)).sum := by
  simp only [HalfPlaneIntersection.segExtCount]

/-- For each vertex, its contribution to the total ext count is even
    (because its degree is even). -/
private lemma even_ext_contribution (hpi : HalfPlaneIntersection)
    (G : EvenGraph) (v : Vector2D) :
    Even ((G.segments.countP fun seg => decide (seg.p1 = v ∨ seg.p2 = v)) *
      (if v ∈ hpi.toExteriorSet then 1 else 0)) := by
  have h_even := G.even_degree v
  obtain ⟨k, hk⟩ := h_even
  rw [hk]
  by_cases hv_ext : v ∈ hpi.toExteriorSet
  · simp [hv_ext]
  · simp [hv_ext]

/-- Helper: sum of cc + extCount over all segments is even (from per-segment parity). -/
private lemma even_cc_plus_ext (hpi : HalfPlaneIntersection) (G : EvenGraph)
    (h_vertices_not_boundary : ∀ v ∈ G.toVertices, v ∉ hpi.toBoundarySet)
    (h_avoids_vertices : ∀ seg ∈ G.segments, ∀ q ∈ seg.toSet, q ∉ hpi.toVertexSet) :
    Even ((G.segments.map fun seg =>
      segCrossingCount seg hpi + hpi.segExtCount seg).sum) := by
  -- Each term is even (by segment_parity), so the sum is even
  -- First: each segment contributes an even value
  have h_each : ∀ seg ∈ G.segments,
      Even (segCrossingCount seg hpi + hpi.segExtCount seg) := by
    intro seg hseg
    exact (hpi.segment_parity seg
      (h_vertices_not_boundary seg.p1 (G.segments_endpoints seg hseg).1)
      (h_vertices_not_boundary seg.p2 (G.segments_endpoints seg hseg).2)
      (h_avoids_vertices seg hseg)).2
  -- Then: sum of a list of even numbers is even
  have h_sum_even : ∀ (xs : List ℕ), (∀ x ∈ xs, Even x) → Even xs.sum := by
    intro xs
    induction xs with
    | nil => simp
    | cons x tl ih =>
      intro h
      simp only [List.sum_cons]
      exact Even.add (h x (List.mem_cons_self _ _))
        (ih (fun y hy => h y (List.mem_cons.mpr (Or.inr hy))))
  apply h_sum_even
  simp only [List.mem_map]
  rintro _ ⟨seg, hseg, rfl⟩
  exact h_each seg hseg

/-- Helper: all-zero map when a point doesn't match any vertex. -/
private lemma sum_zero_of_ne (l : List Vector2D) (p : Vector2D)
    (h_ne : ∀ v ∈ l, p ≠ v) (E : Set Vector2D) :
    (l.map (fun v => (if p = v then (1 : ℕ) else 0) * (if v ∈ E then 1 else 0))).sum = 0 := by
  apply List.sum_eq_zero
  intro x hx
  obtain ⟨v, hv, rfl⟩ := List.mem_map.mp hx
  simp [h_ne v hv]

/-- Helper: sum of indicator times ext-indicator over a nodup list equals the single match. -/
private lemma single_seg_sum_eq (verts : List Vector2D) (p : Vector2D)
    (h_nodup : verts.Nodup) (h_mem : p ∈ verts) (E : Set Vector2D) :
    (verts.map (fun v => (if p = v then (1 : ℕ) else 0) * (if v ∈ E then 1 else 0))).sum =
    if p ∈ E then 1 else 0 := by
  induction verts with
  | nil => simp at h_mem
  | cons hd tl ih =>
    simp only [List.map_cons, List.sum_cons, List.nodup_cons, List.mem_cons] at *
    obtain ⟨h_nhead, h_nd⟩ := h_nodup
    rcases h_mem with rfl | h_mem_tail
    · simp only [ite_true]
      have := sum_zero_of_ne tl p (fun v hv => fun h => h_nhead (h ▸ hv)) E
      omega
    · have h_ne : p ≠ hd := fun h => h_nhead (h ▸ h_mem_tail)
      simp only [if_neg h_ne, zero_mul, zero_add]
      exact ih h_nd h_mem_tail

/-- Helper: sum of (if s.p1 ∈ E) over segments = sum over vertices of countP(p1=v) * ext(v). -/
private lemma sum_indicator_eq_verts_sum (segs : List LineSegment) (verts : List Vector2D)
    (h_nodup : verts.Nodup) (h_cover : ∀ s ∈ segs, s.p1 ∈ verts) (E : Set Vector2D) :
    (segs.map (fun s : LineSegment => if s.p1 ∈ E then (1 : ℕ) else 0)).sum =
    (verts.map (fun v => segs.countP (fun s => decide (s.p1 = v)) * (if v ∈ E then 1 else 0))).sum := by
  induction segs with
  | nil => simp
  | cons seg rest ih =>
    have h_cover_rest : ∀ s ∈ rest, s.p1 ∈ verts := fun s hs => h_cover s (List.mem_cons_of_mem _ hs)
    have h_p1_mem := h_cover seg (List.mem_cons_self _ _)
    simp only [List.map_cons, List.sum_cons]
    rw [ih h_cover_rest]
    have h1 : (verts.map (fun v : Vector2D => (seg :: rest).countP (fun s => decide (s.p1 = v)) *
            (if v ∈ E then (1 : ℕ) else 0))).sum =
        (verts.map (fun v : Vector2D =>
            (if seg.p1 = v then (1 : ℕ) else 0) * (if v ∈ E then 1 else 0) +
            rest.countP (fun s => decide (s.p1 = v)) * (if v ∈ E then 1 else 0))).sum := by
      congr 1; apply List.map_congr_left; intro v _
      simp only [List.countP_cons]
      by_cases h : seg.p1 = v <;> by_cases he : v ∈ E <;> simp [h, he]; omega
    rw [h1, show (verts.map (fun v : Vector2D =>
            (if seg.p1 = v then (1 : ℕ) else 0) * (if v ∈ E then 1 else 0) +
            rest.countP (fun s => decide (s.p1 = v)) * (if v ∈ E then 1 else 0))).sum =
        (verts.map (fun v : Vector2D => (if seg.p1 = v then (1 : ℕ) else 0) * (if v ∈ E then 1 else 0))).sum +
        (verts.map (fun v : Vector2D => rest.countP (fun s => decide (s.p1 = v)) * (if v ∈ E then 1 else 0))).sum from by simp,
      single_seg_sum_eq verts seg.p1 h_nodup h_p1_mem E]

/-- Helper: sum of (if s.p2 ∈ E) over segments = sum over vertices of countP(p2=v) * ext(v). -/
private lemma sum_indicator_p2_eq_verts_sum (segs : List LineSegment) (verts : List Vector2D)
    (h_nodup : verts.Nodup) (h_cover : ∀ s ∈ segs, s.p2 ∈ verts) (E : Set Vector2D) :
    (segs.map (fun s : LineSegment => if s.p2 ∈ E then (1 : ℕ) else 0)).sum =
    (verts.map (fun v => segs.countP (fun s => decide (s.p2 = v)) * (if v ∈ E then 1 else 0))).sum := by
  induction segs with
  | nil => simp
  | cons seg rest ih =>
    have h_cover_rest : ∀ s ∈ rest, s.p2 ∈ verts := fun s hs => h_cover s (List.mem_cons_of_mem _ hs)
    have h_p2_mem := h_cover seg (List.mem_cons_self _ _)
    simp only [List.map_cons, List.sum_cons]
    rw [ih h_cover_rest]
    have h1 : (verts.map (fun v : Vector2D => (seg :: rest).countP (fun s => decide (s.p2 = v)) *
            (if v ∈ E then (1 : ℕ) else 0))).sum =
        (verts.map (fun v : Vector2D =>
            (if seg.p2 = v then (1 : ℕ) else 0) * (if v ∈ E then 1 else 0) +
            rest.countP (fun s => decide (s.p2 = v)) * (if v ∈ E then 1 else 0))).sum := by
      congr 1; apply List.map_congr_left; intro v _
      simp only [List.countP_cons]
      by_cases h : seg.p2 = v <;> by_cases he : v ∈ E <;> simp [h, he]; omega
    rw [h1, show (verts.map (fun v : Vector2D =>
            (if seg.p2 = v then (1 : ℕ) else 0) * (if v ∈ E then 1 else 0) +
            rest.countP (fun s => decide (s.p2 = v)) * (if v ∈ E then 1 else 0))).sum =
        (verts.map (fun v : Vector2D => (if seg.p2 = v then (1 : ℕ) else 0) * (if v ∈ E then 1 else 0))).sum +
        (verts.map (fun v : Vector2D => rest.countP (fun s => decide (s.p2 = v)) * (if v ∈ E then 1 else 0))).sum from by simp,
      single_seg_sum_eq verts seg.p2 h_nodup h_p2_mem E]

/-- Helper: sum of even-valued terms is even. -/
private lemma even_sum_of_even_terms (verts : List Vector2D) (f : Vector2D → ℕ)
    (h : ∀ v ∈ verts, Even (f v)) : Even (verts.map f).sum := by
  induction verts with
  | nil => simp
  | cons hd tl ih =>
    simp only [List.map_cons, List.sum_cons]
    exact Even.add (h hd (List.mem_cons_self _ _)) (ih (fun x hx => h x (List.mem_cons.mpr (Or.inr hx))))

/-- Helper: the total ext count over the graph is even because each vertex
    has even degree. -/
private lemma even_total_ext (hpi : HalfPlaneIntersection) (G : EvenGraph)
    (_h_vertices_not_boundary : ∀ v ∈ G.toVertices, v ∉ hpi.toBoundarySet) :
    Even ((G.segments.map fun seg => hpi.segExtCount seg).sum) := by
  simp only [HalfPlaneIntersection.segExtCount]
  have h_split : (G.segments.map fun seg =>
      (if seg.p1 ∈ hpi.toExteriorSet then (1 : ℕ) else 0) +
      (if seg.p2 ∈ hpi.toExteriorSet then 1 else 0)).sum =
    (G.segments.map fun seg => if seg.p1 ∈ hpi.toExteriorSet then (1 : ℕ) else 0).sum +
    (G.segments.map fun seg => if seg.p2 ∈ hpi.toExteriorSet then (1 : ℕ) else 0).sum := by
    induction G.segments with
    | nil => simp
    | cons seg tl ih => simp [ih]; omega
  rw [h_split]
  let verts := G.toVertices.dedup
  have h_nodup : verts.Nodup := List.nodup_dedup _
  have h_p1_cover : ∀ s ∈ G.segments, s.p1 ∈ verts :=
    fun s hs => List.mem_dedup.mpr (G.segments_endpoints s hs).1
  have h_p2_cover : ∀ s ∈ G.segments, s.p2 ∈ verts :=
    fun s hs => List.mem_dedup.mpr (G.segments_endpoints s hs).2
  rw [sum_indicator_eq_verts_sum G.segments verts h_nodup h_p1_cover hpi.toExteriorSet,
      sum_indicator_p2_eq_verts_sum G.segments verts h_nodup h_p2_cover hpi.toExteriorSet]
  rw [show (verts.map (fun v => G.segments.countP (fun s => decide (s.p1 = v)) *
          (if v ∈ hpi.toExteriorSet then (1 : ℕ) else 0))).sum +
      (verts.map (fun v => G.segments.countP (fun s => decide (s.p2 = v)) *
          (if v ∈ hpi.toExteriorSet then (1 : ℕ) else 0))).sum =
      (verts.map (fun v => (G.segments.countP (fun s => decide (s.p1 = v)) +
          G.segments.countP (fun s => decide (s.p2 = v))) *
          (if v ∈ hpi.toExteriorSet then (1 : ℕ) else 0))).sum from by
    induction verts with
    | nil => simp
    | cons hd tl ih =>
      simp only [List.map_cons, List.sum_cons]
      have : (G.segments.countP (fun s => decide (s.p1 = hd)) +
              G.segments.countP (fun s => decide (s.p2 = hd))) *
              (if hd ∈ hpi.toExteriorSet then (1 : ℕ) else 0) =
          G.segments.countP (fun s => decide (s.p1 = hd)) * (if hd ∈ hpi.toExteriorSet then 1 else 0) +
          G.segments.countP (fun s => decide (s.p2 = hd)) * (if hd ∈ hpi.toExteriorSet then 1 else 0) := by ring
      omega]
  apply even_sum_of_even_terms
  intro v _hv
  have h_deg_even := G.even_degree v
  rw [countP_or_of_disjoint G.segments G.segments_nondegenerate v] at h_deg_even
  exact Even.mul_right h_deg_even _

theorem graph_crossings_even
    (hpi : HalfPlaneIntersection) (G : EvenGraph)
    (h_vertices_not_boundary : ∀ v ∈ G.toVertices, v ∉ hpi.toBoundarySet)
    (h_avoids_vertices : ∀ seg ∈ G.segments, ∀ q ∈ seg.toSet, q ∉ hpi.toVertexSet) :
    (∀ seg ∈ G.segments, (seg.boundaryCrossings hpi).Finite) ∧
    Even ((G.segments.map fun seg => segCrossingCount seg hpi).sum) := by
  constructor
  · -- Finiteness
    intro seg hseg
    have hp1_nb := h_vertices_not_boundary seg.p1 (G.segments_endpoints seg hseg).1
    have hp2_nb := h_vertices_not_boundary seg.p2 (G.segments_endpoints seg hseg).2
    exact (hpi.segment_parity seg hp1_nb hp2_nb (h_avoids_vertices seg hseg)).1
  · -- Evenness: Even(total_cc + total_ext) and Even(total_ext) → Even(total_cc)
    have h1 := even_cc_plus_ext hpi G h_vertices_not_boundary h_avoids_vertices
    have h2 := even_total_ext hpi G h_vertices_not_boundary
    -- total_cc = total(cc + ext) - total(ext)
    -- Split the sum: sum(cc + ext) = sum(cc) + sum(ext)
    have h_split : (G.segments.map fun seg =>
        segCrossingCount seg hpi + hpi.segExtCount seg).sum =
      (G.segments.map fun seg => segCrossingCount seg hpi).sum +
      (G.segments.map fun seg => hpi.segExtCount seg).sum := by
      induction G.segments with
      | nil => simp
      | cons seg tl ih => simp [ih]; omega
    rw [h_split] at h1
    obtain ⟨k1, hk1⟩ := h1
    obtain ⟨k2, hk2⟩ := h2
    exact ⟨k1 - k2, by omega⟩

/-! ### Combining even graphs -/

/-- Combine a list of even graphs into one by concatenating their segments.
    Non-degeneracy holds segment-wise. Even-degree holds because a sum of
    even numbers is even. -/
def combine (Gs : List EvenGraph) : EvenGraph where
  segments := Gs.flatMap (·.segments)
  segments_nondegenerate := by
    intro seg hseg
    rw [List.mem_flatMap] at hseg
    obtain ⟨G, _, h_in_G⟩ := hseg
    exact G.segments_nondegenerate seg h_in_G
  even_degree := by
    intro v
    induction Gs with
    | nil => simp
    | cons G rest ih =>
      simp only [List.flatMap_cons, List.countP_append]
      exact (G.even_degree v).add ih

/-! ### Equivalence preserves the boundary -/

/-- The point set of a segment is symmetric in its endpoints. -/
lemma lineSegment_toSet_swap (a b : Vector2D) :
    (LineSegment.mk a b).toSet = (LineSegment.mk b a).toSet := by
  ext p
  simp only [LineSegment.toSet, Set.mem_setOf_eq]
  constructor
  · rintro ⟨t, h0, h1, hx, hy⟩
    refine ⟨1 - t, by linarith, by linarith, ?_, ?_⟩
    · rw [hx]; ring
    · rw [hy]; ring
  · rintro ⟨t, h0, h1, hx, hy⟩
    refine ⟨1 - t, by linarith, by linarith, ?_, ?_⟩
    · rw [hx]; ring
    · rw [hy]; ring

/-- Two segments with the same unordered-endpoint multiset have the same
    point set. -/
lemma lineSegment_toSet_eq_of_pair_eq (s1 s2 : LineSegment)
    (h : ({s1.p1, s1.p2} : Multiset Vector2D) = {s2.p1, s2.p2}) :
    s1.toSet = s2.toSet := by
  cases s1 with
  | mk a b =>
  cases s2 with
  | mk c d =>
  simp only at h
  have ha_cases : a = c ∨ a = d := by
    have ha : a ∈ ({c, d} : Multiset Vector2D) := by
      rw [← h]; exact Multiset.mem_cons_self _ _
    rcases Multiset.mem_cons.mp ha with hc | hd
    · exact Or.inl hc
    · exact Or.inr (Multiset.mem_singleton.mp hd)
  rcases ha_cases with ha_eq | ha_eq
  · subst ha_eq
    have h_eq : ({b} : Multiset Vector2D) = {d} := by
      have step :
          Multiset.erase ({a, b} : Multiset Vector2D) a =
          Multiset.erase ({a, d} : Multiset Vector2D) a := by rw [h]
      have l1 : ({a, b} : Multiset Vector2D) = a ::ₘ ({b} : Multiset Vector2D) := rfl
      have l2 : ({a, d} : Multiset Vector2D) = a ::ₘ ({d} : Multiset Vector2D) := rfl
      rw [l1, l2, Multiset.erase_cons_head, Multiset.erase_cons_head] at step
      exact step
    have hbd : b = d := by
      have : b ∈ ({d} : Multiset Vector2D) := by
        rw [← h_eq]; exact Multiset.mem_singleton.mpr rfl
      exact Multiset.mem_singleton.mp this
    subst hbd
    rfl
  · subst ha_eq
    have h_swap : ({c, a} : Multiset Vector2D) = ({a, c} : Multiset Vector2D) :=
      Multiset.cons_swap _ _ _
    rw [h_swap] at h
    have h_eq : ({b} : Multiset Vector2D) = {c} := by
      have step :
          Multiset.erase ({a, b} : Multiset Vector2D) a =
          Multiset.erase ({a, c} : Multiset Vector2D) a := by rw [h]
      have l1 : ({a, b} : Multiset Vector2D) = a ::ₘ ({b} : Multiset Vector2D) := rfl
      have l2 : ({a, c} : Multiset Vector2D) = a ::ₘ ({c} : Multiset Vector2D) := rfl
      rw [l1, l2, Multiset.erase_cons_head, Multiset.erase_cons_head] at step
      exact step
    have hbc : b = c := by
      have : b ∈ ({c} : Multiset Vector2D) := by
        rw [← h_eq]; exact Multiset.mem_singleton.mpr rfl
      exact Multiset.mem_singleton.mp this
    subst hbc
    exact lineSegment_toSet_swap a b

/-- If two even graphs have permutation-equal segment lists (up to direction),
    then the boundary of the first is contained in the boundary of the second. -/
lemma boundarySet_subset_of_perm {G1 G2 : EvenGraph}
    (h : G1.segments.map (fun s => ({s.p1, s.p2} : Multiset Vector2D)) ~
         G2.segments.map (fun s => ({s.p1, s.p2} : Multiset Vector2D))) :
    G1.toBoundarySet ⊆ G2.toBoundarySet := by
  rintro p ⟨seg, hseg, hp⟩
  have hm1 :
      ({seg.p1, seg.p2} : Multiset Vector2D) ∈
        G1.segments.map (fun s => ({s.p1, s.p2} : Multiset Vector2D)) :=
    List.mem_map.mpr ⟨seg, hseg, rfl⟩
  have hm2 :
      ({seg.p1, seg.p2} : Multiset Vector2D) ∈
        G2.segments.map (fun s => ({s.p1, s.p2} : Multiset Vector2D)) :=
    h.mem_iff.mp hm1
  obtain ⟨seg', hseg', h_eq⟩ := List.mem_map.mp hm2
  refine ⟨seg', hseg', ?_⟩
  have h_pair : ({seg.p1, seg.p2} : Multiset Vector2D) =
                ({seg'.p1, seg'.p2} : Multiset Vector2D) := h_eq.symm
  rw [lineSegment_toSet_eq_of_pair_eq seg seg' h_pair] at hp
  exact hp

/-! ### Equivalence preserves the interior -/

/-- If two even graphs have permutation-equal segment lists (up to direction),
    then the first's vertex set is contained in the second's vertex set. -/
lemma toVertexSet_subset_of_perm {G1 G2 : EvenGraph}
    (h : G1.segments.map (fun s => ({s.p1, s.p2} : Multiset Vector2D)) ~
         G2.segments.map (fun s => ({s.p1, s.p2} : Multiset Vector2D))) :
    G1.toVertexSet ⊆ G2.toVertexSet := by
  intro p hp
  simp only [Graph.toVertexSet, Set.mem_setOf_eq] at hp
  rw [EvenGraph.mem_toVertices_iff] at hp
  obtain ⟨seg, hseg, hpoint⟩ := hp
  have hm1 :
      ({seg.p1, seg.p2} : Multiset Vector2D) ∈
        G1.segments.map (fun s => ({s.p1, s.p2} : Multiset Vector2D)) :=
    List.mem_map.mpr ⟨seg, hseg, rfl⟩
  have hm2 :
      ({seg.p1, seg.p2} : Multiset Vector2D) ∈
        G2.segments.map (fun s => ({s.p1, s.p2} : Multiset Vector2D)) :=
    h.mem_iff.mp hm1
  obtain ⟨seg', hseg', h_eq⟩ := List.mem_map.mp hm2
  simp only [Graph.toVertexSet, Set.mem_setOf_eq]
  rw [EvenGraph.mem_toVertices_iff]
  refine ⟨seg', hseg', ?_⟩
  have h_p_in : p ∈ ({seg.p1, seg.p2} : Multiset Vector2D) := by
    rcases hpoint with rfl | rfl
    · exact Multiset.mem_cons_self _ _
    · exact Multiset.mem_cons_of_mem (Multiset.mem_singleton.mpr rfl)
  rw [← h_eq] at h_p_in
  rcases Multiset.mem_cons.mp h_p_in with hp1 | hp1
  · exact Or.inl hp1.symm
  · exact Or.inr (Multiset.mem_singleton.mp hp1).symm

/-- Generic: if `L1.map f ~ L2.map f` and `p` factors through `f`, then `L1.countP p = L2.countP p`. -/
private lemma countP_eq_via_map {α β : Type*} {L1 L2 : List α} {f : α → β} {p : α → Bool}
    (h : (L1.map f) ~ (L2.map f))
    (hp : ∀ x1 x2 : α, f x1 = f x2 → p x1 = p x2) :
    L1.countP p = L2.countP p := by
  classical
  let q : β → Bool := fun y =>
    if hy : ∃ x : α, f x = y then p (Classical.choose hy) else false
  have hq : ∀ x : α, q (f x) = p x := by
    intro x
    show (if hy : ∃ x' : α, f x' = f x then p (Classical.choose hy) else false) = p x
    have hy : ∃ x' : α, f x' = f x := ⟨x, rfl⟩
    rw [dif_pos hy]
    exact hp _ _ (Classical.choose_spec hy)
  have key : ∀ L : List α, L.countP p = (L.map f).countP q := by
    intro L
    induction L with
    | nil => rfl
    | cons a t ih =>
      simp only [List.countP_cons, List.map_cons]
      rw [ih, hq a]
  rw [key L1, key L2]
  exact h.countP_eq q

/-- Ray intersection count is preserved under the segment-endpoint permutation. -/
lemma intersectionRayGraphSegmentsNumber_eq_of_perm {G1 G2 : EvenGraph}
    (h : G1.segments.map (fun s => ({s.p1, s.p2} : Multiset Vector2D)) ~
         G2.segments.map (fun s => ({s.p1, s.p2} : Multiset Vector2D))) (r : Ray) :
    intersectionRayGraphSegmentsNumber r G1 = intersectionRayGraphSegmentsNumber r G2 := by
  show G1.segments.countP _ = G2.segments.countP _
  apply countP_eq_via_map h
  intro s1 s2 h_pair
  have h_ts : s1.toSet = s2.toSet := lineSegment_toSet_eq_of_pair_eq s1 s2 h_pair
  show decide (rayIntersectsSegment r s1) = decide (rayIntersectsSegment r s2)
  have h_ris : rayIntersectsSegment r s1 = rayIntersectsSegment r s2 := by
    unfold rayIntersectsSegment
    rw [h_ts]
  rw [h_ris]

/-- Equivalent even graphs have the same boundary set. -/
theorem Equiv_toBoundarySet_eq {G1 G2 : EvenGraph} (h : G1.Equiv G2) :
    G1.toBoundarySet = G2.toBoundarySet :=
  Set.Subset.antisymm
    (boundarySet_subset_of_perm h)
    (boundarySet_subset_of_perm h.symm)

/-- Equivalent even graphs have the same vertex set. -/
theorem Equiv_toVertexSet_eq {G1 G2 : EvenGraph} (h : G1.Equiv G2) :
    G1.toVertexSet = G2.toVertexSet :=
  Set.Subset.antisymm
    (toVertexSet_subset_of_perm h)
    (toVertexSet_subset_of_perm h.symm)

/-- Equivalent even graphs have the same interior. -/
theorem Equiv_interior_eq {G1 G2 : EvenGraph} (h : G1.Equiv G2) :
    G1.interior = G2.interior := by
  have h_boundary := Equiv_toBoundarySet_eq h
  have h_vset := Equiv_toVertexSet_eq h
  have h_count : ∀ r, intersectionRayGraphSegmentsNumber r G1 =
                      intersectionRayGraphSegmentsNumber r G2 :=
    fun r => intersectionRayGraphSegmentsNumber_eq_of_perm h r
  have hP : ∀ p : Vector2D, (∀ seg ∈ G1.segments, pointAvoidsSegment p seg) ↔
                             (∀ seg ∈ G2.segments, pointAvoidsSegment p seg) := by
    intro p
    have eq1 : (∀ seg ∈ G1.segments, pointAvoidsSegment p seg) ↔ p ∉ G1.toBoundarySet := by
      refine ⟨fun hAll ⟨seg, hseg, hp⟩ => hAll seg hseg hp,
              fun hNot seg hseg hp => hNot ⟨seg, hseg, hp⟩⟩
    have eq2 : (∀ seg ∈ G2.segments, pointAvoidsSegment p seg) ↔ p ∉ G2.toBoundarySet := by
      refine ⟨fun hAll ⟨seg, hseg, hp⟩ => hAll seg hseg hp,
              fun hNot seg hseg hp => hNot ⟨seg, hseg, hp⟩⟩
    rw [eq1, eq2, h_boundary]
  have h_avoid : ∀ r : Ray, rayAvoidsGraphVertices r G1 ↔ rayAvoidsGraphVertices r G2 := by
    intro r
    unfold rayAvoidsGraphVertices
    rw [h_vset]
  ext p
  simp only [EvenGraph.interior, Set.mem_setOf_eq]
  rw [hP p]
  refine and_congr_right (fun _ => ?_)
  constructor
  · intro hAll r hro hav
    rw [← h_count r]
    exact hAll r hro ((h_avoid r).mpr hav)
  · intro hAll r hro hav
    rw [h_count r]
    exact hAll r hro ((h_avoid r).mp hav)

/-! ### Boundary of a combined graph -/

/-- The segments of `combine Gs` are the concatenation of the components' segments
    (rfl). -/
lemma combine_segments (Gs : List EvenGraph) :
    (combine Gs).segments = Gs.flatMap (·.segments) := rfl

/-- The boundary of a combined even graph equals the union of the
    component boundaries. -/
theorem combine_toBoundarySet (Gs : List EvenGraph) :
    (combine Gs).toBoundarySet = ⋃ G ∈ Gs, G.toBoundarySet := by
  ext p
  simp only [Graph.toBoundarySet, combine_segments,
             Set.mem_setOf_eq, List.mem_flatMap, Set.mem_iUnion, exists_prop]
  constructor
  · rintro ⟨seg, ⟨G, hG, hs⟩, hp⟩
    exact ⟨G, hG, seg, hs, hp⟩
  · rintro ⟨G, hG, seg, hs, hp⟩
    exact ⟨seg, ⟨G, hG, hs⟩, hp⟩

/-! ### Interior of a combined graph: XOR of component interiors -/

/-- The vertex set of a combined even graph is the union of component vertex sets. -/
lemma combine_toVertexSet_eq_iUnion (Gs : List EvenGraph) :
    (combine Gs).toVertexSet = ⋃ G ∈ Gs, G.toVertexSet := by
  ext p
  simp only [Graph.toVertexSet, Set.mem_setOf_eq, Set.mem_iUnion,
             EvenGraph.mem_toVertices_iff, combine_segments, List.mem_flatMap,
             exists_prop]
  constructor
  · rintro ⟨seg, ⟨G, hG, hseg⟩, hp⟩
    exact ⟨G, hG, seg, hseg, hp⟩
  · rintro ⟨G, hG, seg, hseg, hp⟩
    exact ⟨seg, ⟨G, hG, hseg⟩, hp⟩

/-- The ray-segment intersection count is additive over combined graphs. -/
lemma combine_intersectionRayGraphSegmentsNumber_eq_sum
    (r : Ray) (Gs : List EvenGraph) :
    intersectionRayGraphSegmentsNumber r (combine Gs) =
    (Gs.map (fun G : EvenGraph => intersectionRayGraphSegmentsNumber r G.toGraph)).sum := by
  show (combine Gs).segments.countP _ = _
  simp only [combine_segments]
  induction Gs with
  | nil => simp
  | cons G rest ih =>
    simp only [List.flatMap_cons, List.countP_append, List.map_cons, List.sum_cons, ih]
    rfl

/-- For a list of naturals, the parity of the sum equals the parity of the
    count of odd elements. -/
private lemma Nat_sum_mod_two_eq_countP_odd_mod_two (l : List ℕ) :
    l.sum % 2 = (l.countP (fun n => decide (n % 2 = 1))) % 2 := by
  induction l with
  | nil => simp
  | cons a t ih =>
    simp only [List.sum_cons, List.countP_cons]
    by_cases h : a % 2 = 1
    · simp [h]; omega
    · simp [h]; omega

/-- Crossing count parity is the XOR of the component crossing parities. -/
lemma combine_crossing_parity_eq (r : Ray) (Gs : List EvenGraph) :
    intersectionRayGraphSegmentsNumber r (combine Gs) % 2 =
    (Gs.countP
      (fun G : EvenGraph =>
        decide (intersectionRayGraphSegmentsNumber r G.toGraph % 2 = 1))) % 2 := by
  rw [combine_intersectionRayGraphSegmentsNumber_eq_sum,
      Nat_sum_mod_two_eq_countP_odd_mod_two, List.countP_map]
  rfl

/-- Helper: `p` is on a segment whose endpoint is `p`. -/
private lemma point_mem_seg_of_endpoint {seg : LineSegment} {p : Vector2D}
    (h : seg.p1 = p ∨ seg.p2 = p) : p ∈ seg.toSet := by
  rcases h with h | h
  · exact ⟨0, le_refl _, zero_le_one, by rw [← h]; ring, by rw [← h]; ring⟩
  · exact ⟨1, zero_le_one, le_refl _, by rw [← h]; ring, by rw [← h]; ring⟩

/-- Auxiliary form: under the avoid-all-boundaries hypothesis, the interior of
    a combined even graph is the symmetric difference (XOR) of the component
    interiors. -/
private theorem combine_interior_iff_xor_aux (Gs : List EvenGraph) (p : Vector2D)
    (h_avoid : ∀ G ∈ Gs, p ∉ G.toBoundarySet) :
    p ∈ (combine Gs).interior ↔
    Odd (Gs.countP (fun G => decide (p ∈ G.interior))) := by
  classical
  -- p is not a vertex of any G (endpoints are boundary points).
  have h_p_not_vertex_G : ∀ G ∈ Gs, p ∉ G.toVertexSet := by
    intro G hG hv
    simp only [Graph.toVertexSet, Set.mem_setOf_eq] at hv
    rw [EvenGraph.mem_toVertices_iff] at hv
    obtain ⟨seg, hseg, hp⟩ := hv
    exact h_avoid G hG ⟨seg, hseg, point_mem_seg_of_endpoint hp⟩
  -- p is not a vertex of combine Gs.
  have h_p_not_vertex_combine : ∀ v ∈ (combine Gs).toVertices, v ≠ p := by
    intro v hv hvp
    subst hvp
    rw [EvenGraph.mem_toVertices_iff] at hv
    obtain ⟨seg, hseg, hp⟩ := hv
    rw [combine_segments, List.mem_flatMap] at hseg
    obtain ⟨G, hG, hsG⟩ := hseg
    exact h_avoid G hG ⟨seg, hsG, point_mem_seg_of_endpoint hp⟩
  -- Get a ray from p avoiding all combine vertices.
  obtain ⟨r, hr_origin, hr_avoids⟩ :=
    exists_ray_avoiding_graph_vertices p (combine Gs) h_p_not_vertex_combine
  -- That ray also avoids each G's vertices.
  have hr_avoids_G : ∀ G ∈ Gs, rayAvoidsGraphVertices r G := by
    intro G hG
    have h_subset : G.toVertexSet ⊆ (combine Gs).toVertexSet := by
      intro v hv
      rw [combine_toVertexSet_eq_iUnion]
      exact Set.mem_iUnion₂.mpr ⟨G, hG, hv⟩
    rw [rayAvoidsGraphVertices] at hr_avoids ⊢
    rw [Set.eq_empty_iff_forall_not_mem] at hr_avoids ⊢
    intro x ⟨hx_r, hx_G⟩
    exact hr_avoids x ⟨hx_r, h_subset hx_G⟩
  -- p avoids all segments of each G and of combine Gs.
  have h_p_avoid_G : ∀ G ∈ Gs, ∀ seg ∈ G.segments, pointAvoidsSegment p seg := by
    intro G hG seg hseg hp
    exact h_avoid G hG ⟨seg, hseg, hp⟩
  have h_p_avoid_combine : ∀ seg ∈ (combine Gs).segments, pointAvoidsSegment p seg := by
    intro seg hseg
    rw [combine_segments, List.mem_flatMap] at hseg
    obtain ⟨G, hG, hsG⟩ := hseg
    exact h_p_avoid_G G hG seg hsG
  -- For each G: p ∈ G.interior iff count(r, G) is odd.
  have h_G_iff : ∀ G ∈ Gs,
      (p ∈ G.interior ↔ intersectionRayGraphSegmentsNumber r G % 2 = 1) := by
    intro G hG
    refine ⟨fun hp_int => hp_int.2 r hr_origin (hr_avoids_G G hG), fun hcount => ?_⟩
    refine ⟨h_p_avoid_G G hG, ?_⟩
    intro r' hr'_origin hr'_avoids
    have h_origin_seg : ∀ seg ∈ G.segments, pointAvoidsSegment r.origin seg := by
      rw [hr_origin]; exact h_p_avoid_G G hG
    have := intersectionParity_eq_of_sameOrigin_avoidsGraphVertices
      r r' G (by show r.origin = r'.origin; rw [hr_origin, hr'_origin])
      (hr_avoids_G G hG) hr'_avoids h_origin_seg
    omega
  -- Similar for combine Gs.
  have h_combine_iff : p ∈ (combine Gs).interior ↔
      intersectionRayGraphSegmentsNumber r (combine Gs) % 2 = 1 := by
    refine ⟨fun hp_int => hp_int.2 r hr_origin hr_avoids, fun hcount => ?_⟩
    refine ⟨h_p_avoid_combine, ?_⟩
    intro r' hr'_origin hr'_avoids
    have h_origin_seg : ∀ seg ∈ (combine Gs).segments, pointAvoidsSegment r.origin seg := by
      rw [hr_origin]; exact h_p_avoid_combine
    have := intersectionParity_eq_of_sameOrigin_avoidsGraphVertices
      r r' (combine Gs) (by show r.origin = r'.origin; rw [hr_origin, hr'_origin])
      hr_avoids hr'_avoids h_origin_seg
    omega
  rw [h_combine_iff, combine_crossing_parity_eq]
  -- Rewrite the predicate in countP using h_G_iff.
  have h_countP_eq :
      Gs.countP (fun G : EvenGraph =>
          decide (intersectionRayGraphSegmentsNumber r G.toGraph % 2 = 1)) =
      Gs.countP (fun G : EvenGraph => decide (p ∈ G.interior)) := by
    apply List.countP_congr
    intro G hG
    simp only [decide_eq_true_eq]
    exact (h_G_iff G hG).symm
  rw [h_countP_eq]
  exact Nat.odd_iff.symm

/-- The interior of a combined even graph: a point lies in the combined
    interior iff it avoids the combined boundary and an odd number of
    component interiors contain it. -/
theorem combine_interior_iff_xor (Gs : List EvenGraph) (p : Vector2D) :
    p ∈ (combine Gs).interior ↔
    p ∉ (combine Gs).toBoundarySet ∧
      Odd (Gs.countP (fun G => decide (p ∈ G.interior))) := by
  classical
  have h_boundary_iff :
      p ∉ (combine Gs).toBoundarySet ↔ ∀ G ∈ Gs, p ∉ G.toBoundarySet := by
    rw [combine_toBoundarySet]
    simp only [Set.mem_iUnion, exists_prop, not_exists, not_and]
  refine ⟨fun hp => ?_, fun ⟨h_not_bnd, hodd⟩ => ?_⟩
  · have h_not_bnd : p ∉ (combine Gs).toBoundarySet := by
      rintro ⟨seg, hseg, hp_seg⟩
      exact hp.1 seg hseg hp_seg
    exact ⟨h_not_bnd,
      (combine_interior_iff_xor_aux Gs p (h_boundary_iff.mp h_not_bnd)).mp hp⟩
  · exact (combine_interior_iff_xor_aux Gs p (h_boundary_iff.mp h_not_bnd)).mpr hodd

/-- A point lies in the symmetric difference of a list of sets iff it belongs
    to an odd number of those sets. -/
private lemma mem_symmDiffAll_iff_odd_countP {α : Type*}
    (l : List (Set α)) (p : α) :
    p ∈ l.symmDiffAll ↔ Odd (l.countP (fun S => decide (p ∈ S))) := by
  induction l with
  | nil =>
    show p ∈ (∅ : Set α) ↔ Odd 0
    simp
  | cons A t ih =>
    show p ∈ symmDiff A t.symmDiffAll ↔ _
    rw [Set.mem_symmDiff]
    by_cases hpA : p ∈ A
    · rw [List.countP_cons_of_pos (p := fun S => decide (p ∈ S)) (l := t)
            (pa := decide_eq_true hpA)]
      have hLHS :
          (p ∈ A ∧ p ∉ t.symmDiffAll ∨ p ∈ t.symmDiffAll ∧ p ∉ A) ↔
            p ∉ t.symmDiffAll := by
        constructor
        · rintro (⟨_, h⟩ | ⟨_, h⟩)
          · exact h
          · exact absurd hpA h
        · intro h; exact Or.inl ⟨hpA, h⟩
      rw [hLHS, ih, Nat.odd_add_one]
    · have hnd : ¬ ((fun S => decide (p ∈ S)) A = true) := by
        simp [hpA]
      rw [List.countP_cons_of_neg (p := fun S => decide (p ∈ S)) (l := t)
            (pa := hnd)]
      have hLHS :
          (p ∈ A ∧ p ∉ t.symmDiffAll ∨ p ∈ t.symmDiffAll ∧ p ∉ A) ↔
            p ∈ t.symmDiffAll := by
        constructor
        · rintro (⟨h, _⟩ | ⟨h, _⟩)
          · exact absurd h hpA
          · exact h
        · intro h; exact Or.inr ⟨h, hpA⟩
      rw [hLHS]; exact ih

/-- The interior of a combined even graph equals the symmetric difference of
    the component interiors with the combined boundary removed. -/
theorem combine_interior_eq_symmDiff_sdiff_boundary (Gs : List EvenGraph) :
    (combine Gs).interior =
    (Gs.map EvenGraph.interior).symmDiffAll \ (combine Gs).toBoundarySet := by
  ext p
  rw [combine_interior_iff_xor, Set.mem_diff,
      mem_symmDiffAll_iff_odd_countP, List.countP_map]
  exact and_comm

end EvenGraphProofs
