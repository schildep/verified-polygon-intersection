            have h32 : (q.x - O1.x) * n3.x + (q.y - O1.y) * n3.y = 0 := hdot_a
            have h12 : (q.x - O1.x) * n1.x + (q.y - O1.y) * n1.y = 0 := hdot_b
            have hdx : q.x - O1.x = 0 :=
