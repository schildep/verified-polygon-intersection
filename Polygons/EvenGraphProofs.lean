              have h_q1_n3 : (q1.x - O1.x) * n3.x + (q1.y - O1.y) * n3.y = t * κ := by
                have hqx : q1.x - O1.x = t * d.x := by linarith
                have hqy : q1.y - O1.y = t * d.y := by linarith
                calc (q1.x - O1.x) * n3.x + (q1.y - O1.y) * n3.y
                    = (t * d.x) * n3.x + (t * d.y) * n3.y := by rw [hqx, hqy]
                  _ = t * (d.x * n3.x + d.y * n3.y) := by ring
                  _ = t * κ := by rw [h_d_n3]
