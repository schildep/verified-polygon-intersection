          have h_seg_r1_sub : (seg.toSet ∩ r1'.toSet).Subsingleton := by
            -- r1' ⊆ hp1 boundary (n1 ⊥ d)
            let hp1' : HalfPlane := ⟨O1, n1, egp_par_n1_nonzero d delta hd_nz⟩
            have h_r1_bnd : r1'.toSet ⊆ hp1'.toBoundarySet := by
              intro q ⟨t, _, htx, hty⟩
              show (q.x - O1.x) * n1.x + (q.y - O1.y) * n1.y = 0
