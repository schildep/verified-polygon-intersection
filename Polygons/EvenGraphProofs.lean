        -- Apply graph_crossings_even to get even total
        have h_even_total := (graph_crossings_even' hpi G h_verts_avoid_hpi h_seg_av).2
        -- Relate total crossing count to count(r1') + count(r2')
        have h_total_eq : (G.segments.map fun seg => segCrossingCount seg hpi).sum =
            intersectionRayGraphSegmentsNumber r1' G +
            intersectionRayGraphSegmentsNumber r2' G := by
          simp only [intersectionRayGraphSegmentsNumber]
          rw [egp_countP_eq_map_sum, egp_countP_eq_map_sum]
          suffices h_per : ∀ seg ∈ G.segments,
              segCrossingCount seg hpi =
                (if decide (rayIntersectsSegment r1' seg) then 1 else 0) +
                (if decide (rayIntersectsSegment r2' seg) then 1 else 0) by
            rw [List.map_congr_left h_per, egp_sum_map_add]
          intro seg hseg
          have h_p1_not_bnd : seg.p1 ∉ hpi.toBoundarySet := h_verts_avoid_hpi seg.p1 (G.segments_endpoints seg hseg).1
          have h_p2_not_bnd : seg.p2 ∉ hpi.toBoundarySet := h_verts_avoid_hpi seg.p2 (G.segments_endpoints seg hseg).2
          have h_seg_avoids := h_seg_av seg hseg
          have h_fin : (seg.boundaryCrossings hpi).Finite :=
            HalfPlaneIntersection.boundaryCrossings_finite hpi seg h_p1_not_bnd h_p2_not_bnd h_seg_avoids
          have h_cc : segCrossingCount seg hpi = h_fin.toFinset.card := by
            simp [segCrossingCount, dif_pos h_fin]
          -- Boundary crossings = seg ∩ r1' ∪ seg ∩ r2' (since seg ∩ seg(O1,O2) = ∅)
          have h_mid_empty : seg.toSet ∩ (LineSegment.mk O1 O2).toSet = ∅ := by
            have h_disj := h_origin_segment_avoids seg hseg
            unfold segmentDoesNotIntersectSegment at h_disj
            ext q; simp only [Set.mem_inter_iff, Set.mem_empty_iff_false, iff_false, not_and]
            intro hq_seg hq_conn
            have hq_mem : q ∈ (LineSegment.mk O1 O2).toSet ∩ seg.toSet := ⟨hq_conn, hq_seg⟩
            rw [h_disj] at hq_mem; exact hq_mem
          have h_cross_union : seg.boundaryCrossings hpi =
              (seg.toSet ∩ r1'.toSet) ∪ (seg.toSet ∩ r2'.toSet) := by
            unfold LineSegment.boundaryCrossings
            rw [h_bnd, Set.inter_union_distrib_left, Set.inter_union_distrib_left, h_mid_empty,
                Set.union_empty]
          -- r1' and r2' have disjoint intersection with seg
          have h_r1r2_disj_on_seg : ∀ q, q ∈ seg.toSet → q ∈ r1'.toSet → ¬(q ∈ r2'.toSet) := by
            intro q _ hq_r1 hq_r2
            obtain ⟨t1, _, ht1x, ht1y⟩ := hq_r1
            obtain ⟨t2, _, ht2x, ht2y⟩ := hq_r2
            -- q = O1 + t1*d = O2 + t2*d → (O1 - O2) = (t2 - t1)*d → delta = (t2 - t1)*(-d)
            -- egp_cross d delta = (t2-t1) * egp_cross d (-d) = 0, contradicting h_nc
            have heqx : O1.x + t1 * d.x = O2.x + t2 * d.x := by linarith
            have heqy : O1.y + t1 * d.y = O2.y + t2 * d.y := by linarith
            have h_cross : egp_cross d delta = 0 := by
              unfold egp_cross; simp only [delta]
              have hx : O2.x - O1.x = (t1 - t2) * d.x := by linarith
              have hy : O2.y - O1.y = (t1 - t2) * d.y := by linarith
              rw [hx, hy]; ring
