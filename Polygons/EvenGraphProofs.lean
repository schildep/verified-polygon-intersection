                  have hq1_O2 : q1 = O2 := (Vector2D.mk.injEq _ _ _ _).mpr ⟨by linarith, by linarith⟩
                  exact absurd (hq1_O2 ▸ hq1_seg) (h_O2_avoids seg hseg)
                · exact h
              -- q1 = O2 + t*d, so (q1 - O1) = t*d + delta
              have h_q1_n3_pos : (q1.x - O1.x) * n3.x + (q1.y - O1.y) * n3.y > 0 := by
                have hqx : q1.x - O1.x = t * d.x + delta.x := by simp only [delta]; linarith [htx]
                have hqy : q1.y - O1.y = t * d.y + delta.y := by simp only [delta]; linarith [hty]
                have : (q1.x - O1.x) * n3.x + (q1.y - O1.y) * n3.y = t * κ := by
                  calc (q1.x - O1.x) * n3.x + (q1.y - O1.y) * n3.y
                      = (t * d.x + delta.x) * n3.x + (t * d.y + delta.y) * n3.y := by rw [hqx, hqy]
                    _ = t * (d.x * n3.x + d.y * n3.y) + (delta.x * n3.x + delta.y * n3.y) := by ring
                    _ = t * κ + 0 := by rw [h_d_n3, h_dn3_zero]
