import Polygons.Parity

open Classical Set

noncomputable section

namespace PolygonProofs

/-- Any point that is not a vertex of the polygon admits a ray that avoids all vertices.
    The direction (1, q) is chosen with q avoiding the finitely many "bad" slopes. -/
private lemma exists_ray_avoiding_vertices (p : Vector2D) (poly : Polygon)
    (h_not_vertex : ∀ v ∈ poly.vertices, v ≠ p) :
    ∃ r : Ray, r.origin = p ∧ rayAvoidsVertices r poly := by
  have : Infinite ℚ := Infinite.of_injective (fun n : ℕ => (n : ℚ)) Nat.cast_injective
  let badSlopes : Finset ℚ := (poly.vertices.filterMap fun v =>
    if v.x > p.x then some ((v.y - p.y) / (v.x - p.x)) else none).toFinset
  obtain ⟨q, hq⟩ := Finset.exists_not_mem badSlopes
  have h_nonzero : (⟨1, q⟩ : Vector2D) ≠ ⟨0, 0⟩ := by
    intro h; exact absurd (congrArg Vector2D.x h) (by norm_num)
  refine ⟨⟨p, ⟨1, q⟩, h_nonzero⟩, rfl, ?_⟩
  rw [rayAvoidsVertices, Set.eq_empty_iff_forall_not_mem]
  intro v hv
  simp only [Set.mem_inter_iff] at hv
  obtain ⟨hv_ray, hv_vert⟩ := hv
  simp only [Ray.toSet, Set.mem_setOf_eq] at hv_ray
  simp only [Polygon.toVertices, Set.mem_setOf_eq] at hv_vert
  obtain ⟨t, ht_nonneg, hvx, hvy⟩ := hv_ray
  simp only [mul_one] at hvx
  have hne : v ≠ p := h_not_vertex v hv_vert
  have ht_eq : t = v.x - p.x := by linarith
  by_cases h_gt : v.x > p.x
  · have h_slope_mem : (v.y - p.y) / (v.x - p.x) ∈ badSlopes := by
      simp only [badSlopes, List.mem_toFinset, List.mem_filterMap]
      exact ⟨v, hv_vert, by simp [if_pos h_gt]⟩
    have hvmy : v.y - p.y = t * q := by linarith
    rw [ht_eq] at hvmy
    have hvx_ne : v.x - p.x ≠ 0 := ne_of_gt (by linarith : v.x - p.x > 0)
    have hq_eq : q = (v.y - p.y) / (v.x - p.x) := by
      rw [eq_div_iff hvx_ne, mul_comm]; linarith
    exact hq (hq_eq ▸ h_slope_mem)
  · push_neg at h_gt
    by_cases h_eq : v.x = p.x
    · have ht_zero : t = 0 := by linarith
      have hvy_eq : v.y = p.y := by
        have := hvy; rw [ht_zero] at this; simp at this; exact this
      exact hne (by cases v; cases p; simp_all)
    · linarith [lt_of_le_of_ne h_gt h_eq]

/-- If a ∈ l1 and l1.length ≤ l2.length, then ∃ b, (a, b) ∈ l1.zip l2. -/
private lemma exists_zip_pair' {l1 l2 : List Vector2D} {v : Vector2D}
    (hv : v ∈ l1) (hlen : l1.length ≤ l2.length) :
    ∃ w, (v, w) ∈ l1.zip l2 := by
  induction l1 generalizing l2 with
  | nil => simp at hv
  | cons x xs ih =>
    match l2 with
    | [] => simp at hlen
    | y :: ys =>
      rcases List.mem_cons.mp hv with rfl | hv'
      · exact ⟨y, List.mem_cons.mpr (Or.inl rfl)⟩
      · obtain ⟨w, hw⟩ := ih (l2 := ys) hv' (by simp only [List.length_cons] at hlen; omega)
        exact ⟨w, List.mem_cons_of_mem _ hw⟩

/-- For a polygon with ≥ 2 vertices, every vertex lies on some polygon segment. -/
private lemma vertex_on_some_segment' (poly : Polygon) (v : Vector2D)
    (hv : v ∈ poly.vertices) (h_len : poly.vertices.length ≥ 2) :
    ∃ seg ∈ poly.segments, v ∈ seg.toSet := by
  cases h_eq : poly.vertices with
  | nil => simp [h_eq] at hv
  | cons a tl =>
    cases tl with
    | nil => simp [h_eq] at h_len
    | cons b rest =>
      rw [h_eq] at hv
      have hlen : (a :: b :: rest).length ≤ ((b :: rest) ++ [a]).length := by
        simp [List.length_cons, List.length_append]
      obtain ⟨w, hw⟩ := exists_zip_pair' hv hlen
      refine ⟨⟨v, w⟩, ?_, ⟨0, le_refl _, le_of_lt one_pos, by simp, by simp⟩⟩
      have h_poly : poly = ⟨a :: b :: rest⟩ := by cases poly; simp_all
      rw [h_poly]
      show (⟨v, w⟩ : LineSegment) ∈ (Polygon.mk (a :: b :: rest)).segments
      simp only [Polygon.segments, List.mem_map, Prod.exists]
      exact ⟨v, w, hw, rfl⟩

theorem interior_forall_eq_exists (poly : Polygon)
    (h_len : poly.vertices.length ≥ 2) :
    { p : Vector2D |
        (∀ seg ∈ poly.segments, pointAvoidsSegment p seg) ∧
        ∀ r : Ray, r.origin = p → rayAvoidsVertices r poly →
          intersectionRayPolygonSegmentsNumber r poly % 2 = 1 } =
    { p : Vector2D |
        (∀ seg ∈ poly.segments, pointAvoidsSegment p seg) ∧
        ∃ r : Ray, r.origin = p ∧ rayAvoidsVertices r poly ∧
          intersectionRayPolygonSegmentsNumber r poly % 2 = 1 } := by
  ext p
  simp only [mem_setOf_eq]
  constructor
  · -- forall → exists: construct a witness ray
    intro ⟨h_avoids_segs, h_forall⟩
    have h_not_vertex : ∀ v ∈ poly.vertices, v ≠ p := by
      intro v hv h_eq; subst h_eq
      obtain ⟨seg, hseg, hp_on⟩ := vertex_on_some_segment' poly v hv h_len
      exact h_avoids_segs seg hseg hp_on
    obtain ⟨r, h_origin, h_avoids_verts⟩ := exists_ray_avoiding_vertices p poly h_not_vertex
    exact ⟨h_avoids_segs, r, h_origin, h_avoids_verts, h_forall r h_origin h_avoids_verts⟩
  · -- exists → forall: use parity invariance
    intro ⟨h_avoids_segs, r₀, h_origin₀, h_avoids₀, h_parity₀⟩
    refine ⟨h_avoids_segs, fun r h_origin h_avoids => ?_⟩
    have h_same : sameOrigin r₀ r := by
      simp [sameOrigin, h_origin₀, h_origin]
    have h_seg_avoids : ∀ seg ∈ poly.segments, pointAvoidsSegment r₀.origin seg := by
      rwa [h_origin₀]
    have h_eq := intersectionParity_eq_of_sameOrigin_avoidsVertices r₀ r poly
      h_same h_avoids₀ h_avoids h_seg_avoids
    omega

end PolygonProofs
