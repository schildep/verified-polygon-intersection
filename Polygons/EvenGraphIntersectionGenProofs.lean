import Polygons.EvenGraphIntersectionProofs

/-!
# Even Graph Intersection without the finiteness hypothesis — Implementation

Given two even graphs `G1`, `G2` (no assumption that `∂G1 ∩ ∂G2` is finite), we construct an
even graph whose ray-parity interior equals `G1.interior ∩ G2.interior`.

See `RemoveFinitenessInformalProof.md` for the full mathematical proof. The construction
mirrors the finite case (`graphRefinementSelfAndWrt` + `selectSegmentsInside`) but:
* refines each graph at a **finite, explicit** breakpoint set (transversal crossings +
  the other graph's vertices that lie on this graph's boundary) instead of the whole, possibly
  infinite, intersection `∂G1 ∩ ∂G2`;
* adds the **shared** (collinearly overlapping) boundary edges that lie on the boundary of
  `G1.interior ∩ G2.interior` (the `onInterBoundary` test).
-/

open Classical Set

noncomputable section

namespace EvenGraphIntersectionGenProofs

/-! ### Lines and collinearity of segments -/

/-- The set of points on the line through `seg.p1` in direction `seg.p2 - seg.p1`,
    expressed by the cross-product test `(p - seg.p1) × (seg.p2 - seg.p1) = 0`. -/
def lineOf (seg : LineSegment) : Set Vector2D :=
  { p : Vector2D |
    (p.x - seg.p1.x) * (seg.p2.y - seg.p1.y) = (p.y - seg.p1.y) * (seg.p2.x - seg.p1.x) }

/-- Two segments lie on the same line: both endpoints of `t` are on the line of `s`. -/
def SameLine (s t : LineSegment) : Prop :=
  t.p1 ∈ lineOf s ∧ t.p2 ∈ lineOf s

theorem mem_lineOf_p1 (seg : LineSegment) : seg.p1 ∈ lineOf seg := by
  simp only [lineOf, Set.mem_setOf_eq]; ring

theorem mem_lineOf_p2 (seg : LineSegment) : seg.p2 ∈ lineOf seg := by
  simp only [lineOf, Set.mem_setOf_eq]; ring

/-- Every point of a segment lies on its line. -/
theorem toSet_subset_lineOf (seg : LineSegment) : seg.toSet ⊆ lineOf seg := by
  intro p hp
  obtain ⟨t, _, _, hx, hy⟩ := hp
  simp only [lineOf, Set.mem_setOf_eq]
  rw [hx, hy]; ring

/-- If two distinct points lie on the line of a non-degenerate segment `s`, then any point on
    the line through those two points (here: any point `z` collinear with them) … is captured
    by the direction being parallel. Concretely: the direction of `s` is parallel to `q - p`. -/
theorem dir_parallel_of_two_mem_lineOf
    (s : LineSegment) (p q : Vector2D)
    (hp : p ∈ lineOf s) (hq : q ∈ lineOf s) :
    (q.x - p.x) * (s.p2.y - s.p1.y) = (q.y - p.y) * (s.p2.x - s.p1.x) := by
  simp only [lineOf, Set.mem_setOf_eq] at hp hq
  linarith [hp, hq]

/-- Cross product of `u` and `v` (treating points as vectors). -/
def cross2 (ux uy vx vy : ℚ) : ℚ := ux * vy - uy * vx

/-- A point `z` whose displacement from `p` is parallel to both `q - p` (nonzero) forces `z`
    to lie on the line through `p` with direction `q - p`. Auxiliary algebra: if
    `(q-p)` is parallel to direction `d` (nonzero as a 2-vector) and to `(z-p)`, then `z-p`
    is parallel to `q-p`. -/
theorem parallel_trans_of_nonzero
    (qx qy zx zy dx dy : ℚ)
    (hd : (dx, dy) ≠ (0, 0))
    (hq : qx * dy = qy * dx)        -- (q) ∥ d
    (hz : zx * dy = zy * dx) :      -- (z) ∥ d
    qx * zy = qy * zx := by
  -- q ∥ d and z ∥ d with d ≠ 0 ⟹ q ∥ z.
  rcases (by
    by_contra h
    push_neg at h
    exact hd (Prod.ext h.1 h.2) : dx ≠ 0 ∨ dy ≠ 0) with hdx | hdy
  · -- dx ≠ 0
    have e1 : qx * dy * zx = qy * dx * zx := by rw [hq]
    have e2 : zx * dy * qx = zy * dx * qx := by rw [hz]
    -- qx*zy*dx = qy*zx*dx  (derive), then cancel dx
    have key : (qx * zy - qy * zx) * dx = 0 := by nlinarith [e1, e2]
    rcases mul_eq_zero.mp key with h | h
    · linarith
    · exact absurd h hdx
  · have e1 : qx * dy * zy = qy * dx * zy := by rw [hq]
    have e2 : zx * dy * qy = zy * dx * qy := by rw [hz]
    have key : (qx * zy - qy * zx) * dy = 0 := by nlinarith [e1, e2]
    rcases mul_eq_zero.mp key with h | h
    · linarith
    · exact absurd h hdy

/-- A degenerate segment is a single point. -/
theorem toSet_degenerate (t : LineSegment) (h : t.p1 = t.p2) : t.toSet = {t.p1} := by
  ext z
  simp only [LineSegment.toSet, Set.mem_setOf_eq, Set.mem_singleton_iff]
  constructor
  · rintro ⟨u, _, _, hx, hy⟩
    rw [← h] at hx hy
    exact Vector2D.ext (by rw [hx]; ring) (by rw [hy]; ring)
  · rintro rfl
    exact ⟨0, le_refl 0, zero_le_one, by ring, by ring⟩

/-- Non-degenerate segment `s` and any segment `t` that do **not** lie on the same line meet
    in at most one point. -/
theorem inter_subsingleton_of_not_sameLine
    (s t : LineSegment) (hs : s.p1 ≠ s.p2)
    (h_not : ¬ SameLine s t) :
    (s.toSet ∩ t.toSet).Subsingleton := by
  by_cases hdeg : t.p1 = t.p2
  · -- t is a single point; intersection ⊆ {t.p1}.
    have : s.toSet ∩ t.toSet ⊆ {t.p1} := by
      rw [toSet_degenerate t hdeg]; exact Set.inter_subset_right
    exact (Set.subsingleton_singleton).anti this
  intro p ⟨hps, hpt⟩ q ⟨hqs, hqt⟩
  by_contra hpq
  -- p, q distinct, both on lineOf s and lineOf t. Show SameLine s t (contradiction).
  apply h_not
  have hps' : p ∈ lineOf s := toSet_subset_lineOf s hps
  have hqs' : q ∈ lineOf s := toSet_subset_lineOf s hqs
  have hpt' : p ∈ lineOf t := toSet_subset_lineOf t hpt
  have hqt' : q ∈ lineOf t := toSet_subset_lineOf t hqt
  -- (q-p) ∥ d_s  and  (q-p) ∥ d_t.
  have hs_par : (q.x - p.x) * (s.p2.y - s.p1.y) = (q.y - p.y) * (s.p2.x - s.p1.x) :=
    dir_parallel_of_two_mem_lineOf s p q hps' hqs'
  have ht_par : (q.x - p.x) * (t.p2.y - t.p1.y) = (q.y - p.y) * (t.p2.x - t.p1.x) :=
    dir_parallel_of_two_mem_lineOf t p q hpt' hqt'
  -- d_s ≠ 0 (s nondegenerate).
  have hds : (s.p2.x - s.p1.x, s.p2.y - s.p1.y) ≠ (0, 0) := by
    intro h
    apply hs
    have hx : s.p2.x - s.p1.x = 0 := congrArg Prod.fst h
    have hy : s.p2.y - s.p1.y = 0 := congrArg Prod.snd h
    exact (Vector2D.ext (by linarith) (by linarith)).symm
  -- (q-p) ≠ 0 since p ≠ q.
  have hqp_ne : (q.x - p.x, q.y - p.y) ≠ (0, 0) := by
    intro h
    apply hpq
    have hx : q.x - p.x = 0 := congrArg Prod.fst h
    have hy : q.y - p.y = 0 := congrArg Prod.snd h
    exact (Vector2D.ext (by linarith) (by linarith))
  -- We need: t.p1 ∈ lineOf s and t.p2 ∈ lineOf s.
  -- Strategy: (q-p) ∥ d_s. Show d_t ∥ d_s using that (q-p) ∥ d_t and (q-p) ≠ 0.
  -- Then t.p1 - p ∥ (q-p) [from p,t.p1 ∈ lineOf t and d_t ∥ (q-p)] ... cleaner: any point on
  -- lineOf t has displacement-from-p parallel to (q-p), hence parallel to d_s, and p itself
  -- is on lineOf s, so the point is on lineOf s.
  -- First: for any z ∈ lineOf t, (z - p) ∥ (q - p).
  have hdt : (t.p2.x - t.p1.x, t.p2.y - t.p1.y) ≠ (0, 0) := by
    intro h
    apply hdeg
    have hx : t.p2.x - t.p1.x = 0 := congrArg Prod.fst h
    have hy : t.p2.y - t.p1.y = 0 := congrArg Prod.snd h
    exact (Vector2D.ext (by linarith) (by linarith)).symm
  have hz_par_qp : ∀ z : Vector2D, z ∈ lineOf t →
      (z.x - p.x) * (q.y - p.y) = (z.y - p.y) * (q.x - p.x) := by
    intro z hz
    have hzt : (z.x - p.x) * (t.p2.y - t.p1.y) = (z.y - p.y) * (t.p2.x - t.p1.x) :=
      dir_parallel_of_two_mem_lineOf t p z hpt' hz
    have := parallel_trans_of_nonzero (q.x - p.x) (q.y - p.y) (z.x - p.x) (z.y - p.y)
      (t.p2.x - t.p1.x) (t.p2.y - t.p1.y) hdt ht_par hzt
    linear_combination -this
  -- For z ∈ lineOf t: (z-p) ∥ (q-p) ∥ d_s, so (z-p) ∥ d_s, so z ∈ lineOf s (since p ∈ lineOf s).
  have hz_in_s : ∀ z : Vector2D, z ∈ lineOf t → z ∈ lineOf s := by
    intro z hz
    have h1 := hz_par_qp z hz   -- (z-p) ∥ (q-p)
    -- (q-p) ∥ d_s : hs_par. (z-p) ∥ (q-p) : h1. (q-p) ≠ 0.
    -- ⟹ (z-p) ∥ d_s.
    have hzp_par_ds : (z.x - p.x) * (s.p2.y - s.p1.y) = (z.y - p.y) * (s.p2.x - s.p1.x) := by
      -- use parallel_trans with d := (q-p), q := (z-p), z := d_s
      have := parallel_trans_of_nonzero (z.x - p.x) (z.y - p.y)
        (s.p2.x - s.p1.x) (s.p2.y - s.p1.y) (q.x - p.x) (q.y - p.y) hqp_ne
        (by linarith [h1]) (by linarith [hs_par])
      linarith [this]
    -- z ∈ lineOf s : (z.x - s.p1.x)*d_s.y = (z.y - s.p1.y)*d_s.x.
    -- p ∈ lineOf s: (p.x - s.p1.x)*d_s.y = (p.y - s.p1.y)*d_s.x.
    simp only [lineOf, Set.mem_setOf_eq] at hps' ⊢
    linarith [hps', hzp_par_ds]
  exact ⟨hz_in_s t.p1 (mem_lineOf_p1 t), hz_in_s t.p2 (mem_lineOf_p2 t)⟩

/-! ### Finite breakpoint set and the arrangement refinement -/

/-- The finite set of breakpoints at which we split `H1`: transversal crossings of `H1`'s
    segments with `H1`'s own segments (self-arrangement) and with `H2`'s segments (arrangement
    w.r.t. `H2`), and `H2`-vertices lying on `∂H1`. -/
def breakpointsSet (H1 H2 : EvenGraph) : Set Vector2D :=
  { x | (∃ s ∈ H1.segments, ∃ t ∈ H1.segments ++ H2.segments,
            ¬ SameLine s t ∧ x ∈ s.toSet ∧ x ∈ t.toSet) ∨
        (x ∈ H2.toVertices ∧ x ∈ H1.toBoundarySet) }

theorem breakpointsSet_subset_boundary (H1 H2 : EvenGraph) :
    breakpointsSet H1 H2 ⊆ H1.toBoundarySet := by
  intro x hx
  rcases hx with ⟨s, hs, t, _, _, hxs, _⟩ | ⟨_, hxb⟩
  · exact ⟨s, hs, hxs⟩
  · exact hxb

theorem breakpointsSet_finite (H1 H2 : EvenGraph) : (breakpointsSet H1 H2).Finite := by
  apply Set.Finite.union
  · -- transversal crossings: finite union (over the finite segment lists) of subsingletons
    have hsub : { x | ∃ s ∈ H1.segments, ∃ t ∈ H1.segments ++ H2.segments,
          ¬ SameLine s t ∧ x ∈ s.toSet ∧ x ∈ t.toSet } ⊆
        ⋃ s ∈ H1.segments, ⋃ t ∈ H1.segments ++ H2.segments,
          { x | ¬ SameLine s t ∧ x ∈ s.toSet ∧ x ∈ t.toSet } := by
      intro x hx
      obtain ⟨s, hs, t, ht, hsl, hxs, hxt⟩ := hx
      exact Set.mem_biUnion hs (Set.mem_biUnion ht ⟨hsl, hxs, hxt⟩)
    apply Set.Finite.subset _ hsub
    apply Set.Finite.biUnion (H1.segments.finite_toSet)
    intro s hs
    apply Set.Finite.biUnion (H1.segments ++ H2.segments).finite_toSet
    intro t _
    by_cases hsl : SameLine s t
    · simp only [hsl, not_true, false_and, Set.setOf_false]
      exact Set.finite_empty
    · apply Set.Finite.subset (inter_subsingleton_of_not_sameLine s t
        (H1.segments_nondegenerate s hs) hsl).finite
      intro x hx; exact ⟨hx.2.1, hx.2.2⟩
  · -- H2-vertices on ∂H1: subset of the finite vertex list.
    apply Set.Finite.subset (H2.toVertices.toFinset.finite_toSet)
    intro x hx
    simp only [List.coe_toFinset, Set.mem_setOf_eq]
    exact hx.1

/-- The breakpoint list for refining `H1` w.r.t. `H2`. -/
def breakpointsList (H1 H2 : EvenGraph) : List Vector2D :=
  (breakpointsSet_finite H1 H2).toFinset.toList

theorem mem_breakpointsList_iff (H1 H2 : EvenGraph) (x : Vector2D) :
    x ∈ breakpointsList H1 H2 ↔ x ∈ breakpointsSet H1 H2 := by
  rw [breakpointsList, Finset.mem_toList, Set.Finite.mem_toFinset]

theorem breakpointsList_subset_boundary (H1 H2 : EvenGraph) :
    ∀ pt ∈ breakpointsList H1 H2, pt ∈ H1.toBoundarySet := by
  intro pt hpt
  exact breakpointsSet_subset_boundary H1 H2 ((mem_breakpointsList_iff H1 H2 pt).mp hpt)

/-- The arrangement-refined `G1` w.r.t. `G2`: first self-refine, then split at the finite
    breakpoints w.r.t. `G2`. -/
def arr (G1 G2 : EvenGraph) : EvenGraph :=
  EvenGraphRefinementProofs.refineGraphWithPoints (graphRefinementSelf G1)
    (breakpointsList (graphRefinementSelf G1) G2)
    (breakpointsList_subset_boundary (graphRefinementSelf G1) G2)

theorem arr_boundary_eq (G1 G2 : EvenGraph) :
    (arr G1 G2).toBoundarySet = G1.toBoundarySet := by
  rw [arr, EvenGraphRefinementProofs.refineGraphWithPoints_boundary_eq,
      graphRefinementSelf_boundary_eq]

theorem arr_interior_eq (G1 G2 : EvenGraph) :
    (arr G1 G2).interior = G1.interior := by
  rw [arr, EvenGraphRefinementProofs.refineGraphWithPoints_interior_eq,
      graphRefinementSelf_interior_eq]

theorem arr_no_segment_interior_vertices (G1 G2 : EvenGraph) :
    ∀ v ∈ (arr G1 G2).toVertices, ∀ seg ∈ (arr G1 G2).segments,
      seg.p1 ≠ v → seg.p2 ≠ v → v ∉ seg.toSet := by
  rw [arr]
  exact EvenGraphRefinementProofs.refineGraphWithPoints_preserves_no_segment_interior_vertices
    (graphRefinementSelf G1) _ _ (graphRefinementSelf_no_segment_interior_vertices G1)

/-- The segments of `arr G1 G2`, viewed as a multiset of unordered endpoint pairs, equal
    `G1.segments.flatMap (fun s => iterativeSplit s (selfPts ++ breakpoints))` mapped to
    endpoint multisets, where `selfPts` are the self-refinement points of `G1` and
    `breakpoints` are the (finite, explicit) breakpoints of `graphRefinementSelf G1` w.r.t. `G2`.
    No finiteness hypothesis is required. -/
theorem arr_segments_perm (G1 G2 : EvenGraph) :
    List.Perm
      ((arr G1 G2).segments.map LineSegment.toEndpointsMultiset)
      ((G1.segments.flatMap (fun s => EvenGraphRefinementProofs.iterativeSplit s
          ((EvenGraphRefinementProofs.selfSegmentInteriorVertices_finite G1).toFinset.toList ++
           breakpointsList (graphRefinementSelf G1) G2))).map
        LineSegment.toEndpointsMultiset) := by
  set selfPts : List Vector2D :=
    (EvenGraphRefinementProofs.selfSegmentInteriorVertices_finite G1).toFinset.toList
    with hselfPts_def
  set h_fin_self := EvenGraphRefinementProofs.selfSegmentInteriorVertices_finite G1
    with h_fin_self_def
  set breakpoints : List Vector2D := breakpointsList (graphRefinementSelf G1) G2
    with hbreakpoints_def
  -- `arr G1 G2` is by definition `refineGraphWithPoints (graphRefinementSelf G1) breakpoints _`.
  -- So `refineGraphWithPoints_segments_perm` gives the first perm directly.
  have h1 : List.Perm
      ((arr G1 G2).segments.map LineSegment.toEndpointsMultiset)
      (((graphRefinementSelf G1).segments.flatMap
        (fun s => EvenGraphRefinementProofs.iterativeSplit s breakpoints)).map
        LineSegment.toEndpointsMultiset) := by
    rw [arr]
    exact EvenGraphRefinementProofs.refineGraphWithPoints_segments_perm
      (graphRefinementSelf G1) breakpoints
      (breakpointsList_subset_boundary (graphRefinementSelf G1) G2)
  refine h1.trans ?_
  -- `graphRefinementSelf G1 = refineGraphWithPoints G1 selfPts _`, so a second
  -- `refineGraphWithPoints_segments_perm` expresses its segments via `iterativeSplit · selfPts`.
  have h_all_self : ∀ pt ∈ selfPts, pt ∈ G1.toBoundarySet := fun pt h_mem => by
    have h1 : pt ∈ h_fin_self.toFinset := Finset.mem_toList.mp h_mem
    exact EvenGraphRefinementProofs.selfSegmentInteriorVertices_subset_boundary G1
      (h_fin_self.mem_toFinset.mp h1)
  have h2 : List.Perm
      ((graphRefinementSelf G1).segments.map LineSegment.toEndpointsMultiset)
      ((G1.segments.flatMap
        (fun s => EvenGraphRefinementProofs.iterativeSplit s selfPts)).map
        LineSegment.toEndpointsMultiset) := by
    have h_def_self : (graphRefinementSelf G1).segments =
        (EvenGraphRefinementProofs.refineGraphWithPoints G1 selfPts h_all_self).segments := rfl
    rw [h_def_self]
    exact EvenGraphRefinementProofs.refineGraphWithPoints_segments_perm G1 selfPts h_all_self
  -- Lift `h2` through the outer `flatMap (iterativeSplit · breakpoints)`.
  have h_lift := EvenGraphRefinementProofs.flatMap_iterativeSplit_perm_of_perm_toEM
    breakpoints _ _ h2
  refine h_lift.trans ?_
  rw [List.flatMap_assoc]
  -- Collapse the nested splits into a single `iterativeSplit · (selfPts ++ breakpoints)`.
  have h_funext :
      (fun (x : LineSegment) =>
        (EvenGraphRefinementProofs.iterativeSplit x selfPts).flatMap
          (fun s => EvenGraphRefinementProofs.iterativeSplit s breakpoints)) =
      (fun (s : LineSegment) =>
        EvenGraphRefinementProofs.iterativeSplit s (selfPts ++ breakpoints)) := by
    funext s
    rw [EvenGraphRefinementProofs.iterativeSplit_append]
  rw [h_funext]

/-! ### The dichotomy: each arrangement segment is transversal or shared -/

/-- Every segment of `refineGraphWithPoints G pts` is contained in some segment of `G`. -/
theorem refineGraphWithPoints_seg_subset :
    ∀ (G : EvenGraph) (pts : List Vector2D)
      (h_all : ∀ pt ∈ pts, pt ∈ G.toBoundarySet) (σ : LineSegment),
      σ ∈ (EvenGraphRefinementProofs.refineGraphWithPoints G pts h_all).segments →
      ∃ s ∈ G.segments, σ.toSet ⊆ s.toSet
  | G, [], _, σ, hσ => ⟨σ, hσ, le_refl _⟩
  | G, pt :: rest, h_all, σ, hσ => by
      simp only [EvenGraphRefinementProofs.refineGraphWithPoints] at hσ
      obtain ⟨s', hs', hsub'⟩ :=
        refineGraphWithPoints_seg_subset (EvenGraphRefinementProofs.refineAllPt G pt) rest _ σ hσ
      obtain ⟨s, hs, hform⟩ := EvenGraphRefinementProofs.refineAllPt_segment_form G pt s' hs'
      refine ⟨s, hs, ?_⟩
      rcases hform with rfl | ⟨rfl, hpt, _, _⟩ | ⟨rfl, hpt, _, _⟩
      · exact hsub'
      · exact hsub'.trans (EvenGraphRefinementProofs.subseg_p1_subset s pt hpt)
      · exact hsub'.trans (EvenGraphRefinementProofs.subseg_p2_subset s pt hpt)

/-- Every segment of `arr G1 G2` is contained in some self-refined-`G1` segment. -/
theorem arr_seg_subset (G1 G2 : EvenGraph) (σ : LineSegment) (hσ : σ ∈ (arr G1 G2).segments) :
    ∃ s ∈ (graphRefinementSelf G1).segments, σ.toSet ⊆ s.toSet :=
  refineGraphWithPoints_seg_subset (graphRefinementSelf G1) _ _ σ hσ

/-- A segment `σ` is **shared** w.r.t. `G2` if its whole point set lies in `∂G2`. -/
def IsShared (G2 : EvenGraph) (σ : LineSegment) : Prop := σ.toSet ⊆ G2.toBoundarySet

theorem seg_p1_mem (σ : LineSegment) : σ.p1 ∈ σ.toSet :=
  ⟨0, le_refl 0, zero_le_one, by ring, by ring⟩

theorem seg_p2_mem (σ : LineSegment) : σ.p2 ∈ σ.toSet :=
  ⟨1, zero_le_one, le_refl 1, by ring, by ring⟩

set_option maxHeartbeats 1600000 in
/-- 1D interval containment for collinear segments: if `σ` and `t` lie on the line of a
    non-degenerate `s`, `x` is in the open interior of `σ` and on `t`, and neither endpoint of
    `t` is in the open interior of `σ`, then `σ ⊆ t`. -/
theorem collinear_containment (s σ t : LineSegment)
    (hσ1 : σ.p1 ∈ lineOf s) (hσ2 : σ.p2 ∈ lineOf s)
    (ht1 : t.p1 ∈ lineOf s) (ht2 : t.p2 ∈ lineOf s)
    (hsnd : s.p1 ≠ s.p2) (hσnd : σ.p1 ≠ σ.p2)
    (x : Vector2D) (hxσ : x ∈ σ.toSet) (hxt : x ∈ t.toSet)
    (hxne1 : x ≠ σ.p1) (hxne2 : x ≠ σ.p2)
    (ht1' : t.p1 ∈ σ.toSet → t.p1 = σ.p1 ∨ t.p1 = σ.p2)
    (ht2' : t.p2 ∈ σ.toSet → t.p2 = σ.p1 ∨ t.p2 = σ.p2) :
    σ.toSet ⊆ t.toSet := by
  set dx := s.p2.x - s.p1.x with hdx_def
  set dy := s.p2.y - s.p1.y with hdy_def
  -- The linear projection onto the direction of `s`, introduced as an *opaque* local
  -- constant (not a `let`) so that later rewriting/`isDefEq` does not unfold a heavy body.
  obtain ⟨π, hπ_def⟩ : ∃ π : Vector2D → ℚ,
      ∀ p : Vector2D, π p = (p.x - s.p1.x) * dx + (p.y - s.p1.y) * dy :=
    ⟨fun p => (p.x - s.p1.x) * dx + (p.y - s.p1.y) * dy, fun _ => rfl⟩
  -- (dx,dy) ≠ 0, hence D := dx*dx+dy*dy > 0.
  have hdxy : dx ≠ 0 ∨ dy ≠ 0 := by
    by_contra h
    push_neg at h
    exact hsnd (Vector2D.ext (by have := h.1; simp only [hdx_def] at this; linarith)
      (by have := h.2; simp only [hdy_def] at this; linarith)).symm
  have hD : 0 < dx * dx + dy * dy := by
    rcases hdxy with h | h
    · have hpos : 0 < dx * dx := mul_self_pos.mpr h
      have := mul_self_nonneg dy
      linarith
    · have hpos : 0 < dy * dy := mul_self_pos.mpr h
      have := mul_self_nonneg dx
      linarith
  -- Injectivity of π on the line of s.
  have hinj : ∀ p q : Vector2D, p ∈ lineOf s → q ∈ lineOf s → π p = π q → p = q := by
    intro p q hp hq hpq
    simp only [lineOf, Set.mem_setOf_eq, ← hdx_def, ← hdy_def] at hp hq
    simp only [hπ_def] at hpq
    -- u := p.x - q.x, v := p.y - q.y.
    have hpar : (p.x - q.x) * dy = (p.y - q.y) * dx := by linear_combination hp - hq
    have hproj : (p.x - q.x) * dx + (p.y - q.y) * dy = 0 := by linear_combination hpq
    have hu : (p.x - q.x) * (dx * dx + dy * dy) = 0 := by linear_combination dx * hproj + dy * hpar
    have hv : (p.y - q.y) * (dx * dx + dy * dy) = 0 := by linear_combination dy * hproj - dx * hpar
    have hux : p.x - q.x = 0 := by
      rcases mul_eq_zero.mp hu with h | h
      · exact h
      · exact absurd h (ne_of_gt hD)
    have hvy : p.y - q.y = 0 := by
      rcases mul_eq_zero.mp hv with h | h
      · exact h
      · exact absurd h (ne_of_gt hD)
    exact Vector2D.ext (by linarith) (by linarith)
  -- A convex combination of two points of `lineOf s` is on `lineOf s`.
  have hconv_line : ∀ a b : Vector2D, a ∈ lineOf s → b ∈ lineOf s → ∀ r : ℚ,
      (⟨(1 - r) * a.x + r * b.x, (1 - r) * a.y + r * b.y⟩ : Vector2D) ∈ lineOf s := by
    intro a b ha hb r
    simp only [lineOf, Set.mem_setOf_eq, ← hdx_def, ← hdy_def] at ha hb ⊢
    linear_combination (1 - r) * ha + r * hb
  -- π of a convex combination.
  have hπ_conv : ∀ a b : Vector2D, ∀ r : ℚ,
      π (⟨(1 - r) * a.x + r * b.x, (1 - r) * a.y + r * b.y⟩ : Vector2D)
        = (1 - r) * π a + r * π b := by
    intro a b r
    simp only [hπ_def]
    ring
  -- Step 4: a point of a collinear segment `u'` is on the line and has π between endpoints.
  have step4 : ∀ u' : LineSegment, u'.p1 ∈ lineOf s → u'.p2 ∈ lineOf s → ∀ p : Vector2D,
      p ∈ u'.toSet → p ∈ lineOf s ∧
        ((π p - π u'.p1) * (π p - π u'.p2) ≤ 0) := by
    intro u' h1 h2 p hp
    obtain ⟨r, hr0, hr1, hxeq, hyeq⟩ := hp
    have hpeq : p = (⟨(1 - r) * u'.p1.x + r * u'.p2.x, (1 - r) * u'.p1.y + r * u'.p2.y⟩ : Vector2D) :=
      Vector2D.ext hxeq hyeq
    subst hpeq
    refine ⟨hconv_line _ _ h1 h2 r, ?_⟩
    rw [hπ_conv]
    obtain ⟨a, b, ha, hb⟩ : ∃ a b : ℚ, a = π u'.p1 ∧ b = π u'.p2 := ⟨_, _, rfl, rfl⟩
    rw [← ha, ← hb]
    nlinarith [hr0, hr1, mul_nonneg hr0 (sub_nonneg.mpr hr1), sq_nonneg (a - b)]
  -- Step 5: on the line with π between endpoints ⟹ membership (for nondegenerate u').
  have step5 : ∀ u' : LineSegment, u'.p1 ∈ lineOf s → u'.p2 ∈ lineOf s → u'.p1 ≠ u'.p2 →
      ∀ p : Vector2D, p ∈ lineOf s → (π p - π u'.p1) * (π p - π u'.p2) ≤ 0 →
      p ∈ u'.toSet := by
    intro u' h1 h2 hnd p hp hbetween
    have hπne : π u'.p1 ≠ π u'.p2 := fun h => hnd (hinj _ _ h1 h2 h)
    have hden : π u'.p2 - π u'.p1 ≠ 0 := sub_ne_zero.mpr (Ne.symm hπne)
    -- Work with abstracted scalars to keep arithmetic small.
    obtain ⟨a, b, c, ha, hb, hc⟩ :
        ∃ a b c : ℚ, a = π u'.p1 ∧ b = π u'.p2 ∧ c = π p := ⟨_, _, _, rfl, rfl, rfl⟩
    have hbetween' : (c - a) * (c - b) ≤ 0 := by rw [ha, hb, hc]; exact hbetween
    have hab : b - a ≠ 0 := by rw [ha, hb]; exact hden
    -- r := (c - a) / (b - a) ∈ [0,1].
    have hr0 : 0 ≤ (c - a) / (b - a) := by
      rcases lt_or_gt_of_ne hab with hlt | hgt
      · apply div_nonneg_of_nonpos
        · nlinarith [hbetween', hlt]
        · linarith
      · apply div_nonneg
        · nlinarith [hbetween', hgt]
        · linarith
    have hr1 : (c - a) / (b - a) ≤ 1 := by
      rcases lt_or_gt_of_ne hab with hlt | hgt
      · rw [div_le_one_of_neg (by linarith)]; nlinarith [hbetween', hlt]
      · rw [div_le_one (by linarith)]; nlinarith [hbetween', hgt]
    set r : ℚ := (c - a) / (b - a) with hr_def
    -- The convex combination point.
    refine ⟨r, hr0, hr1, ?_, ?_⟩ <;>
    · -- Show p equals the convex combination point, via injectivity of π.
      have hqline : (⟨(1 - r) * u'.p1.x + r * u'.p2.x, (1 - r) * u'.p1.y + r * u'.p2.y⟩ : Vector2D)
          ∈ lineOf s := hconv_line _ _ h1 h2 r
      have hπq : π (⟨(1 - r) * u'.p1.x + r * u'.p2.x, (1 - r) * u'.p1.y + r * u'.p2.y⟩ : Vector2D)
          = π p := by
        rw [hπ_conv, ← ha, ← hb, ← hc, hr_def]
        field_simp
        ring
      have hpq : p = (⟨(1 - r) * u'.p1.x + r * u'.p2.x, (1 - r) * u'.p1.y + r * u'.p2.y⟩ : Vector2D) :=
        hinj p _ hp hqline hπq.symm
      rw [hpq]
  -- Obtain the betweenness facts BEFORE abstracting, then abstract.
  obtain ⟨hxline, hξbetween0⟩ := step4 σ hσ1 hσ2 x hxσ
  obtain ⟨_, hξBbetween0⟩ := step4 t ht1 ht2 x hxt
  -- Set up the projected coordinates.
  set A1 := π σ.p1 with hA1
  set A2 := π σ.p2 with hA2
  set B1 := π t.p1 with hB1
  set B2 := π t.p2 with hB2
  set ξ := π x with hξ
  -- Rewrite the betweenness facts in terms of the abstracted coordinates.
  have hξbetween : (ξ - A1) * (ξ - A2) ≤ 0 := hξbetween0
  have hξBbetween : (ξ - B1) * (ξ - B2) ≤ 0 := hξBbetween0
  have hA12 : A1 ≠ A2 := fun h => hσnd (hinj _ _ hσ1 hσ2 h)
  -- ξ ≠ A1, A2.
  have hξne1 : ξ ≠ A1 := fun h => hxne1 (hinj _ _ hxline hσ1 h)
  have hξne2 : ξ ≠ A2 := fun h => hxne2 (hinj _ _ hxline hσ2 h)
  -- Make the projected coordinates opaque rationals (their defining equations `hA1 … hξ`
  -- are retained), so the pure interval arithmetic below does not unfold any heavy bodies.
  clear_value A1 A2 B1 B2 ξ
  -- B1 is not strictly between A1 and A2.
  have hB1out : (B1 - A1) * (B1 - A2) ≥ 0 := by
    by_contra h
    push_neg at h
    -- B1 strictly between A1, A2 ⟹ t.p1 ∈ σ.toSet.
    have ht1mem : t.p1 ∈ σ.toSet :=
      step5 σ hσ1 hσ2 hσnd t.p1 ht1 (le_of_lt (by rw [← hB1, ← hA1, ← hA2]; exact h))
    rcases ht1' ht1mem with he | he
    · have hh : B1 - A1 = 0 := by rw [hB1, hA1, he]; ring
      have hz : (B1 - A1) * (B1 - A2) = 0 := by linear_combination (B1 - A2) * hh
      linarith [h, hz]
    · have hh : B1 - A2 = 0 := by rw [hB1, hA2, he]; ring
      have hz : (B1 - A1) * (B1 - A2) = 0 := by linear_combination (B1 - A1) * hh
      linarith [h, hz]
  -- B2 is not strictly between A1 and A2.
  have hB2out : (B2 - A1) * (B2 - A2) ≥ 0 := by
    by_contra h
    push_neg at h
    have ht2mem : t.p2 ∈ σ.toSet :=
      step5 σ hσ1 hσ2 hσnd t.p2 ht2 (le_of_lt (by rw [← hB2, ← hA1, ← hA2]; exact h))
    rcases ht2' ht2mem with he | he
    · have hh : B2 - A1 = 0 := by rw [hB2, hA1, he]; ring
      have hz : (B2 - A1) * (B2 - A2) = 0 := by linear_combination (B2 - A2) * hh
      linarith [h, hz]
    · have hh : B2 - A2 = 0 := by rw [hB2, hA2, he]; ring
      have hz : (B2 - A1) * (B2 - A2) = 0 := by linear_combination (B2 - A1) * hh
      linarith [h, hz]
  -- Interval containment: [min A1 A2, max A1 A2] ⊆ [min B1 B2, max B1 B2].
  -- We prove: ∀ z, (z - A1)*(z - A2) ≤ 0 → (z - B1)*(z - B2) ≤ 0.
  have hcontain : ∀ z : ℚ, (z - A1) * (z - A2) ≤ 0 → (z - B1) * (z - B2) ≤ 0 := by
    intro z hz
    -- ξ strictly between A1, A2: (ξ-A1)*(ξ-A2) < 0.
    have hξstrict : (ξ - A1) * (ξ - A2) < 0 := by
      have hne1 : ξ - A1 ≠ 0 := sub_ne_zero.mpr hξne1
      have hne2 : ξ - A2 ≠ 0 := sub_ne_zero.mpr hξne2
      rcases lt_trichotomy ((ξ - A1) * (ξ - A2)) 0 with h | h | h
      · exact h
      · exact absurd (mul_eq_zero.mp h) (by push_neg; exact ⟨hne1, hne2⟩)
      · exact absurd hξbetween (by push_neg; exact h)
    rcases le_total A1 A2 with hAle | hAle
    · -- A1 ≤ A2; A1 < ξ < A2; B1, B2 ∉ (A1, A2); ξ in [min B1 B2, max B1 B2].
      have hξlo : A1 < ξ := by nlinarith [hξstrict, hAle]
      have hξhi : ξ < A2 := by nlinarith [hξstrict, hAle]
      -- B1 ≤ A1 ∨ A2 ≤ B1.
      have hB1c : B1 ≤ A1 ∨ A2 ≤ B1 := by
        by_contra hc; push_neg at hc; nlinarith [hB1out, hc.1, hc.2]
      have hB2c : B2 ≤ A1 ∨ A2 ≤ B2 := by
        by_contra hc; push_neg at hc; nlinarith [hB2out, hc.1, hc.2]
      -- z ∈ [A1, A2].
      have hzlo : A1 ≤ z := by nlinarith [hz, hAle]
      have hzhi : z ≤ A2 := by nlinarith [hz, hAle]
      -- ξ ∈ [min B1 B2, max B1 B2], i.e. (ξ-B1)*(ξ-B2) ≤ 0.
      -- One of B1,B2 ≤ A1 and the other ≥ A2 (since ξ is strictly inside).
      rcases hB1c with h1 | h1 <;> rcases hB2c with h2 | h2
      · -- both ≤ A1: then ξ > A1 ≥ B1,B2, so (ξ-B1)*(ξ-B2) > 0, contradicting hξBbetween.
        exfalso; nlinarith [hξBbetween, hξlo, h1, h2]
      · -- B1 ≤ A1, A2 ≤ B2: z between, so B1 ≤ A1 ≤ z ≤ A2 ≤ B2.
        nlinarith [h1, h2, hzlo, hzhi]
      · nlinarith [h1, h2, hzlo, hzhi]
      · exfalso; nlinarith [hξBbetween, hξhi, h1, h2]
    · -- A2 ≤ A1 case (symmetric).
      have hξlo : A2 < ξ := by nlinarith [hξstrict, hAle]
      have hξhi : ξ < A1 := by nlinarith [hξstrict, hAle]
      have hB1c : B1 ≤ A2 ∨ A1 ≤ B1 := by
        by_contra hc; push_neg at hc; nlinarith [hB1out, hc.1, hc.2]
      have hB2c : B2 ≤ A2 ∨ A1 ≤ B2 := by
        by_contra hc; push_neg at hc; nlinarith [hB2out, hc.1, hc.2]
      have hzlo : A2 ≤ z := by nlinarith [hz, hAle]
      have hzhi : z ≤ A1 := by nlinarith [hz, hAle]
      rcases hB1c with h1 | h1 <;> rcases hB2c with h2 | h2
      · exfalso; nlinarith [hξBbetween, hξlo, h1, h2]
      · nlinarith [h1, h2, hzlo, hzhi]
      · nlinarith [h1, h2, hzlo, hzhi]
      · exfalso; nlinarith [hξBbetween, hξhi, h1, h2]
  -- t is nondegenerate: B1 ≠ B2.
  have htnd : t.p1 ≠ t.p2 := by
    intro h
    -- if t.p1 = t.p2 then B1 = B2, so [min B1 B2, max B1 B2] is a point.
    -- But ξ strictly inside (A1,A2) is in that interval and A1 in interval too ⟹ A1 = B1 = ξ,
    -- contradicting hξne1.
    have hBeq : B1 = B2 := by rw [hB1, hB2, h]
    have hA1in : (A1 - B1) * (A1 - B2) ≤ 0 := hcontain A1 (by ring_nf; nlinarith [hA12])
    have : A1 = B1 := by nlinarith [hA1in, hBeq]
    -- and ξ in interval too.
    have hξin : (ξ - B1) * (ξ - B2) ≤ 0 := hcontain ξ (le_of_lt (by
      rcases lt_trichotomy ((ξ - A1) * (ξ - A2)) 0 with hh | hh | hh
      · exact hh
      · exact absurd (mul_eq_zero.mp hh)
          (by push_neg; exact ⟨sub_ne_zero.mpr hξne1, sub_ne_zero.mpr hξne2⟩)
      · exact absurd hξbetween (by push_neg; exact hh)))
    have : ξ = B1 := by nlinarith [hξin, hBeq]
    exact hξne1 (by rw [this, ← ‹A1 = B1›])
  -- Conclude: every y ∈ σ.toSet is in t.toSet.
  intro y hy
  obtain ⟨hyline, hybetween⟩ := step4 σ hσ1 hσ2 y hy
  -- π y between A1, A2 ⟹ between B1, B2.
  have hyB : (π y - π t.p1) * (π y - π t.p2) ≤ 0 := by
    have hc := hcontain (π y) (by rw [hA1, hA2]; exact hybetween)
    rw [hB1, hB2] at hc; exact hc
  exact step5 t ht1 ht2 htnd y hyline hyB

/-- **Dichotomy.** Every segment of `arr G1 G2` either meets `∂G2` only at its endpoints
    (transversal) or lies entirely in `∂G2` (shared). -/
theorem arr_dichotomy (G1 G2 : EvenGraph) (σ : LineSegment) (hσ : σ ∈ (arr G1 G2).segments) :
    (σ.toSet ∩ G2.toBoundarySet ⊆ ({σ.p1, σ.p2} : Set Vector2D)) ∨ IsShared G2 σ := by
  by_cases htrans : σ.toSet ∩ G2.toBoundarySet ⊆ ({σ.p1, σ.p2} : Set Vector2D)
  · exact Or.inl htrans
  right
  rw [Set.not_subset] at htrans
  obtain ⟨x, ⟨hxσ, hxG2⟩, hxnotep⟩ := htrans
  simp only [Set.mem_insert_iff, Set.mem_singleton_iff] at hxnotep
  push_neg at hxnotep
  obtain ⟨hxne1, hxne2⟩ := hxnotep
  obtain ⟨t, ht, hxt⟩ := hxG2
  obtain ⟨s, hs, hσ_sub_s⟩ := arr_seg_subset G1 G2 σ hσ
  have hsnd : s.p1 ≠ s.p2 := (graphRefinementSelf G1).segments_nondegenerate s hs
  have hσnd : σ.p1 ≠ σ.p2 := (arr G1 G2).segments_nondegenerate σ hσ
  have hσ1 : σ.p1 ∈ lineOf s := toSet_subset_lineOf s (hσ_sub_s (seg_p1_mem σ))
  have hσ2 : σ.p2 ∈ lineOf s := toSet_subset_lineOf s (hσ_sub_s (seg_p2_mem σ))
  have hxs : x ∈ s.toSet := hσ_sub_s hxσ
  by_cases hsl : SameLine s t
  · obtain ⟨ht1L, ht2L⟩ := hsl
    have key : ∀ v : Vector2D, v ∈ G2.toVertices → v ∈ σ.toSet → v = σ.p1 ∨ v = σ.p2 := by
      intro v hv hvσ
      have hvs : v ∈ s.toSet := hσ_sub_s hvσ
      have hv_bp : v ∈ breakpointsSet (graphRefinementSelf G1) G2 := Or.inr ⟨hv, s, hs, hvs⟩
      have hv_list : v ∈ breakpointsList (graphRefinementSelf G1) G2 :=
        (mem_breakpointsList_iff _ _ v).mpr hv_bp
      exact EvenGraphRefinementProofs.refineGraphWithPoints_pts_endpoint
        (graphRefinementSelf G1) _ _ v hv_list σ hσ hvσ
    have ht1v : t.p1 ∈ G2.toVertices := (G2.segments_endpoints t ht).1
    have ht2v : t.p2 ∈ G2.toVertices := (G2.segments_endpoints t ht).2
    have hcont := collinear_containment s σ t hσ1 hσ2 ht1L ht2L hsnd hσnd x hxσ hxt hxne1 hxne2
      (key t.p1 ht1v) (key t.p2 ht2v)
    intro y hy
    exact ⟨t, ht, hcont hy⟩
  · exfalso
    have hx_bp : x ∈ breakpointsSet (graphRefinementSelf G1) G2 :=
      Or.inl ⟨s, hs, t, List.mem_append.mpr (Or.inr ht), hsl, hxs, hxt⟩
    have hx_list : x ∈ breakpointsList (graphRefinementSelf G1) G2 :=
      (mem_breakpointsList_iff _ _ x).mpr hx_bp
    rcases EvenGraphRefinementProofs.refineGraphWithPoints_pts_endpoint
        (graphRefinementSelf G1) _ _ x hx_list σ hσ hxσ with h | h
    · exact hxne1 h
    · exact hxne2 h

/-! ### Selection -/

/-- Canonical orientation of a segment (so two reverse-equal segments share a representative). -/
def canonSeg (σ : LineSegment) : LineSegment :=
  if σ.p1.x < σ.p2.x ∨ (σ.p1.x = σ.p2.x ∧ σ.p1.y ≤ σ.p2.y) then σ else ⟨σ.p2, σ.p1⟩

theorem canonSeg_nondeg (σ : LineSegment) (h : σ.p1 ≠ σ.p2) :
    (canonSeg σ).p1 ≠ (canonSeg σ).p2 := by
  unfold canonSeg; split <;> simp_all [ne_comm]

theorem canonSeg_toSet (σ : LineSegment) : (canonSeg σ).toSet = σ.toSet := by
  unfold canonSeg; split
  · rfl
  · ext p
    simp only [LineSegment.toSet, Set.mem_setOf_eq]
    constructor
    · rintro ⟨t, h0, h1, hx, hy⟩
      exact ⟨1 - t, by linarith, by linarith, by rw [hx]; ring, by rw [hy]; ring⟩
    · rintro ⟨t, h0, h1, hx, hy⟩
      exact ⟨1 - t, by linarith, by linarith, by rw [hx]; ring, by rw [hy]; ring⟩

/-- An endpoint of a nondegenerate segment `σ'` that lies in another nondegenerate, collinear
    segment `σ` with the same point set must be an endpoint of `σ`. -/
private theorem endpoint_mem_endpoints (σ σ' : LineSegment)
    (hσnd : σ.p1 ≠ σ.p2) (heq : σ.toSet = σ'.toSet)
    (e : Vector2D) (he : e = σ'.p1 ∨ e = σ'.p2) : e = σ.p1 ∨ e = σ.p2 := by
  -- Projection onto σ's direction.
  set dx := σ.p2.x - σ.p1.x with hdx
  set dy := σ.p2.y - σ.p1.y with hdy
  have hD : 0 < dx * dx + dy * dy := by
    have hne : dx ≠ 0 ∨ dy ≠ 0 := by
      by_contra h; push_neg at h
      exact hσnd (Vector2D.ext (by have := h.1; simp only [hdx] at this; linarith)
        (by have := h.2; simp only [hdy] at this; linarith)).symm
    rcases hne with h | h
    · nlinarith [mul_self_pos.mpr h, mul_self_nonneg dy]
    · nlinarith [mul_self_pos.mpr h, mul_self_nonneg dx]
  set π : Vector2D → ℚ := fun p => (p.x - σ.p1.x) * dx + (p.y - σ.p1.y) * dy with hπ
  -- π σ.p1 = 0, π σ.p2 = dx² + dy² > 0
  have hπ1 : π σ.p1 = 0 := by simp only [hπ]; ring
  have hπ2 : π σ.p2 = dx * dx + dy * dy := by simp only [hπ, hdx, hdy]
  -- For p ∈ σ.toSet, π p ∈ [0, D].
  have hrange : ∀ p ∈ σ.toSet, 0 ≤ π p ∧ π p ≤ dx * dx + dy * dy := by
    intro p hp
    obtain ⟨t, ht0, ht1, hpx, hpy⟩ := hp
    have : π p = t * (dx * dx + dy * dy) := by
      simp only [hπ]; rw [hpx, hpy, hdx, hdy]; ring
    rw [this]
    constructor
    · exact mul_nonneg ht0 (le_of_lt hD)
    · nlinarith [hD, ht1, ht0]
  -- e ∈ σ.toSet (since e is endpoint of σ' and σ.toSet = σ'.toSet)
  have he_mem : e ∈ σ.toSet := by
    rw [heq]; rcases he with rfl | rfl
    · exact seg_p1_mem σ'
    · exact seg_p2_mem σ'
  -- σ'.p1, σ'.p2 ∈ σ.toSet
  have h1m : σ'.p1 ∈ σ.toSet := by rw [heq]; exact seg_p1_mem σ'
  have h2m : σ'.p2 ∈ σ.toSet := by rw [heq]; exact seg_p2_mem σ'
  -- σ.p1, σ.p2 ∈ σ'.toSet = σ.toSet (trivially in σ.toSet)
  -- The π-extremes 0 and D are attained by σ.p1, σ.p2. Since σ'.toSet = σ.toSet, the
  -- endpoints σ'.p1,σ'.p2 have π in [0,D], and {min,max} of π over σ'.toSet = {0,D}.
  -- e is an endpoint of σ', so π e is the min or max of π over σ'.toSet = σ.toSet, = 0 or D.
  -- Every point of σ' is a convex combo of σ'.p1,σ'.p2, so π is between π σ'.p1, π σ'.p2.
  have hconv : ∀ p ∈ σ'.toSet, (π p - π σ'.p1) * (π p - π σ'.p2) ≤ 0 := by
    intro p hp
    obtain ⟨t, ht0, ht1, hpx, hpy⟩ := hp
    have hpπ : π p = (1 - t) * π σ'.p1 + t * π σ'.p2 := by
      simp only [hπ]; rw [hpx, hpy]; ring
    rw [hpπ]; nlinarith [ht0, ht1, mul_nonneg ht0 (sub_nonneg.mpr ht1),
      sq_nonneg (π σ'.p1 - π σ'.p2)]
  -- σ.p1 (π=0) and σ.p2 (π=D) are in σ'.toSet, so 0 and D are between π σ'.p1 and π σ'.p2.
  have hc1 := hconv σ.p1 (by rw [← heq]; exact seg_p1_mem σ)
  have hc2 := hconv σ.p2 (by rw [← heq]; exact seg_p2_mem σ)
  rw [hπ1] at hc1; rw [hπ2] at hc2
  -- π σ'.p1, π σ'.p2 ∈ [0,D] and 0,D are between them ⟹ {π σ'.p1, π σ'.p2} = {0, D}.
  have hr1 := hrange σ'.p1 h1m
  have hr2 := hrange σ'.p2 h2m
  set u := π σ'.p1 with hu
  set v := π σ'.p2 with hv
  set D := dx * dx + dy * dy with hDdef
  -- u,v ∈ [0,D]; 0 between u,v ⟹ u*v ≤ 0 ⟹ u=0 ∨ v=0; D between u,v ⟹ (D-u)(D-v) ≤ 0.
  have hzero : u = 0 ∨ v = 0 := by
    have hprod : u * v = 0 := le_antisymm (by nlinarith [hc1]) (mul_nonneg hr1.1 hr2.1)
    exact mul_eq_zero.mp hprod
  have hDmax : u = D ∨ v = D := by
    have hprod : (D - u) * (D - v) = 0 :=
      le_antisymm (by nlinarith [hc2]) (mul_nonneg (by linarith [hr1.2]) (by linarith [hr2.2]))
    rcases mul_eq_zero.mp hprod with h | h
    · exact Or.inl (by linarith)
    · exact Or.inr (by linarith)
  -- π injective on σ.toSet (collinear); e has π e ∈ {0, D}; 0 ↦ σ.p1, D ↦ σ.p2.
  have hinj : ∀ p q, p ∈ σ.toSet → q ∈ σ.toSet → π p = π q → p = q := by
    intro p q hp hq hpq
    obtain ⟨tp, _, _, hpx, hpy⟩ := hp
    obtain ⟨tq, _, _, hqx, hqy⟩ := hq
    have hπp : π p = tp * (dx*dx+dy*dy) := by simp only [hπ]; rw [hpx, hpy, hdx, hdy]; ring
    have hπq : π q = tq * (dx*dx+dy*dy) := by simp only [hπ]; rw [hqx, hqy, hdx, hdy]; ring
    have hteq : tp = tq := by
      have := hpq; rw [hπp, hπq] at this
      have hD' : dx*dx+dy*dy ≠ 0 := ne_of_gt hD
      field_simp at this
      rcases this with h | h
      · exact h
      · exact absurd h hD'
    exact Vector2D.ext (by rw [hpx, hqx, hteq]) (by rw [hpy, hqy, hteq])
  -- e endpoint of σ': π e = u or v, which is 0 or D.
  have hπe : π e = 0 ∨ π e = D := by
    rcases he with rfl | rfl
    · rw [← hu]
      rcases hzero with h | h
      · exact Or.inl h
      · rcases hDmax with h' | h'
        · exact Or.inr h'
        · exact absurd (by rw [← h', h] : (0 : ℚ) = D) (ne_of_lt hD)
    · rw [← hv]
      rcases hzero with h | h
      · rcases hDmax with h' | h'
        · exact absurd (by rw [← h', h] : (0 : ℚ) = D) (ne_of_lt hD)
        · exact Or.inr h'
      · exact Or.inl h
  rcases hπe with h | h
  · left; exact hinj e σ.p1 he_mem (seg_p1_mem σ) (by rw [h, hπ1])
  · right; exact hinj e σ.p2 he_mem (seg_p2_mem σ) (by rw [h, hπ2])

/-- `canonSeg` is invariant under reversing endpoints. -/
private theorem canonSeg_reverse (a b : Vector2D) :
    canonSeg ⟨a, b⟩ = canonSeg ⟨b, a⟩ := by
  unfold canonSeg
  by_cases hab : a.x < b.x ∨ a.x = b.x ∧ a.y ≤ b.y
  · have hba : ¬ (b.x < a.x ∨ b.x = a.x ∧ b.y ≤ a.y) ∨ (a = b) := by
      rcases hab with h | ⟨hx, hy⟩
      · left; push_neg; exact ⟨le_of_lt h, fun he => absurd he.symm (ne_of_lt h)⟩
      · rcases lt_or_eq_of_le hy with h | h
        · left; push_neg; exact ⟨le_of_eq hx, fun _ => h⟩
        · right; exact Vector2D.ext hx h
    rcases hba with hba | hab'
    · simp only [hab, hba, if_true, if_false]
    · subst hab'; simp
  · push_neg at hab
    obtain ⟨hx, hy⟩ := hab
    have hba : b.x < a.x ∨ b.x = a.x ∧ b.y ≤ a.y := by
      rcases lt_or_eq_of_le hx with h | h
      · exact Or.inl h
      · exact Or.inr ⟨h, le_of_lt (hy h.symm)⟩
    have hab2 : ¬ (a.x < b.x ∨ a.x = b.x ∧ a.y ≤ b.y) := by push_neg; exact ⟨hx, hy⟩
    simp only [hab2, hba, if_true, if_false]

/-- For nondegenerate segments, equal point sets force equal canonical orientations. -/
private theorem canonSeg_eq_of_toSet_eq (σ σ' : LineSegment)
    (hσnd : σ.p1 ≠ σ.p2) (hσ'nd : σ'.p1 ≠ σ'.p2) (heq : σ.toSet = σ'.toSet) :
    canonSeg σ = canonSeg σ' := by
  have h1 : σ'.p1 = σ.p1 ∨ σ'.p1 = σ.p2 :=
    endpoint_mem_endpoints σ σ' hσnd heq σ'.p1 (Or.inl rfl)
  have h2 : σ'.p2 = σ.p1 ∨ σ'.p2 = σ.p2 :=
    endpoint_mem_endpoints σ σ' hσnd heq σ'.p2 (Or.inr rfl)
  have hpair : (σ'.p1 = σ.p1 ∧ σ'.p2 = σ.p2) ∨ (σ'.p1 = σ.p2 ∧ σ'.p2 = σ.p1) := by
    rcases h1 with ha | ha <;> rcases h2 with hb | hb
    · exact absurd (ha.trans hb.symm) hσ'nd
    · exact Or.inl ⟨ha, hb⟩
    · exact Or.inr ⟨ha, hb⟩
    · exact absurd (ha.trans hb.symm) hσ'nd
  rcases hpair with ⟨e1, e2⟩ | ⟨e1, e2⟩
  · -- σ' = σ
    have heq' : σ' = σ := by cases σ; cases σ'; simp_all
    rw [heq']
  · -- σ' = ⟨σ.p2, σ.p1⟩
    have hσ'eq : σ' = ⟨σ.p2, σ.p1⟩ := by cases σ'; simp_all
    have hσeq : σ = ⟨σ.p1, σ.p2⟩ := by cases σ; rfl
    rw [hσ'eq]
    conv_lhs => rw [hσeq]
    rw [canonSeg_reverse]

/-- Side-point test: crossing `σ` toggles membership in `G1.interior ∩ G2.interior`. -/
def onInterBoundary (G1 G2 : EvenGraph) (σ : LineSegment) : Prop :=
  ∃ q1 q2 : Vector2D,
    q1 ∉ G1.toBoundarySet ∧ q1 ∉ G2.toBoundarySet ∧
    q2 ∉ G1.toBoundarySet ∧ q2 ∉ G2.toBoundarySet ∧
    (∃ c, c ∈ σ.toSet ∧ c ≠ σ.p1 ∧ c ≠ σ.p2 ∧ c ∈ (LineSegment.mk q1 q2).toSet ∧
      (∀ x ∈ (LineSegment.mk q1 q2).toSet,
        (x ∈ G1.toBoundarySet ∨ x ∈ G2.toBoundarySet) → x = c)) ∧
    ((q1 ∈ G1.interior ∧ q1 ∈ G2.interior) ↔ ¬ (q2 ∈ G1.interior ∧ q2 ∈ G2.interior))

/-- The selected shared edges: distinct shared point-sets of `arr G1 G2` lying on
    `∂(G1.interior ∩ G2.interior)`. -/
def sharedSelected (G1 G2 : EvenGraph) : List LineSegment :=
  (((arr G1 G2).segments.map canonSeg).dedup).filter
    (fun σ => decide (IsShared G2 σ ∧ onInterBoundary G1 G2 σ))

theorem sharedSelected_nondeg (G1 G2 : EvenGraph) :
    ∀ σ ∈ sharedSelected G1 G2, σ.p1 ≠ σ.p2 := by
  intro σ hσ
  rw [sharedSelected, List.mem_filter] at hσ
  have hmem : σ ∈ (arr G1 G2).segments.map canonSeg := List.mem_dedup.mp hσ.1
  obtain ⟨σ0, hσ0, hcanon⟩ := List.mem_map.mp hmem
  rw [← hcanon]
  exact canonSeg_nondeg σ0 ((arr G1 G2).segments_nondegenerate σ0 hσ0)

/-- The **phantom (doubled) shared edges**: every shared `arr G1 G2` edge **not** selected by
    `onInterBoundary` (i.e. across which `A ∩ B` does not flip), each included **twice**. The
    doubling makes their crossing count even (parity-neutral, so the parity identity
    `interGraph_parity_core` is unchanged), while still placing the edge in `interGraph` so its
    points are excluded from `interGraph.interior`. Together with `sharedSelected` (the
    `onInterBoundary` edges) this puts **every** shared edge into `interGraph` — which is what the
    set-theoretic equality `interGraph.interior = A ∩ B` requires at shared/overlapping edges: an
    edge `⊆ ∂G1` is excluded from `A ∩ B`, so it must also be excluded from the interior. (Including
    the "exterior" phantom edges too is harmless: they are `⊆ ∂G1`, hence off `A ∩ B`.) -/
def phantomDoubled (G1 G2 : EvenGraph) : List LineSegment :=
  ((((arr G1 G2).segments.map canonSeg).dedup).filter
    (fun σ => decide (IsShared G2 σ ∧ ¬ onInterBoundary G1 G2 σ))).flatMap
    (fun σ => [σ, σ])

theorem phantomDoubled_nondeg (G1 G2 : EvenGraph) :
    ∀ σ ∈ phantomDoubled G1 G2, σ.p1 ≠ σ.p2 := by
  intro σ hσ
  rw [phantomDoubled, List.mem_flatMap] at hσ
  obtain ⟨τ, hτ, hmem⟩ := hσ
  have hστ : σ = τ := by
    rcases List.mem_cons.mp hmem with h | h
    · exact h
    · rcases List.mem_cons.mp h with h' | h'
      · exact h'
      · exact absurd h' (List.not_mem_nil _)
  rw [hστ]
  have hτ' : τ ∈ (arr G1 G2).segments.map canonSeg :=
    List.mem_dedup.mp (List.mem_of_mem_filter hτ)
  obtain ⟨σ0, hσ0, hcanon⟩ := List.mem_map.mp hτ'
  rw [← hcanon]
  exact canonSeg_nondeg σ0 ((arr G1 G2).segments_nondegenerate σ0 hσ0)

/-- Every `phantomDoubled` segment is a `canonSeg` of a shared `arr G1 G2` segment, so its
    point set lies in `∂G1` (= `(arr G1 G2).toBoundarySet`). -/
theorem phantomDoubled_toSet_subset (G1 G2 : EvenGraph) (seg : LineSegment)
    (hseg : seg ∈ phantomDoubled G1 G2) : seg.toSet ⊆ (arr G1 G2).toBoundarySet := by
  rw [phantomDoubled, List.mem_flatMap] at hseg
  obtain ⟨τ, hτ, hmem⟩ := hseg
  have hστ : seg = τ := by
    rcases List.mem_cons.mp hmem with h | h
    · exact h
    · rcases List.mem_cons.mp h with h' | h'
      · exact h'
      · exact absurd h' (List.not_mem_nil _)
  rw [hστ]
  obtain ⟨σ0, hσ0, hcanon⟩ :=
    List.mem_map.mp (List.mem_dedup.mp (List.mem_of_mem_filter hτ))
  rw [← hcanon, canonSeg_toSet]
  intro q hq
  exact ⟨σ0, hσ0, hq⟩

/-- Counting a predicate over a list with each element doubled yields twice the original count. -/
theorem countP_flatMap_double {α} (l : List α) (p : α → Bool) :
    (l.flatMap (fun a => [a, a])).countP p = 2 * l.countP p := by
  induction l with
  | nil => simp
  | cons a t ih =>
    simp only [List.flatMap_cons, List.countP_append, List.countP_cons, List.countP_nil, ih]
    ring

/-- The crossing/predicate count over `phantomDoubled` is even (each edge appears twice). -/
theorem phantomDoubled_countP_even (G1 G2 : EvenGraph) (p : LineSegment → Bool) :
    (phantomDoubled G1 G2).countP p % 2 = 0 := by
  rw [phantomDoubled, countP_flatMap_double]
  omega

/-- The intersection graph: refined-`G1` segments inside `G2`, refined-`G2` segments inside
    `G1`, the shared edges on `∂(G1.interior ∩ G2.interior)`, plus the phantom (doubled) shared
    edges interior to `A ∩ B`. -/
def interGraph (G1 G2 : EvenGraph) : Graph :=
  ((((arr G1 G2).toGraph.selectSegmentsInside G2.interior).append
    ((arr G2 G1).toGraph.selectSegmentsInside G1.interior)).append
    ⟨sharedSelected G1 G2, sharedSelected_nondeg G1 G2⟩).append
    ⟨phantomDoubled G1 G2, phantomDoubled_nondeg G1 G2⟩

theorem interGraph_segments (G1 G2 : EvenGraph) :
    (interGraph G1 G2).segments =
      ((_root_.selectSegmentsInside (arr G1 G2).segments G2.interior ++
        _root_.selectSegmentsInside (arr G2 G1).segments G1.interior) ++
        sharedSelected G1 G2) ++ phantomDoubled G1 G2 := rfl

/-- Every segment of `interGraph G1 G2` comes from `arr G1 G2`, `arr G2 G1`, or is the
    canonicalisation of an `arr G1 G2` segment (covering both `sharedSelected` and
    `phantomDoubled`). -/
theorem interGraph_seg_origin (G1 G2 : EvenGraph) (seg : LineSegment)
    (hseg : seg ∈ (interGraph G1 G2).segments) :
    seg ∈ (arr G1 G2).segments ∨ seg ∈ (arr G2 G1).segments ∨
      ∃ σ0 ∈ (arr G1 G2).segments, seg = canonSeg σ0 := by
  rw [interGraph_segments, List.mem_append, List.mem_append, List.mem_append] at hseg
  rcases hseg with ((h | h) | h) | h
  · exact Or.inl (List.mem_of_mem_filter h)
  · exact Or.inr (Or.inl (List.mem_of_mem_filter h))
  · -- sharedSelected
    obtain ⟨σ0, hσ0, hcanon⟩ :=
      List.mem_map.mp (List.mem_dedup.mp (List.mem_of_mem_filter h))
    exact Or.inr (Or.inr ⟨σ0, hσ0, hcanon.symm⟩)
  · -- phantomDoubled
    rw [phantomDoubled, List.mem_flatMap] at h
    obtain ⟨τ, hτ, hmem⟩ := h
    have hστ : seg = τ := by
      rcases List.mem_cons.mp hmem with h' | h'
      · exact h'
      · rcases List.mem_cons.mp h' with h'' | h''
        · exact h''
        · exact absurd h'' (List.not_mem_nil _)
    obtain ⟨σ0, hσ0, hcanon⟩ :=
      List.mem_map.mp (List.mem_dedup.mp (List.mem_of_mem_filter hτ))
    exact Or.inr (Or.inr ⟨σ0, hσ0, hστ.trans hcanon.symm⟩)

/-- A shared-selected segment's point set lies in `∂G1` (it is a canonicalised `arr G1 G2`
    segment). -/
theorem sharedSelected_toSet_subset (G1 G2 : EvenGraph) (seg : LineSegment)
    (hseg : seg ∈ sharedSelected G1 G2) : seg.toSet ⊆ (arr G1 G2).toBoundarySet := by
  rw [sharedSelected, List.mem_filter] at hseg
  obtain ⟨σ0, hσ0, hcanon⟩ := List.mem_map.mp (List.mem_dedup.mp hseg.1)
  rw [← hcanon, canonSeg_toSet]
  intro q hq
  exact ⟨σ0, hσ0, hq⟩

/-- The boundary of `interGraph G1 G2` is contained in `∂G1 ∪ ∂G2`. -/
theorem interGraph_boundary_subset (G1 G2 : EvenGraph) :
    (interGraph G1 G2).toBoundarySet ⊆ G1.toBoundarySet ∪ G2.toBoundarySet := by
  rintro q ⟨seg, hseg, hq⟩
  rcases interGraph_seg_origin G1 G2 seg hseg with h | h | ⟨σ0, hσ0, hcanon⟩
  · left; rw [← arr_boundary_eq G1 G2]; exact ⟨seg, h, hq⟩
  · right; rw [← arr_boundary_eq G2 G1]; exact ⟨seg, h, hq⟩
  · left; rw [← arr_boundary_eq G1 G2]
    rw [hcanon, canonSeg_toSet] at hq
    exact ⟨σ0, hσ0, hq⟩

/-! ### A general interior-transport lemma -/

/-- Transport interior membership of an even graph `H` along a segment that avoids `H`'s
    boundary. Generalises `EvenGraphIntersectionProofs.G2_interior_via_segment` to any even
    graph (no finiteness hypothesis). -/
theorem interior_via_segment_gen (H : EvenGraph) (p q : Vector2D)
    (h_p_int : p ∈ H.interior) (h_q_not : q ∉ H.toBoundarySet)
    (h_segpq : ∀ x ∈ (LineSegment.mk p q).toSet, x ∉ H.toBoundarySet) :
    q ∈ H.interior := by
  have h_pos := H.incident_count_pos
  have h_p_not_bnd : p ∉ H.toBoundarySet := by
    intro h_in
    obtain ⟨seg', hseg', h_in_seg⟩ := h_in
    exact h_p_int.1 seg' hseg' h_in_seg
  have h_q_avoids_segs : ∀ seg ∈ H.segments, pointAvoidsSegment q seg := by
    intro seg' hseg' h_in
    exact h_q_not ⟨seg', hseg', h_in⟩
  refine ⟨h_q_avoids_segs, fun r_q h_r_q_origin h_r_q_avoids_verts => ?_⟩
  have h_p_not_verts : ∀ v ∈ H.toVertices, v ≠ p := by
    intro v hv heq
    obtain ⟨s, hs_mem, hs_v⟩ :=
      EvenGraphIntersectionProofs.vertex_on_some_segment H v (h_pos v hv)
    exact h_p_not_bnd ⟨s, hs_mem, heq ▸ hs_v⟩
  obtain ⟨r_p, h_r_p_origin, h_r_p_avoids_verts⟩ :=
    EvenGraphIntersectionProofs.exists_ray_avoiding_graph_verts p H h_p_not_verts
  have h_seg_pq_avoids_segs : ∀ seg ∈ H.segments,
      segmentDoesNotIntersectSegment ⟨p, q⟩ seg := by
    intro seg hseg
    ext x
    simp only [Set.mem_inter_iff, Set.mem_empty_iff_false, iff_false, not_and]
    intro hx_pq hx_seg
    exact h_segpq x hx_pq ⟨seg, hseg, hx_seg⟩
  have h_verts_avoid_pq : ∀ v ∈ H.toVertices, v ∉ (LineSegment.mk p q).toSet := by
    intro v hv hv_mem
    obtain ⟨s, hs_mem, hs_v⟩ :=
      EvenGraphIntersectionProofs.vertex_on_some_segment H v (h_pos v hv)
    exact h_segpq v hv_mem ⟨s, hs_mem, hs_v⟩
  have h_sego_avoids : ∀ seg ∈ H.segments,
      segmentDoesNotIntersectSegment ⟨r_p.origin, r_q.origin⟩ seg := by
    rw [h_r_p_origin, h_r_q_origin]; exact h_seg_pq_avoids_segs
  have h_verts_avoid_sego : ∀ v ∈ H.toVertices,
      v ∉ (LineSegment.mk r_p.origin r_q.origin).toSet := by
    rw [h_r_p_origin, h_r_q_origin]; exact h_verts_avoid_pq
  have h_parity := intersectionParity_eq_of_originSegmentAvoidsGraphSegments
    r_p r_q H h_r_p_avoids_verts h_r_q_avoids_verts h_sego_avoids h_verts_avoid_sego
  have h_p_odd : intersectionRayGraphSegmentsNumber r_p H % 2 = 1 :=
    h_p_int.2 r_p h_r_p_origin h_r_p_avoids_verts
  rw [h_parity] at h_p_odd
  exact h_p_odd

/-! ### Transversal-segment helpers (for the parity pair-counting) -/

/-- A non-shared (transversal) `arr G1 G2` segment meets `∂G2` only at its endpoints. -/
theorem arr_transversal_inter_boundary (G1 G2 : EvenGraph) (σ : LineSegment)
    (hσ : σ ∈ (arr G1 G2).segments) (hns : ¬ IsShared G2 σ) :
    σ.toSet ∩ G2.toBoundarySet ⊆ ({σ.p1, σ.p2} : Set Vector2D) := by
  rcases arr_dichotomy G1 G2 σ hσ with h | h
  · exact h
  · exact absurd h hns

/-- For a transversal `arr G1 G2` segment crossed by a ray avoiding `arr`-vertices, the
    crossing point is not on `∂G2`. -/
theorem arr_crossingPoint_avoids (G1 G2 : EvenGraph) (r : Ray) (σ : LineSegment)
    (hσ : σ ∈ (arr G1 G2).segments) (hns : ¬ IsShared G2 σ)
    (h_avoids : rayAvoidsGraphVertices r (arr G1 G2))
    (h_int : rayIntersectsSegment r σ) :
    EvenGraphIntersectionProofs.rayCrossingPoint r σ h_int ∉ G2.toBoundarySet := by
  intro h_mem
  have h_on : EvenGraphIntersectionProofs.rayCrossingPoint r σ h_int ∈ σ.toSet :=
    EvenGraphIntersectionProofs.rayCrossingPoint_mem_seg r σ h_int
  have h_ne := EvenGraphIntersectionProofs.rayCrossingPoint_not_endpoint r (arr G1 G2) σ hσ
    h_avoids h_int
  have hin : EvenGraphIntersectionProofs.rayCrossingPoint r σ h_int ∈ ({σ.p1, σ.p2} : Set Vector2D) :=
    arr_transversal_inter_boundary G1 G2 σ hσ hns ⟨h_on, h_mem⟩
  rcases hin with h | h
  · exact h_ne.1 h
  · exact h_ne.2 h

/-- For a transversal `arr G1 G2` segment, `B`-membership is constant on its open interior. -/
theorem arr_same_B_status (G1 G2 : EvenGraph) (σ : LineSegment)
    (hσ : σ ∈ (arr G1 G2).segments) (hns : ¬ IsShared G2 σ)
    (p q : Vector2D) (hp : p ∈ σ.toSet) (hp1 : p ≠ σ.p1) (hp2 : p ≠ σ.p2)
    (hq : q ∈ σ.toSet) (hq1 : q ≠ σ.p1) (hq2 : q ≠ σ.p2)
    (hpB : p ∈ G2.interior) : q ∈ G2.interior := by
  have h_open_disj : ∀ x ∈ σ.toSet, x ≠ σ.p1 → x ≠ σ.p2 → x ∉ G2.toBoundarySet := by
    intro x hx hx1 hx2 hxb
    rcases arr_transversal_inter_boundary G1 G2 σ hσ hns ⟨hx, hxb⟩ with h | h
    · exact hx1 h
    · exact hx2 h
  have hB_eq : (arr G2 G1).interior = G2.interior := arr_interior_eq G2 G1
  have hbnd_eq : (arr G2 G1).toBoundarySet = G2.toBoundarySet := arr_boundary_eq G2 G1
  have hpB' : p ∈ (arr G2 G1).interior := by rw [hB_eq]; exact hpB
  have hq_not : q ∉ (arr G2 G1).toBoundarySet := by rw [hbnd_eq]; exact h_open_disj q hq hq1 hq2
  have h_segpq : ∀ x ∈ (LineSegment.mk p q).toSet, x ∉ (arr G2 G1).toBoundarySet := by
    intro x hx
    rw [hbnd_eq]
    obtain ⟨hxσ, hx1, hx2⟩ :=
      EvenGraphIntersectionProofs.segment_in_open_interior σ p q hp hp1 hp2 hq hq1 hq2 x hx
    exact h_open_disj x hxσ hx1 hx2
  have := interior_via_segment_gen (arr G2 G1) p q hpB' hq_not h_segpq
  rw [hB_eq] at this; exact this

/-- For a transversal `arr G1 G2` segment crossed by a ray (avoiding both `arr`-vertices), its
    open interior is inside `B` iff the sub-ray from the crossing point crosses `arr G2 G1` an
    odd number of times. -/
theorem arr_seg_inside_iff_subRay_odd (G1 G2 : EvenGraph) (r : Ray) (σ : LineSegment)
    (hσ : σ ∈ (arr G1 G2).segments) (hns : ¬ IsShared G2 σ)
    (h_avoids1 : rayAvoidsGraphVertices r (arr G1 G2))
    (h_avoids2 : rayAvoidsGraphVertices r (arr G2 G1))
    (h_int : rayIntersectsSegment r σ) :
    segmentOpenInteriorSubset σ G2.interior ↔
    intersectionRayGraphSegmentsNumber
      (EvenGraphIntersectionProofs.subRay r (EvenGraphIntersectionProofs.rayCrossingParam r σ h_int))
      (arr G2 G1) % 2 = 1 := by
  set t₁ := EvenGraphIntersectionProofs.rayCrossingParam r σ h_int with ht₁
  set p₁ := EvenGraphIntersectionProofs.rayCrossingPoint r σ h_int with hp₁_def
  have h_p₁_on : p₁ ∈ σ.toSet := EvenGraphIntersectionProofs.rayCrossingPoint_mem_seg r σ h_int
  have hne := EvenGraphIntersectionProofs.rayCrossingPoint_not_endpoint r (arr G1 G2) σ hσ
    h_avoids1 h_int
  have h_p₁_not_G2 : p₁ ∉ G2.toBoundarySet :=
    arr_crossingPoint_avoids G1 G2 r σ hσ hns h_avoids1 h_int
  have h_p₁_not_arr2 : p₁ ∉ (arr G2 G1).toBoundarySet := by
    rw [arr_boundary_eq G2 G1]; exact h_p₁_not_G2
  have ht₁_nn : 0 ≤ t₁ := EvenGraphIntersectionProofs.rayCrossingParam_nonneg r σ h_int
  have h_subRay_avoids : rayAvoidsGraphVertices
      (EvenGraphIntersectionProofs.subRay r t₁) (arr G2 G1) := by
    rw [rayAvoidsGraphVertices, Set.eq_empty_iff_forall_not_mem]
    intro v ⟨hv_ray, hv_vert⟩
    have hv_r : v ∈ r.toSet :=
      EvenGraphIntersectionProofs.subRay_toSet_subset r t₁ ht₁_nn hv_ray
    have : v ∈ r.toSet ∩ (arr G2 G1).toVertexSet := ⟨hv_r, hv_vert⟩
    rw [h_avoids2] at this; exact this
  have h_subRay_origin : (EvenGraphIntersectionProofs.subRay r t₁).origin = p₁ := by
    show (⟨r.origin.x + t₁ * r.direction.x, r.origin.y + t₁ * r.direction.y⟩ : Vector2D) = p₁
    ext
    · exact (EvenGraphIntersectionProofs.rayCrossingPoint_x r σ h_int).symm
    · exact (EvenGraphIntersectionProofs.rayCrossingPoint_y r σ h_int).symm
  have h_subRay_origin_avoids : ∀ seg ∈ (arr G2 G1).segments,
      pointAvoidsSegment (EvenGraphIntersectionProofs.subRay r t₁).origin seg := by
    intro seg hseg hmem
    rw [h_subRay_origin] at hmem
    exact h_p₁_not_arr2 ⟨seg, hseg, hmem⟩
  have h_iff1 : (EvenGraphIntersectionProofs.subRay r t₁).origin ∈ (arr G2 G1).interior ↔
      intersectionRayGraphSegmentsNumber (EvenGraphIntersectionProofs.subRay r t₁) (arr G2 G1)
        % 2 = 1 :=
    EvenGraphIntersectionProofs.point_in_interior_iff_odd_count
      (EvenGraphIntersectionProofs.subRay r t₁) (arr G2 G1) h_subRay_origin_avoids h_subRay_avoids
  rw [h_subRay_origin, arr_interior_eq G2 G1] at h_iff1
  constructor
  · intro h_sub
    exact h_iff1.mp (h_sub p₁ h_p₁_on hne.1 hne.2)
  · intro h_odd
    have h_p₁_mem : p₁ ∈ G2.interior := h_iff1.mpr h_odd
    intro q hq hq1 hq2
    exact arr_same_B_status G1 G2 σ hσ hns p₁ q h_p₁_on hne.1 hne.2 hq hq1 hq2 h_p₁_mem

/-- The open interior of an `arr G1 G2` segment `σ` meets a `(graphRefinementSelf G1)`- or
    `G2`-segment `u` only if `u` is collinear with `σ`. (Full-arrangement consequence: `arr`
    is split at all self- and `G2`-crossings.) -/
theorem arr_int_avoids_noncollinear (G1 G2 : EvenGraph) (σ : LineSegment)
    (hσ : σ ∈ (arr G1 G2).segments) (u : LineSegment)
    (hu : u ∈ (graphRefinementSelf G1).segments ++ G2.segments) (hncol : ¬ SameLine σ u)
    (x : Vector2D) (hx : x ∈ σ.toSet) (hx1 : x ≠ σ.p1) (hx2 : x ≠ σ.p2) :
    x ∉ u.toSet := by
  intro hxu
  obtain ⟨s, hs, hσ_sub_s⟩ := arr_seg_subset G1 G2 σ hσ
  -- σ ⊆ s, so σ and s are collinear; ¬SameLine σ u ⇒ ¬SameLine s u.
  have hσ1 : σ.p1 ∈ lineOf s := toSet_subset_lineOf s (hσ_sub_s (seg_p1_mem σ))
  have hσ2 : σ.p2 ∈ lineOf s := toSet_subset_lineOf s (hσ_sub_s (seg_p2_mem σ))
  have hσnd : σ.p1 ≠ σ.p2 := (arr G1 G2).segments_nondegenerate σ hσ
  have hsnd : s.p1 ≠ s.p2 := (graphRefinementSelf G1).segments_nondegenerate s hs
  have hncol_su : ¬ SameLine s u := by
    intro hsu
    apply hncol
    -- SameLine s u and σ.p1,σ.p2 ∈ lineOf s ⇒ lineOf s = lineOf σ ⇒ SameLine σ u.
    -- u.p1,u.p2 ∈ lineOf s; show they're ∈ lineOf σ.
    obtain ⟨hu1, hu2⟩ := hsu
    constructor
    · -- u.p1 ∈ lineOf σ : use that σ.p1, σ.p2, u.p1 all ∈ lineOf s with σ nondeg.
      have h := dir_parallel_of_two_mem_lineOf s σ.p1 u.p1 hσ1 hu1
      have hσ12 := dir_parallel_of_two_mem_lineOf s σ.p1 σ.p2 hσ1 hσ2
      -- (u.p1 - σ.p1) ∥ d_s, (σ.p2 - σ.p1) ∥ d_s, d_s ≠ 0 ⇒ (u.p1-σ.p1) ∥ (σ.p2-σ.p1).
      have hds : (s.p2.x - s.p1.x, s.p2.y - s.p1.y) ≠ (0, 0) := by
        intro hh
        apply hsnd
        have hhx : s.p2.x - s.p1.x = 0 := congrArg Prod.fst hh
        have hhy : s.p2.y - s.p1.y = 0 := congrArg Prod.snd hh
        exact (Vector2D.ext (by linarith) (by linarith)).symm
      have := parallel_trans_of_nonzero (σ.p2.x - σ.p1.x) (σ.p2.y - σ.p1.y)
        (u.p1.x - σ.p1.x) (u.p1.y - σ.p1.y) (s.p2.x - s.p1.x) (s.p2.y - s.p1.y) hds hσ12 h
      simp only [lineOf, Set.mem_setOf_eq]; linarith [this]
    · have h := dir_parallel_of_two_mem_lineOf s σ.p1 u.p2 hσ1 hu2
      have hσ12 := dir_parallel_of_two_mem_lineOf s σ.p1 σ.p2 hσ1 hσ2
      have hds : (s.p2.x - s.p1.x, s.p2.y - s.p1.y) ≠ (0, 0) := by
        intro hh
        apply hsnd
        have hhx : s.p2.x - s.p1.x = 0 := congrArg Prod.fst hh
        have hhy : s.p2.y - s.p1.y = 0 := congrArg Prod.snd hh
        exact (Vector2D.ext (by linarith) (by linarith)).symm
      have := parallel_trans_of_nonzero (σ.p2.x - σ.p1.x) (σ.p2.y - σ.p1.y)
        (u.p2.x - σ.p1.x) (u.p2.y - σ.p1.y) (s.p2.x - s.p1.x) (s.p2.y - s.p1.y) hds hσ12 h
      simp only [lineOf, Set.mem_setOf_eq]; linarith [this]
  -- x ∈ s ∩ u, ¬SameLine s u ⇒ x is a breakpoint ⇒ x is an endpoint of σ ⇒ contradiction.
  have hxs : x ∈ s.toSet := hσ_sub_s hx
  have hx_bp : x ∈ breakpointsSet (graphRefinementSelf G1) G2 :=
    Or.inl ⟨s, hs, u, hu, hncol_su, hxs, hxu⟩
  have hx_list : x ∈ breakpointsList (graphRefinementSelf G1) G2 :=
    (mem_breakpointsList_iff _ _ x).mpr hx_bp
  rcases EvenGraphRefinementProofs.refineGraphWithPoints_pts_endpoint
      (graphRefinementSelf G1) _ _ x hx_list σ hσ hx with h | h
  · exact hx1 h
  · exact hx2 h

/-! ### Pairwise crossing points (the `X` set in `V_extra`) -/

/-- All pairwise transversal-crossing points among the segments of `arr G1 G2` and
    `arr G2 G1`. A qualifying ray avoids these, so at each of its crossing points only one
    point-set is involved. -/
def crossingsSet (G1 G2 : EvenGraph) : Set Vector2D :=
  { x | ∃ s ∈ (arr G1 G2).segments ++ (arr G2 G1).segments,
        ∃ t ∈ (arr G1 G2).segments ++ (arr G2 G1).segments,
        ¬ SameLine s t ∧ x ∈ s.toSet ∧ x ∈ t.toSet }

theorem crossingsSet_finite (G1 G2 : EvenGraph) : (crossingsSet G1 G2).Finite := by
  have hsub : crossingsSet G1 G2 ⊆
      ⋃ s ∈ (arr G1 G2).segments ++ (arr G2 G1).segments,
        ⋃ t ∈ (arr G1 G2).segments ++ (arr G2 G1).segments,
          { x | ¬ SameLine s t ∧ x ∈ s.toSet ∧ x ∈ t.toSet } := by
    intro x hx
    obtain ⟨s, hs, t, ht, hsl, hxs, hxt⟩ := hx
    exact Set.mem_biUnion hs (Set.mem_biUnion ht ⟨hsl, hxs, hxt⟩)
  apply Set.Finite.subset _ hsub
  apply Set.Finite.biUnion ((arr G1 G2).segments ++ (arr G2 G1).segments).finite_toSet
  intro s hs
  apply Set.Finite.biUnion ((arr G1 G2).segments ++ (arr G2 G1).segments).finite_toSet
  intro t _
  by_cases hsl : SameLine s t
  · simp only [hsl, not_true, false_and, Set.setOf_false]; exact Set.finite_empty
  · have hsnd : s.p1 ≠ s.p2 := by
      rcases List.mem_append.mp hs with h | h
      · exact (arr G1 G2).segments_nondegenerate s h
      · exact (arr G2 G1).segments_nondegenerate s h
    apply Set.Finite.subset (inter_subsingleton_of_not_sameLine s t hsnd hsl).finite
    intro x hx; exact ⟨hx.2.1, hx.2.2⟩

/-- The list of pairwise crossing points. -/
def Xlist (G1 G2 : EvenGraph) : List Vector2D := (crossingsSet_finite G1 G2).toFinset.toList

theorem mem_Xlist_iff (G1 G2 : EvenGraph) (x : Vector2D) :
    x ∈ Xlist G1 G2 ↔ x ∈ crossingsSet G1 G2 := by
  rw [Xlist, Finset.mem_toList, Set.Finite.mem_toFinset]

/-! ### Crossing-parameter uniqueness for arrangement segments -/

open EvenGraphIntersectionProofs in
/-- For a segment of `arr G1 G2` crossed by a ray (origin off `∂G1`, avoiding `arr` vertices),
    the crossing parameter is the unique nonnegative parameter whose ray-point lies on the
    segment. -/
theorem arr_param_unique (G1 G2 : EvenGraph) (r : Ray) (s : LineSegment)
    (hs : s ∈ (arr G1 G2).segments) (h_avoids : rayAvoidsGraphVertices r (arr G1 G2))
    (hoff : r.origin ∉ G1.toBoundarySet)
    (h : rayIntersectsSegment r s) (t : ℚ) (ht : 0 ≤ t)
    (hmem : (⟨r.origin.x + t * r.direction.x, r.origin.y + t * r.direction.y⟩ : Vector2D)
      ∈ s.toSet) :
    t = rayCrossingParam r s h := by
  apply rayCrossingParam_unique r s h _ _ _ t ht hmem
  · -- origin avoids s: origin not on ∂(arr G1 G2) = ∂G1
    intro h_on
    apply hoff
    rw [← arr_boundary_eq G1 G2]
    exact ⟨s, hs, h_on⟩
  · intro h_p1
    have : s.p1 ∈ r.toSet ∩ (arr G1 G2).toVertexSet :=
      ⟨h_p1, ((arr G1 G2).segments_endpoints s hs).1⟩
    rw [h_avoids] at this; exact this
  · intro h_p2
    have : s.p2 ∈ r.toSet ∩ (arr G1 G2).toVertexSet :=
      ⟨h_p2, ((arr G1 G2).segments_endpoints s hs).2⟩
    rw [h_avoids] at this; exact this

/-- A segment of `interGraph G1 G2` has the same point set as some segment of `arr G1 G2` or
    `arr G2 G1`, and both of its endpoints are vertices of `arr G1 G2` or `arr G2 G1`. -/
theorem interGraph_seg_data (G1 G2 : EvenGraph) (s : LineSegment)
    (hs : s ∈ (interGraph G1 G2).segments) :
    (s.p1 ∈ (arr G1 G2).toVertices ∨ s.p1 ∈ (arr G2 G1).toVertices) ∧
    (s.p2 ∈ (arr G1 G2).toVertices ∨ s.p2 ∈ (arr G2 G1).toVertices) := by
  rcases interGraph_seg_origin G1 G2 s hs with h | h | ⟨σ0, hσ0, hcanon⟩
  · exact ⟨Or.inl ((arr G1 G2).segments_endpoints s h).1,
           Or.inl ((arr G1 G2).segments_endpoints s h).2⟩
  · exact ⟨Or.inr ((arr G2 G1).segments_endpoints s h).1,
           Or.inr ((arr G2 G1).segments_endpoints s h).2⟩
  · -- canonicalised: s = canonSeg σ0 for σ0 ∈ arr G1 G2 segments; endpoints are σ0's (swapped)
    have he1 := ((arr G1 G2).segments_endpoints σ0 hσ0).1
    have he2 := ((arr G1 G2).segments_endpoints σ0 hσ0).2
    rw [hcanon]
    unfold canonSeg
    split
    · exact ⟨Or.inl he1, Or.inl he2⟩
    · exact ⟨Or.inl he2, Or.inl he1⟩

/-- An `interGraph G1 G2` segment's endpoints are off a ray that avoids both arrangements'
    vertices. -/
theorem interGraph_seg_endpoints_off_ray (G1 G2 : EvenGraph) (r : Ray) (s : LineSegment)
    (hs : s ∈ (interGraph G1 G2).segments)
    (h1 : rayAvoidsGraphVertices r (arr G1 G2)) (h2 : rayAvoidsGraphVertices r (arr G2 G1)) :
    s.p1 ∉ r.toSet ∧ s.p2 ∉ r.toSet := by
  obtain ⟨hd1, hd2⟩ := interGraph_seg_data G1 G2 s hs
  have key : ∀ v : Vector2D, (v ∈ (arr G1 G2).toVertices ∨ v ∈ (arr G2 G1).toVertices) →
      v ∉ r.toSet := by
    intro v hv hvr
    rcases hv with hv | hv
    · have : v ∈ r.toSet ∩ (arr G1 G2).toVertexSet := ⟨hvr, hv⟩
      rw [h1] at this; exact this
    · have : v ∈ r.toSet ∩ (arr G2 G1).toVertexSet := ⟨hvr, hv⟩
      rw [h2] at this; exact this
  exact ⟨key s.p1 hd1, key s.p2 hd2⟩

/-- The origin of a ray off `∂G1 ∪ ∂G2` is off every `interGraph G1 G2` segment. -/
theorem interGraph_origin_off (G1 G2 : EvenGraph) (r : Ray) (s : LineSegment)
    (hs : s ∈ (interGraph G1 G2).segments)
    (hoff1 : r.origin ∉ G1.toBoundarySet) (hoff2 : r.origin ∉ G2.toBoundarySet) :
    r.origin ∉ s.toSet := by
  intro h_on
  have : r.origin ∈ (interGraph G1 G2).toBoundarySet := ⟨s, hs, h_on⟩
  rcases interGraph_boundary_subset G1 G2 this with h | h
  · exact hoff1 h
  · exact hoff2 h

open EvenGraphIntersectionProofs in
/-- Crossing-parameter uniqueness for `interGraph G1 G2` segments. -/
theorem interGraph_param_unique (G1 G2 : EvenGraph) (r : Ray) (s : LineSegment)
    (hs : s ∈ (interGraph G1 G2).segments)
    (h1 : rayAvoidsGraphVertices r (arr G1 G2)) (h2 : rayAvoidsGraphVertices r (arr G2 G1))
    (hoff1 : r.origin ∉ G1.toBoundarySet) (hoff2 : r.origin ∉ G2.toBoundarySet)
    (h : rayIntersectsSegment r s) (t : ℚ) (ht : 0 ≤ t)
    (hmem : (⟨r.origin.x + t * r.direction.x, r.origin.y + t * r.direction.y⟩ : Vector2D)
      ∈ s.toSet) :
    t = rayCrossingParam r s h := by
  obtain ⟨hp1, hp2⟩ := interGraph_seg_endpoints_off_ray G1 G2 r s hs h1 h2
  exact rayCrossingParam_unique r s h
    (interGraph_origin_off G1 G2 r s hs hoff1 hoff2) hp1 hp2 t ht hmem

/-! ### Counting split at a parameter -/

/-- `crossedPastB r t' s` : the ray crosses `s` at a parameter strictly greater than `t'`. -/
def crossedPastB (r : Ray) (t' : ℚ) (s : LineSegment) : Bool :=
  decide (∃ t : ℚ, t > t' ∧
    (⟨r.origin.x + t * r.direction.x, r.origin.y + t * r.direction.y⟩ : Vector2D) ∈ s.toSet)

/-- `crossedB r s` : the ray crosses `s`. -/
def crossedB (r : Ray) (s : LineSegment) : Bool := decide (rayIntersectsSegment r s)

theorem crossedPastB_le_crossedB (r : Ray) (t' : ℚ) (ht' : 0 ≤ t') (s : LineSegment) :
    crossedPastB r t' s = true → crossedB r s = true := by
  intro h
  simp only [crossedPastB, decide_eq_true_eq] at h
  obtain ⟨t, ht, hmem⟩ := h
  simp only [crossedB, decide_eq_true_eq]
  exact (EvenGraphIntersectionProofs.rayIntersectsSegment_iff_exists_param r s).mpr
    ⟨t, le_of_lt (lt_of_le_of_lt ht' ht), hmem⟩

/-- Pure list identity: count of crossed = count of (crossed and not-past) + count of past,
    provided past ⟹ crossed pointwise. -/
theorem countP_split (r : Ray) (t' : ℚ) (ht' : 0 ≤ t') (L : List LineSegment) :
    L.countP (crossedB r) =
      L.countP (fun s => crossedB r s && !(crossedPastB r t' s)) +
        L.countP (crossedPastB r t') := by
  induction L with
  | nil => simp
  | cons a rest ih =>
    simp only [List.countP_cons]
    by_cases hc : crossedB r a = true
    · by_cases hp : crossedPastB r t' a = true
      · simp [hc, hp, ih]; omega
      · simp only [Bool.not_eq_true] at hp
        simp [hc, hp, ih]; omega
    · simp only [Bool.not_eq_true] at hc
      have hp : crossedPastB r t' a = false := by
        by_contra h
        simp only [Bool.not_eq_false] at h
        rw [crossedPastB_le_crossedB r t' ht' a h] at hc; exact absurd hc (by simp)
      simp [hc, hp, ih]

/-- The past-count over a graph's segment list equals the sub-ray crossing count, provided the
    point at `t'` is off the graph's boundary. -/
theorem past_count_eq_subRay (r : Ray) (t' : ℚ) (H : EvenGraph)
    (h_off : (⟨r.origin.x + t' * r.direction.x, r.origin.y + t' * r.direction.y⟩ : Vector2D)
      ∉ H.toBoundarySet) :
    H.segments.countP (crossedPastB r t') =
      intersectionRayGraphSegmentsNumber (EvenGraphIntersectionProofs.subRay r t') H := by
  rw [EvenGraphIntersectionProofs.subRay_count_eq_past_count r t' H h_off]
  rfl

/-- If a boolean predicate `P` is constant (equal to `c0`) on all list elements satisfying
    `Q`, then `countP (P ∧ Q)` is `countP Q` when `c0` and `0` otherwise. -/
theorem countP_and_const {α : Type*} (P Q : α → Bool) (l : List α) (c0 : Bool)
    (h : ∀ a ∈ l, Q a = true → P a = c0) :
    l.countP (fun a => P a && Q a) = if c0 then l.countP Q else 0 := by
  cases c0 with
  | false =>
    show l.countP (fun a => P a && Q a) = 0
    induction l with
    | nil => simp
    | cons a rest ih =>
      have ih' := ih (fun b hb => h b (List.mem_cons_of_mem _ hb))
      have ha := h a (List.mem_cons_self _ _)
      simp only [List.countP_cons]
      by_cases hQ : Q a = true
      · have hP : P a = false := ha hQ
        simp [hQ, hP, ih']
      · simp only [Bool.not_eq_true] at hQ
        simp [hQ, ih']
  | true =>
    show l.countP (fun a => P a && Q a) = l.countP Q
    induction l with
    | nil => simp
    | cons a rest ih =>
      have ih' := ih (fun b hb => h b (List.mem_cons_of_mem _ hb))
      have ha := h a (List.mem_cons_self _ _)
      simp only [List.countP_cons]
      by_cases hQ : Q a = true
      · have hP : P a = true := ha hQ
        simp [hQ, hP, ih']
      · simp only [Bool.not_eq_true] at hQ
        simp [hQ, ih']

/-! ### Gap construction -/

open EvenGraphIntersectionProofs in
/-- The finite set of ray-crossing parameters of the segments in a list. -/
noncomputable def paramFinset (r : Ray) (L : List LineSegment) : Finset ℚ :=
  (L.filterMap (fun s => if h : rayIntersectsSegment r s then some (rayCrossingParam r s h)
    else none)).toFinset

open EvenGraphIntersectionProofs in
theorem mem_paramFinset (r : Ray) (L : List LineSegment) (p : ℚ) :
    p ∈ paramFinset r L ↔ ∃ s ∈ L, ∃ h : rayIntersectsSegment r s, rayCrossingParam r s h = p := by
  rw [paramFinset, List.mem_toFinset, List.mem_filterMap]
  constructor
  · rintro ⟨s, hs, heq⟩
    by_cases h : rayIntersectsSegment r s
    · rw [dif_pos h] at heq
      exact ⟨s, hs, h, Option.some.inj heq⟩
    · rw [dif_neg h] at heq
      exact absurd heq (by simp)
  · rintro ⟨s, hs, h, heq⟩
    exact ⟨s, hs, by rw [dif_pos h, heq]⟩

open EvenGraphIntersectionProofs in
theorem paramFinset_append_comm (r : Ray) (L1 L2 : List LineSegment) :
    paramFinset r (L1 ++ L2) = paramFinset r (L2 ++ L1) := by
  ext p
  rw [mem_paramFinset, mem_paramFinset]
  constructor <;>
  · rintro ⟨s, hs, h, heq⟩
    rcases List.mem_append.mp hs with hin | hin
    · exact ⟨s, List.mem_append.mpr (Or.inr hin), h, heq⟩
    · exact ⟨s, List.mem_append.mpr (Or.inl hin), h, heq⟩

open EvenGraphIntersectionProofs in
/-- Gap construction: given that some segment in `L` is crossed, produce the minimum crossing
    parameter `t₀ ≥ 0` and a gap `t'` with `t₀ < t'` strictly below every larger crossing
    parameter. -/
theorem exists_gap (r : Ray) (L : List LineSegment)
    (h_ne : (paramFinset r L).Nonempty) :
    ∃ t₀ t' : ℚ, 0 ≤ t₀ ∧ t₀ < t' ∧
      (∀ p ∈ paramFinset r L, t₀ ≤ p) ∧
      (∀ p ∈ paramFinset r L, t₀ < p → t' < p) := by
  classical
  set t₀ := (paramFinset r L).min' h_ne with ht₀_def
  have ht₀_mem : t₀ ∈ paramFinset r L := (paramFinset r L).min'_mem h_ne
  have ht₀_min : ∀ p ∈ paramFinset r L, t₀ ≤ p := fun p hp => (paramFinset r L).min'_le p hp
  -- t₀ ≥ 0
  have ht₀_nn : 0 ≤ t₀ := by
    rw [mem_paramFinset] at ht₀_mem
    obtain ⟨s, _, h, heq⟩ := ht₀_mem
    rw [← heq]; exact rayCrossingParam_nonneg r s h
  -- larger params
  set P' := (paramFinset r L).filter (fun p => t₀ < p) with hP'_def
  by_cases hP'ne : P'.Nonempty
  · set t₁ := P'.min' hP'ne with ht₁_def
    have ht₁_mem : t₁ ∈ P' := P'.min'_mem hP'ne
    have ht₁_gt : t₀ < t₁ := (Finset.mem_filter.mp ht₁_mem).2
    refine ⟨t₀, (t₀ + t₁) / 2, ht₀_nn, by linarith, ht₀_min, ?_⟩
    intro p hp hlt
    have hp' : p ∈ P' := Finset.mem_filter.mpr ⟨hp, hlt⟩
    have : t₁ ≤ p := P'.min'_le p hp'
    linarith
  · refine ⟨t₀, t₀ + 1, ht₀_nn, by linarith, ht₀_min, ?_⟩
    intro p hp hlt
    exact absurd (Finset.mem_filter.mpr ⟨hp, hlt⟩) (by
      intro hcontra; exact hP'ne ⟨p, hcontra⟩)

open EvenGraphIntersectionProofs in
/-- Like `exists_gap` but additionally reports that the minimum parameter `t₀` is itself a
    crossing parameter (a member of `paramFinset r L`). -/
theorem exists_gap_mem (r : Ray) (L : List LineSegment)
    (h_ne : (paramFinset r L).Nonempty) :
    ∃ t₀ t' : ℚ, 0 ≤ t₀ ∧ t₀ < t' ∧ t₀ ∈ paramFinset r L ∧
      (∀ p ∈ paramFinset r L, t₀ ≤ p) ∧
      (∀ p ∈ paramFinset r L, t₀ < p → t' < p) := by
  classical
  set t₀ := (paramFinset r L).min' h_ne with ht₀_def
  have ht₀_mem : t₀ ∈ paramFinset r L := (paramFinset r L).min'_mem h_ne
  have ht₀_min : ∀ p ∈ paramFinset r L, t₀ ≤ p := fun p hp => (paramFinset r L).min'_le p hp
  have ht₀_nn : 0 ≤ t₀ := by
    rw [mem_paramFinset] at ht₀_mem
    obtain ⟨s, _, h, heq⟩ := ht₀_mem
    rw [← heq]; exact rayCrossingParam_nonneg r s h
  set P' := (paramFinset r L).filter (fun p => t₀ < p) with hP'_def
  by_cases hP'ne : P'.Nonempty
  · set t₁ := P'.min' hP'ne with ht₁_def
    have ht₁_mem : t₁ ∈ P' := P'.min'_mem hP'ne
    have ht₁_gt : t₀ < t₁ := (Finset.mem_filter.mp ht₁_mem).2
    refine ⟨t₀, (t₀ + t₁) / 2, ht₀_nn, by linarith, ht₀_mem, ht₀_min, ?_⟩
    intro p hp hlt
    have hp' : p ∈ P' := Finset.mem_filter.mpr ⟨hp, hlt⟩
    have : t₁ ≤ p := P'.min'_le p hp'
    linarith
  · refine ⟨t₀, t₀ + 1, ht₀_nn, by linarith, ht₀_mem, ht₀_min, ?_⟩
    intro p hp hlt
    exact absurd (Finset.mem_filter.mpr ⟨hp, hlt⟩) (by
      intro hcontra; exact hP'ne ⟨p, hcontra⟩)

/-! ### Parity property (core) -/

open EvenGraphIntersectionProofs in
/-- Abbreviation: the point on `r` at parameter `t`. -/
private def rayPt (r : Ray) (t : ℚ) : Vector2D :=
  ⟨r.origin.x + t * r.direction.x, r.origin.y + t * r.direction.y⟩

private theorem rayPt_mem_ray (r : Ray) (t : ℚ) (ht : 0 ≤ t) : rayPt r t ∈ r.toSet :=
  ⟨t, ht, rfl, rfl⟩

open EvenGraphIntersectionProofs in
/-- For a segment of `arr G1 G2` crossed by a qualifying ray, a ray point at parameter `t ≥ 0`
    lies on the segment iff `t` is the crossing parameter. -/
private theorem arr_on_iff_param (G1 G2 : EvenGraph) (r : Ray) (s : LineSegment)
    (hs : s ∈ (arr G1 G2).segments) (h_avoids : rayAvoidsGraphVertices r (arr G1 G2))
    (hoff : r.origin ∉ G1.toBoundarySet) (h : rayIntersectsSegment r s) (t : ℚ) (ht : 0 ≤ t) :
    rayPt r t ∈ s.toSet ↔ t = rayCrossingParam r s h := by
  constructor
  · intro hmem
    exact arr_param_unique G1 G2 r s hs h_avoids hoff h t ht hmem
  · rintro rfl
    exact rayCrossingParam_point_mem_seg r s h

open EvenGraphIntersectionProofs in
/-- `crossedAtB r t₀ s` : the ray crosses `s` and its crossing point is at parameter `t₀`. -/
private def crossedAtB (r : Ray) (t₀ : ℚ) (s : LineSegment) : Bool :=
  decide (rayIntersectsSegment r s ∧ rayPt r t₀ ∈ s.toSet)

open EvenGraphIntersectionProofs in
/-- For a qualifying ray and a list `L ⊆ arr1.segs ++ arr2.segs`, with a gap `(t₀, t')` from
    the combined parameter finset, the "peeled" count (crossed but not past `t'`) equals the
    count of segments crossed exactly at parameter `t₀`. -/
private theorem peeled_eq_crossedAt (G1 G2 : EvenGraph) (r : Ray)
    (h1 : rayAvoidsGraphVertices r (arr G1 G2)) (h2 : rayAvoidsGraphVertices r (arr G2 G1))
    (hoff1 : r.origin ∉ G1.toBoundarySet) (hoff2 : r.origin ∉ G2.toBoundarySet)
    (t₀ t' : ℚ) (ht₀ : 0 ≤ t₀) (htlt : t₀ < t')
    (hmin : ∀ p ∈ paramFinset r ((arr G1 G2).segments ++ (arr G2 G1).segments), t₀ ≤ p)
    (hgap : ∀ p ∈ paramFinset r ((arr G1 G2).segments ++ (arr G2 G1).segments), t₀ < p → t' < p)
    (L : List LineSegment) (hL : ∀ s ∈ L, s ∈ (arr G1 G2).segments ∨ s ∈ (arr G2 G1).segments) :
    L.countP (fun s => crossedB r s && !(crossedPastB r t' s)) =
      L.countP (crossedAtB r t₀) := by
  apply List.countP_congr
  intro s hs
  -- The crossing parameter of s (if crossed) is in the combined finset.
  have hmem_fs : ∀ (hc : rayIntersectsSegment r s),
      rayCrossingParam r s hc ∈ paramFinset r ((arr G1 G2).segments ++ (arr G2 G1).segments) := by
    intro hc
    rw [mem_paramFinset]
    rcases hL s hs with hin | hin
    · exact ⟨s, List.mem_append_left _ hin, hc, rfl⟩
    · exact ⟨s, List.mem_append_right _ hin, hc, rfl⟩
  -- param-uniqueness for s
  have huniq : ∀ (hc : rayIntersectsSegment r s) (t : ℚ), 0 ≤ t → rayPt r t ∈ s.toSet →
      t = rayCrossingParam r s hc := by
    intro hc t ht hmem
    rcases hL s hs with hin | hin
    · exact arr_param_unique G1 G2 r s hin h1 hoff1 hc t ht hmem
    · exact arr_param_unique G2 G1 r s hin h2 hoff2 hc t ht hmem
  by_cases hc : rayIntersectsSegment r s
  · set τ := rayCrossingParam r s hc with hτ
    have hτ_nn : 0 ≤ τ := rayCrossingParam_nonneg r s hc
    have hτ_mem : τ ∈ paramFinset r ((arr G1 G2).segments ++ (arr G2 G1).segments) := hmem_fs hc
    have hτ_ge : t₀ ≤ τ := hmin τ hτ_mem
    -- LHS predicate value
    have hcrossed : crossedB r s = true := by simp [crossedB, hc]
    -- crossedPastB r t' s ↔ τ > t'
    have hpast_iff : crossedPastB r t' s = true ↔ t' < τ := by
      simp only [crossedPastB, decide_eq_true_eq]
      constructor
      · rintro ⟨t, ht, hmem⟩
        have ht0 : 0 ≤ t := le_of_lt (lt_of_le_of_lt (le_of_lt (lt_of_le_of_lt ht₀ htlt)) ht)
        have : t = τ := huniq hc t ht0 hmem
        rw [this] at ht; exact ht
      · intro h
        exact ⟨τ, h, by rw [hτ]; exact rayCrossingParam_point_mem_seg r s hc⟩
    -- crossedAtB r t₀ s ↔ τ = t₀
    have hat_iff : crossedAtB r t₀ s = true ↔ τ = t₀ := by
      simp only [crossedAtB, decide_eq_true_eq]
      constructor
      · rintro ⟨_, hmem⟩
        exact ((huniq hc t₀ ht₀ hmem)).symm
      · intro h
        refine ⟨hc, ?_⟩
        rw [show rayPt r t₀ = rayPt r τ by rw [h]]
        exact rayCrossingParam_point_mem_seg r s hc
    -- Now show LHS = RHS bool
    by_cases hτeq : τ = t₀
    · -- crossed at t₀: not past t' (since τ = t₀ < t'), and crossedAt true
      have hnotpast : crossedPastB r t' s = false := by
        rw [Bool.eq_false_iff]; intro hp; rw [hpast_iff] at hp; rw [hτeq] at hp; linarith
      have hat : crossedAtB r t₀ s = true := hat_iff.mpr hτeq
      rw [hcrossed, hnotpast, hat]; simp
    · -- τ > t₀ hence τ > t', so it is "past" and not "at"
      have hτgt : t₀ < τ := lt_of_le_of_ne hτ_ge (Ne.symm hτeq)
      have hτpast : t' < τ := hgap τ hτ_mem hτgt
      have hpast : crossedPastB r t' s = true := hpast_iff.mpr hτpast
      have hnat : crossedAtB r t₀ s = false := by
        rw [Bool.eq_false_iff]; intro hcon; rw [hat_iff] at hcon; exact hτeq hcon
      rw [hcrossed, hpast, hnat]; simp
  · -- not crossed: both sides false
    have hnc : crossedB r s = false := by simp [crossedB, hc]
    have hnat : crossedAtB r t₀ s = false := by
      simp only [crossedAtB, Bool.decide_and]
      rw [Bool.eq_false_iff]; intro hcon
      simp only [Bool.and_eq_true, decide_eq_true_eq] at hcon
      exact hc hcon.1
    rw [hnc, hnat]; simp

open EvenGraphIntersectionProofs in
/-- A gap parameter `t'` (strictly below every crossing parameter exceeding `t₀`, but no
    crossing parameter lies in `(t₀, t']`) is itself not a crossing parameter, so the ray point
    at `t'` is off `∂G1` and off `∂G2`. -/
private theorem gap_point_off_boundaries (G1 G2 : EvenGraph) (r : Ray)
    (h1 : rayAvoidsGraphVertices r (arr G1 G2)) (h2 : rayAvoidsGraphVertices r (arr G2 G1))
    (hoff1 : r.origin ∉ G1.toBoundarySet) (hoff2 : r.origin ∉ G2.toBoundarySet)
    (t₀ t' : ℚ) (ht₀ : 0 ≤ t₀) (htlt : t₀ < t')
    (hgap : ∀ p ∈ paramFinset r ((arr G1 G2).segments ++ (arr G2 G1).segments), t₀ < p → t' < p) :
    rayPt r t' ∉ G1.toBoundarySet ∧ rayPt r t' ∉ G2.toBoundarySet := by
  have ht'_nn : 0 ≤ t' := le_of_lt (lt_of_le_of_lt ht₀ htlt)
  have key : ∀ (H : EvenGraph), (∀ s ∈ H.segments, s ∈ (arr G1 G2).segments ∨
        s ∈ (arr G2 G1).segments) →
      rayPt r t' ∉ H.toBoundarySet := by
    intro H hHsub hmem
    obtain ⟨s, hs, hon⟩ := hmem
    have hc : rayIntersectsSegment r s :=
      (rayIntersectsSegment_iff_exists_param r s).mpr ⟨t', ht'_nn, hon⟩
    have huniq : t' = rayCrossingParam r s hc := by
      rcases hHsub s hs with hin | hin
      · exact arr_param_unique G1 G2 r s hin h1 hoff1 hc t' ht'_nn hon
      · exact arr_param_unique G2 G1 r s hin h2 hoff2 hc t' ht'_nn hon
    have hmemfs : t' ∈ paramFinset r ((arr G1 G2).segments ++ (arr G2 G1).segments) := by
      rw [mem_paramFinset]
      rcases hHsub s hs with hin | hin
      · exact ⟨s, List.mem_append_left _ hin, hc, huniq.symm⟩
      · exact ⟨s, List.mem_append_right _ hin, hc, huniq.symm⟩
    exact absurd (hgap t' hmemfs htlt) (lt_irrefl t')
  refine ⟨?_, ?_⟩
  · rw [← arr_boundary_eq G1 G2]
    exact key (arr G1 G2) (fun s hs => Or.inl hs)
  · rw [← arr_boundary_eq G2 G1]
    exact key (arr G2 G1) (fun s hs => Or.inr hs)

open EvenGraphIntersectionProofs in
/-- `intersectionRayGraphSegmentsNumber r H = H.segments.countP (crossedB r)`. -/
private theorem count_eq_countP_crossedB (r : Ray) (H : Graph) :
    intersectionRayGraphSegmentsNumber r H = H.segments.countP (crossedB r) := rfl

open EvenGraphIntersectionProofs in
/-- Graph-level analogue of `subRay_count_eq_past_count`. -/
private theorem subRay_count_eq_past_count_graph (r : Ray) (t₀ : ℚ) (G : Graph)
    (h_off : rayPt r t₀ ∉ G.toBoundarySet) :
    intersectionRayGraphSegmentsNumber (subRay r t₀) G =
      G.segments.countP (crossedPastB r t₀) := by
  unfold intersectionRayGraphSegmentsNumber
  apply List.countP_congr
  intro s hs
  have h_p_not_s : rayPt r t₀ ∉ s.toSet := fun h_on => h_off ⟨s, hs, h_on⟩
  have h_iff : rayIntersectsSegment (subRay r t₀) s ↔
      ∃ t : ℚ, t > t₀ ∧ rayPt r t ∈ s.toSet := by
    rw [subRay_crosses_iff]
    constructor
    · rintro ⟨t, ht_ge, hmem⟩
      refine ⟨t, ?_, hmem⟩
      rcases lt_or_eq_of_le ht_ge with h_lt | h_eq
      · exact h_lt
      · exfalso; apply h_p_not_s
        have : rayPt r t₀ = rayPt r t := by rw [rayPt, rayPt, h_eq]
        rw [this]; exact hmem
    · rintro ⟨t, ht_gt, hmem⟩
      exact ⟨t, le_of_lt ht_gt, hmem⟩
  simp only [crossedB, crossedPastB, decide_eq_true_iff]
  exact h_iff

open EvenGraphIntersectionProofs in
/-- Split a graph's crossing count into the peeled (crossed-not-past) part plus the sub-ray
    count, given the ray point at `t'` is off the graph's boundary. -/
private theorem count_split_subRay (r : Ray) (t' : ℚ) (ht' : 0 ≤ t') (H : Graph)
    (h_off : rayPt r t' ∉ H.toBoundarySet) :
    intersectionRayGraphSegmentsNumber r H =
      H.segments.countP (fun s => crossedB r s && !(crossedPastB r t' s)) +
        intersectionRayGraphSegmentsNumber (subRay r t') H := by
  rw [count_eq_countP_crossedB, countP_split r t' ht' H.segments]
  congr 1
  rw [subRay_count_eq_past_count_graph r t' H h_off]

/-- `x * y` and `x * (y % 2)` are congruent mod 2. -/
private theorem mul_mod2_inner (x y : ℕ) : (x * (y % 2)) % 2 = (x * y) % 2 := by
  rw [Nat.mul_mod, Nat.mod_mod, ← Nat.mul_mod]

/-- Pure mod-2 algebra used to assemble the inductive step. -/
private theorem mod2_assemble (pIG igr p1 p2 a b : ℕ)
    (hIH : igr % 2 = (a * b) % 2)
    (hloc : pIG % 2 = (p1 * (b % 2) + p2 * (a % 2) + p1 * p2) % 2) :
    (pIG + igr) % 2 = ((p1 + a) * (p2 + b)) % 2 := by
  have eb : (p1 * (b % 2)) % 2 = (p1 * b) % 2 := mul_mod2_inner p1 b
  have ea : (p2 * (a % 2)) % 2 = (p2 * a) % 2 := mul_mod2_inner p2 a
  -- Work with ModEq.
  have h1 : (pIG + igr) % 2 = ((p1 * (b % 2) + p2 * (a % 2) + p1 * p2) + a * b) % 2 := by
    rw [Nat.add_mod, hloc, hIH, ← Nat.add_mod]
  have h2 : ((p1 * (b % 2) + p2 * (a % 2) + p1 * p2) + a * b) % 2 =
      (p1 * b + p2 * a + p1 * p2 + a * b) % 2 := by omega
  have h3 : (p1 * b + p2 * a + p1 * p2 + a * b) % 2 = ((p1 + a) * (p2 + b)) % 2 := by
    congr 1; ring
  rw [h1, h2, h3]

open EvenGraphIntersectionProofs in
/-- If the ray point at `t₀` is off `∂(arr G1 G2)` (no `arr1`-crossing at `t₀`), then the
    `arr1`-counts of the sub-rays from `t₀` and from the gap point `t'` agree. -/
private theorem subRay_count_t0_eq_t' (G1 G2 : EvenGraph) (r : Ray)
    (h1 : rayAvoidsGraphVertices r (arr G1 G2)) (h2 : rayAvoidsGraphVertices r (arr G2 G1))
    (hoff1 : r.origin ∉ G1.toBoundarySet) (hoff2 : r.origin ∉ G2.toBoundarySet)
    (t₀ t' : ℚ) (ht₀ : 0 ≤ t₀) (htlt : t₀ < t')
    (hmin : ∀ p ∈ paramFinset r ((arr G1 G2).segments ++ (arr G2 G1).segments), t₀ ≤ p)
    (hgap : ∀ p ∈ paramFinset r ((arr G1 G2).segments ++ (arr G2 G1).segments), t₀ < p → t' < p)
    (H : EvenGraph) (hHsub : ∀ s ∈ H.segments, s ∈ (arr G1 G2).segments ∨
        s ∈ (arr G2 G1).segments)
    (h_off_t0 : rayPt r t₀ ∉ H.toBoundarySet) :
    intersectionRayGraphSegmentsNumber (subRay r t₀) H =
      intersectionRayGraphSegmentsNumber (subRay r t') H := by
  have ht'_nn : 0 ≤ t' := le_of_lt (lt_of_le_of_lt ht₀ htlt)
  obtain ⟨hoff1', hoff2'⟩ :=
    gap_point_off_boundaries G1 G2 r h1 h2 hoff1 hoff2 t₀ t' ht₀ htlt hgap
  have h_off_t' : rayPt r t' ∉ H.toBoundarySet := by
    intro hmem; obtain ⟨s, hs, hon⟩ := hmem
    rcases hHsub s hs with hin | hin
    · exact (hoff1' (by rw [← arr_boundary_eq G1 G2]; exact ⟨s, hin, hon⟩))
    · exact (hoff2' (by rw [← arr_boundary_eq G2 G1]; exact ⟨s, hin, hon⟩))
  rw [subRay_count_eq_past_count_graph r t₀ H.toGraph h_off_t0,
    subRay_count_eq_past_count_graph r t' H.toGraph h_off_t']
  apply List.countP_congr
  intro s hs
  simp only [crossedPastB, decide_eq_true_iff]
  constructor
  · rintro ⟨t, ht, hmem⟩
    -- t > t₀; show t > t'. t is a crossing param of s (in arr1∪arr2), so t ∈ finset, and gap.
    have hc : rayIntersectsSegment r s :=
      (rayIntersectsSegment_iff_exists_param r s).mpr
        ⟨t, le_of_lt (lt_of_le_of_lt ht₀ ht), hmem⟩
    have htt : 0 ≤ t := le_of_lt (lt_of_le_of_lt ht₀ ht)
    have huniq : t = rayCrossingParam r s hc := by
      rcases hHsub s hs with hin | hin
      · exact arr_param_unique G1 G2 r s hin h1 hoff1 hc t htt hmem
      · exact arr_param_unique G2 G1 r s hin h2 hoff2 hc t htt hmem
    have hmemfs : rayCrossingParam r s hc ∈
        paramFinset r ((arr G1 G2).segments ++ (arr G2 G1).segments) := by
      rw [mem_paramFinset]
      rcases hHsub s hs with hin | hin
      · exact ⟨s, List.mem_append_left _ hin, hc, rfl⟩
      · exact ⟨s, List.mem_append_right _ hin, hc, rfl⟩
    have : t' < rayCrossingParam r s hc := hgap _ hmemfs (by rw [← huniq]; exact ht)
    exact ⟨t, by rw [huniq]; exact this, hmem⟩
  · rintro ⟨t, ht, hmem⟩
    exact ⟨t, lt_trans htlt ht, hmem⟩

open EvenGraphIntersectionProofs in
/-- A peeled `arr1` or `arr2` segment is crossed exactly at parameter `t₀`. -/
private theorem peeled_implies_param_eq (G1 G2 : EvenGraph) (r : Ray)
    (h1 : rayAvoidsGraphVertices r (arr G1 G2)) (h2 : rayAvoidsGraphVertices r (arr G2 G1))
    (hoff1 : r.origin ∉ G1.toBoundarySet) (hoff2 : r.origin ∉ G2.toBoundarySet)
    (t₀ t' : ℚ) (ht₀ : 0 ≤ t₀) (htlt : t₀ < t')
    (hmin : ∀ p ∈ paramFinset r ((arr G1 G2).segments ++ (arr G2 G1).segments), t₀ ≤ p)
    (hgap : ∀ p ∈ paramFinset r ((arr G1 G2).segments ++ (arr G2 G1).segments), t₀ < p → t' < p)
    (s : LineSegment) (hs : s ∈ (arr G1 G2).segments ∨ s ∈ (arr G2 G1).segments)
    (hc : rayIntersectsSegment r s)
    (hpeel : (crossedB r s && !(crossedPastB r t' s)) = true) :
    rayCrossingParam r s hc = t₀ := by
  have ht'_nn : 0 ≤ t' := le_of_lt (lt_of_le_of_lt ht₀ htlt)
  set τ := rayCrossingParam r s hc with hτdef
  have hτ_nn : 0 ≤ τ := rayCrossingParam_nonneg r s hc
  have hτ_mem : τ ∈ paramFinset r ((arr G1 G2).segments ++ (arr G2 G1).segments) := by
    rw [mem_paramFinset]
    rcases hs with hin | hin
    · exact ⟨s, List.mem_append_left _ hin, hc, rfl⟩
    · exact ⟨s, List.mem_append_right _ hin, hc, rfl⟩
  have hτ_ge : t₀ ≤ τ := hmin τ hτ_mem
  -- not past t': so τ ≤ t'
  simp only [Bool.and_eq_true, Bool.not_eq_true', crossedPastB, decide_eq_false_iff_not,
    not_exists, not_and] at hpeel
  have hnotpast := hpeel.2
  by_contra hne
  have hτgt : t₀ < τ := lt_of_le_of_ne hτ_ge (Ne.symm hne)
  have hτpast : t' < τ := hgap τ hτ_mem hτgt
  exact hnotpast τ hτpast (rayCrossingParam_point_mem_seg r s hc)

open EvenGraphIntersectionProofs in
/-- The ray point at `t₀` lies on `∂(arr G1 G2)` iff some `arr G1 G2` segment is peeled. -/
private theorem boundary_iff_peeled_pos (G1 G2 : EvenGraph) (r : Ray)
    (h1 : rayAvoidsGraphVertices r (arr G1 G2)) (h2 : rayAvoidsGraphVertices r (arr G2 G1))
    (hoff1 : r.origin ∉ G1.toBoundarySet) (hoff2 : r.origin ∉ G2.toBoundarySet)
    (t₀ t' : ℚ) (ht₀ : 0 ≤ t₀) (htlt : t₀ < t')
    (hmin : ∀ p ∈ paramFinset r ((arr G1 G2).segments ++ (arr G2 G1).segments), t₀ ≤ p)
    (hgap : ∀ p ∈ paramFinset r ((arr G1 G2).segments ++ (arr G2 G1).segments), t₀ < p → t' < p) :
    rayPt r t₀ ∈ G1.toBoundarySet ↔
      0 < (arr G1 G2).segments.countP (fun s => crossedB r s && !(crossedPastB r t' s)) := by
  constructor
  · intro hbd
    rw [← arr_boundary_eq G1 G2] at hbd
    obtain ⟨s, hs, hon⟩ := hbd
    -- s crossed at t₀
    have hc : rayIntersectsSegment r s :=
      (rayIntersectsSegment_iff_exists_param r s).mpr ⟨t₀, ht₀, hon⟩
    have hτ : t₀ = rayCrossingParam r s hc := arr_param_unique G1 G2 r s hs h1 hoff1 hc t₀ ht₀ hon
    -- s is peeled
    rw [List.countP_pos_iff]
    refine ⟨s, hs, ?_⟩
    have hcrossed : crossedB r s = true := by simp [crossedB, hc]
    have hnotpast : crossedPastB r t' s = false := by
      rw [Bool.eq_false_iff]; intro hp
      simp only [crossedPastB, decide_eq_true_eq] at hp
      obtain ⟨t, ht, hmem⟩ := hp
      have ht0 : 0 ≤ t := le_of_lt (lt_of_le_of_lt (le_of_lt (lt_of_le_of_lt ht₀ htlt)) ht)
      have huniq : t = rayCrossingParam r s hc :=
        arr_param_unique G1 G2 r s hs h1 hoff1 hc t ht0 hmem
      rw [← hτ] at huniq; rw [huniq] at ht; linarith
    simp only [hcrossed, hnotpast, Bool.not_false, Bool.and_true]
  · intro hpos
    rw [List.countP_pos_iff] at hpos
    obtain ⟨s, hs, hpeel⟩ := hpos
    have hc : rayIntersectsSegment r s := by
      simp only [Bool.and_eq_true, crossedB, decide_eq_true_eq] at hpeel; exact hpeel.1
    have hτ : rayCrossingParam r s hc = t₀ :=
      peeled_implies_param_eq G1 G2 r h1 h2 hoff1 hoff2 t₀ t' ht₀ htlt hmin hgap s (Or.inl hs)
        hc hpeel
    rw [← arr_boundary_eq G1 G2]
    refine ⟨s, hs, ?_⟩
    rw [← hτ]; exact rayCrossingParam_point_mem_seg r s hc

open EvenGraphIntersectionProofs in
/-- The peeled count over `in1 = selectSegmentsInside arr1.segs G2.interior` equals the count
    of peeled `arr1` segments whose `G2`-interior-selection status is constant `c0`, where `c0`
    is `false` if `rayPt r t₀ ∈ ∂G2` and `decide (#arr2(subRay r t') % 2 = 1)` otherwise. -/
private theorem in1_peeled_count (G1 G2 : EvenGraph) (r : Ray)
    (h1 : rayAvoidsGraphVertices r (arr G1 G2)) (h2 : rayAvoidsGraphVertices r (arr G2 G1))
    (hoff1 : r.origin ∉ G1.toBoundarySet) (hoff2 : r.origin ∉ G2.toBoundarySet)
    (t₀ t' : ℚ) (ht₀ : 0 ≤ t₀) (htlt : t₀ < t')
    (hmin : ∀ p ∈ paramFinset r ((arr G1 G2).segments ++ (arr G2 G1).segments), t₀ ≤ p)
    (hgap : ∀ p ∈ paramFinset r ((arr G1 G2).segments ++ (arr G2 G1).segments), t₀ < p → t' < p) :
    (selectSegmentsInside (arr G1 G2).segments G2.interior).countP
        (fun s => crossedB r s && !(crossedPastB r t' s)) =
      if rayPt r t₀ ∈ G2.toBoundarySet then 0
      else if intersectionRayGraphSegmentsNumber (subRay r t') (arr G2 G1) % 2 = 1
        then (arr G1 G2).segments.countP (fun s => crossedB r s && !(crossedPastB r t' s))
        else 0 := by
  -- in1 count = arr1.segs.countP (peeled && selG2)
  rw [selectSegmentsInside, countP_filter_eq]
  -- choose c0
  set c0 : Bool := if rayPt r t₀ ∈ G2.toBoundarySet then false
    else decide (intersectionRayGraphSegmentsNumber (subRay r t') (arr G2 G1) % 2 = 1) with hc0
  -- selG2 is constant c0 on peeled arr1 segments
  have hconst : ∀ s ∈ (arr G1 G2).segments,
      (crossedB r s && !(crossedPastB r t' s)) = true →
        decide (segmentOpenInteriorSubset s G2.interior) = c0 := by
    intro s hs hpeel
    -- s is crossed at t₀
    have hc : rayIntersectsSegment r s := by
      simp only [Bool.and_eq_true] at hpeel
      simp only [crossedB, decide_eq_true_eq] at hpeel; exact hpeel.1
    have hτ : rayCrossingParam r s hc = t₀ :=
      peeled_implies_param_eq G1 G2 r h1 h2 hoff1 hoff2 t₀ t' ht₀ htlt hmin hgap s
        (Or.inl hs) hc hpeel
    -- p₁ = rayPt r t₀ is on s in its open interior.
    have hp₁_on : rayPt r t₀ ∈ s.toSet := by
      rw [← hτ]; exact rayCrossingParam_point_mem_seg r s hc
    have hp₁_ne := rayCrossingPoint_not_endpoint r (arr G1 G2) s hs h1 hc
    have hp₁_x : (rayCrossingPoint r s hc) = rayPt r t₀ := by
      rw [rayPt]; ext
      · rw [rayCrossingPoint_x, hτ]
      · rw [rayCrossingPoint_y, hτ]
    have hp₁_ne1 : rayPt r t₀ ≠ s.p1 := by rw [← hp₁_x]; exact hp₁_ne.1
    have hp₁_ne2 : rayPt r t₀ ≠ s.p2 := by rw [← hp₁_x]; exact hp₁_ne.2
    rw [hc0]
    by_cases hbd : rayPt r t₀ ∈ G2.toBoundarySet
    · -- shared: selection status false
      simp only [hbd, if_true]
      rw [decide_eq_false_iff_not]
      intro hsel
      -- segmentOpenInteriorSubset s G2.interior says p₁ ∈ G2.interior, but p₁ ∈ ∂G2 ⟹ ∉ interior
      have hp₁_int : rayPt r t₀ ∈ G2.interior := hsel (rayPt r t₀) hp₁_on hp₁_ne1 hp₁_ne2
      obtain ⟨seg', hseg', hon'⟩ := hbd
      exact hp₁_int.1 seg' hseg' hon'
    · -- transversal: selection status = decide(b%2 = 1)
      simp only [hbd, if_false]
      -- s is not shared w.r.t. G2
      have hns : ¬ IsShared G2 s := by
        intro hsh; exact hbd (hsh hp₁_on)
      have hiff := arr_seg_inside_iff_subRay_odd G1 G2 r s hs hns h1 h2 hc
      rw [hτ] at hiff
      -- #arr2(subRay r t₀) = #arr2(subRay r t')
      have heq : intersectionRayGraphSegmentsNumber (subRay r t₀) (arr G2 G1) =
          intersectionRayGraphSegmentsNumber (subRay r t') (arr G2 G1) := by
        apply subRay_count_t0_eq_t' G1 G2 r h1 h2 hoff1 hoff2 t₀ t' ht₀ htlt hmin hgap
          (arr G2 G1) (fun s hs => Or.inr hs)
        rw [arr_boundary_eq G2 G1]; exact hbd
      rw [heq] at hiff
      -- conclude: both decides agree via the iff.
      simp only [hiff]
  rw [countP_and_const _ _ _ c0 hconst]
  -- now case-split c0
  rw [hc0]
  by_cases hbd : rayPt r t₀ ∈ G2.toBoundarySet
  · simp [hbd]
  · simp only [hbd, if_false]
    by_cases hodd : intersectionRayGraphSegmentsNumber (subRay r t') (arr G2 G1) % 2 = 1
    · simp [hodd]
    · simp [hodd]

open EvenGraphIntersectionProofs in
/-- For a `sharedSelected` segment crossed by a qualifying ray, the crossing parameter is the
    unique nonnegative parameter whose ray point lies on it (its endpoints are `arr G1 G2`
    vertices, off the ray). -/
private theorem sharedSelected_param_unique (G1 G2 : EvenGraph) (r : Ray)
    (h1 : rayAvoidsGraphVertices r (arr G1 G2)) (h2 : rayAvoidsGraphVertices r (arr G2 G1))
    (hoff1 : r.origin ∉ G1.toBoundarySet)
    (σ : LineSegment) (hσ : σ ∈ sharedSelected G1 G2) (hc : rayIntersectsSegment r σ)
    (t : ℚ) (ht : 0 ≤ t) (hmem : rayPt r t ∈ σ.toSet) :
    t = rayCrossingParam r σ hc := by
  -- endpoints of σ are arr G1 G2 vertices.
  obtain ⟨hd1, hd2⟩ := interGraph_seg_data G1 G2 σ (by
    rw [interGraph_segments]; exact List.mem_append_left _ (List.mem_append_right _ hσ))
  have key : ∀ v : Vector2D, (v ∈ (arr G1 G2).toVertices ∨ v ∈ (arr G2 G1).toVertices) →
      v ∉ r.toSet := by
    intro v hv hvr
    rcases hv with hv | hv
    · have : v ∈ r.toSet ∩ (arr G1 G2).toVertexSet := ⟨hvr, hv⟩
      rw [h1] at this; exact this
    · have : v ∈ r.toSet ∩ (arr G2 G1).toVertexSet := ⟨hvr, hv⟩
      rw [h2] at this; exact this
  -- origin off σ: origin ∉ ∂(interGraph) hence ∉ σ.toSet … use sharedSelected ⊆ ∂G1.
  have horigin : pointAvoidsSegment r.origin σ := by
    intro h_on
    exact hoff1 (by rw [← arr_boundary_eq G1 G2]; exact sharedSelected_toSet_subset G1 G2 σ hσ h_on)
  exact rayCrossingParam_unique r σ hc horigin (key σ.p1 hd1) (key σ.p2 hd2) t ht hmem

/-- Two `arr G1 G2` segments that lie on a common line and share an interior point have equal
    point sets (collinear segments of an arrangement are interior-disjoint or identical). -/
private theorem arr_collinear_toSet_eq (G1 G2 : EvenGraph) (σ σ' : LineSegment)
    (hσ : σ ∈ (arr G1 G2).segments) (hσ' : σ' ∈ (arr G1 G2).segments)
    (hsl : SameLine σ σ') (x : Vector2D)
    (hxσ : x ∈ σ.toSet) (hx1 : x ≠ σ.p1) (hx2 : x ≠ σ.p2)
    (hxσ' : x ∈ σ'.toSet) (hx1' : x ≠ σ'.p1) (hx2' : x ≠ σ'.p2) :
    σ.toSet = σ'.toSet := by
  have hσnd : σ.p1 ≠ σ.p2 := (arr G1 G2).segments_nondegenerate σ hσ
  have hσ'nd : σ'.p1 ≠ σ'.p2 := (arr G1 G2).segments_nondegenerate σ' hσ'
  -- lineOf σ contains both segments.
  have hσ1 : σ.p1 ∈ lineOf σ := mem_lineOf_p1 σ
  have hσ2 : σ.p2 ∈ lineOf σ := mem_lineOf_p2 σ
  obtain ⟨hσ'1, hσ'2⟩ := hsl
  -- SameLine σ' σ (symmetric): endpoints of σ on lineOf σ'.
  have hslsym : SameLine σ' σ := by
    -- σ.p1, σ.p2 ∈ lineOf σ'. Use that σ'.p1, σ'.p2 ∈ lineOf σ and σ nondeg, plus x.
    -- Easier: lineOf σ = lineOf σ' as both contain two distinct points x-direction.
    constructor
    · -- σ.p1 ∈ lineOf σ'
      have hd := dir_parallel_of_two_mem_lineOf σ σ'.p1 σ'.p2 hσ'1 hσ'2
      -- direction of σ' is parallel to direction of σ; and σ'.p1 ∈ lineOf σ.
      simp only [lineOf, Set.mem_setOf_eq] at hσ'1 hσ'2 ⊢
      -- σ.p1 ∈ lineOf σ' : (σ.p1 - σ'.p1) ∥ (σ'.p2 - σ'.p1).
      have hds : (σ.p2.x - σ.p1.x, σ.p2.y - σ.p1.y) ≠ (0, 0) := by
        intro hh; apply hσnd
        exact (Vector2D.ext (by have := congrArg Prod.fst hh; simp at this; linarith)
          (by have := congrArg Prod.snd hh; simp at this; linarith)).symm
      have h12 : (σ'.p1.x - σ.p1.x) * (σ.p2.y - σ.p1.y) =
          (σ'.p1.y - σ.p1.y) * (σ.p2.x - σ.p1.x) := hσ'1
      have h22 : (σ'.p2.x - σ.p1.x) * (σ.p2.y - σ.p1.y) =
          (σ'.p2.y - σ.p1.y) * (σ.p2.x - σ.p1.x) := hσ'2
      -- (σ'.p2 - σ'.p1) ∥ (σ.p2 - σ.p1)
      have hpar : (σ'.p2.x - σ'.p1.x) * (σ.p2.y - σ.p1.y) =
          (σ'.p2.y - σ'.p1.y) * (σ.p2.x - σ.p1.x) := by linarith
      have := parallel_trans_of_nonzero (σ.p1.x - σ'.p1.x) (σ.p1.y - σ'.p1.y)
        (σ'.p2.x - σ'.p1.x) (σ'.p2.y - σ'.p1.y) (σ.p2.x - σ.p1.x) (σ.p2.y - σ.p1.y) hds
        (by linarith [h12]) (by linarith [hpar])
      linarith [this]
    · have hds : (σ.p2.x - σ.p1.x, σ.p2.y - σ.p1.y) ≠ (0, 0) := by
        intro hh; apply hσnd
        exact (Vector2D.ext (by have := congrArg Prod.fst hh; simp at this; linarith)
          (by have := congrArg Prod.snd hh; simp at this; linarith)).symm
      simp only [lineOf, Set.mem_setOf_eq] at hσ'1 hσ'2 ⊢
      have h12 : (σ'.p1.x - σ.p1.x) * (σ.p2.y - σ.p1.y) =
          (σ'.p1.y - σ.p1.y) * (σ.p2.x - σ.p1.x) := hσ'1
      have h22 : (σ'.p2.x - σ.p1.x) * (σ.p2.y - σ.p1.y) =
          (σ'.p2.y - σ.p1.y) * (σ.p2.x - σ.p1.x) := hσ'2
      have hpar : (σ'.p2.x - σ'.p1.x) * (σ.p2.y - σ.p1.y) =
          (σ'.p2.y - σ'.p1.y) * (σ.p2.x - σ.p1.x) := by linarith
      have := parallel_trans_of_nonzero (σ.p2.x - σ'.p1.x) (σ.p2.y - σ'.p1.y)
        (σ'.p2.x - σ'.p1.x) (σ'.p2.y - σ'.p1.y) (σ.p2.x - σ.p1.x) (σ.p2.y - σ.p1.y) hds
        (by
          -- σ.p2 ∈ lineOf σ : need (σ.p2 - σ'.p1) ∥ (σ.p2 - σ.p1)? use hσ2 and h12.
          have : (σ.p2.x - σ.p1.x) * (σ.p2.y - σ.p1.y) =
              (σ.p2.y - σ.p1.y) * (σ.p2.x - σ.p1.x) := by ring
          linarith [h12, this]) (by linarith [hpar])
      linarith [this]
  obtain ⟨hσ_on1, hσ_on2⟩ := hslsym
  -- endpoint-not-interior facts
  have hvert_not : ∀ (v : Vector2D) (τ : LineSegment), τ ∈ (arr G1 G2).segments →
      v ∈ (arr G1 G2).toVertices → v ∈ τ.toSet → v = τ.p1 ∨ v = τ.p2 := by
    intro v τ hτ hv hvon
    by_contra hcon
    push_neg at hcon
    exact arr_no_segment_interior_vertices G1 G2 v hv τ hτ (Ne.symm hcon.1) (Ne.symm hcon.2) hvon
  have hσ'1v : σ'.p1 ∈ (arr G1 G2).toVertices := ((arr G1 G2).segments_endpoints σ' hσ').1
  have hσ'2v : σ'.p2 ∈ (arr G1 G2).toVertices := ((arr G1 G2).segments_endpoints σ' hσ').2
  have hσ1v : σ.p1 ∈ (arr G1 G2).toVertices := ((arr G1 G2).segments_endpoints σ hσ).1
  have hσ2v : σ.p2 ∈ (arr G1 G2).toVertices := ((arr G1 G2).segments_endpoints σ hσ).2
  -- σ ⊆ σ' via collinear_containment (line = σ).
  have hsub1 : σ.toSet ⊆ σ'.toSet :=
    collinear_containment σ σ σ' hσ1 hσ2 hσ'1 hσ'2 hσnd hσnd x hxσ hxσ' hx1 hx2
      (fun h => hvert_not σ'.p1 σ hσ hσ'1v h)
      (fun h => hvert_not σ'.p2 σ hσ hσ'2v h)
  -- σ' ⊆ σ via collinear_containment (line = σ').
  have hsub2 : σ'.toSet ⊆ σ.toSet :=
    collinear_containment σ' σ' σ (mem_lineOf_p1 σ') (mem_lineOf_p2 σ') hσ_on1 hσ_on2 hσ'nd hσ'nd
      x hxσ' hxσ hx1' hx2'
      (fun h => hvert_not σ.p1 σ' hσ' hσ1v h)
      (fun h => hvert_not σ.p2 σ' hσ' hσ2v h)
  exact Set.Subset.antisymm hsub1 hsub2

open EvenGraphIntersectionProofs in
/-- A peeled `sharedSelected` segment passes through the crossing point `rayPt r t₀`, which is
    therefore on both `∂G1` and `∂G2`. Hence if either fails, there are no peeled shared
    segments. -/
private theorem sharedSelected_peeled_on_both (G1 G2 : EvenGraph) (r : Ray) (t₀ t' : ℚ)
    (σ : LineSegment) (hσ : σ ∈ sharedSelected G1 G2)
    (hpeel : (crossedB r σ && !(crossedPastB r t' σ)) = true)
    (hc : rayIntersectsSegment r σ)
    (hτ : rayCrossingParam r σ hc = t₀) :
    rayPt r t₀ ∈ G1.toBoundarySet ∧ rayPt r t₀ ∈ G2.toBoundarySet := by
  have hp₁_on : rayPt r t₀ ∈ σ.toSet := by
    rw [← hτ]; exact rayCrossingParam_point_mem_seg r σ hc
  -- σ ⊆ ∂(arr G1 G2) = ∂G1
  have hsub1 : σ.toSet ⊆ (arr G1 G2).toBoundarySet := sharedSelected_toSet_subset G1 G2 σ hσ
  have hG1 : rayPt r t₀ ∈ G1.toBoundarySet := by
    rw [← arr_boundary_eq G1 G2]; exact hsub1 hp₁_on
  -- σ shared w.r.t. G2 (from the filter): σ.toSet ⊆ ∂G2
  rw [sharedSelected, List.mem_filter] at hσ
  have hshared : IsShared G2 σ ∧ onInterBoundary G1 G2 σ := by
    have := hσ.2; rw [decide_eq_true_iff] at this; exact this
  exact ⟨hG1, hshared.1 hp₁_on⟩

open EvenGraphIntersectionProofs in
/-- A peeled `sharedSelected` segment is crossed exactly at parameter `t₀`. -/
private theorem peeled_shared_implies_param_eq (G1 G2 : EvenGraph) (r : Ray)
    (h1 : rayAvoidsGraphVertices r (arr G1 G2)) (h2 : rayAvoidsGraphVertices r (arr G2 G1))
    (hoff1 : r.origin ∉ G1.toBoundarySet)
    (t₀ t' : ℚ) (ht₀ : 0 ≤ t₀) (htlt : t₀ < t')
    (hmin : ∀ p ∈ paramFinset r ((arr G1 G2).segments ++ (arr G2 G1).segments), t₀ ≤ p)
    (hgap : ∀ p ∈ paramFinset r ((arr G1 G2).segments ++ (arr G2 G1).segments), t₀ < p → t' < p)
    (σ : LineSegment) (hσ : σ ∈ sharedSelected G1 G2) (hc : rayIntersectsSegment r σ)
    (hpeel : (crossedB r σ && !(crossedPastB r t' σ)) = true) :
    rayCrossingParam r σ hc = t₀ := by
  have ht'_nn : 0 ≤ t' := le_of_lt (lt_of_le_of_lt ht₀ htlt)
  set τ := rayCrossingParam r σ hc with hτdef
  have hτ_nn : 0 ≤ τ := rayCrossingParam_nonneg r σ hc
  have hτ_on : rayPt r τ ∈ σ.toSet := rayCrossingParam_point_mem_seg r σ hc
  -- σ = canonSeg σ0 for σ0 ∈ arr1; σ.toSet = σ0.toSet, so τ is a crossing param of σ0.
  rw [sharedSelected, List.mem_filter] at hσ
  obtain ⟨σ0, hσ0, hcanon⟩ := List.mem_map.mp (List.mem_dedup.mp hσ.1)
  have hσ0_on : rayPt r τ ∈ σ0.toSet := by
    rw [← canonSeg_toSet σ0, hcanon]; exact hτ_on
  have hc0 : rayIntersectsSegment r σ0 :=
    (rayIntersectsSegment_iff_exists_param r σ0).mpr ⟨τ, hτ_nn, hσ0_on⟩
  have hτ0 : τ = rayCrossingParam r σ0 hc0 :=
    arr_param_unique G1 G2 r σ0 hσ0 h1 hoff1 hc0 τ hτ_nn hσ0_on
  have hτ_mem : τ ∈ paramFinset r ((arr G1 G2).segments ++ (arr G2 G1).segments) := by
    rw [mem_paramFinset]
    exact ⟨σ0, List.mem_append_left _ hσ0, hc0, hτ0.symm⟩
  have hτ_ge : t₀ ≤ τ := hmin τ hτ_mem
  -- not past t': any param > t' isn't a crossing param ≤ τ; use peeled.
  simp only [Bool.and_eq_true, Bool.not_eq_true', crossedPastB, decide_eq_false_iff_not,
    not_exists, not_and] at hpeel
  have hnotpast := hpeel.2
  by_contra hne
  have hτgt : t₀ < τ := lt_of_le_of_ne hτ_ge (Ne.symm hne)
  have hτpast : t' < τ := hgap τ hτ_mem hτgt
  exact hnotpast τ hτpast hτ_on

open EvenGraphIntersectionProofs in
/-- Two `arr` segments (of either arrangement) sharing a ray point are collinear: otherwise the
    shared point would be a pairwise crossing in `Xlist`, which the ray avoids. -/
private theorem arr_segs_through_rayPt_sameLine (G1 G2 : EvenGraph) (r : Ray)
    (hX : ∀ x ∈ Xlist G1 G2, x ∉ r.toSet) (t₀ : ℚ) (ht₀ : 0 ≤ t₀)
    (s s' : LineSegment)
    (hs : s ∈ (arr G1 G2).segments ∨ s ∈ (arr G2 G1).segments)
    (hs' : s' ∈ (arr G1 G2).segments ∨ s' ∈ (arr G2 G1).segments)
    (hon : rayPt r t₀ ∈ s.toSet) (hon' : rayPt r t₀ ∈ s'.toSet) :
    SameLine s s' := by
  by_contra hsl
  have hp₁_r : rayPt r t₀ ∈ r.toSet := rayPt_mem_ray r t₀ ht₀
  apply hX (rayPt r t₀) ((mem_Xlist_iff G1 G2 _).mpr ?_) hp₁_r
  refine ⟨s, ?_, s', ?_, hsl, hon, hon'⟩
  · rcases hs with h | h
    · exact List.mem_append_left _ h
    · exact List.mem_append_right _ h
  · rcases hs' with h | h
    · exact List.mem_append_left _ h
    · exact List.mem_append_right _ h

open EvenGraphIntersectionProofs in
/-- Two peeled `sharedSelected` segments are equal: both pass through the single crossing point
    `rayPt r t₀` in their interior, are collinear (by `hX`) and within `arr G1 G2` collinear
    segments through a common interior point coincide. -/
private theorem peeled_shared_eq (G1 G2 : EvenGraph) (r : Ray)
    (h1 : rayAvoidsGraphVertices r (arr G1 G2)) (h2 : rayAvoidsGraphVertices r (arr G2 G1))
    (hX : ∀ x ∈ Xlist G1 G2, x ∉ r.toSet)
    (hoff1 : r.origin ∉ G1.toBoundarySet)
    (t₀ t' : ℚ) (ht₀ : 0 ≤ t₀) (htlt : t₀ < t')
    (hmin : ∀ p ∈ paramFinset r ((arr G1 G2).segments ++ (arr G2 G1).segments), t₀ ≤ p)
    (hgap : ∀ p ∈ paramFinset r ((arr G1 G2).segments ++ (arr G2 G1).segments), t₀ < p → t' < p)
    (σ σ' : LineSegment) (hσ : σ ∈ sharedSelected G1 G2) (hσ' : σ' ∈ sharedSelected G1 G2)
    (hpσ : (crossedB r σ && !(crossedPastB r t' σ)) = true)
    (hpσ' : (crossedB r σ' && !(crossedPastB r t' σ')) = true) :
    σ = σ' := by
  -- crossing facts
  have hcσ : rayIntersectsSegment r σ := by
    simp only [Bool.and_eq_true, crossedB, decide_eq_true_eq] at hpσ; exact hpσ.1
  have hcσ' : rayIntersectsSegment r σ' := by
    simp only [Bool.and_eq_true, crossedB, decide_eq_true_eq] at hpσ'; exact hpσ'.1
  have hτσ : rayCrossingParam r σ hcσ = t₀ :=
    peeled_shared_implies_param_eq G1 G2 r h1 h2 hoff1 t₀ t' ht₀ htlt hmin hgap σ hσ hcσ hpσ
  have hτσ' : rayCrossingParam r σ' hcσ' = t₀ :=
    peeled_shared_implies_param_eq G1 G2 r h1 h2 hoff1 t₀ t' ht₀ htlt hmin hgap σ' hσ' hcσ' hpσ'
  have honσ : rayPt r t₀ ∈ σ.toSet := by rw [← hτσ]; exact rayCrossingParam_point_mem_seg r σ hcσ
  have honσ' : rayPt r t₀ ∈ σ'.toSet := by
    rw [← hτσ']; exact rayCrossingParam_point_mem_seg r σ' hcσ'
  -- underlying arr1 segments
  rw [sharedSelected, List.mem_filter] at hσ hσ'
  obtain ⟨σ0, hσ0, hcanon0⟩ := List.mem_map.mp (List.mem_dedup.mp hσ.1)
  obtain ⟨σ0', hσ0', hcanon0'⟩ := List.mem_map.mp (List.mem_dedup.mp hσ'.1)
  -- p₁ on σ0, σ0', not at endpoints (interior)
  have honσ0 : rayPt r t₀ ∈ σ0.toSet := by rw [← canonSeg_toSet σ0, hcanon0]; exact honσ
  have honσ0' : rayPt r t₀ ∈ σ0'.toSet := by rw [← canonSeg_toSet σ0', hcanon0']; exact honσ'
  -- interior: rayPt r t₀ ≠ endpoints of σ0, σ0' (they are arr1 vertices on ray, excluded)
  have hne : ∀ τ : LineSegment, τ ∈ (arr G1 G2).segments → rayPt r t₀ ∈ τ.toSet →
      rayPt r t₀ ≠ τ.p1 ∧ rayPt r t₀ ≠ τ.p2 := by
    intro τ hτ _
    constructor <;> intro heq
    · have : τ.p1 ∈ r.toSet ∩ (arr G1 G2).toVertexSet :=
        ⟨heq ▸ rayPt_mem_ray r t₀ ht₀, ((arr G1 G2).segments_endpoints τ hτ).1⟩
      rw [h1] at this; exact this
    · have : τ.p2 ∈ r.toSet ∩ (arr G1 G2).toVertexSet :=
        ⟨heq ▸ rayPt_mem_ray r t₀ ht₀, ((arr G1 G2).segments_endpoints τ hτ).2⟩
      rw [h1] at this; exact this
  obtain ⟨hne01, hne02⟩ := hne σ0 hσ0 honσ0
  obtain ⟨hne01', hne02'⟩ := hne σ0' hσ0' honσ0'
  -- SameLine σ0 σ0'
  have hsl : SameLine σ0 σ0' :=
    arr_segs_through_rayPt_sameLine G1 G2 r hX t₀ ht₀ σ0 σ0' (Or.inl hσ0) (Or.inl hσ0')
      honσ0 honσ0'
  -- equal toSet ⟹ equal canonSeg
  have htoSet : σ0.toSet = σ0'.toSet :=
    arr_collinear_toSet_eq G1 G2 σ0 σ0' hσ0 hσ0' hsl (rayPt r t₀) honσ0 hne01 hne02
      honσ0' hne01' hne02'
  -- canonSeg depends only on toSet (for nondeg segs): equal toSet ⟹ equal canonSeg.
  have : canonSeg σ0 = canonSeg σ0' := canonSeg_eq_of_toSet_eq σ0 σ0'
    ((arr G1 G2).segments_nondegenerate σ0 hσ0)
    ((arr G1 G2).segments_nondegenerate σ0' hσ0') htoSet
  rw [← hcanon0, ← hcanon0', this]

/-! ### Well-definedness of `onInterBoundary`: `onInterBoundary_iff_flip` -/

/-- For propositions, `P ↔ ¬Q` is the same as `P ≠ Q`. -/
private theorem iff_not_eq_ne (P Q : Prop) : (P ↔ ¬ Q) ↔ (P ≠ Q) := by
  by_cases hQ : Q <;> by_cases hP : P <;>
    simp_all [hP, hQ, ne_eq, eq_iff_iff]

/-- Reversing a segment's endpoints preserves its point set. -/
theorem lineSegment_toSet_comm (u v : Vector2D) :
    (LineSegment.mk u v).toSet = (LineSegment.mk v u).toSet := by
  ext p
  simp only [LineSegment.toSet, Set.mem_setOf_eq]
  constructor
  · rintro ⟨t, h0, h1, hx, hy⟩
    exact ⟨1 - t, by linarith, by linarith, by rw [hx]; ring, by rw [hy]; ring⟩
  · rintro ⟨t, h0, h1, hx, hy⟩
    exact ⟨1 - t, by linarith, by linarith, by rw [hx]; ring, by rw [hy]; ring⟩

/-- The endpoints of `canonSeg σ` are exactly the endpoints of `σ` (possibly swapped); hence a
    point distinct from both endpoints of `σ` is distinct from both endpoints of `canonSeg σ`. -/
theorem canonSeg_ne_endpoints (σ : LineSegment) (c : Vector2D)
    (hc1 : c ≠ σ.p1) (hc2 : c ≠ σ.p2) :
    c ≠ (canonSeg σ).p1 ∧ c ≠ (canonSeg σ).p2 := by
  unfold canonSeg
  split
  · exact ⟨hc1, hc2⟩
  · exact ⟨hc2, hc1⟩

/-- Local constancy of the `A ∩ B` indicator across a clean path: if `u, v` and every point of
    `⟨u,v⟩` avoid both boundaries, then `u` and `v` agree on being in `A ∩ B`. -/
private theorem flip_eq_of_clean_path (G1 G2 : EvenGraph) (u v : Vector2D)
    (hu1 : u ∉ G1.toBoundarySet) (hu2 : u ∉ G2.toBoundarySet)
    (hv1 : v ∉ G1.toBoundarySet) (hv2 : v ∉ G2.toBoundarySet)
    (hpath : ∀ x ∈ (LineSegment.mk u v).toSet, x ∉ G1.toBoundarySet ∧ x ∉ G2.toBoundarySet) :
    (u ∈ G1.interior ∧ u ∈ G2.interior) = (v ∈ G1.interior ∧ v ∈ G2.interior) := by
  -- u ∈ G1.interior ↔ v ∈ G1.interior, via interior_via_segment_gen for `arr G1 G2`.
  have hAvb1 := arr_boundary_eq G1 G2
  have hAvi1 := arr_interior_eq G1 G2
  have hAvb2 := arr_boundary_eq G2 G1
  have hAvi2 := arr_interior_eq G2 G1
  have hsegUV : ∀ x ∈ (LineSegment.mk u v).toSet, x ∉ G1.toBoundarySet :=
    fun x hx => (hpath x hx).1
  have hsegVU : ∀ x ∈ (LineSegment.mk v u).toSet, x ∉ G1.toBoundarySet := by
    rw [← lineSegment_toSet_comm]; exact hsegUV
  have hsegUV2 : ∀ x ∈ (LineSegment.mk u v).toSet, x ∉ G2.toBoundarySet :=
    fun x hx => (hpath x hx).2
  have hsegVU2 : ∀ x ∈ (LineSegment.mk v u).toSet, x ∉ G2.toBoundarySet := by
    rw [← lineSegment_toSet_comm]; exact hsegUV2
  -- A-side equivalence
  have hA : u ∈ G1.interior ↔ v ∈ G1.interior := by
    constructor
    · intro hu
      have hu' : u ∈ (arr G1 G2).interior := by rw [hAvi1]; exact hu
      have hv' : v ∉ (arr G1 G2).toBoundarySet := by rw [hAvb1]; exact hv1
      have hpath' : ∀ x ∈ (LineSegment.mk u v).toSet, x ∉ (arr G1 G2).toBoundarySet := by
        intro x hx; rw [hAvb1]; exact hsegUV x hx
      have := interior_via_segment_gen (arr G1 G2) u v hu' hv' hpath'
      rw [hAvi1] at this; exact this
    · intro hv
      have hv' : v ∈ (arr G1 G2).interior := by rw [hAvi1]; exact hv
      have hu' : u ∉ (arr G1 G2).toBoundarySet := by rw [hAvb1]; exact hu1
      have hpath' : ∀ x ∈ (LineSegment.mk v u).toSet, x ∉ (arr G1 G2).toBoundarySet := by
        intro x hx; rw [hAvb1]; exact hsegVU x hx
      have := interior_via_segment_gen (arr G1 G2) v u hv' hu' hpath'
      rw [hAvi1] at this; exact this
  -- B-side equivalence
  have hB : u ∈ G2.interior ↔ v ∈ G2.interior := by
    constructor
    · intro hu
      have hu' : u ∈ (arr G2 G1).interior := by rw [hAvi2]; exact hu
      have hv' : v ∉ (arr G2 G1).toBoundarySet := by rw [hAvb2]; exact hv2
      have hpath' : ∀ x ∈ (LineSegment.mk u v).toSet, x ∉ (arr G2 G1).toBoundarySet := by
        intro x hx; rw [hAvb2]; exact hsegUV2 x hx
      have := interior_via_segment_gen (arr G2 G1) u v hu' hv' hpath'
      rw [hAvi2] at this; exact this
    · intro hv
      have hv' : v ∈ (arr G2 G1).interior := by rw [hAvi2]; exact hv
      have hu' : u ∉ (arr G2 G1).toBoundarySet := by rw [hAvb2]; exact hu2
      have hpath' : ∀ x ∈ (LineSegment.mk v u).toSet, x ∉ (arr G2 G1).toBoundarySet := by
        intro x hx; rw [hAvb2]; exact hsegVU2 x hx
      have := interior_via_segment_gen (arr G2 G1) v u hv' hu' hpath'
      rw [hAvi2] at this; exact this
  rw [eq_iff_iff]
  exact and_congr hA hB

/-! ### Side-of-line algebra for `flip_well_defined` -/

/-- Signed area / cross-product test placing a point `z` relative to the directed line of `σ`.
    `z ∈ lineOf σ ↔ sideOf σ z = 0`. -/
def sideOf (σ : LineSegment) (z : Vector2D) : ℚ :=
  (σ.p2.x - σ.p1.x) * (z.y - σ.p1.y) - (σ.p2.y - σ.p1.y) * (z.x - σ.p1.x)

/-- `sideOf σ z = 0` iff `z` is on `lineOf σ`. -/
theorem sideOf_eq_zero_iff (σ : LineSegment) (z : Vector2D) :
    sideOf σ z = 0 ↔ z ∈ lineOf σ := by
  simp only [sideOf, lineOf, Set.mem_setOf_eq]
  constructor <;> intro h <;> linarith

/-- `sideOf` is affine along a convex combination of two points. -/
theorem sideOf_affine (σ : LineSegment) (u v : Vector2D) (w : ℚ) (z : Vector2D)
    (hx : z.x = (1 - w) * u.x + w * v.x) (hy : z.y = (1 - w) * u.y + w * v.y) :
    sideOf σ z = (1 - w) * sideOf σ u + w * sideOf σ v := by
  simp only [sideOf]
  rw [hx, hy]; ring

/-- A segment `s` that is `SameLine σ` lies entirely on `lineOf σ`. -/
theorem sameLine_toSet_subset_lineOf (σ s : LineSegment) (hsl : SameLine σ s) :
    s.toSet ⊆ lineOf σ := by
  intro z hz
  obtain ⟨t, _, _, hzx, hzy⟩ := hz
  rw [← sideOf_eq_zero_iff]
  obtain ⟨hs1, hs2⟩ := hsl
  rw [← sideOf_eq_zero_iff] at hs1 hs2
  have := sideOf_affine σ s.p1 s.p2 t z hzx hzy
  rw [this, hs1, hs2]; ring

/-- The list of `(graphRefinementSelf G1) ++ G2` segments that are **not** collinear with `σ0`. -/
def Lnc (G1 G2 : EvenGraph) (σ0 : LineSegment) : List LineSegment :=
  ((graphRefinementSelf G1).segments ++ G2.segments).filter
    (fun s => decide (¬ SameLine σ0 s))

theorem mem_Lnc_iff (G1 G2 : EvenGraph) (σ0 s : LineSegment) :
    s ∈ Lnc G1 G2 σ0 ↔
      (s ∈ (graphRefinementSelf G1).segments ++ G2.segments ∧ ¬ SameLine σ0 s) := by
  simp only [Lnc, List.mem_filter, decide_eq_true_eq]

/-- Every segment in `Lnc` is non-degenerate. -/
theorem Lnc_nondeg (G1 G2 : EvenGraph) (σ0 : LineSegment) :
    ∀ s ∈ Lnc G1 G2 σ0, s.p1 ≠ s.p2 := by
  intro s hs
  rw [mem_Lnc_iff] at hs
  rcases List.mem_append.mp hs.1 with h | h
  · exact (graphRefinementSelf G1).segments_nondegenerate s h
  · exact G2.segments_nondegenerate s h

/-- **Boundary coverage.** A point off `lineOf σ0` and off every `Lnc` segment is off both
    boundaries `∂G1` and `∂G2`. (Because `∂G1 = ⋃ (graphRefinementSelf G1).segments` and
    `∂G2 = ⋃ G2.segments`, and every such segment is either collinear with `σ0` — hence on
    `lineOf σ0` — or in `Lnc`.) -/
private theorem off_boundaries_of_off_line_and_Lnc (G1 G2 : EvenGraph) (σ0 : LineSegment)
    (z : Vector2D) (hline : z ∉ lineOf σ0) (hLnc : ∀ s ∈ Lnc G1 G2 σ0, z ∉ s.toSet) :
    z ∉ G1.toBoundarySet ∧ z ∉ G2.toBoundarySet := by
  -- common argument for either segment list
  have key : ∀ s ∈ (graphRefinementSelf G1).segments ++ G2.segments, z ∉ s.toSet := by
    intro s hs hzs
    by_cases hsl : SameLine σ0 s
    · exact hline (sameLine_toSet_subset_lineOf σ0 s hsl hzs)
    · exact hLnc s ((mem_Lnc_iff G1 G2 σ0 s).mpr ⟨hs, hsl⟩) hzs
  constructor
  · -- ∂G1 = (graphRefinementSelf G1).toBoundarySet
    intro hz
    rw [← graphRefinementSelf_boundary_eq G1] at hz
    obtain ⟨s, hs, hzs⟩ := hz
    exact key s (List.mem_append_left _ hs) hzs
  · intro hz
    obtain ⟨s, hs, hzs⟩ := hz
    exact key s (List.mem_append_right _ hs) hzs

/-- Projection of `z` onto the direction of nondegenerate `σ0`. `σ0.p1 ↦ 0`, `σ0.p2 ↦ D`. -/
private def projOf (σ0 : LineSegment) (z : Vector2D) : ℚ :=
  (z.x - σ0.p1.x) * (σ0.p2.x - σ0.p1.x) + (z.y - σ0.p1.y) * (σ0.p2.y - σ0.p1.y)

/-- `D := |σ0.p2 - σ0.p1|² > 0` for nondegenerate `σ0`. -/
private theorem projOf_D_pos (σ0 : LineSegment) (hnd : σ0.p1 ≠ σ0.p2) :
    0 < (σ0.p2.x - σ0.p1.x) * (σ0.p2.x - σ0.p1.x)
        + (σ0.p2.y - σ0.p1.y) * (σ0.p2.y - σ0.p1.y) := by
  have hdxy : σ0.p2.x - σ0.p1.x ≠ 0 ∨ σ0.p2.y - σ0.p1.y ≠ 0 := by
    by_contra h; push_neg at h
    exact hnd (Vector2D.ext (by have := h.1; linarith) (by have := h.2; linarith))
  rcases hdxy with h | h
  · have := mul_self_pos.mpr h; have := mul_self_nonneg (σ0.p2.y - σ0.p1.y); linarith
  · have := mul_self_pos.mpr h; have := mul_self_nonneg (σ0.p2.x - σ0.p1.x); linarith

/-- `projOf` is injective on `lineOf σ0` (for nondegenerate `σ0`). -/
private theorem projOf_inj (σ0 : LineSegment) (hnd : σ0.p1 ≠ σ0.p2)
    (p q : Vector2D) (hp : p ∈ lineOf σ0) (hq : q ∈ lineOf σ0)
    (hpq : projOf σ0 p = projOf σ0 q) : p = q := by
  set dx := σ0.p2.x - σ0.p1.x
  set dy := σ0.p2.y - σ0.p1.y
  simp only [lineOf, Set.mem_setOf_eq] at hp hq
  simp only [projOf] at hpq
  have hD := projOf_D_pos σ0 hnd
  have hpar : (p.x - q.x) * dy = (p.y - q.y) * dx := by linear_combination hp - hq
  have hproj : (p.x - q.x) * dx + (p.y - q.y) * dy = 0 := by linear_combination hpq
  have hu : (p.x - q.x) * (dx * dx + dy * dy) = 0 := by linear_combination dx * hproj + dy * hpar
  have hv : (p.y - q.y) * (dx * dx + dy * dy) = 0 := by linear_combination dy * hproj - dx * hpar
  have hux : p.x - q.x = 0 := by
    rcases mul_eq_zero.mp hu with h | h
    · exact h
    · exact absurd h (ne_of_gt hD)
  have hvy : p.y - q.y = 0 := by
    rcases mul_eq_zero.mp hv with h | h
    · exact h
    · exact absurd h (ne_of_gt hD)
  exact Vector2D.ext (by linarith) (by linarith)

/-- `projOf` of a convex combination is the convex combination of `projOf`s. -/
private theorem projOf_affine (σ0 : LineSegment) (u v : Vector2D) (w : ℚ) (z : Vector2D)
    (hx : z.x = (1 - w) * u.x + w * v.x) (hy : z.y = (1 - w) * u.y + w * v.y) :
    projOf σ0 z = (1 - w) * projOf σ0 u + w * projOf σ0 v := by
  simp only [projOf]; rw [hx, hy]; ring

/-- For `z ∈ lineOf σ0`, membership in `σ0.toSet` is `0 ≤ projOf σ0 z ≤ D`. (One direction.) -/
private theorem mem_seg_of_proj_mem (σ0 : LineSegment) (hnd : σ0.p1 ≠ σ0.p2) (z : Vector2D)
    (hz : z ∈ lineOf σ0)
    (hlo : 0 ≤ projOf σ0 z)
    (hhi : projOf σ0 z ≤ (σ0.p2.x - σ0.p1.x) * (σ0.p2.x - σ0.p1.x)
        + (σ0.p2.y - σ0.p1.y) * (σ0.p2.y - σ0.p1.y)) :
    z ∈ σ0.toSet := by
  set dx := σ0.p2.x - σ0.p1.x with hdx_def
  set dy := σ0.p2.y - σ0.p1.y with hdy_def
  have hD : 0 < dx * dx + dy * dy := projOf_D_pos σ0 hnd
  have hDne : dx * dx + dy * dy ≠ 0 := ne_of_gt hD
  -- abbreviations
  set u := z.x - σ0.p1.x with hu_def
  set v := z.y - σ0.p1.y with hv_def
  have hpt : u * dy = v * dx := hz
  have hproj : projOf σ0 z = u * dx + v * dy := rfl
  set r := projOf σ0 z / (dx * dx + dy * dy) with hr_def
  have hzc : projOf σ0 z = r * (dx * dx + dy * dy) := by
    rw [hr_def]; field_simp
  have hpr : u * dx + v * dy = r * (dx * dx + dy * dy) := by rw [← hproj]; exact hzc
  -- u = r*dx and v = r*dy via cancellation
  have hux : u * (dx * dx + dy * dy) = (r * dx) * (dx * dx + dy * dy) := by
    have e1 : u * (dx * dx + dy * dy) = dx * (u * dx + v * dy) := by
      linear_combination dy * hpt
    rw [e1, hpr]; ring
  have hvy : v * (dx * dx + dy * dy) = (r * dy) * (dx * dx + dy * dy) := by
    have e1 : v * (dx * dx + dy * dy) = dy * (u * dx + v * dy) := by
      linear_combination (-dx) * hpt
    rw [e1, hpr]; ring
  have hxeq : u = r * dx := mul_right_cancel₀ hDne hux
  have hyeq : v = r * dy := mul_right_cancel₀ hDne hvy
  refine ⟨r, ?_, ?_, ?_, ?_⟩
  · exact div_nonneg hlo (le_of_lt hD)
  · rw [hr_def, div_le_one hD]; exact hhi
  · show z.x = (1 - r) * σ0.p1.x + r * σ0.p2.x
    have : z.x - σ0.p1.x = r * (σ0.p2.x - σ0.p1.x) := hxeq
    linarith [this]
  · show z.y = (1 - r) * σ0.p1.y + r * σ0.p2.y
    have : z.y - σ0.p1.y = r * (σ0.p2.y - σ0.p1.y) := hyeq
    linarith [this]

/-- For `z ∈ σ0.toSet`, `0 ≤ projOf σ0 z ≤ D`. Moreover if `z ≠ σ0.p1` and `z ≠ σ0.p2` then
    the bounds are strict. -/
private theorem proj_mem_of_mem_seg (σ0 : LineSegment) (hnd : σ0.p1 ≠ σ0.p2) (z : Vector2D)
    (hz : z ∈ σ0.toSet) (hz1 : z ≠ σ0.p1) (hz2 : z ≠ σ0.p2) :
    0 < projOf σ0 z ∧ projOf σ0 z < (σ0.p2.x - σ0.p1.x) * (σ0.p2.x - σ0.p1.x)
        + (σ0.p2.y - σ0.p1.y) * (σ0.p2.y - σ0.p1.y) := by
  obtain ⟨r, hr0, hr1, hzx, hzy⟩ := hz
  have hD := projOf_D_pos σ0 hnd
  set D := (σ0.p2.x - σ0.p1.x) * (σ0.p2.x - σ0.p1.x)
      + (σ0.p2.y - σ0.p1.y) * (σ0.p2.y - σ0.p1.y) with hD_def
  have hproj : projOf σ0 z = r * D := by
    simp only [projOf]; rw [hzx, hzy, hD_def]; ring
  -- r ≠ 0 (else z = σ0.p1) and r ≠ 1 (else z = σ0.p2)
  have hr0' : r ≠ 0 := by
    intro h; apply hz1; rw [h] at hzx hzy
    exact Vector2D.ext (by rw [hzx]; ring) (by rw [hzy]; ring)
  have hr1' : r ≠ 1 := by
    intro h; apply hz2; rw [h] at hzx hzy
    exact Vector2D.ext (by rw [hzx]; ring) (by rw [hzy]; ring)
  have hrpos : 0 < r := lt_of_le_of_ne hr0 (Ne.symm hr0')
  have hrlt : r < 1 := lt_of_le_of_ne hr1 hr1'
  rw [hproj]
  exact ⟨mul_pos hrpos hD, by nlinarith [hD, hrlt]⟩

/-- **Open-interior neighbour on the line.** If `c` is in the open interior of `σ0` and `a` is a
    distinct point of `lineOf σ0`, then there is a point `x ∈ ⟨a,c⟩`, `x ≠ c`, that still lies
    in `σ0.toSet`. -/
private theorem exists_neighbor_in_seg (σ0 : LineSegment) (hnd : σ0.p1 ≠ σ0.p2)
    (c : Vector2D) (hc : c ∈ σ0.toSet) (hc1 : c ≠ σ0.p1) (hc2 : c ≠ σ0.p2)
    (a : Vector2D) (ha : a ∈ lineOf σ0) (hac : a ≠ c) :
    ∃ x ∈ (LineSegment.mk a c).toSet, x ≠ c ∧ x ∈ σ0.toSet := by
  have hD := projOf_D_pos σ0 hnd
  set D := (σ0.p2.x - σ0.p1.x) * (σ0.p2.x - σ0.p1.x)
      + (σ0.p2.y - σ0.p1.y) * (σ0.p2.y - σ0.p1.y) with hD_def
  obtain ⟨hcpos, hclt⟩ := proj_mem_of_mem_seg σ0 hnd c hc hc1 hc2
  have hcline : c ∈ lineOf σ0 := toSet_subset_lineOf σ0 hc
  -- projOf a ≠ projOf c since a ≠ c and both on line.
  have hproj_ne : projOf σ0 a ≠ projOf σ0 c := by
    intro h; exact hac (projOf_inj σ0 hnd a c ha hcline h)
  set pa := projOf σ0 a with hpa
  set pc := projOf σ0 c with hpc
  -- choose ε and λ
  set ε : ℚ := min pc (D - pc) with hε_def
  have hεpos : 0 < ε := lt_min hcpos (by linarith)
  set δ : ℚ := |pa - pc| with hδ_def
  have hδpos : 0 < δ := abs_pos.mpr (sub_ne_zero.mpr hproj_ne)
  -- λ := min (1/2) (ε / (2*δ))
  set lam : ℚ := min (1/2) (ε / (2 * δ)) with hlam_def
  have hlampos : 0 < lam := lt_min (by norm_num) (by positivity)
  have hlamle : lam ≤ 1/2 := min_le_left _ _
  have hlamle2 : lam ≤ ε / (2 * δ) := min_le_right _ _
  -- x := (1-lam)*c + lam*a  [convex comb on ⟨c,a⟩, equiv ⟨a,c⟩]
  set x : Vector2D := ⟨(1 - lam) * c.x + lam * a.x, (1 - lam) * c.y + lam * a.y⟩ with hx_def
  -- x ∈ ⟨a,c⟩
  have hx_mem_seg : x ∈ (LineSegment.mk a c).toSet := by
    refine ⟨1 - lam, by linarith, by linarith, ?_, ?_⟩
    · show (1 - lam) * c.x + lam * a.x = (1 - (1 - lam)) * a.x + (1 - lam) * c.x; ring
    · show (1 - lam) * c.y + lam * a.y = (1 - (1 - lam)) * a.y + (1 - lam) * c.y; ring
  -- x ∈ lineOf σ0
  have hxline : x ∈ lineOf σ0 := by
    rw [← sideOf_eq_zero_iff]
    rw [← sideOf_eq_zero_iff] at ha hcline
    have := sideOf_affine σ0 c a lam x (by rw [hx_def]) (by rw [hx_def])
    rw [this, ha, hcline]; ring
  -- projOf x = (1-lam)*pc + lam*pa
  have hpx : projOf σ0 x = (1 - lam) * pc + lam * pa := by
    rw [hpa, hpc]; exact projOf_affine σ0 c a lam x (by rw [hx_def]) (by rw [hx_def])
  -- bound: |projOf x - pc| = lam*|pa-pc| = lam*δ ≤ ε/2 < ε
  have hdiff : projOf σ0 x - pc = lam * (pa - pc) := by rw [hpx]; ring
  have habs : |projOf σ0 x - pc| = lam * δ := by
    rw [hdiff, hδ_def, abs_mul, abs_of_pos hlampos]
  have hbound : lam * δ < ε := by
    have : lam * δ ≤ (ε / (2 * δ)) * δ :=
      mul_le_mul_of_nonneg_right hlamle2 (le_of_lt hδpos)
    have heq : (ε / (2 * δ)) * δ = ε / 2 := by field_simp; ring
    rw [heq] at this; linarith
  have habslt : |projOf σ0 x - pc| < ε := by rw [habs]; exact hbound
  -- so projOf x ∈ (0, D)
  have hxabs := abs_lt.mp habslt
  have hxlo : 0 < projOf σ0 x := by
    have : pc - ε ≤ pc - 0 := by
      have := min_le_left pc (D - pc); rw [← hε_def] at this; linarith
    -- pc - ε ≥ 0 since ε ≤ pc
    have hεle : ε ≤ pc := min_le_left _ _
    linarith [hxabs.1]
  have hxhi : projOf σ0 x < D := by
    have hεle : ε ≤ D - pc := min_le_right _ _
    linarith [hxabs.2]
  -- x ∈ σ0.toSet
  have hxseg : x ∈ σ0.toSet :=
    mem_seg_of_proj_mem σ0 hnd x hxline (le_of_lt hxlo) (le_of_lt hxhi)
  -- x ≠ c
  have hxne : x ≠ c := by
    intro h
    have heq0 : projOf σ0 x = pc := by rw [h]
    have hz0 : lam * (pa - pc) = 0 := by linarith [hdiff, heq0]
    rcases mul_eq_zero.mp hz0 with hh | hh
    · exact (ne_of_gt hlampos) hh
    · exact hproj_ne (by linarith [hh])
  exact ⟨x, hx_mem_seg, hxne, hxseg⟩

open EvenGraphIntersectionProofs in
/-- An endpoint `a` of a clean transversal `(a,b,c)` through the open interior of `σ0`
    (with `σ0.toSet ⊆ ∂G1`) is **off** `lineOf σ0`. -/
private theorem endpoint_off_line (G1 G2 : EvenGraph) (σ0 : LineSegment)
    (hnd : σ0.p1 ≠ σ0.p2) (hsub : σ0.toSet ⊆ G1.toBoundarySet)
    (a b c : Vector2D)
    (ha1 : a ∉ G1.toBoundarySet)
    (hc : c ∈ σ0.toSet) (hc1 : c ≠ σ0.p1) (hc2 : c ≠ σ0.p2)
    (hcab : c ∈ (LineSegment.mk a b).toSet)
    (hclean : ∀ x ∈ (LineSegment.mk a b).toSet,
        (x ∈ G1.toBoundarySet ∨ x ∈ G2.toBoundarySet) → x = c) :
    a ∉ lineOf σ0 := by
  intro ha
  -- a ≠ c: c is on ∂G1 but a is not.
  have hac : a ≠ c := by
    intro h; exact ha1 (h ▸ hsub hc)
  -- neighbour x of c along ⟨a,c⟩, in σ0, ≠ c
  obtain ⟨x, hx_ac, hxne, hxseg⟩ := exists_neighbor_in_seg σ0 hnd c hc hc1 hc2 a ha hac
  -- ⟨a,c⟩ ⊆ ⟨a,b⟩
  have ha_mem : a ∈ (LineSegment.mk a b).toSet := ⟨0, le_refl _, zero_le_one, by ring, by ring⟩
  have hx_ab : x ∈ (LineSegment.mk a b).toSet :=
    segment_pq_subset_refined_seg (LineSegment.mk a b) a c ha_mem hcab x hx_ac
  -- x ∈ ∂G1, so by cleanness x = c, contradiction with x ≠ c
  exact hxne (hclean x hx_ab (Or.inl (hsub hxseg)))

/-- The two endpoints of a clean transversal lie on strictly **opposite** sides of `lineOf σ0`:
    `sideOf σ0 a * sideOf σ0 b < 0`. -/
private theorem clean_transversal_opposite_sides (G1 G2 : EvenGraph) (σ0 : LineSegment)
    (hnd : σ0.p1 ≠ σ0.p2) (hsub : σ0.toSet ⊆ G1.toBoundarySet)
    (a b c : Vector2D)
    (ha1 : a ∉ G1.toBoundarySet) (hb1 : b ∉ G1.toBoundarySet)
    (hc : c ∈ σ0.toSet) (hc1 : c ≠ σ0.p1) (hc2 : c ≠ σ0.p2)
    (hcab : c ∈ (LineSegment.mk a b).toSet)
    (hclean : ∀ x ∈ (LineSegment.mk a b).toSet,
        (x ∈ G1.toBoundarySet ∨ x ∈ G2.toBoundarySet) → x = c) :
    sideOf σ0 a * sideOf σ0 b < 0 := by
  -- both a, b off the line
  have haoff : a ∉ lineOf σ0 :=
    endpoint_off_line G1 G2 σ0 hnd hsub a b c ha1 hc hc1 hc2 hcab hclean
  -- symmetric clean for b: rewrite ⟨a,b⟩ as ⟨b,a⟩
  have hcba : c ∈ (LineSegment.mk b a).toSet := by rw [← lineSegment_toSet_comm]; exact hcab
  have hclean' : ∀ x ∈ (LineSegment.mk b a).toSet,
      (x ∈ G1.toBoundarySet ∨ x ∈ G2.toBoundarySet) → x = c := by
    intro x hx; rw [← lineSegment_toSet_comm] at hx; exact hclean x hx
  have hboff : b ∉ lineOf σ0 :=
    endpoint_off_line G1 G2 σ0 hnd hsub b a c hb1 hc hc1 hc2 hcba hclean'
  -- sa, sb ≠ 0
  have hsa : sideOf σ0 a ≠ 0 := fun h => haoff ((sideOf_eq_zero_iff σ0 a).mp h)
  have hsb : sideOf σ0 b ≠ 0 := fun h => hboff ((sideOf_eq_zero_iff σ0 b).mp h)
  -- c = (1-w) a + w b with w ∈ (0,1); sideOf σ0 c = 0
  obtain ⟨w, hw0, hw1, hcx, hcy⟩ := hcab
  have hsc0 : sideOf σ0 c = 0 := (sideOf_eq_zero_iff σ0 c).mpr (toSet_subset_lineOf σ0 hc)
  have haff := sideOf_affine σ0 a b w c hcx hcy
  rw [hsc0] at haff
  -- w ≠ 0 (else c = a, but a off line, c on line); w ≠ 1 (else c = b)
  have hw0' : w ≠ 0 := by
    intro h; apply hsa
    -- c = a when w = 0
    rw [h] at hcx hcy
    have : c = a := Vector2D.ext (by rw [hcx]; ring) (by rw [hcy]; ring)
    rw [← this]; exact hsc0
  have hw1' : w ≠ 1 := by
    intro h; apply hsb
    rw [h] at hcx hcy
    have : c = b := Vector2D.ext (by rw [hcx]; ring) (by rw [hcy]; ring)
    rw [← this]; exact hsc0
  have hwpos : 0 < w := lt_of_le_of_ne hw0 (Ne.symm hw0')
  have hwlt : w < 1 := lt_of_le_of_ne hw1 hw1'
  -- 0 = (1-w) sa + w sb, with (1-w),w > 0 ⟹ sa, sb opposite signs.
  set sa := sideOf σ0 a
  set sb := sideOf σ0 b
  -- haff : 0 = (1 - w) * sa + w * sb
  have hkey : (1 - w) * sa + w * sb = 0 := by linarith [haff]
  -- show sa * sb < 0
  rcases lt_trichotomy sa 0 with hsan | hsaz | hsap
  · -- sa < 0 ⟹ w*sb = -(1-w)*sa > 0 ⟹ sb > 0
    have hwsb_pos : 0 < w * sb := by
      have := mul_pos (by linarith : (0:ℚ) < 1 - w) (neg_pos.mpr hsan)
      nlinarith [hkey]
    have hsb_pos : 0 < sb := by
      by_contra hc'; push_neg at hc'; nlinarith [mul_nonpos_of_nonneg_of_nonpos (le_of_lt hwpos) hc']
    nlinarith [hsan, hsb_pos]
  · exact absurd hsaz hsa
  · have hwsb_neg : w * sb < 0 := by
      have := mul_pos (by linarith : (0:ℚ) < 1 - w) hsap
      nlinarith [hkey]
    have hsb_neg : sb < 0 := by
      by_contra hc'; push_neg at hc'; nlinarith [mul_nonneg (le_of_lt hwpos) hc']
    nlinarith [hsap, hsb_neg]

/-- If both endpoints of `⟨u,v⟩` are strictly on the same side of `lineOf σ0` (`sideOf` has the
    same sign, here both nonzero with product positive) then **no** point of `⟨u,v⟩` is on
    `lineOf σ0`. -/
private theorem off_line_of_same_side (σ0 : LineSegment) (u v : Vector2D)
    (hsign : 0 < sideOf σ0 u * sideOf σ0 v) :
    ∀ x ∈ (LineSegment.mk u v).toSet, x ∉ lineOf σ0 := by
  intro x hx hxl
  obtain ⟨w, hw0, hw1, hxx, hxy⟩ := hx
  have haff := sideOf_affine σ0 u v w x hxx hxy
  rw [← sideOf_eq_zero_iff] at hxl
  rw [hxl] at haff
  -- 0 = (1-w)*su + w*sv with su,sv same nonzero sign and w ∈ [0,1]
  -- This is impossible: a convex combination of two same-sign nonzero numbers is nonzero.
  set su := sideOf σ0 u
  set sv := sideOf σ0 v
  rcases mul_pos_iff.mp hsign with ⟨hpu, hpv⟩ | ⟨hnu, hnv⟩
  · nlinarith [mul_nonneg (sub_nonneg.mpr hw1) (le_of_lt hpu), mul_nonneg hw0 (le_of_lt hpv)]
  · nlinarith [mul_nonneg (sub_nonneg.mpr hw1) (le_of_lt (neg_pos.mpr hnu)),
      mul_nonneg hw0 (le_of_lt (neg_pos.mpr hnv))]

/-- Clean-path constancy of `χ := (·∈A ∧ ·∈B)` between two points strictly on the same side of
    `lineOf σ0` whose connecting segment avoids every `Lnc` segment. -/
private theorem flip_eq_of_same_side_off_Lnc (G1 G2 : EvenGraph) (σ0 : LineSegment)
    (u v : Vector2D) (hsign : 0 < sideOf σ0 u * sideOf σ0 v)
    (hpath : ∀ x ∈ (LineSegment.mk u v).toSet, ∀ s ∈ Lnc G1 G2 σ0, x ∉ s.toSet) :
    (u ∈ G1.interior ∧ u ∈ G2.interior) = (v ∈ G1.interior ∧ v ∈ G2.interior) := by
  have hoff_line := off_line_of_same_side σ0 u v hsign
  -- every point of ⟨u,v⟩ (incl. endpoints) is off both boundaries
  have hpt : ∀ x ∈ (LineSegment.mk u v).toSet,
      x ∉ G1.toBoundarySet ∧ x ∉ G2.toBoundarySet := by
    intro x hx
    exact off_boundaries_of_off_line_and_Lnc G1 G2 σ0 x (hoff_line x hx) (hpath x hx)
  have hu_mem : u ∈ (LineSegment.mk u v).toSet := ⟨0, le_refl _, zero_le_one, by ring, by ring⟩
  have hv_mem : v ∈ (LineSegment.mk u v).toSet := ⟨1, zero_le_one, le_refl _, by ring, by ring⟩
  exact flip_eq_of_clean_path G1 G2 u v (hpt u hu_mem).1 (hpt u hu_mem).2
    (hpt v hv_mem).1 (hpt v hv_mem).2 hpt

/-- A point in `σ0`'s open interior (in `σ0.toSet`, distinct from both endpoints) is off every
    `Lnc` segment, since each `Lnc` segment is non-collinear with `σ0` and `σ0 ∈ arr G1 G2`. -/
theorem crossing_off_Lnc (G1 G2 : EvenGraph) (σ0 : LineSegment)
    (hσ0 : σ0 ∈ (arr G1 G2).segments)
    (z : Vector2D) (hz : z ∈ σ0.toSet) (hz1 : z ≠ σ0.p1) (hz2 : z ≠ σ0.p2) :
    ∀ s ∈ Lnc G1 G2 σ0, z ∉ s.toSet := by
  intro s hs
  rw [mem_Lnc_iff] at hs
  exact arr_int_avoids_noncollinear G1 G2 σ0 hσ0 s hs.1 hs.2 z hz hz1 hz2

/-- `sideOf σ0 (offset)` for a point `c* + μ·(1,q)` with `c* ∈ lineOf σ0`: it equals `μ·κ`
    where `κ := dx*q - dy` (with `dx,dy` the direction of `σ0`). -/
theorem sideOf_offset (σ0 : LineSegment) (cstar : Vector2D)
    (hcl : cstar ∈ lineOf σ0) (μ q : ℚ) :
    sideOf σ0 ⟨cstar.x + μ * 1, cstar.y + μ * q⟩ =
      μ * ((σ0.p2.x - σ0.p1.x) * q - (σ0.p2.y - σ0.p1.y)) := by
  have hc0 : sideOf σ0 cstar = 0 := (sideOf_eq_zero_iff σ0 cstar).mpr hcl
  simp only [sideOf] at hc0 ⊢
  linear_combination hc0

/-- A slope `q` such that the direction `(1, q)` is **not parallel** to `σ0` (so `κ ≠ 0`) and
    not parallel to any `Lnc` segment (so each `Lnc` "denominator" is nonzero). -/
private theorem exists_good_slope (G1 G2 : EvenGraph) (σ0 : LineSegment)
    (hnd : σ0.p1 ≠ σ0.p2) :
    ∃ q : ℚ,
      ((σ0.p2.x - σ0.p1.x) * q - (σ0.p2.y - σ0.p1.y)) ≠ 0 ∧
      ∀ s ∈ Lnc G1 G2 σ0,
        ((s.p2.y - s.p1.y) - q * (s.p2.x - s.p1.x)) ≠ 0 := by
  have h_inf : Infinite ℚ :=
    Infinite.of_injective (fun n : ℕ => (n : ℚ)) Nat.cast_injective
  -- bad slopes: slopes of σ0 and of each Lnc seg with a vertical exception handled separately.
  -- We use the (1,q)·s parallel test directly via a finset of forbidden slopes.
  let badSlopes : Finset ℚ := ((σ0 :: Lnc G1 G2 σ0).filterMap fun seg =>
    if seg.p2.x = seg.p1.x then none
    else some ((seg.p2.y - seg.p1.y) / (seg.p2.x - seg.p1.x))).toFinset
  obtain ⟨q, hq⟩ := Finset.exists_not_mem badSlopes
  -- generic statement: for any nondegenerate seg in (σ0 :: Lnc), the parallel test is nonzero.
  have key : ∀ seg ∈ (σ0 :: Lnc G1 G2 σ0), seg.p1 ≠ seg.p2 →
      ((seg.p2.y - seg.p1.y) - q * (seg.p2.x - seg.p1.x)) ≠ 0 := by
    intro seg hmem hne hpar
    by_cases hx : seg.p2.x = seg.p1.x
    · have hxsub : seg.p2.x - seg.p1.x = 0 := by linarith
      have hy_eq : seg.p2.y - seg.p1.y = 0 := by rw [hxsub] at hpar; linarith
      exact hne (Vector2D.ext (by linarith) (by linarith))
    · apply hq
      simp only [badSlopes, List.mem_toFinset, List.mem_filterMap]
      refine ⟨seg, hmem, ?_⟩
      have hxne : seg.p2.x - seg.p1.x ≠ 0 := sub_ne_zero.mpr hx
      have hq_eq : q = (seg.p2.y - seg.p1.y) / (seg.p2.x - seg.p1.x) := by
        rw [eq_div_iff hxne]; linarith
      simp only [if_neg hx]; exact hq_eq ▸ rfl
  refine ⟨q, ?_, ?_⟩
  · -- κ = dx*q - dy ≠ 0: from the parallel test for σ0 (κ = -(test for σ0)).
    have := key σ0 (List.mem_cons_self _ _) hnd
    intro hκ; apply this; linarith
  · intro s hs
    exact key s (List.mem_cons_of_mem _ hs) (Lnc_nondeg G1 G2 σ0 s hs)

/-- Crossing parameter of the line `{p + t·(1,q)}` with segment `s`. -/
def tOff (q : ℚ) (s : LineSegment) (p : Vector2D) : ℚ :=
  ((s.p1.x - p.x) * (s.p2.y - s.p1.y) - (s.p1.y - p.y) * (s.p2.x - s.p1.x)) /
    ((s.p2.y - s.p1.y) - q * (s.p2.x - s.p1.x))

/-- If `p + μ·(1,q)` lands on segment `s` (with `s`-denominator nonzero), then `μ = tOff q s p`. -/
theorem tOff_eq_of_mem (q : ℚ) (s : LineSegment) (p : Vector2D)
    (hden : (s.p2.y - s.p1.y) - q * (s.p2.x - s.p1.x) ≠ 0)
    (μ : ℚ) (hmem : (⟨p.x + μ * 1, p.y + μ * q⟩ : Vector2D) ∈ s.toSet) :
    μ = tOff q s p := by
  obtain ⟨u, _, _, hsx, hsy⟩ := hmem
  -- hsx : p.x + μ*1 = (1-u)*s.p1.x + u*s.p2.x ; hsy : p.y + μ*q = ...
  have h1 : μ = (s.p1.x - p.x) + u * (s.p2.x - s.p1.x) := by
    have : p.x + μ * 1 = (1 - u) * s.p1.x + u * s.p2.x := hsx
    linarith
  have h2 : μ * q = (s.p1.y - p.y) + u * (s.p2.y - s.p1.y) := by
    have : p.y + μ * q = (1 - u) * s.p1.y + u * s.p2.y := hsy
    linarith
  have h_s_den :
      μ * ((s.p2.y - s.p1.y) - q * (s.p2.x - s.p1.x)) =
      (s.p1.x - p.x) * (s.p2.y - s.p1.y) - (s.p1.y - p.y) * (s.p2.x - s.p1.x) := by
    have e1 : μ * (s.p2.y - s.p1.y) =
        ((s.p1.x - p.x) + u * (s.p2.x - s.p1.x)) * (s.p2.y - s.p1.y) := by rw [h1]
    have e2 : (μ * q) * (s.p2.x - s.p1.x) =
        ((s.p1.y - p.y) + u * (s.p2.y - s.p1.y)) * (s.p2.x - s.p1.x) := by rw [h2]
    linear_combination e1 - e2
  rw [tOff, eq_div_iff hden]; linarith

/-- The crossing parameter `tOff q s ·` is affine: along `p_w := (1-w)·p0 + w·p1`,
    `tOff q s p_w = (1-w)·tOff q s p0 + w·tOff q s p1`. -/
private theorem tOff_affine (q : ℚ) (s : LineSegment) (p0 p1 : Vector2D) (w : ℚ)
    (hden : (s.p2.y - s.p1.y) - q * (s.p2.x - s.p1.x) ≠ 0)
    (p : Vector2D) (hx : p.x = (1 - w) * p0.x + w * p1.x)
    (hy : p.y = (1 - w) * p0.y + w * p1.y) :
    tOff q s p = (1 - w) * tOff q s p0 + w * tOff q s p1 := by
  -- common denominator; numerators are affine in `p.x, p.y`.
  set den := (s.p2.y - s.p1.y) - q * (s.p2.x - s.p1.x) with hden_def
  have hnum : (s.p1.x - p.x) * (s.p2.y - s.p1.y) - (s.p1.y - p.y) * (s.p2.x - s.p1.x) =
      (1 - w) * ((s.p1.x - p0.x) * (s.p2.y - s.p1.y) - (s.p1.y - p0.y) * (s.p2.x - s.p1.x)) +
      w * ((s.p1.x - p1.x) * (s.p2.y - s.p1.y) - (s.p1.y - p1.y) * (s.p2.x - s.p1.x)) := by
    rw [hx, hy]; ring
  simp only [tOff]
  rw [hnum]
  rw [add_div, mul_div_assoc, mul_div_assoc]

/-- `min over a list of segments of the positive crossing parameters (default `1`)` is positive.
    Here `ε ∈ {±1}` selects the offset direction `(ε, ε·q)` and the relevant crossing parameter
    is `ε · tOff q s p`. -/
def offClearance (ε q : ℚ) (L : List LineSegment) (p : Vector2D) : ℚ :=
  L.foldr (fun s acc => if 0 < ε * tOff q s p then min acc (ε * tOff q s p) else acc) 1

theorem offClearance_pos (ε q : ℚ) (L : List LineSegment) (p : Vector2D) :
    0 < offClearance ε q L p := by
  unfold offClearance
  induction L with
  | nil => norm_num
  | cons s rest ih =>
    simp only [List.foldr_cons]
    split_ifs with h
    · exact lt_min ih h
    · exact ih

theorem offClearance_le (ε q : ℚ) (L : List LineSegment) (p : Vector2D)
    (s : LineSegment) (hs : s ∈ L) (hpos : 0 < ε * tOff q s p) :
    offClearance ε q L p ≤ ε * tOff q s p := by
  unfold offClearance
  induction L with
  | nil => exact absurd hs (List.not_mem_nil s)
  | cons hd rest ih =>
    simp only [List.foldr_cons]
    rcases List.mem_cons.mp hs with rfl | hs'
    · rw [if_pos hpos]; exact min_le_right _ _
    · split_ifs with h
      · exact (min_le_left _ _).trans (ih hs')
      · exact ih hs'

/-- **Point clearance.** For a base point `p` (with direction slope `q` making every `Lnc`
    denominator nonzero) that is itself off every `Lnc` segment, and a sign `ε = ±1`, there is
    `δ > 0` such that for all `0 < μ ≤ δ`, the offset point `p + μ·(ε, ε·q)` is off every `Lnc`
    segment. -/
private theorem exists_point_clearance (G1 G2 : EvenGraph) (σ0 : LineSegment) (ε q : ℚ)
    (hε : ε = 1 ∨ ε = -1)
    (hden : ∀ s ∈ Lnc G1 G2 σ0, ((s.p2.y - s.p1.y) - q * (s.p2.x - s.p1.x)) ≠ 0)
    (p : Vector2D) :
    ∃ δ : ℚ, 0 < δ ∧ ∀ μ : ℚ, 0 < μ → μ ≤ δ →
      ∀ s ∈ Lnc G1 G2 σ0,
        (⟨p.x + μ * ε, p.y + μ * (ε * q)⟩ : Vector2D) ∉ s.toSet := by
  refine ⟨offClearance ε q (Lnc G1 G2 σ0) p / 2,
    by have := offClearance_pos ε q (Lnc G1 G2 σ0) p; linarith, ?_⟩
  intro μ hμpos hμle s hs hmem
  -- p + μ·(ε,εq) = p + (με)·(1,q)
  have hmem' : (⟨p.x + (μ * ε) * 1, p.y + (μ * ε) * q⟩ : Vector2D) ∈ s.toSet := by
    have hxe : p.x + (μ * ε) * 1 = p.x + μ * ε := by ring
    have hye : p.y + (μ * ε) * q = p.y + μ * (ε * q) := by ring
    rw [show (⟨p.x + (μ * ε) * 1, p.y + (μ * ε) * q⟩ : Vector2D) =
        (⟨p.x + μ * ε, p.y + μ * (ε * q)⟩ : Vector2D) from Vector2D.ext hxe hye]
    exact hmem
  have hμ_eq : μ * ε = tOff q s p := tOff_eq_of_mem q s p (hden s hs) (μ * ε) hmem'
  have hε2 : ε * ε = 1 := by rcases hε with h | h <;> rw [h] <;> norm_num
  -- ε·tOff = ε·(μ·ε) = μ·(ε·ε) = μ > 0
  have htpos : 0 < ε * tOff q s p := by
    rw [← hμ_eq]; calc 0 < μ := hμpos
      _ = ε * (μ * ε) := by rw [show ε * (μ * ε) = μ * (ε * ε) by ring, hε2, mul_one]
  have hclear_le : offClearance ε q (Lnc G1 G2 σ0) p ≤ ε * tOff q s p :=
    offClearance_le ε q (Lnc G1 G2 σ0) p s hs htpos
  rw [← hμ_eq] at hclear_le
  have hμμ : ε * (μ * ε) = μ := by rw [show ε * (μ * ε) = μ * (ε * ε) by ring, hε2, mul_one]
  rw [hμμ] at hclear_le
  have hpos := offClearance_pos ε q (Lnc G1 G2 σ0) p
  linarith

/-- Segment-param of the crossing of the line `{p + t·(1,q)}` with segment `s`. -/
private def uOff (q : ℚ) (s : LineSegment) (p : Vector2D) : ℚ :=
  (q * (s.p1.x - p.x) - (s.p1.y - p.y)) /
    ((s.p2.y - s.p1.y) - q * (s.p2.x - s.p1.x))

/-- If `p + μ·(1,q)` lands on segment `s` (denominator nonzero) at convex parameter `u`, then
    `u = uOff q s p`. -/
private theorem uOff_eq_of_mem (q : ℚ) (s : LineSegment) (p : Vector2D)
    (hden : (s.p2.y - s.p1.y) - q * (s.p2.x - s.p1.x) ≠ 0)
    (μ u : ℚ) (h0 : 0 ≤ u) (h1 : u ≤ 1)
    (hsx : p.x + μ * 1 = (1 - u) * s.p1.x + u * s.p2.x)
    (hsy : p.y + μ * q = (1 - u) * s.p1.y + u * s.p2.y) :
    u = uOff q s p := by
  have h1' : μ = (s.p1.x - p.x) + u * (s.p2.x - s.p1.x) := by
    have : p.x + μ * 1 = (1 - u) * s.p1.x + u * s.p2.x := hsx; linarith
  have h2' : μ * q = (s.p1.y - p.y) + u * (s.p2.y - s.p1.y) := by
    have : p.y + μ * q = (1 - u) * s.p1.y + u * s.p2.y := hsy; linarith
  -- eliminate μ: q*h1' - h2'
  have hu_den :
      u * ((s.p2.y - s.p1.y) - q * (s.p2.x - s.p1.x)) =
        q * (s.p1.x - p.x) - (s.p1.y - p.y) := by
    have e1 : μ * q = (q * (s.p1.x - p.x)) + u * (q * (s.p2.x - s.p1.x)) := by
      rw [h1']; ring
    linear_combination e1 - h2'
  rw [uOff, eq_div_iff hden]; linarith

/-- `uOff q s ·` is affine along `(1-w)·p0 + w·p1`. -/
private theorem uOff_affine (q : ℚ) (s : LineSegment) (p0 p1 : Vector2D) (w : ℚ)
    (p : Vector2D) (hx : p.x = (1 - w) * p0.x + w * p1.x)
    (hy : p.y = (1 - w) * p0.y + w * p1.y) :
    uOff q s p = (1 - w) * uOff q s p0 + w * uOff q s p1 := by
  have hnum : q * (s.p1.x - p.x) - (s.p1.y - p.y) =
      (1 - w) * (q * (s.p1.x - p0.x) - (s.p1.y - p0.y)) +
      w * (q * (s.p1.x - p1.x) - (s.p1.y - p1.y)) := by
    rw [hx, hy]; ring
  simp only [uOff]
  rw [hnum, add_div, mul_div_assoc, mul_div_assoc]

/-- If the offset crossing parameter `tOff q s p = 0` and the segment parameter `uOff q s p ∈
    [0,1]`, then the base point `p` itself lies on `s`. -/
private theorem mem_of_tOff_zero (q : ℚ) (s : LineSegment) (p : Vector2D)
    (hden : (s.p2.y - s.p1.y) - q * (s.p2.x - s.p1.x) ≠ 0)
    (ht0 : tOff q s p = 0) (hu0 : 0 ≤ uOff q s p) (hu1 : uOff q s p ≤ 1) :
    p ∈ s.toSet := by
  -- tOff = 0 numerator: (s.p1.x - p.x)*Δy - (s.p1.y - p.y)*Δx = 0
  have htnum : (s.p1.x - p.x) * (s.p2.y - s.p1.y) - (s.p1.y - p.y) * (s.p2.x - s.p1.x) = 0 := by
    have h := ht0
    rw [tOff, div_eq_zero_iff] at h
    rcases h with h | h
    · exact h
    · exact absurd h hden
  -- uOff: u * den = q*(s.p1.x - p.x) - (s.p1.y - p.y)
  have hunum : uOff q s p * ((s.p2.y - s.p1.y) - q * (s.p2.x - s.p1.x)) =
      q * (s.p1.x - p.x) - (s.p1.y - p.y) := by
    rw [uOff]; field_simp
  -- abbreviations
  set u := uOff q s p
  set A := s.p1.x - p.x with hA
  set B := s.p1.y - p.y with hB
  set Δx := s.p2.x - s.p1.x with hΔx
  set Δy := s.p2.y - s.p1.y with hΔy
  -- htnum : A*Δy - B*Δx = 0 ; hunum : u*(Δy - qΔx) = q*A - B
  have hAB : A * Δy = B * Δx := by linarith [htnum]
  -- A = -u*Δx via cancellation by (Δy - qΔx)
  have hAeq : A * (Δy - q * Δx) = (-(u * Δx)) * (Δy - q * Δx) := by
    linear_combination hAB + Δx * hunum
  have hBeq : B * (Δy - q * Δx) = (-(u * Δy)) * (Δy - q * Δx) := by
    linear_combination Δy * hunum + q * hAB
  have hA' : A = -(u * Δx) := mul_right_cancel₀ hden hAeq
  have hB' : B = -(u * Δy) := mul_right_cancel₀ hden hBeq
  refine ⟨u, hu0, hu1, ?_, ?_⟩
  · show p.x = (1 - u) * s.p1.x + u * s.p2.x
    have : A = -(u * Δx) := hA'
    rw [hA, hΔx] at this; linarith
  · show p.y = (1 - u) * s.p1.y + u * s.p2.y
    have : B = -(u * Δy) := hB'
    rw [hB, hΔy] at this; linarith

/-- An affine map `t ↦ (1-t)*A + t*B` that is nonzero at both ends of `[0,1]` and positive
    somewhere stays `≥ min A B > 0` throughout — provided it has no interior root, which we get
    from `hnoroot`. -/
private theorem affine_pos_lower (A B : ℚ)
    (hnoroot : ∀ t : ℚ, 0 ≤ t → t ≤ 1 → (1 - t) * A + t * B ≠ 0)
    (t : ℚ) (ht0 : 0 ≤ t) (ht1 : t ≤ 1)
    (hpos : 0 < (1 - t) * A + t * B) :
    0 < A ∧ 0 < B ∧ min A B ≤ (1 - t) * A + t * B := by
  -- A,B nonzero (ends) and same sign (no interior root) ⟹ both positive.
  have hA : A ≠ 0 := by have := hnoroot 0 le_rfl zero_le_one; simpa using this
  have hB : B ≠ 0 := by have := hnoroot 1 zero_le_one le_rfl; simpa using this
  -- both positive
  have hApos : 0 < A := by
    rcases lt_trichotomy A 0 with h | h | h
    · exfalso
      -- A<0 and f t>0 ⟹ root r=(-A)/(B-A) ∈ (0,t]⊆[0,1]
      have hBA : B - A ≠ 0 := by
        intro hba; have : B = A := by linarith
        rw [this] at hpos; nlinarith
      set r := (-A) / (B - A) with hr
      have hBApos : 0 < B - A := by
        -- f t = A + t(B-A) > 0, A<0, t∈[0,1] ⟹ t(B-A) > -A > 0 ⟹ B-A>0
        rcases lt_trichotomy (B - A) 0 with hb | hb | hb
        · exfalso; nlinarith
        · exact absurd hb hBA
        · exact hb
      have hr0 : 0 ≤ r := by
        rw [hr]; exact div_nonneg (by linarith) (le_of_lt hBApos)
      have hrt : r ≤ t := by
        rw [hr, div_le_iff hBApos]; nlinarith
      have hfr : (1 - r) * A + r * B = 0 := by rw [hr]; field_simp; ring
      exact hnoroot r hr0 (le_trans hrt ht1) hfr
    · exact absurd h hA
    · exact h
  have hBpos : 0 < B := by
    rcases lt_trichotomy B 0 with h | h | h
    · exfalso
      have hBA : B - A ≠ 0 := by
        intro hba; have : A = B := by linarith
        rw [this] at hpos; nlinarith
      set r := (-A) / (B - A) with hr
      have hBAneg : B - A < 0 := by
        rcases lt_trichotomy (B - A) 0 with hb | hb | hb
        · exact hb
        · exact absurd hb hBA
        · exfalso; nlinarith
      have hr0 : 0 ≤ r := by
        rw [hr]; exact div_nonneg_of_nonpos (by linarith) (by linarith)
      have hr1 : r ≤ 1 := by
        rw [hr, div_le_iff_of_neg hBAneg]; nlinarith
      have hfr : (1 - r) * A + r * B = 0 := by rw [hr]; field_simp; ring
      exact hnoroot r hr0 hr1 hfr
    · exact absurd h hB
    · exact h
  -- f t = (1-t)A + tB ≥ (1-t)minAB + t minAB = minAB
  refine ⟨hApos, hBpos, ?_⟩
  have h1 := mul_le_mul_of_nonneg_left (min_le_left A B) (by linarith : (0:ℚ) ≤ 1 - t)
  have h2 := mul_le_mul_of_nonneg_left (min_le_right A B) ht0
  have heq : (1 - t) * min A B + t * min A B = min A B := by ring
  linarith

/-- Reparametrise the affine bound onto an explicit window `[lo, hi] ⊆ [0,1]` that contains every
    feasible `w`: this yields the uniform positive lower bound. -/
private theorem affine_clearance_window (α β γ ν lo hi : ℚ)
    (hlohi : lo ≤ hi) (hlo0 : 0 ≤ lo) (hhi1 : hi ≤ 1)
    (hwin : ∀ w : ℚ, lo ≤ w → w ≤ hi → 0 ≤ (1 - w) * γ + w * ν ∧ (1 - w) * γ + w * ν ≤ 1)
    (hcover : ∀ w : ℚ, 0 ≤ w → w ≤ 1 → 0 ≤ (1 - w) * γ + w * ν → (1 - w) * γ + w * ν ≤ 1 →
      lo ≤ w ∧ w ≤ hi)
    (hkey : ∀ w : ℚ, 0 ≤ w → w ≤ 1 → 0 ≤ (1 - w) * γ + w * ν → (1 - w) * γ + w * ν ≤ 1 →
      (1 - w) * α + w * β ≠ 0) :
    ∃ δ : ℚ, 0 < δ ∧ ∀ w : ℚ, 0 ≤ w → w ≤ 1 →
      0 ≤ (1 - w) * γ + w * ν → (1 - w) * γ + w * ν ≤ 1 →
      0 < (1 - w) * α + w * β → δ ≤ (1 - w) * α + w * β := by
  -- A := f lo, B := f hi
  set fl := (1 - lo) * α + lo * β with hfl
  set fh := (1 - hi) * α + hi * β with hfh
  -- reparametrisation: for t ∈ [0,1], w(t) := lo + t*(hi-lo) ∈ [lo,hi], and f(w t) = (1-t)fl+t fh
  have hreparam : ∀ t : ℚ, (1 - t) * fl + t * fh =
      (1 - (lo + t * (hi - lo))) * α + (lo + t * (hi - lo)) * β := by
    intro t; rw [hfl, hfh]; ring
  -- no interior root of the reparametrised f
  have hnoroot : ∀ t : ℚ, 0 ≤ t → t ≤ 1 → (1 - t) * fl + t * fh ≠ 0 := by
    intro t ht0 ht1
    set w := lo + t * (hi - lo) with hw
    have hwlo : lo ≤ w := by rw [hw]; nlinarith
    have hwhi : w ≤ hi := by rw [hw]; nlinarith
    have hw0 : 0 ≤ w := le_trans hlo0 hwlo
    have hw1 : w ≤ 1 := le_trans hwhi hhi1
    obtain ⟨hg0, hg1⟩ := hwin w hwlo hwhi
    rw [hreparam t]
    exact hkey w hw0 hw1 hg0 hg1
  refine ⟨if 0 < min fl fh then min fl fh else 1, ?_, ?_⟩
  · split_ifs with h
    · exact h
    · exact one_pos
  · intro w hw0 hw1 hg0 hg1 hfpos
    obtain ⟨hwlo, hwhi⟩ := hcover w hw0 hw1 hg0 hg1
    -- t for w
    have hlohi' : lo < hi ∨ lo = hi := lt_or_eq_of_le hlohi
    -- compute t := (w - lo)/(hi - lo) if lo<hi, else 0
    rcases hlohi' with hlt | heq
    · set t := (w - lo) / (hi - lo) with ht
      have hd : 0 < hi - lo := by linarith
      have ht0 : 0 ≤ t := by rw [ht]; exact div_nonneg (by linarith) (le_of_lt hd)
      have ht1 : t ≤ 1 := by rw [ht, div_le_one hd]; linarith
      have hwt : w = lo + t * (hi - lo) := by rw [ht]; field_simp
      have hfw : (1 - w) * α + w * β = (1 - t) * fl + t * fh := by
        rw [hreparam t, ← hwt]
      have hpos' : 0 < (1 - t) * fl + t * fh := by rw [← hfw]; exact hfpos
      obtain ⟨hflpos, hfhpos, hmin⟩ := affine_pos_lower fl fh hnoroot t ht0 ht1 hpos'
      have hminpos : 0 < min fl fh := lt_min hflpos hfhpos
      rw [if_pos hminpos, hfw]; exact hmin
    · -- lo = hi : window is a single point; w = lo = hi
      have hwval : w = lo := le_antisymm (heq ▸ hwhi) hwlo
      -- f w = fl, and fl ≠ 0 (hnoroot at t=0), fl > 0 (= f w > 0)
      have hfw : (1 - w) * α + w * β = fl := by rw [hwval, hfl]
      have hflpos : 0 < fl := by rw [← hfw]; exact hfpos
      have hfhpos : 0 < fh := by rw [hfh, ← heq, ← hfl]; exact hflpos
      have hminpos : 0 < min fl fh := lt_min hflpos hfhpos
      rw [if_pos hminpos, hfw]
      exact min_le_left _ _

private theorem affine_clearance (α β γ ν : ℚ)
    (hkey : ∀ w : ℚ, 0 ≤ w → w ≤ 1 → 0 ≤ (1 - w) * γ + w * ν → (1 - w) * γ + w * ν ≤ 1 →
      (1 - w) * α + w * β ≠ 0) :
    ∃ δ : ℚ, 0 < δ ∧ ∀ w : ℚ, 0 ≤ w → w ≤ 1 →
      0 ≤ (1 - w) * γ + w * ν → (1 - w) * γ + w * ν ≤ 1 →
      0 < (1 - w) * α + w * β → δ ≤ (1 - w) * α + w * β := by
  -- g w = γ + w(ν - γ). Construct the window [lo, hi] by sign of (ν - γ).
  -- If the window is empty, return δ = 1 vacuously.
  by_cases hwin_ne : ∃ w : ℚ, 0 ≤ w ∧ w ≤ 1 ∧ 0 ≤ (1 - w) * γ + w * ν ∧ (1 - w) * γ + w * ν ≤ 1
  · obtain ⟨w0, hw00, hw01, hg00, hg01⟩ := hwin_ne
    rcases lt_trichotomy ν γ with hslope | hslope | hslope
    · -- ν < γ : g decreasing. g w ∈ [0,1] ⟺ w ∈ [ (γ-1)/(γ-ν), γ/(γ-ν) ].
      set d := γ - ν with hd
      have hdpos : 0 < d := by rw [hd]; linarith
      have hgw : ∀ w : ℚ, (1 - w) * γ + w * ν = γ - w * d := by intro w; rw [hd]; ring
      set lo := max 0 ((γ - 1) / d) with hlo
      set hi := min 1 (γ / d) with hhi
      have hwin : ∀ w : ℚ, lo ≤ w → w ≤ hi →
          0 ≤ (1 - w) * γ + w * ν ∧ (1 - w) * γ + w * ν ≤ 1 := by
        intro w hwlo hwhi
        have hlow : (γ - 1) / d ≤ w := le_trans (le_max_right _ _) hwlo
        have hwhi' : w ≤ γ / d := le_trans hwhi (min_le_right _ _)
        rw [hgw]
        constructor
        · have : w * d ≤ γ := by rw [← le_div_iff hdpos] at *; linarith [hwhi']
          linarith
        · have : γ - 1 ≤ w * d := by rw [div_le_iff hdpos] at hlow; linarith
          linarith
      have hcover : ∀ w : ℚ, 0 ≤ w → w ≤ 1 →
          0 ≤ (1 - w) * γ + w * ν → (1 - w) * γ + w * ν ≤ 1 → lo ≤ w ∧ w ≤ hi := by
        intro w hw0 hw1 hg0 hg1
        rw [hgw] at hg0 hg1
        constructor
        · rw [hlo, max_le_iff]; exact ⟨hw0, by rw [div_le_iff hdpos]; linarith⟩
        · rw [hhi, le_min_iff]; exact ⟨hw1, by rw [le_div_iff hdpos]; linarith⟩
      have hlo0 : 0 ≤ lo := le_max_left _ _
      have hhi1 : hi ≤ 1 := min_le_left _ _
      have hlohi : lo ≤ hi := by
        obtain ⟨hl, hh⟩ := hcover w0 hw00 hw01 hg00 hg01; exact le_trans hl hh
      exact affine_clearance_window α β γ ν lo hi hlohi hlo0 hhi1 hwin hcover hkey
    · -- ν = γ : g constant ≡ γ, window = [0,1] (since some w has g∈[0,1] ⟹ γ∈[0,1]).
      have hgconst : ∀ w : ℚ, (1 - w) * γ + w * ν = γ := by intro w; rw [hslope]; ring
      have hγ0 : 0 ≤ γ := by have := hg00; rw [hgconst] at this; exact this
      have hγ1 : γ ≤ 1 := by have := hg01; rw [hgconst] at this; exact this
      exact affine_clearance_window α β γ ν 0 1 zero_le_one le_rfl le_rfl
        (fun w _ _ => ⟨by rw [hgconst]; exact hγ0, by rw [hgconst]; exact hγ1⟩)
        (fun w hw0 hw1 _ _ => ⟨hw0, hw1⟩) hkey
    · -- γ < ν : g increasing. g w ∈ [0,1] ⟺ w ∈ [ -γ/(ν-γ), (1-γ)/(ν-γ) ].
      set d := ν - γ with hd
      have hdpos : 0 < d := by rw [hd]; linarith
      have hgw : ∀ w : ℚ, (1 - w) * γ + w * ν = γ + w * d := by intro w; rw [hd]; ring
      set lo := max 0 ((-γ) / d) with hlo
      set hi := min 1 ((1 - γ) / d) with hhi
      have hwin : ∀ w : ℚ, lo ≤ w → w ≤ hi →
          0 ≤ (1 - w) * γ + w * ν ∧ (1 - w) * γ + w * ν ≤ 1 := by
        intro w hwlo hwhi
        have hlow : (-γ) / d ≤ w := le_trans (le_max_right _ _) hwlo
        have hwhi' : w ≤ (1 - γ) / d := le_trans hwhi (min_le_right _ _)
        rw [hgw]
        constructor
        · have : -γ ≤ w * d := by rw [div_le_iff hdpos] at hlow; linarith
          linarith
        · have : w * d ≤ 1 - γ := by rw [le_div_iff hdpos] at hwhi'; linarith
          linarith
      have hcover : ∀ w : ℚ, 0 ≤ w → w ≤ 1 →
          0 ≤ (1 - w) * γ + w * ν → (1 - w) * γ + w * ν ≤ 1 → lo ≤ w ∧ w ≤ hi := by
        intro w hw0 hw1 hg0 hg1
        rw [hgw] at hg0 hg1
        constructor
        · rw [hlo, max_le_iff]; exact ⟨hw0, by rw [div_le_iff hdpos]; linarith⟩
        · rw [hhi, le_min_iff]; exact ⟨hw1, by rw [le_div_iff hdpos]; linarith⟩
      have hlo0 : 0 ≤ lo := le_max_left _ _
      have hhi1 : hi ≤ 1 := min_le_left _ _
      have hlohi : lo ≤ hi := by
        obtain ⟨hl, hh⟩ := hcover w0 hw00 hw01 hg00 hg01; exact le_trans hl hh
      exact affine_clearance_window α β γ ν lo hi hlohi hlo0 hhi1 hwin hcover hkey
  · push_neg at hwin_ne
    exact ⟨1, one_pos, fun w hw0 hw1 hg0 hg1 _ => absurd (hwin_ne w hw0 hw1 hg0) (not_lt.mpr hg1)⟩

/-- **Slide clearance (per `Lnc` segment).** Given the offset direction `(ε,ε·q)` (with `ε=±1`),
    the segment `⟨c,c'⟩` between two open-interior points of `σ0` (so every `c''(w)` is off `s`),
    and a non-collinear segment `s ∈ Lnc` with nonzero denominator, there is `δ_s > 0` such that
    for all `w ∈ [0,1]` and all `0 < μ ≤ δ_s`, the slide point `c''(w) + μ·(ε,ε·q)` is off `s`.

    The crossing parameter `f(w) := ε·tOff q s (c''(w))` and segment parameter
    `g(w) := uOff q s (c''(w))` are both affine in `w`; off-`s`-ness of every `c''(w)` forces
    `f(w) ≠ 0` whenever `g(w) ∈ [0,1]`, and an affine function that is nonzero on the
    sub-interval `{w : g(w) ∈ [0,1]}` is bounded away from `0` there. -/
private theorem exists_slide_clearance_seg (q ε : ℚ) (hε : ε = 1 ∨ ε = -1)
    (s : LineSegment) (hden : (s.p2.y - s.p1.y) - q * (s.p2.x - s.p1.x) ≠ 0)
    (c c' : Vector2D)
    (hoff : ∀ w : ℚ, 0 ≤ w → w ≤ 1 →
      (⟨(1 - w) * c.x + w * c'.x, (1 - w) * c.y + w * c'.y⟩ : Vector2D) ∉ s.toSet) :
    ∃ δ : ℚ, 0 < δ ∧ ∀ w : ℚ, 0 ≤ w → w ≤ 1 → ∀ μ : ℚ, 0 < μ → μ ≤ δ →
      (⟨(1 - w) * c.x + w * c'.x + μ * ε,
        (1 - w) * c.y + w * c'.y + μ * (ε * q)⟩ : Vector2D) ∉ s.toSet := by
  have hε2 : ε * ε = 1 := by rcases hε with h | h <;> rw [h] <;> norm_num
  -- base point cw and its tOff / uOff coefficients
  set cw : ℚ → Vector2D := fun w =>
    (⟨(1 - w) * c.x + w * c'.x, (1 - w) * c.y + w * c'.y⟩ : Vector2D) with hcw
  -- affineness of tOff and uOff along w
  have htAff : ∀ w : ℚ, tOff q s (cw w) = (1 - w) * tOff q s c + w * tOff q s c' := by
    intro w; exact tOff_affine q s c c' w hden (cw w) rfl rfl
  have huAff : ∀ w : ℚ, uOff q s (cw w) = (1 - w) * uOff q s c + w * uOff q s c' := by
    intro w; exact uOff_affine q s c c' w (cw w) rfl rfl
  -- key: where g ∈ [0,1], ε·tOff(cw) ≠ 0
  have hkey : ∀ w : ℚ, 0 ≤ w → w ≤ 1 →
      0 ≤ (1 - w) * uOff q s c + w * uOff q s c' →
      (1 - w) * uOff q s c + w * uOff q s c' ≤ 1 →
      (1 - w) * (ε * tOff q s c) + w * (ε * tOff q s c') ≠ 0 := by
    intro w hw0 hw1 hg0 hg1 hf0
    -- ε·tOff(cw) = (1-w)(ε tOff c) + w(ε tOff c')
    have hfval : ε * tOff q s (cw w) = (1 - w) * (ε * tOff q s c) + w * (ε * tOff q s c') := by
      rw [htAff w]; ring
    have htw0 : tOff q s (cw w) = 0 := by
      have : ε * tOff q s (cw w) = 0 := by rw [hfval]; exact hf0
      rcases mul_eq_zero.mp this with h | h
      · rcases hε with he | he <;> rw [he] at h <;> norm_num at h
      · exact h
    have huw : uOff q s (cw w) = (1 - w) * uOff q s c + w * uOff q s c' := huAff w
    have hcwmem : cw w ∈ s.toSet :=
      mem_of_tOff_zero q s (cw w) hden htw0 (by rw [huw]; exact hg0) (by rw [huw]; exact hg1)
    exact hoff w hw0 hw1 hcwmem
  obtain ⟨δ, hδpos, hδ⟩ := affine_clearance (ε * tOff q s c) (ε * tOff q s c')
    (uOff q s c) (uOff q s c') hkey
  refine ⟨δ / 2, by linarith, ?_⟩
  intro w hw0 hw1 μ hμpos hμle hmem
  -- the offset point is cw w + (μ·ε)·(1,q)
  have hmem' : (⟨(cw w).x + (μ * ε) * 1, (cw w).y + (μ * ε) * q⟩ : Vector2D) ∈ s.toSet := by
    have hxe : (cw w).x + (μ * ε) * 1 = (1 - w) * c.x + w * c'.x + μ * ε := by rw [hcw]; ring
    have hye : (cw w).y + (μ * ε) * q = (1 - w) * c.y + w * c'.y + μ * (ε * q) := by rw [hcw]; ring
    rw [show (⟨(cw w).x + (μ * ε) * 1, (cw w).y + (μ * ε) * q⟩ : Vector2D) =
      (⟨(1 - w) * c.x + w * c'.x + μ * ε, (1 - w) * c.y + w * c'.y + μ * (ε * q)⟩ : Vector2D)
      from Vector2D.ext hxe hye]
    exact hmem
  -- so με = tOff(cw) and the convex param u = uOff(cw) ∈ [0,1]
  have hμε : μ * ε = tOff q s (cw w) := tOff_eq_of_mem q s (cw w) hden (μ * ε) hmem'
  obtain ⟨u, hu0, hu1, hsx, hsy⟩ := hmem'
  have hueq : u = uOff q s (cw w) := uOff_eq_of_mem q s (cw w) hden (μ * ε) u hu0 hu1 hsx hsy
  -- f w = ε·tOff(cw) = ε·(με) = μ (since ε² = 1)
  have hfμ : (1 - w) * (ε * tOff q s c) + w * (ε * tOff q s c') = μ := by
    have : (1 - w) * (ε * tOff q s c) + w * (ε * tOff q s c') = ε * tOff q s (cw w) := by
      rw [htAff w]; ring
    rw [this, ← hμε]; nlinarith [hε2]
  -- g w ∈ [0,1]
  have hg0 : 0 ≤ (1 - w) * uOff q s c + w * uOff q s c' := by
    rw [← huAff w, ← hueq]; exact hu0
  have hg1 : (1 - w) * uOff q s c + w * uOff q s c' ≤ 1 := by
    rw [← huAff w, ← hueq]; exact hu1
  -- apply the bound: δ ≤ f w = μ ; but μ ≤ δ/2 < δ — contradiction.
  have hfpos : 0 < (1 - w) * (ε * tOff q s c) + w * (ε * tOff q s c') := by rw [hfμ]; exact hμpos
  have hbound := hδ w hw0 hw1 hg0 hg1 hfpos
  rw [hfμ] at hbound
  linarith

/-- **Slide clearance over all of `Lnc`.** A single `δ > 0` so that for all `w ∈ [0,1]` and
    `0 < μ ≤ δ` the slide point `c''(w) + μ·(ε,εq)` is off **every** `Lnc` segment. -/
private theorem exists_slide_clearance (G1 G2 : EvenGraph) (σ0 : LineSegment) (q ε : ℚ)
    (hε : ε = 1 ∨ ε = -1)
    (hden : ∀ s ∈ Lnc G1 G2 σ0, ((s.p2.y - s.p1.y) - q * (s.p2.x - s.p1.x)) ≠ 0)
    (c c' : Vector2D)
    (hoff : ∀ w : ℚ, 0 ≤ w → w ≤ 1 → ∀ s ∈ Lnc G1 G2 σ0,
      (⟨(1 - w) * c.x + w * c'.x, (1 - w) * c.y + w * c'.y⟩ : Vector2D) ∉ s.toSet) :
    ∃ δ : ℚ, 0 < δ ∧ ∀ w : ℚ, 0 ≤ w → w ≤ 1 → ∀ μ : ℚ, 0 < μ → μ ≤ δ →
      ∀ s ∈ Lnc G1 G2 σ0,
      (⟨(1 - w) * c.x + w * c'.x + μ * ε,
        (1 - w) * c.y + w * c'.y + μ * (ε * q)⟩ : Vector2D) ∉ s.toSet := by
  -- Induct over the list, intersecting the per-segment clearances.
  suffices h : ∀ L : List LineSegment,
      (∀ s ∈ L, ((s.p2.y - s.p1.y) - q * (s.p2.x - s.p1.x)) ≠ 0) →
      (∀ s ∈ L, ∀ w : ℚ, 0 ≤ w → w ≤ 1 →
        (⟨(1 - w) * c.x + w * c'.x, (1 - w) * c.y + w * c'.y⟩ : Vector2D) ∉ s.toSet) →
      ∃ δ : ℚ, 0 < δ ∧ ∀ w : ℚ, 0 ≤ w → w ≤ 1 → ∀ μ : ℚ, 0 < μ → μ ≤ δ →
        ∀ s ∈ L,
        (⟨(1 - w) * c.x + w * c'.x + μ * ε,
          (1 - w) * c.y + w * c'.y + μ * (ε * q)⟩ : Vector2D) ∉ s.toSet by
    exact h (Lnc G1 G2 σ0) hden (fun s hs w hw0 hw1 => hoff w hw0 hw1 s hs)
  intro L
  induction L with
  | nil => intro _ _; exact ⟨1, by norm_num, fun w _ _ μ _ _ s hs => absurd hs (List.not_mem_nil s)⟩
  | cons hd rest ih =>
    intro hden' hoff'
    obtain ⟨δ_hd, hδ_hd_pos, hδ_hd⟩ := exists_slide_clearance_seg q ε hε hd
      (hden' hd (List.mem_cons_self _ _)) c c'
      (fun w hw0 hw1 => hoff' hd (List.mem_cons_self _ _) w hw0 hw1)
    obtain ⟨δ_rest, hδ_rest_pos, hδ_rest⟩ := ih
      (fun s hs => hden' s (List.mem_cons_of_mem _ hs))
      (fun s hs => hoff' s (List.mem_cons_of_mem _ hs))
    refine ⟨min δ_hd δ_rest, lt_min hδ_hd_pos hδ_rest_pos, ?_⟩
    intro w hw0 hw1 μ hμpos hμle s hs
    rcases List.mem_cons.mp hs with rfl | hs'
    · exact hδ_hd w hw0 hw1 μ hμpos (le_trans hμle (min_le_left _ _))
    · exact hδ_rest w hw0 hw1 μ hμpos (le_trans hμle (min_le_right _ _)) s hs'

/-- A point off both boundaries is off every `Lnc` segment (since each `Lnc` segment lies in
    `∂G1 ∪ ∂G2`). -/
private theorem off_Lnc_of_off_boundaries (G1 G2 : EvenGraph) (σ0 : LineSegment)
    (z : Vector2D) (h1 : z ∉ G1.toBoundarySet) (h2 : z ∉ G2.toBoundarySet) :
    ∀ s ∈ Lnc G1 G2 σ0, z ∉ s.toSet := by
  intro s hs hzs
  rw [mem_Lnc_iff] at hs
  rcases List.mem_append.mp hs.1 with h | h
  · exact h1 (by rw [← graphRefinementSelf_boundary_eq G1]; exact ⟨s, h, hzs⟩)
  · exact h2 ⟨s, h, hzs⟩

open EvenGraphIntersectionProofs in
/-- A point strictly between `c` and `c'` (both in `σ0`'s open interior) is itself in `σ0`'s open
    interior — in particular off both endpoints of `σ0`. -/
private theorem between_open_interior (σ0 : LineSegment) (hnd : σ0.p1 ≠ σ0.p2)
    (c c' : Vector2D) (hc : c ∈ σ0.toSet) (hc1 : c ≠ σ0.p1) (hc2 : c ≠ σ0.p2)
    (hc' : c' ∈ σ0.toSet) (hc'1 : c' ≠ σ0.p1) (hc'2 : c' ≠ σ0.p2)
    (w : ℚ) (hw0 : 0 ≤ w) (hw1 : w ≤ 1) :
    let z : Vector2D := ⟨(1 - w) * c.x + w * c'.x, (1 - w) * c.y + w * c'.y⟩
    z ∈ σ0.toSet ∧ z ≠ σ0.p1 ∧ z ≠ σ0.p2 := by
  intro z
  have hzseg : z ∈ σ0.toSet :=
    segment_pq_subset_refined_seg σ0 c c' hc hc' z
      ⟨w, hw0, hw1, by show z.x = _; ring, by show z.y = _; ring⟩
  -- projOf z = (1-w)·projOf c + w·projOf c' ∈ (0, D)
  obtain ⟨hpc0, hpcD⟩ := proj_mem_of_mem_seg σ0 hnd c hc hc1 hc2
  obtain ⟨hpc'0, hpc'D⟩ := proj_mem_of_mem_seg σ0 hnd c' hc' hc'1 hc'2
  have hpz : projOf σ0 z = (1 - w) * projOf σ0 c + w * projOf σ0 c' :=
    projOf_affine σ0 c c' w z (by show z.x = _; ring) (by show z.y = _; ring)
  set D := (σ0.p2.x - σ0.p1.x) * (σ0.p2.x - σ0.p1.x)
      + (σ0.p2.y - σ0.p1.y) * (σ0.p2.y - σ0.p1.y) with hD_def
  have h1w : 0 ≤ 1 - w := by linarith
  -- lower bound by the minimum of the two positive endpoints
  have hpz0 : 0 < projOf σ0 z := by
    rw [hpz]
    have hge : (1 - w) * projOf σ0 c + w * projOf σ0 c'
        ≥ (1 - w) * min (projOf σ0 c) (projOf σ0 c') + w * min (projOf σ0 c) (projOf σ0 c') := by
      have h1 := mul_le_mul_of_nonneg_left (min_le_left (projOf σ0 c) (projOf σ0 c')) h1w
      have h2 := mul_le_mul_of_nonneg_left (min_le_right (projOf σ0 c) (projOf σ0 c')) hw0
      linarith
    have hmin : 0 < min (projOf σ0 c) (projOf σ0 c') := lt_min hpc0 hpc'0
    have : (1 - w) * min (projOf σ0 c) (projOf σ0 c') + w * min (projOf σ0 c) (projOf σ0 c')
        = min (projOf σ0 c) (projOf σ0 c') := by ring
    linarith
  have hpzD : projOf σ0 z < D := by
    rw [hpz]
    have hge : (1 - w) * (D - projOf σ0 c) + w * (D - projOf σ0 c')
        ≥ (1 - w) * min (D - projOf σ0 c) (D - projOf σ0 c')
          + w * min (D - projOf σ0 c) (D - projOf σ0 c') := by
      have h1 := mul_le_mul_of_nonneg_left
        (min_le_left (D - projOf σ0 c) (D - projOf σ0 c')) h1w
      have h2 := mul_le_mul_of_nonneg_left
        (min_le_right (D - projOf σ0 c) (D - projOf σ0 c')) hw0
      linarith
    have hmin : 0 < min (D - projOf σ0 c) (D - projOf σ0 c') :=
      lt_min (by linarith) (by linarith)
    have heq : (1 - w) * min (D - projOf σ0 c) (D - projOf σ0 c')
        + w * min (D - projOf σ0 c) (D - projOf σ0 c')
        = min (D - projOf σ0 c) (D - projOf σ0 c') := by ring
    linarith
  refine ⟨hzseg, ?_, ?_⟩
  · intro h; rw [h] at hpz0
    have hp1 : projOf σ0 σ0.p1 = 0 := by simp only [projOf]; ring
    rw [hp1] at hpz0; exact lt_irrefl _ hpz0
  · intro h; rw [h] at hpzD
    have hp2 : projOf σ0 σ0.p2 = D := by rw [hD_def, projOf]
    rw [hp2] at hpzD; exact lt_irrefl _ hpzD

/-- A `Lnc`-clearance for the whole segment `⟨p, p+μ·(ε,εq)⟩` from off-boundary `p` (`μ > 0`). -/
private theorem point_leg_off_Lnc (G1 G2 : EvenGraph) (σ0 : LineSegment) (ε q μ : ℚ)
    (hμpos : 0 < μ) (p : Vector2D)
    (hp1 : p ∉ G1.toBoundarySet) (hp2 : p ∉ G2.toBoundarySet)
    (hclear : ∀ ν : ℚ, 0 < ν → ν ≤ μ →
      ∀ s ∈ Lnc G1 G2 σ0, (⟨p.x + ν * ε, p.y + ν * (ε * q)⟩ : Vector2D) ∉ s.toSet) :
    ∀ x ∈ (LineSegment.mk p ⟨p.x + μ * ε, p.y + μ * (ε * q)⟩).toSet,
      ∀ s ∈ Lnc G1 G2 σ0, x ∉ s.toSet := by
  intro x hx s hs
  obtain ⟨t, ht0, ht1, hxx, hxy⟩ := hx
  have hxx' : x.x = p.x + (t * μ) * ε := by rw [hxx]; ring
  have hxy' : x.y = p.y + (t * μ) * (ε * q) := by rw [hxy]; ring
  have hxeq : x = (⟨p.x + (t * μ) * ε, p.y + (t * μ) * (ε * q)⟩ : Vector2D) :=
    Vector2D.ext hxx' hxy'
  rcases eq_or_lt_of_le ht0 with ht | ht
  · -- t = 0 ⟹ x = p
    have : x = p := by rw [hxeq, ← ht]; simp
    rw [this]; exact off_Lnc_of_off_boundaries G1 G2 σ0 p hp1 hp2 s hs
  · -- t > 0
    have hν0 : 0 < t * μ := mul_pos ht hμpos
    have hνle : t * μ ≤ μ := by nlinarith
    rw [hxeq]; exact hclear (t * μ) hν0 hνle s hs

/-- `sideOf σ0` of the offset point `z + μ·(ε,εq)` equals `sideOf σ0 z + μ·(ε·κ)` where
    `κ := dx·q - dy`. -/
private theorem sideOf_offset_pt (σ0 : LineSegment) (z : Vector2D) (μ ε q : ℚ) :
    sideOf σ0 (⟨z.x + μ * ε, z.y + μ * (ε * q)⟩ : Vector2D) =
      sideOf σ0 z + μ * (ε * ((σ0.p2.x - σ0.p1.x) * q - (σ0.p2.y - σ0.p1.y))) := by
  simp only [sideOf]; ring

/-- A slide-leg `Lnc`-clearance restated for the segment `⟨X+μd, Y+μd⟩`. -/
private theorem slide_leg_off_Lnc (G1 G2 : EvenGraph) (σ0 : LineSegment) (ε q μ : ℚ)
    (X Y : Vector2D)
    (hslide : ∀ w : ℚ, 0 ≤ w → w ≤ 1 → ∀ s ∈ Lnc G1 G2 σ0,
      (⟨(1 - w) * X.x + w * Y.x + μ * ε, (1 - w) * X.y + w * Y.y + μ * (ε * q)⟩ : Vector2D)
        ∉ s.toSet) :
    ∀ x ∈ (LineSegment.mk ⟨X.x + μ * ε, X.y + μ * (ε * q)⟩
        ⟨Y.x + μ * ε, Y.y + μ * (ε * q)⟩).toSet, ∀ s ∈ Lnc G1 G2 σ0, x ∉ s.toSet := by
  intro x hx s hs
  obtain ⟨w, hw0, hw1, hxx, hxy⟩ := hx
  have hxeq : x = (⟨(1 - w) * X.x + w * Y.x + μ * ε,
      (1 - w) * X.y + w * Y.y + μ * (ε * q)⟩ : Vector2D) :=
    Vector2D.ext (by rw [hxx]; ring) (by rw [hxy]; ring)
  rw [hxeq]; exact hslide w hw0 hw1 s hs

/-- **The flip-transport chain.** Connect the `A ∩ B` indicator at two clean-transversal endpoints
    `p, p'` (lying strictly on the same side `ε·κ` of `σ0`, with crossings `cp, cp'` in `σ0`'s open
    interior, where `κ := dx·q - dy ≠ 0`) by the 5-leg same-side path
    `p → p+μd → cp+μd → cp'+μd → p'+μd → p'` with `d := (ε, ε·q)`. -/
private theorem chi_eq_via_chain (G1 G2 : EvenGraph) (σ0 : LineSegment) (ε q μ : ℚ)
    (hμpos : 0 < μ)
    (p p' cp cp' : Vector2D)
    (hp1 : p ∉ G1.toBoundarySet) (hp2 : p ∉ G2.toBoundarySet)
    (hp'1 : p' ∉ G1.toBoundarySet) (hp'2 : p' ∉ G2.toBoundarySet)
    (hcp0 : sideOf σ0 cp = 0) (hcp'0 : sideOf σ0 cp' = 0)
    (hsp : 0 < sideOf σ0 p * (μ * (ε * ((σ0.p2.x - σ0.p1.x) * q - (σ0.p2.y - σ0.p1.y)))))
    (hsp' : 0 < sideOf σ0 p' * (μ * (ε * ((σ0.p2.x - σ0.p1.x) * q - (σ0.p2.y - σ0.p1.y)))))
    (hm0 : (μ * (ε * ((σ0.p2.x - σ0.p1.x) * q - (σ0.p2.y - σ0.p1.y)))) ≠ 0)
    (hclear_p : ∀ ν : ℚ, 0 < ν → ν ≤ μ → ∀ s ∈ Lnc G1 G2 σ0,
      (⟨p.x + ν * ε, p.y + ν * (ε * q)⟩ : Vector2D) ∉ s.toSet)
    (hclear_p' : ∀ ν : ℚ, 0 < ν → ν ≤ μ → ∀ s ∈ Lnc G1 G2 σ0,
      (⟨p'.x + ν * ε, p'.y + ν * (ε * q)⟩ : Vector2D) ∉ s.toSet)
    (hslide_pcp : ∀ w : ℚ, 0 ≤ w → w ≤ 1 → ∀ s ∈ Lnc G1 G2 σ0,
      (⟨(1 - w) * p.x + w * cp.x + μ * ε, (1 - w) * p.y + w * cp.y + μ * (ε * q)⟩ : Vector2D)
        ∉ s.toSet)
    (hslide_cc : ∀ w : ℚ, 0 ≤ w → w ≤ 1 → ∀ s ∈ Lnc G1 G2 σ0,
      (⟨(1 - w) * cp.x + w * cp'.x + μ * ε, (1 - w) * cp.y + w * cp'.y + μ * (ε * q)⟩ : Vector2D)
        ∉ s.toSet)
    (hslide_cp' : ∀ w : ℚ, 0 ≤ w → w ≤ 1 → ∀ s ∈ Lnc G1 G2 σ0,
      (⟨(1 - w) * cp'.x + w * p'.x + μ * ε, (1 - w) * cp'.y + w * p'.y + μ * (ε * q)⟩ : Vector2D)
        ∉ s.toSet) :
    (p ∈ G1.interior ∧ p ∈ G2.interior) = (p' ∈ G1.interior ∧ p' ∈ G2.interior) := by
  set κ := (σ0.p2.x - σ0.p1.x) * q - (σ0.p2.y - σ0.p1.y) with hκ_def
  set m := μ * (ε * κ) with hm_def
  -- offset points
  set Pp : Vector2D := ⟨p.x + μ * ε, p.y + μ * (ε * q)⟩ with hPp
  set Pcp : Vector2D := ⟨cp.x + μ * ε, cp.y + μ * (ε * q)⟩ with hPcp
  set Pcp' : Vector2D := ⟨cp'.x + μ * ε, cp'.y + μ * (ε * q)⟩ with hPcp'
  set Pp' : Vector2D := ⟨p'.x + μ * ε, p'.y + μ * (ε * q)⟩ with hPp'
  -- sideOf values
  have hSPp : sideOf σ0 Pp = sideOf σ0 p + m := by rw [hPp, hm_def]; exact sideOf_offset_pt σ0 p μ ε q
  have hSPcp : sideOf σ0 Pcp = m := by
    rw [hPcp]; rw [sideOf_offset_pt σ0 cp μ ε q, hcp0, hm_def]; ring
  have hSPcp' : sideOf σ0 Pcp' = m := by
    rw [hPcp']; rw [sideOf_offset_pt σ0 cp' μ ε q, hcp'0, hm_def]; ring
  have hSPp' : sideOf σ0 Pp' = sideOf σ0 p' + m := by
    rw [hPp', hm_def]; exact sideOf_offset_pt σ0 p' μ ε q
  -- abbreviations for the two transversal-endpoint side values
  set Sp := sideOf σ0 p with hSp_def
  set Sp' := sideOf σ0 p' with hSp'_def
  have hSpm : 0 < Sp * m := by rw [hSp_def, hm_def]; exact hsp
  have hSp'm : 0 < Sp' * m := by rw [hSp'_def, hm_def]; exact hsp'
  have hmm : 0 < m * m := by
    rcases lt_trichotomy m 0 with h | h | h
    · exact mul_pos_of_neg_of_neg h h
    · exact absurd h hm0
    · exact mul_pos h h
  -- Leg 1 : ⟨p, Pp⟩
  have hleg1 : (p ∈ G1.interior ∧ p ∈ G2.interior) = (Pp ∈ G1.interior ∧ Pp ∈ G2.interior) := by
    refine flip_eq_of_same_side_off_Lnc G1 G2 σ0 p Pp ?_ ?_
    · rw [hSPp]; nlinarith [hSpm, mul_self_nonneg Sp]
    · exact point_leg_off_Lnc G1 G2 σ0 ε q μ hμpos p hp1 hp2 hclear_p
  -- Leg 2 : ⟨Pp, Pcp⟩  (slide of base ⟨p, cp⟩)
  have hleg2 : (Pp ∈ G1.interior ∧ Pp ∈ G2.interior) =
      (Pcp ∈ G1.interior ∧ Pcp ∈ G2.interior) := by
    refine flip_eq_of_same_side_off_Lnc G1 G2 σ0 Pp Pcp ?_ ?_
    · rw [hSPp, hSPcp]; nlinarith [hSpm, hmm]
    · exact slide_leg_off_Lnc G1 G2 σ0 ε q μ p cp hslide_pcp
  -- Leg 3 : ⟨Pcp, Pcp'⟩  (slide of base ⟨cp, cp'⟩)
  have hleg3 : (Pcp ∈ G1.interior ∧ Pcp ∈ G2.interior) =
      (Pcp' ∈ G1.interior ∧ Pcp' ∈ G2.interior) := by
    refine flip_eq_of_same_side_off_Lnc G1 G2 σ0 Pcp Pcp' ?_ ?_
    · rw [hSPcp, hSPcp']; exact hmm
    · exact slide_leg_off_Lnc G1 G2 σ0 ε q μ cp cp' hslide_cc
  -- Leg 4 : ⟨Pcp', Pp'⟩  (slide of base ⟨cp', p'⟩)
  have hleg4 : (Pcp' ∈ G1.interior ∧ Pcp' ∈ G2.interior) =
      (Pp' ∈ G1.interior ∧ Pp' ∈ G2.interior) := by
    refine flip_eq_of_same_side_off_Lnc G1 G2 σ0 Pcp' Pp' ?_ ?_
    · rw [hSPcp', hSPp']; nlinarith [hSp'm, hmm]
    · exact slide_leg_off_Lnc G1 G2 σ0 ε q μ cp' p' hslide_cp'
  -- Leg 5 : ⟨Pp', p'⟩
  have hleg5 : (Pp' ∈ G1.interior ∧ Pp' ∈ G2.interior) =
      (p' ∈ G1.interior ∧ p' ∈ G2.interior) := by
    refine (flip_eq_of_same_side_off_Lnc G1 G2 σ0 p' Pp' ?_ ?_).symm
    · rw [hSPp']; nlinarith [hSp'm, mul_self_nonneg Sp']
    · exact point_leg_off_Lnc G1 G2 σ0 ε q μ hμpos p' hp'1 hp'2 hclear_p'
  rw [hleg1, hleg2, hleg3, hleg4, hleg5]

/-- For a chosen sign `ε = ±1` and good slope `q` (κ ≠ 0), an endpoint `e` strictly off `σ0`'s
    line on the `ε·κ` side is on the `ε·κ` side: `0 < sideOf σ0 e * (ε·κ)`. We package the sign
    choice: given `e` off the line, the sign `ε := if 0 < sideOf σ0 e * κ then 1 else -1` works. -/
private theorem sign_choice (σ0 : LineSegment) (q : ℚ) (e : Vector2D)
    (hse : sideOf σ0 e ≠ 0)
    (hκ : (σ0.p2.x - σ0.p1.x) * q - (σ0.p2.y - σ0.p1.y) ≠ 0) :
    ∃ ε : ℚ, (ε = 1 ∨ ε = -1) ∧
      0 < sideOf σ0 e * (ε * ((σ0.p2.x - σ0.p1.x) * q - (σ0.p2.y - σ0.p1.y))) := by
  set κ := (σ0.p2.x - σ0.p1.x) * q - (σ0.p2.y - σ0.p1.y) with hκ_def
  by_cases h : 0 < sideOf σ0 e * κ
  · exact ⟨1, Or.inl rfl, by rw [one_mul]; exact h⟩
  · refine ⟨-1, Or.inr rfl, ?_⟩
    have hne : sideOf σ0 e * κ ≠ 0 := mul_ne_zero hse hκ
    have hlt : sideOf σ0 e * κ < 0 := lt_of_le_of_ne (not_lt.mp h) hne
    nlinarith [hlt]

open EvenGraphIntersectionProofs in
/-- The whole transversal base `⟨p, cp⟩` (from a clean transversal `⟨p, p_other⟩` crossing `σ0` at
    `cp`, with `cp` off `Lnc`) avoids every `Lnc` segment. -/
private theorem transversal_base_off_Lnc (G1 G2 : EvenGraph) (σ0 : LineSegment)
    (p p_other cp : Vector2D)
    (hcp_off : ∀ s ∈ Lnc G1 G2 σ0, cp ∉ s.toSet)
    (hp_mem : p ∈ (LineSegment.mk p p_other).toSet)
    (hcp_mem : cp ∈ (LineSegment.mk p p_other).toSet)
    (hclean : ∀ x ∈ (LineSegment.mk p p_other).toSet,
        (x ∈ G1.toBoundarySet ∨ x ∈ G2.toBoundarySet) → x = cp) :
    ∀ z ∈ (LineSegment.mk p cp).toSet, ∀ s ∈ Lnc G1 G2 σ0, z ∉ s.toSet := by
  intro z hz_pcp s hs hzs
  have hz_ab : z ∈ (LineSegment.mk p p_other).toSet :=
    segment_pq_subset_refined_seg (LineSegment.mk p p_other) p cp hp_mem hcp_mem z hz_pcp
  -- z ∈ s.toSet ⊆ ∂G1 ∪ ∂G2 ⟹ z = cp ⟹ cp ∈ s, contradiction.
  rw [mem_Lnc_iff] at hs
  have hz_bd : z ∈ G1.toBoundarySet ∨ z ∈ G2.toBoundarySet := by
    rcases List.mem_append.mp hs.1 with h | h
    · exact Or.inl (by rw [← graphRefinementSelf_boundary_eq G1]; exact ⟨s, h, hzs⟩)
    · exact Or.inr ⟨s, h, hzs⟩
  have hzcp : z = cp := hclean z hz_ab hz_bd
  exact hcp_off s ((mem_Lnc_iff G1 G2 σ0 s).mpr hs) (hzcp ▸ hzs)

/-- Convert a "segment off `Lnc`" fact to the `(1-w)·X + w·Y` parametrized form needed by the
    slide clearance, for either orientation of the base segment. -/
private theorem seg_off_to_param (G1 G2 : EvenGraph) (σ0 : LineSegment) (X Y : Vector2D)
    (hseg : ∀ z ∈ (LineSegment.mk X Y).toSet, ∀ s ∈ Lnc G1 G2 σ0, z ∉ s.toSet) :
    ∀ w : ℚ, 0 ≤ w → w ≤ 1 → ∀ s ∈ Lnc G1 G2 σ0,
      (⟨(1 - w) * X.x + w * Y.x, (1 - w) * X.y + w * Y.y⟩ : Vector2D) ∉ s.toSet := by
  intro w hw0 hw1 s hs
  exact hseg _ ⟨w, hw0, hw1, rfl, rfl⟩ s hs

open EvenGraphIntersectionProofs in
/-- **One transport chain.** For a fixed good slope `q` (κ ≠ 0, `Lnc`-denominators nonzero) and a
    sign `ε = ±1`, transport the `A ∩ B` indicator from a clean-transversal endpoint `p`
    (transversal `⟨p, p_other⟩` crossing `σ0`'s open interior at `c`) to another endpoint `p'`
    (transversal `⟨p', p_other'⟩` crossing at `c'`), assuming both `p, p'` lie strictly on the
    `ε·κ` side of `σ0`. -/
private theorem one_chain (G1 G2 : EvenGraph) (σ0 : LineSegment)
    (hσ0 : σ0 ∈ (arr G1 G2).segments) (hnd : σ0.p1 ≠ σ0.p2) (q ε : ℚ) (hε : ε = 1 ∨ ε = -1)
    (hκ : (σ0.p2.x - σ0.p1.x) * q - (σ0.p2.y - σ0.p1.y) ≠ 0)
    (hden : ∀ s ∈ Lnc G1 G2 σ0, ((s.p2.y - s.p1.y) - q * (s.p2.x - s.p1.x)) ≠ 0)
    (p p_other c p' p_other' c' : Vector2D)
    (hp1 : p ∉ G1.toBoundarySet) (hp2 : p ∉ G2.toBoundarySet)
    (hp'1 : p' ∉ G1.toBoundarySet) (hp'2 : p' ∉ G2.toBoundarySet)
    (hc : c ∈ σ0.toSet) (hc1 : c ≠ σ0.p1) (hc2 : c ≠ σ0.p2)
    (hc' : c' ∈ σ0.toSet) (hc'1 : c' ≠ σ0.p1) (hc'2 : c' ≠ σ0.p2)
    (hcab : c ∈ (LineSegment.mk p p_other).toSet)
    (hclean : ∀ x ∈ (LineSegment.mk p p_other).toSet,
        (x ∈ G1.toBoundarySet ∨ x ∈ G2.toBoundarySet) → x = c)
    (hc'ab : c' ∈ (LineSegment.mk p' p_other').toSet)
    (hclean' : ∀ x ∈ (LineSegment.mk p' p_other').toSet,
        (x ∈ G1.toBoundarySet ∨ x ∈ G2.toBoundarySet) → x = c')
    (hsp : 0 < sideOf σ0 p * (ε * ((σ0.p2.x - σ0.p1.x) * q - (σ0.p2.y - σ0.p1.y))))
    (hsp' : 0 < sideOf σ0 p' * (ε * ((σ0.p2.x - σ0.p1.x) * q - (σ0.p2.y - σ0.p1.y)))) :
    (p ∈ G1.interior ∧ p ∈ G2.interior) = (p' ∈ G1.interior ∧ p' ∈ G2.interior) := by
  -- crossings off Lnc
  have hc_off : ∀ s ∈ Lnc G1 G2 σ0, c ∉ s.toSet := crossing_off_Lnc G1 G2 σ0 hσ0 c hc hc1 hc2
  have hc'_off : ∀ s ∈ Lnc G1 G2 σ0, c' ∉ s.toSet := crossing_off_Lnc G1 G2 σ0 hσ0 c' hc' hc'1 hc'2
  -- base segments off Lnc
  have hp_mem : p ∈ (LineSegment.mk p p_other).toSet := seg_p1_mem _
  have hp'_mem : p' ∈ (LineSegment.mk p' p_other').toSet := seg_p1_mem _
  have hbase_pc : ∀ z ∈ (LineSegment.mk p c).toSet, ∀ s ∈ Lnc G1 G2 σ0, z ∉ s.toSet :=
    transversal_base_off_Lnc G1 G2 σ0 p p_other c hc_off hp_mem hcab hclean
  have hbase_p'c' : ∀ z ∈ (LineSegment.mk p' c').toSet, ∀ s ∈ Lnc G1 G2 σ0, z ∉ s.toSet :=
    transversal_base_off_Lnc G1 G2 σ0 p' p_other' c' hc'_off hp'_mem hc'ab hclean'
  -- ⟨c', p'⟩ off Lnc (reverse of ⟨p', c'⟩)
  have hbase_c'p' : ∀ z ∈ (LineSegment.mk c' p').toSet, ∀ s ∈ Lnc G1 G2 σ0, z ∉ s.toSet := by
    intro z hz; rw [← lineSegment_toSet_comm] at hz; exact hbase_p'c' z hz
  -- ⟨c, c'⟩ off Lnc (open interior of σ0)
  have hbase_cc : ∀ z ∈ (LineSegment.mk c c').toSet, ∀ s ∈ Lnc G1 G2 σ0, z ∉ s.toSet := by
    intro z hz s hs
    obtain ⟨w, hw0, hw1, hzx, hzy⟩ := hz
    have := between_open_interior σ0 hnd c c' hc hc1 hc2 hc' hc'1 hc'2 w hw0 hw1
    obtain ⟨hzseg, hzn1, hzn2⟩ := this
    have hzeq : z = (⟨(1 - w) * c.x + w * c'.x, (1 - w) * c.y + w * c'.y⟩ : Vector2D) :=
      Vector2D.ext hzx hzy
    rw [hzeq]
    exact crossing_off_Lnc G1 G2 σ0 hσ0 _ hzseg hzn1 hzn2 s hs
  -- clearances
  obtain ⟨δ1, hδ1pos, hδ1⟩ := exists_point_clearance G1 G2 σ0 ε q hε hden p
  obtain ⟨δ2, hδ2pos, hδ2⟩ := exists_point_clearance G1 G2 σ0 ε q hε hden p'
  obtain ⟨δ3, hδ3pos, hδ3⟩ := exists_slide_clearance G1 G2 σ0 q ε hε hden p c
    (seg_off_to_param G1 G2 σ0 p c hbase_pc)
  obtain ⟨δ4, hδ4pos, hδ4⟩ := exists_slide_clearance G1 G2 σ0 q ε hε hden c c'
    (seg_off_to_param G1 G2 σ0 c c' hbase_cc)
  obtain ⟨δ5, hδ5pos, hδ5⟩ := exists_slide_clearance G1 G2 σ0 q ε hε hden c' p'
    (seg_off_to_param G1 G2 σ0 c' p' hbase_c'p')
  set μ := min δ1 (min δ2 (min δ3 (min δ4 δ5))) with hμ_def
  have hμpos : 0 < μ := lt_min hδ1pos (lt_min hδ2pos (lt_min hδ3pos (lt_min hδ4pos hδ5pos)))
  have hμ1 : μ ≤ δ1 := min_le_left _ _
  have hμ2 : μ ≤ δ2 := le_trans (min_le_right _ _) (min_le_left _ _)
  have hμ3 : μ ≤ δ3 := le_trans (min_le_right _ _) (le_trans (min_le_right _ _) (min_le_left _ _))
  have hμ4 : μ ≤ δ4 := le_trans (min_le_right _ _) (le_trans (min_le_right _ _)
    (le_trans (min_le_right _ _) (min_le_left _ _)))
  have hμ5 : μ ≤ δ5 := le_trans (min_le_right _ _) (le_trans (min_le_right _ _)
    (le_trans (min_le_right _ _) (min_le_right _ _)))
  -- side facts and m ≠ 0
  have hc0 : sideOf σ0 c = 0 := (sideOf_eq_zero_iff σ0 c).mpr (toSet_subset_lineOf σ0 hc)
  have hc'0 : sideOf σ0 c' = 0 := (sideOf_eq_zero_iff σ0 c').mpr (toSet_subset_lineOf σ0 hc')
  have hε0 : ε ≠ 0 := by rcases hε with h | h <;> rw [h] <;> norm_num
  have hm0 : (μ * (ε * ((σ0.p2.x - σ0.p1.x) * q - (σ0.p2.y - σ0.p1.y)))) ≠ 0 :=
    mul_ne_zero (ne_of_gt hμpos) (mul_ne_zero hε0 hκ)
  have hspμ : 0 < sideOf σ0 p * (μ * (ε * ((σ0.p2.x - σ0.p1.x) * q - (σ0.p2.y - σ0.p1.y)))) := by
    have heq : sideOf σ0 p * (μ * (ε * ((σ0.p2.x - σ0.p1.x) * q - (σ0.p2.y - σ0.p1.y)))) =
        μ * (sideOf σ0 p * (ε * ((σ0.p2.x - σ0.p1.x) * q - (σ0.p2.y - σ0.p1.y)))) := by ring
    rw [heq]; exact mul_pos hμpos hsp
  have hsp'μ : 0 < sideOf σ0 p' * (μ * (ε * ((σ0.p2.x - σ0.p1.x) * q - (σ0.p2.y - σ0.p1.y)))) := by
    have heq : sideOf σ0 p' * (μ * (ε * ((σ0.p2.x - σ0.p1.x) * q - (σ0.p2.y - σ0.p1.y)))) =
        μ * (sideOf σ0 p' * (ε * ((σ0.p2.x - σ0.p1.x) * q - (σ0.p2.y - σ0.p1.y)))) := by ring
    rw [heq]; exact mul_pos hμpos hsp'
  -- assemble the chain
  refine chi_eq_via_chain G1 G2 σ0 ε q μ hμpos p p' c c' hp1 hp2 hp'1 hp'2 hc0 hc'0
    hspμ hsp'μ hm0 ?_ ?_ ?_ ?_ ?_
  · intro ν hν0 hνle s hs; exact hδ1 ν hν0 (le_trans hνle hμ1) s hs
  · intro ν hν0 hνle s hs; exact hδ2 ν hν0 (le_trans hνle hμ2) s hs
  · intro w hw0 hw1 s hs; exact hδ3 w hw0 hw1 μ hμpos hμ3 s hs
  · intro w hw0 hw1 s hs; exact hδ4 w hw0 hw1 μ hμpos hμ4 s hs
  · intro w hw0 hw1 s hs; exact hδ5 w hw0 hw1 μ hμpos hμ5 s hs

open EvenGraphIntersectionProofs in
/-- **Well-definedness of the flip** (geometric heart of `onInterBoundary_iff_flip`).
    For a shared segment `σ0 ∈ arr G1 G2` and two *clean transversals* through `σ0`'s open
    interior — `(a, b)` crossing at `c` and `(q1, q2)` crossing at `c'`, each meeting
    `∂G1 ∪ ∂G2` only at its own crossing point — the `A ∩ B` flip is the same:
    `((a∈A∧a∈B) ≠ (b∈A∧b∈B)) ↔ ((q1∈A∧q1∈B) ≠ (q2∈A∧q2∈B))`.

    See `RemoveFinitenessInformalProof.md` §4. -/
private theorem flip_two_chains (G1 G2 : EvenGraph) (σ0 : LineSegment)
    (hσ0 : σ0 ∈ (arr G1 G2).segments)
    (hnd : σ0.p1 ≠ σ0.p2)
    (hsub1 : σ0.toSet ⊆ G1.toBoundarySet)
    (a b c : Vector2D)
    (ha1 : a ∉ G1.toBoundarySet) (ha2 : a ∉ G2.toBoundarySet)
    (hb1 : b ∉ G1.toBoundarySet) (hb2 : b ∉ G2.toBoundarySet)
    (hc : c ∈ σ0.toSet) (hc1 : c ≠ σ0.p1) (hc2 : c ≠ σ0.p2)
    (hcab : c ∈ (LineSegment.mk a b).toSet)
    (hclean : ∀ x ∈ (LineSegment.mk a b).toSet,
        (x ∈ G1.toBoundarySet ∨ x ∈ G2.toBoundarySet) → x = c)
    (q1 q2 c' : Vector2D)
    (hq11 : q1 ∉ G1.toBoundarySet) (hq12 : q1 ∉ G2.toBoundarySet)
    (hq21 : q2 ∉ G1.toBoundarySet) (hq22 : q2 ∉ G2.toBoundarySet)
    (hc' : c' ∈ σ0.toSet) (hc'1 : c' ≠ σ0.p1) (hc'2 : c' ≠ σ0.p2)
    (hc'ab : c' ∈ (LineSegment.mk q1 q2).toSet)
    (hclean' : ∀ x ∈ (LineSegment.mk q1 q2).toSet,
        (x ∈ G1.toBoundarySet ∨ x ∈ G2.toBoundarySet) → x = c')
    (hsame : 0 < sideOf σ0 a * sideOf σ0 q1) :
    (a ∈ G1.interior ∧ a ∈ G2.interior) = (q1 ∈ G1.interior ∧ q1 ∈ G2.interior) ∧
    (b ∈ G1.interior ∧ b ∈ G2.interior) = (q2 ∈ G1.interior ∧ q2 ∈ G2.interior) := by
  -- good slope
  obtain ⟨q, hκ, hden⟩ := exists_good_slope G1 G2 σ0 hnd
  set κ := (σ0.p2.x - σ0.p1.x) * q - (σ0.p2.y - σ0.p1.y) with hκ_def
  -- opposite-side products
  have hab_opp : sideOf σ0 a * sideOf σ0 b < 0 :=
    clean_transversal_opposite_sides G1 G2 σ0 hnd hsub1 a b c ha1 hb1 hc hc1 hc2 hcab hclean
  have hq_opp : sideOf σ0 q1 * sideOf σ0 q2 < 0 :=
    clean_transversal_opposite_sides G1 G2 σ0 hnd hsub1 q1 q2 c' hq11 hq21 hc' hc'1 hc'2 hc'ab hclean'
  have hsa : sideOf σ0 a ≠ 0 := fun h => by simp [h] at hab_opp
  have hsb : sideOf σ0 b ≠ 0 := fun h => by simp [h] at hab_opp
  -- comm versions for b- and q2-transversals
  have hcba : c ∈ (LineSegment.mk b a).toSet := by rw [← lineSegment_toSet_comm]; exact hcab
  have hcleanba : ∀ x ∈ (LineSegment.mk b a).toSet,
      (x ∈ G1.toBoundarySet ∨ x ∈ G2.toBoundarySet) → x = c := by
    intro x hx; rw [← lineSegment_toSet_comm] at hx; exact hclean x hx
  have hc'q2q1 : c' ∈ (LineSegment.mk q2 q1).toSet := by rw [← lineSegment_toSet_comm]; exact hc'ab
  have hclean'q2q1 : ∀ x ∈ (LineSegment.mk q2 q1).toSet,
      (x ∈ G1.toBoundarySet ∨ x ∈ G2.toBoundarySet) → x = c' := by
    intro x hx; rw [← lineSegment_toSet_comm] at hx; exact hclean' x hx
  -- sign choices
  obtain ⟨εa, hεa, hsaε⟩ := sign_choice σ0 q a hsa hκ
  obtain ⟨εb, hεb, hsbε⟩ := sign_choice σ0 q b hsb hκ
  -- q1 on a's side
  have hsq1ε : 0 < sideOf σ0 q1 * (εa * κ) := by
    have hsa2 : 0 < sideOf σ0 a * sideOf σ0 a := mul_self_pos.mpr hsa
    have hprod : 0 < (sideOf σ0 a * sideOf σ0 a) * (sideOf σ0 q1 * (εa * κ)) := by
      have hp := mul_pos hsame hsaε
      have heq : (sideOf σ0 a * sideOf σ0 q1) * (sideOf σ0 a * (εa * κ)) =
          (sideOf σ0 a * sideOf σ0 a) * (sideOf σ0 q1 * (εa * κ)) := by ring
      rwa [heq] at hp
    exact (mul_pos_iff_of_pos_left hsa2).mp hprod
  -- q2 on b's side : first q2 ~ b
  have hbq2 : 0 < sideOf σ0 b * sideOf σ0 q2 := by
    -- (Sa·Sb)<0, (Sq1·Sq2)<0, (Sa·Sq1)>0 ⟹ Sb·Sq2>0
    have hp := mul_pos_of_neg_of_neg hab_opp hq_opp
    have heq : (sideOf σ0 a * sideOf σ0 b) * (sideOf σ0 q1 * sideOf σ0 q2) =
        (sideOf σ0 a * sideOf σ0 q1) * (sideOf σ0 b * sideOf σ0 q2) := by ring
    rw [heq] at hp
    exact (mul_pos_iff_of_pos_left hsame).mp hp
  have hsq2ε : 0 < sideOf σ0 q2 * (εb * κ) := by
    have hsb2 : 0 < sideOf σ0 b * sideOf σ0 b := mul_self_pos.mpr hsb
    have hprod : 0 < (sideOf σ0 b * sideOf σ0 b) * (sideOf σ0 q2 * (εb * κ)) := by
      have hp := mul_pos hbq2 hsbε
      have heq : (sideOf σ0 b * sideOf σ0 q2) * (sideOf σ0 b * (εb * κ)) =
          (sideOf σ0 b * sideOf σ0 b) * (sideOf σ0 q2 * (εb * κ)) := by ring
      rwa [heq] at hp
    exact (mul_pos_iff_of_pos_left hsb2).mp hprod
  -- the two chains
  refine ⟨?_, ?_⟩
  · exact one_chain G1 G2 σ0 hσ0 hnd q εa hεa hκ hden a b c q1 q2 c'
      ha1 ha2 hq11 hq12 hc hc1 hc2 hc' hc'1 hc'2 hcab hclean hc'ab hclean' hsaε hsq1ε
  · exact one_chain G1 G2 σ0 hσ0 hnd q εb hεb hκ hden b a c q2 q1 c'
      hb1 hb2 hq21 hq22 hc hc1 hc2 hc' hc'1 hc'2 hcba hcleanba hc'q2q1 hclean'q2q1 hsbε hsq2ε

open EvenGraphIntersectionProofs in
private theorem flip_well_defined (G1 G2 : EvenGraph) (σ0 : LineSegment)
    (hσ0 : σ0 ∈ (arr G1 G2).segments) (hshared : IsShared G2 σ0)
    (a b c : Vector2D)
    (ha1 : a ∉ G1.toBoundarySet) (ha2 : a ∉ G2.toBoundarySet)
    (hb1 : b ∉ G1.toBoundarySet) (hb2 : b ∉ G2.toBoundarySet)
    (hc : c ∈ σ0.toSet) (hc1 : c ≠ σ0.p1) (hc2 : c ≠ σ0.p2)
    (hcab : c ∈ (LineSegment.mk a b).toSet)
    (hclean : ∀ x ∈ (LineSegment.mk a b).toSet,
        (x ∈ G1.toBoundarySet ∨ x ∈ G2.toBoundarySet) → x = c)
    (q1 q2 c' : Vector2D)
    (hq11 : q1 ∉ G1.toBoundarySet) (hq12 : q1 ∉ G2.toBoundarySet)
    (hq21 : q2 ∉ G1.toBoundarySet) (hq22 : q2 ∉ G2.toBoundarySet)
    (hc' : c' ∈ σ0.toSet) (hc'1 : c' ≠ σ0.p1) (hc'2 : c' ≠ σ0.p2)
    (hc'ab : c' ∈ (LineSegment.mk q1 q2).toSet)
    (hclean' : ∀ x ∈ (LineSegment.mk q1 q2).toSet,
        (x ∈ G1.toBoundarySet ∨ x ∈ G2.toBoundarySet) → x = c') :
    ((a ∈ G1.interior ∧ a ∈ G2.interior) ≠ (b ∈ G1.interior ∧ b ∈ G2.interior)) ↔
      ((q1 ∈ G1.interior ∧ q1 ∈ G2.interior) ≠ (q2 ∈ G1.interior ∧ q2 ∈ G2.interior)) := by
  -- Basic facts.
  have hnd : σ0.p1 ≠ σ0.p2 := (arr G1 G2).segments_nondegenerate σ0 hσ0
  have hsub1 : σ0.toSet ⊆ G1.toBoundarySet := by
    intro z hz; rw [← arr_boundary_eq G1 G2]; exact ⟨σ0, hσ0, hz⟩
  -- a, b strictly on opposite sides of σ0's line.
  have hab_opp : sideOf σ0 a * sideOf σ0 b < 0 :=
    clean_transversal_opposite_sides G1 G2 σ0 hnd hsub1 a b c ha1 hb1 hc hc1 hc2 hcab hclean
  have hq_opp : sideOf σ0 q1 * sideOf σ0 q2 < 0 :=
    clean_transversal_opposite_sides G1 G2 σ0 hnd hsub1 q1 q2 c' hq11 hq21 hc' hc'1 hc'2 hc'ab hclean'
  -- Align: WLOG sideOf a and sideOf q1 have the same sign.
  by_cases hsame : 0 < sideOf σ0 a * sideOf σ0 q1
  · obtain ⟨haq1, hbq2⟩ := flip_two_chains G1 G2 σ0 hσ0 hnd hsub1 a b c ha1 ha2 hb1 hb2
      hc hc1 hc2 hcab hclean q1 q2 c' hq11 hq12 hq21 hq22 hc' hc'1 hc'2 hc'ab hclean' hsame
    rw [haq1, hbq2]
  · -- sideOf a and sideOf q1 opposite ⟹ sideOf a and sideOf q2 same sign; swap q1 ↔ q2.
    have hsa : sideOf σ0 a ≠ 0 := fun h => by simp [h] at hab_opp
    have hsq1 : sideOf σ0 q1 ≠ 0 := by
      intro h; rw [h, zero_mul] at hq_opp; exact lt_irrefl _ hq_opp
    have hsame' : 0 < sideOf σ0 a * sideOf σ0 q2 := by
      have hle : sideOf σ0 a * sideOf σ0 q1 ≤ 0 := not_lt.mp hsame
      have hne : sideOf σ0 a * sideOf σ0 q1 ≠ 0 := mul_ne_zero hsa hsq1
      have hneg : sideOf σ0 a * sideOf σ0 q1 < 0 := lt_of_le_of_ne hle hne
      have hq1sq : 0 < sideOf σ0 q1 * sideOf σ0 q1 := mul_self_pos.mpr hsq1
      nlinarith [mul_pos (neg_pos.mpr hneg) (neg_pos.mpr hq_opp), hq1sq]
    have hc'ab2 : c' ∈ (LineSegment.mk q2 q1).toSet := by
      rw [← lineSegment_toSet_comm]; exact hc'ab
    have hclean'2 : ∀ x ∈ (LineSegment.mk q2 q1).toSet,
        (x ∈ G1.toBoundarySet ∨ x ∈ G2.toBoundarySet) → x = c' := by
      intro x hx; rw [← lineSegment_toSet_comm] at hx; exact hclean' x hx
    obtain ⟨haq2, hbq1⟩ := flip_two_chains G1 G2 σ0 hσ0 hnd hsub1 a b c ha1 ha2 hb1 hb2
      hc hc1 hc2 hcab hclean q2 q1 c' hq21 hq22 hq11 hq12 hc' hc'1 hc'2 hc'ab2 hclean'2 hsame'
    rw [haq2, hbq1]
    exact ne_comm

open EvenGraphIntersectionProofs in
/-- **Reusable characterisation of `onInterBoundary`.** For a shared segment
    `σ0 ∈ arr G1 G2` (so `σ0.toSet ⊆ ∂G1 ∩ ∂G2`) and *any clean transversal* `(a, b, c)`
    through `σ0`'s open interior, `onInterBoundary G1 G2 (canonSeg σ0)` holds iff the
    `A ∩ B` indicator flips between `a` and `b` (with `A := G1.interior`, `B := G2.interior`). -/
theorem onInterBoundary_iff_flip (G1 G2 : EvenGraph) (σ0 : LineSegment)
    (hσ0 : σ0 ∈ (arr G1 G2).segments) (hshared : IsShared G2 σ0)
    (a b c : Vector2D)
    (ha1 : a ∉ G1.toBoundarySet) (ha2 : a ∉ G2.toBoundarySet)
    (hb1 : b ∉ G1.toBoundarySet) (hb2 : b ∉ G2.toBoundarySet)
    (hc : c ∈ σ0.toSet) (hc1 : c ≠ σ0.p1) (hc2 : c ≠ σ0.p2)
    (hcab : c ∈ (LineSegment.mk a b).toSet)
    (hclean : ∀ x ∈ (LineSegment.mk a b).toSet,
        (x ∈ G1.toBoundarySet ∨ x ∈ G2.toBoundarySet) → x = c) :
    onInterBoundary G1 G2 (canonSeg σ0) ↔
      ((a ∈ G1.interior ∧ a ∈ G2.interior) ≠ (b ∈ G1.interior ∧ b ∈ G2.interior)) := by
  -- endpoints of `canonSeg σ0` are σ0's endpoints (possibly swapped)
  obtain ⟨hcne1, hcne2⟩ := canonSeg_ne_endpoints σ0 c hc1 hc2
  have hc_canon : c ∈ (canonSeg σ0).toSet := by rw [canonSeg_toSet]; exact hc
  constructor
  · -- (→): from a witness, transport the flip to (a, b) via `flip_well_defined`.
    rintro ⟨q1, q2, hq11, hq12, hq21, hq22, ⟨c', hc'mem, hc'1, hc'2, hc'ab, hclean'⟩, hflip⟩
    -- move c' off canonSeg σ0 back to σ0
    have hc'σ0 : c' ∈ σ0.toSet := by rw [← canonSeg_toSet σ0]; exact hc'mem
    obtain ⟨hc'ne1, hc'ne2⟩ : c' ≠ σ0.p1 ∧ c' ≠ σ0.p2 := by
      -- hc'1 : c' ≠ (canonSeg σ0).p1, hc'2 : c' ≠ (canonSeg σ0).p2
      revert hc'1 hc'2; unfold canonSeg; split
      · intro h1 h2; exact ⟨h1, h2⟩
      · intro h1 h2; exact ⟨h2, h1⟩
    -- the witness's flip in ≠ form
    have hflip' : (q1 ∈ G1.interior ∧ q1 ∈ G2.interior) ≠
        (q2 ∈ G1.interior ∧ q2 ∈ G2.interior) :=
      (iff_not_eq_ne _ _).mp hflip
    -- transport via flip_well_defined
    exact (flip_well_defined G1 G2 σ0 hσ0 hshared a b c ha1 ha2 hb1 hb2 hc hc1 hc2 hcab hclean
      q1 q2 c' hq11 hq12 hq21 hq22 hc'σ0 hc'ne1 hc'ne2 hc'ab hclean').mpr hflip'
  · -- (←): provide the witness (q1 := a, q2 := b, inner witness c).
    intro hflip
    refine ⟨a, b, ha1, ha2, hb1, hb2, ⟨c, hc_canon, hcne1, hcne2, hcab, hclean⟩, ?_⟩
    -- turn `P ≠ Q` into `P ↔ ¬Q`
    exact (iff_not_eq_ne _ _).mpr hflip

open EvenGraphIntersectionProofs in
/-- Every point of the "far→near" transversal `⟨rayPt r t', r.origin⟩` is a ray point at some
    parameter `s ∈ [0, t']`. -/
private theorem mem_far_near_seg (r : Ray) (t' : ℚ) (ht' : 0 ≤ t') (x : Vector2D)
    (hx : x ∈ (LineSegment.mk (rayPt r t') r.origin).toSet) :
    ∃ s : ℚ, 0 ≤ s ∧ s ≤ t' ∧ x = rayPt r s := by
  obtain ⟨w, hw0, hw1, hxx, hxy⟩ := hx
  refine ⟨(1 - w) * t', mul_nonneg (by linarith) ht', ?_, ?_⟩
  · calc (1 - w) * t' ≤ 1 * t' := by
          apply mul_le_mul_of_nonneg_right _ ht'; linarith
        _ = t' := one_mul t'
  · -- `rayPt (r) ((1-w)*t')`
    apply Vector2D.ext
    · show x.x = r.origin.x + (1 - w) * t' * r.direction.x
      rw [hxx]; show (1 - w) * (r.origin.x + t' * r.direction.x) + w * r.origin.x = _; ring
    · show x.y = r.origin.y + (1 - w) * t' * r.direction.y
      rw [hxy]; show (1 - w) * (r.origin.y + t' * r.direction.y) + w * r.origin.y = _; ring

/-- In a `Nodup` list, a predicate satisfied only by (copies of) a single element is satisfied at
    most once. -/
private theorem countP_le_one_of_unique {α : Type*} (l : List α) (p : α → Bool) (a : α)
    (hnd : l.Nodup) (huniq : ∀ x ∈ l, p x → x = a) : l.countP p ≤ 1 := by
  induction l with
  | nil => simp
  | cons hd tl ih =>
    rw [List.nodup_cons] at hnd
    obtain ⟨hhd, htl⟩ := hnd
    have ih' := ih htl (fun x hx hpx => huniq x (List.mem_cons_of_mem _ hx) hpx)
    rw [List.countP_cons]
    by_cases hp : p hd
    · -- hd = a, so no element of tl can satisfy p (it would also = a = hd ∉ tl).
      have heq : hd = a := huniq hd (List.mem_cons_self _ _) hp
      have hzero : tl.countP p = 0 := by
        rw [List.countP_eq_zero]
        intro x hx hpx
        have hxa : x = a := huniq x (List.mem_cons_of_mem _ hx) hpx
        exact hhd (heq.trans hxa.symm ▸ hx)
      simp [hp, hzero]
    · simp only [hp, if_false, Nat.add_zero]; exact ih'

/-- Pure mod-2 arithmetic of the bilinear toggle: the XOR of `a∧b` and `(p1+a)∧(p2+b)` (as parity
    predicates) equals `p1·(b%2) + p2·(a%2) + p1·p2` modulo 2. -/
private theorem flip_arith (p1 p2 a b : ℕ) :
    (if ((a % 2 = 1 ∧ b % 2 = 1) ↔ ¬ ((p1 + a) % 2 = 1 ∧ (p2 + b) % 2 = 1)) then 1 else 0) % 2 =
      (p1 * (b % 2) + p2 * (a % 2) + p1 * p2) % 2 := by
  -- Reduce both sides to depend only on the residues `a%2, b%2, p1%2, p2%2`.
  have hpa : (p1 + a) % 2 = (p1 % 2 + a % 2) % 2 := Nat.add_mod p1 a 2
  have hpb : (p2 + b) % 2 = (p2 % 2 + b % 2) % 2 := Nat.add_mod p2 b 2
  have hr : (p1 * (b % 2) + p2 * (a % 2) + p1 * p2) % 2 =
      ((p1 % 2) * (b % 2) + (p2 % 2) * (a % 2) + (p1 % 2) * (p2 % 2)) % 2 := by
    conv_lhs => rw [Nat.add_mod, Nat.add_mod (p1 * (b % 2)), Nat.mul_mod p1 (b % 2),
      Nat.mul_mod p2 (a % 2), Nat.mul_mod p1 p2]
    conv_rhs => rw [Nat.add_mod, Nat.add_mod (p1 % 2 * (b % 2)), Nat.mul_mod (p1 % 2) (b % 2),
      Nat.mul_mod (p2 % 2) (a % 2), Nat.mul_mod (p1 % 2) (p2 % 2)]
    simp only [Nat.mod_mod]
  rw [hpa, hpb, hr]
  rcases Nat.mod_two_eq_zero_or_one a with ha | ha <;>
    rcases Nat.mod_two_eq_zero_or_one b with hb | hb <;>
    rcases Nat.mod_two_eq_zero_or_one p1 with hp1 | hp1 <;>
    rcases Nat.mod_two_eq_zero_or_one p2 with hp2 | hp2 <;>
    rw [ha, hb, hp1, hp2] <;> decide

open EvenGraphIntersectionProofs in
/-- In the shared case (the crossing point lies on both boundaries) the peeled `sharedSelected`
    count matches the bilinear toggle modulo 2. -/
private theorem shared_local_identity (G1 G2 : EvenGraph) (r : Ray)
    (h1 : rayAvoidsGraphVertices r (arr G1 G2)) (h2 : rayAvoidsGraphVertices r (arr G2 G1))
    (hX : ∀ x ∈ Xlist G1 G2, x ∉ r.toSet)
    (hoff1 : r.origin ∉ G1.toBoundarySet) (hoff2 : r.origin ∉ G2.toBoundarySet)
    (t₀ t' : ℚ) (ht₀ : 0 ≤ t₀) (htlt : t₀ < t')
    (hmin : ∀ p ∈ paramFinset r ((arr G1 G2).segments ++ (arr G2 G1).segments), t₀ ≤ p)
    (hgap : ∀ p ∈ paramFinset r ((arr G1 G2).segments ++ (arr G2 G1).segments), t₀ < p → t' < p)
    (hbd1 : rayPt r t₀ ∈ G1.toBoundarySet) (hbd2 : rayPt r t₀ ∈ G2.toBoundarySet) :
    (sharedSelected G1 G2).countP (fun s => crossedB r s && !(crossedPastB r t' s)) % 2 =
      ((arr G1 G2).segments.countP (fun s => crossedB r s && !(crossedPastB r t' s)) *
          (intersectionRayGraphSegmentsNumber (subRay r t') (arr G2 G1) % 2) +
        (arr G2 G1).segments.countP (fun s => crossedB r s && !(crossedPastB r t' s)) *
          (intersectionRayGraphSegmentsNumber (subRay r t') (arr G1 G2) % 2) +
        (arr G1 G2).segments.countP (fun s => crossedB r s && !(crossedPastB r t' s)) *
          (arr G2 G1).segments.countP (fun s => crossedB r s && !(crossedPastB r t' s))) % 2 := by
  -- The shared-edge case. The crossing point `p₁ = rayPt r t₀` lies on `∂G1 ∩ ∂G2`. All
  -- `arr`-segments peeled at `t₀` share the single point-set `σ` through `p₁` (by `hX`, no
  -- transversal pairwise crossing there; within each `arr` collinear segments are
  -- interior-disjoint-or-equal). Exactly one `sharedSelected` representative of `σ` exists, and
  -- it is peeled iff `onInterBoundary G1 G2 σ`. The latter equals the toggle
  -- `(far ∈ A∩B) ≠ (near ∈ A∩B)` where `far := r' = subRay r t'` (param `t'`, off both
  -- boundaries) and `near` is a ray point just below `t₀`; with `far∈A ↔ a%2=1`,
  -- `far∈B ↔ b%2=1`, `near∈A ↔ (a+p1)%2=1`, `near∈B ↔ (b+p2)%2=1`, this XOR expands (mod 2)
  -- to `p1·(b%2) + p2·(a%2) + p1·p2`.
  --
  set peeled := fun s => crossedB r s && !(crossedPastB r t' s) with hpeeldef
  set p1 := (arr G1 G2).segments.countP peeled with hp1def
  set p2 := (arr G2 G1).segments.countP peeled with hp2def
  set a := intersectionRayGraphSegmentsNumber (subRay r t') (arr G1 G2) with hadef
  set b := intersectionRayGraphSegmentsNumber (subRay r t') (arr G2 G1) with hbdef
  set Csh := (sharedSelected G1 G2).countP peeled with hCshdef
  have ht'_nn : 0 ≤ t' := le_of_lt (lt_of_le_of_lt ht₀ htlt)
  set p₁ := rayPt r t₀ with hp₁def
  obtain ⟨hgapoff1, hgapoff2⟩ :=
    gap_point_off_boundaries G1 G2 r h1 h2 hoff1 hoff2 t₀ t' ht₀ htlt hgap
  -- `t₀ > 0`: else `p₁ = r.origin ∈ ∂G1`, contradicting `hoff1`.
  have ht₀pos : 0 < t₀ := by
    rcases lt_or_eq_of_le ht₀ with h | h
    · exact h
    · exfalso; apply hoff1
      have : p₁ = r.origin := by
        rw [hp₁def, rayPt, ← h]; simp [Ray.origin]
      rw [← this]; exact hbd1
  -- ## STEP A: the arr1 segment through `p₁` is shared; its canonical form is `σ`.
  rw [← arr_boundary_eq G1 G2] at hbd1
  obtain ⟨σ0, hσ0, hp₁σ0⟩ := hbd1
  -- `p₁` is not an endpoint of `σ0` (endpoints are arr1-vertices on the ray, excluded by `h1`).
  have hne0 : p₁ ≠ σ0.p1 ∧ p₁ ≠ σ0.p2 := by
    constructor <;> intro heq
    · have : σ0.p1 ∈ r.toSet ∩ (arr G1 G2).toVertexSet :=
        ⟨heq ▸ (hp₁def ▸ rayPt_mem_ray r t₀ ht₀), ((arr G1 G2).segments_endpoints σ0 hσ0).1⟩
      rw [h1] at this; exact this
    · have : σ0.p2 ∈ r.toSet ∩ (arr G1 G2).toVertexSet :=
        ⟨heq ▸ (hp₁def ▸ rayPt_mem_ray r t₀ ht₀), ((arr G1 G2).segments_endpoints σ0 hσ0).2⟩
      rw [h1] at this; exact this
  -- `σ0` is shared with respect to `G2`.
  have hσ0_sh : IsShared G2 σ0 := by
    by_contra hns
    rcases arr_transversal_inter_boundary G1 G2 σ0 hσ0 hns ⟨hp₁σ0, hbd2⟩ with h | h
    · exact hne0.1 h
    · exact hne0.2 h
  set σ := canonSeg σ0 with hσdef
  have hσtoSet : σ.toSet = σ0.toSet := canonSeg_toSet σ0
  have hp₁σ : p₁ ∈ σ.toSet := by rw [hσtoSet]; exact hp₁σ0
  obtain ⟨hσne1, hσne2⟩ := canonSeg_ne_endpoints σ0 p₁ hne0.1 hne0.2
  -- ## STEP B: `Csh = if onInterBoundary G1 G2 σ then 1 else 0`.
  -- Any peeled member of `sharedSelected` is exactly `σ`.
  have huniq_peeled : ∀ τ ∈ sharedSelected G1 G2, peeled τ = true → τ = σ := by
    intro τ hτ hpeel
    have hc : rayIntersectsSegment r τ := by
      simp only [hpeeldef, Bool.and_eq_true, crossedB, decide_eq_true_eq] at hpeel; exact hpeel.1
    have hτpar : rayCrossingParam r τ hc = t₀ :=
      peeled_shared_implies_param_eq G1 G2 r h1 h2 hoff1 t₀ t' ht₀ htlt hmin hgap τ hτ hc hpeel
    have honτ : p₁ ∈ τ.toSet := by
      rw [hp₁def, ← hτpar]; exact rayCrossingParam_point_mem_seg r τ hc
    -- underlying arr1 segment of τ
    rw [sharedSelected, List.mem_filter] at hτ
    obtain ⟨τ0, hτ0, hcanonτ⟩ := List.mem_map.mp (List.mem_dedup.mp hτ.1)
    have honτ0 : p₁ ∈ τ0.toSet := by rw [← canonSeg_toSet τ0, hcanonτ]; exact honτ
    -- p₁ not an endpoint of τ0
    have hneτ0 : p₁ ≠ τ0.p1 ∧ p₁ ≠ τ0.p2 := by
      constructor <;> intro heq
      · have : τ0.p1 ∈ r.toSet ∩ (arr G1 G2).toVertexSet :=
          ⟨heq ▸ (hp₁def ▸ rayPt_mem_ray r t₀ ht₀), ((arr G1 G2).segments_endpoints τ0 hτ0).1⟩
        rw [h1] at this; exact this
      · have : τ0.p2 ∈ r.toSet ∩ (arr G1 G2).toVertexSet :=
          ⟨heq ▸ (hp₁def ▸ rayPt_mem_ray r t₀ ht₀), ((arr G1 G2).segments_endpoints τ0 hτ0).2⟩
        rw [h1] at this; exact this
    have hsl : SameLine σ0 τ0 :=
      arr_segs_through_rayPt_sameLine G1 G2 r hX t₀ ht₀ σ0 τ0 (Or.inl hσ0) (Or.inl hτ0)
        (hp₁def ▸ hp₁σ0) (hp₁def ▸ honτ0)
    have htoSet : σ0.toSet = τ0.toSet :=
      arr_collinear_toSet_eq G1 G2 σ0 τ0 hσ0 hτ0 hsl p₁ (hp₁def ▸ hp₁σ0) hne0.1 hne0.2
        (hp₁def ▸ honτ0) hneτ0.1 hneτ0.2
    have hcanonEq : canonSeg σ0 = canonSeg τ0 := canonSeg_eq_of_toSet_eq σ0 τ0
      ((arr G1 G2).segments_nondegenerate σ0 hσ0)
      ((arr G1 G2).segments_nondegenerate τ0 hτ0) htoSet
    rw [← hcanonτ, ← hcanonEq, ← hσdef]
  -- `σ ∈ sharedSelected G1 G2 ↔ onInterBoundary G1 G2 σ`.
  have hσ_in_dedup : σ ∈ ((arr G1 G2).segments.map canonSeg).dedup := by
    rw [List.mem_dedup]; exact List.mem_map.mpr ⟨σ0, hσ0, rfl⟩
  -- `σ` is shared (its toSet = σ0.toSet ⊆ ∂G2).
  have hσ_sh : IsShared G2 σ := by
    intro x hx; rw [hσtoSet] at hx; exact hσ0_sh hx
  -- `σ` is peeled (crossed at `t₀ ≤ t'`).
  have hσ_peeled : peeled σ = true := by
    have hcσ : rayIntersectsSegment r σ :=
      (rayIntersectsSegment_iff_exists_param r σ).mpr ⟨t₀, ht₀, by
        have := hp₁σ; rw [hp₁def, rayPt] at this; exact this⟩
    have hcrossed : crossedB r σ = true := by simp [crossedB, hcσ]
    have hnotpast : crossedPastB r t' σ = false := by
      rw [Bool.eq_false_iff]; intro hp
      simp only [crossedPastB, decide_eq_true_eq] at hp
      obtain ⟨t, ht, hmem⟩ := hp
      have ht0 : 0 ≤ t := le_of_lt (lt_of_le_of_lt ht'_nn ht)
      -- t is a crossing param of σ0 (= σ in toSet), so t ∈ paramFinset, t₀ ≤ t, but t > t' > t₀.
      have hmemσ0 : (⟨r.origin.x + t * r.direction.x, r.origin.y + t * r.direction.y⟩ :
          Vector2D) ∈ σ0.toSet := by rw [← hσtoSet]; exact hmem
      have hc0 : rayIntersectsSegment r σ0 :=
        (rayIntersectsSegment_iff_exists_param r σ0).mpr ⟨t, ht0, hmemσ0⟩
      have huniq : t = rayCrossingParam r σ0 hc0 :=
        arr_param_unique G1 G2 r σ0 hσ0 h1 hoff1 hc0 t ht0 hmemσ0
      -- σ0 is also crossed at t₀ (at p₁), so its crossing param is t₀, hence t = t₀.
      have hp₁memσ0 : (⟨r.origin.x + t₀ * r.direction.x, r.origin.y + t₀ * r.direction.y⟩ :
          Vector2D) ∈ σ0.toSet := by
        show p₁ ∈ σ0.toSet; exact hp₁σ0
      have huniq₀ : t₀ = rayCrossingParam r σ0 hc0 :=
        arr_param_unique G1 G2 r σ0 hσ0 h1 hoff1 hc0 t₀ ht₀ hp₁memσ0
      have : t = t₀ := by rw [huniq, ← huniq₀]
      linarith
    simp only [hpeeldef, hcrossed, hnotpast, Bool.not_false, Bool.and_true]
  -- Csh equals the indicator of `onInterBoundary`.
  have hCsh_val : Csh = if onInterBoundary G1 G2 σ then 1 else 0 := by
    by_cases hoib : onInterBoundary G1 G2 σ
    · -- σ ∈ sharedSelected and is the unique peeled member.
      have hσ_mem : σ ∈ sharedSelected G1 G2 := by
        rw [sharedSelected, List.mem_filter]
        exact ⟨hσ_in_dedup, by simp only [decide_eq_true_eq]; exact ⟨hσ_sh, hoib⟩⟩
      rw [if_pos hoib]
      -- Csh ≥ 1 (σ counts) and Csh ≤ 1 (uniqueness in nodup list).
      have hle : Csh ≤ 1 := by
        rw [hCshdef]
        exact countP_le_one_of_unique _ peeled σ (List.Nodup.filter _ (List.nodup_dedup _))
          huniq_peeled
      have hge : 1 ≤ Csh := by
        rw [hCshdef, Nat.one_le_iff_ne_zero, Ne, List.countP_eq_zero]
        intro hzero
        exact absurd hσ_peeled (by simpa using hzero σ hσ_mem)
      omega
    · -- no peeled member: any would equal σ, but σ ∉ sharedSelected.
      rw [if_neg hoib, hCshdef, List.countP_eq_zero]
      intro τ hτ hpeel
      have hτeq : τ = σ := huniq_peeled τ hτ hpeel
      rw [sharedSelected, List.mem_filter] at hτ
      have := hτ.2; rw [decide_eq_true_eq] at this
      rw [hτeq] at this
      exact hoib this.2
  -- ## STEP C: rewrite `onInterBoundary G1 G2 σ` as the `A ∩ B` flip on the clean transversal
  -- `⟨a_pt, b_pt⟩` with `a_pt := rayPt r t'` (far), `b_pt := r.origin` (near), through `c := p₁`.
  set a_pt := rayPt r t' with ha_pt
  set b_pt := r.origin with hb_pt
  -- The transversal is clean: it meets `∂G1 ∪ ∂G2` only at `p₁`.
  have hclean : ∀ x ∈ (LineSegment.mk a_pt b_pt).toSet,
      (x ∈ G1.toBoundarySet ∨ x ∈ G2.toBoundarySet) → x = p₁ := by
    intro x hx hxbd
    obtain ⟨s, hs0, hst', hxs⟩ := mem_far_near_seg r t' ht'_nn x hx
    -- `x = rayPt r s` lies on a crossed arr-segment, so `s` is a crossing parameter ⇒ `s = t₀`.
    have hskey : s = t₀ := by
      -- get a segment of `arr G1 G2` or `arr G2 G1` containing `x = rayPt r s`
      have hxonseg : ∃ seg, (seg ∈ (arr G1 G2).segments ∨ seg ∈ (arr G2 G1).segments) ∧
          rayPt r s ∈ seg.toSet := by
        rcases hxbd with hb | hb
        · rw [← arr_boundary_eq G1 G2] at hb
          obtain ⟨seg, hseg, hon⟩ := hb
          exact ⟨seg, Or.inl hseg, hxs ▸ hon⟩
        · rw [← arr_boundary_eq G2 G1] at hb
          obtain ⟨seg, hseg, hon⟩ := hb
          exact ⟨seg, Or.inr hseg, hxs ▸ hon⟩
      obtain ⟨seg, hseg, hon⟩ := hxonseg
      have honxy : (⟨r.origin.x + s * r.direction.x, r.origin.y + s * r.direction.y⟩ :
          Vector2D) ∈ seg.toSet := hon
      have hcseg : rayIntersectsSegment r seg :=
        (rayIntersectsSegment_iff_exists_param r seg).mpr ⟨s, hs0, honxy⟩
      have hsmem : s ∈ paramFinset r ((arr G1 G2).segments ++ (arr G2 G1).segments) := by
        rw [mem_paramFinset]
        rcases hseg with hin | hin
        · exact ⟨seg, List.mem_append_left _ hin, hcseg,
            (arr_param_unique G1 G2 r seg hin h1 hoff1 hcseg s hs0 honxy).symm⟩
        · exact ⟨seg, List.mem_append_right _ hin, hcseg,
            (arr_param_unique G2 G1 r seg hin h2 hoff2 hcseg s hs0 honxy).symm⟩
      -- `t₀ ≤ s ≤ t'`; if `t₀ < s` then `t' < s`, contradicting `s ≤ t'`.
      rcases eq_or_lt_of_le (hmin s hsmem) with h | h
      · exact h.symm
      · exact absurd (hgap s hsmem h) (not_lt.mpr hst')
    rw [hxs, hskey]
  -- the boundary-avoidance facts for `a_pt` and `b_pt`
  have ha1 : a_pt ∉ G1.toBoundarySet := hgapoff1
  have ha2 : a_pt ∉ G2.toBoundarySet := hgapoff2
  have hb1 : b_pt ∉ G1.toBoundarySet := hoff1
  have hb2 : b_pt ∉ G2.toBoundarySet := hoff2
  -- `p₁ ∈ ⟨a_pt, b_pt⟩.toSet` with parameter `w = (t' - t₀)/t'`.
  have ht'pos : (0 : ℚ) < t' := lt_of_le_of_lt ht₀ htlt
  have hcab : p₁ ∈ (LineSegment.mk a_pt b_pt).toSet := by
    refine ⟨(t' - t₀) / t', ?_, ?_, ?_, ?_⟩
    · apply div_nonneg (by linarith) (le_of_lt ht'pos)
    · rw [div_le_one ht'pos]; linarith
    · show p₁.x = (1 - (t' - t₀) / t') * a_pt.x + (t' - t₀) / t' * b_pt.x
      rw [hp₁def, ha_pt, hb_pt]
      show r.origin.x + t₀ * r.direction.x =
        (1 - (t' - t₀) / t') * (r.origin.x + t' * r.direction.x) + (t' - t₀) / t' * r.origin.x
      field_simp; ring
    · show p₁.y = (1 - (t' - t₀) / t') * a_pt.y + (t' - t₀) / t' * b_pt.y
      rw [hp₁def, ha_pt, hb_pt]
      show r.origin.y + t₀ * r.direction.y =
        (1 - (t' - t₀) / t') * (r.origin.y + t' * r.direction.y) + (t' - t₀) / t' * r.origin.y
      field_simp; ring
  -- Apply the flip characterisation (note `σ = canonSeg σ0`).
  have hflip_iff : onInterBoundary G1 G2 σ ↔
      ((a_pt ∈ G1.interior ∧ a_pt ∈ G2.interior) ≠ (b_pt ∈ G1.interior ∧ b_pt ∈ G2.interior)) := by
    rw [hσdef]
    exact onInterBoundary_iff_flip G1 G2 σ0 hσ0 hσ0_sh a_pt b_pt p₁ ha1 ha2 hb1 hb2
      hp₁σ0 hne0.1 hne0.2 hcab hclean
  -- ## STEP D: evaluate the four interior memberships as parities.
  -- `a_pt = (subRay r t').origin`; off arr1-segs (= ∂G1) and subRay avoids arr1-vertices.
  have hsub_avoids : ∀ (H : EvenGraph), rayAvoidsGraphVertices r H →
      rayAvoidsGraphVertices (subRay r t') H := by
    intro H hH
    rw [rayAvoidsGraphVertices, Set.eq_empty_iff_forall_not_mem]
    intro v ⟨hv1, hv2⟩
    have : v ∈ r.toSet ∩ H.toVertexSet :=
      ⟨subRay_toSet_subset r t' ht'_nn hv1, hv2⟩
    rw [hH] at this; exact this
  have hsubRay_origin : (subRay r t').origin = a_pt := rfl
  -- a_pt ∈ G1.interior ↔ a % 2 = 1
  have hAa : a_pt ∈ G1.interior ↔ a % 2 = 1 := by
    have horigin_avoids : ∀ seg ∈ (arr G1 G2).segments,
        pointAvoidsSegment (subRay r t').origin seg := by
      intro seg hseg hmem
      rw [hsubRay_origin] at hmem
      exact ha1 (by rw [← arr_boundary_eq G1 G2]; exact ⟨seg, hseg, hmem⟩)
    have := point_in_interior_iff_odd_count (subRay r t') (arr G1 G2) horigin_avoids
      (hsub_avoids _ h1)
    rw [hsubRay_origin, arr_interior_eq G1 G2] at this
    rw [this, hadef]
  -- a_pt ∈ G2.interior ↔ b % 2 = 1
  have hAb : a_pt ∈ G2.interior ↔ b % 2 = 1 := by
    have horigin_avoids : ∀ seg ∈ (arr G2 G1).segments,
        pointAvoidsSegment (subRay r t').origin seg := by
      intro seg hseg hmem
      rw [hsubRay_origin] at hmem
      exact ha2 (by rw [← arr_boundary_eq G2 G1]; exact ⟨seg, hseg, hmem⟩)
    have := point_in_interior_iff_odd_count (subRay r t') (arr G2 G1) horigin_avoids
      (hsub_avoids _ h2)
    rw [hsubRay_origin, arr_interior_eq G2 G1] at this
    rw [this, hbdef]
  -- b_pt = r.origin ∈ G1.interior ↔ (p1 + a) % 2 = 1
  have hsplit1 := count_split_subRay r t' ht'_nn (arr G1 G2)
    (by rw [arr_boundary_eq]; exact ha1)
  have hsplit2 := count_split_subRay r t' ht'_nn (arr G2 G1)
    (by rw [arr_boundary_eq]; exact ha2)
  have hBa : b_pt ∈ G1.interior ↔ (p1 + a) % 2 = 1 := by
    have horigin_avoids : ∀ seg ∈ (arr G1 G2).segments,
        pointAvoidsSegment r.origin seg := by
      intro seg hseg hmem
      exact hoff1 (by rw [← arr_boundary_eq G1 G2]; exact ⟨seg, hseg, hmem⟩)
    have := point_in_interior_iff_odd_count r (arr G1 G2) horigin_avoids h1
    rw [arr_interior_eq G1 G2] at this
    rw [hb_pt, this]
    -- `#arr1(r) = p1 + a`
    rw [show intersectionRayGraphSegmentsNumber r (arr G1 G2) = p1 + a from hsplit1]
  -- b_pt = r.origin ∈ G2.interior ↔ (p2 + b) % 2 = 1
  have hBb : b_pt ∈ G2.interior ↔ (p2 + b) % 2 = 1 := by
    have horigin_avoids : ∀ seg ∈ (arr G2 G1).segments,
        pointAvoidsSegment r.origin seg := by
      intro seg hseg hmem
      exact hoff2 (by rw [← arr_boundary_eq G2 G1]; exact ⟨seg, hseg, hmem⟩)
    have := point_in_interior_iff_odd_count r (arr G2 G1) horigin_avoids h2
    rw [arr_interior_eq G2 G1] at this
    rw [hb_pt, this]
    rw [show intersectionRayGraphSegmentsNumber r (arr G2 G1) = p2 + b from hsplit2]
  -- ## STEP E: combine. `onInterBoundary σ` ↔ the parity toggle in `↔¬` form.
  have hfinal : onInterBoundary G1 G2 σ ↔
      ((a % 2 = 1 ∧ b % 2 = 1) ↔ ¬ ((p1 + a) % 2 = 1 ∧ (p2 + b) % 2 = 1)) := by
    rw [hflip_iff]
    rw [← iff_not_eq_ne]
    -- rewrite the four interior membership props via Step D
    constructor
    · intro h
      rw [show (a % 2 = 1 ∧ b % 2 = 1) ↔ (a_pt ∈ G1.interior ∧ a_pt ∈ G2.interior) from
            (and_congr hAa hAb).symm,
          show ((p1 + a) % 2 = 1 ∧ (p2 + b) % 2 = 1) ↔ (b_pt ∈ G1.interior ∧ b_pt ∈ G2.interior)
            from (and_congr hBa hBb).symm]
      exact h
    · intro h
      rw [show (a_pt ∈ G1.interior ∧ a_pt ∈ G2.interior) ↔ (a % 2 = 1 ∧ b % 2 = 1) from
            (and_congr hAa hAb),
          show (b_pt ∈ G1.interior ∧ b_pt ∈ G2.interior) ↔ ((p1 + a) % 2 = 1 ∧ (p2 + b) % 2 = 1)
            from (and_congr hBa hBb)]
      exact h
  rw [hCsh_val]
  rw [show (if onInterBoundary G1 G2 σ then (1 : ℕ) else 0) =
      (if ((a % 2 = 1 ∧ b % 2 = 1) ↔ ¬ ((p1 + a) % 2 = 1 ∧ (p2 + b) % 2 = 1)) then 1 else 0) from by
    by_cases h : onInterBoundary G1 G2 σ
    · rw [if_pos h, if_pos (hfinal.mp h)]
    · rw [if_neg h, if_neg (fun hc => h (hfinal.mpr hc))]]
  exact flip_arith p1 p2 a b

open EvenGraphIntersectionProofs in
private theorem local_identity (G1 G2 : EvenGraph) (r : Ray)
    (h1 : rayAvoidsGraphVertices r (arr G1 G2)) (h2 : rayAvoidsGraphVertices r (arr G2 G1))
    (hX : ∀ x ∈ Xlist G1 G2, x ∉ r.toSet)
    (hoff1 : r.origin ∉ G1.toBoundarySet) (hoff2 : r.origin ∉ G2.toBoundarySet)
    (t₀ t' : ℚ) (ht₀ : 0 ≤ t₀) (htlt : t₀ < t')
    (hmin : ∀ p ∈ paramFinset r ((arr G1 G2).segments ++ (arr G2 G1).segments), t₀ ≤ p)
    (hgap : ∀ p ∈ paramFinset r ((arr G1 G2).segments ++ (arr G2 G1).segments), t₀ < p → t' < p) :
    (interGraph G1 G2).segments.countP (fun s => crossedB r s && !(crossedPastB r t' s)) % 2 =
      ((arr G1 G2).segments.countP (fun s => crossedB r s && !(crossedPastB r t' s)) *
          (intersectionRayGraphSegmentsNumber (subRay r t') (arr G2 G1) % 2) +
        (arr G2 G1).segments.countP (fun s => crossedB r s && !(crossedPastB r t' s)) *
          (intersectionRayGraphSegmentsNumber (subRay r t') (arr G1 G2) % 2) +
        (arr G1 G2).segments.countP (fun s => crossedB r s && !(crossedPastB r t' s)) *
          (arr G2 G1).segments.countP (fun s => crossedB r s && !(crossedPastB r t' s))) % 2 := by
  set peeled := fun s => crossedB r s && !(crossedPastB r t' s) with hpeeldef
  set p1 := (arr G1 G2).segments.countP peeled with hp1def
  set p2 := (arr G2 G1).segments.countP peeled with hp2def
  set a := intersectionRayGraphSegmentsNumber (subRay r t') (arr G1 G2) with hadef
  set b := intersectionRayGraphSegmentsNumber (subRay r t') (arr G2 G1) with hbdef
  -- Decompose interGraph.segments. The extra outer `phantomDoubled` block contributes an even
  -- count (each edge appears twice), so it vanishes mod 2.
  rw [interGraph_segments]
  rw [List.countP_append, List.countP_append, List.countP_append]
  have hph_even : (phantomDoubled G1 G2).countP peeled % 2 = 0 :=
    phantomDoubled_countP_even G1 G2 peeled
  -- Drop the (even) phantom term from the mod-2 goal.
  rw [Nat.add_mod, hph_even, Nat.add_zero, Nat.mod_mod]
  -- in1 count
  have hC1 := in1_peeled_count G1 G2 r h1 h2 hoff1 hoff2 t₀ t' ht₀ htlt hmin hgap
  -- in2 count (swap G1/G2)
  have hmin' : ∀ p ∈ paramFinset r ((arr G2 G1).segments ++ (arr G1 G2).segments), t₀ ≤ p := by
    rw [paramFinset_append_comm]; exact hmin
  have hgap' : ∀ p ∈ paramFinset r ((arr G2 G1).segments ++ (arr G1 G2).segments), t₀ < p → t' < p := by
    rw [paramFinset_append_comm]; exact hgap
  have hC2 := in1_peeled_count G2 G1 r h2 h1 hoff2 hoff1 t₀ t' ht₀ htlt hmin' hgap'
  -- boundary characterizations
  have hbd1 := boundary_iff_peeled_pos G1 G2 r h1 h2 hoff1 hoff2 t₀ t' ht₀ htlt hmin hgap
  have hbd2 := boundary_iff_peeled_pos G2 G1 r h2 h1 hoff2 hoff1 t₀ t' ht₀ htlt hmin' hgap'
  -- fold names into the count lemmas
  rw [show (arr G1 G2).segments.countP peeled = p1 from rfl] at hC1
  rw [show (arr G2 G1).segments.countP peeled = p2 from rfl] at hC2
  -- Csh peeled
  set Csh := (sharedSelected G1 G2).countP peeled with hCshdef
  -- The two `selectSegmentsInside` counts.
  rw [hC1, hC2]
  -- Case-split on the two boundary memberships.
  by_cases hin1 : rayPt r t₀ ∈ G1.toBoundarySet <;>
    by_cases hin2 : rayPt r t₀ ∈ G2.toBoundarySet
  · -- shared case: both selects are 0, peeledIG = Csh.
    simp only [hin2, if_true]
    simp only [hin1, if_true]
    -- in1 select gives `if hin2 then 0`, in2 gives `if hin1 then 0`
    rw [add_zero, zero_add]
    exact shared_local_identity G1 G2 r h1 h2 hX hoff1 hoff2 t₀ t' ht₀ htlt hmin hgap hin1 hin2
  · -- inG1, ¬inG2: p2 = 0, Csh = 0, peeledIG = in1 = p1·χB
    have hp2_zero : p2 = 0 := by
      by_contra hne; exact hin2 ((hbd2.mpr (Nat.pos_of_ne_zero hne)))
    have hCsh_zero : Csh = 0 := by
      rw [hCshdef, List.countP_eq_zero]
      intro σ hσ hpeel
      have hc : rayIntersectsSegment r σ := by
        simp only [hpeeldef, Bool.and_eq_true, crossedB, decide_eq_true_eq] at hpeel
        exact hpeel.1
      have hτ : rayCrossingParam r σ hc = t₀ :=
        peeled_shared_implies_param_eq G1 G2 r h1 h2 hoff1 t₀ t' ht₀ htlt hmin hgap σ hσ hc hpeel
      have := sharedSelected_peeled_on_both G1 G2 r t₀ t' σ hσ hpeel hc hτ
      exact hin2 this.2
    -- in1 select with ¬inG2: `if hin2 then 0 else if b%2=1 then p1 else 0`
    simp only [hin2, if_false, hin1, if_true]
    rw [add_zero, hCsh_zero, add_zero, hp2_zero]
    -- goal: (if b%2=1 then p1 else 0) % 2 = (p1·(b%2) + 0·(a%2) + p1·0) % 2
    by_cases hbodd : b % 2 = 1
    · rw [hbodd]; simp
    · have hb0 : b % 2 = 0 := by omega
      rw [hb0]; simp
  · -- ¬inG1, inG2: p1 = 0, Csh = 0, peeledIG = in2 = p2·χA
    have hp1_zero : p1 = 0 := by
      by_contra hne; exact hin1 ((hbd1.mpr (Nat.pos_of_ne_zero hne)))
    have hCsh_zero : Csh = 0 := by
      rw [hCshdef, List.countP_eq_zero]
      intro σ hσ hpeel
      have hc : rayIntersectsSegment r σ := by
        simp only [hpeeldef, Bool.and_eq_true, crossedB, decide_eq_true_eq] at hpeel
        exact hpeel.1
      have hτ : rayCrossingParam r σ hc = t₀ :=
        peeled_shared_implies_param_eq G1 G2 r h1 h2 hoff1 t₀ t' ht₀ htlt hmin hgap σ hσ hc hpeel
      have := sharedSelected_peeled_on_both G1 G2 r t₀ t' σ hσ hpeel hc hτ
      exact hin1 this.1
    simp only [hin2, if_true, hin1, if_false]
    rw [zero_add, hCsh_zero, add_zero, hp1_zero]
    by_cases haodd : a % 2 = 1
    · rw [haodd]; simp
    · have ha0 : a % 2 = 0 := by omega
      rw [ha0]; simp
  · -- ¬inG1, ¬inG2: everything zero.
    have hp1_zero : p1 = 0 := by
      by_contra hne; exact hin1 ((hbd1.mpr (Nat.pos_of_ne_zero hne)))
    have hp2_zero : p2 = 0 := by
      by_contra hne; exact hin2 ((hbd2.mpr (Nat.pos_of_ne_zero hne)))
    have hCsh_zero : Csh = 0 := by
      rw [hCshdef, List.countP_eq_zero]
      intro σ hσ hpeel
      have hc : rayIntersectsSegment r σ := by
        simp only [hpeeldef, Bool.and_eq_true, crossedB, decide_eq_true_eq] at hpeel
        exact hpeel.1
      have hτ : rayCrossingParam r σ hc = t₀ :=
        peeled_shared_implies_param_eq G1 G2 r h1 h2 hoff1 t₀ t' ht₀ htlt hmin hgap σ hσ hc hpeel
      have := sharedSelected_peeled_on_both G1 G2 r t₀ t' σ hσ hpeel hc hτ
      exact hin1 this.1
    simp only [hin2, if_false, hin1, if_false]
    rw [hCsh_zero, hp1_zero, hp2_zero]
    simp

open EvenGraphIntersectionProofs in
/-- **Parity identity (peeling core).** For a ray avoiding the vertices of `arr G1 G2` and
    `arr G2 G1`, avoiding the pairwise crossing points `Xlist`, with origin off `∂G1` and
    `∂G2`, the number of `interGraph`-crossings has the parity of the product of the
    `arr G1 G2`- and `arr G2 G1`-crossing counts. -/
theorem interGraph_parity_core (G1 G2 : EvenGraph) (r : Ray)
    (h1 : rayAvoidsGraphVertices r (arr G1 G2))
    (h2 : rayAvoidsGraphVertices r (arr G2 G1))
    (hX : ∀ x ∈ Xlist G1 G2, x ∉ r.toSet)
    (hoff1 : r.origin ∉ G1.toBoundarySet) (hoff2 : r.origin ∉ G2.toBoundarySet) :
    intersectionRayGraphSegmentsNumber r (interGraph G1 G2) % 2 =
      (intersectionRayGraphSegmentsNumber r (arr G1 G2) *
        intersectionRayGraphSegmentsNumber r (arr G2 G1)) % 2 := by
  -- Strong induction on a bound for #arr1 r + #arr2 r.
  suffices key : ∀ n : ℕ, ∀ r : Ray,
      intersectionRayGraphSegmentsNumber r (arr G1 G2) +
        intersectionRayGraphSegmentsNumber r (arr G2 G1) ≤ n →
      rayAvoidsGraphVertices r (arr G1 G2) → rayAvoidsGraphVertices r (arr G2 G1) →
      (∀ x ∈ Xlist G1 G2, x ∉ r.toSet) →
      r.origin ∉ G1.toBoundarySet → r.origin ∉ G2.toBoundarySet →
      intersectionRayGraphSegmentsNumber r (interGraph G1 G2) % 2 =
        (intersectionRayGraphSegmentsNumber r (arr G1 G2) *
          intersectionRayGraphSegmentsNumber r (arr G2 G1)) % 2 by
    exact key _ r (le_refl _) h1 h2 hX hoff1 hoff2
  clear h1 h2 hX hoff1 hoff2 r
  intro n
  induction n using Nat.strong_induction_on with
  | _ n ih =>
    intro r hn h1 h2 hX hoff1 hoff2
    -- Is anything crossed?
    by_cases hne : (paramFinset r ((arr G1 G2).segments ++ (arr G2 G1).segments)).Nonempty
    · -- Inductive step: peel the nearest crossing.
      obtain ⟨t₀, t', ht₀_nn, htlt, ht₀mem, hmin, hgap⟩ := exists_gap_mem r _ hne
      have ht'_nn : 0 ≤ t' := le_of_lt (lt_of_le_of_lt ht₀_nn htlt)
      obtain ⟨hoff1', hoff2'⟩ :=
        gap_point_off_boundaries G1 G2 r h1 h2 hoff1 hoff2 t₀ t' ht₀_nn htlt hgap
      set r' := subRay r t' with hr'
      -- r'.origin = rayPt r t'
      have hr'_origin : r'.origin = rayPt r t' := rfl
      -- Transfer hypotheses to r'.
      have hsub_subset : r'.toSet ⊆ r.toSet := subRay_toSet_subset r t' ht'_nn
      have h1' : rayAvoidsGraphVertices r' (arr G1 G2) := by
        rw [rayAvoidsGraphVertices, Set.eq_empty_iff_forall_not_mem]
        intro v ⟨hv1, hv2⟩
        have : v ∈ r.toSet ∩ (arr G1 G2).toVertexSet := ⟨hsub_subset hv1, hv2⟩
        rw [h1] at this; exact this
      have h2' : rayAvoidsGraphVertices r' (arr G2 G1) := by
        rw [rayAvoidsGraphVertices, Set.eq_empty_iff_forall_not_mem]
        intro v ⟨hv1, hv2⟩
        have : v ∈ r.toSet ∩ (arr G2 G1).toVertexSet := ⟨hsub_subset hv1, hv2⟩
        rw [h2] at this; exact this
      have hX' : ∀ x ∈ Xlist G1 G2, x ∉ r'.toSet := fun x hx hxr => hX x hx (hsub_subset hxr)
      have hoff1'' : r'.origin ∉ G1.toBoundarySet := by rw [hr'_origin]; exact hoff1'
      have hoff2'' : r'.origin ∉ G2.toBoundarySet := by rw [hr'_origin]; exact hoff2'
      -- Splitting identities.
      have hoffIG : rayPt r t' ∉ (interGraph G1 G2).toBoundarySet := by
        intro hmem
        rcases interGraph_boundary_subset G1 G2 hmem with h | h
        · exact hoff1' h
        · exact hoff2' h
      have hsplit1 := count_split_subRay r t' ht'_nn (arr G1 G2)
        (by rw [arr_boundary_eq]; exact hoff1')
      have hsplit2 := count_split_subRay r t' ht'_nn (arr G2 G1)
        (by rw [arr_boundary_eq]; exact hoff2')
      have hsplitIG := count_split_subRay r t' ht'_nn (interGraph G1 G2) hoffIG
      rw [← hr'] at hsplit1 hsplit2 hsplitIG
      -- Bound for IH on r'.
      have hbound : intersectionRayGraphSegmentsNumber r' (arr G1 G2) +
          intersectionRayGraphSegmentsNumber r' (arr G2 G1) < n := by
        -- t₀ ∈ finset gives a segment crossed at t₀, hence peeled ≥ 1 somewhere.
        have hpos : 0 < (arr G1 G2).segments.countP
            (fun s => crossedB r s && !(crossedPastB r t' s)) +
              (arr G2 G1).segments.countP (fun s => crossedB r s && !(crossedPastB r t' s)) := by
          rw [mem_paramFinset] at ht₀mem
          obtain ⟨s, hs, hc, hτ⟩ := ht₀mem
          -- the segment s is peeled
          have hcrossed : crossedB r s = true := by simp [crossedB, hc]
          have hnotpast : crossedPastB r t' s = false := by
            rw [Bool.eq_false_iff]
            intro hp
            simp only [crossedPastB, decide_eq_true_eq] at hp
            obtain ⟨t, ht, hmem⟩ := hp
            have ht0 : 0 ≤ t := le_of_lt (lt_of_le_of_lt ht'_nn ht)
            have huniq : t = rayCrossingParam r s hc := by
              rcases List.mem_append.mp hs with hin | hin
              · exact arr_param_unique G1 G2 r s hin h1 hoff1 hc t ht0 hmem
              · exact arr_param_unique G2 G1 r s hin h2 hoff2 hc t ht0 hmem
            rw [hτ] at huniq; rw [huniq] at ht; linarith
          rcases List.mem_append.mp hs with hin | hin
          · have : 0 < (arr G1 G2).segments.countP
                (fun s => crossedB r s && !(crossedPastB r t' s)) := by
              rw [List.countP_pos_iff]
              exact ⟨s, hin, by simp only [hcrossed, hnotpast, Bool.not_false, Bool.and_true]⟩
            omega
          · have : 0 < (arr G2 G1).segments.countP
                (fun s => crossedB r s && !(crossedPastB r t' s)) := by
              rw [List.countP_pos_iff]
              exact ⟨s, hin, by simp only [hcrossed, hnotpast, Bool.not_false, Bool.and_true]⟩
            omega
        omega
      -- Apply IH at r'.
      have hIH := ih (intersectionRayGraphSegmentsNumber r' (arr G1 G2) +
        intersectionRayGraphSegmentsNumber r' (arr G2 G1)) hbound r' (le_refl _)
        h1' h2' hX' hoff1'' hoff2''
      -- Local identity.
      have hloc := local_identity G1 G2 r h1 h2 hX hoff1 hoff2 t₀ t' ht₀_nn htlt hmin hgap
      -- Assemble via mod-2 algebra.
      rw [hsplit1, hsplit2, hsplitIG]
      exact mod2_assemble _ _ _ _ _ _ hIH hloc
    · -- Base case: nothing is crossed, so all counts are zero.
      have hzero : ∀ (H : EvenGraph), (∀ s ∈ H.segments, s ∈ (arr G1 G2).segments ∨
          s ∈ (arr G2 G1).segments) → intersectionRayGraphSegmentsNumber r H = 0 := by
        intro H hHsub
        rw [count_eq_countP_crossedB, List.countP_eq_zero]
        intro s hs hc
        simp only [crossedB, decide_eq_true_eq] at hc
        rcases List.mem_append.mp (by
          rcases hHsub s hs with hin | hin
          · exact List.mem_append_left _ hin
          · exact List.mem_append_right _ hin :
            s ∈ (arr G1 G2).segments ++ (arr G2 G1).segments) with hin | hin
        · exact hne ⟨rayCrossingParam r s hc, (mem_paramFinset _ _ _).mpr
            ⟨s, List.mem_append_left _ hin, hc, rfl⟩⟩
        · exact hne ⟨rayCrossingParam r s hc, (mem_paramFinset _ _ _).mpr
            ⟨s, List.mem_append_right _ hin, hc, rfl⟩⟩
      have hzero1 : intersectionRayGraphSegmentsNumber r (arr G1 G2) = 0 :=
        hzero (arr G1 G2) (fun s hs => Or.inl hs)
      have hzero2 : intersectionRayGraphSegmentsNumber r (arr G2 G1) = 0 :=
        hzero (arr G2 G1) (fun s hs => Or.inr hs)
      -- interGraph has no crossings either: every interGraph segment, if crossed, would make
      -- some arr segment crossed.
      have hzeroIG : intersectionRayGraphSegmentsNumber r (interGraph G1 G2) = 0 := by
        rw [count_eq_countP_crossedB, List.countP_eq_zero]
        intro s hs hc
        simp only [crossedB, decide_eq_true_eq] at hc
        -- s comes from arr1, arr2, or sharedSelected (whose toSet = an arr1 segment's)
        have horigin := interGraph_seg_origin G1 G2 s hs
        rcases horigin with hin | hin | ⟨σ0, hσ0, hcanon⟩
        · exact hne ⟨rayCrossingParam r s hc, (mem_paramFinset _ _ _).mpr
            ⟨s, List.mem_append_left _ hin, hc, rfl⟩⟩
        · exact hne ⟨rayCrossingParam r s hc, (mem_paramFinset _ _ _).mpr
            ⟨s, List.mem_append_right _ hin, hc, rfl⟩⟩
        · -- canonicalised: s = canonSeg σ0 for some σ0 ∈ arr1; s.toSet = σ0.toSet, so r crosses σ0.
          have hcross0 : rayIntersectsSegment r σ0 := by
            obtain ⟨q, hqr, hqs⟩ := hc
            refine ⟨q, hqr, ?_⟩
            rw [← canonSeg_toSet σ0, ← hcanon]; exact hqs
          exact hne ⟨rayCrossingParam r σ0 hcross0, (mem_paramFinset _ _ _).mpr
            ⟨σ0, List.mem_append_left _ hσ0, hcross0, rfl⟩⟩
      rw [hzero1, hzero2, hzeroIG]

end EvenGraphIntersectionGenProofs

end
