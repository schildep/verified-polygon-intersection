import Polygons.Defs
import Polygons.Polygon
import Polygons.EvenGraph

/-!
# Multipolygon Proofs

Implementation of `Multipolygon.toEvenGraph` (combine of polygon-derived even
graphs) and proofs that its boundary/vertex set/interior agree with the
multipolygon's. Yields a characterization of `Multipolygon.interior` as the
symmetric difference of the polygon interiors with the multipolygon boundary
removed.
-/

open Classical Set

noncomputable section

namespace MultipolygonProofs

/-- Convert a "flat" non-degeneracy hypothesis over the multipolygon segments
    to a per-polygon hypothesis. -/
theorem distinct_per_polygon (m : Multipolygon)
    (h : ∀ seg ∈ m.segments, seg.p1 ≠ seg.p2) :
    ∀ poly ∈ m.polygons, ∀ seg ∈ poly.segments, seg.p1 ≠ seg.p2 := by
  intro poly hpoly seg hseg
  exact h seg (List.mem_flatMap.mpr ⟨poly, hpoly, hseg⟩)

/-- Convert a list of polygons (each with `length ≥ 2` and non-degenerate
    segments) into a list of even graphs via `Polygon.toEvenGraph`. -/
def polyEvenGraphs : (polys : List Polygon) →
    (∀ poly ∈ polys, poly.vertices.length ≥ 2) →
    (∀ poly ∈ polys, ∀ seg ∈ poly.segments, seg.p1 ≠ seg.p2) →
    List EvenGraph
  | [], _, _ => []
  | p :: ps, hl, hd =>
    p.toEvenGraph (hl p (List.mem_cons_self _ _)) (hd p (List.mem_cons_self _ _)) ::
      polyEvenGraphs ps (fun q hq => hl q (List.mem_cons_of_mem _ hq))
                        (fun q hq => hd q (List.mem_cons_of_mem _ hq))

/-- The even graph associated with a multipolygon: combine the polygon-derived
    even graphs of its polygons. -/
def toEvenGraph (m : Multipolygon)
    (h_len : ∀ poly ∈ m.polygons, poly.vertices.length ≥ 2)
    (h_distinct : ∀ seg ∈ m.segments, seg.p1 ≠ seg.p2) :
    EvenGraph :=
  EvenGraph.combine (polyEvenGraphs m.polygons h_len (distinct_per_polygon m h_distinct))

/-- The concatenation of the segments of `polyEvenGraphs` equals the
    concatenation of the polygon segments. -/
theorem polyEvenGraphs_flatMap_segments :
    ∀ (polys : List Polygon)
      (h_len : ∀ poly ∈ polys, poly.vertices.length ≥ 2)
      (h_distinct : ∀ poly ∈ polys, ∀ seg ∈ poly.segments, seg.p1 ≠ seg.p2),
    (polyEvenGraphs polys h_len h_distinct).flatMap (·.segments) =
      polys.flatMap Polygon.segments
  | [], _, _ => rfl
  | p :: ps, hl, hd => by
    show (p.toEvenGraph _ _).segments ++
          (polyEvenGraphs ps _ _).flatMap (·.segments)
        = p.segments ++ ps.flatMap Polygon.segments
    rw [Polygon.toEvenGraph_segments_eq, polyEvenGraphs_flatMap_segments ps]

/-- The segments of `Multipolygon.toEvenGraph` equal the multipolygon
    segments. -/
theorem toEvenGraph_segments_eq (m : Multipolygon)
    (h_len : ∀ poly ∈ m.polygons, poly.vertices.length ≥ 2)
    (h_distinct : ∀ seg ∈ m.segments, seg.p1 ≠ seg.p2) :
    (toEvenGraph m h_len h_distinct).segments = m.segments := by
  show (EvenGraph.combine _).segments = m.segments
  rw [EvenGraph.combine_segments]
  exact polyEvenGraphs_flatMap_segments m.polygons h_len (distinct_per_polygon m h_distinct)

/-- A polygon appears in `polys` iff its derived even graph appears in
    `polyEvenGraphs`. (Direction we need: each derived graph corresponds to a
    polygon in the list.) -/
theorem mem_polyEvenGraphs_iff :
    ∀ (polys : List Polygon)
      (h_len : ∀ poly ∈ polys, poly.vertices.length ≥ 2)
      (h_distinct : ∀ poly ∈ polys, ∀ seg ∈ poly.segments, seg.p1 ≠ seg.p2)
      (G : EvenGraph),
    G ∈ polyEvenGraphs polys h_len h_distinct ↔
    ∃ poly, ∃ hp : poly ∈ polys,
      G = poly.toEvenGraph (h_len poly hp) (h_distinct poly hp)
  | [], _, _, _ => by simp [polyEvenGraphs]
  | p :: ps, hl, hd, G => by
    show G ∈ (p.toEvenGraph _ _ :: polyEvenGraphs ps _ _) ↔ _
    rw [List.mem_cons]
    constructor
    · rintro (rfl | hG)
      · exact ⟨p, (List.mem_cons_self _ _), rfl⟩
      · obtain ⟨poly, hp, hG_eq⟩ :=
          (mem_polyEvenGraphs_iff ps _ _ G).mp hG
        exact ⟨poly, List.mem_cons_of_mem _ hp, hG_eq⟩
    · rintro ⟨poly, hp, hG_eq⟩
      rcases List.mem_cons.mp hp with rfl | hp'
      · exact Or.inl hG_eq
      · refine Or.inr ?_
        exact (mem_polyEvenGraphs_iff ps _ _ G).mpr ⟨poly, hp', hG_eq⟩

/-- The boundary of `Multipolygon.toEvenGraph` equals the multipolygon
    boundary. -/
theorem toEvenGraph_toBoundarySet_eq (m : Multipolygon)
    (h_len : ∀ poly ∈ m.polygons, poly.vertices.length ≥ 2)
    (h_distinct : ∀ seg ∈ m.segments, seg.p1 ≠ seg.p2) :
    (toEvenGraph m h_len h_distinct).toBoundarySet = m.toBoundarySet := by
  -- Both are `{p | ∃ seg ∈ <list>, p ∈ seg.toSet}` and the segment lists agree.
  show {p | ∃ seg ∈ (toEvenGraph m h_len h_distinct).segments, p ∈ seg.toSet} =
       {p | ∃ seg ∈ m.segments, p ∈ seg.toSet}
  rw [toEvenGraph_segments_eq]

/-- The vertex set of `Multipolygon.toEvenGraph` equals the multipolygon's
    set of vertices. -/
theorem toEvenGraph_toVertexSet_eq (m : Multipolygon)
    (h_len : ∀ poly ∈ m.polygons, poly.vertices.length ≥ 2)
    (h_distinct : ∀ seg ∈ m.segments, seg.p1 ≠ seg.p2) :
    (toEvenGraph m h_len h_distinct).toVertexSet = m.toVertices := by
  show (EvenGraph.combine _).toVertexSet = m.toVertices
  rw [EvenGraph.combine_toVertexSet]
  ext p
  simp only [Set.mem_iUnion, exists_prop, Multipolygon.toVertices,
             Multipolygon.allVertices, Set.mem_setOf_eq, List.mem_flatMap]
  constructor
  · rintro ⟨G, hG, hp⟩
    obtain ⟨poly, hpoly, hG_eq⟩ :=
      (mem_polyEvenGraphs_iff m.polygons h_len (distinct_per_polygon m h_distinct) G).mp hG
    refine ⟨poly, hpoly, ?_⟩
    -- hp: p ∈ G.toVertexSet; goal: p ∈ poly.vertices.
    have hp' : p ∈ poly.toVertices := by
      rw [← Polygon.toEvenGraph_toVertexSet_eq poly (h_len poly hpoly)
            (distinct_per_polygon m h_distinct poly hpoly), ← hG_eq]
      exact hp
    exact hp'
  · rintro ⟨poly, hpoly, hp⟩
    -- hp: p ∈ poly.vertices; want: p ∈ some G ∈ polyEvenGraphs with G.toVertexSet.
    refine ⟨poly.toEvenGraph (h_len poly hpoly) (distinct_per_polygon m h_distinct poly hpoly), ?_, ?_⟩
    · exact (mem_polyEvenGraphs_iff m.polygons h_len (distinct_per_polygon m h_distinct) _).mpr
        ⟨poly, hpoly, rfl⟩
    · rw [Polygon.toEvenGraph_toVertexSet_eq]
      show p ∈ poly.toVertices
      exact hp

/-- The interior of `Multipolygon.toEvenGraph` equals the multipolygon
    interior. The two interior definitions coincide because they have the
    same segment list and the same vertex set. -/
theorem toEvenGraph_interior_eq (m : Multipolygon)
    (h_len : ∀ poly ∈ m.polygons, poly.vertices.length ≥ 2)
    (h_distinct : ∀ seg ∈ m.segments, seg.p1 ≠ seg.p2) :
    (toEvenGraph m h_len h_distinct).interior = m.interior := by
  ext p
  simp only [EvenGraph.interior, Multipolygon.interior, Set.mem_setOf_eq]
  have h_segs : (toEvenGraph m h_len h_distinct).segments = m.segments :=
    toEvenGraph_segments_eq m h_len h_distinct
  have h_vset : (toEvenGraph m h_len h_distinct).toVertexSet = m.toVertices :=
    toEvenGraph_toVertexSet_eq m h_len h_distinct
  -- Segments equality gives both the avoid-segments part and the crossing count.
  constructor <;> intro ⟨h1, h2⟩
  · refine ⟨fun seg hs => h1 seg (by rw [h_segs]; exact hs), fun r hr hav => ?_⟩
    have hav' : rayAvoidsGraphVertices r (toEvenGraph m h_len h_distinct) := by
      rw [rayAvoidsGraphVertices, h_vset]
      rwa [rayAvoidsMultipolygonVertices] at hav
    have := h2 r hr hav'
    change m.segments.countP _ % 2 = 1
    show intersectionRayMultipolygonSegmentsNumber r m % 2 = 1
    show m.segments.countP _ % 2 = 1
    rw [← h_segs]
    exact this
  · refine ⟨fun seg hs => h1 seg (by rw [← h_segs]; exact hs), fun r hr hav => ?_⟩
    have hav' : rayAvoidsMultipolygonVertices r m := by
      rw [rayAvoidsMultipolygonVertices, ← h_vset]
      rwa [rayAvoidsGraphVertices] at hav
    have := h2 r hr hav'
    change (toEvenGraph m h_len h_distinct).segments.countP _ % 2 = 1
    rw [h_segs]
    exact this

/-- For a multipolygon satisfying length and non-degeneracy hypotheses, every
    vertex in `allVertices` lies on some multipolygon segment. -/
theorem vertex_on_some_segment (m : Multipolygon)
    (h_len : ∀ poly ∈ m.polygons, poly.vertices.length ≥ 2)
    (h_distinct : ∀ seg ∈ m.segments, seg.p1 ≠ seg.p2)
    (v : Vector2D) (hv : v ∈ m.allVertices) :
    ∃ seg ∈ m.segments, v ∈ seg.toSet := by
  -- v ∈ m.allVertices = m.toVertices = (m.toEvenGraph).toVertexSet.
  have hv_set : v ∈ m.toVertices := hv
  rw [← toEvenGraph_toVertexSet_eq m h_len h_distinct] at hv_set
  -- Unfold `toVertexSet` and use `mem_toVertices_iff` to get a segment endpoint.
  change v ∈ (toEvenGraph m h_len h_distinct).toGraph.toVertexSet at hv_set
  simp only [Graph.toVertexSet, Set.mem_setOf_eq,
             EvenGraph.mem_toVertices_iff] at hv_set
  obtain ⟨seg, hseg, hve⟩ := hv_set
  -- Transfer membership: (toEvenGraph).segments = m.segments.
  rw [toEvenGraph_segments_eq m h_len h_distinct] at hseg
  refine ⟨seg, hseg, ?_⟩
  rcases hve with hp1 | hp2
  · refine ⟨0, le_refl _, zero_le_one, ?_, ?_⟩
    · rw [← hp1]; ring
    · rw [← hp1]; ring
  · refine ⟨1, zero_le_one, le_refl _, ?_, ?_⟩
    · rw [← hp2]; ring
    · rw [← hp2]; ring

/-- The interior of a multipolygon characterized via *some* ray (rather than
    *every* ray), analogous to `Polygon.interior_eq_exists`. -/
theorem interior_eq_exists (m : Multipolygon)
    (h_len : ∀ poly ∈ m.polygons, poly.vertices.length ≥ 2)
    (h_distinct : ∀ seg ∈ m.segments, seg.p1 ≠ seg.p2) :
    m.interior =
    { p : Vector2D |
        (∀ seg ∈ m.segments, pointAvoidsSegment p seg) ∧
        ∃ r : Ray, r.origin = p ∧ rayAvoidsMultipolygonVertices r m ∧
          intersectionRayMultipolygonSegmentsNumber r m % 2 = 1 } := by
  rw [← toEvenGraph_interior_eq m h_len h_distinct]
  rw [EvenGraph.interior_eq_exists]
  ext p
  simp only [Set.mem_setOf_eq]
  have h_segs := toEvenGraph_segments_eq m h_len h_distinct
  have h_vset := toEvenGraph_toVertexSet_eq m h_len h_distinct
  constructor
  · rintro ⟨h_avoid, r, hr, h_av, h_count⟩
    refine ⟨fun seg hs => h_avoid seg (by rw [h_segs]; exact hs), r, hr, ?_, ?_⟩
    · rw [rayAvoidsMultipolygonVertices, ← h_vset]
      exact h_av
    · change m.segments.countP _ % 2 = 1
      rw [← h_segs]; exact h_count
  · rintro ⟨h_avoid, r, hr, h_av, h_count⟩
    refine ⟨fun seg hs => h_avoid seg (by rw [← h_segs]; exact hs), r, hr, ?_, ?_⟩
    · rw [rayAvoidsGraphVertices, h_vset]
      rwa [rayAvoidsMultipolygonVertices] at h_av
    · change (toEvenGraph m h_len h_distinct).segments.countP _ % 2 = 1
      rw [h_segs]; exact h_count

/-- The list of polygon interiors corresponds, element-wise, to the list of
    `polyEvenGraphs` interiors. -/
theorem polyEvenGraphs_map_interior :
    ∀ (polys : List Polygon)
      (h_len : ∀ poly ∈ polys, poly.vertices.length ≥ 2)
      (h_distinct : ∀ poly ∈ polys, ∀ seg ∈ poly.segments, seg.p1 ≠ seg.p2),
    (polyEvenGraphs polys h_len h_distinct).map EvenGraph.interior =
      polys.map Polygon.interior
  | [], _, _ => rfl
  | p :: ps, hl, hd => by
    show ((p.toEvenGraph _ _).interior :: _) = _
    rw [Polygon.toEvenGraph_interior_eq, polyEvenGraphs_map_interior ps]
    rfl

/-- The interior of a multipolygon equals the symmetric difference of its
    polygons' interiors, with the multipolygon boundary removed. -/
theorem interior_eq_symmDiffAll_sdiff_boundary (m : Multipolygon)
    (h_len : ∀ poly ∈ m.polygons, poly.vertices.length ≥ 2)
    (h_distinct : ∀ seg ∈ m.segments, seg.p1 ≠ seg.p2) :
    m.interior =
      (m.polygons.map Polygon.interior).symmDiffAll \ m.toBoundarySet := by
  rw [← toEvenGraph_interior_eq m h_len h_distinct]
  show (EvenGraph.combine _).interior = _
  rw [EvenGraph.combine_interior_eq_symmDiff_sdiff_boundary]
  show _ \ (toEvenGraph m h_len h_distinct).toBoundarySet = _
  rw [toEvenGraph_toBoundarySet_eq, polyEvenGraphs_map_interior]

end MultipolygonProofs

