        have hqx1 : q.x - O1.x = t * d.x + delta.x := by
          simp only [delta]; linarith [htx]
        have hqy1 : q.y - O1.y = t * d.y + delta.y := by
          simp only [delta]; linarith [hty]
        constructor
        · -- On HP2 boundary
          exact ⟨_, Or.inr (Or.inl rfl), by rw [htx, hty]; simp only; linarith [h_d_n2 t]⟩
        · intro hp hp_mem
          rcases hp_mem with rfl | rfl | rfl
          · -- HP1: dot = delta · n1 + 0 = κ > 0
            intro h_neg; rw [hqx1, hqy1] at h_neg; simp only at h_neg
            have : (t * d.x + delta.x) * n1.x + (t * d.y + delta.y) * n1.y =
                (t * d.x) * n1.x + (t * d.y) * n1.y + (delta.x * n1.x + delta.y * n1.y) := by ring
            rw [this, h_d_n1 t, h_delta_n1] at h_neg; simp at h_neg; linarith [hκ_pos]
          · -- HP2: dot = 0, not exterior
            intro h_neg; rw [htx, hty] at h_neg; simp only at h_neg; linarith [h_d_n2 t]
          · -- HP3: dot = delta · n3 + t * d · n3 = 0 + t * κ ≥ 0
            intro h_neg
            have h_expand : (q.x - O1.x) * n3.x + (q.y - O1.y) * n3.y =
                t * κ + 0 := by
              calc (q.x - O1.x) * n3.x + (q.y - O1.y) * n3.y
                  = (t * d.x + delta.x) * n3.x + (t * d.y + delta.y) * n3.y := by rw [hqx1, hqy1]
                _ = t * (d.x * n3.x + d.y * n3.y) + (delta.x * n3.x + delta.y * n3.y) := by ring
                _ = t * κ + 0 := by rw [h_d_n3, h_dn3_zero]
            rw [h_expand] at h_neg; nlinarith [hκ_pos]
  -- =====================================================================
  -- Polygon vertices avoid boundary
  -- =====================================================================
  have h_vert : ∀ v ∈ poly.vertices, v ∉ hpi.toBoundarySet := by
    rw [h_bnd]
    intro v hv hmem
    simp only [mem_union] at hmem
    rcases hmem with (hr1 | hseg) | hr2
    · have : v ∈ r1.toSet ∩ poly.toVertices := ⟨hr1, hv⟩
      rw [rayAvoidsVertices] at h_r1_avoids
      rw [h_r1_avoids] at this; exact this
    · exact h_vert_avoids_seg v hv hseg
    · have : v ∈ r2.toSet ∩ poly.toVertices := ⟨hr2, hv⟩
      rw [rayAvoidsVertices] at h_r2_avoids
      rw [h_r2_avoids] at this; exact this
  -- =====================================================================
  -- HPI vertex set = {O1, O2}
  -- Polygon segments avoid HPI vertices
  -- =====================================================================
  have h_seg_av : ∀ seg ∈ poly.segments, ∀ q ∈ seg.toSet, q ∉ hpi.toVertexSet := by
    intro seg hseg q hq_seg hq_vert
    -- hpi.toVertexSet: q on boundary of two distinct HPs
    simp only [HalfPlaneIntersection.toVertexSet, mem_setOf_eq] at hq_vert
    obtain ⟨hp_a, hp_a_mem, hp_b, hp_b_mem, hne, hdot_a, hdot_b⟩ := hq_vert
    -- hp_a, hp_b ∈ hpi.halfPlanes = [hp1, hp2, hp3]
    rw [h_hpi_list] at hp_a_mem hp_b_mem
    simp only [List.mem_cons, (List.not_mem_nil _), or_false] at hp_a_mem hp_b_mem
    suffices hq_origin : q = O1 ∨ q = O2 by
      rcases hq_origin with rfl | rfl
      · exact h_O1_avoids seg hseg hq_seg
      · exact h_O2_avoids seg hseg hq_seg
    have h_det13 : n1.x * n3.y - n1.y * n3.x ≠ 0 := by
      simp only [n1, par_n1, n3, par_n3]
      split <;> (dsimp; intro h; apply h_nc; unfold cross; ring_linarith)
    -- Similarly det(n2, n3)
    have h_det23 : n2.x * n3.y - n2.y * n3.x ≠ 0 := by
      simp only [n2, par_n2, n3, par_n3]
      split <;> (dsimp; intro h; apply h_nc; unfold cross; ring_linarith)
    -- Helper to extract raw dot product from boundary membership
    have to_dot1 : q ∈ hp1.toBoundarySet → (q.x - O1.x) * n1.x + (q.y - O1.y) * n1.y = 0 := id
    have to_dot2 : q ∈ hp2.toBoundarySet → (q.x - O2.x) * n2.x + (q.y - O2.y) * n2.y = 0 := id
    have to_dot3 : q ∈ hp3.toBoundarySet → (q.x - O1.x) * n3.x + (q.y - O1.y) * n3.y = 0 := id
    rcases hp_a_mem with rfl | rfl | rfl <;> rcases hp_b_mem with rfl | rfl | rfl
    · exact absurd rfl hne
    · exfalso
      have h12 : (q.x - O1.x) * n1.x + (q.y - O1.y) * n1.y = 0 := to_dot1 hdot_a
      have h22 : (q.x - O2.x) * n2.x + (q.y - O2.y) * n2.y = 0 := to_dot2 hdot_b
