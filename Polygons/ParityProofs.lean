        calc (seg.p1.x - O1.x) * n3.x + (seg.p1.y - O1.y) * n3.y
            = (tp1 * d.x + delta.x) * n3.x + (tp1 * d.y + delta.y) * n3.y := by rw [hx, hy]
          _ = tp1 * (d.x * n3.x + d.y * n3.y) + (delta.x * n3.x + delta.y * n3.y) := by ring
          _ = tp1 * κ + 0 := by rw [h_d_n3, h_dn3_zero]
          _ = tp1 * κ := by ring
      have h_dot3_p2 : (seg.p2.x - O1.x) * n3.x + (seg.p2.y - O1.y) * n3.y = tp2 * κ := by
        have hx : seg.p2.x - O1.x = tp2 * d.x + delta.x := by
          simp only [delta]; linarith [htp2x]
        have hy : seg.p2.y - O1.y = tp2 * d.y + delta.y := by
          simp only [delta]; linarith [htp2y]
        calc (seg.p2.x - O1.x) * n3.x + (seg.p2.y - O1.y) * n3.y
