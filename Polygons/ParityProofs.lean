        have ht_le : t ≤ 1 := by nlinarith [hκ_pos]
        left; right
        exact ⟨t, ht_nn, ht_le,
          by rw [htx]; ring,
          by rw [hty]; ring⟩
    · -- Backward: r1 ∪ seg ∪ r2 → HPI boundary
      intro hq
      simp only [hpi, par_rays_hpi, HalfPlaneIntersection.toBoundarySet, HalfPlane.toBoundarySet,
