          _ = n2.x * 0 - n3.x * 0 := by rw [h22, h32']
          _ = 0 := by ring
        exact (mul_eq_zero.mp this).resolve_right h_det23
      exact (Vector2D.mk.injEq _ _ _ _).mpr ⟨by linarith, by linarith⟩
    · -- HP3 + HP1: same as HP1 + HP3 with swapped order → q = O1
      left
      have h32 : (q.x - O1.x) * n3.x + (q.y - O1.y) * n3.y = 0 := to_dot3 hdot_a
      have h12 : (q.x - O1.x) * n1.x + (q.y - O1.y) * n1.y = 0 := to_dot1 hdot_b
      have hdx : q.x - O1.x = 0 := by
        have := calc (q.x - O1.x) * (n1.x * n3.y - n1.y * n3.x)
            = n3.y * ((q.x - O1.x) * n1.x + (q.y - O1.y) * n1.y) -
              n1.y * ((q.x - O1.x) * n3.x + (q.y - O1.y) * n3.y) := by ring
          _ = n3.y * 0 - n1.y * 0 := by rw [h12, h32]
          _ = 0 := by ring
        exact (mul_eq_zero.mp this).resolve_right h_det13
      have hdy : q.y - O1.y = 0 := by
        have := calc (q.y - O1.y) * (n1.x * n3.y - n1.y * n3.x)
            = n1.x * ((q.x - O1.x) * n3.x + (q.y - O1.y) * n3.y) -
              n3.x * ((q.x - O1.x) * n1.x + (q.y - O1.y) * n1.y) := by ring
          _ = n1.x * 0 - n3.x * 0 := by rw [h12, h32]
          _ = 0 := by ring
        exact (mul_eq_zero.mp this).resolve_right h_det13
      exact (Vector2D.mk.injEq _ _ _ _).mpr ⟨by linarith, by linarith⟩
    · -- HP3 + HP2: same as HP2 + HP3 with swapped order → q = O2
      right
      have h32 : (q.x - O1.x) * n3.x + (q.y - O1.y) * n3.y = 0 := to_dot3 hdot_a
      have h22 : (q.x - O2.x) * n2.x + (q.y - O2.y) * n2.y = 0 := to_dot2 hdot_b
      have h32' : (q.x - O2.x) * n3.x + (q.y - O2.y) * n3.y = 0 := by
        have hqx : q.x - O2.x = (q.x - O1.x) - delta.x := by simp only [delta]; ring
        have hqy : q.y - O2.y = (q.y - O1.y) - delta.y := by simp only [delta]; ring
        rw [hqx, hqy]
        have : ((q.x - O1.x) - delta.x) * n3.x + ((q.y - O1.y) - delta.y) * n3.y =
            ((q.x - O1.x) * n3.x + (q.y - O1.y) * n3.y) -
            (delta.x * n3.x + delta.y * n3.y) := by ring
        rw [this, h32]
        have : delta.x * n3.x + delta.y * n3.y = 0 := h_dn3_zero
        linarith
      have hdx : q.x - O2.x = 0 := by
        have := calc (q.x - O2.x) * (n2.x * n3.y - n2.y * n3.x)
            = n3.y * ((q.x - O2.x) * n2.x + (q.y - O2.y) * n2.y) -
              n2.y * ((q.x - O2.x) * n3.x + (q.y - O2.y) * n3.y) := by ring
          _ = n3.y * 0 - n2.y * 0 := by rw [h22, h32']
          _ = 0 := by ring
        exact (mul_eq_zero.mp this).resolve_right h_det23
      have hdy : q.y - O2.y = 0 := by
        have := calc (q.y - O2.y) * (n2.x * n3.y - n2.y * n3.x)
            = n2.x * ((q.x - O2.x) * n3.x + (q.y - O2.y) * n3.y) -
              n3.x * ((q.x - O2.x) * n2.x + (q.y - O2.y) * n2.y) := by ring
          _ = n2.x * 0 - n3.x * 0 := by rw [h22, h32']
          _ = 0 := by ring
        exact (mul_eq_zero.mp this).resolve_right h_det23
      exact (Vector2D.mk.injEq _ _ _ _).mpr ⟨by linarith, by linarith⟩
    · exact absurd rfl hne
