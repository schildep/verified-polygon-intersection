            intro h_neg
            have : (q.x - O1.x) * n3.x + (q.y - O1.y) * n3.y = t * (d.x * n3.x + d.y * n3.y) := by
              rw [show q.x - O1.x = t * d.x from by linarith [htx],
                  show q.y - O1.y = t * d.y from by linarith [hty]]
              ring
            rw [this, h_d_n3] at h_neg; nlinarith [hκ_pos]
