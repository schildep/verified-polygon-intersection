        -- q = (1-t)*O1 + t*O2 = O1 + t*delta
        have hqx : q.x - O1.x = t * delta.x := by
          simp only [delta]; linarith [htx]
        have hqy : q.y - O1.y = t * delta.y := by
          simp only [delta]; linarith [hty]
        constructor
        · -- On HP3 boundary
          exact ⟨_, Or.inr (Or.inr rfl), by rw [hqx, hqy]; linarith [h_delta_n3 t]⟩
        · intro hp hp_mem
          rcases hp_mem with rfl | rfl | rfl
          · -- HP1: dot = t * delta · n1 = t * κ ≥ 0
            intro h_neg
            have h_expand : (q.x - O1.x) * n1.x + (q.y - O1.y) * n1.y =
                t * (delta.x * n1.x + delta.y * n1.y) := by
              rw [hqx, hqy]; ring
            rw [h_expand, h_delta_n1] at h_neg
            nlinarith [hκ_pos]
          · -- HP2: dot = (t-1) * delta · n2 = (t-1) * (-κ) ≥ 0
            intro h_neg
            have h_expand : (q.x - O2.x) * n2.x + (q.y - O2.y) * n2.y =
                (t - 1) * (delta.x * n2.x + delta.y * n2.y) := by
              have hqx2 : q.x - O2.x = (t - 1) * delta.x := by
                simp only [delta]; linarith [htx]
              have hqy2 : q.y - O2.y = (t - 1) * delta.y := by
                simp only [delta]; linarith [hty]
              rw [hqx2, hqy2]; ring
            rw [h_expand, h_delta_n2] at h_neg
            nlinarith [hκ_pos]
          · -- HP3: dot = 0, not exterior
            intro h_neg; rw [hqx, hqy] at h_neg; simp only at h_neg
            have h_dn3 := h_delta_n3 t
            ring_nf at h_dn3 h_neg
            linarith
      · -- q ∈ r2 (t ≥ 0)
