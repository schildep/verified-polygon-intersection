        by_contra h_nn; push_neg at h_nn
        apply h_p2_not_bnd; rw [h_bnd]
        exact Set.mem_union_left _ (Set.mem_union_left _ ⟨tp2, h_nn, htp2x, htp2y⟩)
      -- q1 on r1 at parameter t > 0 → (q1 - O1) · n3 = t * κ > 0
      -- seg.p1 at tp1 < 0 → dot3 = tp1 * κ < 0
      -- seg.p2 at tp2 < 0 → dot3 = tp2 * κ < 0
      -- q1 on segment: q1 = (1-s)*p1 + s*p2
