-- ============================================================================
-- Helper: rotation preserves nonzero
-- ============================================================================

private lemma rot90_nonzero (v : Vector2D) (hv : v ≠ ⟨0, 0⟩) :
    (⟨-v.y, v.x⟩ : Vector2D) ≠ ⟨0, 0⟩ := by
  intro h; apply hv
  have hx : (-v.y : ℚ) = 0 := congrArg Vector2D.x h
  have hy : v.x = 0 := congrArg Vector2D.y h
  simp at hx
  exact (Vector2D.mk.injEq _ _ _ _).mpr ⟨hy, hx⟩

private lemma rot270_nonzero (v : Vector2D) (hv : v ≠ ⟨0, 0⟩) :
    (⟨v.y, -v.x⟩ : Vector2D) ≠ ⟨0, 0⟩ := by
  intro h; apply hv
  have hx : v.y = 0 := congrArg Vector2D.x h
  have hy : (-v.x : ℚ) = 0 := congrArg Vector2D.y h
  simp at hy
  exact (Vector2D.mk.injEq _ _ _ _).mpr ⟨hy, hx⟩

-- ============================================================================
-- Cross product and direction trichotomy
-- ============================================================================

/-- Cross product (z-component) of two 2D vectors. -/
private def cross (v w : Vector2D) : ℚ := v.x * w.y - v.y * w.x

/-- Two nonzero 2D vectors are either positively proportional,
    negatively proportional, or non-collinear (nonzero cross product). -/
private lemma direction_trichotomy (d1 d2 : Vector2D)
    (hd1 : d1 ≠ ⟨0, 0⟩) (hd2 : d2 ≠ ⟨0, 0⟩) :
    (∃ c : ℚ, c > 0 ∧ d1.x = c * d2.x ∧ d1.y = c * d2.y) ∨
    (∃ c : ℚ, c < 0 ∧ d1.x = c * d2.x ∧ d1.y = c * d2.y) ∨
    cross d1 d2 ≠ 0 := by
  by_cases hcross : cross d1 d2 ≠ 0
  · exact Or.inr (Or.inr hcross)
  · push_neg at hcross
    unfold cross at hcross
    have hcross : d1.x * d2.y = d1.y * d2.x := by linarith
    have hd2_or : d2.x ≠ 0 ∨ d2.y ≠ 0 := by
      by_contra h; push_neg at h
      exact hd2 ((Vector2D.mk.injEq _ _ _ _).mpr ⟨h.1, h.2⟩)
    -- Helper: given c with d1.x = c * d2.x and d1.y = c * d2.y, classify by sign
    suffices ∃ c : ℚ, d1.x = c * d2.x ∧ d1.y = c * d2.y by
      obtain ⟨c, hcx, hcy⟩ := this
      rcases lt_trichotomy c 0 with hlt | heq | hgt
      · exact Or.inr (Or.inl ⟨c, hlt, hcx, hcy⟩)
      · -- c = 0 → d1 = 0, contradiction
        subst heq; simp at hcx hcy
        exact absurd ((Vector2D.mk.injEq _ _ _ _).mpr ⟨hcx, hcy⟩) hd1
      · exact Or.inl ⟨c, hgt, hcx, hcy⟩
    rcases hd2_or with hx | hy
    · refine ⟨d1.x / d2.x, ?_, ?_⟩
      · exact (div_mul_cancel₀ d1.x hx).symm
      · calc d1.y = d1.y * d2.x / d2.x := (mul_div_cancel_right₀ d1.y hx).symm
          _ = d1.x * d2.y / d2.x := by rw [hcross.symm]
          _ = d1.x / d2.x * d2.y := by ring
    · refine ⟨d1.y / d2.y, ?_, ?_⟩
      · calc d1.x = d1.x * d2.y / d2.y := (mul_div_cancel_right₀ d1.x hy).symm
          _ = d1.y * d2.x / d2.y := by rw [hcross]
          _ = d1.y / d2.y * d2.x := by ring
      · exact (div_mul_cancel₀ d1.y hy).symm

-- ============================================================================
-- Case 1: Same direction → same ray → equal counts
-- ============================================================================

/-- Rays with same origin and proportional positive direction have equal point sets. -/
private lemma same_dir_same_toSet (r1 r2 : Ray) (h_origin : sameOrigin r1 r2)
    (h_same : ∃ c : ℚ, c > 0 ∧ r1.direction.x = c * r2.direction.x ∧
                                  r1.direction.y = c * r2.direction.y) :
    r1.toSet = r2.toSet := by
  obtain ⟨c, hc_pos, hcx, hcy⟩ := h_same
  unfold sameOrigin at h_origin
  ext p
  simp only [Ray.toSet, mem_setOf_eq]
  constructor
  · -- p ∈ r1.toSet → p ∈ r2.toSet
    rintro ⟨t, ht, hpx, hpy⟩
    refine ⟨t * c, ?_, ?_, ?_⟩
    · exact mul_nonneg ht (le_of_lt hc_pos)
    · rw [hpx, h_origin]; congr 1; rw [hcx]; ring
    · rw [hpy, h_origin]; congr 1; rw [hcy]; ring
  · -- p ∈ r2.toSet → p ∈ r1.toSet
    rintro ⟨t, ht, hpx, hpy⟩
    refine ⟨t / c, ?_, ?_, ?_⟩
    · exact div_nonneg ht (le_of_lt hc_pos)
    · rw [hpx, ← h_origin, hcx, ← mul_assoc, div_mul_cancel₀ t (ne_of_gt hc_pos)]
    · rw [hpy, ← h_origin, hcy, ← mul_assoc, div_mul_cancel₀ t (ne_of_gt hc_pos)]

/-- Same-direction rays give equal intersection counts. -/
private lemma same_dir_eq_count (r1 r2 : Ray) (poly : Polygon)
    (h_origin : sameOrigin r1 r2)
    (h_same : ∃ c : ℚ, c > 0 ∧ r1.direction.x = c * r2.direction.x ∧
                                  r1.direction.y = c * r2.direction.y) :
    intersectionRayPolygonSegmentsNumber r1 poly =
    intersectionRayPolygonSegmentsNumber r2 poly := by
  have h_eq := same_dir_same_toSet r1 r2 h_origin h_same
  have : ∀ seg : LineSegment, rayIntersectsSegment r1 seg = rayIntersectsSegment r2 seg := by
    intro seg; unfold rayIntersectsSegment; rw [h_eq]
  simp [intersectionRayPolygonSegmentsNumber, this]

-- ============================================================================
-- Case 2: Opposite direction → single half-plane
-- The boundary of the HP is the line containing both rays.
-- polygon_crossings_even gives: total line crossings are even.
-- Total line crossings = count_r1 + count_r2 (since O avoids all segments).
-- Hence same parity.
-- ============================================================================

/-- Single-HP HPI from a ray: boundary is the line through the origin
    perpendicular to the normal (-d.y, d.x). -/
private def opposite_rays_hpi (r : Ray) : HalfPlaneIntersection :=
  ⟨[⟨r.origin, ⟨-r.direction.y, r.direction.x⟩, rot90_nonzero r.direction r.direction_nonzero⟩]⟩

/-- The boundary of this HPI equals the line through the origin with direction d,
    which is r1.toSet ∪ r2.toSet when the rays are opposite. -/
private lemma opposite_hpi_boundary_eq (r1 r2 : Ray) (h_origin : sameOrigin r1 r2)
    (h_opp : ∃ c : ℚ, c < 0 ∧ r1.direction.x = c * r2.direction.x ∧
                                 r1.direction.y = c * r2.direction.y) :
    (opposite_rays_hpi r1).toBoundarySet = r1.toSet ∪ r2.toSet := by
  obtain ⟨c, hc_neg, hcx, hcy⟩ := h_opp
  unfold sameOrigin at h_origin
  ext q; simp only [mem_union]; constructor
  · -- HPI boundary → r1 ∪ r2
    intro hq
    simp only [opposite_rays_hpi, HalfPlaneIntersection.toBoundarySet, HalfPlane.toBoundarySet,
               HalfPlane.toExteriorSet, HalfPlane.dot, mem_setOf_eq, List.mem_singleton] at hq
    obtain ⟨⟨_, rfl, hdot⟩, _⟩ := hq
    -- hdot : (q.x - O.x) * (-d.y) + (q.y - O.y) * d.x = 0
    have heq : (q.x - r1.origin.x) * r1.direction.y =
               (q.y - r1.origin.y) * r1.direction.x := by ring_linarith
    have hd_or : r1.direction.x ≠ 0 ∨ r1.direction.y ≠ 0 := by
      by_contra h; push_neg at h
      exact r1.direction_nonzero ((Vector2D.mk.injEq _ _ _ _).mpr ⟨h.1, h.2⟩)
    -- Find t such that q = O + t*d
    suffices ∃ t : ℚ, q.x = r1.origin.x + t * r1.direction.x ∧
                       q.y = r1.origin.y + t * r1.direction.y by
      obtain ⟨t, htx, hty⟩ := this
      by_cases ht : 0 ≤ t
      · left; exact ⟨t, ht, htx, hty⟩
      · push_neg at ht; right
        refine ⟨t * c, le_of_lt (mul_pos_of_neg_of_neg ht hc_neg), ?_, ?_⟩
        · rw [htx, h_origin, hcx]; ring
        · rw [hty, h_origin, hcy]; ring
    rcases hd_or with hdx | hdy
    · refine ⟨(q.x - r1.origin.x) / r1.direction.x, ?_, ?_⟩
      · rw [div_mul_cancel₀ (q.x - r1.origin.x) hdx]; ring
      · have h1 : (q.x - r1.origin.x) / r1.direction.x * r1.direction.y * r1.direction.x =
                   (q.y - r1.origin.y) * r1.direction.x := by
          calc _ = (q.x - r1.origin.x) / r1.direction.x * r1.direction.x * r1.direction.y := by ring
            _ = (q.x - r1.origin.x) * r1.direction.y := by rw [div_mul_cancel₀ _ hdx]
            _ = (q.y - r1.origin.y) * r1.direction.x := heq
        linarith [mul_right_cancel₀ hdx h1]
    · refine ⟨(q.y - r1.origin.y) / r1.direction.y, ?_, ?_⟩
      · have h1 : (q.y - r1.origin.y) / r1.direction.y * r1.direction.x * r1.direction.y =
                   (q.x - r1.origin.x) * r1.direction.y := by
          calc _ = (q.y - r1.origin.y) / r1.direction.y * r1.direction.y * r1.direction.x := by ring
            _ = (q.y - r1.origin.y) * r1.direction.x := by rw [div_mul_cancel₀ _ hdy]
            _ = (q.x - r1.origin.x) * r1.direction.y := heq.symm
        linarith [mul_right_cancel₀ hdy h1]
      · rw [div_mul_cancel₀ (q.y - r1.origin.y) hdy]; ring
  · -- r1 ∪ r2 → HPI boundary
    intro hq
    have hdot_eq : (q.x - r1.origin.x) * (-r1.direction.y) +
                   (q.y - r1.origin.y) * r1.direction.x = 0 := by
      rcases hq with ⟨t, _, hqx, hqy⟩ | ⟨t, _, hqx, hqy⟩
      · rw [hqx, hqy]; ring
      · rw [hqx, hqy, hcx, hcy, h_origin]; ring
    simp only [opposite_rays_hpi, HalfPlaneIntersection.toBoundarySet, HalfPlane.toBoundarySet,
               HalfPlane.toExteriorSet, HalfPlane.dot, mem_setOf_eq, List.mem_singleton]
    exact ⟨⟨_, rfl, hdot_eq⟩, fun _ ha => by subst ha; ring_linarith⟩

/-- Polygon vertices avoid the single-HP boundary. -/
private lemma opposite_hpi_vertices_avoid (r1 r2 : Ray) (poly : Polygon)
    (h_origin : sameOrigin r1 r2)
    (h_opp : ∃ c : ℚ, c < 0 ∧ r1.direction.x = c * r2.direction.x ∧
                                 r1.direction.y = c * r2.direction.y)
    (h_r1_avoids : rayAvoidsVertices r1 poly)
    (h_r2_avoids : rayAvoidsVertices r2 poly) :
    ∀ v ∈ poly.vertices, v ∉ (opposite_rays_hpi r1).toBoundarySet := by
  rw [opposite_hpi_boundary_eq r1 r2 h_origin h_opp]
  intro v hv hmem
  simp only [mem_union] at hmem
  rcases hmem with hr1 | hr2
  · have : v ∈ r1.toSet ∩ poly.toVertices := ⟨hr1, hv⟩
    rw [rayAvoidsVertices] at h_r1_avoids
    rw [h_r1_avoids] at this; exact this
  · have : v ∈ r2.toSet ∩ poly.toVertices := ⟨hr2, hv⟩
    rw [rayAvoidsVertices] at h_r2_avoids
    rw [h_r2_avoids] at this; exact this

/-- Single-HP HPI has empty vertex set (only one half-plane). -/
private lemma opposite_hpi_segments_avoid (r : Ray) (poly : Polygon) :
    ∀ seg ∈ poly.segments, ∀ q ∈ seg.toSet, q ∉ (opposite_rays_hpi r).toVertexSet := by
  intro seg _ q _ hq
  simp only [opposite_rays_hpi, HalfPlaneIntersection.toVertexSet, mem_setOf_eq] at hq
  obtain ⟨hp1, hp1_mem, hp2, hp2_mem, hne, _, _⟩ := hq
  simp only [List.mem_singleton] at hp1_mem hp2_mem
  exact hne (hp1_mem.trans hp2_mem.symm)

/-- For a single-HP HPI, the HPI boundary set = the HP boundary set. -/
private lemma single_hpi_boundary_eq_hp (hp : HalfPlane) :
    (HalfPlaneIntersection.mk [hp]).toBoundarySet = hp.toBoundarySet := by
  ext q; simp only [HalfPlaneIntersection.toBoundarySet, HalfPlane.toBoundarySet,
    HalfPlane.toExteriorSet, mem_setOf_eq, List.mem_singleton]
  constructor
  · rintro ⟨⟨_, rfl, h⟩, _⟩; exact h
  · intro h; exact ⟨⟨_, rfl, h⟩, fun _ ha => by subst ha; simp; linarith⟩

/-- In a subsingleton finite set, card = 0 or 1; card = 1 iff nonempty. -/
private lemma subsingleton_card (S : Set Vector2D) (hfin : S.Finite) (hsub : S.Subsingleton) :
    hfin.toFinset.card ≤ 1 := by
  rw [Finset.card_le_one]
  intro a ha b hb
  exact hsub (hfin.mem_toFinset.mp ha) (hfin.mem_toFinset.mp hb)

/-- A finite nonempty set has card ≥ 1. -/
private lemma nonempty_card (S : Set Vector2D) (hfin : S.Finite) (hne : S.Nonempty) :
    1 ≤ hfin.toFinset.card := by
  rw [Finset.one_le_card]
  exact hfin.toFinset_nonempty.mpr hne

/-- countP as sum of map. -/
private lemma countP_eq_map_sum {α : Type} (p : α → Bool) (l : List α) :
    l.countP p = (l.map fun x => if p x then 1 else 0).sum := by
  induction l with
  | nil => simp
  | cons a rest ih => simp only [List.countP_cons, List.map_cons, List.sum_cons, ih]; split <;> omega

/-- sum of map (f + g) = sum of map f + sum of map g. -/
private lemma sum_map_add {α : Type} (f g : α → ℕ) (l : List α) :
    (l.map fun x => f x + g x).sum = (l.map f).sum + (l.map g).sum := by
  induction l with
  | nil => simp
  | cons a rest ih => simp only [List.map_cons, List.sum_cons, ih]; omega

/-- If (a, b) ∈ l1.zip l2 then a ∈ l1. -/
private lemma zip_mem_left {α β : Type} {a : α} {b : β} {l1 : List α} {l2 : List β}
    (h : (a, b) ∈ l1.zip l2) : a ∈ l1 := by
  induction l1 generalizing l2 with
  | nil => simp at h
  | cons x xs ih =>
    match l2 with
    | [] => simp at h
    | _ :: ys =>
      simp at h
      rcases h with ⟨rfl, _⟩ | htl
      · exact .head _
      · exact .tail _ (ih htl)

/-- If (a, b) ∈ l1.zip l2 then b ∈ l2. -/
private lemma zip_mem_right {α β : Type} {a : α} {b : β} {l1 : List α} {l2 : List β}
    (h : (a, b) ∈ l1.zip l2) : b ∈ l2 := by
  induction l1 generalizing l2 with
  | nil => simp at h
  | cons x xs ih =>
    match l2 with
    | [] => simp at h
    | _ :: ys =>
      simp at h
      rcases h with ⟨_, rfl⟩ | htl
      · exact .head _
      · exact .tail _ (ih htl)

/-- For seg ∈ poly.segments, seg.p1 ∈ poly.vertices. -/
private lemma seg_p1_mem_vertices (poly : Polygon) (seg : LineSegment)
    (hseg : seg ∈ poly.segments) : seg.p1 ∈ poly.vertices := by
  cases hv : poly.vertices with
  | nil => simp [Polygon.segments, hv] at hseg
  | cons v vs =>
    cases vs with
    | nil => simp [Polygon.segments, hv] at hseg
    | cons w ws =>
      have hpoly : poly = ⟨v :: w :: ws⟩ := by cases poly; simp_all
      subst hpoly
      simp only [Polygon.segments, List.mem_map, Prod.exists] at hseg
      obtain ⟨a, b, h_zip, h_eq⟩ := hseg
      have : seg.p1 = a := congrArg LineSegment.p1 h_eq.symm
      rw [this]; exact zip_mem_left h_zip

/-- For seg ∈ poly.segments, seg.p2 ∈ poly.vertices. -/
private lemma seg_p2_mem_vertices (poly : Polygon) (seg : LineSegment)
    (hseg : seg ∈ poly.segments) : seg.p2 ∈ poly.vertices := by
  cases hv : poly.vertices with
  | nil => simp [Polygon.segments, hv] at hseg
  | cons v vs =>
    cases vs with
    | nil => simp [Polygon.segments, hv] at hseg
    | cons w ws =>
      have hpoly : poly = ⟨v :: w :: ws⟩ := by cases poly; simp_all
      subst hpoly
      simp only [Polygon.segments, List.mem_map, Prod.exists] at hseg
      obtain ⟨a, b, h_zip, h_eq⟩ := hseg
      have : seg.p2 = b := congrArg LineSegment.p2 h_eq.symm
      rw [this]
      have hb : b ∈ (w :: ws) ++ [v] := zip_mem_right h_zip
      simp only [List.mem_append, List.mem_cons] at hb ⊢
      tauto

/-- Total crossings of single-HP HPI = r1 count + r2 count for opposite rays. -/
private lemma opposite_hpi_total_eq (r1 r2 : Ray) (poly : Polygon)
    (h_origin : sameOrigin r1 r2)
    (h_opp : ∃ c : ℚ, c < 0 ∧ r1.direction.x = c * r2.direction.x ∧
                                 r1.direction.y = c * r2.direction.y)
    (h_r1_avoids : rayAvoidsVertices r1 poly)
    (h_r2_avoids : rayAvoidsVertices r2 poly)
    (h_origin_avoids : ∀ seg ∈ poly.segments, pointAvoidsSegment r1.origin seg) :
    (poly.segments.map fun seg => segCrossingCount seg (opposite_rays_hpi r1)).sum =
    intersectionRayPolygonSegmentsNumber r1 poly +
    intersectionRayPolygonSegmentsNumber r2 poly := by
  obtain ⟨c, hc_neg, hcx, hcy⟩ := h_opp
  unfold sameOrigin at h_origin
  set hpi := opposite_rays_hpi r1 with hpi_def
  set hp : HalfPlane := ⟨r1.origin, ⟨-r1.direction.y, r1.direction.x⟩,
    rot90_nonzero r1.direction r1.direction_nonzero⟩ with hp_def
  have h_bnd := opposite_hpi_boundary_eq r1 r2 h_origin ⟨c, hc_neg, hcx, hcy⟩
  have h_hpi_hp : hpi.toBoundarySet = hp.toBoundarySet :=
    single_hpi_boundary_eq_hp hp
  have h_vert := opposite_hpi_vertices_avoid r1 r2 poly h_origin ⟨c, hc_neg, hcx, hcy⟩
    h_r1_avoids h_r2_avoids
  -- Helper: endpoint not on boundary → hp.dot ≠ 0
  have endpoint_not_on_bnd : ∀ v ∈ poly.vertices, hp.dot v ≠ 0 := by
    intro v hv hdot
    have : v ∈ hpi.toBoundarySet := by rw [h_hpi_hp]; exact hdot
    exact h_vert v hv this
  -- Per-segment: segCrossingCount = decide_r1 + decide_r2
  suffices h_per : ∀ seg ∈ poly.segments,
      segCrossingCount seg hpi =
        (if decide (rayIntersectsSegment r1 seg) then 1 else 0) +
        (if decide (rayIntersectsSegment r2 seg) then 1 else 0) by
    -- Rewrite via List.map_congr + sum_map_add
    have h_map : (poly.segments.map fun seg => segCrossingCount seg hpi) =
        poly.segments.map fun seg =>
          (if decide (rayIntersectsSegment r1 seg) then 1 else 0) +
          (if decide (rayIntersectsSegment r2 seg) then 1 else 0) :=
      List.map_congr_left h_per
    rw [h_map, sum_map_add]
    unfold intersectionRayPolygonSegmentsNumber
    rw [countP_eq_map_sum, countP_eq_map_sum]
  -- Prove per-segment result
  intro seg hseg
  have hp1_vert := seg_p1_mem_vertices poly seg hseg
  have hp2_vert := seg_p2_mem_vertices poly seg hseg
  have hp_dot_p1 : hp.dot seg.p1 ≠ 0 := endpoint_not_on_bnd seg.p1 hp1_vert
  have hp_dot_p2 : hp.dot seg.p2 ≠ 0 := endpoint_not_on_bnd seg.p2 hp2_vert
  -- Crossing set is subsingleton
  have h_sub := hp.boundary_segment_subsingleton seg (Or.inl hp_dot_p1)
  -- Crossing set in terms of hpi boundary
  have h_cross_eq : seg.boundaryCrossings hpi = seg.toSet ∩ hp.toBoundarySet := by
    unfold LineSegment.boundaryCrossings; rw [h_hpi_hp]
  -- Crossing set is subsingleton (rewritten)
  have h_sub2 : (seg.boundaryCrossings hpi).Subsingleton := by
    rw [h_cross_eq]; exact h_sub
  -- Crossing set is finite
  have h_fin : (seg.boundaryCrossings hpi).Finite := h_sub2.finite
  -- card ≤ 1
  have h_card_le := subsingleton_card _ h_fin h_sub2
  -- segCrossingCount = card
  have h_cc : segCrossingCount seg hpi = h_fin.toFinset.card := by
    simp [segCrossingCount, dif_pos h_fin]
  -- Boundary = r1 ∪ r2
  -- Origin avoids segment
  have h_O_avoids := h_origin_avoids seg hseg
  unfold pointAvoidsSegment at h_O_avoids
  -- r1 ∩ r2 ∩ seg = ∅ (only common point is origin, which avoids seg)
  -- So: seg ∩ r1 and seg ∩ r2 are disjoint
  have h_disjoint : ∀ q, q ∈ seg.toSet → q ∈ r1.toSet → q ∈ r2.toSet → False := by
    intro q hq_seg hq_r1 hq_r2
    -- q ∈ r1 and q ∈ r2 → q = origin
    obtain ⟨t1, ht1, ht1x, ht1y⟩ := hq_r1
    obtain ⟨t2, ht2, ht2x, ht2y⟩ := hq_r2
    -- q.x = O.x + t1 * d1.x = O.x + t2 * d2.x (using h_origin for r2)
    -- So t1 * d1.x = t2 * d2.x and t1 * d1.y = t2 * d2.y
    have heqx : t1 * r1.direction.x = t2 * r2.direction.x := by
      have := ht1x; rw [ht2x, h_origin] at this; linarith
    have heqy : t1 * r1.direction.y = t2 * r2.direction.y := by
      have := ht1y; rw [ht2y, h_origin] at this; linarith
    -- d1 = c * d2, so t1 * c * d2.x = t2 * d2.x and t1 * c * d2.y = t2 * d2.y
    -- Hence (t1 * c - t2) * d2 = 0 → t1 * c = t2 (since d2 ≠ 0)
    have hd2_or : r2.direction.x ≠ 0 ∨ r2.direction.y ≠ 0 := by
      by_contra h; push_neg at h
      exact r2.direction_nonzero ((Vector2D.mk.injEq _ _ _ _).mpr ⟨h.1, h.2⟩)
    have h_tc : t1 * c = t2 := by
      rcases hd2_or with hdx | hdy
      · have : t1 * (c * r2.direction.x) = t2 * r2.direction.x := by rw [← hcx]; linarith [heqx]
        have : (t1 * c - t2) * r2.direction.x = 0 := by linarith
        have := (mul_eq_zero.mp this).resolve_right hdx; linarith
      · have : t1 * (c * r2.direction.y) = t2 * r2.direction.y := by rw [← hcy]; linarith [heqy]
        have : (t1 * c - t2) * r2.direction.y = 0 := by linarith
        have := (mul_eq_zero.mp this).resolve_right hdy; linarith
    -- t1 ≥ 0, t2 ≥ 0, c < 0, t1 * c = t2 → t1 * c ≥ 0 and c < 0 → t1 ≤ 0 → t1 = 0
    have ht1_zero : t1 = 0 := by nlinarith
    -- Then t2 = 0
    have ht2_zero : t2 = 0 := by nlinarith [h_tc, ht1_zero]
    -- q = origin
    have hq_origin : q = r1.origin := by
      exact (Vector2D.mk.injEq _ _ _ _).mpr
        ⟨by rw [ht1x]; simp [ht1_zero], by rw [ht1y]; simp [ht1_zero]⟩
    exact h_O_avoids (hq_origin ▸ hq_seg)
  -- Now case-split on card
  -- Boundary crossing = seg ∩ (r1 ∪ r2) via h_bnd
  have h_cross_union : seg.boundaryCrossings hpi = seg.toSet ∩ (r1.toSet ∪ r2.toSet) := by
    unfold LineSegment.boundaryCrossings; rw [h_bnd]
  -- Card ∈ {0, 1}
  have h_01 : h_fin.toFinset.card = 0 ∨ h_fin.toFinset.card = 1 := by omega
  rcases h_01 with hcard | hcard
  · -- card = 0: no crossings → neither ray intersects
    rw [h_cc, hcard]
    have h_empty : seg.boundaryCrossings hpi = ∅ :=
      (Set.Finite.toFinset_eq_empty (h := h_fin)).mp (Finset.card_eq_zero.mp hcard)
    have h_r1_no : ¬rayIntersectsSegment r1 seg := by
      intro ⟨q, hq1, hq2⟩
      have : q ∈ seg.boundaryCrossings hpi := by rw [h_cross_union]; exact ⟨hq2, Or.inl hq1⟩
      rw [h_empty] at this; exact this
    have h_r2_no : ¬rayIntersectsSegment r2 seg := by
      intro ⟨q, hq1, hq2⟩
      have : q ∈ seg.boundaryCrossings hpi := by rw [h_cross_union]; exact ⟨hq2, Or.inr hq1⟩
      rw [h_empty] at this; exact this
    simp [h_r1_no, h_r2_no]
  · -- card = 1: exactly one crossing → exactly one ray intersects
    rw [h_cc, hcard]
    -- There exists exactly one crossing point
    have h_ne : (seg.boundaryCrossings hpi).Nonempty :=
      h_fin.toFinset_nonempty.mp (Finset.card_pos.mp (by omega))
    rw [h_cross_union] at h_ne
    obtain ⟨q, hq_seg, hq_ray⟩ := h_ne
    rcases hq_ray with hq_r1 | hq_r2
    · -- q on r1: r1 intersects, r2 doesn't (by disjointness + subsingleton)
      have h_r1_yes : rayIntersectsSegment r1 seg := ⟨q, hq_r1, hq_seg⟩
      have h_r2_no : ¬rayIntersectsSegment r2 seg := by
        intro ⟨q', hq'_r2, hq'_seg⟩
        -- q' is on seg ∩ r2, so q' ∈ boundary crossings
        have hq'_cross : q' ∈ seg.boundaryCrossings hpi := by
          rw [h_cross_union]; exact ⟨hq'_seg, Or.inr hq'_r2⟩
        -- q is also in boundary crossings
        have hq_cross : q ∈ seg.boundaryCrossings hpi := by
          rw [h_cross_union]; exact ⟨hq_seg, Or.inl hq_r1⟩
        -- subsingleton: q = q'
        have := h_sub2 hq_cross hq'_cross
        -- But q ∈ r1, q' ∈ r2, and q = q' → q ∈ r1 ∩ r2 ∩ seg
        exact h_disjoint q hq_seg hq_r1 (this ▸ hq'_r2)
      simp [h_r1_yes, h_r2_no]
    · -- q on r2: r2 intersects, r1 doesn't
      have h_r2_yes : rayIntersectsSegment r2 seg := ⟨q, hq_r2, hq_seg⟩
      have h_r1_no : ¬rayIntersectsSegment r1 seg := by
        intro ⟨q', hq'_r1, hq'_seg⟩
        have hq'_cross : q' ∈ seg.boundaryCrossings hpi := by
          rw [h_cross_union]; exact ⟨hq'_seg, Or.inl hq'_r1⟩
        have hq_cross : q ∈ seg.boundaryCrossings hpi := by
          rw [h_cross_union]; exact ⟨hq_seg, Or.inr hq_r2⟩
        have := h_sub2 hq_cross hq'_cross
        exact h_disjoint q hq_seg (this ▸ hq'_r1) hq_r2
      simp [h_r1_no, h_r2_yes]

/-- Opposite-direction rays have same crossing parity via polygon_crossings_even. -/
private lemma opposite_rays_same_parity (r1 r2 : Ray) (poly : Polygon)
    (h_origin : sameOrigin r1 r2)
    (h_opp : ∃ c : ℚ, c < 0 ∧ r1.direction.x = c * r2.direction.x ∧
                                 r1.direction.y = c * r2.direction.y)
    (h_r1_avoids : rayAvoidsVertices r1 poly)
    (h_r2_avoids : rayAvoidsVertices r2 poly)
    (h_origin_avoids : ∀ seg ∈ poly.segments, pointAvoidsSegment r1.origin seg) :
    intersectionRayPolygonSegmentsNumber r1 poly % 2 =
    intersectionRayPolygonSegmentsNumber r2 poly % 2 := by
  -- Apply polygon_crossings_even to the single-HP HPI
  have h_pcr := HalfPlaneIntersection.polygon_crossings_even_proof
    (opposite_rays_hpi r1) poly
    (opposite_hpi_vertices_avoid r1 r2 poly h_origin h_opp h_r1_avoids h_r2_avoids)
    (opposite_hpi_segments_avoid r1 poly)
  -- Total crossings are even
  have h_even := h_pcr.2
  -- Relate total to ray counts
  have h_total := opposite_hpi_total_eq r1 r2 poly h_origin h_opp
    h_r1_avoids h_r2_avoids h_origin_avoids
  rw [h_total] at h_even
  -- Even (count_r1 + count_r2) → count_r1 % 2 = count_r2 % 2
  obtain ⟨k, hk⟩ := h_even
  omega

-- ============================================================================
-- Case 3: Non-collinear → two half-planes
-- The HPI boundary = r1 ∪ r2 (with normals chosen so each ray is the
-- "non-exterior" part of its boundary line).
-- polygon_crossings_even gives: total boundary crossings are even.
-- Total = count_r1 + count_r2. Hence same parity.
-- ============================================================================

/-- Normal to d1 pointing toward d2's side (for the first half-plane). -/
private def choose_n1 (d1 d2 : Vector2D) : Vector2D :=
  if cross d1 d2 > 0 then ⟨-d1.y, d1.x⟩ else ⟨d1.y, -d1.x⟩

/-- Normal to d2 pointing toward d1's side (for the second half-plane). -/
private def choose_n2 (d1 d2 : Vector2D) : Vector2D :=
  if cross d1 d2 > 0 then ⟨d2.y, -d2.x⟩ else ⟨-d2.y, d2.x⟩

private lemma choose_n1_nonzero (d1 d2 : Vector2D) (hd1 : d1 ≠ ⟨0, 0⟩) :
    choose_n1 d1 d2 ≠ ⟨0, 0⟩ := by
  simp only [choose_n1]; split
  · exact rot90_nonzero d1 hd1
  · exact rot270_nonzero d1 hd1

private lemma choose_n2_nonzero (d1 d2 : Vector2D) (hd2 : d2 ≠ ⟨0, 0⟩) :
    choose_n2 d1 d2 ≠ ⟨0, 0⟩ := by
  simp only [choose_n2]; split
  · exact rot270_nonzero d2 hd2
  · exact rot90_nonzero d2 hd2

/-- Construct 2-HP HPI from non-collinear rays.
    HP1 has boundary = line through O in direction d1, normal pointing toward r2.
    HP2 has boundary = line through O in direction d2, normal pointing toward r1.
    The HPI boundary then equals r1.toSet ∪ r2.toSet. -/
private noncomputable def nc_rays_hpi (r1 r2 : Ray) (_h_origin : sameOrigin r1 r2)
    (_h_nc : cross r1.direction r2.direction ≠ 0) : HalfPlaneIntersection :=
  ⟨[⟨r1.origin, choose_n1 r1.direction r2.direction,
     choose_n1_nonzero r1.direction r2.direction r1.direction_nonzero⟩,
    ⟨r1.origin, choose_n2 r1.direction r2.direction,
     choose_n2_nonzero r1.direction r2.direction r2.direction_nonzero⟩]⟩

/-- Extract line parameter: if (q-O)·n = 0 and d⊥n, then q = O + t*d. -/
private lemma extract_line_param (d O q : Vector2D) (hd : d ≠ ⟨0, 0⟩)
    (h : (q.x - O.x) * d.y = (q.y - O.y) * d.x) :
    ∃ t : ℚ, q.x = O.x + t * d.x ∧ q.y = O.y + t * d.y := by
  have hd_or : d.x ≠ 0 ∨ d.y ≠ 0 := by
    by_contra hc; push_neg at hc
    exact hd ((Vector2D.mk.injEq _ _ _ _).mpr ⟨hc.1, hc.2⟩)
  rcases hd_or with hdx | hdy
  · refine ⟨(q.x - O.x) / d.x, ?_, ?_⟩
    · rw [div_mul_cancel₀ (q.x - O.x) hdx]; ring
    · have h2 : (q.x - O.x) / d.x * d.y * d.x = (q.y - O.y) * d.x := by
        calc _ = (q.x - O.x) / d.x * d.x * d.y := by ring
          _ = (q.x - O.x) * d.y := by rw [div_mul_cancel₀ _ hdx]
          _ = (q.y - O.y) * d.x := h
      linarith [mul_right_cancel₀ hdx h2]
  · refine ⟨(q.y - O.y) / d.y, ?_, ?_⟩
    · have h2 : (q.y - O.y) / d.y * d.x * d.y = (q.x - O.x) * d.y := by
        calc _ = (q.y - O.y) / d.y * d.y * d.x := by ring
          _ = (q.y - O.y) * d.x := by rw [div_mul_cancel₀ _ hdy]
          _ = (q.x - O.x) * d.y := h.symm
      linarith [mul_right_cancel₀ hdy h2]
    · rw [div_mul_cancel₀ (q.y - O.y) hdy]; ring

/-- The boundary of the 2-HP HPI equals r1 ∪ r2. -/
private lemma nc_hpi_boundary_eq (r1 r2 : Ray) (h_origin : sameOrigin r1 r2)
    (h_nc : cross r1.direction r2.direction ≠ 0) :
    (nc_rays_hpi r1 r2 h_origin h_nc).toBoundarySet = r1.toSet ∪ r2.toSet := by
  unfold sameOrigin at h_origin
  set d1 := r1.direction; set d2 := r2.direction; set O := r1.origin
  set n1 := choose_n1 d1 d2; set n2 := choose_n2 d1 d2
  -- Key algebraic facts: normals are perpendicular to own direction, cross-dot is positive
  have h_d1_n1 : ∀ t : ℚ, (t * d1.x) * n1.x + (t * d1.y) * n1.y = 0 := by
    intro t; simp only [n1, choose_n1]; split <;> ring
  have h_d2_n2 : ∀ t : ℚ, (t * d2.x) * n2.x + (t * d2.y) * n2.y = 0 := by
    intro t; simp only [n2, choose_n2]; split <;> ring
  -- Cross dot products: t * d1 · n2 and t * d2 · n1
  set κ : ℚ := if cross d1 d2 > 0 then cross d1 d2 else -(cross d1 d2)
  have hκ_pos : κ > 0 := by
    simp only [κ]; split
    · assumption
    · rename_i h; push_neg at h; linarith [lt_of_le_of_ne h h_nc]
  have h_d1_n2 : ∀ t : ℚ, (t * d1.x) * n2.x + (t * d1.y) * n2.y = t * κ := by
    intro t; simp only [n2, choose_n2, κ, cross]; split <;> ring
  have h_d2_n1 : ∀ t : ℚ, (t * d2.x) * n1.x + (t * d2.y) * n1.y = t * κ := by
    intro t; simp only [n1, choose_n1, κ, cross]; split <;> ring
  -- Perpendicularity conversions: dot=0 → line equation
  have h_perp1 : ∀ q : Vector2D, (q.x - O.x) * n1.x + (q.y - O.y) * n1.y = 0 →
      (q.x - O.x) * d1.y = (q.y - O.y) * d1.x := by
    intro q hq; simp only [n1, choose_n1] at hq; split at hq <;> ring_linarith
  have h_perp2 : ∀ q : Vector2D, (q.x - O.x) * n2.x + (q.y - O.y) * n2.y = 0 →
      (q.x - O.x) * d2.y = (q.y - O.y) * d2.x := by
    intro q hq; simp only [n2, choose_n2] at hq; split at hq <;> ring_linarith
  ext q; simp only [mem_union]; constructor
  · -- Forward: HPI boundary → r1 ∪ r2
    intro hq
    simp only [nc_rays_hpi, HalfPlaneIntersection.toBoundarySet, HalfPlane.toBoundarySet,
      HalfPlane.toExteriorSet, HalfPlane.dot, mem_setOf_eq, List.mem_cons, (List.not_mem_nil _), or_false] at hq
    obtain ⟨⟨hp, hp_mem, hdot⟩, h_not_ext⟩ := hq
    rcases hp_mem with rfl | rfl
    · -- hp = hp1 (boundary along d1)
      have h_line := h_perp1 q hdot
      obtain ⟨t, htx, hty⟩ := extract_line_param d1 O q r1.direction_nonzero h_line
      have h_hp2 := h_not_ext _ (Or.inr rfl)
      push_neg at h_hp2
      have h_dot2 : (q.x - O.x) * n2.x + (q.y - O.y) * n2.y = t * κ := by
        rw [show (q.x - O.x) = t * d1.x from by linarith [htx],
            show (q.y - O.y) = t * d1.y from by linarith [hty]]
        exact h_d1_n2 t
      have ht_nn : 0 ≤ t := by nlinarith [h_hp2, h_dot2, hκ_pos]
      left; exact ⟨t, ht_nn, htx, hty⟩
    · -- hp = hp2 (boundary along d2)
      have h_line := h_perp2 q hdot
      obtain ⟨t, htx, hty⟩ := extract_line_param d2 O q r2.direction_nonzero h_line
      have h_hp1 := h_not_ext _ (Or.inl rfl)
      push_neg at h_hp1
      have h_dot1 : (q.x - O.x) * n1.x + (q.y - O.y) * n1.y = t * κ := by
        rw [show (q.x - O.x) = t * d2.x from by linarith [htx],
            show (q.y - O.y) = t * d2.y from by linarith [hty]]
        exact h_d2_n1 t
      have ht_nn : 0 ≤ t := by nlinarith [h_hp1, h_dot1, hκ_pos]
      right; exact ⟨t, ht_nn, by rw [htx, h_origin], by rw [hty, h_origin]⟩
  · -- Backward: r1 ∪ r2 → HPI boundary
    intro hq
    simp only [nc_rays_hpi, HalfPlaneIntersection.toBoundarySet, HalfPlane.toBoundarySet,
      HalfPlane.toExteriorSet, HalfPlane.dot, mem_setOf_eq, List.mem_cons, (List.not_mem_nil _), or_false]
    rcases hq with ⟨t, ht, htx, hty⟩ | ⟨t, ht, htx, hty⟩
    · -- q ∈ r1: on hp1 boundary, not exterior to hp2
      constructor
      · exact ⟨_, Or.inl rfl, by rw [htx, hty]; simp only; linarith [h_d1_n1 t]⟩
      · intro hp hp_mem
        rcases hp_mem with rfl | rfl
        · intro h_neg; rw [htx, hty] at h_neg; simp only at h_neg; linarith [h_d1_n1 t]
        · intro h_neg; rw [htx, hty] at h_neg; simp only at h_neg; nlinarith [h_d1_n2 t]
    · -- q ∈ r2: on hp2 boundary, not exterior to hp1
      have h_oeq : r1.origin = r2.origin := h_origin
      constructor
      · exact ⟨_, Or.inr rfl, by rw [htx, hty]; simp only; rw [h_oeq]; linarith [h_d2_n2 t]⟩
      · intro hp hp_mem
        rcases hp_mem with rfl | rfl
        · intro h_neg; rw [htx, hty] at h_neg; simp only at h_neg; rw [h_oeq] at h_neg; nlinarith [h_d2_n1 t]
        · intro h_neg; rw [htx, hty] at h_neg; simp only at h_neg; rw [h_oeq] at h_neg; linarith [h_d2_n2 t]

/-- Polygon vertices avoid the 2-HP boundary. -/
private lemma nc_hpi_vertices_avoid (r1 r2 : Ray) (poly : Polygon)
    (h_origin : sameOrigin r1 r2) (h_nc : cross r1.direction r2.direction ≠ 0)
    (h_r1_avoids : rayAvoidsVertices r1 poly)
    (h_r2_avoids : rayAvoidsVertices r2 poly) :
    ∀ v ∈ poly.vertices, v ∉ (nc_rays_hpi r1 r2 h_origin h_nc).toBoundarySet := by
  rw [nc_hpi_boundary_eq r1 r2 h_origin h_nc]
  intro v hv hmem
  simp only [mem_union] at hmem
  rcases hmem with hr1 | hr2
  · have : v ∈ r1.toSet ∩ poly.toVertices := ⟨hr1, hv⟩
    rw [rayAvoidsVertices] at h_r1_avoids
    rw [h_r1_avoids] at this; exact this
  · have : v ∈ r2.toSet ∩ poly.toVertices := ⟨hr2, hv⟩
    rw [rayAvoidsVertices] at h_r2_avoids
    rw [h_r2_avoids] at this; exact this

/-- Polygon segments avoid the 2-HP HPI vertices (= {origin}). -/
private lemma nc_hpi_segments_avoid (r1 r2 : Ray) (poly : Polygon)
    (h_origin : sameOrigin r1 r2) (h_nc : cross r1.direction r2.direction ≠ 0)
    (h_origin_avoids : ∀ seg ∈ poly.segments, pointAvoidsSegment r1.origin seg) :
    ∀ seg ∈ poly.segments, ∀ q ∈ seg.toSet,
      q ∉ (nc_rays_hpi r1 r2 h_origin h_nc).toVertexSet := by
  intro seg hseg q hq_seg hq_vert
  simp only [nc_rays_hpi, HalfPlaneIntersection.toVertexSet, HalfPlane.toBoundarySet,
    HalfPlane.dot, mem_setOf_eq, List.mem_cons] at hq_vert
  obtain ⟨hp1, hp1_mem, hp2, hp2_mem, hne, hdot1, hdot2⟩ := hq_vert
  unfold sameOrigin at h_origin
  -- Determinant of the normal vectors ≠ 0
  have h_det : (choose_n1 r1.direction r2.direction).x *
               (choose_n2 r1.direction r2.direction).y -
               (choose_n1 r1.direction r2.direction).y *
               (choose_n2 r1.direction r2.direction).x ≠ 0 := by
    unfold choose_n1 choose_n2
    split <;> (dsimp; intro h; apply h_nc; unfold cross; linarith)
  -- Extract both dot-product equations from membership in 2-element list
  have h_both : (q.x - r1.origin.x) * (choose_n1 r1.direction r2.direction).x +
                (q.y - r1.origin.y) * (choose_n1 r1.direction r2.direction).y = 0 ∧
                (q.x - r1.origin.x) * (choose_n2 r1.direction r2.direction).x +
                (q.y - r1.origin.y) * (choose_n2 r1.direction r2.direction).y = 0 := by
    rcases hp1_mem with rfl | rfl | h1
    · rcases hp2_mem with rfl | rfl | h2
      · exact absurd rfl hne
      · exact ⟨hdot1, hdot2⟩
      · simp at h2
    · rcases hp2_mem with rfl | rfl | h2
      · exact ⟨hdot2, hdot1⟩
      · exact absurd rfl hne
      · simp at h2
    · simp at h1
  obtain ⟨eq1, eq2⟩ := h_both
  -- Abbreviate for readability
  set n1 := choose_n1 r1.direction r2.direction
  set n2 := choose_n2 r1.direction r2.direction
  -- Cramer's rule via ring identity + rw
  have hdx : q.x - r1.origin.x = 0 := by
    have := calc (q.x - r1.origin.x) * (n1.x * n2.y - n1.y * n2.x)
        = n2.y * ((q.x - r1.origin.x) * n1.x + (q.y - r1.origin.y) * n1.y) -
          n1.y * ((q.x - r1.origin.x) * n2.x + (q.y - r1.origin.y) * n2.y) := by ring
      _ = n2.y * 0 - n1.y * 0 := by rw [eq1, eq2]
      _ = 0 := by ring
    exact (mul_eq_zero.mp this).resolve_right h_det
  have hdy : q.y - r1.origin.y = 0 := by
    have := calc (q.y - r1.origin.y) * (n1.x * n2.y - n1.y * n2.x)
        = n1.x * ((q.x - r1.origin.x) * n2.x + (q.y - r1.origin.y) * n2.y) -
          n2.x * ((q.x - r1.origin.x) * n1.x + (q.y - r1.origin.y) * n1.y) := by ring
      _ = n1.x * 0 - n2.x * 0 := by rw [eq1, eq2]
      _ = 0 := by ring
    exact (mul_eq_zero.mp this).resolve_right h_det
  have hq_eq : q = r1.origin :=
    (Vector2D.mk.injEq _ _ _ _).mpr ⟨by linarith, by linarith⟩
  exact h_origin_avoids seg hseg (hq_eq ▸ hq_seg)

/-- Total crossings of 2-HP HPI = r1 count + r2 count for non-collinear rays. -/
private lemma nc_hpi_total_eq (r1 r2 : Ray) (poly : Polygon)
    (h_origin : sameOrigin r1 r2) (h_nc : cross r1.direction r2.direction ≠ 0)
    (h_r1_avoids : rayAvoidsVertices r1 poly)
    (h_r2_avoids : rayAvoidsVertices r2 poly)
    (h_origin_avoids : ∀ seg ∈ poly.segments, pointAvoidsSegment r1.origin seg) :
    (poly.segments.map fun seg => segCrossingCount seg (nc_rays_hpi r1 r2 h_origin h_nc)).sum =
    intersectionRayPolygonSegmentsNumber r1 poly +
    intersectionRayPolygonSegmentsNumber r2 poly := by
  have h_oeq : r1.origin = r2.origin := h_origin
  set hpi := nc_rays_hpi r1 r2 h_origin h_nc with hpi_def
  set d1 := r1.direction; set d2 := r2.direction; set O := r1.origin
  set n1 := choose_n1 d1 d2; set n2 := choose_n2 d1 d2
  have h_bnd := nc_hpi_boundary_eq r1 r2 h_origin h_nc
  have h_vert := nc_hpi_vertices_avoid r1 r2 poly h_origin h_nc h_r1_avoids h_r2_avoids
  -- Algebraic dot-product identities
  have h_d1_n1 : ∀ t : ℚ, (t * d1.x) * n1.x + (t * d1.y) * n1.y = 0 := by
    intro t; simp only [n1, choose_n1]; split <;> ring
  have h_d2_n2 : ∀ t : ℚ, (t * d2.x) * n2.x + (t * d2.y) * n2.y = 0 := by
    intro t; simp only [n2, choose_n2]; split <;> ring
  set κ : ℚ := if cross d1 d2 > 0 then cross d1 d2 else -(cross d1 d2)
  have hκ_pos : κ > 0 := by
    simp only [κ]; split
    · assumption
    · rename_i h; push_neg at h; linarith [lt_of_le_of_ne h h_nc]
  have h_d1_n2 : ∀ t : ℚ, (t * d1.x) * n2.x + (t * d1.y) * n2.y = t * κ := by
    intro t; simp only [n2, choose_n2, κ, cross]; split <;> ring
  have h_d2_n1 : ∀ t : ℚ, (t * d2.x) * n1.x + (t * d2.y) * n1.y = t * κ := by
    intro t; simp only [n1, choose_n1, κ, cross]; split <;> ring
  -- Per-segment: segCrossingCount = decide_r1 + decide_r2
  suffices h_per : ∀ seg ∈ poly.segments,
      segCrossingCount seg hpi =
        (if decide (rayIntersectsSegment r1 seg) then 1 else 0) +
        (if decide (rayIntersectsSegment r2 seg) then 1 else 0) by
    have h_map : (poly.segments.map fun seg => segCrossingCount seg hpi) =
        poly.segments.map fun seg =>
          (if decide (rayIntersectsSegment r1 seg) then 1 else 0) +
          (if decide (rayIntersectsSegment r2 seg) then 1 else 0) :=
      List.map_congr_left h_per
    rw [h_map, sum_map_add]
    unfold intersectionRayPolygonSegmentsNumber
    rw [countP_eq_map_sum, countP_eq_map_sum]
  -- Prove per-segment result
  intro seg hseg
  have hp1_vert := seg_p1_mem_vertices poly seg hseg
  have hp2_vert := seg_p2_mem_vertices poly seg hseg
  -- Endpoints not on HPI boundary
  have h_p1_not_bnd : seg.p1 ∉ hpi.toBoundarySet := h_vert seg.p1 hp1_vert
  have h_p2_not_bnd : seg.p2 ∉ hpi.toBoundarySet := h_vert seg.p2 hp2_vert
  -- Segments avoid HPI vertices
  have h_seg_avoids := nc_hpi_segments_avoid r1 r2 poly h_origin h_nc h_origin_avoids seg hseg
  -- Boundary crossings are finite
  have h_fin : (seg.boundaryCrossings hpi).Finite :=
    HalfPlaneIntersection.boundaryCrossings_finite hpi seg h_p1_not_bnd h_p2_not_bnd h_seg_avoids
  -- segCrossingCount = card
  have h_cc : segCrossingCount seg hpi = h_fin.toFinset.card := by
    simp [segCrossingCount, dif_pos h_fin]
  -- Boundary = r1 ∪ r2
  have h_cross_union : seg.boundaryCrossings hpi = seg.toSet ∩ (r1.toSet ∪ r2.toSet) := by
    unfold LineSegment.boundaryCrossings; rw [h_bnd]
  -- Origin avoids segment
  have h_O_avoids := h_origin_avoids seg hseg
  unfold pointAvoidsSegment at h_O_avoids
  -- Disjointness: no segment point is on both rays
  have h_disjoint : ∀ q, q ∈ seg.toSet → q ∈ r1.toSet → q ∈ r2.toSet → False := by
    intro q hq_seg hq_r1 hq_r2
    obtain ⟨t1, ht1, ht1x, ht1y⟩ := hq_r1
    obtain ⟨t2, ht2, ht2x, ht2y⟩ := hq_r2
    have h_ox : r1.origin.x = r2.origin.x := congrArg Vector2D.x h_oeq
    have h_oy : r1.origin.y = r2.origin.y := congrArg Vector2D.y h_oeq
    have heqx : t1 * d1.x = t2 * d2.x := by linarith
    have heqy : t1 * d1.y = t2 * d2.y := by linarith
    have h_tc : t1 * cross d1 d2 = 0 := by
      have hm1 : (t1 * d1.x) * d2.y = (t2 * d2.x) * d2.y := congr_arg (· * d2.y) heqx
      have hm2 : (t1 * d1.y) * d2.x = (t2 * d2.y) * d2.x := congr_arg (· * d2.x) heqy
      simp only [cross]; ring_nf at hm1 hm2 ⊢; linarith
    have ht1_zero : t1 = 0 := (mul_eq_zero.mp h_tc).resolve_right h_nc
    have ht2_zero : t2 = 0 := by
      have hd2_or : d2.x ≠ 0 ∨ d2.y ≠ 0 := by
        by_contra h; push_neg at h
        exact r2.direction_nonzero ((Vector2D.mk.injEq _ _ _ _).mpr ⟨h.1, h.2⟩)
      have h0x : t1 * d1.x = 0 := by rw [ht1_zero]; ring
      have h0y : t1 * d1.y = 0 := by rw [ht1_zero]; ring
      have h1 : t2 * d2.x = 0 := by linarith
      have h2 : t2 * d2.y = 0 := by linarith
      rcases hd2_or with hdx | hdy
      · exact (mul_eq_zero.mp h1).resolve_right hdx
      · exact (mul_eq_zero.mp h2).resolve_right hdy
    rw [ht1_zero] at ht1x ht1y
    simp only [zero_mul, add_zero] at ht1x ht1y
    rw [show q = O from (Vector2D.mk.injEq _ _ _ _).mpr ⟨ht1x, ht1y⟩] at hq_seg
    exact h_O_avoids hq_seg
  -- seg ∩ r1 is subsingleton
  have h_seg_r1_sub : (seg.toSet ∩ r1.toSet).Subsingleton := by
    let hp1' : HalfPlane := ⟨O, n1, choose_n1_nonzero d1 d2 r1.direction_nonzero⟩
    have h_r1_bnd : r1.toSet ⊆ hp1'.toBoundarySet := by
      intro q ⟨t, _, htx, hty⟩
      show (q.x - O.x) * n1.x + (q.y - O.y) * n1.y = 0
      rw [show q.x - O.x = t * d1.x from by linarith,
          show q.y - O.y = t * d1.y from by linarith]
      exact h_d1_n1 t
    by_cases h_nd1 : hp1'.dot seg.p1 ≠ 0 ∨ hp1'.dot seg.p2 ≠ 0
    · intro a ha b hb
      exact hp1'.boundary_segment_subsingleton seg h_nd1
        ⟨ha.1, h_r1_bnd ha.2⟩ ⟨hb.1, h_r1_bnd hb.2⟩
    · push_neg at h_nd1
      -- Both endpoints on hp1' boundary → seg ∩ r1 empty
      intro q1 ⟨hq1_seg, hq1_r1⟩ q2 _; exfalso
      obtain ⟨t, ht, htx, hty⟩ := hq1_r1
      have h_tpos : 0 < t := by
        rcases eq_or_lt_of_le ht with rfl | h
        · exfalso; apply h_O_avoids
          simp only [zero_mul, add_zero] at htx hty
          rw [show q1 = O from (Vector2D.mk.injEq _ _ _ _).mpr ⟨htx, hty⟩] at hq1_seg
          exact hq1_seg
        · exact h
      -- hp2.dot q1 = t*κ > 0 (from being on r1)
      have h_dot_pos : (q1.x - O.x) * n2.x + (q1.y - O.y) * n2.y > 0 := by
        rw [show q1.x - O.x = t * d1.x from by linarith,
            show q1.y - O.y = t * d1.y from by linarith]
        linarith [h_d1_n2 t, mul_pos h_tpos hκ_pos]
      -- hp2.dot seg.p1 < 0 (if ≥ 0 then seg.p1 ∈ r1, contradiction)
      have h_hp2_p1 : (seg.p1.x - O.x) * n2.x + (seg.p1.y - O.y) * n2.y < 0 := by
        by_contra hge; push_neg at hge
        have h_line : (seg.p1.x - O.x) * d1.y = (seg.p1.y - O.y) * d1.x := by
          have h0 : (seg.p1.x - O.x) * n1.x + (seg.p1.y - O.y) * n1.y = 0 := h_nd1.1
          simp only [n1, choose_n1] at h0; split at h0 <;> ring_linarith
        obtain ⟨tp, htpx, htpy⟩ := extract_line_param d1 O seg.p1 r1.direction_nonzero h_line
        have h_tpk : tp * κ ≥ 0 := by
          have : (seg.p1.x - O.x) * n2.x + (seg.p1.y - O.y) * n2.y = tp * κ := by
            rw [show seg.p1.x - O.x = tp * d1.x from by linarith,
                show seg.p1.y - O.y = tp * d1.y from by linarith]; exact h_d1_n2 tp
          linarith
        have h_tp_nn : tp ≥ 0 := by
          by_contra h_neg; push_neg at h_neg
          exact absurd h_tpk (not_le.mpr (mul_neg_of_neg_of_pos h_neg hκ_pos))
        exact absurd (show seg.p1 ∈ hpi.toBoundarySet by
          rw [h_bnd]; exact Set.mem_union_left _ ⟨tp, h_tp_nn, htpx, htpy⟩) h_p1_not_bnd
      -- hp2.dot seg.p2 < 0
      have h_hp2_p2 : (seg.p2.x - O.x) * n2.x + (seg.p2.y - O.y) * n2.y < 0 := by
        by_contra hge; push_neg at hge
        have h_line : (seg.p2.x - O.x) * d1.y = (seg.p2.y - O.y) * d1.x := by
          have h0 : (seg.p2.x - O.x) * n1.x + (seg.p2.y - O.y) * n1.y = 0 := h_nd1.2
          simp only [n1, choose_n1] at h0; split at h0 <;> ring_linarith
        obtain ⟨tp, htpx, htpy⟩ := extract_line_param d1 O seg.p2 r1.direction_nonzero h_line
        have h_tpk : tp * κ ≥ 0 := by
          have : (seg.p2.x - O.x) * n2.x + (seg.p2.y - O.y) * n2.y = tp * κ := by
            rw [show seg.p2.x - O.x = tp * d1.x from by linarith,
                show seg.p2.y - O.y = tp * d1.y from by linarith]; exact h_d1_n2 tp
          linarith
        have h_tp_nn : tp ≥ 0 := by
          by_contra h_neg; push_neg at h_neg
          exact absurd h_tpk (not_le.mpr (mul_neg_of_neg_of_pos h_neg hκ_pos))
        exact absurd (show seg.p2 ∈ hpi.toBoundarySet by
          rw [h_bnd]; exact Set.mem_union_left _ ⟨tp, h_tp_nn, htpx, htpy⟩) h_p2_not_bnd
      -- hp2.dot q1 < 0 from segment (contradicts > 0 from r1)
      obtain ⟨s, hs0, hs1, hsx, hsy⟩ := hq1_seg
      have h_dot_seg : (q1.x - O.x) * n2.x + (q1.y - O.y) * n2.y =
        (1 - s) * ((seg.p1.x - O.x) * n2.x + (seg.p1.y - O.y) * n2.y) +
        s * ((seg.p2.x - O.x) * n2.x + (seg.p2.y - O.y) * n2.y) := by
        rw [show q1.x - O.x = (1 - s) * (seg.p1.x - O.x) + s * (seg.p2.x - O.x) from by linarith,
            show q1.y - O.y = (1 - s) * (seg.p1.y - O.y) + s * (seg.p2.y - O.y) from by linarith]
        ring
      rcases eq_or_lt_of_le hs0 with rfl | hs_pos
      · simp at h_dot_seg; linarith
      · linarith [mul_neg_of_pos_of_neg hs_pos h_hp2_p2,
          mul_nonpos_of_nonneg_of_nonpos (show (1 : ℚ) - s ≥ 0 by linarith) (le_of_lt h_hp2_p1)]
  -- seg ∩ r2 is subsingleton
  have h_seg_r2_sub : (seg.toSet ∩ r2.toSet).Subsingleton := by
    let hp2' : HalfPlane := ⟨O, n2, choose_n2_nonzero d1 d2 r2.direction_nonzero⟩
    have h_r2_bnd : r2.toSet ⊆ hp2'.toBoundarySet := by
      intro q ⟨t, _, htx, hty⟩
      show (q.x - O.x) * n2.x + (q.y - O.y) * n2.y = 0
      rw [show q.x - O.x = t * d2.x from by linarith [congrArg Vector2D.x h_oeq],
          show q.y - O.y = t * d2.y from by linarith [congrArg Vector2D.y h_oeq]]
      exact h_d2_n2 t
    by_cases h_nd2 : hp2'.dot seg.p1 ≠ 0 ∨ hp2'.dot seg.p2 ≠ 0
    · intro a ha b hb
      exact hp2'.boundary_segment_subsingleton seg h_nd2
        ⟨ha.1, h_r2_bnd ha.2⟩ ⟨hb.1, h_r2_bnd hb.2⟩
    · push_neg at h_nd2
      intro q1 ⟨hq1_seg, hq1_r2⟩ q2 _; exfalso
      obtain ⟨t, ht, htx, hty⟩ := hq1_r2
      have h_tpos : 0 < t := by
        rcases eq_or_lt_of_le ht with rfl | h
        · exfalso; apply h_O_avoids
          simp only [zero_mul, add_zero] at htx hty
          have hqx : q1.x = O.x := by linarith [congrArg Vector2D.x h_oeq]
          have hqy : q1.y = O.y := by linarith [congrArg Vector2D.y h_oeq]
          rw [show q1 = O from (Vector2D.mk.injEq _ _ _ _).mpr ⟨hqx, hqy⟩] at hq1_seg
          exact hq1_seg
        · exact h
      -- hp1.dot q1 = t*κ > 0 (from being on r2)
      have h_dot_pos : (q1.x - O.x) * n1.x + (q1.y - O.y) * n1.y > 0 := by
        rw [show q1.x - O.x = t * d2.x from by linarith [congrArg Vector2D.x h_oeq],
            show q1.y - O.y = t * d2.y from by linarith [congrArg Vector2D.y h_oeq]]
        linarith [h_d2_n1 t, mul_pos h_tpos hκ_pos]
      -- hp1.dot seg.p1 < 0 (if ≥ 0 then seg.p1 ∈ r2, contradiction)
      have h_hp1_p1 : (seg.p1.x - O.x) * n1.x + (seg.p1.y - O.y) * n1.y < 0 := by
        by_contra hge; push_neg at hge
        have h_line : (seg.p1.x - O.x) * d2.y = (seg.p1.y - O.y) * d2.x := by
          have h0 : (seg.p1.x - O.x) * n2.x + (seg.p1.y - O.y) * n2.y = 0 := h_nd2.1
          simp only [n2, choose_n2] at h0; split at h0 <;> ring_linarith
        obtain ⟨tp, htpx, htpy⟩ := extract_line_param d2 O seg.p1 r2.direction_nonzero h_line
        have h_tpk : tp * κ ≥ 0 := by
          have : (seg.p1.x - O.x) * n1.x + (seg.p1.y - O.y) * n1.y = tp * κ := by
            rw [show seg.p1.x - O.x = tp * d2.x from by linarith,
                show seg.p1.y - O.y = tp * d2.y from by linarith]; exact h_d2_n1 tp
          linarith
        have h_tp_nn : tp ≥ 0 := by
          by_contra h_neg; push_neg at h_neg
          exact absurd h_tpk (not_le.mpr (mul_neg_of_neg_of_pos h_neg hκ_pos))
        exact absurd (show seg.p1 ∈ hpi.toBoundarySet by
          rw [h_bnd]; exact Set.mem_union_right _
            ⟨tp, h_tp_nn, by linarith [congrArg Vector2D.x h_oeq],
                           by linarith [congrArg Vector2D.y h_oeq]⟩) h_p1_not_bnd
      -- hp1.dot seg.p2 < 0
      have h_hp1_p2 : (seg.p2.x - O.x) * n1.x + (seg.p2.y - O.y) * n1.y < 0 := by
        by_contra hge; push_neg at hge
        have h_line : (seg.p2.x - O.x) * d2.y = (seg.p2.y - O.y) * d2.x := by
          have h0 : (seg.p2.x - O.x) * n2.x + (seg.p2.y - O.y) * n2.y = 0 := h_nd2.2
          simp only [n2, choose_n2] at h0; split at h0 <;> ring_linarith
        obtain ⟨tp, htpx, htpy⟩ := extract_line_param d2 O seg.p2 r2.direction_nonzero h_line
        have h_tpk : tp * κ ≥ 0 := by
          have : (seg.p2.x - O.x) * n1.x + (seg.p2.y - O.y) * n1.y = tp * κ := by
            rw [show seg.p2.x - O.x = tp * d2.x from by linarith,
                show seg.p2.y - O.y = tp * d2.y from by linarith]; exact h_d2_n1 tp
          linarith
        have h_tp_nn : tp ≥ 0 := by
          by_contra h_neg; push_neg at h_neg
          exact absurd h_tpk (not_le.mpr (mul_neg_of_neg_of_pos h_neg hκ_pos))
        exact absurd (show seg.p2 ∈ hpi.toBoundarySet by
          rw [h_bnd]; exact Set.mem_union_right _
            ⟨tp, h_tp_nn, by linarith [congrArg Vector2D.x h_oeq],
                           by linarith [congrArg Vector2D.y h_oeq]⟩) h_p2_not_bnd
      -- hp1.dot q1 < 0 from segment (contradicts > 0 from r2)
      obtain ⟨s, hs0, hs1, hsx, hsy⟩ := hq1_seg
      have h_dot_seg : (q1.x - O.x) * n1.x + (q1.y - O.y) * n1.y =
        (1 - s) * ((seg.p1.x - O.x) * n1.x + (seg.p1.y - O.y) * n1.y) +
        s * ((seg.p2.x - O.x) * n1.x + (seg.p2.y - O.y) * n1.y) := by
        rw [show q1.x - O.x = (1 - s) * (seg.p1.x - O.x) + s * (seg.p2.x - O.x) from by linarith,
            show q1.y - O.y = (1 - s) * (seg.p1.y - O.y) + s * (seg.p2.y - O.y) from by linarith]
        ring
      rcases eq_or_lt_of_le hs0 with rfl | hs_pos
      · simp at h_dot_seg; linarith
      · linarith [mul_neg_of_pos_of_neg hs_pos h_hp1_p2,
          mul_nonpos_of_nonneg_of_nonpos (show (1 : ℚ) - s ≥ 0 by linarith) (le_of_lt h_hp1_p1)]
  -- Split crossings into disjoint union
  have h_cross_split : seg.boundaryCrossings hpi =
      (seg.toSet ∩ r1.toSet) ∪ (seg.toSet ∩ r2.toSet) := by
    rw [h_cross_union, Set.inter_union_distrib_left]
  have h_fin_r1 : (seg.toSet ∩ r1.toSet).Finite := h_seg_r1_sub.finite
  have h_fin_r2 : (seg.toSet ∩ r2.toSet).Finite := h_seg_r2_sub.finite
  have h_disj : Disjoint h_fin_r1.toFinset h_fin_r2.toFinset := by
    rw [Finset.disjoint_left]; intro q hq1 hq2
    exact h_disjoint q (h_fin_r1.mem_toFinset.mp hq1).1
      (h_fin_r1.mem_toFinset.mp hq1).2 (h_fin_r2.mem_toFinset.mp hq2).2
  have h_tofinset : h_fin.toFinset = h_fin_r1.toFinset ∪ h_fin_r2.toFinset := by
    ext q; simp only [Set.Finite.mem_toFinset, Finset.mem_union, h_cross_split, Set.mem_union]
  rw [h_cc, h_tofinset, Finset.card_union_of_disjoint h_disj]
  congr 1
  · -- card(seg ∩ r1) = if decide ... then 1 else 0
    by_cases hr1 : rayIntersectsSegment r1 seg
    · rw [if_pos (decide_eq_true hr1)]
      have h_ne : (seg.toSet ∩ r1.toSet).Nonempty := by
        obtain ⟨q, hq1, hq2⟩ := hr1; exact ⟨q, hq2, hq1⟩
      have := subsingleton_card _ h_fin_r1 h_seg_r1_sub
      have := nonempty_card _ h_fin_r1 h_ne
      omega
    · have hd1 : ¬(decide (rayIntersectsSegment r1 seg) = true) :=
        fun h => hr1 (of_decide_eq_true h)
      rw [if_neg hd1, Finset.card_eq_zero, Finset.eq_empty_iff_forall_not_mem]
      intro q hq
      exact hr1 ⟨q, (h_fin_r1.mem_toFinset.mp hq).2, (h_fin_r1.mem_toFinset.mp hq).1⟩
  · -- card(seg ∩ r2) = if decide ... then 1 else 0
    by_cases hr2 : rayIntersectsSegment r2 seg
    · rw [if_pos (decide_eq_true hr2)]
      have h_ne : (seg.toSet ∩ r2.toSet).Nonempty := by
        obtain ⟨q, hq1, hq2⟩ := hr2; exact ⟨q, hq2, hq1⟩
      have := subsingleton_card _ h_fin_r2 h_seg_r2_sub
      have := nonempty_card _ h_fin_r2 h_ne
      omega
    · have hd2 : ¬(decide (rayIntersectsSegment r2 seg) = true) :=
        fun h => hr2 (of_decide_eq_true h)
      rw [if_neg hd2, Finset.card_eq_zero, Finset.eq_empty_iff_forall_not_mem]
      intro q hq
      exact hr2 ⟨q, (h_fin_r2.mem_toFinset.mp hq).2, (h_fin_r2.mem_toFinset.mp hq).1⟩

/-- Non-collinear rays have same crossing parity via polygon_crossings_even. -/
private lemma non_collinear_same_parity (r1 r2 : Ray) (poly : Polygon)
    (h_origin : sameOrigin r1 r2) (h_nc : cross r1.direction r2.direction ≠ 0)
    (h_r1_avoids : rayAvoidsVertices r1 poly)
    (h_r2_avoids : rayAvoidsVertices r2 poly)
    (h_origin_avoids : ∀ seg ∈ poly.segments, pointAvoidsSegment r1.origin seg) :
    intersectionRayPolygonSegmentsNumber r1 poly % 2 =
    intersectionRayPolygonSegmentsNumber r2 poly % 2 := by
  -- Apply polygon_crossings_even to the 2-HP HPI
  have h_pcr := HalfPlaneIntersection.polygon_crossings_even_proof
    (nc_rays_hpi r1 r2 h_origin h_nc) poly
    (nc_hpi_vertices_avoid r1 r2 poly h_origin h_nc h_r1_avoids h_r2_avoids)
    (nc_hpi_segments_avoid r1 r2 poly h_origin h_nc h_origin_avoids)
  -- Total crossings are even
  have h_even := h_pcr.2
  -- Relate total to ray counts
  have h_total := nc_hpi_total_eq r1 r2 poly h_origin h_nc
    h_r1_avoids h_r2_avoids h_origin_avoids
  rw [h_total] at h_even
  -- Even (count_r1 + count_r2) → count_r1 % 2 = count_r2 % 2
  obtain ⟨k, hk⟩ := h_even
  omega

-- ============================================================================
-- Main theorem: combine the three cases
-- ============================================================================

theorem intersectionParity_eq_of_sameOrigin_avoidsVertices
    (r1 r2 : Ray) (poly : Polygon)
    (h_origin : sameOrigin r1 r2)
    (h_r1_avoids : rayAvoidsVertices r1 poly)
    (h_r2_avoids : rayAvoidsVertices r2 poly)
    (h_origin_avoids_segments : ∀ seg ∈ poly.segments, pointAvoidsSegment r1.origin seg) :
    (intersectionRayPolygonSegmentsNumber r1 poly) % 2 =
    (intersectionRayPolygonSegmentsNumber r2 poly) % 2 := by
  rcases direction_trichotomy r1.direction r2.direction
    r1.direction_nonzero r2.direction_nonzero with h_same | h_opp | h_nc
  · -- Same direction: same ray → equal counts → equal mod 2
    rw [same_dir_eq_count r1 r2 poly h_origin h_same]
  · -- Opposite direction: single HP → polygon_crossings_even → even sum → same mod 2
    exact opposite_rays_same_parity r1 r2 poly h_origin h_opp
      h_r1_avoids h_r2_avoids h_origin_avoids_segments
  · -- Non-collinear: two HPs → polygon_crossings_even → even sum → same mod 2
    exact non_collinear_same_parity r1 r2 poly h_origin h_nc
      h_r1_avoids h_r2_avoids h_origin_avoids_segments

-- ============================================================================
-- Proof of intersectionParity_eq_of_originSegmentAvoidsSegments
-- ============================================================================

/-- An endpoint of a non-intersecting segment avoids each polygon segment. -/
private lemma endpoint_avoids_of_segmentDoesNotIntersect (O1 O2 : Vector2D)
    (seg : LineSegment)
    (h : segmentDoesNotIntersectSegment ⟨O1, O2⟩ seg) :
    pointAvoidsSegment O1 seg ∧ pointAvoidsSegment O2 seg := by
  unfold segmentDoesNotIntersectSegment at h
  unfold pointAvoidsSegment
  constructor
  · intro h_mem
    have h1 : O1 ∈ (LineSegment.mk O1 O2).toSet :=
      ⟨0, le_refl _, le_of_lt one_pos, by simp, by simp⟩
    have : O1 ∈ (LineSegment.mk O1 O2).toSet ∩ seg.toSet := ⟨h1, h_mem⟩
    rw [h] at this; exact this
  · intro h_mem
    have h1 : O2 ∈ (LineSegment.mk O1 O2).toSet :=
      ⟨1, le_of_lt one_pos, le_refl _, by simp, by simp⟩
    have : O2 ∈ (LineSegment.mk O1 O2).toSet ∩ seg.toSet := ⟨h1, h_mem⟩
    rw [h] at this; exact this

/-- The direction vector O2 - O1 is nonzero when O1 ≠ O2. -/
private lemma sub_nonzero (O1 O2 : Vector2D) (h : O1 ≠ O2) :
    (⟨O2.x - O1.x, O2.y - O1.y⟩ : Vector2D) ≠ ⟨0, 0⟩ := by
  intro heq
  apply h
  have hx : O2.x - O1.x = 0 := congrArg Vector2D.x heq
  have hy : O2.y - O1.y = 0 := congrArg Vector2D.y heq
  exact (Vector2D.mk.injEq _ _ _ _).mpr ⟨by linarith, by linarith⟩

/-- For any finite list of nonzero directions, there exists a nonzero direction
    not collinear with any of them. -/
private lemma exists_noncollinear_direction (dirs : List Vector2D)
    (h_nz : ∀ w ∈ dirs, w ≠ ⟨0, 0⟩) :
    ∃ d : Vector2D, d ≠ ⟨0, 0⟩ ∧ ∀ w ∈ dirs, cross d w ≠ 0 := by
  -- Pick d = (1, k) for some k avoiding finitely many bad values.
  -- cross (1, k) (wx, wy) = wy - k*wx
  -- For w ≠ 0: if wx ≠ 0 then cross = 0 iff k = wy/wx; if wx = 0 then wy ≠ 0 and cross = wy ≠ 0.
  let bad_ks : List ℚ := dirs.filterMap fun w =>
    if w.x = 0 then none else some (w.y / w.x)
  -- There exists a k not equal to any of the finitely many bad values
  -- We use the fact that ℕ → ℚ is injective and ℕ is infinite
  have h_exists : ∃ k : ℚ, ∀ b ∈ bad_ks, k ≠ b := by
    -- Suffices to find a natural number n such that (n : ℚ) ∉ bad_ks
    -- The list has finitely many elements; at most bad_ks.length of them are naturals
    -- Among 0, 1, ..., bad_ks.length, at least one is not in bad_ks
    suffices ∀ (l : List ℚ), ∃ k : ℚ, k ∉ l from
      let ⟨k, hk⟩ := this bad_ks; ⟨k, fun b hb hkb => hk (hkb ▸ hb)⟩
    intro l
    -- There are l.length+1 natural numbers 0..l.length, but l has only l.length elements
    -- By pigeonhole, some natural number in this range is not in l
    by_contra h; push_neg at h
    -- h : ∀ k : ℚ, k ∈ l. This means l contains all rationals.
    -- But Finset.univ on ℚ is not finite, so we just exhibit l.length+1 distinct elements in l.
    -- Actually, simpler: the naturals 0, 1, ..., l.length are l.length+1 distinct elements.
    -- l has l.length elements, so by pigeonhole two of these coincide in l. But they're distinct...
    -- No, l can have duplicates. We need a cleaner argument.
    -- Simplest: l.toFinset is finite with card ≤ l.length. But {0, 1, ..., l.length} has l.length+1
    -- elements and all are in l.toFinset. Contradiction.
    have : ∀ n : ℕ, (n : ℚ) ∈ l := fun n => h n
    have h_inj : Function.Injective (fun n : ℕ => (n : ℚ)) := Nat.cast_injective
    have h_le : l.toFinset.card ≤ l.length := List.toFinset_card_le l
    have h_range : ∀ n ∈ Finset.range (l.length + 1), (n : ℚ) ∈ l.toFinset := by
      intro n _; exact List.mem_toFinset.mpr (this n)
    have h_inj2 : Set.InjOn (fun n : ℕ => (n : ℚ)) (Finset.range (l.length + 1)) :=
      fun a _ b _ hab => h_inj hab
    have h_card := Finset.card_le_card_of_injOn _ h_range h_inj2
    simp at h_card; omega
  obtain ⟨k, hk⟩ := h_exists
  refine ⟨⟨1, k⟩, ?_, ?_⟩
  · intro h; have := congrArg Vector2D.x h; simp at this
  · intro w hw hcross
    have hw_nz := h_nz w hw
    have hd_or : w.x ≠ 0 ∨ w.y ≠ 0 := by
      by_contra hc; push_neg at hc
      exact hw_nz ((Vector2D.mk.injEq _ _ _ _).mpr ⟨hc.1, hc.2⟩)
    -- cross (1,k) (wx,wy) = 1*wy - k*wx = wy - k*wx
    have hcross' : w.y - k * w.x = 0 := by unfold cross at hcross; ring_linarith
    have heq : w.y = k * w.x := by linarith
    by_cases hwx : w.x = 0
    · -- w.x = 0 → from heq, w.y = k * 0 = 0 → w = 0, contradicts w ≠ 0
      -- Unless w.y ≠ 0, but heq says w.y = k * 0 = 0. Contradiction.
      have : w.y = 0 := by rw [heq, hwx, mul_zero]
      exact hw_nz ((Vector2D.mk.injEq _ _ _ _).mpr ⟨hwx, this⟩)
    · -- w.x ≠ 0 → k = w.y / w.x → k ∈ bad_ks → contradiction
      have hk_eq : k = w.y / w.x := by
        rw [heq, mul_div_cancel_right₀ k hwx]
      have hk_bad : w.y / w.x ∈ bad_ks := by
        show w.y / w.x ∈ dirs.filterMap fun w => if w.x = 0 then none else some (w.y / w.x)
        rw [List.mem_filterMap]
        exact ⟨w, hw, by simp [hwx]⟩
      exact hk _ hk_bad hk_eq

/-- Given O1 ≠ O2, and lists of vertices not equal to O1 or O2,
    find a direction d not collinear with O2-O1 and avoiding all vertices from both origins. -/
private lemma exists_good_direction (O1 O2 : Vector2D) (h_neq : O1 ≠ O2)
    (vertices : List Vector2D)
    (h_v_ne_O1 : ∀ v ∈ vertices, v ≠ O1)
    (h_v_ne_O2 : ∀ v ∈ vertices, v ≠ O2) :
    ∃ d : Vector2D, d ≠ ⟨0, 0⟩ ∧
      cross d ⟨O2.x - O1.x, O2.y - O1.y⟩ ≠ 0 ∧
      (∀ v ∈ vertices, cross d ⟨v.x - O1.x, v.y - O1.y⟩ ≠ 0) ∧
      (∀ v ∈ vertices, cross d ⟨v.x - O2.x, v.y - O2.y⟩ ≠ 0) := by
  -- Build the list of directions to avoid being collinear with
  have h_delta_nz : (⟨O2.x - O1.x, O2.y - O1.y⟩ : Vector2D) ≠ ⟨0, 0⟩ :=
    sub_nonzero O1 O2 h_neq
  -- All direction vectors v - O1 and v - O2 are nonzero (since v ≠ O1 and v ≠ O2)
  have h_dirs1_nz : ∀ v ∈ vertices, (⟨v.x - O1.x, v.y - O1.y⟩ : Vector2D) ≠ ⟨0, 0⟩ := by
    intro v hv heq
    have hx : v.x - O1.x = 0 := congrArg Vector2D.x heq
    have hy : v.y - O1.y = 0 := congrArg Vector2D.y heq
    exact h_v_ne_O1 v hv ((Vector2D.mk.injEq _ _ _ _).mpr ⟨by linarith, by linarith⟩)
  have h_dirs2_nz : ∀ v ∈ vertices, (⟨v.x - O2.x, v.y - O2.y⟩ : Vector2D) ≠ ⟨0, 0⟩ := by
    intro v hv heq
    have hx : v.x - O2.x = 0 := congrArg Vector2D.x heq
    have hy : v.y - O2.y = 0 := congrArg Vector2D.y heq
    exact h_v_ne_O2 v hv ((Vector2D.mk.injEq _ _ _ _).mpr ⟨by linarith, by linarith⟩)
  -- Build the complete list
  set dirs := ⟨O2.x - O1.x, O2.y - O1.y⟩ ::
    ((vertices.map fun v => (⟨v.x - O1.x, v.y - O1.y⟩ : Vector2D)) ++
     (vertices.map fun v => (⟨v.x - O2.x, v.y - O2.y⟩ : Vector2D)))
  have h_all_nz : ∀ w ∈ dirs, w ≠ ⟨0, 0⟩ := by
    intro w hw
    simp only [dirs, List.mem_cons, List.mem_append, List.mem_map] at hw
    rcases hw with rfl | (⟨v, hv, rfl⟩ | ⟨v, hv, rfl⟩)
    · exact h_delta_nz
    · exact h_dirs1_nz v hv
    · exact h_dirs2_nz v hv
  obtain ⟨d, hd_nz, hd_cross⟩ := exists_noncollinear_direction dirs h_all_nz
  refine ⟨d, hd_nz, ?_, ?_, ?_⟩
  · exact hd_cross _ (List.mem_cons_self _ _)
  · intro v hv
    have hmem : (⟨v.x - O1.x, v.y - O1.y⟩ : Vector2D) ∈
        vertices.map (fun (w : Vector2D) => (⟨w.x - O1.x, w.y - O1.y⟩ : Vector2D)) :=
      List.mem_map_of_mem _ hv
    exact hd_cross _ (List.mem_cons_of_mem _ (List.mem_append_left _ hmem))
  · intro v hv
    have hmem : (⟨v.x - O2.x, v.y - O2.y⟩ : Vector2D) ∈
        vertices.map (fun (w : Vector2D) => (⟨w.x - O2.x, w.y - O2.y⟩ : Vector2D)) :=
      List.mem_map_of_mem _ hv
    exact hd_cross _ (List.mem_cons_of_mem _ (List.mem_append_right _ hmem))

/-- cross d (v - O) ≠ 0 implies v ∉ Ray(O, d). -/
private lemma cross_ne_zero_not_on_ray (O : Vector2D) (d : Vector2D) (hd : d ≠ ⟨0, 0⟩)
    (v : Vector2D) (hcross : cross d ⟨v.x - O.x, v.y - O.y⟩ ≠ 0) :
    v ∉ (Ray.mk O d hd).toSet := by
  intro ⟨t, _, htx, hty⟩
  apply hcross
  unfold cross
  rw [show v.x - O.x = t * d.x from by linarith,
      show v.y - O.y = t * d.y from by linarith]
  ring

/-- If a ∈ l1 and l1.length ≤ l2.length, then ∃ b, (a,b) ∈ l1.zip l2. -/
private lemma exists_zip_pair {α β : Type} (l1 : List α) (l2 : List β) (a : α)
    (ha : a ∈ l1) (hlen : l1.length ≤ l2.length) :
    ∃ b, (a, b) ∈ l1.zip l2 := by
  induction l1 generalizing l2 with
  | nil => simp at ha
  | cons x xs ih =>
    match l2 with
    | [] => simp at hlen
    | y :: ys =>
      rcases List.mem_cons.mp ha with rfl | ha'
      · exact ⟨y, List.mem_cons.mpr (Or.inl rfl)⟩
      · have hlen' : xs.length ≤ ys.length := by simp at hlen; omega
        obtain ⟨b, hb⟩ := ih ys ha' hlen'
        exact ⟨b, List.mem_cons_of_mem _ hb⟩

/-- In a polygon with ≥ 2 vertices, every vertex is p1 of some segment. -/
private lemma vertex_is_p1_of_segment (v0 : Vector2D) (v1 : Vector2D) (vs : List Vector2D)
    (v : Vector2D) (hv : v ∈ (v0 :: v1 :: vs)) :
    ∃ seg ∈ (Polygon.mk (v0 :: v1 :: vs)).segments, v = seg.p1 := by
  have hlen : (v0 :: v1 :: vs).length ≤ ((v1 :: vs) ++ [v0]).length := by
    simp [List.length_cons, List.length_append]
  obtain ⟨b, hb⟩ := exists_zip_pair (v0 :: v1 :: vs) ((v1 :: vs) ++ [v0]) v hv hlen
  refine ⟨⟨v, b⟩, ?_, rfl⟩
  show (⟨v, b⟩ : LineSegment) ∈ (Polygon.mk (v0 :: v1 :: vs)).segments
  simp only [Polygon.segments, List.mem_map, Prod.exists]
  exact ⟨v, b, hb, rfl⟩

/-- p1 is in the toSet of any segment at parameter t = 0. -/
private lemma p1_mem_toSet (seg : LineSegment) : seg.p1 ∈ seg.toSet :=
  ⟨0, le_refl _, le_of_lt one_pos, by simp, by simp⟩

/-- For a polygon with ≥ 2 vertices, every vertex lies on some polygon segment. -/
private lemma vertex_on_some_segment (poly : Polygon) (v : Vector2D)
    (hv : v ∈ poly.vertices) (h_segs : poly.segments ≠ []) :
    ∃ seg ∈ poly.segments, v ∈ seg.toSet := by
  cases hpv : poly.vertices with
  | nil =>
    rw [hpv] at hv; simp at hv
  | cons w ws =>
    cases ws with
    | nil =>
      have : poly.segments = [] := by cases poly; simp_all [Polygon.segments]
      exact absurd this h_segs
    | cons w2 ws2 =>
      have hpoly_eq : poly = ⟨w :: w2 :: ws2⟩ := by cases poly; simp_all
      have hv' : v ∈ (w :: w2 :: ws2) := by rw [hpoly_eq] at hv; exact hv
      obtain ⟨seg, hseg, hveq⟩ := vertex_is_p1_of_segment w w2 ws2 v hv'
      have hseg' : seg ∈ poly.segments := by rw [hpoly_eq]; exact hseg
      exact ⟨seg, hseg', hveq ▸ p1_mem_toSet seg⟩

-- ============================================================================
-- 3-HP HPI for parallel rays from different origins
-- ============================================================================

/-- The normals for the 3-HP construction.
    HP1: boundary through O1, direction d, normal pointing toward O2.
    HP2: boundary through O2, direction d, normal pointing toward O1.
    HP3: boundary through O1, direction delta, normal pointing toward d. -/
private def par_n1 (d delta : Vector2D) : Vector2D :=
  if cross d delta > 0 then ⟨-d.y, d.x⟩ else ⟨d.y, -d.x⟩

private def par_n2 (d delta : Vector2D) : Vector2D :=
  if cross d delta > 0 then ⟨d.y, -d.x⟩ else ⟨-d.y, d.x⟩

private def par_n3 (d delta : Vector2D) : Vector2D :=
  if cross d delta > 0 then ⟨delta.y, -delta.x⟩ else ⟨-delta.y, delta.x⟩

private lemma par_n1_nonzero (d delta : Vector2D) (hd : d ≠ ⟨0, 0⟩) :
    par_n1 d delta ≠ ⟨0, 0⟩ := by
  simp only [par_n1]; split
  · exact rot90_nonzero d hd
  · exact rot270_nonzero d hd

private lemma par_n2_nonzero (d delta : Vector2D) (hd : d ≠ ⟨0, 0⟩) :
    par_n2 d delta ≠ ⟨0, 0⟩ := by
  simp only [par_n2]; split
  · exact rot270_nonzero d hd
  · exact rot90_nonzero d hd

private lemma par_n3_nonzero (d delta : Vector2D) (hd : delta ≠ ⟨0, 0⟩) :
    par_n3 d delta ≠ ⟨0, 0⟩ := by
  simp only [par_n3]; split
  · exact rot270_nonzero delta hd
  · exact rot90_nonzero delta hd

/-- 3-HP HPI for parallel rays from different origins. -/
private noncomputable def par_rays_hpi (O1 O2 : Vector2D) (d : Vector2D)
    (hd : d ≠ ⟨0, 0⟩) (h_neq : O1 ≠ O2)
    (_h_nc : cross d ⟨O2.x - O1.x, O2.y - O1.y⟩ ≠ 0) :
    HalfPlaneIntersection :=
  let delta : Vector2D := ⟨O2.x - O1.x, O2.y - O1.y⟩
  ⟨[⟨O1, par_n1 d delta, par_n1_nonzero d delta hd⟩,
    ⟨O2, par_n2 d delta, par_n2_nonzero d delta hd⟩,
    ⟨O1, par_n3 d delta, par_n3_nonzero d delta (sub_nonzero O1 O2 h_neq)⟩]⟩

set_option maxHeartbeats 4000000 in
/-- Parallel rays from different origins connected by a non-intersecting segment
    have the same crossing parity. Uses a 3-HP HPI construction. -/
private lemma parallel_rays_same_parity
    (O1 O2 : Vector2D) (d : Vector2D) (hd : d ≠ ⟨0, 0⟩)
    (h_neq : O1 ≠ O2)
    (h_nc : cross d ⟨O2.x - O1.x, O2.y - O1.y⟩ ≠ 0)
    (poly : Polygon)
    (h_r1_avoids : rayAvoidsVertices ⟨O1, d, hd⟩ poly)
    (h_r2_avoids : rayAvoidsVertices ⟨O2, d, hd⟩ poly)
    (h_O1_avoids : ∀ seg ∈ poly.segments, pointAvoidsSegment O1 seg)
    (h_O2_avoids : ∀ seg ∈ poly.segments, pointAvoidsSegment O2 seg)
    (h_seg_avoids : ∀ seg ∈ poly.segments,
      segmentDoesNotIntersectSegment ⟨O1, O2⟩ seg)
    (h_vert_avoids_seg : ∀ v ∈ poly.vertices, v ∉ (LineSegment.mk O1 O2).toSet) :
    (intersectionRayPolygonSegmentsNumber ⟨O1, d, hd⟩ poly) % 2 =
    (intersectionRayPolygonSegmentsNumber ⟨O2, d, hd⟩ poly) % 2 := by
  set delta : Vector2D := ⟨O2.x - O1.x, O2.y - O1.y⟩
  set n1 := par_n1 d delta
  set n2 := par_n2 d delta
  set n3 := par_n3 d delta
  set r1 : Ray := ⟨O1, d, hd⟩
  set r2 : Ray := ⟨O2, d, hd⟩
  set hpi := par_rays_hpi O1 O2 d hd h_neq h_nc
  set hp1 : HalfPlane := ⟨O1, n1, par_n1_nonzero d delta hd⟩
  set hp2 : HalfPlane := ⟨O2, n2, par_n2_nonzero d delta hd⟩
  set hp3 : HalfPlane := ⟨O1, n3, par_n3_nonzero d delta (sub_nonzero O1 O2 h_neq)⟩
  -- κ = |cross d delta|
  set κ : ℚ := if cross d delta > 0 then cross d delta else -(cross d delta)
  have hκ_pos : κ > 0 := by
    simp only [κ]; split
    · assumption
    · rename_i h; push_neg at h; linarith [lt_of_le_of_ne h h_nc]
  -- Key algebraic identities
  -- d · n1 = 0, d · n2 = 0 (normals perpendicular to d)
  have h_d_n1 : ∀ t : ℚ, (t * d.x) * n1.x + (t * d.y) * n1.y = 0 := by
    intro t; simp only [n1, par_n1]; split <;> ring
  have h_d_n2 : ∀ t : ℚ, (t * d.x) * n2.x + (t * d.y) * n2.y = 0 := by
    intro t; simp only [n2, par_n2]; split <;> ring
  -- delta · n1 = κ (positive: O2 is interior to HP1)
  have h_delta_n1 : delta.x * n1.x + delta.y * n1.y = κ := by
    simp only [n1, par_n1, κ, cross]; split <;> ring
  -- (-delta) · n2 = κ (positive: O1 is interior to HP2)
  have h_neg_delta_n2 : (-delta.x) * n2.x + (-delta.y) * n2.y = κ := by
    simp only [n2, par_n2, κ, cross]; split <;> ring
  -- delta · n2 = -κ
  have h_delta_n2 : delta.x * n2.x + delta.y * n2.y = -κ := by linarith [h_neg_delta_n2]
  -- d · n3 = κ (positive: d direction is in interior of HP3)
  have h_d_n3 : d.x * n3.x + d.y * n3.y = κ := by
    simp only [n3, par_n3, κ, cross]; split <;> ring
  -- delta · n3 = 0 (n3 perpendicular to delta)
  have h_delta_n3 : ∀ t : ℚ, (t * delta.x) * n3.x + (t * delta.y) * n3.y = 0 := by
    intro t; simp only [n3, par_n3]; split <;> ring
  have h_dn3_zero : delta.x * n3.x + delta.y * n3.y = 0 := by
    have := h_delta_n3 1; simp at this; exact this
  -- Perpendicularity conversions
  have h_perp1 : ∀ q : Vector2D, (q.x - O1.x) * n1.x + (q.y - O1.y) * n1.y = 0 →
      (q.x - O1.x) * d.y = (q.y - O1.y) * d.x := by
    intro q hq; simp only [n1, par_n1] at hq; split at hq <;> ring_linarith
  have h_perp2 : ∀ q : Vector2D, (q.x - O2.x) * n2.x + (q.y - O2.y) * n2.y = 0 →
      (q.x - O2.x) * d.y = (q.y - O2.y) * d.x := by
    intro q hq; simp only [n2, par_n2] at hq; split at hq <;> ring_linarith
  have h_perp3 : ∀ q : Vector2D, (q.x - O1.x) * n3.x + (q.y - O1.y) * n3.y = 0 →
      (q.x - O1.x) * delta.y = (q.y - O1.y) * delta.x := by
    intro q hq; simp only [n3, par_n3] at hq; split at hq <;> ring_linarith
  -- The hpi list is [hp1, hp2, hp3]
  have h_hpi_list : hpi.halfPlanes = [hp1, hp2, hp3] := rfl
  -- =====================================================================
  -- Boundary characterization: hpi.toBoundarySet = r1.toSet ∪ seg(O1,O2).toSet ∪ r2.toSet
  -- =====================================================================
  have h_bnd : hpi.toBoundarySet = r1.toSet ∪ (LineSegment.mk O1 O2).toSet ∪ r2.toSet := by
    ext q; simp only [mem_union]; constructor
    · -- Forward: HPI boundary → r1 ∪ seg ∪ r2
      intro hq
      simp only [hpi, par_rays_hpi, HalfPlaneIntersection.toBoundarySet, HalfPlane.toBoundarySet,
        HalfPlane.toExteriorSet, HalfPlane.dot, mem_setOf_eq,
        List.mem_cons, (List.not_mem_nil _), or_false] at hq
      obtain ⟨⟨hp, hp_mem, hdot⟩, h_not_ext⟩ := hq
      rcases hp_mem with rfl | rfl | rfl
      · -- q on HP1 boundary (line through O1, direction d)
        have h_line := h_perp1 q hdot
        obtain ⟨t, htx, hty⟩ := extract_line_param d O1 q hd h_line
        -- Not exterior to HP2: (q - O2) · n2 ≥ 0
        have h_hp2_nn : (q.x - O2.x) * n2.x + (q.y - O2.y) * n2.y ≥ 0 := by
          have := h_not_ext _ (Or.inr (Or.inl rfl))
          push_neg at this; exact this
        -- (q - O2) · n2 = (O1 + t*d - O2) · n2 = (-delta + t*d) · n2 = -κ + 0 = -κ ... wait
        -- q - O2 = (q - O1) + (O1 - O2) = t*d + (-delta)
        have h_dot2 : (q.x - O2.x) * n2.x + (q.y - O2.y) * n2.y =
            (t * d.x + (-delta.x)) * n2.x + (t * d.y + (-delta.y)) * n2.y := by
          have : q.x - O2.x = t * d.x + (-delta.x) := by
            simp only [delta]; linarith [htx]
          have : q.y - O2.y = t * d.y + (-delta.y) := by
            simp only [delta]; linarith [hty]
          rw [‹q.x - O2.x = _›, ‹q.y - O2.y = _›]
        rw [h_dot2] at h_hp2_nn
        have : (t * d.x + (-delta.x)) * n2.x + (t * d.y + (-delta.y)) * n2.y =
            (t * d.x) * n2.x + (t * d.y) * n2.y + ((-delta.x) * n2.x + (-delta.y) * n2.y) := by ring
        rw [this, h_d_n2 t, h_neg_delta_n2] at h_hp2_nn
        simp at h_hp2_nn
