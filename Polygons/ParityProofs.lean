          have := h_delta_n3 1; simp at this; exact this
        rw [h_dot3, h_d_n3, h_dn3_zero] at h_hp3_nn
        simp at h_hp3_nn
        have ht_nn : 0 ≤ t := by nlinarith [hκ_pos]
        right
        exact ⟨t, ht_nn, htx, hty⟩
