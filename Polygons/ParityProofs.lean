      -- Both endpoints on HP1 boundary and not on HPI boundary
      -- → endpoint is exterior to HP2 or HP3
      -- Since endpoint is on HP1 boundary (on the line through O1 in direction d),
      -- (endpoint - O2) · n2 = -κ (constant for all points on this line)
      -- Wait, n2 = -n1, and endpoint is on HP1 boundary, so (endpoint - O1) · n1 = 0
      -- (endpoint - O2) · n2 = (endpoint - O1 - delta) · n2 = -(delta) · n2 - 0 = κ
      -- So endpoint is interior to HP2, not exterior.
      -- Then endpoint must be exterior to HP3: (endpoint - O1) · n3 < 0
      -- (endpoint - O1) · n3 = 0 (HP1 bnd) + t * d · n3... wait, we need a parameter.
      -- Actually (seg.p1 - O1) · n1 = 0, so seg.p1 is on the line through O1 in direction d
      -- Get parameter for seg.p1
      have h_line_p1 := h_perp1 seg.p1 h_nd1.1
      obtain ⟨tp1, htp1x, htp1y⟩ := extract_line_param d O1 seg.p1 hd h_line_p1
      -- (seg.p1 - O2) · n2 = (tp1 * d - delta) · n2 = 0 - delta · n2 = κ
      -- So seg.p1 is in HP2 interior (κ > 0), not exterior.
      -- So seg.p1 must be exterior to HP3.
      -- (seg.p1 - O1) · n3 = tp1 * (d · n3) = tp1 * κ
      have h_dot3_p1 : (seg.p1.x - O1.x) * n3.x + (seg.p1.y - O1.y) * n3.y = tp1 * κ := by
        calc (seg.p1.x - O1.x) * n3.x + (seg.p1.y - O1.y) * n3.y
            = (tp1 * d.x) * n3.x + (tp1 * d.y) * n3.y := by
              rw [show seg.p1.x - O1.x = tp1 * d.x from by linarith,
                  show seg.p1.y - O1.y = tp1 * d.y from by linarith]
          _ = tp1 * (d.x * n3.x + d.y * n3.y) := by ring
          _ = tp1 * κ := by rw [h_d_n3]
      have h_tp1_neg : tp1 < 0 := by
        by_contra h_nn; push_neg at h_nn
        apply h_p1_not_bnd; rw [h_bnd]
        exact Set.mem_union_left _ (Set.mem_union_left _ ⟨tp1, h_nn, htp1x, htp1y⟩)
      have h_line_p2 := h_perp1 seg.p2 h_nd1.2
      obtain ⟨tp2, htp2x, htp2y⟩ := extract_line_param d O1 seg.p2 hd h_line_p2
      have h_dot3_p2 : (seg.p2.x - O1.x) * n3.x + (seg.p2.y - O1.y) * n3.y = tp2 * κ := by
        calc (seg.p2.x - O1.x) * n3.x + (seg.p2.y - O1.y) * n3.y
            = (tp2 * d.x) * n3.x + (tp2 * d.y) * n3.y := by
              rw [show seg.p2.x - O1.x = tp2 * d.x from by linarith,
                  show seg.p2.y - O1.y = tp2 * d.y from by linarith]
          _ = tp2 * (d.x * n3.x + d.y * n3.y) := by ring
          _ = tp2 * κ := by rw [h_d_n3]
