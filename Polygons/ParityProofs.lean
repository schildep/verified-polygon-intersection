          _ = t * (d.x * n3.x + d.y * n3.y) + (delta.x * n3.x + delta.y * n3.y) := by ring
          _ = t * κ + 0 := by rw [h_d_n3, h_dn3_zero]
          _ = t * κ := by ring
      have h_dot3_seg : (q1.x - O1.x) * n3.x + (q1.y - O1.y) * n3.y =
