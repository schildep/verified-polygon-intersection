        have h_hp3_nn : (q.x - O1.x) * n3.x + (q.y - O1.y) * n3.y ≥ 0 := by
          have := h_not_ext _ (Or.inr (Or.inr rfl))
          push_neg at this; exact this
        have h_dot3 : (q.x - O1.x) * n3.x + (q.y - O1.y) * n3.y = t * (d.x * n3.x + d.y * n3.y) := by
          rw [show q.x - O1.x = t * d.x from by linarith [htx],
              show q.y - O1.y = t * d.y from by linarith [hty]]
          ring
        rw [h_dot3, h_d_n3] at h_hp3_nn
        have ht_nn : 0 ≤ t := by nlinarith [hκ_pos]
        left; left
        exact ⟨t, ht_nn, htx, hty⟩
      · -- q on HP2 boundary (line through O2, direction d)
