        List.mem_cons, (List.not_mem_nil _), or_false]
      rcases hq with (⟨t, ht, htx, hty⟩ | ⟨t, ht0, ht1, htx, hty⟩) | ⟨t, ht, htx, hty⟩
      · -- q ∈ r1 (t ≥ 0)
        constructor
        · -- On HP1 boundary
          exact ⟨_, Or.inl rfl, by rw [htx, hty]; simp only; linarith [h_d_n1 t]⟩
        · intro hp hp_mem
          rcases hp_mem with rfl | rfl | rfl
          · -- HP1: dot = 0, not exterior
            intro h_neg; rw [htx, hty] at h_neg; simp only at h_neg; linarith [h_d_n1 t]
          · -- HP2: dot = κ ≥ 0 (since (-delta + t*d) · n2 = κ + 0 = κ > 0)
