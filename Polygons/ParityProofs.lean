import Polygons.ConvexProofs
import Mathlib.Tactic.LinearCombination

-- v4.15's `linarith` doesn't normalise `a * -b` to `-(a*b)`, so several
-- equation-shuffling proofs below fail under v4.15 even though they pass
-- under v4.29. `ring_linarith` runs `ring_nf` on every hypothesis and the
-- goal before invoking `linarith`, restoring the v4.29 behaviour where
-- those proofs go through unchanged.
syntax "ring_linarith" : tactic
macro_rules
  | `(tactic| ring_linarith) => `(tactic| (ring_nf at * <;> linarith))

open Classical Set

noncomputable section

namespace ParityProofs

