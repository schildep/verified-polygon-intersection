        calc (q1.x - O1.x) * n3.x + (q1.y - O1.y) * n3.y
            = (1 - s) * ((seg.p1.x - O1.x) * n3.x + (seg.p1.y - O1.y) * n3.y) +
              s * ((seg.p2.x - O1.x) * n3.x + (seg.p2.y - O1.y) * n3.y) := by
                rw [show q1.x - O1.x = (1 - s) * (seg.p1.x - O1.x) + s * (seg.p2.x - O1.x) from by linarith,
                    show q1.y - O1.y = (1 - s) * (seg.p1.y - O1.y) + s * (seg.p2.y - O1.y) from by linarith]
                ring
          _ = (1 - s) * (tp1 * κ) + s * (tp2 * κ) := by rw [h_dot3_p1, h_dot3_p2]
      have h_eq : t * κ = (1 - s) * (tp1 * κ) + s * (tp2 * κ) := by
        linarith [h_dot3_q1, h_dot3_seg]
      have h_lhs_pos : t * κ > 0 := mul_pos h_tpos hκ_pos
      have h_tp1k_neg : tp1 * κ < 0 := mul_neg_of_neg_of_pos h_tp1_neg hκ_pos
      have h_tp2k_neg : tp2 * κ < 0 := mul_neg_of_neg_of_pos h_tp2_neg hκ_pos
      have h1s_nn : (1 : ℚ) - s ≥ 0 := by linarith
      have h_term1 : (1 - s) * (tp1 * κ) ≤ 0 := by nlinarith
      have h_term2 : s * (tp2 * κ) ≤ 0 := by nlinarith
      linarith
  have h_seg_r2_sub : ∀ seg ∈ poly.segments, (seg.toSet ∩ r2.toSet).Subsingleton := by
    intro seg hseg
    have hp1_vert := seg_p1_mem_vertices poly seg hseg
    have hp2_vert := seg_p2_mem_vertices poly seg hseg
    have h_p1_not_bnd : seg.p1 ∉ hpi.toBoundarySet := h_vert seg.p1 hp1_vert
    have h_p2_not_bnd : seg.p2 ∉ hpi.toBoundarySet := h_vert seg.p2 hp2_vert
