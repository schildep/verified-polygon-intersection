          have hqx : q.x - O1.x = t * d.x + delta.x := by
            simp only [delta]; linarith [htx]
          have hqy : q.y - O1.y = t * d.y + delta.y := by
            simp only [delta]; linarith [hty]
          rw [hqx, hqy]; ring
        rw [h_dot1, h_d_n1 t, h_delta_n1] at h_hp1_nn
        simp at h_hp1_nn
        -- Not exterior to HP3: (q - O1) · n3 ≥ 0
        have h_hp3_nn : (q.x - O1.x) * n3.x + (q.y - O1.y) * n3.y ≥ 0 := by
          have := h_not_ext _ (Or.inr (Or.inr rfl))
          push_neg at this; exact this
        have h_dot3 : (q.x - O1.x) * n3.x + (q.y - O1.y) * n3.y =
            t * (d.x * n3.x + d.y * n3.y) + (delta.x * n3.x + delta.y * n3.y) := by
          have hqx : q.x - O1.x = t * d.x + delta.x := by
            simp only [delta]; linarith [htx]
          have hqy : q.y - O1.y = t * d.y + delta.y := by
            simp only [delta]; linarith [hty]
          rw [hqx, hqy]; ring
