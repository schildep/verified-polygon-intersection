        obtain ⟨t, htx, hty⟩ := extract_line_param delta O1 q (sub_nonzero O1 O2 h_neq) h_line
        -- Not exterior to HP1: (q - O1) · n1 ≥ 0
        have h_hp1_nn : (q.x - O1.x) * n1.x + (q.y - O1.y) * n1.y ≥ 0 := by
          have := h_not_ext _ (Or.inl rfl)
          push_neg at this; exact this
        have h_dot1 : (q.x - O1.x) * n1.x + (q.y - O1.y) * n1.y =
            t * (delta.x * n1.x + delta.y * n1.y) := by
          rw [show q.x - O1.x = t * delta.x from by linarith [htx],
              show q.y - O1.y = t * delta.y from by linarith [hty]]
          ring
        rw [h_dot1, h_delta_n1] at h_hp1_nn
        have ht_nn : 0 ≤ t := by nlinarith [hκ_pos]
        -- Not exterior to HP2: (q - O2) · n2 ≥ 0
        have h_hp2_nn : (q.x - O2.x) * n2.x + (q.y - O2.y) * n2.y ≥ 0 := by
          have := h_not_ext _ (Or.inr (Or.inl rfl))
          push_neg at this; exact this
        have h_dot2 : (q.x - O2.x) * n2.x + (q.y - O2.y) * n2.y =
            (t - 1) * (delta.x * n2.x + delta.y * n2.y) := by
          have hqx : q.x - O2.x = (t - 1) * delta.x := by
            simp only [delta]; (ring_nf at *; linarith [htx])
          have hqy : q.y - O2.y = (t - 1) * delta.y := by
            simp only [delta]; (ring_nf at *; linarith [hty])
          rw [hqx, hqy]; ring
        rw [h_dot2, h_delta_n2] at h_hp2_nn
