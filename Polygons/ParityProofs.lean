      -- seg.p_i is on HP2 boundary, in HP1 interior ((seg.p_i - O1) · n1 = delta · n1 = κ > 0... wait)
      -- (seg.p_i - O1) · n1 = (tp_i * d + delta) · n1 = 0 + delta · n1 = κ > 0 → HP1 interior
      -- And HP3: dot = tp_i * κ. If ≥ 0, not exterior. So seg.p_i is on boundary or interior.
      -- seg.p_i on HP2 boundary, HP1 interior, HP3 not-exterior → seg.p_i on HPI boundary
      -- → contradicts h_p_not_bnd
      have h_tp1_neg : tp1 < 0 := by
        by_contra h_nn; push_neg at h_nn
        apply h_p1_not_bnd; rw [h_bnd]
        exact Set.mem_union_right _ ⟨tp1, h_nn, htp1x, htp1y⟩
      have h_tp2_neg : tp2 < 0 := by
        by_contra h_nn; push_neg at h_nn
        apply h_p2_not_bnd; rw [h_bnd]
        exact Set.mem_union_right _ ⟨tp2, h_nn, htp2x, htp2y⟩
      -- q1 on r2 at parameter t > 0 → (q1 - O1) · n3 = t * κ + 0 > 0
      -- But from segment: (q1 - O1) · n3 = (1-s)*tp1*κ + s*tp2*κ < 0 (since tp1, tp2 < 0)
      obtain ⟨s, hs0, hs1, hsx, hsy⟩ := hq1_seg
      have h_dot3_q1 : (q1.x - O1.x) * n3.x + (q1.y - O1.y) * n3.y = t * κ := by
        have hx : q1.x - O1.x = t * d.x + delta.x := by
