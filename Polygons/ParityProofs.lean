      -- (seg.p_i - O1) · n3 = (tp_i * d + delta) · n3 = tp_i * κ + 0 = tp_i * κ + delta · n3
      -- Wait: seg.p1 - O1 = (seg.p1 - O2) + (O2 - O1) = tp1 * d + delta
      have h_dot3_p1 : (seg.p1.x - O1.x) * n3.x + (seg.p1.y - O1.y) * n3.y = tp1 * κ := by
        have hx : seg.p1.x - O1.x = tp1 * d.x + delta.x := by
