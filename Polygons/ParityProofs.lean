        (seg.toSet ∩ r1.toSet) ∪ (seg.toSet ∩ (LineSegment.mk O1 O2).toSet) ∪
        (seg.toSet ∩ r2.toSet) from rfl]
    rw [h_mid, Set.union_empty]
  -- seg ∩ r1 and seg ∩ r2 are each subsingleton
  -- (same argument as nc_hpi_total_eq, using HP1/HP2 as the containing half-plane)
  have h_seg_r1_sub : ∀ seg ∈ poly.segments, (seg.toSet ∩ r1.toSet).Subsingleton := by
    intro seg hseg
    have hp1_vert := seg_p1_mem_vertices poly seg hseg
    have hp2_vert := seg_p2_mem_vertices poly seg hseg
    have h_p1_not_bnd : seg.p1 ∉ hpi.toBoundarySet := h_vert seg.p1 hp1_vert
    have h_p2_not_bnd : seg.p2 ∉ hpi.toBoundarySet := h_vert seg.p2 hp2_vert
    -- r1 ⊆ hp1.toBoundarySet
    have h_r1_bnd : r1.toSet ⊆ hp1.toBoundarySet := by
      intro q ⟨t, _, htx, hty⟩
      show (q.x - O1.x) * n1.x + (q.y - O1.y) * n1.y = 0
      rw [show q.x - O1.x = t * d.x from by linarith,
          show q.y - O1.y = t * d.y from by linarith]
      linarith [h_d_n1 t]
    by_cases h_nd1 : hp1.dot seg.p1 ≠ 0 ∨ hp1.dot seg.p2 ≠ 0
    · intro a ha b hb
      exact hp1.boundary_segment_subsingleton seg h_nd1
        ⟨ha.1, h_r1_bnd ha.2⟩ ⟨hb.1, h_r1_bnd hb.2⟩
    · push_neg at h_nd1
      -- Both endpoints on hp1 boundary → they're on the line through O1 with direction d
      -- But endpoints not on hpi boundary → they must be exterior to HP2 or HP3
      -- Show: if any point of seg is on r1, derive contradiction
      intro q1 ⟨hq1_seg, hq1_r1⟩ q2 _; exfalso
      obtain ⟨t, ht, htx, hty⟩ := hq1_r1
      have h_tpos : 0 < t := by
        rcases eq_or_lt_of_le ht with rfl | h
        · exfalso; apply h_O1_avoids seg hseg
          simp only [zero_mul, add_zero] at htx hty
          rw [show q1 = O1 from (Vector2D.mk.injEq _ _ _ _).mpr ⟨htx, hty⟩] at hq1_seg
