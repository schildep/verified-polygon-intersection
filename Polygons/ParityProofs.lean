        calc (q1.x - O1.x) * n3.x + (q1.y - O1.y) * n3.y
            = (t * d.x) * n3.x + (t * d.y) * n3.y := by
              rw [show q1.x - O1.x = t * d.x from by linarith,
                  show q1.y - O1.y = t * d.y from by linarith]
          _ = t * (d.x * n3.x + d.y * n3.y) := by ring
          _ = t * κ := by rw [h_d_n3]
