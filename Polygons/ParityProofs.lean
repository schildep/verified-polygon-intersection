                ((-delta.x) * n2.x + (-delta.y) * n2.y) := by
              rw [show q.x - O2.x = t * d.x + (-delta.x) from by
                    simp only [delta]; linarith [htx],
                  show q.y - O2.y = t * d.y + (-delta.y) from by
                    simp only [delta]; linarith [hty]]
              ring
            rw [this, h_d_n2 t, h_neg_delta_n2] at h_neg; simp at h_neg; linarith [hκ_pos]
