        calc (q1.x - O1.x) * n3.x + (q1.y - O1.y) * n3.y
            = (1 - s) * ((seg.p1.x - O1.x) * n3.x + (seg.p1.y - O1.y) * n3.y) +
              s * ((seg.p2.x - O1.x) * n3.x + (seg.p2.y - O1.y) * n3.y) := by
                rw [show q1.x - O1.x = (1 - s) * (seg.p1.x - O1.x) + s * (seg.p2.x - O1.x) from by linarith,
                    show q1.y - O1.y = (1 - s) * (seg.p1.y - O1.y) + s * (seg.p2.y - O1.y) from by linarith]
                ring
          _ = (1 - s) * (tp1 * κ) + s * (tp2 * κ) := by rw [h_dot3_p1, h_dot3_p2]
      have h_eq : t * κ = (1 - s) * (tp1 * κ) + s * (tp2 * κ) := by
        linarith [h_dot3_q1, h_dot3_seg]
      have h_lhs_pos : t * κ > 0 := mul_pos h_tpos hκ_pos
      have h_tp1k_neg : tp1 * κ < 0 := mul_neg_of_neg_of_pos h_tp1_neg hκ_pos
      have h_tp2k_neg : tp2 * κ < 0 := mul_neg_of_neg_of_pos h_tp2_neg hκ_pos
      have h1s_nn : (1 : ℚ) - s ≥ 0 := by linarith
      have h_term1 : (1 - s) * (tp1 * κ) ≤ 0 := by nlinarith
      have h_term2 : s * (tp2 * κ) ≤ 0 := by nlinarith
      linarith
  -- Disjointness: no segment point is on both rays
  have h_disjoint : ∀ seg ∈ poly.segments, ∀ q, q ∈ seg.toSet → q ∈ r1.toSet → q ∈ r2.toSet → False := by
    intro seg hseg q hq_seg hq_r1 hq_r2
    obtain ⟨t1, ht1, ht1x, ht1y⟩ := hq_r1
    obtain ⟨t2, ht2, ht2x, ht2y⟩ := hq_r2
    -- O1 + t1*d = O2 + t2*d → (t1-t2)*d = O2 - O1 = delta
    have heqx : (t1 - t2) * d.x = delta.x := by simp [delta]; linarith
    have heqy : (t1 - t2) * d.y = delta.y := by simp [delta]; linarith
    -- cross d delta = d.x * delta.y - d.y * delta.x = d.x * (t1-t2)*d.y - d.y * (t1-t2)*d.x = 0
    have : cross d delta = 0 := by
      unfold cross
      have : d.x * delta.y - d.y * delta.x =
          d.x * ((t1 - t2) * d.y) - d.y * ((t1 - t2) * d.x) := by
        rw [← heqy, ← heqx]
      rw [this]; ring
    exact h_nc this
  -- Per-segment: segCrossingCount = decide_r1 + decide_r2
  suffices h_per : ∀ seg ∈ poly.segments,
      segCrossingCount seg hpi =
        (if decide (rayIntersectsSegment r1 seg) then 1 else 0) +
        (if decide (rayIntersectsSegment r2 seg) then 1 else 0) by
    have h_map : (poly.segments.map fun seg => segCrossingCount seg hpi) =
        poly.segments.map fun seg =>
          (if decide (rayIntersectsSegment r1 seg) then 1 else 0) +
          (if decide (rayIntersectsSegment r2 seg) then 1 else 0) :=
      List.map_congr_left h_per
    rw [h_map, sum_map_add] at h_even
    unfold intersectionRayPolygonSegmentsNumber
    rw [countP_eq_map_sum, countP_eq_map_sum]
    obtain ⟨k, hk⟩ := h_even
    omega
  -- Prove per-segment result
  intro seg hseg
  have hp1_vert := seg_p1_mem_vertices poly seg hseg
  have hp2_vert := seg_p2_mem_vertices poly seg hseg
  have h_p1_not_bnd : seg.p1 ∉ hpi.toBoundarySet := h_vert seg.p1 hp1_vert
  have h_p2_not_bnd : seg.p2 ∉ hpi.toBoundarySet := h_vert seg.p2 hp2_vert
  have h_seg_av_vert := h_seg_av seg hseg
  have h_fin : (seg.boundaryCrossings hpi).Finite :=
    HalfPlaneIntersection.boundaryCrossings_finite hpi seg h_p1_not_bnd h_p2_not_bnd h_seg_av_vert
  have h_cc : segCrossingCount seg hpi = h_fin.toFinset.card := by
    simp [segCrossingCount, dif_pos h_fin]
  have h_cross_eq := h_cross_union seg hseg
  have h_fin_r1 : (seg.toSet ∩ r1.toSet).Finite := (h_seg_r1_sub seg hseg).finite
  have h_fin_r2 : (seg.toSet ∩ r2.toSet).Finite := (h_seg_r2_sub seg hseg).finite
  have h_disj : Disjoint h_fin_r1.toFinset h_fin_r2.toFinset := by
    rw [Finset.disjoint_left]; intro q hq1 hq2
    exact h_disjoint seg hseg q (h_fin_r1.mem_toFinset.mp hq1).1
      (h_fin_r1.mem_toFinset.mp hq1).2 (h_fin_r2.mem_toFinset.mp hq2).2
  have h_tofinset : h_fin.toFinset = h_fin_r1.toFinset ∪ h_fin_r2.toFinset := by
    ext q; simp only [Set.Finite.mem_toFinset, Finset.mem_union, h_cross_eq, Set.mem_union]
  rw [h_cc, h_tofinset, Finset.card_union_of_disjoint h_disj]
  congr 1
  · by_cases hr1 : rayIntersectsSegment r1 seg
    · rw [if_pos (decide_eq_true hr1)]
      have h_ne : (seg.toSet ∩ r1.toSet).Nonempty := by
        obtain ⟨q, hq1, hq2⟩ := hr1; exact ⟨q, hq2, hq1⟩
      have := subsingleton_card _ h_fin_r1 (h_seg_r1_sub seg hseg)
      have := nonempty_card _ h_fin_r1 h_ne
      omega
    · have hd1 : ¬(decide (rayIntersectsSegment r1 seg) = true) :=
        fun h => hr1 (of_decide_eq_true h)
      rw [if_neg hd1, Finset.card_eq_zero, Finset.eq_empty_iff_forall_not_mem]
      intro q hq
      exact hr1 ⟨q, (h_fin_r1.mem_toFinset.mp hq).2, (h_fin_r1.mem_toFinset.mp hq).1⟩
  · by_cases hr2 : rayIntersectsSegment r2 seg
    · rw [if_pos (decide_eq_true hr2)]
      have h_ne : (seg.toSet ∩ r2.toSet).Nonempty := by
        obtain ⟨q, hq1, hq2⟩ := hr2; exact ⟨q, hq2, hq1⟩
      have := subsingleton_card _ h_fin_r2 (h_seg_r2_sub seg hseg)
      have := nonempty_card _ h_fin_r2 h_ne
      omega
    · have hd2 : ¬(decide (rayIntersectsSegment r2 seg) = true) :=
        fun h => hr2 (of_decide_eq_true h)
      rw [if_neg hd2, Finset.card_eq_zero, Finset.eq_empty_iff_forall_not_mem]
      intro q hq
      exact hr2 ⟨q, (h_fin_r2.mem_toFinset.mp hq).2, (h_fin_r2.mem_toFinset.mp hq).1⟩

/-- Polygon with no segments has zero intersection count. -/
private lemma no_segments_zero_count (r : Ray) (poly : Polygon)
    (h : poly.segments = []) :
    intersectionRayPolygonSegmentsNumber r poly = 0 := by
  unfold intersectionRayPolygonSegmentsNumber
  rw [h]; simp

theorem intersectionParity_eq_of_originSegmentAvoidsSegments
    (r1 r2 : Ray) (poly : Polygon)
    (h_r1_avoids : rayAvoidsVertices r1 poly)
    (h_r2_avoids : rayAvoidsVertices r2 poly)
    (h_origin_segment_avoids : ∀ seg ∈ poly.segments,
      segmentDoesNotIntersectSegment ⟨r1.origin, r2.origin⟩ seg) :
    (intersectionRayPolygonSegmentsNumber r1 poly) % 2 =
    (intersectionRayPolygonSegmentsNumber r2 poly) % 2 := by
  set O1 := r1.origin
  set O2 := r2.origin
  -- Derive: O1 and O2 avoid all polygon segments
  have h_O1_avoids : ∀ seg ∈ poly.segments, pointAvoidsSegment O1 seg := by
    intro seg hseg
    exact (endpoint_avoids_of_segmentDoesNotIntersect O1 O2 seg (h_origin_segment_avoids seg hseg)).1
  have h_O2_avoids : ∀ seg ∈ poly.segments, pointAvoidsSegment O2 seg := by
    intro seg hseg
    exact (endpoint_avoids_of_segmentDoesNotIntersect O1 O2 seg (h_origin_segment_avoids seg hseg)).2
  by_cases h_eq : O1 = O2
  · -- Case 1: Same origin
    have h_same_origin : sameOrigin r1 r2 := h_eq
    exact intersectionParity_eq_of_sameOrigin_avoidsVertices r1 r2 poly
      h_same_origin h_r1_avoids h_r2_avoids
      (fun seg hseg => by rw [show r1.origin = O1 from rfl]; exact h_O1_avoids seg hseg)
  · -- Case 2: Different origins
    -- If polygon has no segments, both counts are 0
    by_cases h_segs : poly.segments = []
    · rw [no_segments_zero_count r1 poly h_segs, no_segments_zero_count r2 poly h_segs]
    · -- Polygon has segments. Every vertex is on some segment.
      -- So every vertex avoids the segment O1→O2.
      have h_vert_avoids_seg : ∀ v ∈ poly.vertices, v ∉ (LineSegment.mk O1 O2).toSet := by
        intro v hv hv_seg
        obtain ⟨seg, hseg, hv_on_seg⟩ := vertex_on_some_segment poly v hv h_segs
        have h_disj := h_origin_segment_avoids seg hseg
        unfold segmentDoesNotIntersectSegment at h_disj
        have : v ∈ (LineSegment.mk O1 O2).toSet ∩ seg.toSet := ⟨hv_seg, hv_on_seg⟩
        rw [h_disj] at this; exact this
      -- Every vertex avoids O1 and O2 (they're not on any segment, hence not vertices)
      have h_v_ne_O1 : ∀ v ∈ poly.vertices, v ≠ O1 := by
        intro v hv hveq
        obtain ⟨seg, hseg, hv_on_seg⟩ := vertex_on_some_segment poly v hv h_segs
        exact (h_O1_avoids seg hseg) (hveq ▸ hv_on_seg)
      have h_v_ne_O2 : ∀ v ∈ poly.vertices, v ≠ O2 := by
        intro v hv hveq
        obtain ⟨seg, hseg, hv_on_seg⟩ := vertex_on_some_segment poly v hv h_segs
        exact (h_O2_avoids seg hseg) (hveq ▸ hv_on_seg)
      -- Find a good direction d
      obtain ⟨d, hd_nz, h_nc, h_d_O1, h_d_O2⟩ :=
        exists_good_direction O1 O2 h_eq poly.vertices h_v_ne_O1 h_v_ne_O2
      -- Construct auxiliary rays
      set r1' : Ray := ⟨O1, d, hd_nz⟩
      set r2' : Ray := ⟨O2, d, hd_nz⟩
      -- r1' avoids all polygon vertices
      have h_r1'_avoids : rayAvoidsVertices r1' poly := by
        rw [rayAvoidsVertices]
        ext q; simp only [Set.mem_inter_iff, Set.mem_empty_iff_false, iff_false, not_and]
        intro hq_ray hq_vert
        exact cross_ne_zero_not_on_ray O1 d hd_nz q (h_d_O1 q hq_vert) hq_ray
      -- r2' avoids all polygon vertices
      have h_r2'_avoids : rayAvoidsVertices r2' poly := by
        rw [rayAvoidsVertices]
        ext q; simp only [Set.mem_inter_iff, Set.mem_empty_iff_false, iff_false, not_and]
        intro hq_ray hq_vert
        exact cross_ne_zero_not_on_ray O2 d hd_nz q (h_d_O2 q hq_vert) hq_ray
      -- r1 ≡ r1' (mod 2) by sameOrigin at O1
      have h_step1 : (intersectionRayPolygonSegmentsNumber r1 poly) % 2 =
          (intersectionRayPolygonSegmentsNumber r1' poly) % 2 :=
        intersectionParity_eq_of_sameOrigin_avoidsVertices r1 r1' poly
          (show sameOrigin r1 r1' from rfl)
          h_r1_avoids h_r1'_avoids h_O1_avoids
      -- r2 ≡ r2' (mod 2) by sameOrigin at O2
      have h_step2 : (intersectionRayPolygonSegmentsNumber r2 poly) % 2 =
          (intersectionRayPolygonSegmentsNumber r2' poly) % 2 :=
        intersectionParity_eq_of_sameOrigin_avoidsVertices r2 r2' poly
          (show sameOrigin r2 r2' from rfl)
          h_r2_avoids h_r2'_avoids h_O2_avoids
      -- r1' ≡ r2' (mod 2) by parallel_rays_same_parity
      have h_step3 : (intersectionRayPolygonSegmentsNumber r1' poly) % 2 =
          (intersectionRayPolygonSegmentsNumber r2' poly) % 2 :=
        parallel_rays_same_parity O1 O2 d hd_nz h_eq h_nc poly
          h_r1'_avoids h_r2'_avoids h_O1_avoids h_O2_avoids
          h_origin_segment_avoids h_vert_avoids_seg
      -- Chain: r1 ≡ r1' ≡ r2' ≡ r2 (mod 2)
      omega

end ParityProofs

