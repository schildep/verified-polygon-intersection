import Polygons.DataStructures

/-!
# Ray-segment intersection — computable layer

The boolean `rayIntersectsSegmentBool` and its three arithmetic helpers,
lifted out of `Polygons.RayIntersectionAlgorithmProofs` so the WASM build
can initialise this module alone.
-/

namespace RayIntersectionAlgorithmImpl

instance : Max Rat := maxOfLe
instance : Min Rat := minOfLe
instance : Ord Rat where
  compare a b := compareOfLessAndEq a b

/-- Determinant of the 2×2 system `r.origin + t·r.direction = (1-s)·seg.p1 + s·seg.p2`. -/
def raySegDet (r : Ray) (seg : LineSegment) : Rat :=
  r.direction.x * (seg.p1.y - seg.p2.y) - r.direction.y * (seg.p1.x - seg.p2.x)

/-- Numerator of the ray parameter `t`. -/
def raySegTNum (r : Ray) (seg : LineSegment) : Rat :=
  (seg.p1.x - r.origin.x) * (seg.p1.y - seg.p2.y)
    - (seg.p1.y - r.origin.y) * (seg.p1.x - seg.p2.x)

/-- Numerator of the segment parameter `s`. -/
def raySegSNum (r : Ray) (seg : LineSegment) : Rat :=
  r.direction.x * (seg.p1.y - r.origin.y) - r.direction.y * (seg.p1.x - r.origin.x)

/-- 1-D overlap test for a collinear ray and segment. -/
def collinearRaySegOverlap (r : Ray) (seg : LineSegment) : Bool :=
  if r.direction.x ≠ 0 then
    let t1 : Rat := (seg.p1.x - r.origin.x) / r.direction.x
    let t2 : Rat := (seg.p2.x - r.origin.x) / r.direction.x
    decide (max t1 t2 ≥ 0)
  else
    let t1 : Rat := (seg.p1.y - r.origin.y) / r.direction.y
    let t2 : Rat := (seg.p2.y - r.origin.y) / r.direction.y
    decide (max t1 t2 ≥ 0)

/-- Ray and segment lie on the same affine line. -/
def collinearRaySeg (r : Ray) (seg : LineSegment) : Bool :=
  decide (raySegTNum r seg = 0) && decide (raySegSNum r seg = 0)

/-- Computable Bool version of `rayIntersectsSegment`. -/
def rayIntersectsSegmentBool (r : Ray) (seg : LineSegment) : Bool :=
  let D := raySegDet r seg
  if D = 0 then
    collinearRaySeg r seg && collinearRaySegOverlap r seg
  else
    let tNum := raySegTNum r seg
    let sNum := raySegSNum r seg
    let tOk := decide (tNum * D ≥ 0)
    let sOk := decide (0 ≤ sNum * D) && decide (sNum * D ≤ D * D)
    tOk && sOk

end RayIntersectionAlgorithmImpl
