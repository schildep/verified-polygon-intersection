import Polygons.Polygon
import Polygons.EvenGraph
import Polygons.EvenGraphIntersection
import Polygons.EvenGraphDecomposition

/-!
# Polygon Intersection – Implementation

Proof that the intersection of the interiors of two polygons (with non-degenerate
segments and finite boundary intersection) can be expressed as the symmetric
difference of interiors of a list of polygons, minus the union of those
polygons' boundaries.

The argument:
1. Convert each polygon to an even graph via `Polygon.toEvenGraph`.
2. Form the intersection of the two even graphs via `evenGraphIntersection`,
   whose interior equals the intersection of the input interiors.
3. Decompose this even graph into polygon-derived even graphs via
   `EvenGraph.exists_polygon_decomposition`.
4. Apply `EvenGraph.combine_interior_eq_symmDiff_sdiff_boundary` to the
   decomposition and translate the per-component interiors and boundaries
   back to the underlying polygons.
-/

open Classical Set

noncomputable section

namespace PolygonIntersectionProofs

theorem exists_polygons_inter_interior_eq_symmDiffAll_interiors_sdiff_boundaries_impl
    (poly1 poly2 : Polygon)
    (h1_len : poly1.vertices.length ≥ 2)
    (h2_len : poly2.vertices.length ≥ 2)
    (h1_nondeg : ∀ seg ∈ poly1.segments, seg.p1 ≠ seg.p2)
    (h2_nondeg : ∀ seg ∈ poly2.segments, seg.p1 ≠ seg.p2)
    (h_fin : Set.Finite (poly1.toBoundarySet ∩ poly2.toBoundarySet)) :
    ∃ polys : List Polygon,
      poly1.interior ∩ poly2.interior =
        (polys.map Polygon.interior).symmDiffAll \
          { p : Vector2D | ∃ poly ∈ polys, p ∈ poly.toBoundarySet } := by
  set G1 : EvenGraph := poly1.toEvenGraph h1_len h1_nondeg with hG1_def
  set G2 : EvenGraph := poly2.toEvenGraph h2_len h2_nondeg with hG2_def
  have hb1 : G1.toBoundarySet = poly1.toBoundarySet :=
    Polygon.toEvenGraph_boundary_eq poly1 h1_len h1_nondeg
  have hb2 : G2.toBoundarySet = poly2.toBoundarySet :=
    Polygon.toEvenGraph_boundary_eq poly2 h2_len h2_nondeg
  have hi1 : G1.interior = poly1.interior :=
    Polygon.toEvenGraph_interior_eq poly1 h1_len h1_nondeg
  have hi2 : G2.interior = poly2.interior :=
    Polygon.toEvenGraph_interior_eq poly2 h2_len h2_nondeg
  have h_fin12 : Set.Finite (G1.toBoundarySet ∩ G2.toBoundarySet) := by
    rw [hb1, hb2]; exact h_fin
  obtain ⟨h_even, h_interior_eq⟩ :=
    evenGraphIntersection_isEven_and_interior_eq G1 G2 h_fin12
  set Gint : EvenGraph :=
    ⟨evenGraphIntersection G1 G2 h_fin12, h_even⟩ with hGint_def
  have hGint_int : Gint.interior = poly1.interior ∩ poly2.interior := by
    rw [h_interior_eq, hi1, hi2]
  obtain ⟨polyGraphs, h_polyGraphs, h_equiv⟩ :=
    EvenGraph.exists_polygon_decomposition Gint
  let polyOf : EvenGraph → Polygon := fun pG =>
    if h : pG ∈ polyGraphs then (h_polyGraphs pG h).choose else ⟨[]⟩
  have polyOf_mem : ∀ pG (hmem : pG ∈ polyGraphs),
      polyOf pG = (h_polyGraphs pG hmem).choose := by
    intro pG hmem
    show (if h : pG ∈ polyGraphs then (h_polyGraphs pG h).choose else ⟨[]⟩) = _
    rw [dif_pos hmem]
  have h_each_int : ∀ pG ∈ polyGraphs, (polyOf pG).interior = pG.interior := by
    intro pG hmem
    obtain ⟨h_len, h_distinct, hpG_eq⟩ := (h_polyGraphs pG hmem).choose_spec
    calc (polyOf pG).interior
        = (h_polyGraphs pG hmem).choose.interior := by rw [polyOf_mem pG hmem]
      _ = ((h_polyGraphs pG hmem).choose.toEvenGraph h_len h_distinct).interior :=
          (Polygon.toEvenGraph_interior_eq _ h_len h_distinct).symm
      _ = pG.interior := congrArg EvenGraph.interior hpG_eq.symm
  have h_each_bd : ∀ pG ∈ polyGraphs, (polyOf pG).toBoundarySet = pG.toBoundarySet := by
    intro pG hmem
    obtain ⟨h_len, h_distinct, hpG_eq⟩ := (h_polyGraphs pG hmem).choose_spec
    calc (polyOf pG).toBoundarySet
        = (h_polyGraphs pG hmem).choose.toBoundarySet := by rw [polyOf_mem pG hmem]
      _ = ((h_polyGraphs pG hmem).choose.toEvenGraph h_len h_distinct).toBoundarySet :=
          (Polygon.toEvenGraph_boundary_eq _ h_len h_distinct).symm
      _ = pG.toBoundarySet := congrArg (fun G : EvenGraph => G.toBoundarySet) hpG_eq.symm
  let polys : List Polygon := polyGraphs.map polyOf
  refine ⟨polys, ?_⟩
  have h_map_int :
      polys.map Polygon.interior = polyGraphs.map EvenGraph.interior := by
    show (polyGraphs.map polyOf).map Polygon.interior = polyGraphs.map EvenGraph.interior
    rw [List.map_map]
    refine List.map_congr_left ?_
    intro pG hmem
    exact h_each_int pG hmem
  have h_bd_set :
      { p : Vector2D | ∃ poly ∈ polys, p ∈ poly.toBoundarySet } =
      (EvenGraph.combine polyGraphs).toBoundarySet := by
    rw [EvenGraph.combine_toBoundarySet]
    ext p
    constructor
    · rintro ⟨poly, hpoly_mem, hp_in⟩
      change poly ∈ polyGraphs.map polyOf at hpoly_mem
      rw [List.mem_map] at hpoly_mem
      obtain ⟨pG, hpG_mem, hpG_eq⟩ := hpoly_mem
      simp only [Set.mem_iUnion]
      refine ⟨pG, hpG_mem, ?_⟩
      rw [← h_each_bd pG hpG_mem, hpG_eq]
      exact hp_in
    · intro hp
      simp only [Set.mem_iUnion] at hp
      obtain ⟨pG, hmem, hp_in⟩ := hp
      refine ⟨polyOf pG, ?_, ?_⟩
      · change polyOf pG ∈ polyGraphs.map polyOf
        rw [List.mem_map]
        exact ⟨pG, hmem, rfl⟩
      · rw [h_each_bd pG hmem]
        exact hp_in
  rw [← hGint_int, h_equiv.interior_eq,
      EvenGraph.combine_interior_eq_symmDiff_sdiff_boundary,
      ← h_bd_set, ← h_map_int]

end PolygonIntersectionProofs

